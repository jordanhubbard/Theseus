spec: asyncio_extra158
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers: asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.BoundedSemaphore, and asyncio.Condition class identity. asyncio.Lock.__name__=='Lock' (len=4); asyncio.Lock.__module__=='asyncio.locks' (len=12; defined in Lib/asyncio/locks.py — NOT the top-level 'asyncio' module); asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' (Lock inherits from _ContextManagerMixin, not object directly); asyncio.Event.__name__=='Event' (len=5); asyncio.Event.__module__=='asyncio.locks' (len=12; same submodule as Lock); asyncio.Semaphore.__name__=='Semaphore' (len=9); asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore inherits from Semaphore); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (Condition also inherits from _ContextManagerMixin like Lock). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Lock.__module__=='asyncio.locks' (len=12: 'asyncio'=7+'.'=1+'locks'=5=13... wait: len('asyncio.locks')='a'+'s'+'y'+'n'+'c'+'i'+'o'=7+'.'=1+'l'+'o'+'c'+'k'+'s'=5=13); len('asyncio.locks')==13; verified with Python 3.14.3. All asyncio synchronization primitives (Lock, Event, Semaphore, BoundedSemaphore, Condition) are defined in Lib/asyncio/locks.py and have __module__=='asyncio.locks'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' — asyncio.Lock (and asyncio.Condition) inherit from _ContextManagerMixin, the private mixin class defined in Lib/asyncio/locks.py that implements the async context manager protocol (__aenter__ and __aexit__); _ContextManagerMixin is NOT object; this is different from asyncio.StreamReader and asyncio.StreamWriter which inherit directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' — BoundedSemaphore inherits from Semaphore (not from object or _ContextManagerMixin directly); BoundedSemaphore adds the constraint that the semaphore value cannot exceed the initial value. asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' like Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Lock class identity — extra158
#
# asyncio.Lock.__name__.__eq__('Lock')                               == True
# asyncio.Lock.__module__.__eq__('asyncio.locks')                    == True
# asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin')  == True
# ---------------------------------------------------------------------------

table asyncio_extra158.asyncio_lock_identity:
  description: "asyncio.Lock class identity checks in asynciolock158 namespace — asyncio.Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4; the asyncio mutual-exclusion lock primitive for coroutine-safe access to shared resources); asyncio.Lock.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13; defined in Lib/asyncio/locks.py — NOT the top-level asyncio module); asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' (Lock inherits from _ContextManagerMixin, the private async context manager mixin, NOT from object directly; _ContextManagerMixin provides __aenter__ and __aexit__ for use with async with); asyncio.Lock.__name__.__len__()==4 (shortest lock primitive name); compare: asyncio.Event.__name__.__len__()==5 and asyncio.Semaphore.__name__.__len__()==9; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolock158

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,   asyncio.Lock.__name__.__eq__,                             ["Lock"],                true,  "asyncio.Lock.__name__ == 'Lock' (len=4; asyncio mutual-exclusion lock); verified with Python 3.14.3"]
    - [lock_mod_eq,    asyncio.Lock.__module__.__eq__,                            ["asyncio.locks"],       true,  "asyncio.Lock.__module__ == 'asyncio.locks' (len=13; defined in Lib/asyncio/locks.py); verified with Python 3.14.3"]
    - [lock_base_eq,   "asyncio.Lock.__bases__[0].__name__.__eq__",               ["_ContextManagerMixin"], true, "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin' (inherits from async context manager mixin, not object); verified with Python 3.14.3"]
    - [lock_name_len,  asyncio.Lock.__name__.__len__,                             [],                      4,     "asyncio.Lock.__name__.__len__() == 4 ('Lock'; shortest asyncio lock primitive name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Event class identity — extra158
#
# asyncio.Event.__name__.__eq__('Event')           == True
# asyncio.Event.__module__.__eq__('asyncio.locks') == True
# ---------------------------------------------------------------------------

table asyncio_extra158.asyncio_event_identity:
  description: "asyncio.Event class identity checks in asyncioevent158 namespace — asyncio.Event.__name__=='Event' (len=5: 'E'+'v'+'e'+'n'+'t'=5; the asyncio event synchronization primitive — a one-time signal that multiple coroutines can wait for); asyncio.Event.__module__=='asyncio.locks' (len=13; same submodule as Lock — all asyncio sync primitives are in Lib/asyncio/locks.py); asyncio.Event.__name__.__len__()==5 (one char longer than Lock=4; one char shorter than Condition has the same module); Event provides set(), clear(), is_set(), and wait() coroutine; wait() blocks until set() is called; Event can be used to coordinate multiple coroutines with a single signal; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioevent158

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,   asyncio.Event.__name__.__eq__,    ["Event"],          true,  "asyncio.Event.__name__ == 'Event' (len=5; asyncio one-time signal primitive); verified with Python 3.14.3"]
    - [event_mod_eq,    asyncio.Event.__module__.__eq__,  ["asyncio.locks"],  true,  "asyncio.Event.__module__ == 'asyncio.locks' (len=13; same module as Lock, Semaphore, Condition); verified with Python 3.14.3"]
    - [event_name_len,  asyncio.Event.__name__.__len__,   [],                 5,     "asyncio.Event.__name__.__len__() == 5 ('Event'); verified with Python 3.14.3"]
    - [lock_mod_len,    asyncio.Lock.__module__.__len__,  [],                 13,    "asyncio.Lock.__module__.__len__() == 13 ('asyncio.locks'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore and asyncio.BoundedSemaphore class identity — extra158
#
# asyncio.Semaphore.__name__.__eq__('Semaphore')                              == True
# asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore')          == True
# asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')      == True
# ---------------------------------------------------------------------------

table asyncio_extra158.asyncio_semaphore_condition_identity:
  description: "asyncio.Semaphore, BoundedSemaphore, and Condition class identity checks in asynciosem158 namespace — asyncio.Semaphore.__name__=='Semaphore' (len=9: 'Semaphore'=9; the asyncio counting semaphore that allows up to N concurrent acquisitions); asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore inherits from Semaphore — it adds the constraint that release() raises ValueError if the internal counter exceeds the initial value); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (Condition inherits from _ContextManagerMixin like Lock — both use the async context manager mixin for async with support); BoundedSemaphore does not inherit from _ContextManagerMixin directly — it gets that via Semaphore; Condition.__bases__[0].__name__=='_ContextManagerMixin' confirms Condition is NOT a subclass of Lock despite similar behavior; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosem158

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,     asyncio.Semaphore.__name__.__eq__,                          ["Semaphore"],           true,  "asyncio.Semaphore.__name__ == 'Semaphore' (len=9; asyncio counting semaphore); verified with Python 3.14.3"]
    - [bsem_base_eq,    "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__",    ["Semaphore"],           true,  "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (BoundedSemaphore inherits from Semaphore); verified with Python 3.14.3"]
    - [cond_base_eq,    "asyncio.Condition.__bases__[0].__name__.__eq__",           ["_ContextManagerMixin"], true, "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin' (same base as Lock); verified with Python 3.14.3"]
    - [sem_name_len,    asyncio.Semaphore.__name__.__len__,                         [],                      9,     "asyncio.Semaphore.__name__.__len__() == 9 ('Semaphore'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra158
# ---------------------------------------------------------------------------

invariant asyncio_extra158.asyncio_Lock_name_eq:
  description: "asyncio.Lock.__name__.__eq__('Lock') returns True — asyncio.Lock is the asyncio mutual-exclusion lock; Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4; the shortest asyncio synchronization primitive name); asyncio.Lock provides an async context manager for protecting shared resources in coroutines: async with lock: ...; Lock.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13; defined in Lib/asyncio/locks.py); Lock.__bases__[0].__name__=='_ContextManagerMixin' (Lock inherits from _ContextManagerMixin, NOT object — the mixin provides __aenter__/__aexit__ for async with); compare: asyncio.Event.__name__.__len__()==5 (1 longer), asyncio.Semaphore.__name__.__len__()==9 (5 longer); Lock(4) is the shortest primitive name; NEW in extra158: first standalone asyncio.Lock.__name__ identity invariant in asynciolock158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra158.asyncio_Lock_module_eq:
  description: "asyncio.Lock.__module__.__eq__('asyncio.locks') returns True — asyncio.Lock is defined in Lib/asyncio/locks.py; its __module__ is 'asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); this is NOT the top-level 'asyncio' module — all asyncio synchronization primitives (Lock, Event, Semaphore, BoundedSemaphore, Condition) live in the asyncio.locks submodule; compare: asyncio.StreamReader.__module__=='asyncio.streams' (len=15; 2 chars longer because 'streams'=7 > 'locks'=5); asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14; 1 char longer); asyncio.locks (len=13) has the shortest submodule name among the asyncio submodules covered in the spec series; NEW in extra158: first standalone asyncio.Lock.__module__ identity invariant in asynciolock158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra158.asyncio_Lock_base_is_ContextManagerMixin:
  description: "asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — asyncio.Lock inherits from _ContextManagerMixin (the private async context manager mixin defined in Lib/asyncio/locks.py); __bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'ContextManagerMixin'=19=20; '_ContextManagerMixin' begins with underscore indicating it is private/internal); this is different from asyncio.StreamReader.__bases__[0].__name__=='object' — Lock does NOT inherit directly from object; _ContextManagerMixin provides __aenter__ (acquires the lock and returns self) and __aexit__ (releases the lock) enabling async with lock: ...; both asyncio.Lock and asyncio.Condition share _ContextManagerMixin as their first base; NEW in extra158: first standalone asyncio.Lock.__bases__[0].__name__ identity invariant in asynciolock158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Lock.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra158.asyncio_Event_module_eq:
  description: "asyncio.Event.__module__.__eq__('asyncio.locks') returns True — asyncio.Event is defined in Lib/asyncio/locks.py along with all other asyncio synchronization primitives; Event.__module__=='asyncio.locks' (len=13); asyncio.Event is a one-time coroutine signaling primitive: coroutines call wait() to block until another coroutine calls set(); Event can be cleared and reused via clear(); Event.__name__=='Event' (len=5); Event.__module__=='asyncio.locks' confirms it is in the same submodule as Lock, Semaphore, and Condition (NOT in a separate events submodule); NEW in extra158: first standalone asyncio.Event.__module__ identity invariant in asyncioevent158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra158.asyncio_BoundedSemaphore_base_is_Semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — asyncio.BoundedSemaphore inherits from asyncio.Semaphore; __bases__[0].__name__=='Semaphore' (len=9); BoundedSemaphore is a Semaphore that raises ValueError if release() is called more times than acquire(), preventing the internal counter from exceeding the initial value; because BoundedSemaphore inherits from Semaphore (not from _ContextManagerMixin directly), it gets async context manager support via the MRO chain; compare: asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' vs asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' — the two have different inheritance patterns; NEW in extra158: first standalone asyncio.BoundedSemaphore.__bases__[0].__name__ identity invariant in asynciosem158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

