spec: dataclasses_extra6
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends prior dataclasses specs."
    - "Focus: dataclasses helper functions and field configuration."
    - "dataclasses.fields(dataclasses.make_dataclass('Foo', ['x', 'y'])) returns a tuple of 2 Field objects."
    - "dataclasses.make_dataclass.__name__ == 'make_dataclass'."
    - "dataclasses.replace.__name__ == 'replace'."
    - "dataclasses.asdict.__name__ == 'asdict'."
    - "dataclasses.astuple.__name__ == 'astuple'."
    - "dataclasses.field(default=1).default == 1."
    - "dataclasses.field(default_factory=list).default_factory == list."
    - "dataclasses.field().repr == True (default)."
    - "dataclasses.field().init == True (default)."
    - "dataclasses.field().compare == True (default)."
    - "dataclasses.field().hash is None (default)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table dataclasses_extra6.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [make_dataclass, make_dataclass.__name__.__eq__, ["make_dataclass"], true]
    - [replace,        replace.__name__.__eq__,        ["replace"],        true]
    - [asdict,         asdict.__name__.__eq__,         ["asdict"],         true]
    - [astuple,        astuple.__name__.__eq__,        ["astuple"],        true]
    - [fields,         fields.__name__.__eq__,         ["fields"],         true]
    - [is_dataclass,   is_dataclass.__name__.__eq__,   ["is_dataclass"],   true]

invariant dataclasses_extra6.field.repr_default:
  description: "dataclasses.field().repr == True"
  category: field_defaults
  kind: python_call_eq
  function: field
  args: []
  method: repr.__eq__
  method_args: [true]
  expected: true

invariant dataclasses_extra6.field.init_default:
  description: "dataclasses.field().init == True"
  category: field_defaults
  kind: python_call_eq
  function: field
  args: []
  method: init.__eq__
  method_args: [true]
  expected: true

invariant dataclasses_extra6.field.compare_default:
  description: "dataclasses.field().compare == True"
  category: field_defaults
  kind: python_call_eq
  function: field
  args: []
  method: compare.__eq__
  method_args: [true]
  expected: true

invariant dataclasses_extra6.field.name_attr_class:
  description: "dataclasses.field().__class__.__name__ == 'Field'"
  category: field_defaults
  kind: python_call_eq
  function: field
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Field"]
  expected: true

invariant dataclasses_extra6.Field.class_name:
  description: "dataclasses.Field.__name__ == 'Field'"
  category: class_names
  kind: python_call_eq
  function: Field.__name__.__eq__
  args: ["Field"]
  expected: true

invariant dataclasses_extra6.Field.module:
  description: "dataclasses.Field.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: Field.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra6.make_dataclass.module:
  description: "dataclasses.make_dataclass.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: make_dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra6.replace.module:
  description: "dataclasses.replace.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: replace.__module__.__eq__
  args: ["dataclasses"]
  expected: true
