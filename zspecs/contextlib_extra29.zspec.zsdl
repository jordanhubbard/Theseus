spec: contextlib_extra29
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib_extra28.zspec.zsdl."
    - "Prior specs covered: contextmanager/asynccontextmanager/closing/suppress/redirect_stdout/redirect_stderr/ExitStack/AsyncExitStack/nullcontext/__name__/__module__/__qualname__, closing/nullcontext/redirect_stdout bases, ContextDecorator/__name__/__module__/__qualname__, AbstractContextManager/__name__/__module__, AbstractAsyncContextManager/__name__, ExitStack/AsyncExitStack bases, chdir/__name__, class_modules table, decorator_modules table."
    - "This spec covers: __module__.__len__() for contextmanager/asynccontextmanager/closing/suppress/ExitStack (all 'contextlib', length 10), __name__.__len__() for contextmanager/asynccontextmanager/closing/suppress/ExitStack/nullcontext/redirect_stdout."
    - "contextlib.contextmanager.__module__.__len__() == 10 — 'contextlib' has length 10."
    - "contextlib.asynccontextmanager.__module__.__len__() == 10 — 'contextlib' has length 10."
    - "contextlib.closing.__module__.__len__() == 10 — 'contextlib' has length 10."
    - "contextlib.suppress.__module__.__len__() == 10 — 'contextlib' has length 10."
    - "contextlib.ExitStack.__module__.__len__() == 10 — 'contextlib' has length 10."
    - "contextlib.contextmanager.__name__.__len__() == 14 — 'contextmanager' has length 14."
    - "contextlib.asynccontextmanager.__name__.__len__() == 19 — 'asynccontextmanager' has length 19."
    - "contextlib.closing.__name__.__len__() == 7 — 'closing' has length 7."
    - "contextlib.suppress.__name__.__len__() == 8 — 'suppress' has length 8."
    - "contextlib.ExitStack.__name__.__len__() == 9 — 'ExitStack' has length 9."
    - "contextlib.nullcontext.__name__.__len__() == 11 — 'nullcontext' has length 11."
    - "contextlib.redirect_stdout.__name__.__len__() == 15 — 'redirect_stdout' has length 15."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() combined table for contextlib symbols (extra29 namespace)
#
# contextmanager/asynccontextmanager/closing/suppress/ExitStack all have
# __module__ == 'contextlib' (length 10). Prior specs record the __module__
# string values in contextlib_extra28; this table exercises the string
# __len__ call path for the first time across these five symbols.
# ---------------------------------------------------------------------------

table contextlib_extra29.module_lens:
  description: "__module__.__len__() for contextlib symbols — all have module 'contextlib' (length 10)"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,      contextmanager.__module__.__len__,      [], 10]
    - [asynccontextmanager, asynccontextmanager.__module__.__len__, [], 10]
    - [closing,             closing.__module__.__len__,             [], 10]
    - [suppress,            suppress.__module__.__len__,            [], 10]
    - [ExitStack,           ExitStack.__module__.__len__,           [], 10]

# ---------------------------------------------------------------------------
# __name__.__len__() combined table for contextlib symbols (extra29 namespace)
#
# Prior specs record __name__ strings but not their lengths. This table
# exercises the string __len__ call path for seven contextlib symbols:
#   'contextmanager' -> 14, 'asynccontextmanager' -> 19, 'closing' -> 7,
#   'suppress' -> 8, 'ExitStack' -> 9, 'nullcontext' -> 11,
#   'redirect_stdout' -> 15.
# ---------------------------------------------------------------------------

table contextlib_extra29.name_lens:
  description: "__name__.__len__() for contextlib symbols in the extra29 namespace"
  kind: python_call_eq
  category: name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,      contextmanager.__name__.__len__,      [], 14]
    - [asynccontextmanager, asynccontextmanager.__name__.__len__, [], 19]
    - [closing,             closing.__name__.__len__,             [], 7]
    - [suppress,            suppress.__name__.__len__,            [], 8]
    - [ExitStack,           ExitStack.__name__.__len__,           [], 9]
    - [nullcontext,         nullcontext.__name__.__len__,         [], 11]
    - [redirect_stdout,     redirect_stdout.__name__.__len__,     [], 15]

# ---------------------------------------------------------------------------
# contextlib.asynccontextmanager.__module__.__len__() == 10 — standalone
# (extra29 namespace)
#
# asynccontextmanager is a Python function defined in contextlib. Its
# __module__ is 'contextlib', which has length 10. Re-anchored as a standalone
# in the extra29 namespace to emphasize this independently of the table.
# ---------------------------------------------------------------------------

invariant contextlib_extra29.asynccontextmanager.module.len:
  description: "contextlib.asynccontextmanager.__module__.__len__() == 10 — 'contextlib' has length 10"
  category: module_attrs
  kind: python_call_eq
  function: asynccontextmanager.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# contextlib.asynccontextmanager.__name__.__len__() == 19 — standalone
# (extra29 namespace)
#
# 'asynccontextmanager' is the longest __name__ among the contextlib symbols
# covered in this spec (19 characters). Re-anchored as a standalone to
# highlight its length relative to contextmanager (14) and redirect_stdout (15).
# ---------------------------------------------------------------------------

invariant contextlib_extra29.asynccontextmanager.name.len:
  description: "contextlib.asynccontextmanager.__name__.__len__() == 19 — 'asynccontextmanager' has 19 characters, longest among common contextlib symbols"
  category: name_attrs
  kind: python_call_eq
  function: asynccontextmanager.__name__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# contextlib.ExitStack.__name__.__len__() == 9 — standalone (extra29 namespace)
#
# 'ExitStack' has length 9. Re-anchored as a standalone invariant in the
# extra29 namespace to contrast with AsyncExitStack (13 characters, covered
# in earlier specs) and confirm ExitStack's shorter name.
# ---------------------------------------------------------------------------

invariant contextlib_extra29.ExitStack.name.len:
  description: "contextlib.ExitStack.__name__.__len__() == 9 — 'ExitStack' has length 9"
  category: name_attrs
  kind: python_call_eq
  function: ExitStack.__name__.__len__
  args: []
  expected: 9
