spec: re_extra63
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra62.zspec.zsdl — covers re.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16; re.__spec__.origin.__class__.__name__.__eq__('str'); re.__spec__.submodule_search_locations.__class__.__name__.__eq__('list'); re.__spec__.has_location.__eq__(True)."
    - "re_extra56.zspec.zsdl — covers search/compile/sub/findall __qualname__.__eq__() as namespace re-anchors; Pattern/Match/error/RegexFlag __dict__.__class__.__name__.__eq__('mappingproxy')."
    - "re_extra55.zspec.zsdl — covers search/compile/match/fullmatch/sub/findall/subn/split/escape/purge __qualname__.__eq__() in requal55 namespace."
    - "re_extra35.zspec.zsdl — covers error.__init__.__qualname__.__len__()==21 and error.__str__.__qualname__.__len__()==21."
    - "re_extra34.zspec.zsdl — covers search/compile/match/fullmatch/sub/findall __qualname__.__len__() in table form."
    - "re_extra26.zspec.zsdl — covers Pattern.search/findall/fullmatch/match/sub/split/finditer __qualname__.__eq__()."
    - "re_extra9.zspec.zsdl — covers error.__qualname__.__eq__('PatternError') (Python 3.12+); Pattern.__qualname__.__eq__('Pattern'); Match.__qualname__.__eq__('Match')."
    - "re_extra8.zspec.zsdl — covers search.__qualname__.__eq__('search') and related module-level function qualnames."
  notes:
    - "This spec extends re_extra62.zspec.zsdl."
    - "Wave 227 theme: Class method __qualname__ string equality checks for methods not yet covered."
    - "re.error.__init__.__qualname__.__eq__('PatternError.__init__') — re.error is an alias for re.PatternError in Python 3.12+. error.__init__ is inherited from PatternError and has __qualname__=='PatternError.__init__'. re_extra35 covers __len__()==21 but no prior re spec checks __qualname__.__eq__() for error.__init__. Novel equality anchor in requal63 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.subn.__qualname__.__eq__('Pattern.subn') — Pattern is the compiled regular expression type (C extension). subn is a method_descriptor with __qualname__=='Pattern.subn'. Prior specs cover __len__()==12 but no prior spec checks __qualname__.__eq__() for Pattern.subn. Novel equality anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.span/__qualname__.__eq__('Match.span'), Match.groupdict/__qualname__.__eq__('Match.groupdict'), Match.expand/__qualname__.__eq__('Match.expand') — Match is a C extension type. These three methods have __qualname__=='Match.span'/'Match.groupdict'/'Match.expand'. Prior specs cover Match.group/groups/start/end __qualname__.__eq__() but not span/groupdict/expand. Novel equality anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Module-level function qualnames (search/compile/match/fullmatch/sub/findall) — already covered in multiple prior specs (re_extra8/re_extra13/re_extra25/re_extra55/re_extra56). Re-anchored here in requal63 namespace as wave 227 cross-wave traceability anchors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error.__init__.__qualname__.__eq__('PatternError.__init__')
#
# re.error is an alias for re.PatternError (Python 3.12+). Its __init__ method
# is defined on PatternError, so its __qualname__ is 'PatternError.__init__'
# (21 characters).
#
#   re.error.__init__.__qualname__.__eq__('PatternError.__init__') == True
#
# re_extra35 covers __qualname__.__len__()==21 for error.__init__.
# No prior re spec checks __qualname__.__eq__() for error.__init__.
# Novel equality anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra63.error_init_qualname:
  description: "re.error.__init__.__qualname__.__eq__('PatternError.__init__') — re.error is an alias for re.PatternError (Python 3.12+); __init__ is defined on PatternError so __qualname__=='PatternError.__init__' (21 chars); re_extra35 covers __len__()==21; no prior re spec checks __qualname__.__eq__() for error.__init__; novel equality anchor in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: requal63errinit

  columns: [id, function, args, expected]
  rows:
    - [error_init_qualname_eq, error.__init__.__qualname__.__eq__, ["PatternError.__init__"], true]

# ---------------------------------------------------------------------------
# re.Pattern.subn __qualname__.__eq__('Pattern.subn')
#
# Pattern is the compiled regular expression type (C extension, _sre.SRE_Pattern
# exposed as re.Pattern). subn is a method_descriptor with __qualname__
# following the pattern 'Pattern.<method>'.
#
#   re.Pattern.subn.__qualname__.__eq__('Pattern.subn') == True
#
# Prior specs cover Pattern.subn.__qualname__.__len__()==12 and Pattern.match/
# search/findall/sub/fullmatch/split/finditer __qualname__.__eq__().
# Pattern.subn.__qualname__.__eq__() specifically is not yet covered.
# Novel equality anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra63.pattern_subn_qualname:
  description: "re.Pattern.subn.__qualname__.__eq__('Pattern.subn') — Pattern is C extension type; subn is a method_descriptor with __qualname__=='Pattern.subn' (12 chars); prior specs cover __len__()==12; prior specs cover Pattern.match/search/findall/sub/fullmatch/split/finditer __qualname__.__eq__() but not subn; novel equality anchor in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: requal63ptnsubn

  columns: [id, function, args, expected]
  rows:
    - [pattern_subn_qualname_eq, Pattern.subn.__qualname__.__eq__, ["Pattern.subn"], true]

# ---------------------------------------------------------------------------
# re.Match.span / groupdict / expand __qualname__.__eq__()
#
# Match is a C extension type. Its methods are method_descriptors whose
# __qualname__ follows 'Match.<method>'.
#
#   re.Match.span.__qualname__      == 'Match.span'      (len 10)
#   re.Match.groupdict.__qualname__ == 'Match.groupdict' (len 15)
#   re.Match.expand.__qualname__    == 'Match.expand'    (len 12)
#
# Prior re specs cover Match.group/groups/start/end __qualname__.__eq__() but
# not Match.span/groupdict/expand. Novel equality anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra63.match_method_qualnames:
  description: "re.Match.span/groupdict/expand __qualname__.__eq__() — Match is a C extension type; these three methods are method_descriptors with __qualname__=='Match.<method>'; prior specs cover Match.group/groups/start/end __qualname__.__eq__() but not span/groupdict/expand; novel equality anchors in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: requal63match

  columns: [id, function, args, expected]
  rows:
    - [span_qualname_eq,      Match.span.__qualname__.__eq__,      ["Match.span"],      true]
    - [groupdict_qualname_eq, Match.groupdict.__qualname__.__eq__,  ["Match.groupdict"], true]
    - [expand_qualname_eq,    Match.expand.__qualname__.__eq__,     ["Match.expand"],    true]

# ---------------------------------------------------------------------------
# Module-level re function __qualname__.__eq__() — requal63 namespace re-anchors
#
# These qualnames are already covered in multiple prior specs (re_extra8,
# re_extra13, re_extra25, re_extra55, re_extra56). Re-anchored here in the
# requal63 namespace for wave 227 cross-wave traceability.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra63.module_func_qualnames:
  description: "re module-level function __qualname__.__eq__() — search/compile/match/fullmatch/sub/findall are top-level functions whose qualname equals their simple name; all covered in re_extra8/re_extra13/re_extra25/re_extra55/re_extra56; re-anchored in requal63 namespace for wave 227 cross-wave traceability; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_func_identity
  id_prefix: requal63modfunc

  columns: [id, function, args, expected]
  rows:
    - [search_qualname_eq,   search.__qualname__.__eq__,   ["search"],   true]
    - [compile_qualname_eq,  compile.__qualname__.__eq__,  ["compile"],  true]
    - [match_qualname_eq,    match.__qualname__.__eq__,    ["match"],    true]
    - [fullmatch_qualname_eq, fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [sub_qualname_eq,      sub.__qualname__.__eq__,      ["sub"],      true]
    - [findall_qualname_eq,  findall.__qualname__.__eq__,  ["findall"],  true]

invariant re_extra63.error_init_qualname_eq:
  description: "re.error.__init__.__qualname__.__eq__('PatternError.__init__') == True — re.error is an alias for re.PatternError (Python 3.12+); __init__ defined on PatternError so __qualname__=='PatternError.__init__' (21 chars); re_extra35 covers __len__()==21; no prior re spec checks __qualname__.__eq__() for error.__init__; novel equality anchor in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: error.__init__.__qualname__.__eq__
  args: ["PatternError.__init__"]
  expected: true

invariant re_extra63.pattern_subn_qualname_eq:
  description: "re.Pattern.subn.__qualname__.__eq__('Pattern.subn') == True — Pattern is a C extension type; subn is a method_descriptor with __qualname__=='Pattern.subn' (12 chars); prior specs cover __len__()==12 and match/search/findall/sub/fullmatch/split/finditer __qualname__.__eq__(); Pattern.subn __qualname__.__eq__() specifically not covered; novel equality anchor in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Pattern.subn.__qualname__.__eq__
  args: ["Pattern.subn"]
  expected: true

invariant re_extra63.match_span_qualname_eq:
  description: "re.Match.span.__qualname__.__eq__('Match.span') == True — Match is a C extension type; span is a method_descriptor with __qualname__=='Match.span' (10 chars); prior specs cover Match.group/groups/start/end __qualname__.__eq__() but not span; novel equality anchor in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Match.span.__qualname__.__eq__
  args: ["Match.span"]
  expected: true

invariant re_extra63.match_groupdict_qualname_eq:
  description: "re.Match.groupdict.__qualname__.__eq__('Match.groupdict') == True — Match is a C extension type; groupdict is a method_descriptor with __qualname__=='Match.groupdict' (15 chars); no prior re spec checks Match.groupdict.__qualname__.__eq__(); novel equality anchor in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__eq__
  args: ["Match.groupdict"]
  expected: true

invariant re_extra63.match_expand_qualname_eq:
  description: "re.Match.expand.__qualname__.__eq__('Match.expand') == True — Match is a C extension type; expand is a method_descriptor with __qualname__=='Match.expand' (12 chars); no prior re spec checks Match.expand.__qualname__.__eq__(); novel equality anchor in requal63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Match.expand.__qualname__.__eq__
  args: ["Match.expand"]
  expected: true
