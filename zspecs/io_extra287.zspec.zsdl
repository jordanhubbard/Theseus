spec: io_extra287
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "io_extra286 covers io SEEK constants and io.open/io.open_code function identity."
    - "This spec focuses on io.__all__ type, length, and membership."
    - "io.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list, not a tuple or set."
    - "io.__all__.__len__() == 24 — the io module exports exactly 24 public names as of Python 3.14."
    - "'BytesIO' in io.__all__ — BytesIO is listed in the public API."
    - "'StringIO' in io.__all__ — StringIO is listed in the public API."
    - "'DEFAULT_BUFFER_SIZE' in io.__all__ — the buffer-size constant is part of the public API."
    - "'IOBase' in io.__all__ — the root abstract base class is exported."
    - "'RawIOBase' in io.__all__ — the raw-I/O ABC is exported."
    - "'UnsupportedOperation' in io.__all__ — the exception class is exported."
    - "'FileIO' in io.__all__ — the raw file I/O class is exported."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__all__ type and length
# io.__all__ is a list (not tuple/set/frozenset) containing 24 names.
# This is a structural contract: the type must be list and the count must be 24.
# ---------------------------------------------------------------------------

table io_extra287.all_type_and_length:
  description: "io.__all__ is a plain list with exactly 24 entries"
  kind: python_call_eq
  category: module_metadata
  id_prefix: alltype287

  columns: [id, function, args, expected, description]
  rows:
    - [all_class,    "__all__.__class__.__name__.__eq__", ["list"], true,  "io.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list"]
    - [all_not_tuple,"__all__.__class__.__name__.__eq__", ["tuple"],false, "io.__all__.__class__.__name__ != 'tuple'"]
    - [all_len,      "__all__.__len__",                   [],       24,    "io.__all__.__len__() == 24 — exactly 24 names exported"]
    - [all_len_not23,"__all__.__len__",                   [],       24,    "io.__all__ has 24 entries, not 23 or 25"]

# ---------------------------------------------------------------------------
# io.__all__ membership — key public names
# Standard IO classes and the DEFAULT_BUFFER_SIZE constant must all appear
# in io.__all__ to be part of the officially documented public API surface.
# ---------------------------------------------------------------------------

table io_extra287.all_membership:
  description: "Key names must appear in io.__all__: BytesIO, StringIO, FileIO, IOBase, RawIOBase, DEFAULT_BUFFER_SIZE, UnsupportedOperation"
  kind: python_call_eq
  category: module_metadata
  id_prefix: allmem287

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_in,        "__all__.__contains__", ["BytesIO"],              true, "'BytesIO' in io.__all__"]
    - [stringio_in,       "__all__.__contains__", ["StringIO"],             true, "'StringIO' in io.__all__"]
    - [fileio_in,         "__all__.__contains__", ["FileIO"],               true, "'FileIO' in io.__all__"]
    - [iobase_in,         "__all__.__contains__", ["IOBase"],               true, "'IOBase' in io.__all__"]
    - [rawiobase_in,      "__all__.__contains__", ["RawIOBase"],            true, "'RawIOBase' in io.__all__"]
    - [bufsize_in,        "__all__.__contains__", ["DEFAULT_BUFFER_SIZE"],  true, "'DEFAULT_BUFFER_SIZE' in io.__all__"]
    - [unsupported_in,    "__all__.__contains__", ["UnsupportedOperation"], true, "'UnsupportedOperation' in io.__all__"]
    - [bogus_not_in,      "__all__.__contains__", ["NoSuchName"],           false,"'NoSuchName' not in io.__all__"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra287.all.is_list:
  description: "io.__all__.__class__.__name__ == 'list' — the __all__ export list is a plain Python list object, not a tuple, set, or frozenset"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant io_extra287.all.len_is_24:
  description: "io.__all__.__len__() == 24 — io exports exactly 24 public names as of Python 3.14; any deviation signals a module API change"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 24

invariant io_extra287.all.bytesio_present:
  description: "'BytesIO' in io.__all__ — BytesIO is part of the io module's public API"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["BytesIO"]
  expected: true

invariant io_extra287.all.stringio_present:
  description: "'StringIO' in io.__all__ — StringIO is part of the io module's public API"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["StringIO"]
  expected: true

invariant io_extra287.all.default_buffer_size_present:
  description: "'DEFAULT_BUFFER_SIZE' in io.__all__ — the module-level buffer-size constant is exported in the public API"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["DEFAULT_BUFFER_SIZE"]
  expected: true

invariant io_extra287.all.iobase_present:
  description: "'IOBase' in io.__all__ — the root abstract base class for I/O is part of the public API"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["IOBase"]
  expected: true

invariant io_extra287.all.unsupported_operation_present:
  description: "'UnsupportedOperation' in io.__all__ — the exception class for unsupported I/O operations is exported"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["UnsupportedOperation"]
  expected: true
