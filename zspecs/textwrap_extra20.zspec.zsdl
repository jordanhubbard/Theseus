spec: textwrap_extra20
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra19.zspec.zsdl."
    - "textwrap_extra19 covers: TextWrapper __mro__.__len__(); TextWrapper __mro__[0]/__mro__[1] names; TextWrapper.__name__.__len__()==11; TextWrapper.__qualname__ and __module__ extra19 anchors; table of function __name__ attributes."
    - "textwrap_extra17 covers: TextWrapper.__name__/__module__/__bases__[0].__name__; wrap/fill/shorten/indent/dedent __qualname__; two tables."
    - "textwrap_extra14 covers: TextWrapper.__qualname__ == 'TextWrapper' standalone invariant."
    - "NOT yet covered (now covered here): textwrap.TextWrapper.__qualname__.__len__() == 11 — length of 'TextWrapper'."
    - "NOT yet covered (now covered here): textwrap.wrap.__qualname__.__len__() == 4 — length of 'wrap'."
    - "NOT yet covered (now covered here): textwrap.fill.__qualname__.__len__() == 4 — length of 'fill'."
    - "NOT yet covered (now covered here): textwrap.dedent.__qualname__.__len__() == 6 — length of 'dedent'."
    - "NOT yet covered (now covered here): textwrap.indent.__qualname__.__len__() == 6 — length of 'indent'."
    - "NOT yet covered (now covered here): textwrap.shorten.__qualname__.__len__() == 7 — length of 'shorten'."
    - "NOT yet covered (now covered here): table of function __qualname__ string lengths."
    - "textwrap.TextWrapper.__qualname__.__len__() == 11 verified at runtime ('TextWrapper' has 11 chars)."
    - "textwrap.wrap.__qualname__.__len__() == 4 verified at runtime ('wrap' has 4 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.TextWrapper — __qualname__ string length
#
# textwrap_extra14/extra19 cover TextWrapper.__qualname__ == 'TextWrapper'.
# No prior spec verifies TextWrapper.__qualname__.__len__(). The string
# 'TextWrapper' has 11 characters.
# Verified at runtime: __len__() == 11.
# ---------------------------------------------------------------------------

invariant textwrap_extra20.TextWrapper.qualname_len:
  description: "textwrap.TextWrapper.__qualname__.__len__() == 11 — 'TextWrapper' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# textwrap module functions — __qualname__ string lengths
#
# textwrap_extra17 covers wrap/fill/shorten/indent/dedent __qualname__ values.
# No prior spec verifies the character counts of these __qualname__ strings.
# wrap(4), fill(4), dedent(6), indent(6), shorten(7).
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant textwrap_extra20.wrap.qualname_len:
  description: "textwrap.wrap.__qualname__.__len__() == 4 — 'wrap' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: wrap.__qualname__.__len__
  args: []
  expected: 4

invariant textwrap_extra20.fill.qualname_len:
  description: "textwrap.fill.__qualname__.__len__() == 4 — 'fill' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: fill.__qualname__.__len__
  args: []
  expected: 4

invariant textwrap_extra20.dedent.qualname_len:
  description: "textwrap.dedent.__qualname__.__len__() == 6 — 'dedent' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: dedent.__qualname__.__len__
  args: []
  expected: 6

invariant textwrap_extra20.indent.qualname_len:
  description: "textwrap.indent.__qualname__.__len__() == 6 — 'indent' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: indent.__qualname__.__len__
  args: []
  expected: 6

invariant textwrap_extra20.shorten.qualname_len:
  description: "textwrap.shorten.__qualname__.__len__() == 7 — 'shorten' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: shorten.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__ string lengths
#
# No prior table groups __qualname__.__len__() checks for textwrap module
# functions. Groups all five functions: wrap(4), fill(4), dedent(6),
# indent(6), shorten(7).
# All verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra20.function_qualname_lengths:
  description: "textwrap module-level function __qualname__ string lengths — wrap, fill, dedent, indent, shorten"
  kind: python_call_eq
  category: function_identity
  id_prefix: qnlen20

  columns: [id, function, args, expected]
  rows:
    - [wrap_len,    wrap.__qualname__.__len__,    [], 4]
    - [fill_len,    fill.__qualname__.__len__,    [], 4]
    - [dedent_len,  dedent.__qualname__.__len__,  [], 6]
    - [indent_len,  indent.__qualname__.__len__,  [], 6]
    - [shorten_len, shorten.__qualname__.__len__, [], 7]
