spec: sysconfig_extra4
version: ">=3.10"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sysconfig.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
  notes:
    - "This spec extends sysconfig.zspec.zsdl through sysconfig_extra3.zspec.zsdl."
    - "sysconfig (base) covers: function names table (10 functions); return types for get_python_version/get_scheme_names/get_path_names/get_platform; get_scheme_names len==7; get_path_names contains stdlib/platlib."
    - "sysconfig_extra covers: function names table (9 functions); return types for same 4 functions via method/method_chain."
    - "sysconfig_extra2 covers: get_config_vars/get_paths return dict and non-empty; get_scheme_names contains 'posix_prefix'; get_path_names len>=1/contains scripts/data; get_python_version contains '.'/len>=3."
    - "sysconfig_extra3 covers: __qualname__ for 8 public functions; __module__ for get_python_version and get_platform; get_default_scheme __name__/__qualname__/returns_str/non-empty."
    - "This spec adds: is_python_build().__class__.__name__ == 'bool'; get_platform().__len__() >= 1; get_config_var.__module__ == 'sysconfig'; parse_config_h.__module__ == 'sysconfig'; get_path_names().__len__() == 8; get_scheme_names contains 'posix_home'; module __name__ == 'sysconfig'; get_default_scheme().__class__.__name__ == 'str' (direct return, new angle); get_config_var.__qualname__ and parse_config_h.__qualname__."
    - "sysconfig.is_python_build() returns a bool — True if running from a CPython build tree."
    - "sysconfig.get_platform() always returns a non-empty string on any supported platform."
    - "sysconfig.get_path_names() returns exactly 8 path categories: stdlib, platstdlib, platlib, purelib, include, scripts, data, platinclude."
    - "sysconfig.get_scheme_names() always includes 'posix_home' on POSIX platforms (macOS, Linux, FreeBSD)."
    - "get_config_var and parse_config_h are module-level functions; __module__ == 'sysconfig'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module __name__ — sysconfig reports its own name correctly.
# Not covered in any prior sysconfig spec.
# ---------------------------------------------------------------------------

invariant sysconfig_extra4.module.self_name:
  description: "sysconfig.__name__ == 'sysconfig' — the module's own __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["sysconfig"]
  expected: true

# ---------------------------------------------------------------------------
# is_python_build() return type — bool.
# Prior specs only check the function name; the return type is new.
# Not covered in any prior sysconfig spec.
# ---------------------------------------------------------------------------

invariant sysconfig_extra4.is_python_build.returns_bool:
  description: "sysconfig.is_python_build().__class__.__name__ == 'bool' — returns a boolean"
  category: runtime
  kind: python_call_eq
  function: is_python_build
  args: []
  method: __class__
  method_chain: __name__
  expected: "bool"

# ---------------------------------------------------------------------------
# get_platform() non-empty — prior specs check return type (str) only.
# The platform string is always at least 1 character.
# Not covered in any prior sysconfig spec.
# ---------------------------------------------------------------------------

invariant sysconfig_extra4.get_platform.nonempty:
  description: "len(sysconfig.get_platform()) >= 1 — platform string is always non-empty"
  category: runtime
  kind: python_call_eq
  function: get_platform
  args: []
  method: __len__
  method_args: []
  method_chain: __ge__
  method_chain_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# get_path_names() length — CPython defines exactly 8 path categories.
# sysconfig_extra2 checks len >= 1; the exact count is new here.
# Not covered in any prior sysconfig spec.
# ---------------------------------------------------------------------------

invariant sysconfig_extra4.get_path_names.len_eq_8:
  description: "len(sysconfig.get_path_names()) == 8 — CPython defines exactly 8 path categories"
  category: runtime
  kind: python_call_eq
  function: get_path_names
  args: []
  method: __len__
  method_args: []
  expected: 8

# ---------------------------------------------------------------------------
# get_scheme_names() contains 'posix_home' — all POSIX platforms include this.
# sysconfig_extra2 already checks 'posix_prefix'; 'posix_home' is new.
# Not covered in any prior sysconfig spec.
# ---------------------------------------------------------------------------

invariant sysconfig_extra4.get_scheme_names.posix_home:
  description: "sysconfig.get_scheme_names().__contains__('posix_home') — posix_home is always present on POSIX"
  category: runtime
  kind: python_call_eq
  function: get_scheme_names
  args: []
  method: __contains__
  method_args: ["posix_home"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for get_config_var and parse_config_h.
# sysconfig_extra3 only adds __module__ for get_python_version and get_platform.
# Not covered in any prior sysconfig spec.
# ---------------------------------------------------------------------------

table sysconfig_extra4.additional_func_modules:
  kind: python_call_eq
  category: modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [get_config_var,  "get_config_var.__module__.__eq__",  ["sysconfig"], true]
    - [parse_config_h,  "parse_config_h.__module__.__eq__",  ["sysconfig"], true]
    - [get_path,        "get_path.__module__.__eq__",        ["sysconfig"], true]
    - [get_paths,       "get_paths.__module__.__eq__",       ["sysconfig"], true]

# ---------------------------------------------------------------------------
# __qualname__ for get_config_var and parse_config_h.
# sysconfig_extra3 adds __qualname__ for 8 functions but omits these two.
# Not covered in any prior sysconfig spec.
# ---------------------------------------------------------------------------

table sysconfig_extra4.additional_func_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [get_config_var, "get_config_var.__qualname__.__eq__", ["get_config_var"], true]
    - [parse_config_h, "parse_config_h.__qualname__.__eq__", ["parse_config_h"], true]
