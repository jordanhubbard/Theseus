spec: keyword
version: ">=3.12"
backend: python_module(keyword)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/keyword.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "keyword source: keyword.py (PSF; source inspection permitted)"
  not_derived_from:
    - "keyword source: internal implementation details"
  notes:
    - "keyword.iskeyword(s) returns True if s is a Python keyword, False otherwise."
    - "keyword.kwlist is a list of all 35 Python keywords as of Python 3.12."
    - "keyword.issoftkeyword(s) returns True if s is a soft keyword (Python 3.12+)."
    - "Soft keywords: 'match', 'case', 'type', '_' — they are only keywords in specific syntactic contexts."
    - "Hard keywords like 'for' are NOT soft keywords; issoftkeyword('for') == False."
    - "Non-identifiers and common builtins like 'print', 'len' are not keywords."
    - "kwlist length verified as 35 on Python 3.12."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "keyword functions raise TypeError for non-string arguments."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# iskeyword() — True for Python hard keywords
# ---------------------------------------------------------------------------

table keyword.iskeyword.true_cases:
  kind: python_call_eq
  category: iskeyword
  id_prefix: iskeyword_true
  function: iskeyword

  columns: [id, args, expected]
  rows:
    - [for,     ["for"],     true]
    - [while,   ["while"],   true]
    - [if,      ["if"],      true]
    - [def,     ["def"],     true]
    - [class,   ["class"],   true]
    - [return,  ["return"],  true]
    - [import,  ["import"],  true]
    - [lambda,  ["lambda"],  true]
    - [True,    ["True"],    true]
    - [False,   ["False"],   true]
    - [None,    ["None"],    true]
    - [and,     ["and"],     true]
    - [or,      ["or"],      true]
    - [not,     ["not"],     true]
    - [in,      ["in"],      true]
    - [is,      ["is"],      true]

# ---------------------------------------------------------------------------
# iskeyword() — False for non-keywords
# ---------------------------------------------------------------------------

table keyword.iskeyword.false_cases:
  kind: python_call_eq
  category: iskeyword
  id_prefix: iskeyword_false
  function: iskeyword

  columns: [id, args, expected]
  rows:
    - [hello,   ["hello"],   false]
    - [foo,     ["foo"],     false]
    - [print,   ["print"],   false]
    - [len,     ["len"],     false]
    - [match,   ["match"],   false]
    - [case,    ["case"],    false]

# ---------------------------------------------------------------------------
# issoftkeyword() — True for Python soft keywords (Python 3.12+)
# ---------------------------------------------------------------------------

table keyword.issoftkeyword.true_cases:
  kind: python_call_eq
  category: issoftkeyword
  id_prefix: issoftkeyword_true
  function: issoftkeyword

  columns: [id, args, expected]
  rows:
    - [match,  ["match"],  true]
    - [case,   ["case"],   true]
    - [type,   ["type"],   true]

# ---------------------------------------------------------------------------
# issoftkeyword() — False for hard keywords and non-keywords
# ---------------------------------------------------------------------------

table keyword.issoftkeyword.false_cases:
  kind: python_call_eq
  category: issoftkeyword
  id_prefix: issoftkeyword_false
  function: issoftkeyword

  columns: [id, args, expected]
  rows:
    - [for,    ["for"],    false]
    - [if,     ["if"],     false]
    - [hello,  ["hello"],  false]
