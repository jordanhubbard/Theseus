spec: decimal_extra1171
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.__all__ membership checks for Decimal/Context/DecimalException/ROUND_HALF_UP/setcontext/getcontext, decimal.__all__.__len__, decimal.MAX_PREC.__class__.__name__, and decimal.MAX_EMAX.__class__.__name__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.__all__.__contains__ for Decimal, Context, DecimalException, ROUND_HALF_UP, setcontext, getcontext and non-members; decimal.__all__.__len__ type; decimal.MAX_PREC/__class__.__name__, decimal.MAX_EMAX/__class__.__name__; none of these __all__ membership or MAX_PREC/MAX_EMAX checks were covered in _extra1141 or _extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1171.all_contains_core_names:
  description: "decimal.__all__.__contains__ membership checks for Decimal, Context, DecimalException, and non-members"
  kind: python_call_eq
  category: all_contains_core_names
  id_prefix: dc1171cn
  columns: [id, function, args, expected]
  rows:
    - [dc1171cn001, decimal.__all__.__contains__, ["Decimal"],          true]
    - [dc1171cn002, decimal.__all__.__contains__, ["Context"],          true]
    - [dc1171cn003, decimal.__all__.__contains__, ["DecimalException"], true]
    - [dc1171cn004, decimal.__all__.__contains__, ["setcontext"],       true]
    - [dc1171cn005, decimal.__all__.__contains__, ["getcontext"],       true]
    - [dc1171cn006, decimal.__all__.__contains__, ["localcontext"],     true]
    - [dc1171cn007, decimal.__all__.__contains__, ["decimal"],          false]
    - [dc1171cn008, decimal.__all__.__contains__, ["_Decimal"],         false]
    - [dc1171cn009, decimal.__all__.__contains__, ["context"],          false]
    - [dc1171cn010, decimal.__all__.__contains__, ["Exception"],        false]

table decimal_extra1171.all_contains_rounding_constants:
  description: "decimal.__all__.__contains__ membership checks for ROUND_* constants and non-members"
  kind: python_call_eq
  category: all_contains_rounding_constants
  id_prefix: dc1171rc
  columns: [id, function, args, expected]
  rows:
    - [dc1171rc001, decimal.__all__.__contains__, ["ROUND_HALF_UP"],   true]
    - [dc1171rc002, decimal.__all__.__contains__, ["ROUND_HALF_EVEN"], true]
    - [dc1171rc003, decimal.__all__.__contains__, ["ROUND_DOWN"],      true]
    - [dc1171rc004, decimal.__all__.__contains__, ["ROUND_UP"],        true]
    - [dc1171rc005, decimal.__all__.__contains__, ["ROUND_CEILING"],   true]
    - [dc1171rc006, decimal.__all__.__contains__, ["ROUND_FLOOR"],     true]
    - [dc1171rc007, decimal.__all__.__contains__, ["round_half_up"],   false]
    - [dc1171rc008, decimal.__all__.__contains__, ["ROUNDING"],        false]

table decimal_extra1171.max_prec_emax_and_all_len:
  description: "decimal.MAX_PREC and decimal.MAX_EMAX __class__.__name__ checks, plus __all__.__len__ type"
  kind: python_call_eq
  category: max_prec_emax_and_all_len
  id_prefix: dc1171me
  columns: [id, function, args, expected]
  rows:
    - [dc1171me001, decimal.MAX_PREC.__class__.__name__.__eq__,        ["int"],   true]
    - [dc1171me002, decimal.MAX_PREC.__class__.__name__.__eq__,        ["float"], false]
    - [dc1171me003, decimal.MAX_PREC.__class__.__name__.__eq__,        ["str"],   false]
    - [dc1171me004, decimal.MAX_EMAX.__class__.__name__.__eq__,        ["int"],   true]
    - [dc1171me005, decimal.MAX_EMAX.__class__.__name__.__eq__,        ["float"], false]
    - [dc1171me006, decimal.MAX_EMAX.__class__.__name__.__eq__,        ["str"],   false]
    - [dc1171me007, decimal.__all__.__len__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [dc1171me008, decimal.__all__.__len__.__class__.__name__.__eq__,  ["function"], false]
