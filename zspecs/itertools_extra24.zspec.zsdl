spec: itertools_extra24
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra23.zspec.zsdl."
    - "itertools_extra23 covers: chain.from_iterable, count.__next__, count.__iter__, product.__next__; combinations/permutations/combinations_with_replacement class qualnames."
    - "itertools_extra22 covers: __qualname__.__eq__ for chain/islice/starmap/groupby/count/cycle/repeat/product."
    - "No prior itertools spec records __qualname__.__eq__ for dropwhile/takewhile/filterfalse/accumulate/pairwise together in the extra24 namespace."
    - "Focus: class-level __qualname__ values for five itertools types not yet covered; pairwise requires Python >= 3.10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — filtering itertools class qualnames
#
# itertools.dropwhile, takewhile, filterfalse, and accumulate are C-level types.
# Their qualnames are simple names equal to their module attribute names.
# itertools_extra22 covers chain/islice/starmap/groupby but not these four.
# No prior itertools spec records all four together in the extra24 namespace.
# ---------------------------------------------------------------------------

table itertools_extra24.filtering_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra24.filtering_qualnames.dropwhile,
       dropwhile.__qualname__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__ == 'dropwhile'"]
    - [itertools_extra24.filtering_qualnames.takewhile,
       takewhile.__qualname__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__qualname__ == 'takewhile'"]
    - [itertools_extra24.filtering_qualnames.filterfalse,
       filterfalse.__qualname__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__ == 'filterfalse'"]
    - [itertools_extra24.filtering_qualnames.accumulate,
       accumulate.__qualname__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__ == 'accumulate'"]

# ---------------------------------------------------------------------------
# pairwise.__qualname__.__eq__ — class qualname (Python >= 3.10)
#
# itertools.pairwise was added in Python 3.10. It is a C-level type whose
# qualname is 'pairwise', the same as its module attribute name.
# No prior itertools spec records this in the extra24 namespace.
# This spec requires version >= 3.10 to ensure pairwise is available.
# ---------------------------------------------------------------------------

invariant itertools_extra24.pairwise.qualname:
  description: "itertools.pairwise.__qualname__ == 'pairwise' (Python >= 3.10)"
  category: qualnames
  kind: python_call_eq
  function: pairwise.__qualname__.__eq__
  args: ["pairwise"]
  expected: true

# ---------------------------------------------------------------------------
# dropwhile.__qualname__.__eq__ — standalone class qualname
#
# itertools.dropwhile is a C-level type. Its qualname is 'dropwhile', a
# simple name with no enclosing class scope, confirming module-level definition.
# No prior itertools spec records this standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra24.dropwhile.qualname:
  description: "itertools.dropwhile.__qualname__ == 'dropwhile'"
  category: qualnames
  kind: python_call_eq
  function: dropwhile.__qualname__.__eq__
  args: ["dropwhile"]
  expected: true

# ---------------------------------------------------------------------------
# accumulate.__qualname__.__eq__ — standalone class qualname
#
# itertools.accumulate is a C-level type that computes running totals.
# Its qualname is 'accumulate', confirming it is defined at module scope.
# No prior itertools spec records this standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra24.accumulate.qualname:
  description: "itertools.accumulate.__qualname__ == 'accumulate'"
  category: qualnames
  kind: python_call_eq
  function: accumulate.__qualname__.__eq__
  args: ["accumulate"]
  expected: true
