spec: itertools_extra2056
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "itertools C-types are not sequence/mapping types — none define item access or attribute protocol methods."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra2056.getitem_protocol:
  description: "itertools C-types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2056
  columns: [id, function, args, expected]
  rows:
    - ["it2056001", "itertools.count.__dict__.__contains__",        ["__getitem__"], false]
    - ["it2056002", "itertools.cycle.__dict__.__contains__",        ["__getitem__"], false]
    - ["it2056003", "itertools.chain.__dict__.__contains__",        ["__getitem__"], false]
    - ["it2056004", "itertools.islice.__dict__.__contains__",       ["__getitem__"], false]
    - ["it2056005", "itertools.count.__dict__.__contains__",        ["__setitem__"], false]
    - ["it2056006", "itertools.cycle.__dict__.__contains__",        ["__setitem__"], false]
    - ["it2056007", "itertools.chain.__dict__.__contains__",        ["__setitem__"], false]
    - ["it2056008", "itertools.islice.__dict__.__contains__",       ["__setitem__"], false]
    - ["it2056009", "itertools.count.__dict__.__contains__",        ["__delitem__"], false]
    - ["it2056010", "itertools.cycle.__dict__.__contains__",        ["__delitem__"], false]
    - ["it2056011", "itertools.chain.__dict__.__contains__",        ["__delitem__"], false]
    - ["it2056012", "itertools.islice.__dict__.__contains__",       ["__delitem__"], false]

