spec: io_extra1126
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module __doc__ class name, IOBase/FileIO/BytesIO/StringIO/TextIOWrapper __doc__ class name documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.__doc__.__class__.__name__, io.IOBase.__doc__.__class__.__name__, io.FileIO.__doc__.__class__.__name__, io.BytesIO.__doc__.__class__.__name__, io.StringIO.__doc__.__class__.__name__, io.TextIOWrapper.__doc__.__class__.__name__, and io.__spec__.name; none of these doc class name checks were covered in _extra1096 or _extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1126.module_doc_class_names:
  description: "io module and abstract base class __doc__.__class__.__name__ checks"
  kind: python_call_eq
  category: module_doc_class_names
  id_prefix: io1126md
  columns: [id, function, args, expected]
  rows:
    - [io1126md001, io.__doc__.__class__.__name__.__eq__,         ["str"],  true]
    - [io1126md002, io.IOBase.__doc__.__class__.__name__.__eq__,  ["str"],  true]
    - [io1126md003, io.RawIOBase.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1126md004, io.BufferedIOBase.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1126md005, io.TextIOBase.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1126md006, io.__doc__.__class__.__name__.__eq__,         ["bytes"], false]
    - [io1126md007, io.IOBase.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]

table io_extra1126.concrete_class_doc_class_names:
  description: "io concrete class __doc__.__class__.__name__ checks for FileIO, BytesIO, StringIO, TextIOWrapper"
  kind: python_call_eq
  category: concrete_class_doc_class_names
  id_prefix: io1126cd
  columns: [id, function, args, expected]
  rows:
    - [io1126cd001, io.FileIO.__doc__.__class__.__name__.__eq__,       ["str"],  true]
    - [io1126cd002, io.BytesIO.__doc__.__class__.__name__.__eq__,      ["str"],  true]
    - [io1126cd003, io.StringIO.__doc__.__class__.__name__.__eq__,     ["str"],  true]
    - [io1126cd004, io.TextIOWrapper.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1126cd005, io.BufferedReader.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1126cd006, io.BufferedWriter.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1126cd007, io.BufferedRandom.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io1126cd008, io.FileIO.__doc__.__class__.__name__.__eq__,       ["bytes"], false]

table io_extra1126.module_spec_and_name:
  description: "io.__spec__.name and class __name__ cross-checks not previously covered"
  kind: python_call_eq
  category: module_spec_and_name
  id_prefix: io1126sn
  columns: [id, function, args, expected]
  rows:
    - [io1126sn001, io.__spec__.name.__eq__,                          ["io"],          true]
    - [io1126sn002, io.__spec__.name.__class__.__name__.__eq__,       ["str"],         true]
    - [io1126sn003, io.__spec__.name.__eq__,                          ["_io"],         false]
    - [io1126sn004, io.IOBase.__name__.__class__.__name__.__eq__,     ["str"],         true]
    - [io1126sn005, io.FileIO.__name__.__class__.__name__.__eq__,     ["str"],         true]
    - [io1126sn006, io.BytesIO.__name__.__class__.__name__.__eq__,    ["str"],         true]
    - [io1126sn007, io.StringIO.__name__.__class__.__name__.__eq__,   ["str"],         true]
    - [io1126sn008, io.TextIOWrapper.__name__.__class__.__name__.__eq__, ["str"],      true]
    - [io1126sn009, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["str"],         false]
