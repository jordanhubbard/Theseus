spec: struct_extra162
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra161.zspec.zsdl — covers struct.error.__name__/'error'/__module__/'struct'/__bases__[0].__name__/'Exception'; struct.Struct.__name__/'Struct'/__module__/'_struct'/__bases__[0].__name__/'object' (table + invariants)."
    - "struct_extra160.zspec.zsdl — covers struct.Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/size/format) and meta-attributes (__len__()==16/__class__.__name__=='mappingproxy') (table + invariants)."
    - "struct_extra159.zspec.zsdl — covers struct.__spec__.origin type and content / submodule_search_locations NoneType / spec attribute lengths (table + invariants)."
    - "struct_extra158.zspec.zsdl — covers struct.Struct.__new__/__str__ qualnames; struct.error class identity / error.__bases__[0].__name__=='Exception' (table + invariants)."
    - "struct_extra157.zspec.zsdl — covers struct.Struct.__repr__/__sizeof__ qualnames / Struct.__name__/__module__ (table + invariants)."
    - "struct_extra154.zspec.zsdl — covers struct.Struct.pack/__unpack/__pack_into qualnames (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra161."
    - "Wave 348 theme: struct module-level function identity — struct.pack.__name__=='pack' / pack.__module__=='_struct' / struct.unpack.__name__=='unpack' / unpack.__module__=='_struct' / struct.pack_into.__name__=='pack_into' / struct.unpack_from.__name__=='unpack_from' / struct.iter_unpack.__name__=='iter_unpack' / struct.calcsize.__name__=='calcsize'. These are the module-level convenience functions (not Struct instance methods). struct_extra154/160 anchors Struct.pack/unpack/pack_into qualnames as instance method_descriptor; this spec anchors the module-level builtin_function_or_method objects."
    - "struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All six module-level struct functions have __module__ == '_struct' (7 chars). They are C builtin_function_or_method objects from the _struct C extension (Modules/_struct.c), re-exported through Lib/struct.py. This contrasts with struct.error.__module__=='struct' (6 chars, public module) — the error class is explicitly re-exported with the public module name, but the functions retain their C extension module."
    - "Note: Name lengths: 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) == 'iter_unpack'(11) — wait: 'pack_into'=9, 'unpack_from'=11, 'iter_unpack'=11. Actual: 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'(11) == 'iter_unpack'(11). The two longest names ('unpack_from' and 'iter_unpack') are both 11 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack')
# struct.pack.__module__.__eq__('_struct')
# struct.unpack.__name__.__eq__('unpack')
# struct.unpack.__module__.__eq__('_struct')
#
# Wave 348 theme: struct module-level pack and unpack function identity.
#
# pack.__name__ == 'pack' (4 chars; shortest module-level function name).
# pack.__module__ == '_struct' (7 chars; private C extension).
# unpack.__name__ == 'unpack' (6 chars; 2 chars longer than 'pack').
# unpack.__module__ == '_struct' (7 chars; same C extension as pack).
# No prior struct spec anchors module-level pack.__name__ or unpack.__name__ as a table
# under structfn162. struct_extra154 anchors Struct.pack/unpack as instance method_descriptor
# qualnames; this spec anchors the module-level functions. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra162.pack_unpack_name_and_module:
  description: "struct.pack.__name__.__eq__('pack')==True / pack.__module__.__eq__('_struct')==True / unpack.__name__.__eq__('unpack')==True / unpack.__module__.__eq__('_struct')==True — pack.__name__ is 'pack' (4 chars; the module-level pack function; packs Python values into bytes according to a format string; struct.pack(fmt, *values) is the module-level convenience function; distinct from Struct.pack which is the instance method; pack.__class__.__name__=='builtin_function_or_method' (C extension function from _struct.c); struct_extra154 anchors Struct.pack.__qualname__=='Struct.pack' as an instance method; this spec anchors struct.pack as the module-level function); pack.__module__ is '_struct' (7 chars = '_'=1 + 'struct'=6; private C extension module; all six module-level struct functions have __module__=='_struct'; the leading underscore marks this as a private C extension not intended for direct import; struct.error.__module__=='struct'(6 chars) in contrast — error was re-exported with the public name); unpack.__name__ is 'unpack' (6 chars = 'un'=2 + 'pack'=4; the module-level unpack function; unpacks bytes into a tuple of Python values; 'unpack'(6) > 'pack'(4) by 2 chars — the 'un' prefix adds 2 chars); unpack.__module__ is '_struct' (7 chars; same C extension as pack; all module-level functions from the same _struct.c source); first structfn162 anchor for pack and unpack module-level __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: structfn162

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name,   "pack.__name__.__eq__",   ["pack"],    true, "struct.pack.__name__ == 'pack' (4 chars; module-level convenience function; packs values to bytes; shortest module-level function name)"]
    - [pack_module, "pack.__module__.__eq__",  ["_struct"], true, "struct.pack.__module__ == '_struct' (7 chars; private C extension; _struct.c; all six module-level functions share this __module__)"]
    - [unpack_name,   "unpack.__name__.__eq__",   ["unpack"],  true, "struct.unpack.__name__ == 'unpack' (6 chars = 'un'=2 + 'pack'=4; module-level unpack; inverse of pack; 2 chars longer than 'pack'=4)"]
    - [unpack_module, "unpack.__module__.__eq__",  ["_struct"], true, "struct.unpack.__module__ == '_struct' (7 chars; same C extension as pack; all module-level functions from _struct.c)"]

# ---------------------------------------------------------------------------
# struct.pack_into.__name__ and __module__
# struct.unpack_from.__name__ and __module__
#
# Wave 348 theme: struct pack_into and unpack_from module-level function identity.
#
# pack_into.__name__ == 'pack_into' (9 chars; pack into a buffer at an offset).
# pack_into.__module__ == '_struct' (7 chars; C extension).
# unpack_from.__name__ == 'unpack_from' (11 chars; unpack from buffer at offset).
# unpack_from.__module__ == '_struct' (7 chars; same C extension).
# No prior struct spec anchors module-level pack_into.__name__ or unpack_from.__name__ as
# a table under structfn162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra162.pack_into_unpack_from_name_and_module:
  description: "struct.pack_into.__name__.__eq__('pack_into')==True / pack_into.__module__.__eq__('_struct')==True / unpack_from.__name__.__eq__('unpack_from')==True / unpack_from.__module__.__eq__('_struct')==True — pack_into.__name__ is 'pack_into' (9 chars = 'pack'=4 + '_into'=5; the module-level pack_into function; packs values into a writable buffer at a specified byte offset; struct.pack_into(fmt, buffer, offset, *values); useful for building structured binary data in-place without creating a new bytes object; 'pack_into'(9) > 'unpack'(6) > 'pack'(4) in length ordering so far); pack_into.__module__ is '_struct' (7 chars; private C extension; same as pack and unpack; struct_extra161 anchors error.__module__=='struct'(6) vs Struct.__module__=='_struct'(7)); unpack_from.__name__ is 'unpack_from' (11 chars = 'unpack'=6 + '_from'=5; the module-level unpack_from function; unpacks from a buffer at a specified byte offset; struct.unpack_from(fmt, buffer, offset=0); does not require the buffer to be exactly struct.calcsize(fmt) bytes — only needs to be at least that size starting at offset; 'unpack_from'(11) > 'pack_into'(9) by 2 chars); unpack_from.__module__ is '_struct' (7 chars; same C extension as all other module-level functions); first structfn162 anchor for pack_into and unpack_from module-level __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: structfn162

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_name,     "pack_into.__name__.__eq__",     ["pack_into"],   true, "struct.pack_into.__name__ == 'pack_into' (9 chars = 'pack'=4 + '_into'=5; packs into buffer at offset; 'pack_into'(9) > 'unpack'(6) > 'pack'(4))"]
    - [pack_into_module,   "pack_into.__module__.__eq__",   ["_struct"],     true, "struct.pack_into.__module__ == '_struct' (7 chars; private C extension; same as pack and unpack)"]
    - [unpack_from_name,   "unpack_from.__name__.__eq__",   ["unpack_from"], true, "struct.unpack_from.__name__ == 'unpack_from' (11 chars = 'unpack'=6 + '_from'=5; unpacks from buffer at offset; longest name so far)"]
    - [unpack_from_module, "unpack_from.__module__.__eq__", ["_struct"],     true, "struct.unpack_from.__module__ == '_struct' (7 chars; same C extension as all six module-level functions)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__ and __module__
# struct.calcsize.__name__ and __module__
#
# Wave 348 theme: struct iter_unpack and calcsize module-level function identity.
#
# iter_unpack.__name__ == 'iter_unpack' (11 chars; iterator-based unpack).
# iter_unpack.__module__ == '_struct' (7 chars; C extension).
# calcsize.__name__ == 'calcsize' (8 chars; compute format size).
# calcsize.__module__ == '_struct' (7 chars; same C extension).
# No prior struct spec anchors module-level iter_unpack.__name__ or calcsize.__name__ as
# a table under structfn162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra162.iter_unpack_calcsize_name_and_module:
  description: "struct.iter_unpack.__name__.__eq__('iter_unpack')==True / iter_unpack.__module__.__eq__('_struct')==True / calcsize.__name__.__eq__('calcsize')==True / calcsize.__module__.__eq__('_struct')==True — iter_unpack.__name__ is 'iter_unpack' (11 chars = 'iter_'=5 + 'unpack'=6; the module-level iter_unpack function; returns an iterator that unpacks successive items from a buffer; struct.iter_unpack(fmt, buffer); buffer must have size that is a multiple of struct.calcsize(fmt); unlike unpack_from (takes an offset), iter_unpack traverses the entire buffer yielding tuples; added in Python 3.4; 'iter_unpack'(11) == 'unpack_from'(11) — both 11 chars, the two longest module-level function names; 'iter_unpack'(11) = 'iter_'(5) + 'unpack'(6) vs 'unpack_from'(11) = 'unpack'(6) + '_from'(5): symmetric name lengths); iter_unpack.__module__ is '_struct' (7 chars; same C extension as all five other module-level functions; all six share __module__=='_struct'); calcsize.__name__ is 'calcsize' (8 chars = 'calc'=4 + 'size'=4; computes the number of bytes required by a format string; struct.calcsize(fmt) returns an integer; 'calcsize'(8) is between 'pack_into'(9) and 'unpack'(6): 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9)); calcsize.__module__ is '_struct' (7 chars; same C extension; all six module-level functions from _struct.c); first structfn162 anchor for iter_unpack and calcsize module-level __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: structfn162

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_name,   "iter_unpack.__name__.__eq__",   ["iter_unpack"], true, "struct.iter_unpack.__name__ == 'iter_unpack' (11 chars = 'iter_'=5 + 'unpack'=6; iterator-based unpack; 'iter_unpack'(11) == 'unpack_from'(11) — same length)"]
    - [iter_unpack_module, "iter_unpack.__module__.__eq__", ["_struct"],     true, "struct.iter_unpack.__module__ == '_struct' (7 chars; same C extension as all other module-level functions)"]
    - [calcsize_name,      "calcsize.__name__.__eq__",      ["calcsize"],    true, "struct.calcsize.__name__ == 'calcsize' (8 chars = 'calc'=4 + 'size'=4; computes bytes required by format string; 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9))"]
    - [calcsize_module,    "calcsize.__module__.__eq__",    ["_struct"],     true, "struct.calcsize.__module__ == '_struct' (7 chars; private C extension; all six module-level struct functions share __module__=='_struct')"]

# ---------------------------------------------------------------------------
# struct function class names and name length comparison
#
# Wave 348 theme: module-level struct functions are builtin_function_or_method.
#
# pack.__class__.__name__ == 'builtin_function_or_method' (25 chars).
# calcsize.__class__.__name__ == 'builtin_function_or_method' (25 chars).
# pack.__name__.__len__() == 4 ('pack' = 4 chars; shortest).
# unpack_from.__name__.__len__() == 11 ('unpack_from' = 11 chars; tied longest).
# No prior struct spec anchors module-level function __class__.__name__ as a table under
# structfn162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra162.struct_fn_class_names_and_lengths:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method')==True / calcsize.__class__.__name__.__eq__('builtin_function_or_method')==True / pack.__name__.__len__()==4 / unpack_from.__name__.__len__()==11 — pack.__class__.__name__ is 'builtin_function_or_method' (25 chars; struct.pack is a C builtin function from the _struct extension; 'builtin_function_or_method' is the type name for C-implemented functions and methods; contrasts with uuid.uuid4.__class__.__name__=='function'(8 chars) which is a pure Python function; 'builtin_function_or_method'(25) >> 'function'(8) by 17 chars); calcsize.__class__.__name__ is 'builtin_function_or_method' (25 chars; same type as pack; all six module-level struct functions are builtin_function_or_method from _struct.c); pack.__name__.__len__() is 4 ('pack' = 4 chars; shortest module-level function name; 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'/'iter_unpack'(11)); unpack_from.__name__.__len__() is 11 ('unpack_from' = 'unpack'=6 + '_from'=5 = 11 chars; tied with 'iter_unpack'=11 as longest module-level function names; 'unpack_from'(11) == 'iter_unpack'(11); both are 11 chars); first structfn162 anchor for module-level function __class__.__name__ and name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: structfn162

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class_builtin,       "pack.__class__.__name__.__eq__",       ["builtin_function_or_method"], true, "struct.pack.__class__.__name__ == 'builtin_function_or_method' (25 chars; C extension function from _struct.c; contrasts with Python 'function'=8 chars)"]
    - [calcsize_class_builtin,   "calcsize.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' (25 chars; same type as pack; all six module-level functions are C builtins)"]
    - [pack_name_len_4,          "pack.__name__.__len__",                [], 4,                           "struct.pack.__name__.__len__() is 4 ('pack' = 4 chars; shortest module-level function name; length ordering: 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'/'iter_unpack'(11))"]
    - [unpack_from_name_len_11,  "unpack_from.__name__.__len__",         [], 11,                          "struct.unpack_from.__name__.__len__() is 11 ('unpack_from' = 'unpack'=6 + '_from'=5 = 11; tied with 'iter_unpack'=11 as longest module-level function names)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack') — standalone
#
# struct.pack.__name__ is 'pack' (4 chars). struct.pack is the module-level convenience
# function for packing Python values into bytes. struct.pack(fmt, *values) is equivalent to
# Struct(fmt).pack(*values) but without creating a persistent Struct object. 'pack' is a
# builtin_function_or_method from the _struct C extension (Modules/_struct.c). Its __name__
# is 'pack' (4 chars) — the shortest name among the six module-level struct functions.
# struct_extra154 anchors Struct.pack (instance method) qualname; this spec anchors the
# module-level pack function's own __name__. No prior struct spec anchors struct.pack.__name__
# as a standalone under structfn162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra162.pack_name_eq_pack:
  description: "struct.pack.__name__.__eq__('pack') == True — 'pack' (4 chars; shortest module-level function name); module-level convenience function for packing values to bytes; struct.pack(fmt, *v) equiv to Struct(fmt).pack(*v); builtin_function_or_method from _struct.c; pack.__module__=='_struct'(7 chars); struct_extra154 anchors Struct.pack instance method qualname; 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'/'iter_unpack'(11); first structfn162 standalone for pack.__name__"
  category: identity
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack.__name__.__eq__('unpack') — standalone
#
# struct.unpack.__name__ is 'unpack' (6 chars). struct.unpack is the module-level function
# for unpacking bytes into Python values. struct.unpack(fmt, buffer) returns a tuple.
# 'unpack' (6 chars) = 'un'=2 + 'pack'=4. The 'un' prefix marks the inverse operation
# of 'pack'. struct.unpack is equivalent to Struct(fmt).unpack(buffer).
# No prior struct spec anchors struct.unpack.__name__ as a standalone under structfn162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra162.unpack_name_eq_unpack:
  description: "struct.unpack.__name__.__eq__('unpack') == True — 'unpack' (6 chars = 'un'=2 + 'pack'=4; 'un' prefix is the inverse of 'pack'; module-level unpack; struct.unpack(fmt, buffer) returns tuple; builtin_function_or_method; unpack.__module__=='_struct'(7 chars); 'unpack'(6) > 'pack'(4) by 2 chars; first structfn162 standalone for unpack.__name__"
  category: identity
  kind: python_call_eq
  function: unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__eq__('pack_into') — standalone
#
# struct.pack_into.__name__ is 'pack_into' (9 chars). struct.pack_into(fmt, buffer, offset,
# *values) packs values into a writable buffer object at a specified byte offset. Unlike
# struct.pack() which returns a new bytes object, pack_into writes into an existing buffer
# (e.g., bytearray or memoryview). 'pack_into' (9 chars) = 'pack'=4 + '_into'=5.
# No prior struct spec anchors struct.pack_into.__name__ as a standalone under structfn162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra162.pack_into_name_eq_pack_into:
  description: "struct.pack_into.__name__.__eq__('pack_into') == True — 'pack_into' (9 chars = 'pack'=4 + '_into'=5; packs values into existing writable buffer at byte offset; struct.pack_into(fmt, buffer, offset, *v) unlike pack() which returns new bytes; useful for building structured binary data in-place; pack_into.__module__=='_struct'(7); 'pack_into'(9) > 'unpack'(6) > 'pack'(4); first structfn162 standalone for pack_into.__name__"
  category: identity
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__name__.__eq__('unpack_from') — standalone
#
# struct.unpack_from.__name__ is 'unpack_from' (11 chars). struct.unpack_from(fmt, buffer,
# offset=0) unpacks from a buffer at a specified byte offset. Unlike struct.unpack() which
# requires the buffer to be exactly calcsize(fmt) bytes, unpack_from only needs at least
# calcsize(fmt) bytes starting at the offset. 'unpack_from' (11 chars) = 'unpack'=6 + '_from'=5.
# 'unpack_from'(11) is tied with 'iter_unpack'(11) as the longest module-level function name.
# No prior struct spec anchors struct.unpack_from.__name__ as a standalone under structfn162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra162.unpack_from_name_eq_unpack_from:
  description: "struct.unpack_from.__name__.__eq__('unpack_from') == True — 'unpack_from' (11 chars = 'unpack'=6 + '_from'=5; unpacks from buffer at byte offset; struct.unpack_from(fmt, buffer, offset=0); buffer need only be at least calcsize(fmt) bytes starting at offset; '_from' suffix mirrors '_into' in 'pack_into': pack_into writes into buffer, unpack_from reads from buffer; 'unpack_from'(11) == 'iter_unpack'(11) — tied longest names; unpack_from.__module__=='_struct'(7); first structfn162 standalone for unpack_from.__name__"
  category: identity
  kind: python_call_eq
  function: unpack_from.__name__.__eq__
  args: ["unpack_from"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack.__name__ is 'iter_unpack' (11 chars). struct.iter_unpack(fmt, buffer)
# returns an iterator that yields successive tuples unpacked from the buffer. The buffer
# size must be a multiple of struct.calcsize(fmt). iter_unpack is memory-efficient for
# processing arrays of fixed-size records without unpacking all at once. Added in Python 3.4.
# 'iter_unpack' (11 chars) = 'iter_'=5 + 'unpack'=6. Tied with 'unpack_from'(11 chars) as
# the longest module-level struct function name. No prior struct spec anchors
# struct.iter_unpack.__name__ as a standalone under structfn162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra162.iter_unpack_name_eq_iter_unpack:
  description: "struct.iter_unpack.__name__.__eq__('iter_unpack') == True — 'iter_unpack' (11 chars = 'iter_'=5 + 'unpack'=6; iterator-based unpack; yields successive tuples from buffer; buffer must be multiple of calcsize(fmt); memory-efficient for arrays of fixed-size records; added in Python 3.4; 'iter_unpack'(11) == 'unpack_from'(11) — tied longest module-level function names; iter_unpack.__module__=='_struct'(7); first structfn162 standalone for iter_unpack.__name__"
  category: identity
  kind: python_call_eq
  function: iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__name__.__eq__('calcsize') — standalone
#
# struct.calcsize.__name__ is 'calcsize' (8 chars). struct.calcsize(fmt) returns the number
# of bytes required to pack (or unpack) values according to a format string. 'calcsize'
# (8 chars) = 'calc'=4 + 'size'=4. calcsize is the only module-level struct function that
# does not pack or unpack data — it only computes the size. calcsize is essential for
# determining buffer sizes and offsets before calling pack_into or unpack_from.
# 'calcsize' (8 chars): 'calc'=4 (from 'calculate') + 'size'=4.
# 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) in the length ordering.
# No prior struct spec anchors struct.calcsize.__name__ as a standalone under structfn162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra162.calcsize_name_eq_calcsize:
  description: "struct.calcsize.__name__.__eq__('calcsize') == True — 'calcsize' (8 chars = 'calc'=4 + 'size'=4; 'calc' from 'calculate'; computes bytes required by format string; struct.calcsize(fmt) returns int; only module-level function that does not pack/unpack data; used to determine buffer sizes for pack_into and unpack_from; 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) in length ordering; calcsize.__module__=='_struct'(7); all six module-level functions have __module__=='_struct'; first structfn162 standalone for calcsize.__name__"
  category: identity
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__module__.__eq__('_struct') — standalone
#
# struct.pack.__module__ is '_struct' (7 chars). All six module-level struct functions
# (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) have __module__ == '_struct'.
# They are all builtin_function_or_method objects from the _struct C extension
