spec: socket_extra216
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"
  - "RFC 1700 — Assigned Numbers (network byte order)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "verified with Python 3.14.3."
    - "socket.AF_INET.value == 2; socket.AF_INET6.value == 30 on macOS/Darwin (10 on Linux)."
    - "socket.AF_UNIX.value == 1; socket.AF_UNIX is POSIX-only (not available on Windows)."
    - "socket.SOCK_RAW.value == 3; socket.SOCK_SEQPACKET.value == 5 on macOS/Darwin."
    - "socket.IPPROTO_TCP == 6; socket.IPPROTO_UDP == 17; socket.IPPROTO_IP == 0; socket.IPPROTO_IPV6 == 41."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int' — protocol constants are plain Python ints."
    - "socket.socket.connect.__name__ == 'connect'; socket.socket.bind.__name__ == 'bind'."
    - "socket.socket.listen.__name__ == 'listen'; socket.socket.recv.__name__ == 'recv'."
    - "socket.socket.send.__name__ == 'send'; socket.socket.setsockopt.__name__ == 'setsockopt'."
    - "socket.AF_INET.name == 'AF_INET'; socket.AF_INET6.name == 'AF_INET6'; socket.AF_UNIX.name == 'AF_UNIX'."
    - "AF_INET6.value is platform-dependent (30 macOS, 10 Linux); only the .name attribute is checked in the cross-platform table."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class method name checks
#
# socket.socket.connect.__name__    == 'connect'
# socket.socket.bind.__name__       == 'bind'
# socket.socket.listen.__name__     == 'listen'
# socket.socket.recv.__name__       == 'recv'
# socket.socket.send.__name__       == 'send'
# socket.socket.setsockopt.__name__ == 'setsockopt'
# ---------------------------------------------------------------------------

table socket_extra216.socket_method_names:
  description: "socket.socket class method name checks in socketeq216 namespace — wave 216 theme: socket.socket class methods connect/bind/listen/recv/send/setsockopt each have __name__ matching the method string name; these are core POSIX socket API methods exposed on the socket class; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: socketeq216

  columns: [id, function, args, expected, description]
  rows:
    - [connect_name,    "socket.socket.connect.__name__.__eq__",    ["connect"],    true,  "socket.socket.connect.__name__ == 'connect' — POSIX connect() method name"]
    - [bind_name,       "socket.socket.bind.__name__.__eq__",       ["bind"],       true,  "socket.socket.bind.__name__ == 'bind' — POSIX bind() method name"]
    - [listen_name,     "socket.socket.listen.__name__.__eq__",     ["listen"],     true,  "socket.socket.listen.__name__ == 'listen' — POSIX listen() method name"]
    - [recv_name,       "socket.socket.recv.__name__.__eq__",       ["recv"],       true,  "socket.socket.recv.__name__ == 'recv' — POSIX recv() method name"]
    - [send_name,       "socket.socket.send.__name__.__eq__",       ["send"],       true,  "socket.socket.send.__name__ == 'send' — POSIX send() method name"]
    - [setsockopt_name, "socket.socket.setsockopt.__name__.__eq__", ["setsockopt"], true,  "socket.socket.setsockopt.__name__ == 'setsockopt' — POSIX setsockopt() method name"]

# ---------------------------------------------------------------------------
# IPPROTO_* integer constant values and type
#
# socket.IPPROTO_TCP   == 6
# socket.IPPROTO_UDP   == 17
# socket.IPPROTO_IP    == 0
# socket.IPPROTO_IPV6  == 41
# socket.IPPROTO_TCP.__class__.__name__ == 'int'
# ---------------------------------------------------------------------------

table socket_extra216.ipproto_constants:
  description: "socket IPPROTO_* integer constant value and type checks in socketeq216a namespace — wave 216 theme: IPPROTO_TCP=6; IPPROTO_UDP=17; IPPROTO_IP=0; IPPROTO_IPV6=41; these are IANA-assigned protocol numbers that are fixed across all conforming platforms; IPPROTO values are plain Python ints; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: socketeq216a

  columns: [id, function, args, expected, description]
  rows:
    - [ipproto_tcp_value,   "socket.IPPROTO_TCP.__eq__",                      [6],     true,  "socket.IPPROTO_TCP == 6 — IANA-assigned TCP protocol number"]
    - [ipproto_udp_value,   "socket.IPPROTO_UDP.__eq__",                      [17],    true,  "socket.IPPROTO_UDP == 17 — IANA-assigned UDP protocol number"]
    - [ipproto_ip_value,    "socket.IPPROTO_IP.__eq__",                       [0],     true,  "socket.IPPROTO_IP == 0 — IPPROTO_IP is the wildcard/dummy protocol, value 0"]
    - [ipproto_ipv6_value,  "socket.IPPROTO_IPV6.__eq__",                     [41],    true,  "socket.IPPROTO_IPV6 == 41 — IANA-assigned IPv6 protocol number"]
    - [ipproto_tcp_type,    "socket.IPPROTO_TCP.__class__.__name__.__eq__",   ["int"], true,  "socket.IPPROTO_TCP.__class__.__name__ == 'int' — IPPROTO constants are plain Python ints"]

# ---------------------------------------------------------------------------
# AddressFamily enum .name attribute checks (cross-platform)
#
# socket.AF_INET.name   == 'AF_INET'
# socket.AF_INET6.name  == 'AF_INET6'
# socket.AF_UNIX.name   == 'AF_UNIX'
# ---------------------------------------------------------------------------

table socket_extra216.af_enum_names:
  description: "socket AddressFamily enum .name attribute checks in socketeq216b namespace — wave 216 theme: AF_INET.name == 'AF_INET'; AF_INET6.name == 'AF_INET6'; AF_UNIX.name == 'AF_UNIX'; the .name attribute of an enum member is its Python identifier string; these are cross-platform on POSIX systems; AF_INET6.value is platform-dependent so only .name is tested here; verified with Python 3.14.3"
  kind: python_call_eq
  category: enum_names
  id_prefix: socketeq216b

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_name,   "socket.AF_INET.name.__eq__",   ["AF_INET"],   true,  "socket.AF_INET.name == 'AF_INET' — enum member name matches the constant identifier"]
    - [af_inet6_name,  "socket.AF_INET6.name.__eq__",  ["AF_INET6"],  true,  "socket.AF_INET6.name == 'AF_INET6' — enum member name matches the constant identifier"]
    - [af_unix_name,   "socket.AF_UNIX.name.__eq__",   ["AF_UNIX"],   true,  "socket.AF_UNIX.name == 'AF_UNIX' — enum member name matches the constant identifier (POSIX only)"]

# ---------------------------------------------------------------------------
# SOCK_RAW and SOCK_SEQPACKET — macOS-specific values
# AF_UNIX, AF_INET value checks (universally stable on POSIX)
# ---------------------------------------------------------------------------

invariant socket_extra216.sock_raw_value:
  description: "socket.SOCK_RAW.value == 3 — SOCK_RAW is raw socket type 3; this value is stable across all POSIX platforms (macOS, Linux, FreeBSD); SOCK_RAW allows direct access to network protocol headers; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  category: constants
  kind: python_call_eq
  function: "socket.SOCK_RAW.value.__eq__"
  args: [3]
  expected: true

invariant socket_extra216.af_unix_value:
  description: "socket.AF_UNIX.value == 1 — AF_UNIX is Unix domain socket address family 1; this value is stable on all POSIX platforms (macOS, Linux, FreeBSD); AF_UNIX sockets are used for inter-process communication on the same host; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  category: constants
  kind: python_call_eq
  function: "socket.AF_UNIX.value.__eq__"
  args: [1]
  expected: true

invariant socket_extra216.sock_seqpacket_name:
  description: "socket.SOCK_SEQPACKET.name == 'SOCK_SEQPACKET' — SOCK_SEQPACKET is a SocketKind enum member providing sequenced, reliable, two-way connection-based datagrams; its .name attribute is the enum identifier string; available on macOS and Linux (value 5 on macOS); verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  category: enum_names
  kind: python_call_eq
  function: "socket.SOCK_SEQPACKET.name.__eq__"
  args: ["SOCK_SEQPACKET"]
  expected: true

invariant socket_extra216.inet_aton_bad_raises:
  description: "socket.inet_aton('bad.address') raises OSError — inet_aton validates that its argument is a legal dotted-decimal IPv4 address; 'bad.address' does not conform to the x.x.x.x format; OSError is raised with 'illegal IP address string passed to inet_aton'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: socket.inet_aton
  args: ["bad.address"]
  expected_exception: OSError

