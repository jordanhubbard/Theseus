spec: get_value
version: ">=4.0.1"
backend: node(get-value)

docs: https://www.npmjs.com/package/get-value

provenance:
  derived_from:
    - "get-value README — https://www.npmjs.com/package/get-value"
    - "Test vectors verified with get-value via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "get-value source"
  notes:
    - "get-value is an npm package. Install: npm install get-value"
    - "Retrieves a nested object property using a dot-delimited path. ESM; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the value at the path, or undefined if not found."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table get_value.getValue:
  kind: node_module_call_eq
  function: "default"
  category: lookup
  id_prefix: getval

  columns: [id, args, expected]
  rows:
    - [deep_path,  [{"a": {"b": {"c": 42}}}, "a.b.c"], 42]
    - [nested_obj, [{"a": {"b": {"c": 1}}}, "a.b"],    {"c": 1}]
