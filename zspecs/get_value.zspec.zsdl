table get_value.getValue:
  kind: node_module_call_eq
  function: "default"
  category: lookup
  id_prefix: getval

  columns: [id, args, expected]
  rows:
    - [deep_path,  [{"a": {"b": {"c": 42}}}, "a.b.c"], 42]
    - [nested_obj, [{"a": {"b": {"c": 1}}}, "a.b"],    {"c": 1}]

