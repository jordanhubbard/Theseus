spec: inspect_extra77
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra76.zspec.zsdl."
    - "This spec covers: inspect BoundArguments __dict__ content + getclosurevars/getsourcelines code objects (Wave 243)."
    - "BoundArguments.__dict__.__class__.__name__ == 'mappingproxy' — BoundArguments class namespace is a mappingproxy. Verified with Python 3.14.3."
    - "BoundArguments.__dict__.__contains__('args') == True — BoundArguments.args is a property. Verified with Python 3.14.3."
    - "BoundArguments.__dict__.__contains__('kwargs') == True — BoundArguments.kwargs is a property. Verified with Python 3.14.3."
    - "BoundArguments.__dict__.__contains__('apply_defaults') == True — BoundArguments.apply_defaults is defined. Verified with Python 3.14.3."
    - "getclosurevars.__code__.co_name == 'getclosurevars' — code object name matches function name. Verified with Python 3.14.3."
    - "getclosurevars.__code__.co_argcount == 1 — takes a single 'func' argument. Verified with Python 3.14.3."
    - "getsourcelines.__code__.co_name == 'getsourcelines' — code object name matches function name. Verified with Python 3.14.3."
    - "getsourcelines.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "getfile.__code__.co_name == 'getfile' — code object name matches function name. Verified with Python 3.14.3."
    - "getfile.__code__.co_argcount == 1 — takes a single 'object' argument. Verified with Python 3.14.3."
    - "getmodule.__code__.co_name == 'getmodule' — code object name matches function name. Verified with Python 3.14.3."
    - "getmodule.__code__.co_argcount == 2 — takes 'object' and 'filename' arguments. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BoundArguments __dict__ class name — extra77
#
# Wave 243 theme: BoundArguments __dict__ content.
#
# inspect.BoundArguments.__dict__.__class__.__name__ == 'mappingproxy'
#
# No prior inspect spec checks BoundArguments.__dict__.__class__.__name__ via inspmore77. New to extra77.
# ---------------------------------------------------------------------------

table inspect_extra77.BoundArguments_dict_class_name:
  description: "BoundArguments.__dict__.__class__.__name__=='mappingproxy'; wave 243 BoundArguments __dict__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore77

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_dict_class_name_eq_mappingproxy,
       BoundArguments.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.BoundArguments.__dict__.__class__.__name__.__eq__('mappingproxy') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py that wraps the result of Signature.bind(); its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior inspect spec checks BoundArguments.__dict__.__class__.__name__ via inspmore77; new to extra77"]

# ---------------------------------------------------------------------------
# BoundArguments __dict__ property presence — extra77
#
# Wave 243 theme: BoundArguments __dict__ contains args/kwargs/apply_defaults.
#
# inspect.BoundArguments.__dict__.__contains__('args')          == True
# inspect.BoundArguments.__dict__.__contains__('kwargs')        == True
# inspect.BoundArguments.__dict__.__contains__('apply_defaults') == True
#
# No prior inspect spec checks BoundArguments.__dict__ property keys via inspmore77. New to extra77.
# ---------------------------------------------------------------------------

table inspect_extra77.BoundArguments_dict_properties:
  description: "BoundArguments.__dict__.__contains__('args')==True, 'kwargs'==True, 'apply_defaults'==True; wave 243 BoundArguments __dict__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore77

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_dict_contains_args,
       BoundArguments.__dict__.__contains__,
       ["args"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('args') == True — BoundArguments.args is a property defined in the BoundArguments class body in Lib/inspect.py that returns the positional arguments as a tuple; mappingproxy.__contains__('args') returns True; no prior inspect spec checks BoundArguments.__dict__.__contains__('args') via inspmore77; new to extra77"]
    - [BoundArguments_dict_contains_kwargs,
       BoundArguments.__dict__.__contains__,
       ["kwargs"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('kwargs') == True — BoundArguments.kwargs is a property defined in the BoundArguments class body in Lib/inspect.py that returns the keyword arguments as a dict; mappingproxy.__contains__('kwargs') returns True; no prior inspect spec checks BoundArguments.__dict__.__contains__('kwargs') via inspmore77; new to extra77"]
    - [BoundArguments_dict_contains_apply_defaults,
       BoundArguments.__dict__.__contains__,
       ["apply_defaults"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('apply_defaults') == True — BoundArguments.apply_defaults() is a method defined in the BoundArguments class body in Lib/inspect.py that sets default values for missing arguments; mappingproxy.__contains__('apply_defaults') returns True; no prior inspect spec checks BoundArguments.__dict__.__contains__('apply_defaults') via inspmore77; new to extra77"]

# ---------------------------------------------------------------------------
# getclosurevars and getsourcelines code objects — extra77
#
# Wave 243 theme: getclosurevars/getsourcelines code object attributes.
#
# inspect.getclosurevars.__code__.co_name     == 'getclosurevars'
# inspect.getclosurevars.__code__.co_argcount == 1
# inspect.getsourcelines.__code__.co_name     == 'getsourcelines'
# inspect.getsourcelines.__code__.co_argcount == 1
#
# No prior inspect spec checks getclosurevars/getsourcelines code objects via inspmore77. New to extra77.
# ---------------------------------------------------------------------------

table inspect_extra77.getclosurevars_getsourcelines_code:
  description: "getclosurevars.__code__.co_name=='getclosurevars', co_argcount==1; getsourcelines same; wave 243 code object attrs; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore77

  columns: [id, function, args, expected, description]
  rows:
    - [getclosurevars_code_co_name_eq_getclosurevars,
       getclosurevars.__code__.co_name.__eq__,
       ["getclosurevars"],
       true,
       "inspect.getclosurevars.__code__.co_name.__eq__('getclosurevars') == True — getclosurevars is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'getclosurevars' (14 chars); str.__eq__('getclosurevars') returns True; no prior inspect spec checks getclosurevars.__code__.co_name via inspmore77; new to extra77"]
    - [getclosurevars_code_co_argcount_eq_1,
       getclosurevars.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getclosurevars.__code__.co_argcount.__eq__(1) == True — getclosurevars(func) takes exactly one positional argument 'func'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getclosurevars.__code__.co_argcount via inspmore77; new to extra77"]
    - [getsourcelines_code_co_name_eq_getsourcelines,
       getsourcelines.__code__.co_name.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__code__.co_name.__eq__('getsourcelines') == True — getsourcelines is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'getsourcelines' (14 chars); str.__eq__('getsourcelines') returns True; no prior inspect spec checks getsourcelines.__code__.co_name via inspmore77; new to extra77"]
    - [getsourcelines_code_co_argcount_eq_1,
       getsourcelines.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getsourcelines.__code__.co_argcount.__eq__(1) == True — getsourcelines(object) takes exactly one positional argument 'object'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getsourcelines.__code__.co_argcount via inspmore77; new to extra77"]

# ---------------------------------------------------------------------------
# getfile and getmodule code objects — extra77
#
# Wave 243 theme: getfile/getmodule code object attributes.
#
# inspect.getfile.__code__.co_name      == 'getfile'
# inspect.getfile.__code__.co_argcount  == 1
# inspect.getmodule.__code__.co_name    == 'getmodule'
# inspect.getmodule.__code__.co_argcount == 2
#
# No prior inspect spec checks getfile/getmodule code objects via inspmore77. New to extra77.
# ---------------------------------------------------------------------------

table inspect_extra77.getfile_getmodule_code:
  description: "getfile.__code__.co_name=='getfile', co_argcount==1; getmodule co_name=='getmodule', co_argcount==2; wave 243 code object attrs; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore77

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_code_co_name_eq_getfile,
       getfile.__code__.co_name.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__code__.co_name.__eq__('getfile') == True — getfile is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'getfile' (7 chars); str.__eq__('getfile') returns True; no prior inspect spec checks getfile.__code__.co_name via inspmore77; new to extra77"]
    - [getfile_code_co_argcount_eq_1,
       getfile.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile(object) takes exactly one positional argument 'object'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getfile.__code__.co_argcount via inspmore77; new to extra77"]
    - [getmodule_code_co_name_eq_getmodule,
       getmodule.__code__.co_name.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__code__.co_name.__eq__('getmodule') == True — getmodule is a pure-Python function defined in Lib/inspect.py; its code object's co_name attribute records the function name 'getmodule' (9 chars); str.__eq__('getmodule') returns True; no prior inspect spec checks getmodule.__code__.co_name via inspmore77; new to extra77"]
    - [getmodule_code_co_argcount_eq_2,
       getmodule.__code__.co_argcount.__eq__,
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule(object, _filename=None) takes two positional arguments 'object' and '_filename'; the code object's co_argcount is 2; int.__eq__(2) returns True; no prior inspect spec checks getmodule.__code__.co_argcount via inspmore77; new to extra77"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra77
# ---------------------------------------------------------------------------

invariant inspect_extra77.BoundArguments_dict_class_name:
  description: "inspect.BoundArguments.__dict__.__class__.__name__.__eq__('mappingproxy') == True — BoundArguments class namespace is a mappingproxy; wave 243 BoundArguments __dict__ content; new to extra77"
  kind: python_call_eq
  function: BoundArguments.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant inspect_extra77.BoundArguments_dict_contains_args:
  description: "inspect.BoundArguments.__dict__.__contains__('args') == True — BoundArguments class namespace contains 'args' property; wave 243 BoundArguments __dict__ content; new to extra77"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["args"]
  expected: true

invariant inspect_extra77.BoundArguments_dict_contains_apply_defaults:
  description: "inspect.BoundArguments.__dict__.__contains__('apply_defaults') == True — BoundArguments class namespace contains 'apply_defaults'; wave 243 BoundArguments __dict__ content; new to extra77"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["apply_defaults"]
  expected: true

invariant inspect_extra77.getclosurevars_code_co_argcount:
  description: "inspect.getclosurevars.__code__.co_argcount.__eq__(1) == True — getclosurevars takes one argument; wave 243 code object attrs; new to extra77"
  kind: python_call_eq
  function: getclosurevars.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra77.getmodule_code_co_argcount:
  description: "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule takes two arguments (object, _filename); wave 243 code object attrs; new to extra77"
  kind: python_call_eq
  function: getmodule.__code__.co_argcount.__eq__
  args: [2]
  expected: true
