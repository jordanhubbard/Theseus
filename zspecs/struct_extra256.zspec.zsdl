spec: struct_extra256
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct.zspec.zsdl covers: pack/unpack vectors for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize for H/I/Q/HI/HIQ/q/h/b/?/e; roundtrip for >q/>Q/>H/<I/>BHI; error cases (wrong buffer size)."
    - "struct_extra.zspec.zsdl covers: Struct format/size attrs; calcsize for f/d/B/4s/BHI; pack_into/__name__; unpack_from; iter_unpack; error.__name__; error base class."
    - "Format 'c' (char): packs/unpacks a single byte as a bytes object of length 1. calcsize('c') == 1."
    - "Format 's' (string): without count prefix behaves identically to '1s'. calcsize('s') == 1."
    - "Format '4s': packs/unpacks exactly 4 bytes as a single bytes object. calcsize('4s') == 4."
    - "struct.pack('c', b'A') == b'\\x41'; struct.pack('4s', b'test') == b'test' (0x74657374)."
    - "struct.unpack('c', b'A') returns (b'A',) — a tuple with one bytes element."
    - "struct.unpack('4s', b'test') returns (b'test',) — a tuple with one bytes element."
    - "struct.error is raised when pack('c', ...) receives a bytes object that is not exactly 1 byte."
    - "struct.error is raised when unpack buffer size does not match calcsize for the format."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# calcsize — 'c' and 's' format characters (not covered in prior specs)
# struct_extra covers calcsize('4s')==4 already; 'c' and 's' are new.
# ---------------------------------------------------------------------------

table struct_extra256.calcsize.char_string_formats:
  description: "calcsize for char 'c' and string 's' format characters"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: calcsize

  columns: [id, args, expected]
  rows:
    - [c_char,   ["c"],   1]
    - [s_string, ["s"],   1]

# ---------------------------------------------------------------------------
# pack — 'c' format: packs a single byte as bytes
# ---------------------------------------------------------------------------

invariant struct_extra256.pack.c_A:
  description: "struct.pack('c', b'A').hex() == '41' — character 'A' is ASCII 0x41"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: ["c", !hex 41]
  method: hex
  method_args: []
  expected: "41"

# ---------------------------------------------------------------------------
# pack — '4s' format: packs 4 bytes as a bytes object
# ---------------------------------------------------------------------------

invariant struct_extra256.pack.four_s_test:
  description: "struct.pack('4s', b'test').hex() == '74657374' — b'test' as 4-byte string field"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: ["4s", !hex 74657374]
  method: hex
  method_args: []
  expected: "74657374"

# ---------------------------------------------------------------------------
# unpack — 'c' format: returns (b'A',) tuple
# ---------------------------------------------------------------------------

invariant struct_extra256.unpack.c_A:
  description: "struct.unpack('c', b'A') == (b'A',) — unpack single char returns 1-tuple"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: ["c", !hex 41]
  expected: [!hex 41]

# ---------------------------------------------------------------------------
# unpack — '4s' format: returns (b'test',) tuple
# ---------------------------------------------------------------------------

invariant struct_extra256.unpack.four_s_test:
  description: "struct.unpack('4s', b'test') == (b'test',) — unpack 4-byte string field"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: ["4s", !hex 74657374]
  expected: [!hex 74657374]

# ---------------------------------------------------------------------------
# struct.error — raised when 'c' format receives wrong-size input
# 'c' requires exactly 1 byte; passing a 2-byte value raises struct.error.
# ---------------------------------------------------------------------------

invariant struct_extra256.error.c_too_many_bytes:
  description: "struct.pack('c', b'AB') raises struct.error — 'c' format requires exactly 1 byte"
  category: error
  kind: python_call_raises
  function: pack
  args: ["c", !hex 4142]
  raises: struct.error

# ---------------------------------------------------------------------------
# struct.error — raised when unpack buffer does not match format size
# unpack('c', b'AB') has 2 bytes but 'c' requires exactly 1.
# ---------------------------------------------------------------------------

invariant struct_extra256.error.unpack_c_too_many_bytes:
  description: "struct.unpack('c', b'AB') raises struct.error — buffer must be exactly 1 byte for 'c'"
  category: error
  kind: python_call_raises
  function: unpack
  args: ["c", !hex 4142]
  raises: struct.error
