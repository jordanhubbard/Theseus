spec: inspect_extra1486
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 546 theme: __enter__ and __exit__ context manager protocol checks for inspect classes."
    - "inspect.Parameter: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "inspect.Signature: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "inspect.BoundArguments: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "inspect.Parameter, Signature, and BoundArguments are introspection data containers; none implement the context manager protocol."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — __enter__ and __exit__ absence checks
#
# Wave 546 theme: inspect.Parameter — represents a parameter in a function
# signature (name, kind, default, annotation).
#
# inspect.Parameter.__dict__.__contains__("__enter__") == False
# inspect.Parameter.__dict__.__contains__("__exit__") == False
#
# Parameter is an immutable introspection object that describes one parameter
# of a function's signature. It is not a context manager. New to extra1486.
# ---------------------------------------------------------------------------

table inspect_extra1486.parameter_context_manager_absence:
  description: "inspect.Parameter has no __enter__ or __exit__ in __dict__; Parameter is a signature introspection object, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1486pa

  columns: [id, function, args, expected, description]
  rows:
    - [in1486pa001,
       "Parameter.__dict__.__contains__",
       ["__enter__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__enter__') == False — Parameter is an immutable object describing a single function parameter including its name, kind (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, etc.), default value, and annotation; it does not implement the context manager protocol; __enter__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1486"]
    - [in1486pa002,
       "Parameter.__dict__.__contains__",
       ["__exit__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__exit__') == False — Parameter cannot be used as a context manager; __exit__ is not defined in Parameter.__dict__; verified with Python 3.12; new to extra1486"]
    - [in1486pa003,
       "Parameter.__dict__.__contains__",
       ["name"],
       true,
       "inspect.Parameter.__dict__.__contains__('name') == True — Parameter defines the 'name' attribute as a property in its __dict__ for accessing the parameter name; verified with Python 3.12; new to extra1486"]
    - [in1486pa004,
       "Parameter.__dict__.__contains__",
       ["default"],
       true,
       "inspect.Parameter.__dict__.__contains__('default') == True — Parameter defines the 'default' attribute as a property in its __dict__ for accessing the parameter's default value; verified with Python 3.12; new to extra1486"]
    - [in1486pa005,
       "Parameter.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a class object whose metaclass is the built-in type; str.__eq__('type') returns True; new to extra1486"]
    - [in1486pa006,
       "Parameter.__dict__.__contains__",
       ["annotation"],
       true,
       "inspect.Parameter.__dict__.__contains__('annotation') == True — Parameter defines the 'annotation' attribute as a property in its __dict__ for accessing the parameter's type annotation; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature — __enter__ and __exit__ absence checks
#
# Wave 546 theme: inspect.Signature — represents the call signature of a
# callable object, containing a collection of Parameter objects.
#
# inspect.Signature.__dict__.__contains__("__enter__") == False
# inspect.Signature.__dict__.__contains__("__exit__") == False
#
# Signature is an introspection object that encapsulates a callable's full
# parameter list and return annotation. It is not a context manager.
# New to extra1486.
# ---------------------------------------------------------------------------

table inspect_extra1486.signature_context_manager_absence:
  description: "inspect.Signature has no __enter__ or __exit__ in __dict__; Signature is a call-signature introspection object, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1486si

  columns: [id, function, args, expected, description]
  rows:
    - [in1486si001,
       "Signature.__dict__.__contains__",
       ["__enter__"],
       false,
       "inspect.Signature.__dict__.__contains__('__enter__') == False — Signature is an immutable object that encapsulates a callable's full parameter list and return annotation; it does not implement the context manager protocol; __enter__ is not in Signature.__dict__; verified with Python 3.12; new to extra1486"]
    - [in1486si002,
       "Signature.__dict__.__contains__",
       ["__exit__"],
       false,
       "inspect.Signature.__dict__.__contains__('__exit__') == False — Signature cannot be used as a context manager; __exit__ is not defined in Signature.__dict__; verified with Python 3.12; new to extra1486"]
    - [in1486si003,
       "Signature.__dict__.__contains__",
       ["parameters"],
       true,
       "inspect.Signature.__dict__.__contains__('parameters') == True — Signature defines 'parameters' as a property in its __dict__ that returns an ordered mapping of parameter names to Parameter objects; verified with Python 3.12; new to extra1486"]
    - [in1486si004,
       "Signature.__dict__.__contains__",
       ["return_annotation"],
       true,
       "inspect.Signature.__dict__.__contains__('return_annotation') == True — Signature defines 'return_annotation' as a property in its __dict__ for accessing the return type annotation; verified with Python 3.12; new to extra1486"]
    - [in1486si005,
       "Signature.__dict__.__contains__",
       ["bind"],
       true,
       "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines 'bind' as a method in its __dict__ for mapping positional and keyword arguments to parameters; verified with Python 3.12; new to extra1486"]
    - [in1486si006,
       "Signature.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — Signature is a class object whose metaclass is the built-in type; str.__eq__('type') returns True; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments — __enter__ and __exit__ absence checks
#
# Wave 546 theme: inspect.BoundArguments — the result of Signature.bind(),
# mapping parameters to the actual arguments supplied in a call.
#
# inspect.BoundArguments.__dict__.__contains__("__enter__") == False
# inspect.BoundArguments.__dict__.__contains__("__exit__") == False
#
# BoundArguments holds the mapping produced when positional and keyword
# arguments are bound to the parameters of a Signature. It is not a
# context manager. New to extra1486.
# ---------------------------------------------------------------------------

table inspect_extra1486.boundarguments_context_manager_absence:
  description: "inspect.BoundArguments has no __enter__ or __exit__ in __dict__; BoundArguments is a bound-call introspection object, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1486ba

  columns: [id, function, args, expected, description]
  rows:
    - [in1486ba001,
       "BoundArguments.__dict__.__contains__",
       ["__enter__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__enter__') == False — BoundArguments is an introspection container produced by Signature.bind() that maps parameter names to the argument values supplied in a specific call; it does not implement the context manager protocol; __enter__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1486"]
    - [in1486ba002,
       "BoundArguments.__dict__.__contains__",
       ["__exit__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__exit__') == False — BoundArguments cannot be used as a context manager; __exit__ is not defined in BoundArguments.__dict__; verified with Python 3.12; new to extra1486"]
    - [in1486ba003,
       "BoundArguments.__dict__.__contains__",
       ["arguments"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('arguments') == True — BoundArguments defines 'arguments' as a property in its __dict__ that returns a mutable ordered mapping of parameter names to argument values; verified with Python 3.12; new to extra1486"]
    - [in1486ba004,
       "BoundArguments.__dict__.__contains__",
       ["args"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('args') == True — BoundArguments defines 'args' as a property in its __dict__ that returns a tuple of positional arguments values; verified with Python 3.12; new to extra1486"]
    - [in1486ba005,
       "BoundArguments.__dict__.__contains__",
       ["kwargs"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('kwargs') == True — BoundArguments defines 'kwargs' as a property in its __dict__ that returns a dict of keyword argument values; verified with Python 3.12; new to extra1486"]
    - [in1486ba006,
       "BoundArguments.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments is a class object whose metaclass is the built-in type; str.__eq__('type') returns True; new to extra1486"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1486
# ---------------------------------------------------------------------------

invariant inspect_extra1486.parameter_no_enter:
  description: "inspect.Parameter.__dict__ does not contain '__enter__' — Parameter is a signature introspection object, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant inspect_extra1486.parameter_no_exit:
  description: "inspect.Parameter.__dict__ does not contain '__exit__' — Parameter does not implement the context manager protocol; wave 546; new to extra1486"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__exit__"]
  expected: false

invariant inspect_extra1486.signature_no_enter:
  description: "inspect.Signature.__dict__ does not contain '__enter__' — Signature is a call-signature introspection object, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant inspect_extra1486.signature_no_exit:
  description: "inspect.Signature.__dict__ does not contain '__exit__' — Signature does not implement the context manager protocol; wave 546; new to extra1486"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__exit__"]
  expected: false

invariant inspect_extra1486.boundarguments_no_enter:
  description: "inspect.BoundArguments.__dict__ does not contain '__enter__' — BoundArguments is a bound-call container, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant inspect_extra1486.boundarguments_no_exit:
  description: "inspect.BoundArguments.__dict__ does not contain '__exit__' — BoundArguments does not implement the context manager protocol; wave 546; new to extra1486"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__exit__"]
  expected: false
