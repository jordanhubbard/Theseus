spec: select_extra2
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl and select_extra.zspec.zsdl."
    - "select.select is a C builtin; __name__ == 'select' and __module__ == 'select'."
    - "select.error.__name__ == 'OSError' — select.error IS OSError (an alias), so __name__ is 'OSError'."
    - "select.error.__bases__[0].__name__ == 'Exception' — OSError inherits directly from Exception."
    - "On macOS, POLLIN == 1 and POLLOUT == 4 (these values are platform-defined; verified on Darwin 25.4.0)."
    - "KQ_FILTER_READ == -1 and KQ_FILTER_WRITE == -2 on macOS/BSD — kqueue filter identifiers are negative integers."
    - "KQ_EV_ADD == 1, KQ_EV_DELETE == 2, KQ_EV_ENABLE == 4, KQ_EV_DISABLE == 8 — standard kqueue EV flags."
    - "All constants are integers (type int). Verified on macOS/Darwin 25.4.0 with Python 3.12, 2026-04-09."
    - "POLLIN and POLLOUT exist on macOS via the poll compatibility interface; they may not exist on all POSIX platforms."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# select.select — function name and module
# ---------------------------------------------------------------------------

invariant select_extra2.select.name:
  description: "select.select.__name__ == 'select'"
  category: functions
  kind: python_call_eq
  function: select.__name__.__eq__
  args: ["select"]
  expected: true

invariant select_extra2.select.module:
  description: "select.select.__module__ == 'select' — C builtin reports 'select' as its module"
  category: functions
  kind: python_call_eq
  function: select.__module__.__eq__
  args: ["select"]
  expected: true

# ---------------------------------------------------------------------------
# select.error — class name and base class
#
# select.error is an alias for OSError. Its __name__ is 'OSError' (the class's
# own __name__, not the alias name), and it inherits directly from Exception.
# ---------------------------------------------------------------------------

invariant select_extra2.error.name:
  description: "select.error.__name__ == 'OSError' — select.error is an alias for OSError"
  category: exceptions
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant select_extra2.error.base_class:
  description: "select.error.__bases__[0].__name__ == 'Exception' — OSError inherits directly from Exception"
  category: exceptions
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# POLLIN and POLLOUT — integer constants (macOS/Linux)
#
# On macOS (Darwin): POLLIN == 1, POLLOUT == 4.
# These constants are exposed on macOS via the poll compatibility interface.
# ---------------------------------------------------------------------------

invariant select_extra2.POLLIN.is_int:
  description: "select.POLLIN.__class__.__name__ == 'int' — POLLIN is an integer constant"
  category: constants
  kind: python_call_eq
  function: POLLIN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra2.POLLIN.value:
  description: "select.POLLIN == 1 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: POLLIN.__eq__
  args: [1]
  expected: true

invariant select_extra2.POLLOUT.is_int:
  description: "select.POLLOUT.__class__.__name__ == 'int' — POLLOUT is an integer constant"
  category: constants
  kind: python_call_eq
  function: POLLOUT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra2.POLLOUT.value:
  description: "select.POLLOUT == 4 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: POLLOUT.__eq__
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# KQ_FILTER_READ — macOS/BSD kqueue filter constant
#
# KQ_FILTER_READ == -1 on macOS. Kqueue filter identifiers are negative integers.
# ---------------------------------------------------------------------------

invariant select_extra2.KQ_FILTER_READ.is_int:
  description: "select.KQ_FILTER_READ.__class__.__name__ == 'int' — KQ_FILTER_READ is an integer constant"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_READ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra2.KQ_FILTER_READ.value:
  description: "select.KQ_FILTER_READ == -1 on macOS/BSD"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_READ.__eq__
  args: [-1]
  expected: true

# ---------------------------------------------------------------------------
# KQ_FILTER_WRITE — macOS/BSD kqueue filter constant
# ---------------------------------------------------------------------------

invariant select_extra2.KQ_FILTER_WRITE.value:
  description: "select.KQ_FILTER_WRITE == -2 on macOS/BSD"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_WRITE.__eq__
  args: [-2]
  expected: true

# ---------------------------------------------------------------------------
# KQ_EV_* flag constants — standard kqueue event action flags (macOS/BSD)
# ---------------------------------------------------------------------------

table select_extra2.kq_ev_flags:
  kind: python_call_eq
  category: constants
  id_prefix: kqev

  columns: [id, function, args, expected]
  rows:
    - [add,     KQ_EV_ADD.__eq__,     [1], true]
    - [delete,  KQ_EV_DELETE.__eq__,  [2], true]
    - [enable,  KQ_EV_ENABLE.__eq__,  [4], true]
    - [disable, KQ_EV_DISABLE.__eq__, [8], true]
