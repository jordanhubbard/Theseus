spec: typing_extra5
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 544 — Protocols"
    - "PEP 591 — Adding a final qualifier to typing"
    - "PEP 681 — Data Class Transforms"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "Extends typing.zspec.zsdl through typing_extra4.zspec.zsdl."
    - "Previous specs cover: type alias names (List, Dict, etc.), get_type_hints/cast/overload/final/runtime_checkable/get_origin/get_args function names, TypeVar/Generic/Protocol/TypedDict/NamedTuple class names, Literal/_SpecialForm, Annotated, ForwardRef, TypeVar __name__/__bound__/__qualname__/__module__."
    - "typing.get_type_hints.__module__ == 'typing'."
    - "typing.cast.__module__ == 'typing'."
    - "typing.overload.__module__ == 'typing'."
    - "typing.final.__module__ == 'typing' (Python 3.8+)."
    - "typing.runtime_checkable.__module__ == 'typing'."
    - "typing.dataclass_transform.__module__ == 'typing' (Python 3.12+)."
    - "typing.get_origin.__module__ == 'typing'."
    - "typing.get_args.__module__ == 'typing'."
    - "typing.TypeVar.__module__ == 'typing' — already in extra4, confirmed here via module category."
    - "typing.Generic.__module__ == 'typing'."
    - "typing.Protocol.__module__ == 'typing'."
    - "typing.TypedDict.__module__ == 'typing'."
    - "typing.NamedTuple.__module__ == 'typing'."
    - "typing.TYPE_CHECKING.__class__.__name__ == 'bool' — TYPE_CHECKING is a plain bool constant."
    - "typing.Any.__class__.__name__ == '_SpecialForm' — Any is a _SpecialForm, not a type."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module affiliation — public functions
#
# All public callable helpers in typing must have __module__ == 'typing'.
# ---------------------------------------------------------------------------

invariant typing_extra5.get_type_hints.module:
  description: "typing.get_type_hints.__module__ == 'typing'"
  category: module
  kind: python_call_eq
  function: get_type_hints.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra5.cast.module:
  description: "typing.cast.__module__ == 'typing'"
  category: module
  kind: python_call_eq
  function: cast.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra5.overload.module:
  description: "typing.overload.__module__ == 'typing'"
  category: module
  kind: python_call_eq
  function: overload.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra5.final.module:
  description: "typing.final.__module__ == 'typing'"
  category: module
  kind: python_call_eq
  function: final.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra5.runtime_checkable.module:
  description: "typing.runtime_checkable.__module__ == 'typing'"
  category: module
  kind: python_call_eq
  function: runtime_checkable.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra5.get_origin.module:
  description: "typing.get_origin.__module__ == 'typing'"
  category: module
  kind: python_call_eq
  function: get_origin.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra5.get_args.module:
  description: "typing.get_args.__module__ == 'typing'"
  category: module
  kind: python_call_eq
  function: get_args.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra5.dataclass_transform.module:
  description: "typing.dataclass_transform.__module__ == 'typing' (Python 3.12+)"
  category: module
  version: ">=3.12"
  kind: python_call_eq
  function: dataclass_transform.__module__.__eq__
  args: ["typing"]
  expected: true

