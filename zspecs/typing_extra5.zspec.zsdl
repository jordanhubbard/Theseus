  expected: true

# ---------------------------------------------------------------------------
# TYPE_CHECKING — is a bool constant
#
# typing.TYPE_CHECKING is False at runtime (True only under type checkers).
# Its class name is 'bool', confirming it is a plain Python boolean.
# ---------------------------------------------------------------------------

invariant typing_extra5.TYPE_CHECKING.class_name:
  description: "typing.TYPE_CHECKING.__class__.__name__ == 'bool'"
  category: constants
  kind: python_call_eq
  function: TYPE_CHECKING.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant typing_extra5.TYPE_CHECKING.value_false:
  description: "typing.TYPE_CHECKING == False at runtime"
  category: constants
  kind: python_call_eq
  function: TYPE_CHECKING.__eq__
  args: [false]
  expected: true

# ---------------------------------------------------------------------------
# Any — is a _SpecialForm
#
# typing.Any is not a regular class or type. It is a _SpecialForm instance.
# Its __class__.__name__ == '_SpecialForm'.
# ---------------------------------------------------------------------------

invariant typing_extra5.Any.class_name:
  description: "typing.Any.__class__.__name__ == '_SpecialForm'"
  category: special_forms
  kind: python_call_eq
  function: Any.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
