spec: abc_extra37
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra36.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC/__abstractmethods__/__class__/__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables, abstractmethod/__name__=='abstractmethod' (extra34), get_cache_token/__module__=='_abc' (extra34), ABC/__name__=='ABC' (extra34), ABC/__bases__[0].__name__=='object' (extra34), ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type' (extra35), ABCMeta.register/__qualname__.__len__()==16 (extra35), ABCMeta/__mro__.__len__()==3, ABC/__mro__.__len__()==2, ABC/__mro__[1].__name__=='object' (extra35), ABCMeta MRO entries [0]/'ABCMeta', [1]/'type', [2]/'object', ABC/__mro__[0].__name__=='ABC', abstractmethod/__qualname__.__len__()==14, abstractproperty/__name__=='abstractproperty'/__module__=='abc', abstractclassmethod/__name__=='abstractclassmethod'/__module__=='abc' (extra36)."
    - "This spec covers: abstractproperty.__qualname__=='abstractproperty'; abstractproperty.__qualname__.__len__()==16; abstractproperty.__bases__[0].__name__=='property'; abstractclassmethod.__bases__[0].__name__=='classmethod'; abstractstaticmethod.__name__=='abstractstaticmethod'; abstractstaticmethod.__bases__[0].__name__=='staticmethod'; ABC.__qualname__=='ABC'; ABC.__qualname__.__len__()==3."
    - "abc.abstractproperty.__qualname__ == 'abstractproperty' (16 chars). For top-level classes, __qualname__ equals __name__. abstractproperty is a top-level class in the abc module, so __qualname__ == __name__ == 'abstractproperty'. Prior specs measured __qualname__.__len__() in other namespaces; extra37 captures the string equality and length in this namespace."
    - "abc.abstractproperty.__bases__[0].__name__ == 'property'. abstractproperty inherits from Python's built-in property class. This makes it a property subclass decorated with abstract method semantics. Deprecated since Python 3.3; use @property combined with @abstractmethod instead."
    - "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod'. abstractclassmethod inherits from Python's built-in classmethod class. Deprecated since Python 3.3; use @classmethod combined with @abstractmethod instead."
    - "abc.abstractstaticmethod exists in Python 3.14 (deprecated since Python 3.3). abstractstaticmethod.__name__ == 'abstractstaticmethod' (20 chars) and abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'. It inherits from Python's built-in staticmethod class. Deprecated since Python 3.3; use @staticmethod combined with @abstractmethod instead."
    - "abc.ABC.__qualname__ == 'ABC' (3 chars). ABC is a top-level class in the abc module, so __qualname__ equals __name__ equals 'ABC'. len('ABC') == 3. Prior specs measured ABC.__qualname__.__len__() in other namespaces; extra37 captures string equality and length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractproperty __qualname__ and base class — extra37 namespace
#
# abstractproperty.__qualname__        == 'abstractproperty'  (16 chars)
# abstractproperty.__qualname__.__len__() == 16
# abstractproperty.__bases__[0].__name__ == 'property'
# abstractproperty is a deprecated abstract decorator class that inherits from
# Python's built-in property class. It has been in the module since before
# Python 3.0 and remains for backward compatibility as of Python 3.14.
# 'abstractproperty': a-b-s-t-r-a-c-t-p-r-o-p-e-r-t-y = 16 chars.
# ---------------------------------------------------------------------------

table abc_extra37.abstractproperty_qualname:
  description: "abc.abstractproperty __qualname__ and base class in extra37 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: abcabspropqn37

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_eq,  abstractproperty.__qualname__.__eq__,              ["abstractproperty"], true, "abstractproperty.__qualname__ == 'abstractproperty' — top-level class; qualname equals name (16 chars)"]
    - [qualname_len, abstractproperty.__qualname__.__len__,             [],                  16,   "abstractproperty.__qualname__.__len__() == 16 — 'abstractproperty' has 16 characters"]
    - [bases0,       "abstractproperty.__bases__[0].__name__.__eq__",   ["property"],         true, "abstractproperty.__bases__[0].__name__ == 'property' — inherits from built-in property; deprecated since Python 3.3"]

# ---------------------------------------------------------------------------
# abc deprecated abstract class base classes — extra37 namespace
#
# abstractclassmethod.__bases__[0].__name__ == 'classmethod'
# abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'
# Both deprecated abstract decorator classes inherit from their corresponding
# built-in decorator class. abstractclassmethod extends classmethod;
# abstractstaticmethod extends staticmethod. Both deprecated since Python 3.3.
# Use @classmethod/@staticmethod combined with @abstractmethod in modern code.
# ---------------------------------------------------------------------------

table abc_extra37.deprecated_abstract_base_classes:
  description: "abc deprecated abstract decorator class base class names in extra37 namespace — abstractclassmethod and abstractstaticmethod"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdeprabsbase37

  columns: [id, function, args, expected, description]
  rows:
    - [abstractclassmethod_base,  "abstractclassmethod.__bases__[0].__name__.__eq__",  ["classmethod"],  true, "abstractclassmethod.__bases__[0].__name__ == 'classmethod' — extends built-in classmethod; deprecated since Python 3.3"]
    - [abstractstaticmethod_base, "abstractstaticmethod.__bases__[0].__name__.__eq__", ["staticmethod"], true, "abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' — extends built-in staticmethod; deprecated since Python 3.3"]

# ---------------------------------------------------------------------------
# abc.abstractstaticmethod identity — extra37 namespace
#
# abstractstaticmethod.__name__ == 'abstractstaticmethod' (20 chars)
# abstractstaticmethod is deprecated since Python 3.3 but still present in
# Python 3.14. It extends Python's built-in staticmethod class and adds
# abstract method semantics. Use @staticmethod + @abstractmethod in modern code.
# 'abstractstaticmethod': a-b-s-t-r-a-c-t-s-t-a-t-i-c-m-e-t-h-o-d = 20 chars.
# ---------------------------------------------------------------------------

invariant abc_extra37.abstractstaticmethod_name_eq:
  description: "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' — deprecated abstract static method decorator; still present in Python 3.14 for backward compatibility (20 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__name__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABC __qualname__ — extra37 namespace
#
# ABC.__qualname__ == 'ABC' (3 chars)
# ABC.__qualname__.__len__() == 3
# ABC is a top-level helper class in the abc module. For top-level classes,
# __qualname__ equals __name__. Both are 'ABC' (3 chars: A-B-C).
# Prior specs measured __qualname__.__len__() in other namespaces; extra37
# captures both the string equality and the length in this namespace.
# ---------------------------------------------------------------------------

table abc_extra37.ABC_qualname:
  description: "abc.ABC __qualname__ string equality and length in extra37 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: abcabcqualname37

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_eq,  ABC.__qualname__.__eq__,  ["ABC"], true, "ABC.__qualname__ == 'ABC' — top-level class qualname equals name (3 chars)"]
    - [qualname_len, ABC.__qualname__.__len__, [],      3,    "ABC.__qualname__.__len__() == 3 — 'ABC' has 3 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra37
# ---------------------------------------------------------------------------

invariant abc_extra37.abstractproperty_qualname_eq:
  description: "abc.abstractproperty.__qualname__ == 'abstractproperty' — deprecated abstract property decorator; top-level class so qualname equals name (16 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__qualname__.__eq__
  args: ["abstractproperty"]
  expected: true

invariant abc_extra37.abstractproperty_qualname_len:
  description: "abc.abstractproperty.__qualname__.__len__() == 16 — 'abstractproperty' has 16 characters"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__qualname__.__len__
  args: []
  expected: 16

invariant abc_extra37.abstractproperty_bases0_name_eq:
  description: "abc.abstractproperty.__bases__[0].__name__ == 'property' — abstractproperty inherits from the built-in property class; deprecated since Python 3.3"
  category: class_names
  kind: python_call_eq
  function: "abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true

invariant abc_extra37.abstractclassmethod_bases0_name_eq:
  description: "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod' — abstractclassmethod inherits from the built-in classmethod class; deprecated since Python 3.3"
  category: class_names
  kind: python_call_eq
  function: "abstractclassmethod.__bases__[0].__name__.__eq__"
  args: ["classmethod"]
  expected: true

invariant abc_extra37.abstractstaticmethod_bases0_name_eq:
  description: "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' — abstractstaticmethod inherits from the built-in staticmethod class; deprecated since Python 3.3"
  category: class_names
  kind: python_call_eq
  function: "abstractstaticmethod.__bases__[0].__name__.__eq__"
  args: ["staticmethod"]
  expected: true

invariant abc_extra37.ABC_qualname_eq:
  description: "abc.ABC.__qualname__ == 'ABC' — top-level helper class; qualname equals name (3 chars)"
  category: class_names
  kind: python_call_eq
  function: ABC.__qualname__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra37.ABC_qualname_len:
  description: "abc.ABC.__qualname__.__len__() == 3 — 'ABC' has 3 characters"
  category: class_names
  kind: python_call_eq
  function: ABC.__qualname__.__len__
  args: []
  expected: 3
