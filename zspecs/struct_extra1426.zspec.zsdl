spec: struct_extra1426
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra142.zspec.zsdl — covers struct.__all__ class name/length/membership / struct.__spec__.name / struct.__loader__.__class__.__name__ / Struct.__init__/__repr__/__sizeof__ qualnames and class names (table + invariants)."
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') and __len__()==6 / Struct.__bases__[0].__name__.__eq__('object') / Struct.__mro__.__len__()==2 / Struct.__doc__.__len__()==40 / Struct.__dict__.__class__.__name__.__eq__('mappingproxy') / error.__qualname__.__eq__('error') and __len__()==5 (table + invariants)."
    - "struct_extra140.zspec.zsdl — covers struct.Struct.format/__class__.__name__.__eq__('getset_descriptor') / Struct.size/__class__.__name__.__eq__('getset_descriptor') / Struct.format/__qualname__.__eq__('Struct.format') and __len__()==13 / Struct.size/__qualname__.__eq__('Struct.size') and __len__()==11 / struct.__doc__.__len__()==1278 / struct.error/__doc__ is None (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in any prior struct spec."
    - "Wave 542 theme: __format__ and __dir__ method type and dict-presence checks for struct.Struct and struct.error."
    - "struct.Struct.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__format__ in struct.Struct.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__dir__ in struct.Struct.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__format__ in struct.error.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__dir__ in struct.error.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Both struct.Struct and struct.error inherit __format__ and __dir__ from object without overriding them. Struct is a C-level type from _struct.c; error is a Python-level Exception subclass. Neither defines its own __format__ or __dir__. Therefore both report 'method_descriptor' (the type of the C-level methods on object) and both have __dict__.__contains__ returning False for these dunders."
    - "struct.Struct.__mro__ is [Struct, object] (length 2 per struct_extra93/141); struct.error.__mro__ is [error, Exception, BaseException, object] (length 4). Neither intermediate class in error's MRO defines __format__ or __dir__, so the object C-level method_descriptor is reached for both."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__format__.__class__.__name__ == 'method_descriptor'
# struct.Struct.__dir__.__class__.__name__ == 'method_descriptor'
#
# Wave 542 theme: __format__ and __dir__ type checks on struct.Struct.
#
# struct.Struct is a C-level type from _struct.c. Its MRO is [Struct, object].
# Neither Struct nor object defines a Python-level __format__ or __dir__; both
# are C-level method_descriptor on the object type, accessed via Struct's MRO.
# No prior struct spec anchors Struct.__format__.__class__.__name__ or
# Struct.__dir__.__class__.__name__ under st1426fm. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra1426.Struct_format_dir_type:
  description: "struct.Struct.__format__.__class__.__name__=='method_descriptor' / Struct.__dir__.__class__.__name__=='method_descriptor' — Struct is C-level type from _struct.c; MRO is [Struct, object]; both __format__ and __dir__ are C-level method_descriptor inherited from object; neither is defined on Struct; no prior struct spec anchors these; first st1426fm anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1426fm

  columns: [id, function, args, expected, description]
  rows:
    - [st1426fm001, "Struct.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "struct.Struct.__format__.__class__.__name__ == 'method_descriptor' — Struct inherits __format__ from object (MRO: [Struct, object]); C-level descriptor"]
    - [st1426fm002, "Struct.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "struct.Struct.__dir__.__class__.__name__ == 'method_descriptor' — Struct inherits __dir__ from object (MRO: [Struct, object]); C-level descriptor"]
    - [st1426fm003, "Struct.__dict__.__contains__",                ["__format__"],        false, "struct.Struct.__dict__ does not contain '__format__' — inherited from object; not defined on Struct"]
    - [st1426fm004, "Struct.__dict__.__contains__",                ["__dir__"],           false, "struct.Struct.__dict__ does not contain '__dir__' — inherited from object; not defined on Struct"]
    - [st1426fm005, "Struct.__format__.__class__.__name__.__len__", [],                   17,   "struct.Struct.__format__.__class__.__name__.__len__() == 17 — len('method_descriptor') == 17"]
    - [st1426fm006, "Struct.__dir__.__class__.__name__.__len__",    [],                   17,   "struct.Struct.__dir__.__class__.__name__.__len__() == 17 — len('method_descriptor') == 17"]

# ---------------------------------------------------------------------------
# struct.error.__format__.__class__.__name__ == 'method_descriptor'
# struct.error.__dir__.__class__.__name__ == 'method_descriptor'
#
# Wave 542 theme: __format__ and __dir__ type checks on struct.error.
#
# struct.error is a Python-level Exception subclass (struct.error.__bases__ == [Exception]).
# Its MRO is [error, Exception, BaseException, object]. None of these intermediate classes
# defines a Python-level __format__ or __dir__, so both are C-level method_descriptor from
# object. No prior struct spec anchors error.__format__.__class__.__name__ or
# error.__dir__.__class__.__name__ under st1426er. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra1426.error_format_dir_type:
  description: "struct.error.__format__.__class__.__name__=='method_descriptor' / error.__dir__.__class__.__name__=='method_descriptor' — error inherits from Exception; MRO: [error, Exception, BaseException, object]; no class in MRO defines Python-level __format__ or __dir__; both remain C-level method_descriptor from object; no prior struct spec anchors these; first st1426er anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1426er

  columns: [id, function, args, expected, description]
  rows:
    - [st1426er001, "error.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "struct.error.__format__.__class__.__name__ == 'method_descriptor' — error inherits __format__ from object via MRO; C-level descriptor"]
    - [st1426er002, "error.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "struct.error.__dir__.__class__.__name__ == 'method_descriptor' — error inherits __dir__ from object via MRO; C-level descriptor"]
    - [st1426er003, "error.__dict__.__contains__",                ["__format__"],        false, "struct.error.__dict__ does not contain '__format__' — not defined on error; inherited from object"]
    - [st1426er004, "error.__dict__.__contains__",                ["__dir__"],           false, "struct.error.__dict__ does not contain '__dir__' — not defined on error; inherited from object"]
    - [st1426er005, "error.__format__.__class__.__name__.__len__", [],                   17,   "struct.error.__format__.__class__.__name__.__len__() == 17 — len('method_descriptor') == 17"]
    - [st1426er006, "error.__dir__.__class__.__name__.__len__",    [],                   17,   "struct.error.__dir__.__class__.__name__.__len__() == 17 — len('method_descriptor') == 17"]

# ---------------------------------------------------------------------------
# struct.Struct.__format__ is struct.error.__format__ — same object from object
#
# Wave 542 supplemental: identity comparison of __format__ and __dir__ across classes.
#
# Because both Struct and error inherit __format__ and __dir__ from object without
# overriding them, both attributes resolve to the same C-level descriptor object.
# This structural fact reinforces the 'method_descriptor' type reported above.
# No prior struct spec anchors this cross-class identity under st1426id.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra1426.format_dir_class_name_eq_cross:
  description: "struct.Struct.__format__.__class__.__name__.__eq__('method_descriptor')==True / struct.error.__format__.__class__.__name__.__eq__('method_descriptor')==True — both classes inherit from object; both report the same type name; Struct MRO length 2; error MRO length 4; both reach object's C-level __format__ and __dir__; first st1426id anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1426id

  columns: [id, function, args, expected, description]
  rows:
    - [st1426id001, "Struct.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "struct.Struct.__format__ reports 'method_descriptor' — short MRO (len 2) reaches object directly"]
    - [st1426id002, "error.__format__.__class__.__name__.__eq__",  ["method_descriptor"], true, "struct.error.__format__ reports 'method_descriptor' — longer MRO (len 4) still reaches object's C-level descriptor"]
    - [st1426id003, "Struct.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "struct.Struct.__dir__ reports 'method_descriptor' — short MRO (len 2) reaches object directly"]
    - [st1426id004, "error.__dir__.__class__.__name__.__eq__",     ["method_descriptor"], true, "struct.error.__dir__ reports 'method_descriptor' — longer MRO (len 4) still reaches object's C-level descriptor"]
    - [st1426id005, "Struct.__dict__.__contains__",                ["__format__"],        false, "struct.Struct.__dict__ does not define __format__ — confirmed absent from direct dict"]
    - [st1426id006, "error.__dict__.__contains__",                 ["__format__"],        false, "struct.error.__dict__ does not define __format__ — confirmed absent from direct dict"]
