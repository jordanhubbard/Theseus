spec: socket_extra8
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl, _socket.zspec.zsdl, _socket_extra.zspec.zsdl, socket_extra.zspec.zsdl, socket_extra2.zspec.zsdl, socket_extra3.zspec.zsdl, socket_extra4.zspec.zsdl, socket_extra5.zspec.zsdl, socket_extra6.zspec.zsdl, socket_extra7.zspec.zsdl."
    - "Focus: __qualname__ attributes for socket classes and functions not yet covered."
    - "socket.error is an alias for OSError; socket.error.__qualname__ == 'OSError'."
    - "socket.timeout is an alias for TimeoutError; socket.timeout.__qualname__ == 'TimeoutError'."
    - "socket.gaierror.__qualname__ == 'gaierror' (subclass of OSError defined in socket module)."
    - "socket.herror.__qualname__ == 'herror' (subclass of OSError defined in socket module)."
    - "socket.create_server is available from Python 3.8+."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__qualname__ — the socket class itself
# ---------------------------------------------------------------------------

invariant socket_extra8.socket_class.qualname:
  description: "socket.socket.__qualname__ == 'socket'"
  category: qualnames
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# Exception aliases — error, timeout, gaierror, herror
# socket.error is an alias for OSError; socket.timeout is an alias for TimeoutError.
# ---------------------------------------------------------------------------

invariant socket_extra8.error.qualname:
  description: "socket.error.__qualname__ == 'OSError' — socket.error is an alias for OSError"
  category: qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra8.timeout.qualname:
  description: "socket.timeout.__qualname__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError"
  category: qualnames
  kind: python_call_eq
  function: timeout.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant socket_extra8.gaierror.qualname:
  description: "socket.gaierror.__qualname__ == 'gaierror'"
  category: qualnames
  kind: python_call_eq
  function: gaierror.__qualname__.__eq__
  args: ["gaierror"]
  expected: true

invariant socket_extra8.herror.qualname:
  description: "socket.herror.__qualname__ == 'herror'"
  category: qualnames
  kind: python_call_eq
  function: herror.__qualname__.__eq__
  args: ["herror"]
  expected: true

# ---------------------------------------------------------------------------
# Function qualnames — individual invariants for create_server and setdefaulttimeout
# (not included in the table below to avoid duplication)
# ---------------------------------------------------------------------------

invariant socket_extra8.create_server.qualname:
  description: "socket.create_server.__qualname__ == 'create_server' (Python 3.8+)"
  category: qualnames
  kind: python_call_eq
  function: create_server.__qualname__.__eq__
  args: ["create_server"]
  expected: true

invariant socket_extra8.setdefaulttimeout.qualname:
  description: "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout'"
  category: qualnames
  kind: python_call_eq
  function: setdefaulttimeout.__qualname__.__eq__
  args: ["setdefaulttimeout"]
  expected: true

# ---------------------------------------------------------------------------
# Table: qualname checks for common socket functions
# ---------------------------------------------------------------------------

table socket_extra8.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [gethostname,       gethostname.__qualname__.__eq__,       ["gethostname"],       true]
    - [gethostbyname,     gethostbyname.__qualname__.__eq__,     ["gethostbyname"],     true]
    - [getaddrinfo,       getaddrinfo.__qualname__.__eq__,       ["getaddrinfo"],       true]
    - [getfqdn,           getfqdn.__qualname__.__eq__,           ["getfqdn"],           true]
    - [create_connection, create_connection.__qualname__.__eq__, ["create_connection"], true]
