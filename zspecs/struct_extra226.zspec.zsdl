spec: struct_extra226
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.pack.__name__ == 'pack' — Struct instance method name is 'pack' (4 characters)."
    - "struct.Struct.unpack.__name__ == 'unpack' — Struct instance method name is 'unpack' (6 characters)."
    - "struct.Struct.pack_into.__name__ == 'pack_into' — Struct instance method name is 'pack_into' (9 characters)."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from' — Struct instance method name is 'unpack_from' (11 characters)."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack' — Struct instance method name is 'iter_unpack' (11 characters)."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack' — qualname includes the Struct class prefix."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — qualname includes the Struct class prefix."
    - "struct.pack.__name__ == 'pack' — module-level pack function name is 'pack' (4 characters)."
    - "struct.unpack.__name__ == 'unpack' — module-level unpack function name is 'unpack' (6 characters)."
    - "struct.pack.__module__ == '_struct' — module-level pack is from the _struct C extension."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct method name contracts
#
# struct.Struct.pack.__name__        == 'pack'
# struct.Struct.unpack.__name__      == 'unpack'
# struct.Struct.pack_into.__name__   == 'pack_into'
# struct.Struct.unpack_from.__name__ == 'unpack_from'
# struct.Struct.iter_unpack.__name__ == 'iter_unpack'
#
# struct.Struct is the compiled struct class. pack() packs values into bytes;
# unpack() unpacks bytes to a tuple; pack_into() writes into a buffer at an
# offset; unpack_from() reads from a buffer at an offset; iter_unpack()
# yields successive tuples from a buffer.
# ---------------------------------------------------------------------------

table struct_extra226.struct_method_names:
  description: "Struct.pack.__name__=='pack'; unpack.__name__=='unpack'; pack_into.__name__=='pack_into'; unpack_from.__name__=='unpack_from'; iter_unpack.__name__=='iter_unpack'; Struct method name contracts; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: struct226

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq_pack,
       "Struct.pack.__name__.__eq__",
       ["pack"],
       true,
       "struct.Struct.pack.__name__.__eq__('pack') == True — pack packs values according to the compiled format into bytes; __name__ is 'pack' (4 characters); new anchor in extra226 namespace; verified Python 3.14.3"]
    - [unpack_name_eq_unpack,
       "Struct.unpack.__name__.__eq__",
       ["unpack"],
       true,
       "struct.Struct.unpack.__name__.__eq__('unpack') == True — unpack unpacks bytes to a tuple of values; __name__ is 'unpack' (6 characters); new anchor in extra226 namespace; verified Python 3.14.3"]
    - [pack_into_name_eq,
       "Struct.pack_into.__name__.__eq__",
       ["pack_into"],
       true,
       "struct.Struct.pack_into.__name__.__eq__('pack_into') == True — pack_into writes packed bytes into a writable buffer at a given offset; __name__ is 'pack_into' (9 characters); new anchor in extra226 namespace; verified Python 3.14.3"]
    - [unpack_from_name_eq,
       "Struct.unpack_from.__name__.__eq__",
       ["unpack_from"],
       true,
       "struct.Struct.unpack_from.__name__.__eq__('unpack_from') == True — unpack_from reads from a buffer at an offset; __name__ is 'unpack_from' (11 characters); same length as iter_unpack; new anchor in extra226 namespace; verified Python 3.14.3"]
    - [iter_unpack_name_eq,
       "Struct.iter_unpack.__name__.__eq__",
       ["iter_unpack"],
       true,
       "struct.Struct.iter_unpack.__name__.__eq__('iter_unpack') == True — iter_unpack yields successive tuples from a buffer; __name__ is 'iter_unpack' (11 characters); same length as unpack_from; new anchor in extra226 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct method name length contracts
#
# len('pack')        == 4
# len('unpack')      == 6
# len('pack_into')   == 9
# len('unpack_from') == 11
# len('iter_unpack') == 11
#
# These length anchors are portable checks that verify the correct method
# name string lengths independently of equality comparisons.
# ---------------------------------------------------------------------------

table struct_extra226.struct_method_name_lengths:
  description: "pack name len==4; unpack len==6; pack_into len==9; unpack_from len==11; iter_unpack len==11; Struct method name length contracts; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: struct226a

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_len_4,
       "Struct.pack.__name__.__len__",
       [],
       4,
       "struct.Struct.pack.__name__.__len__() == 4 — the string 'pack' has 4 characters; portable length anchor; new anchor in extra226 namespace; verified Python 3.14.3"]
    - [unpack_name_len_6,
       "Struct.unpack.__name__.__len__",
       [],
       6,
       "struct.Struct.unpack.__name__.__len__() == 6 — the string 'unpack' has 6 characters; 2 more than 'pack'; portable length anchor; new anchor in extra226 namespace; verified Python 3.14.3"]
    - [pack_into_name_len_9,
       "Struct.pack_into.__name__.__len__",
       [],
       9,
       "struct.Struct.pack_into.__name__.__len__() == 9 — the string 'pack_into' has 9 characters including the underscore; portable length anchor; new anchor in extra226 namespace; verified Python 3.14.3"]
    - [unpack_from_name_len_11,
       "Struct.unpack_from.__name__.__len__",
       [],
       11,
       "struct.Struct.unpack_from.__name__.__len__() == 11 — the string 'unpack_from' has 11 characters; same length as 'iter_unpack'; portable length anchor; new anchor in extra226 namespace; verified Python 3.14.3"]
    - [iter_unpack_name_len_11,
       "Struct.iter_unpack.__name__.__len__",
       [],
       11,
       "struct.Struct.iter_unpack.__name__.__len__() == 11 — the string 'iter_unpack' has 11 characters; same length as 'unpack_from'; portable length anchor; new anchor in extra226 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct method qualname contracts
#
# struct.Struct.pack.__qualname__        == 'Struct.pack'
# struct.Struct.unpack.__qualname__      == 'Struct.unpack'
# struct.Struct.pack_into.__qualname__   == 'Struct.pack_into'
# struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'
#
# Qualnames for Struct methods include the 'Struct.' class prefix.
# ---------------------------------------------------------------------------

table struct_extra226.struct_method_qualnames:
  description: "Struct.pack.__qualname__=='Struct.pack'; unpack.__qualname__=='Struct.unpack'; pack_into.__qualname__=='Struct.pack_into'; unpack_from.__qualname__=='Struct.unpack_from'; qualname contracts; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: struct226b

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,
       "Struct.pack.__qualname__.__eq__",
       ["Struct.pack"],
       true,
       "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — pack qualname includes the Struct class prefix; __qualname__ is 'Struct.pack' (11 characters); new anchor in extra226 namespace; verified Python 3.14.3"]
    - [unpack_qualname_eq,
       "Struct.unpack.__qualname__.__eq__",
       ["Struct.unpack"],
       true,
       "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — unpack qualname is 'Struct.unpack' (13 characters); new anchor in extra226 namespace; verified Python 3.14.3"]
    - [pack_into_qualname_eq,
       "Struct.pack_into.__qualname__.__eq__",
       ["Struct.pack_into"],
       true,
       "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — pack_into qualname is 'Struct.pack_into' (16 characters); new anchor in extra226 namespace; verified Python 3.14.3"]
    - [unpack_from_qualname_eq,
       "Struct.unpack_from.__qualname__.__eq__",
       ["Struct.unpack_from"],
       true,
       "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — unpack_from qualname is 'Struct.unpack_from' (18 characters); new anchor in extra226 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra226.pack_name_eq_pack:
  description: "struct.Struct.pack.__name__.__eq__('pack') == True — Struct.pack is the method that packs values into a bytes object according to the compiled format string; the compiled Struct avoids re-parsing the format on each call; __name__ is 'pack' (4 characters); struct.pack at module level also has __name__=='pack' but Struct.pack is a method_descriptor on the Struct class; extra226 is the first namespace to anchor Struct.pack.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Struct.pack.__name__.__eq__"
  args: ["pack"]
  expected: true

invariant struct_extra226.iter_unpack_name_eq:
  description: "struct.Struct.iter_unpack.__name__.__eq__('iter_unpack') == True — Struct.iter_unpack returns an iterator that yields successive tuples unpacked from a buffer; the buffer must be a multiple of the struct size; __name__ is 'iter_unpack' (11 characters); same length as 'unpack_from'; iter_unpack was added in Python 3.4; it is useful for processing arrays of records; extra226 is the first namespace to anchor Struct.iter_unpack.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Struct.iter_unpack.__name__.__eq__"
  args: ["iter_unpack"]
  expected: true

invariant struct_extra226.unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — Struct.unpack_from reads values from a buffer starting at a given offset without consuming the entire buffer; __qualname__ is 'Struct.unpack_from' (18 characters including the 'Struct.' prefix and underscore in method name); the qualname includes the class scope; extra226 is the first namespace to anchor Struct.unpack_from.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Struct.unpack_from.__qualname__.__eq__"
  args: ["Struct.unpack_from"]
  expected: true
