spec: gc_extra3
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/gc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "gc source: internal CPython generational GC implementation details"
    - "gc.zspec.zsdl — covers function names (enable, disable, isenabled, collect, get_count, get_threshold, set_threshold, get_objects, get_referrers, get_referents, is_tracked, is_finalized, freeze, unfreeze, get_freeze_count, callbacks), constants (DEBUG_STATS, DEBUG_COLLECTABLE, DEBUG_UNCOLLECTABLE, DEBUG_SAVEALL, DEBUG_LEAK)"
    - "gc_extra.zspec.zsdl — covers gc.isenabled() returns bool, gc.get_threshold() returns tuple of 3 ints, gc.get_count() returns tuple of 3 ints, gc.is_tracked([]) == True, gc.is_tracked(1) == False, gc.DEBUG_STATS class name ('int')"
    - "gc_extra2.zspec.zsdl — covers gc.enable/__name__, gc.disable/__name__, gc.collect/__name__, gc.get_objects/__name__, gc.is_tracked/__name__, gc.collect/__module__ == 'gc', gc.DEBUG_COLLECTABLE value >= 2, gc.DEBUG_UNCOLLECTABLE value >= 4"
  notes:
    - "This spec extends gc.zspec.zsdl, gc_extra.zspec.zsdl, and gc_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "gc.enable.__module__ == 'gc' — C-level builtin function reports module 'gc'."
    - "gc.disable.__module__ == 'gc' — C-level builtin function reports module 'gc'."
    - "gc.isenabled.__module__ == 'gc' — C-level builtin function reports module 'gc'."
    - "gc.get_count.__module__ == 'gc' — C-level builtin function reports module 'gc'."
    - "gc.get_threshold.__module__ == 'gc' — C-level builtin function reports module 'gc'."
    - "gc.get_objects.__module__ == 'gc' — C-level builtin function reports module 'gc'."
    - "gc.get_referrers.__name__ == 'get_referrers'."
    - "gc.get_referents.__name__ == 'get_referents'."
    - "gc.is_finalized.__name__ == 'is_finalized'."
    - "gc.freeze.__name__ == 'freeze'."
    - "gc.unfreeze.__name__ == 'unfreeze'."
    - "gc.get_freeze_count.__name__ == 'get_freeze_count'."
    - "gc.callbacks is the list of GC callback functions; __class__.__name__ == 'list'."
    - "gc.get_freeze_count() returns an int."
    - "gc.get_count() returns a tuple."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — C-level GC functions report module 'gc'
# New coverage: enable, disable, isenabled, get_count, get_threshold, get_objects
# (gc_extra2 only covers collect.__module__)
# ---------------------------------------------------------------------------

invariant gc_extra3.enable.module:
  description: "gc.enable.__module__ == 'gc'"
  category: function_modules
  kind: python_call_eq
  function: enable.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra3.disable.module:
  description: "gc.disable.__module__ == 'gc'"
  category: function_modules
  kind: python_call_eq
  function: disable.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra3.isenabled.module:
  description: "gc.isenabled.__module__ == 'gc'"
  category: function_modules
  kind: python_call_eq
  function: isenabled.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra3.get_count.module:
  description: "gc.get_count.__module__ == 'gc'"
  category: function_modules
  kind: python_call_eq
  function: get_count.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra3.get_threshold.module:
  description: "gc.get_threshold.__module__ == 'gc'"
  category: function_modules
  kind: python_call_eq
  function: get_threshold.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra3.get_objects.module:
  description: "gc.get_objects.__module__ == 'gc'"
  category: function_modules
  kind: python_call_eq
  function: get_objects.__module__.__eq__
  args: ["gc"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks — new names not in gc_extra2
#
# gc_extra2 covers: enable, disable, collect, get_objects, is_tracked, get_count,
# get_threshold.  New here: get_referrers, get_referents, is_finalized,
# freeze, unfreeze, get_freeze_count.
# ---------------------------------------------------------------------------

invariant gc_extra3.get_referrers.name:
  description: "gc.get_referrers.__name__ == 'get_referrers'"
  category: function_names
  kind: python_call_eq
  function: get_referrers.__name__.__eq__
  args: ["get_referrers"]
  expected: true

invariant gc_extra3.get_referents.name:
  description: "gc.get_referents.__name__ == 'get_referents'"
  category: function_names
  kind: python_call_eq
  function: get_referents.__name__.__eq__
  args: ["get_referents"]
  expected: true

invariant gc_extra3.is_finalized.name:
  description: "gc.is_finalized.__name__ == 'is_finalized'"
  category: function_names
  kind: python_call_eq
  function: is_finalized.__name__.__eq__
  args: ["is_finalized"]
  expected: true

invariant gc_extra3.freeze.name:
  description: "gc.freeze.__name__ == 'freeze'"
  category: function_names
  kind: python_call_eq
  function: freeze.__name__.__eq__
  args: ["freeze"]
  expected: true

invariant gc_extra3.unfreeze.name:
  description: "gc.unfreeze.__name__ == 'unfreeze'"
  category: function_names
  kind: python_call_eq
  function: unfreeze.__name__.__eq__
  args: ["unfreeze"]
  expected: true

invariant gc_extra3.get_freeze_count.name:
  description: "gc.get_freeze_count.__name__ == 'get_freeze_count'"
  category: function_names
  kind: python_call_eq
  function: get_freeze_count.__name__.__eq__
  args: ["get_freeze_count"]
  expected: true

# ---------------------------------------------------------------------------
# callbacks — module-level list attribute
# ---------------------------------------------------------------------------

invariant gc_extra3.callbacks.is_list:
  description: "gc.callbacks.__class__.__name__ == 'list'"
  category: constants
  kind: python_call_eq
  function: callbacks.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# get_freeze_count — return type is int
# ---------------------------------------------------------------------------

invariant gc_extra3.get_freeze_count.return_type:
  description: "gc.get_freeze_count().__class__.__name__ == 'int'"
  category: get_freeze_count
  kind: python_call_eq
  function: get_freeze_count().__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# get_count — return type is tuple
# ---------------------------------------------------------------------------

invariant gc_extra3.get_count.return_type:
  description: "gc.get_count().__class__.__name__ == 'tuple'"
  category: get_count
  kind: python_call_eq
  function: get_count().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
