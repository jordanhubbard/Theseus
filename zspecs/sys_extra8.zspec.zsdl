spec: sys_extra8
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra7.zspec.zsdl."
    - "sys_extra6 covers version_info[0]==3 and version_info.__len__()==5."
    - "No prior spec covers version_info[1] (the minor version index)."
    - "sys_extra3 covers float_info.max/min/epsilon class names but not dig/mant_dig/max_exp/min_exp."
    - "sys_extra3 covers hash_info.width/modulus class names but not value bounds."
    - "No prior spec covers sys.argv.__class__.__name__."
    - "sys_platform covers sys.modules.__class__.__name__=='dict' — this spec does NOT duplicate that."
    - "sys.version_info[1] >= 9 — index 1 is the minor version; this spec requires Python 3.9+."
    - "sys.float_info.dig == 15 — the number of significant decimal digits in a double."
    - "sys.float_info.mant_dig == 53 — mantissa bits in IEEE 754 double (same as BPF in random)."
    - "sys.float_info.max_exp == 1024 — maximum binary exponent for IEEE 754 double."
    - "sys.float_info.min_exp == -1021 — minimum normalized binary exponent for IEEE 754 double."
    - "sys.hash_info.modulus > 0 — the hash modulus is always a positive integer."
    - "sys.hash_info.width > 0 — hash width in bits is always positive."
    - "sys.argv.__class__.__name__ == 'list' — argv is always a list of strings."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version_info[1] — index access to the minor version
#
# sys_extra6 covers version_info[0] == 3 (major).
# This spec adds version_info[1] >= 9 (minor, as required by this spec's
# version constraint).
# ---------------------------------------------------------------------------

invariant sys_extra8.version_info.index_1_ge_9:
  description: "sys.version_info[1] >= 9 — index 1 is the minor version; spec requires Python 3.9+"
  category: version_info
  kind: python_call_eq
  function: version_info.__getitem__
  args: [1]
  method: __ge__
  method_args: [9]
  expected: true

# ---------------------------------------------------------------------------
# float_info — integer fields: dig, mant_dig, max_exp, min_exp
#
# sys_extra3 covers float_info.max/min/epsilon class names (all float).
# This spec adds type checks for the integer fields of float_info.
# ---------------------------------------------------------------------------

table sys_extra8.float_info_int_fields:
  kind: python_call_eq
  category: float_info
  id_prefix: fi

  columns: [id, function, args, expected]
  rows:
    - [dig,     float_info.dig.__class__.__name__.__eq__,     ["int"], true]
    - [mant_dig, float_info.mant_dig.__class__.__name__.__eq__, ["int"], true]
    - [max_exp,  float_info.max_exp.__class__.__name__.__eq__,  ["int"], true]
    - [min_exp,  float_info.min_exp.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# float_info — value checks for integer fields
#
# These are IEEE 754 double-precision constants; all values are universal
# across platforms that use IEEE 754 (which is all modern systems).
# ---------------------------------------------------------------------------

invariant sys_extra8.float_info.dig_eq_15:
  description: "sys.float_info.dig == 15 — significant decimal digits in an IEEE 754 double"
  category: float_info
  kind: python_call_eq
  function: float_info.dig.__eq__
  args: [15]
  expected: true

invariant sys_extra8.float_info.mant_dig_eq_53:
  description: "sys.float_info.mant_dig == 53 — mantissa bits in an IEEE 754 double"
  category: float_info
  kind: python_call_eq
  function: float_info.mant_dig.__eq__
  args: [53]
  expected: true

invariant sys_extra8.float_info.max_exp_eq_1024:
  description: "sys.float_info.max_exp == 1024 — maximum binary exponent for IEEE 754 double"
  category: float_info
  kind: python_call_eq
  function: float_info.max_exp.__eq__
  args: [1024]
  expected: true

invariant sys_extra8.float_info.min_exp_eq_neg1021:
  description: "sys.float_info.min_exp == -1021 — minimum normalized binary exponent for IEEE 754 double"
  category: float_info
  kind: python_call_eq
  function: float_info.min_exp.__eq__
  args: [-1021]
  expected: true

# ---------------------------------------------------------------------------
# hash_info — value bounds
#
# sys_extra3 covers hash_info.width/modulus class names (both int).
# This spec adds value-bound invariants: both are positive.
# ---------------------------------------------------------------------------

invariant sys_extra8.hash_info.modulus.positive:
  description: "sys.hash_info.modulus > 0 — the hash modulus is a large positive prime"
  category: hash_info
  kind: python_call_eq
  function: hash_info.modulus.__gt__
  args: [0]
  expected: true

invariant sys_extra8.hash_info.width.positive:
  description: "sys.hash_info.width > 0 — hash width in bits is always positive"
  category: hash_info
  kind: python_call_eq
  function: hash_info.width.__gt__
  args: [0]
  expected: true

invariant sys_extra8.hash_info.width.ge_32:
  description: "sys.hash_info.width >= 32 — hash width is at least 32 bits on all modern platforms"
  category: hash_info
  kind: python_call_eq
  function: hash_info.width.__ge__
  args: [32]
  expected: true

# ---------------------------------------------------------------------------
# sys.argv — type check
#
# sys.argv is always a list of strings.  No prior spec covers argv.
# ---------------------------------------------------------------------------

invariant sys_extra8.argv.class_name:
  description: "sys.argv.__class__.__name__ == 'list' — command-line arguments are a list"
  category: attributes
  kind: python_call_eq
  function: argv.__class__.__name__.__eq__
  args: ["list"]
  expected: true
