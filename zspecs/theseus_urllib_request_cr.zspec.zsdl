spec: theseus_urllib_request_cr
version: ">=3.8"
backend: python_cleanroom(theseus_urllib_request_cr)
blocks: urllib.request

docs: https://docs.python.org/3/library/urllib.request.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.request.html"
  not_derived_from:
    - "CPython source: Lib/urllib/request.py"
  notes:
    - "Clean-room urllib.request module. Do NOT import urllib.request."

error_model: python_exceptions

invariant theseus_urllib_request_cr.urllib_request2_request:
  description: "Request object stores URL and headers"
  category: behavior
  kind: python_call_eq
  function: urllib_request2_request
  args: []
  expected: true

invariant theseus_urllib_request_cr.urllib_request2_add_header:
  description: "Request.add_header stores header values"
  category: behavior
  kind: python_call_eq
  function: urllib_request2_add_header
  args: []
  expected: true

invariant theseus_urllib_request_cr.urllib_request2_pathname2url:
  description: "pathname2url converts filesystem path to URL path"
  category: behavior
  kind: python_call_eq
  function: urllib_request2_pathname2url
  args: []
  expected: true
