#
# Pool manages a pool of worker processes. It is a pure-Python class and does
# not define __hash__ or __eq__; both are 'wrapper_descriptor' from object.
# Pool.__dict__ contains neither '__hash__' nor '__eq__'.
# ---------------------------------------------------------------------------

table multiprocessing_extra2401.pool_hash_eq:
  description: "multiprocessing.pool.Pool __hash__ and __eq__ implementation type classification"
  kind: python_call_eq
