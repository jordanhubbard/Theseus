spec: multiprocessing_extra2401
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "Theme: __hash__ and __eq__ implementation type classification via .__hash__.__class__.__name__ and .__eq__.__class__.__name__."
    - "multiprocessing.Process is a pure-Python class that does not define __hash__ or __eq__; both are 'wrapper_descriptor' inherited from object."
    - "multiprocessing.pool.Pool is a pure-Python class that does not define __hash__ or __eq__; both are 'wrapper_descriptor' inherited from object."
    - "multiprocessing.pool.AsyncResult is also a pure-Python class with 'wrapper_descriptor' for both __hash__ and __eq__."
    - "None of these classes set __hash__ = None, so __hash__.__class__.__name__ is never 'NoneType'."
    - "Process.__dict__ and Pool.__dict__ contain neither '__hash__' nor '__eq__'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process __hash__ and __eq__ implementation type
#
# Process is a pure-Python class representing a spawned process handle. It does
# not define __hash__ or __eq__; both are inherited from object as
# 'wrapper_descriptor'. Process.__dict__ contains neither attribute.
# ---------------------------------------------------------------------------

table multiprocessing_extra2401.process_hash_eq:
  description: "multiprocessing.Process __hash__ and __eq__ implementation type classification"
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: mp2401

  columns: [id, function, args, expected]
  rows:
    - ["mp2401001", Process.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["mp2401002", Process.__eq__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["mp2401003", Process.__hash__.__class__.__name__.__len__, [], 18]
    - ["mp2401004", Process.__eq__.__class__.__name__.__len__,   [], 18]
    - ["mp2401005", Process.__dict__.__contains__,               ["__hash__"], false]
    - ["mp2401006", Process.__dict__.__contains__,               ["__eq__"], false]
    - ["mp2401007", Process.__hash__.__class__.__name__.__contains__, ["descriptor"], true]
    - ["mp2401008", Process.__eq__.__class__.__name__.__contains__,   ["descriptor"], true]

