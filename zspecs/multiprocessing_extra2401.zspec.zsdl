  id_prefix: mp2401

  columns: [id, function, args, expected]
  rows:
    - ["mp2401009",  Pool.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["mp2401010", Pool.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - ["mp2401011", Pool.__hash__.__class__.__name__.__len__,  [], 18]
    - ["mp2401012", Pool.__eq__.__class__.__name__.__len__,    [], 18]
    - ["mp2401013", Pool.__dict__.__contains__,                ["__hash__"], false]
    - ["mp2401014", Pool.__dict__.__contains__,                ["__eq__"], false]
    - ["mp2401015", Pool.__hash__.__class__.__name__.__contains__, ["wrapper"], true]
    - ["mp2401016", Pool.__eq__.__class__.__name__.__contains__,   ["wrapper"], true]

