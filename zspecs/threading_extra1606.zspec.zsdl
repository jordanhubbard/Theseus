    - ["th1606lo014", "threading.local.__dict__.__contains__", ["__exit__"],         false]
    - ["th1606lo015", "threading.local.__dict__.__contains__", ["__init__"],         false]
    - ["th1606lo016", "threading.local.__name__.__eq__",   ["_local"],   true]
    - ["th1606lo017", "threading.local.__module__.__eq__", ["_thread"],  true]
