spec: threading_extra1606
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "threading.Thread does NOT define __slots__; instances have a per-instance __dict__ (getset_descriptor in Thread.__dict__)"
    - "threading.Event, Condition, Semaphore, Barrier do NOT define __slots__; all are plain Python classes with per-instance __dict__"
    - "threading.BoundedSemaphore and Timer are subclasses (of Semaphore and Thread respectively); neither adds __slots__"
    - "threading.local is _thread._local, a C extension type; no __slots__ in its type dict and no per-instance __dict__ slot descriptor; instances carry a per-thread dict accessed via custom __getattribute__"
    - "threading.RLock() returns an instance of _thread.RLock, a C extension type with no __slots__"
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra1606.thread_no_slots:
  description: "threading.Thread and subclass Timer do not define __slots__; Thread instances have __dict__; Thread exposes public API via methods and properties"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1606th

  columns: [id, function, args, expected]
  rows:
    - ["th1606th001", "threading.Thread.__dict__.__contains__", ["__slots__"],    false]
    - ["th1606th002", "threading.Thread.__dict__.__contains__", ["__dict__"],     true]
    - ["th1606th003", "threading.Thread.__dict__.__contains__", ["__weakref__"],  true]
    - ["th1606th004", "threading.Thread.__dict__.__contains__", ["name"],         true]
    - ["th1606th005", "threading.Thread.__dict__.__contains__", ["ident"],        true]
    - ["th1606th006", "threading.Thread.__dict__.__contains__", ["native_id"],    true]
    - ["th1606th007", "threading.Thread.__dict__.__contains__", ["daemon"],       true]
    - ["th1606th008", "threading.Thread.__dict__.__contains__", ["start"],        true]
    - ["th1606th009", "threading.Thread.__dict__.__contains__", ["run"],          true]
    - ["th1606th010", "threading.Thread.__dict__.__contains__", ["join"],         true]
    - ["th1606th011", "threading.Thread.__dict__.__contains__", ["is_alive"],     true]
    - ["th1606th012", "threading.Thread.__dict__.__contains__", ["__iter__"],     false]
    - ["th1606th013", "threading.Thread.__dict__.__contains__", ["__next__"],     false]
    - ["th1606th014", "threading.Thread.__dict__.__contains__", ["__get__"],      false]
    - ["th1606th015", "threading.Thread.__dict__.__contains__", ["__set__"],      false]
    - ["th1606th016", "threading.Thread.__dict__.__contains__", ["__delete__"],   false]
    - ["th1606th017", "threading.Thread.__name__.__eq__",   ["Thread"],     true]
    - ["th1606th018", "threading.Thread.__module__.__eq__", ["threading"],  true]
    - ["th1606th019", "threading.Thread.__class__.__name__.__eq__", ["type"], true]
    - ["th1606th020", "threading.Thread.__bases__.__len__", [], 1]
    - ["th1606th021", "threading.Timer.__dict__.__contains__",  ["__slots__"],   false]
    - ["th1606th022", "threading.Timer.__dict__.__contains__",  ["__dict__"],    false]
    - ["th1606th023", "threading.Timer.__dict__.__contains__",  ["cancel"],      true]
    - ["th1606th024", "threading.Timer.__dict__.__contains__",  ["run"],         true]
    - ["th1606th025", "threading.Timer.__dict__.__contains__",  ["__get__"],     false]
    - ["th1606th026", "threading.Timer.__name__.__eq__",   ["Timer"],    true]
    - ["th1606th027", "threading.Timer.__module__.__eq__", ["threading"], true]
    - ["th1606th028", "threading.Timer.__class__.__name__.__eq__", ["type"], true]
    - ["th1606th029", "threading.Timer.__bases__.__len__", [], 1]
    - ["th1606th030", "threading.Thread.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]

table threading_extra1606.sync_no_slots:
  description: "threading synchronization primitives (Event, Condition, Semaphore, BoundedSemaphore, Barrier) do not define __slots__; those with __dict__ in their type dict allow per-instance __dict__"
