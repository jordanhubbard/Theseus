    - ["th1606lo008", "threading.local.__dict__.__contains__", ["__get__"],          false]
    - ["th1606lo009", "threading.local.__dict__.__contains__", ["__set__"],          false]
    - ["th1606lo010", "threading.local.__dict__.__contains__", ["__delete__"],       false]
