table threading_extra1606.local_type_attrs:
  description: "threading.local is _thread._local, a C extension type; no __slots__ key, no __dict__ descriptor in its type dict; per-thread dict access via custom __getattribute__/__setattr__/__delattr__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1606lo

  columns: [id, function, args, expected]
  rows:
    - ["th1606lo001", "threading.local.__dict__.__contains__", ["__slots__"],        false]
    - ["th1606lo002", "threading.local.__dict__.__contains__", ["__dict__"],         false]
