    - ["th1606sy025", "threading.BoundedSemaphore.__dict__.__contains__", ["release"],     true]
    - ["th1606sy026", "threading.Barrier.__dict__.__contains__",          ["__slots__"],   false]
    - ["th1606sy027", "threading.Barrier.__dict__.__contains__",          ["__dict__"],    true]
    - ["th1606sy028", "threading.Barrier.__dict__.__contains__",          ["__weakref__"], true]
    - ["th1606sy029", "threading.Barrier.__dict__.__contains__",          ["wait"],        true]
    - ["th1606sy030", "threading.Barrier.__dict__.__contains__",          ["reset"],       true]
    - ["th1606sy031", "threading.Barrier.__dict__.__contains__",          ["abort"],       true]
