    - ["th1606lo020", "threading.local.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["th1606lo021", "threading.local.__dict__.__contains__", ["__repr__"],         false]
    - ["th1606lo022", "threading.local.__dict__.__contains__", ["__doc__"],          true]
    - ["th1606lo023", "threading.Event.__dict__.__contains__",     ["__get__"],      false]
    - ["th1606lo024", "threading.Condition.__dict__.__contains__", ["__get__"],      false]
    - ["th1606lo025", "threading.Semaphore.__dict__.__contains__", ["__get__"],      false]
    - ["th1606lo026", "threading.Barrier.__dict__.__contains__",   ["__get__"],      false]
