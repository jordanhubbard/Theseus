spec: functools_extra247
version: ">=3.2"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra246.zspec.zsdl — covers wraps and update_wrapper identity"
    - "functools_extra.zspec.zsdl — covers reduce/partial/cached_property/cmp_to_key/total_ordering/singledispatch names and modules"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and callable type checks"
  notes:
    - "This spec covers functools.cmp_to_key and functools.WRAPPER_ASSIGNMENTS identity contracts."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' (len=10) — cmp_to_key is a C-level built-in in _functools. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' (len=10) — cmp_to_key is implemented in the C extension _functools; its __module__ is '_functools', not 'functools'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len=10) — same as __name__ for a top-level C built-in. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C-level built-in. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple constant. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_ASSIGNMENTS) == 6 on Python 3.14 — ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cmp_to_key identity contracts
#
# functools.cmp_to_key.__name__ == 'cmp_to_key' (len=10)
# functools.cmp_to_key.__module__ == '_functools' (len=10)
# functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len=10)
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__name__.__len__() == 10
#
# cmp_to_key is a C-level built-in in _functools. New to extra247.
# ---------------------------------------------------------------------------

table functools_extra247.cmptokey247_identity:
  description: "functools.cmp_to_key identity: name, module, qualname, class; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: cmptokey247

  columns: [id, function, args, expected, description]
  rows:
    - [cmptokey_name_eq,
       cmp_to_key.__name__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — cmp_to_key is a C-level built-in in _functools; __name__ is 'cmp_to_key' (len=10); new to extra247"]
    - [cmptokey_name_len_10,
       cmp_to_key.__name__.__len__,
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has exactly 10 characters; str.__len__() returns 10; new to extra247"]
    - [cmptokey_module_eq,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in the C extension _functools; __module__ is '_functools' not 'functools'; new to extra247"]
    - [cmptokey_module_len_10,
       cmp_to_key.__module__.__len__,
       [],
       10,
       "functools.cmp_to_key.__module__.__len__() == 10 — '_functools' has exactly 10 characters; str.__len__() returns 10; new to extra247"]
    - [cmptokey_qualname_eq,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — __qualname__ is 'cmp_to_key' (len=10); same as __name__ for a top-level C built-in; new to extra247"]

# ---------------------------------------------------------------------------
# Table 2: functools.cmp_to_key class and qualname len contracts
#
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__qualname__.__len__() == 10
# functools.cmp_to_key.__module__.__contains__('functools') == True
# functools.cmp_to_key.__name__.__contains__('cmp') == True
# functools.cmp_to_key.__name__.__contains__('key') == True
#
# New to extra247.
# ---------------------------------------------------------------------------

table functools_extra247.cmptokey247_class:
  description: "functools.cmp_to_key class, qualname len, name/module content checks; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: cmptokey247cls

  columns: [id, function, args, expected, description]
  rows:
    - [cmptokey_class_is_builtin,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C-level built-in; its __class__ is builtin_function_or_method; new to extra247"]
    - [cmptokey_qualname_len_10,
       cmp_to_key.__qualname__.__len__,
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — 'cmp_to_key' has exactly 10 characters; str.__len__() returns 10; new to extra247"]
    - [cmptokey_module_contains_functools,
       cmp_to_key.__module__.__contains__,
       ["functools"],
       true,
       "functools.cmp_to_key.__module__.__contains__('functools') == True — '_functools' contains the substring 'functools'; new to extra247"]
    - [cmptokey_name_contains_cmp,
       cmp_to_key.__name__.__contains__,
       ["cmp"],
       true,
       "functools.cmp_to_key.__name__.__contains__('cmp') == True — 'cmp_to_key' contains the prefix 'cmp'; new to extra247"]
    - [cmptokey_name_contains_key,
       cmp_to_key.__name__.__contains__,
       ["key"],
       true,
       "functools.cmp_to_key.__name__.__contains__('key') == True — 'cmp_to_key' contains the suffix 'key'; new to extra247"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS identity contracts
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
# functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
#
# WRAPPER_ASSIGNMENTS is a tuple constant in functools. New to extra247.
# ---------------------------------------------------------------------------

table functools_extra247.wrapperasgn247_identity:
  description: "functools.WRAPPER_ASSIGNMENTS class, length, contents; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: wrapperasgn247

  columns: [id, function, args, expected, description]
  rows:
    - [wa_class_is_tuple,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a tuple constant in functools; new to extra247"]
    - [wa_len_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — Python 3.14 has 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; new to extra247"]
    - [wa_contains_module,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element of WRAPPER_ASSIGNMENTS; new to extra247"]
    - [wa_contains_name,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is the second element of WRAPPER_ASSIGNMENTS; new to extra247"]
    - [wa_contains_qualname,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element of WRAPPER_ASSIGNMENTS; new to extra247"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_ASSIGNMENTS additional content checks
#
# functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' (already in table 3)
# functools.WRAPPER_ASSIGNMENTS.__class__.__module__ == 'builtins'
# functools.WRAPPER_ASSIGNMENTS.__getitem__(0).__eq__('__module__') == True
# functools.WRAPPER_ASSIGNMENTS.__getitem__(1).__eq__('__name__') == True
#
# New to extra247.
# ---------------------------------------------------------------------------

table functools_extra247.wrapperasgn247_items:
  description: "functools.WRAPPER_ASSIGNMENTS doc/annotate contents and index checks; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: wrapperasgn247it

  columns: [id, function, args, expected, description]
  rows:
    - [wa_contains_doc,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is the fourth element; new to extra247"]
    - [wa_class_module_builtins,
       WRAPPER_ASSIGNMENTS.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__module__.__eq__('builtins') == True — tuple is defined in the builtins module; new to extra247"]
    - [wa_item0_is_module,
       WRAPPER_ASSIGNMENTS.__getitem__,
       [0],
       "__module__",
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(0) == '__module__' — first element of WRAPPER_ASSIGNMENTS is '__module__'; new to extra247"]
    - [wa_item1_is_name,
       WRAPPER_ASSIGNMENTS.__getitem__,
       [1],
       "__name__",
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(1) == '__name__' — second element of WRAPPER_ASSIGNMENTS is '__name__'; new to extra247"]
    - [wa_item2_is_qualname,
       WRAPPER_ASSIGNMENTS.__getitem__,
       [2],
       "__qualname__",
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(2) == '__qualname__' — third element of WRAPPER_ASSIGNMENTS is '__qualname__'; new to extra247"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra247
# ---------------------------------------------------------------------------

invariant functools_extra247.cmptokey_name_eq:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' (len=10); new to extra247"
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra247.cmptokey_module_eq:
  description: "functools.cmp_to_key.__module__ == '_functools' — C extension; __module__ is '_functools' not 'functools'; new to extra247"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra247.cmptokey_qualname_eq:
  description: "functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len=10); new to extra247"
  kind: python_call_eq
  function: cmp_to_key.__qualname__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra247.cmptokey_class_is_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'; new to extra247"
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra247.wrapperasgn_class_is_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'; new to extra247"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra247.wrapperasgn_len_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 on Python 3.14; new to extra247"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra247.wrapperasgn_contains_module:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__module__'; new to extra247"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true
