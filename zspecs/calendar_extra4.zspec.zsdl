spec: calendar_extra4
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl and prior extras."
    - "calendar.zspec.zsdl covers: isleap table (2000/2024/1900/2100/2023/2026); weekday vectors; leapdays; month_name/abbr/day_name/day_abbr; MONDAY/WEDNESDAY/SUNDAY/JANUARY/DECEMBER constants."
    - "calendar_extra covers: Calendar/__name__/__module__; TextCalendar/__name__/__bases__; HTMLCalendar/__name__/__bases__; isleap/__name__ and 2000/1900/2024 values; leapdays(2000,2024)==6; month_name class; weekheader; MONDAY/SUNDAY constants."
    - "calendar_extra2 covers: Calendar/__name__; TextCalendar/__name__; HTMLCalendar/__name__; MONDAY/SUNDAY values; month_name class; isleap(2000)/isleap(1900); leapdays(2000,2001)."
    - "calendar_extra3 covers: __qualname__ for Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/isleap/monthrange/weekday; MONDAY/SUNDAY class base is int; isleap.__module__ and Calendar.__module__; isleap(2024)/isleap(2023); monthrange(2024,1)[0]."
    - "This spec adds: Calendar/__name__/__module__/__qualname__ as extra4 anchors; TextCalendar/__name__ as extra4 anchor; HTMLCalendar/__name__ as extra4 anchor; LocaleTextCalendar/__name__ as extra4 anchor; LocaleHTMLCalendar/__name__ as extra4 anchor."
    - "calendar.Calendar.__name__ == 'Calendar'; Calendar.__module__ == 'calendar'; Calendar.__qualname__ == 'Calendar'."
    - "calendar.TextCalendar.__name__ == 'TextCalendar'; calendar.HTMLCalendar.__name__ == 'HTMLCalendar'."
    - "calendar.LocaleTextCalendar.__name__ == 'LocaleTextCalendar'; calendar.LocaleHTMLCalendar.__name__ == 'LocaleHTMLCalendar'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Calendar — name, module, qualname anchors in extra4 namespace
# ---------------------------------------------------------------------------

invariant calendar_extra4.Calendar.name:
  description: "calendar.Calendar.__name__ == 'Calendar'"
  category: class_identity
  kind: python_call_eq
  function: Calendar.__name__.__eq__
  args: ["Calendar"]
  expected: true

invariant calendar_extra4.Calendar.module:
  description: "calendar.Calendar.__module__ == 'calendar'"
  category: class_identity
  kind: python_call_eq
  function: Calendar.__module__.__eq__
  args: ["calendar"]
  expected: true

invariant calendar_extra4.Calendar.qualname:
  description: "calendar.Calendar.__qualname__ == 'Calendar'"
  category: class_identity
  kind: python_call_eq
  function: Calendar.__qualname__.__eq__
  args: ["Calendar"]
  expected: true

# ---------------------------------------------------------------------------
# TextCalendar, HTMLCalendar, LocaleTextCalendar, LocaleHTMLCalendar — names
#
# calendar_extra/extra2/extra3 cover subsets of these; we add extra4 anchors.
# ---------------------------------------------------------------------------

invariant calendar_extra4.TextCalendar.name:
  description: "calendar.TextCalendar.__name__ == 'TextCalendar'"
  category: class_identity
  kind: python_call_eq
  function: TextCalendar.__name__.__eq__
  args: ["TextCalendar"]
  expected: true

invariant calendar_extra4.HTMLCalendar.name:
  description: "calendar.HTMLCalendar.__name__ == 'HTMLCalendar'"
  category: class_identity
  kind: python_call_eq
  function: HTMLCalendar.__name__.__eq__
  args: ["HTMLCalendar"]
  expected: true

invariant calendar_extra4.LocaleTextCalendar.name:
  description: "calendar.LocaleTextCalendar.__name__ == 'LocaleTextCalendar'"
  category: class_identity
  kind: python_call_eq
  function: LocaleTextCalendar.__name__.__eq__
  args: ["LocaleTextCalendar"]
  expected: true

invariant calendar_extra4.LocaleHTMLCalendar.name:
  description: "calendar.LocaleHTMLCalendar.__name__ == 'LocaleHTMLCalendar'"
  category: class_identity
  kind: python_call_eq
  function: LocaleHTMLCalendar.__name__.__eq__
  args: ["LocaleHTMLCalendar"]
  expected: true
