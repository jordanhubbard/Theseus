spec: nanostores
version: ">=1.0.0"
backend: node(nanostores)

docs: https://github.com/nanostores/nanostores#readme

provenance:
  derived_from:
    - "Nano Stores README — https://github.com/nanostores/nanostores#readme"
    - "Test vectors verified with nanostores via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "nanostores source"
  notes:
    - "Tiny (286B) framework-agnostic atomic state — used by Astro and friends."
    - "Install: npm install nanostores"
    - "v1 ESM only; named exports atom / map / computed / task / etc."
    - "Atom and map setters mutate in place but return undefined; chain tests use {tap: true}."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; never throw."
  stderr: "null"
  stickiness: "N/A — each store is independent."
  codes: {}

invariant nanostores.atom_initial_value:
  description: "atom(initial).get() returns the initial value"
  category: atom
  kind: node_chain_eq
  entry: factory
  factory: atom
  entry_args: [42]
  chain:
    - {method: get, args: []}
  expected: 42

invariant nanostores.atom_set_then_get:
  description: "atom.set(v) then get() returns v"
  category: atom
  kind: node_chain_eq
  entry: factory
  factory: atom
  entry_args: [0]
  chain:
    - {method: set, args: [99], tap: true}
    - {method: get, args: []}
  expected: 99

invariant nanostores.atom_initial_string:
  description: "atom('hello').get() is 'hello'"
  category: atom
  kind: node_chain_eq
  entry: factory
  factory: atom
  entry_args: ["hello"]
  chain:
    - {method: get, args: []}
  expected: "hello"

invariant nanostores.map_initial:
  description: "map(initial).get() returns the initial object"
  category: map
  kind: node_chain_eq
  entry: factory
  factory: map
  entry_args: [{name: "alice", age: 30}]
  chain:
    - {method: get, args: []}
  expected: {name: "alice", age: 30}

invariant nanostores.map_setKey:
  description: "map.setKey(k, v) updates only that key"
  category: map
  kind: node_chain_eq
  entry: factory
  factory: map
  entry_args: [{name: "alice", age: 30}]
  chain:
    - {method: setKey, args: ["name", "bob"], tap: true}
    - {method: get, args: []}
  expected: {name: "bob", age: 30}

invariant nanostores.atom_has_listen_method:
  description: "Atom instance exposes a .listen function (subscribe API)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: atom
  entry_args: [0]
  chain:
    - {get: "listen.constructor.name"}
  expected: "Function"

invariant nanostores.atom_value_property:
  description: "Atom instance has a .value property holding the current value"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: atom
  entry_args: [42]
  chain:
    - {get: value}
  expected: 42

invariant nanostores.atom_factory_arity:
  description: "atom factory takes one arg (the initial value)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "atom.length"}
  expected: 1
