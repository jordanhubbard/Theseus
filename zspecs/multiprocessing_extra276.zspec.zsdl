spec: multiprocessing_extra276
version: ">=3.9"
backend: python_module(multiprocessing.connection)

docs: https://docs.python.org/3/library/multiprocessing.html#connection-objects

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#connection-objects — Connection, Listener, Pipe, Client identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "Connection.__bases__[0].__name__ is '_ConnectionBase', not 'object' — Connection subclasses _ConnectionBase"
    - "Connection method qualnames use '_ConnectionBase' prefix (send, recv, close, poll inherited from _ConnectionBase)"
    - "Pipe is a function (not a class) returning a pair of Connection objects"
    - "Client is a function (not a class) returning a Connection"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra276.connection_identity:
  description: "Connection class identity attributes and inherited method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: mpconn

  columns: [id, function, args, expected, description]
  rows:
    - [mpconn001, multiprocessing.connection.Connection.__name__.__eq__, ["Connection"], true, "Connection class __name__"]
    - [mpconn002, multiprocessing.connection.Connection.__module__.__eq__, ["multiprocessing.connection"], true, "Connection class __module__"]
    - [mpconn003, "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__", ["_ConnectionBase"], true, "Connection base class is _ConnectionBase"]
    - [mpconn004, multiprocessing.connection.Connection.send.__qualname__.__eq__, ["_ConnectionBase.send"], true, "Connection.send qualname (inherited from _ConnectionBase)"]
    - [mpconn005, multiprocessing.connection.Connection.recv.__qualname__.__eq__, ["_ConnectionBase.recv"], true, "Connection.recv qualname (inherited from _ConnectionBase)"]
    - [mpconn006, multiprocessing.connection.Connection.close.__qualname__.__eq__, ["_ConnectionBase.close"], true, "Connection.close qualname (inherited from _ConnectionBase)"]
    - [mpconn007, multiprocessing.connection.Connection.poll.__qualname__.__eq__, ["_ConnectionBase.poll"], true, "Connection.poll qualname (inherited from _ConnectionBase)"]

table multiprocessing_extra276.listener_and_helpers:
  description: "Listener class and helper function identity in multiprocessing.connection"
  kind: python_call_eq
  category: identity
  id_prefix: mplist

  columns: [id, function, args, expected, description]
  rows:
    - [mplist001, multiprocessing.connection.Listener.__name__.__eq__, ["Listener"], true, "Listener class __name__"]
    - [mplist002, multiprocessing.connection.Listener.__module__.__eq__, ["multiprocessing.connection"], true, "Listener class __module__"]
    - [mplist003, multiprocessing.connection.Pipe.__name__.__eq__, ["Pipe"], true, "Pipe function __name__"]
    - [mplist004, multiprocessing.connection.Client.__name__.__eq__, ["Client"], true, "Client function __name__"]

invariant multiprocessing_extra276.connection_base_class:
  description: "Connection's direct base class is _ConnectionBase, not object"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__"
  args: ["_ConnectionBase"]
  expected: true

invariant multiprocessing_extra276.pipe_name:
  description: "Pipe is a function with __name__ == 'Pipe'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Pipe.__name__.__eq__
  args: ["Pipe"]
  expected: true

invariant multiprocessing_extra276.listener_module:
  description: "Listener is defined in multiprocessing.connection"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Listener.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true
