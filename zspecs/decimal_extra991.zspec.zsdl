spec: decimal_extra991
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Decimal dunder method __qualname__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra991.decimal_conversion_qualnames:
  description: "decimal.Decimal type-conversion dunder __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dc991v
  columns: [id, function, args, expected]
  rows:
    - [dc991v001, decimal.Decimal.__str__.__qualname__.__eq__,   ["Decimal.__str__"],   true]
    - [dc991v002, decimal.Decimal.__repr__.__qualname__.__eq__,  ["Decimal.__repr__"],  true]
    - [dc991v003, decimal.Decimal.__int__.__qualname__.__eq__,   ["Decimal.__int__"],   true]
    - [dc991v004, decimal.Decimal.__float__.__qualname__.__eq__, ["Decimal.__float__"], true]
    - [dc991v005, decimal.Decimal.__bool__.__qualname__.__eq__,  ["Decimal.__bool__"],  true]

table decimal_extra991.decimal_rounding_qualnames:
  description: "decimal.Decimal rounding dunder __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dc991r
  columns: [id, function, args, expected]
  rows:
    - [dc991r001, decimal.Decimal.__round__.__qualname__.__eq__,  ["Decimal.__round__"],  true]
    - [dc991r002, decimal.Decimal.__trunc__.__qualname__.__eq__,  ["Decimal.__trunc__"],  true]
    - [dc991r003, decimal.Decimal.__floor__.__qualname__.__eq__,  ["Decimal.__floor__"],  true]
    - [dc991r004, decimal.Decimal.__ceil__.__qualname__.__eq__,   ["Decimal.__ceil__"],   true]

table decimal_extra991.decimal_class_identity:
  description: "decimal.Decimal class identity and hash dunder checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: dc991c
  columns: [id, function, args, expected]
  rows:
    - [dc991c001, decimal.Decimal.__hash__.__qualname__.__eq__,   ["Decimal.__hash__"],   true]
    - [dc991c002, decimal.Decimal.__module__.__eq__,              ["decimal"],             true]
    - [dc991c003, decimal.Decimal.__qualname__.__eq__,            ["Decimal"],             true]
    - [dc991c004, decimal.Decimal.__class__.__name__.__eq__,      ["type"],                true]
    - [dc991c005, decimal.Decimal.__doc__.__class__.__name__.__eq__, ["str"],              true]
    - [dc991c006, decimal.Decimal.__abs__.__qualname__.__eq__,    ["Decimal.__abs__"],     true]
    - [dc991c007, decimal.Decimal.__neg__.__qualname__.__eq__,    ["Decimal.__neg__"],     true]
    - [dc991c008, decimal.Decimal.__pos__.__qualname__.__eq__,    ["Decimal.__pos__"],     true]
