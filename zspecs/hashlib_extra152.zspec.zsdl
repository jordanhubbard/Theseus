spec: hashlib_extra152
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra151.zspec.zsdl — covers hashlib._hashlib.HASH.update/__qualname__.__eq__('HASH.update') / HASH.digest/__qualname__.__eq__('HASH.digest') / HASH.hexdigest/__qualname__.__eq__('HASH.hexdigest') / HASH.copy/__qualname__.__eq__('HASH.copy') / HASH.__dict__.__class__.__name__.__eq__('mappingproxy') / HASH.__dict__.__len__()==10 (table + invariants)."
    - "hashlib_extra150.zspec.zsdl — covers hashlib._hashlib.__name__.__eq__('_hashlib') / _hashlib.__spec__.name.__eq__('_hashlib') / _hashlib.__loader__.__class__.__name__.__eq__('ExtensionFileLoader') / _hashlib.__package__.__eq__('') / _hashlib.HASH.__name__/__module__/__qualname__ equality / hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / hashlib.__package__.__eq__('') (table + invariants)."
    - "hashlib_extra149.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__eq__('tuple') / __all__.__len__()==19 / __all__.__contains__ checks for md5/sha256/new/file_digest/algorithms_guaranteed/blake2b/pbkdf2_hmac/sha3_256/algorithms_available (table + invariants)."
    - "hashlib_extra148.zspec.zsdl — covers hashlib.file_digest/__qualname__/__module__/__class__.__name__ / __code__.co_argcount==2 / hashlib.__spec__.name.__eq__('hashlib') / hashlib.__doc__.__len__()==2098 (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / algorithms_guaranteed.__len__()==14."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra151."
    - "Wave 325 theme: hashlib.__dict__.__contains__ module-level membership — hashlib.__dict__.__contains__('md5')==True / __dict__.__contains__('sha256')==True / __dict__.__contains__('sha512')==True / __dict__.__contains__('new')==True / __dict__.__contains__('algorithms_guaranteed')==True / __dict__.__contains__('algorithms_available')==True / __dict__.__contains__('file_digest')==True. Also hashlib.__dict__.__len__()==33 / hashlib.__dict__.__class__.__name__.__eq__('dict')."
    - "hashlib.__dict__.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__contains__('sha512') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__contains__('new') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__contains__('algorithms_guaranteed') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__contains__('algorithms_available') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__contains__('file_digest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__len__() == 33. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__class__.__name__ == 'dict'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__dict__ is a plain 'dict' (4 chars) — not a 'mappingproxy'. Module-level __dict__ objects are always mutable plain dicts; class-level __dict__ objects (like hashlib._hashlib.HASH.__dict__) are mappingproxy objects. This contrasts with HASH.__dict__.__class__.__name__ (anchored in extra151 as 'mappingproxy', 12 chars)."
    - "Note: hashlib.__dict__.__len__() == 33. The 33 module-level entries include: __name__, __doc__, __package__, __loader__, __spec__, __file__, __cached__, __builtins__ (8 metadata), __all__ (1 list), the hash constructor shortcuts (md5, sha1, sha224, sha256, sha384, sha512, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256, blake2b, blake2s — 14 constructors), new, algorithms_guaranteed, algorithms_available, pbkdf2_hmac, scrypt, file_digest, _hashlib (22 public API entries total)."
    - "Note: The theme (hashlib.__dict__.__contains__) tests module-level membership rather than class-level membership. extra149 tests __all__.__contains__ for the same names (from the __all__ tuple); this spec tests hashlib.__dict__.__contains__ for the same names (from the module dict). Both __all__ and __dict__ contain these names, but __dict__ membership is more direct: it tests the actual namespace, while __all__ membership tests the exported API list."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__dict__.__contains__('md5')
# hashlib.__dict__.__contains__('sha256')
# hashlib.__dict__.__contains__('sha512')
# hashlib.__dict__.__contains__('new')
#
# Wave 325 theme: hashlib module-level __dict__ contains the primary hash names.
#
# md5, sha256, sha512 are constructor shortcuts at the module level. new is the
# generic constructor function. All four are present in hashlib.__dict__ as direct
# module-level attributes. extra149 anchors __all__.__contains__ for these same
# names; no prior hashlib spec anchors hashlib.__dict__.__contains__ for any name
# as a table under hashdct152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra152.module_dict_contains_primary_names:
  description: "hashlib.__dict__.__contains__('md5')==True / __dict__.__contains__('sha256')==True / __dict__.__contains__('sha512')==True / __dict__.__contains__('new')==True — module-level plain dict (33 entries); md5/sha256/sha512 are hash constructor shortcuts; new is the generic constructor; extra149 covers __all__.__contains__ for the same names; first hashdct152 anchor for hashlib.__dict__.__contains__ membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashdct152

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_md5,    "__dict__.__contains__", ["md5"],    true, "hashlib.__dict__.__contains__('md5') == True (hash constructor shortcut for the MD5 algorithm)"]
    - [module_dict_sha256, "__dict__.__contains__", ["sha256"], true, "hashlib.__dict__.__contains__('sha256') == True (hash constructor shortcut for SHA-256)"]
    - [module_dict_sha512, "__dict__.__contains__", ["sha512"], true, "hashlib.__dict__.__contains__('sha512') == True (hash constructor shortcut for SHA-512)"]
    - [module_dict_new,    "__dict__.__contains__", ["new"],    true, "hashlib.__dict__.__contains__('new') == True (generic hash constructor accepting algorithm name as string)"]

# ---------------------------------------------------------------------------
# hashlib.__dict__.__contains__('algorithms_guaranteed')
# hashlib.__dict__.__contains__('algorithms_available')
# hashlib.__dict__.__contains__('file_digest')
# hashlib.__dict__.__class__.__name__.__eq__('dict')
#
# Wave 325 theme: hashlib module-level __dict__ contains algorithm sets and file_digest.
#
# algorithms_guaranteed (a frozenset of always-available algorithm names),
# algorithms_available (a set of all available algorithm names), and file_digest
# (a function for hashing file-like objects) are all present in hashlib.__dict__.
# The module dict __class__.__name__ is 'dict' (4 chars), distinguishing it from
# class dicts which are 'mappingproxy' (12 chars). No prior hashlib spec anchors
# these as a table under hashdct152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra152.module_dict_contains_api_and_dict_class:
  description: "hashlib.__dict__.__contains__('algorithms_guaranteed')==True / __dict__.__contains__('algorithms_available')==True / __dict__.__contains__('file_digest')==True / hashlib.__dict__.__class__.__name__.__eq__('dict')==True — algorithms_guaranteed is a frozenset of guaranteed algorithm names; algorithms_available is a set of all available names; file_digest hashes file-like objects; module dict is plain 'dict' (4 chars), not 'mappingproxy' (12 chars) like class dicts; first hashdct152 anchor for these entries"
  kind: python_call_eq
  category: identity
  id_prefix: hashdct152

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_alg_guaranteed, "__dict__.__contains__",               ["algorithms_guaranteed"], true, "hashlib.__dict__.__contains__('algorithms_guaranteed') == True (frozenset of always-present algorithm names)"]
    - [module_dict_alg_available,  "__dict__.__contains__",               ["algorithms_available"],  true, "hashlib.__dict__.__contains__('algorithms_available') == True (set of all available algorithm names)"]
    - [module_dict_file_digest,    "__dict__.__contains__",               ["file_digest"],           true, "hashlib.__dict__.__contains__('file_digest') == True (function that hashes a file-like object)"]
    - [module_dict_class_dict,     "__dict__.__class__.__name__.__eq__",  ["dict"],                  true, "hashlib.__dict__.__class__.__name__ == 'dict' (4 chars; plain mutable dict, not mappingproxy like class dicts)"]

# ---------------------------------------------------------------------------
# hashlib.__dict__.__len__()==33
# hashlib.__dict__.__class__.__name__.__len__()==4
#
# Wave 325 theme: hashlib module-level __dict__ length and type name length.
#
# hashlib.__dict__.__len__() is 33. The 33 entries include 8 metadata attributes
# (__name__, __doc__, etc.), 14 hash constructor shortcuts (md5, sha1, sha224, sha256,
# sha384, sha512, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256,
# blake2b, blake2s), and 11 additional public API entries (new, algorithms_guaranteed,
# algorithms_available, pbkdf2_hmac, scrypt, file_digest, __all__, _hashlib, _clearcache,
# __builtins__, and others). The dict class name 'dict' (4 chars) is shorter than
# the class dict type name 'mappingproxy' (12 chars, anchored in extra151 for HASH.__dict__).
# No prior hashlib spec anchors hashlib.__dict__.__len__() as a table under hashdct152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra152.module_dict_len_and_class_len:
  description: "hashlib.__dict__.__len__()==33 / hashlib.__dict__.__class__.__name__.__len__()==4 — 33 entries: 8 metadata + 14 hash constructors (md5/sha1/sha224/sha256/sha384/sha512/sha3_224/sha3_256/sha3_384/sha3_512/shake_128/shake_256/blake2b/blake2s) + 11 public API entries; class name 'dict' (4 chars) shorter than class dict type 'mappingproxy' (12 chars); no prior hashlib spec anchors these under hashdct152"
  kind: python_call_eq
  category: identity
  id_prefix: hashdct152

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_len_33,       "__dict__.__len__",                     [],      33, "hashlib.__dict__.__len__() is 33 (8 metadata + 14 hash constructors + 11 public API entries)"]
    - [module_dict_class_len_4,  "__dict__.__class__.__name__.__len__",  [],       4, "hashlib.__dict__.__class__.__name__.__len__() is 4 ('dict' = 4 chars; shorter than 'mappingproxy' = 12)"]

# ---------------------------------------------------------------------------
# hashlib.__dict__.__contains__('md5') — standalone
#
# hashlib.__dict__.__contains__('md5') is True. The 'md5' entry at the module level
# is a hash constructor shortcut — calling hashlib.md5(data) is equivalent to
# hashlib.new('md5', data) but faster since it bypasses the name-lookup overhead.
# extra99 anchors hashlib.md5.__class__.__name__.__eq__ and __name__.__eq__('md5');
# extra149 anchors hashlib.__all__.__contains__('md5'); no prior hashlib spec anchors
# hashlib.__dict__.__contains__('md5') as a standalone under hashdct152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra152.module_dict_contains_md5:
  description: "hashlib.__dict__.__contains__('md5') == True — 'md5' is a hash constructor shortcut; hashlib.md5(data) equivalent to hashlib.new('md5', data) but faster; extra99 anchors md5 class name and __name__; extra149 anchors __all__.__contains__('md5'); no prior hashlib spec anchors this as a standalone; first standalone under hashdct152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__dict__.__contains__('sha256') — standalone
#
# hashlib.__dict__.__contains__('sha256') is True. The 'sha256' entry is a hash
# constructor shortcut for the SHA-256 algorithm. SHA-256 produces a 32-byte
# (256-bit) digest and is the most widely used secure hash in modern cryptography.
# It is a member of the SHA-2 family. extra99 anchors hashlib.sha256.__class__.__name__;
# extra149 anchors __all__.__contains__('sha256'); no prior hashlib spec anchors
# hashlib.__dict__.__contains__('sha256') as a standalone under hashdct152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra152.module_dict_contains_sha256:
  description: "hashlib.__dict__.__contains__('sha256') == True — 'sha256' is a hash constructor shortcut; SHA-256 produces 32-byte (256-bit) digest; SHA-2 family; most widely used secure hash; extra99 anchors sha256 class name; extra149 anchors __all__.__contains__('sha256'); no prior hashlib spec anchors this as a standalone; first standalone under hashdct152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__dict__.__contains__('algorithms_guaranteed') — standalone
#
# hashlib.__dict__.__contains__('algorithms_guaranteed') is True. The
# 'algorithms_guaranteed' attribute is a frozenset of algorithm name strings that
# are guaranteed to be available on all CPython platforms (regardless of the
# underlying OpenSSL version). extra145 anchors algorithms_guaranteed.__class__.__name__
# == 'set' (actually a frozenset but reported as 'set' prior to Python 3.12 changes,
# verified as 'set' in extra99 with __len__==14); extra149 anchors
# __all__.__contains__('algorithms_guaranteed'); no prior hashlib spec anchors
# hashlib.__dict__.__contains__('algorithms_guaranteed') as a standalone under
# hashdct152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra152.module_dict_contains_algorithms_guaranteed:
  description: "hashlib.__dict__.__contains__('algorithms_guaranteed') == True — frozenset of algorithm names guaranteed on all CPython platforms; extra145 anchors __class__.__name__=='set'; extra99 anchors __len__()==14; extra149 anchors __all__.__contains__('algorithms_guaranteed'); no prior hashlib spec anchors this as a standalone; first standalone under hashdct152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["algorithms_guaranteed"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__dict__.__contains__('file_digest') — standalone
#
# hashlib.__dict__.__contains__('file_digest') is True. The 'file_digest' function
# (added in Python 3.11) hashes the entire contents of a file-like object, returning
# a HASH object. It reads the file in chunks and updates the hash incrementally,
# making it memory-efficient for large files. extra148 anchors file_digest.__qualname__
# == 'file_digest' and __code__.co_argcount == 2; extra149 anchors
# __all__.__contains__('file_digest'); no prior hashlib spec anchors
# hashlib.__dict__.__contains__('file_digest') as a standalone under hashdct152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra152.module_dict_contains_file_digest:
  description: "hashlib.__dict__.__contains__('file_digest') == True — added in Python 3.11; hashes entire file-like object contents in chunks; returns a HASH object; memory-efficient for large files; extra148 anchors qualname and co_argcount==2; extra149 anchors __all__.__contains__('file_digest'); no prior hashlib spec anchors this as a standalone; first standalone under hashdct152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__dict__.__len__()==33 — standalone
#
# hashlib.__dict__.__len__() is 33. The hashlib module dict is notably large
# compared to the struct module dict (18 entries) because hashlib exposes 14
# individual hash constructor shortcuts (one per algorithm) in addition to the
# common module infrastructure entries. Comparing module dict sizes: struct.__dict__
# (18 entries) < hashlib.__dict__ (33 entries) << uuid.__dict__ (75 entries) <<<
# socket.__dict__ (267 entries, dominated by socket constants). No prior hashlib spec
# anchors hashlib.__dict__.__len__()==33 as a standalone under hashdct152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra152.module_dict_len_33:
  description: "hashlib.__dict__.__len__() == 33 — 33 entries: 8 metadata + 14 hash constructors + 11 public API; module dict ordering: struct(18) < hashlib(33) < uuid(75) << socket(267); larger than struct due to 14 individual hash shortcut entries; no prior hashlib spec anchors this as a standalone; first standalone under hashdct152"
  category: identity
  kind: python_call_eq
  function: "__dict__.__len__"
  args: []
  expected: 33

