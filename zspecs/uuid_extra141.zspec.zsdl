spec: uuid_extra141
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra140.zspec.zsdl — covers uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') (len 16) / UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__') (len 17) / UUID.__setstate__.__qualname__.__eq__('UUID.__setstate__') (len 17) / all three __class__.__name__.__eq__('function') (table + invariants)."
    - "uuid_extra139.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('urn'/'bytes_le'/'node'/'fields'/'__str__'/'__repr__'/'__hash__'/'variant') / UUID.__dict__.__len__()==37 / UUID.__doc__.__len__()==2787 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__package__.__eq__('') (table + invariants)."
    - "uuid_extra138.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') (all four namespace constants) / NAMESPACE_DNS.version==1 / NAMESPACE_DNS.hex.__len__()==32 / uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / uuid.UUID.__name__.__eq__('UUID') (table + invariants)."
    - "uuid_extra137.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('hex'/'int'/'bytes'/'version'/__slots__/__init__) / UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__spec__.name.__eq__('uuid') / uuid.__doc__.__len__()==1948 (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra140."
    - "Wave 326 theme: uuid.__dict__.__contains__ module-level membership — uuid.__dict__.__contains__('UUID')==True / __dict__.__contains__('uuid1')==True / __dict__.__contains__('uuid3')==True / __dict__.__contains__('uuid4')==True / __dict__.__contains__('uuid5')==True / __dict__.__contains__('NAMESPACE_DNS')==True / __dict__.__contains__('NAMESPACE_URL')==True. Also uuid.__dict__.__len__()==75 / uuid.__dict__.__class__.__name__.__eq__('dict')."
    - "uuid.__dict__.__contains__('UUID') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('uuid1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('uuid3') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('uuid4') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('uuid5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('NAMESPACE_DNS') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__('NAMESPACE_URL') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__len__() == 75. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__class__.__name__ == 'dict'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.__dict__ is a plain 'dict' (4 chars) — not a 'mappingproxy'. Module-level __dict__ objects are always mutable plain dicts; class-level __dict__ objects (like uuid.UUID.__dict__) are mappingproxy objects (anchored in extra137). The module dict __class__.__name__ 'dict' (4 chars) is shorter than the class dict type name 'mappingproxy' (12 chars)."
    - "Note: uuid.__dict__.__len__() == 75. The uuid module dict is substantially larger than struct.__dict__ (18 entries) or hashlib.__dict__ (33 entries), but smaller than socket.__dict__ (267 entries). The 75 entries include: UUID class, SafeUUID class, uuid1/uuid3/uuid4/uuid5 functions, 4 NAMESPACE_* constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500), getnode and other utility functions, module metadata (__name__, __doc__, etc.), and a large set of internal helper names."
    - "Note: The four uuid-generation functions uuid1/uuid3/uuid4/uuid5 are all present in uuid.__dict__. extra96 anchors their __code__.co_name equality; this spec is the first to anchor uuid.__dict__.__contains__ for these function names."
    - "Note: The NAMESPACE_* constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) are all present in uuid.__dict__. They are UUID instances with predefined values used as the namespace argument to uuid3() and uuid5() for name-based UUID generation. extra138 anchors NAMESPACE_DNS.__class__.__name__ and .version; this spec anchors NAMESPACE_DNS and NAMESPACE_URL as module-level dict members."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__('UUID')
# uuid.__dict__.__contains__('uuid1')
# uuid.__dict__.__contains__('uuid3')
# uuid.__dict__.__contains__('uuid4')
#
# Wave 326 theme: uuid module-level __dict__ contains the UUID class and generators.
#
# UUID is the central class of the uuid module. uuid1/uuid3/uuid4 are three of the
# four UUID generation functions. All four are present in uuid.__dict__ as direct
# module-level attributes. extra96 anchors uuid1/uuid3/uuid4 __code__.co_name;
# no prior uuid spec anchors uuid.__dict__.__contains__ for any name as a table
# under uuidmod141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra141.module_dict_contains_UUID_and_generators:
  description: "uuid.__dict__.__contains__('UUID')==True / __dict__.__contains__('uuid1')==True / __dict__.__contains__('uuid3')==True / __dict__.__contains__('uuid4')==True — UUID is the central class; uuid1/uuid3/uuid4 are three of the four generation functions; all present in module-level plain dict (75 entries); extra96 anchors uuid1/uuid3/uuid4 co_name; first uuidmod141 anchor for uuid.__dict__.__contains__ membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod141

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_UUID,  "__dict__.__contains__", ["UUID"],  true, "uuid.__dict__.__contains__('UUID') == True (the central UUID class; extra137 anchors UUID.__dict__ as mappingproxy)"]
    - [module_dict_uuid1, "__dict__.__contains__", ["uuid1"], true, "uuid.__dict__.__contains__('uuid1') == True (generates a time-based version-1 UUID)"]
    - [module_dict_uuid3, "__dict__.__contains__", ["uuid3"], true, "uuid.__dict__.__contains__('uuid3') == True (generates a name-based version-3 UUID using MD5)"]
    - [module_dict_uuid4, "__dict__.__contains__", ["uuid4"], true, "uuid.__dict__.__contains__('uuid4') == True (generates a random version-4 UUID)"]

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__('uuid5')
# uuid.__dict__.__contains__('NAMESPACE_DNS')
# uuid.__dict__.__contains__('NAMESPACE_URL')
# uuid.__dict__.__class__.__name__.__eq__('dict')
#
# Wave 326 theme: uuid module-level __dict__ contains uuid5 and namespace constants.
#
# uuid5 is the fourth UUID generation function (name-based using SHA-1). NAMESPACE_DNS
# and NAMESPACE_URL are two of the four predefined namespace UUID constants used with
# uuid3() and uuid5(). The module dict class name is 'dict' (4 chars), confirming it
# is a plain mutable dict rather than a mappingproxy. No prior uuid spec anchors
# these as a table under uuidmod141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra141.module_dict_contains_uuid5_namespaces_and_dict_class:
  description: "uuid.__dict__.__contains__('uuid5')==True / __dict__.__contains__('NAMESPACE_DNS')==True / __dict__.__contains__('NAMESPACE_URL')==True / uuid.__dict__.__class__.__name__.__eq__('dict')==True — uuid5 generates name-based version-5 UUID using SHA-1; NAMESPACE_DNS and NAMESPACE_URL are predefined UUID namespace constants for uuid3()/uuid5(); module dict is plain 'dict' (4 chars) not 'mappingproxy'; extra138 anchors NAMESPACE_DNS identity; first uuidmod141 anchor for these"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod141

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_uuid5,          "__dict__.__contains__",              ["uuid5"],         true, "uuid.__dict__.__contains__('uuid5') == True (name-based version-5 UUID using SHA-1 instead of MD5)"]
    - [module_dict_NAMESPACE_DNS,  "__dict__.__contains__",              ["NAMESPACE_DNS"],  true, "uuid.__dict__.__contains__('NAMESPACE_DNS') == True (predefined DNS namespace UUID; extra138 anchors its identity)"]
    - [module_dict_NAMESPACE_URL,  "__dict__.__contains__",              ["NAMESPACE_URL"],  true, "uuid.__dict__.__contains__('NAMESPACE_URL') == True (predefined URL namespace UUID for name-based generation)"]
    - [module_dict_class_dict,     "__dict__.__class__.__name__.__eq__", ["dict"],           true, "uuid.__dict__.__class__.__name__ == 'dict' (4 chars; plain mutable dict, not mappingproxy like class dicts)"]

# ---------------------------------------------------------------------------
# uuid.__dict__.__len__()==75
# uuid.__dict__.__class__.__name__.__len__()==4
#
# Wave 326 theme: uuid module-level __dict__ length and dict type name length.
#
# uuid.__dict__.__len__() is 75. The 75 entries are notably more than struct.__dict__
# (18) or hashlib.__dict__ (33), reflecting that uuid.py has a richer module namespace:
# the UUID class, SafeUUID, uuid1/3/4/5, four NAMESPACE_* constants, getnode, and
# many internal helper functions and constants (including _CTYPE_UUID, _lsf_int, etc.).
# The 'dict' type name (4 chars) is 8 chars shorter than 'mappingproxy' (12 chars).
# No prior uuid spec anchors uuid.__dict__.__len__() as a table under uuidmod141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra141.module_dict_len_and_class_name_len:
  description: "uuid.__dict__.__len__()==75 / uuid.__dict__.__class__.__name__.__len__()==4 — 75 module-level entries: UUID class + SafeUUID + uuid1/3/4/5 + 4 NAMESPACE_* + getnode + internals + metadata; larger than struct(18) and hashlib(33); module dict ordering: struct(18) < hashlib(33) < uuid(75) << socket(267); 'dict' (4 chars) vs 'mappingproxy' (12 chars); no prior uuid spec anchors these under uuidmod141"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod141

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_len_75,       "__dict__.__len__",                    [],      75, "uuid.__dict__.__len__() is 75 (UUID + SafeUUID + uuid1/3/4/5 + 4 NAMESPACE_* + getnode + internals + metadata)"]
    - [module_dict_class_len_4,  "__dict__.__class__.__name__.__len__", [],       4, "uuid.__dict__.__class__.__name__.__len__() is 4 ('dict' = 4 chars; 8 shorter than 'mappingproxy' = 12)"]

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__('UUID') — standalone
#
# uuid.__dict__.__contains__('UUID') is True. The 'UUID' key at the module level
# refers to the uuid.UUID class — the central type of the uuid module. UUID objects
# represent Universally Unique Identifiers as immutable Python objects. The UUID class
# has a 37-entry class __dict__ (anchored in extra139) and a 2787-char docstring
# (anchored in extra139). extra137 anchors UUID.__dict__.__class__.__name__
# == 'mappingproxy'; no prior uuid spec anchors uuid.__dict__.__contains__('UUID')
# as a standalone under uuidmod141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra141.module_dict_contains_UUID:
  description: "uuid.__dict__.__contains__('UUID') == True — central UUID class; represents immutable Universally Unique Identifiers; UUID.__dict__ has 37 entries (extra139) and 2787-char docstring (extra139); extra137 anchors UUID.__dict__ as mappingproxy; no prior uuid spec anchors this as a standalone; first standalone under uuidmod141"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__('uuid4') — standalone
#
# uuid.__dict__.__contains__('uuid4') is True. uuid4() generates a random version-4
# UUID using random bytes from os.urandom(). Version-4 UUIDs are the most commonly
# used UUID variant in practice because they require no network access, no shared
# state, and no clock synchronization — they rely entirely on random number generation.
# extra96 anchors uuid4.__code__.co_name equality; no prior uuid spec anchors
# uuid.__dict__.__contains__('uuid4') as a standalone under uuidmod141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra141.module_dict_contains_uuid4:
  description: "uuid.__dict__.__contains__('uuid4') == True — uuid4() generates random version-4 UUID using os.urandom(); most commonly used UUID variant (no network/clock/shared state needed); extra96 anchors co_name equality; no prior uuid spec anchors this as a standalone; first standalone under uuidmod141"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__('NAMESPACE_DNS') — standalone
#
# uuid.__dict__.__contains__('NAMESPACE_DNS') is True. NAMESPACE_DNS is a predefined
# UUID constant (6ba7b810-9dad-11d1-80b4-00c04fd430c8) used as the namespace argument
# to uuid3() and uuid5() for generating name-based UUIDs from DNS names. It is a
# UUID instance (anchored in extra138 as __class__.__name__ == 'UUID' with version==1)
# defined in RFC 4122. All four NAMESPACE_* constants are present in uuid.__dict__
# (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500). No prior uuid spec
# anchors uuid.__dict__.__contains__('NAMESPACE_DNS') as a standalone under uuidmod141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra141.module_dict_contains_NAMESPACE_DNS:
  description: "uuid.__dict__.__contains__('NAMESPACE_DNS') == True — predefined UUID 6ba7b810-9dad-11d1-80b4-00c04fd430c8; used as namespace for uuid3()/uuid5() with DNS names; RFC 4122 defined; extra138 anchors __class__.__name__=='UUID' and version==1; no prior uuid spec anchors this as a standalone; first standalone under uuidmod141"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["NAMESPACE_DNS"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__dict__.__contains__('NAMESPACE_URL') — standalone
#
# uuid.__dict__.__contains__('NAMESPACE_URL') is True. NAMESPACE_URL is a predefined
# UUID constant (6ba7b811-9dad-11d1-80b4-00c04fd430c8) used as the namespace argument
# to uuid3() and uuid5() for generating name-based UUIDs from URLs. It is one of the
# four RFC 4122 predefined namespace UUIDs alongside NAMESPACE_DNS, NAMESPACE_OID,
# and NAMESPACE_X500. All four are present in uuid.__dict__. No prior uuid spec anchors
# uuid.__dict__.__contains__('NAMESPACE_URL') as a standalone under uuidmod141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra141.module_dict_contains_NAMESPACE_URL:
  description: "uuid.__dict__.__contains__('NAMESPACE_URL') == True — predefined UUID 6ba7b811-9dad-11d1-80b4-00c04fd430c8; used as namespace for uuid3()/uuid5() with URLs; one of four RFC 4122 predefined namespaces (DNS/URL/OID/X500); all four present in uuid.__dict__; no prior uuid spec anchors this as a standalone; first standalone under uuidmod141"
  category: identity
  kind: python_call_eq
  function: "__dict__.__contains__"
  args: ["NAMESPACE_URL"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__dict__.__len__()==75 — standalone
#
# uuid.__dict__.__len__() is 75. The uuid module dict is substantially larger than
# the struct (18) and hashlib (33) module dicts, reflecting uuid.py's richer module
# namespace including UUID/SafeUUID classes, uuid1/3/4/5 generators, four NAMESPACE_*
# constants, getnode, and many internal helper functions and constants. The size
# ordering across module dicts: struct(18) < hashlib(33) < uuid(75) << socket(267).
# No prior uuid spec anchors uuid.__dict__.__len__()==75 as a standalone under uuidmod141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra141.module_dict_len_75:
  description: "uuid.__dict__.__len__() == 75 — 75 module-level entries: UUID + SafeUUID + uuid1/3/4/5 + 4 NAMESPACE_* + getnode + internals + metadata; ordering: struct(18) < hashlib(33) < uuid(75) << socket(267); richer namespace than struct/hashlib due to multiple internal helpers; no prior uuid spec anchors this as a standalone; first standalone under uuidmod141"
  category: identity
  kind: python_call_eq
  function: "__dict__.__len__"
  args: []
  expected: 75
