spec: is_ascii
version: ">=1.0.0"
backend: node(is-ascii)

docs: https://www.npmjs.com/package/is-ascii

provenance:
  derived_from:
    - "is-ascii README — https://www.npmjs.com/package/is-ascii"
    - "Test vectors verified with is-ascii via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-ascii source"
  notes:
    - "is-ascii is an npm package. Install: npm install is-ascii"
    - "Returns true if the string contains only ASCII characters."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_ascii.check:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: isascii

  columns: [id, args, expected]
  rows:
    - [ascii,     ["hello"],    true]
    - [non_ascii, ["héllo"],    false]
    - [symbols,   ["!@#$%"],    true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:23:23Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
