spec: antigravity_extra2
version: ">=3.0"
backend: python_module(antigravity)

docs: https://docs.python.org/3/library/antigravity.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/antigravity.html — Python antigravity documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/antigravity.py"
  notes:
    - "This spec extends antigravity.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "geohash raises no documented exceptions for valid inputs. Import side-effect opens a browser tab."
  stderr: "null"
  stickiness: "N/A — function attribute checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Module name and file type checks
# ---------------------------------------------------------------------------

invariant antigravity_extra2.module_name:
  description: "antigravity.__name__ == 'antigravity'"
  category: module_meta
  kind: python_call_eq
  function: __name__.__eq__
  args: ["antigravity"]
  expected: true

invariant antigravity_extra2.file_is_str:
  description: "antigravity.__file__.__class__.__name__ == 'str'"
  category: module_meta
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# geohash function attribute checks (new — not in antigravity.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant antigravity_extra2.geohash_name_str:
  description: "antigravity.geohash.__name__ is a str"
  category: functions
  kind: python_call_eq
  function: geohash.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant antigravity_extra2.geohash_module_eq:
  description: "antigravity.geohash.__module__ == 'antigravity'"
  category: functions
  kind: python_call_eq
  function: geohash.__module__.__eq__
  args: ["antigravity"]
  expected: true

invariant antigravity_extra2.geohash_qualname_eq:
  description: "antigravity.geohash.__qualname__ == 'geohash'"
  category: functions
  kind: python_call_eq
  function: geohash.__qualname__.__eq__
  args: ["geohash"]
  expected: true

# ---------------------------------------------------------------------------
# geohash is a callable (function class)
# ---------------------------------------------------------------------------

invariant antigravity_extra2.geohash_is_function:
  description: "antigravity.geohash.__class__.__name__ == 'function'"
  category: functions
  kind: python_call_eq
  function: geohash.__class__.__name__.__eq__
  args: ["function"]
  expected: true
