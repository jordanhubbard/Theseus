spec: re_extra15
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra14.zspec.zsdl."
    - "re_extra14 covers: RegexFlag.__name__/__qualname__/__module__; RegexFlag.__bases__[0].__name__=='IntFlag'; compile(r'[a-z]+').pattern; match(r'(\\w+)\\s+(\\w+)','foo bar').group(2) and .groups().__len__(); subn(r'\\d','X','a1b2c3')[0] and [1]; match(r'\\d+','123abc').start() and .end()."
    - "re_extra12 covers: fullmatch(r'\\d+','123') not None; fullmatch(r'\\d+','12x') None; escape('hello'); IGNORECASE|MULTILINE==10; search named group; search capture group 1; sub whitespace collapse; split(r'\\s+', 'a b c')."
    - "NOT yet covered: re.fullmatch('ab+', 'abbb') returning a non-None match (different pattern from prior specs)."
    - "NOT yet covered: re.fullmatch('ab+', 'abc') returning None (trailing 'c' prevents full match of ab+)."
    - "NOT yet covered: re.split(r'\\s+', 'hello world foo') == ['hello', 'world', 'foo'] — three-word split."
    - "NOT yet covered: re.split(r',', 'a,b,c') == ['a', 'b', 'c'] — comma delimiter split."
    - "NOT yet covered: re.findall(r'\\d+', 'abc123def456') == ['123', '456'] — two digit runs."
    - "NOT yet covered: re.findall(r'[a-z]+', 'abc123def') == ['abc', 'def'] — two alpha runs."
    - "NOT yet covered: re.escape('hello.world') == 'hello\\\\.world' — dot metachar escaped."
    - "NOT yet covered: re.escape('price$') == 'price\\\\$' — dollar metachar escaped."
    - "re.fullmatch('ab+', 'abbb') — the pattern ab+ requires 'a' then one or more 'b'; 'abbb' satisfies this as a full match."
    - "re.fullmatch('ab+', 'abc') — 'abc' ends with 'c' which is not matched by ab+, so fullmatch returns None."
    - "re.split(r'\\s+', 'hello world foo') — three whitespace-delimited tokens yield three list elements."
    - "re.split(r',', 'a,b,c') — comma delimiter; yields three single-character elements."
    - "re.findall(r'\\d+', 'abc123def456') — two runs of consecutive digits; '123' and '456'."
    - "re.findall(r'[a-z]+', 'abc123def') — two lowercase-letter runs; 'abc' and 'def' (digits separate them)."
    - "re.escape('hello.world') == 'hello\\\\.world' — only the dot requires escaping."
    - "re.escape('price$') == 'price\\\\$' — only the dollar sign requires escaping."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.fullmatch — 'ab+' pattern with matching and non-matching subjects
#
# re_extra3 covers fullmatch('a+', 'aaa') returning a Match object.
# re_extra12 covers fullmatch(r'\d+', '123') not None and fullmatch(r'\d+', '12x') None.
# re_patterns covers fullmatch(r'\d{3}', '123') and fullmatch(r'\d{3}', '1234').
# No prior spec uses the pattern 'ab+' (literal 'a' plus one-or-more 'b').
# fullmatch('ab+', 'abbb') returns a Match (not None); we test via __class__.__name__.
# fullmatch('ab+', 'abc') returns None; we test via the `is` None identity.
# ---------------------------------------------------------------------------

invariant re_extra15.fullmatch.abplus_match:
  description: "re.fullmatch('ab+', 'abbb') returns a Match — trailing b's satisfy ab+"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["ab+", "abbb"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

invariant re_extra15.fullmatch.abplus_none:
  description: "re.fullmatch('ab+', 'abc') is None — 'c' prevents full match of ab+"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["ab+", "abc"]
  expected: ~

# ---------------------------------------------------------------------------
# re.split — whitespace and comma delimiters
#
# re_extra12 covers split(r'\s+', 'a b c') == ['a', 'b', 'c'] (single spaces).
# No prior spec uses a three-word string with single-space separators via r'\s+'
# where the words differ ('hello', 'world', 'foo'). No prior spec uses a comma
# literal as the pattern for split.
# ---------------------------------------------------------------------------

invariant re_extra15.split.whitespace_three_words:
  description: "re.split(r'\\s+', 'hello world foo') == ['hello', 'world', 'foo']"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "hello world foo"]
  expected: ["hello", "world", "foo"]

invariant re_extra15.split.comma_delimiter:
  description: "re.split(r',', 'a,b,c') == ['a', 'b', 'c'] — comma-literal split"
  category: split
  kind: python_call_eq
  function: split
  args: [",", "a,b,c"]
  expected: ["a", "b", "c"]

# ---------------------------------------------------------------------------
# re.findall — digit runs and lowercase-letter runs
#
# re_extra10 covers findall(r'\d+', ...) returning a list of length 3.
# No prior spec tests findall returning exactly ['123', '456'] for two digit runs,
# nor findall(r'[a-z]+', ...) returning exactly ['abc', 'def'] for two alpha runs.
# ---------------------------------------------------------------------------

invariant re_extra15.findall.digit_runs:
  description: "re.findall(r'\\d+', 'abc123def456') == ['123', '456'] — two digit runs"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "abc123def456"]
  expected: ["123", "456"]

invariant re_extra15.findall.alpha_runs:
  description: "re.findall(r'[a-z]+', 'abc123def') == ['abc', 'def'] — two lowercase runs"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["[a-z]+", "abc123def"]
  expected: ["abc", "def"]

# ---------------------------------------------------------------------------
# re.escape — metacharacter escaping
#
# re_extra10 covers escape('a.b') == 'a\\.b'.
# re_extra12 covers escape('hello') == 'hello' (no metacharacters).
# No prior spec uses 'hello.world' (dot in the middle) or 'price$' (dollar sign).
# re.escape only adds a backslash before characters that have special regex meaning.
# ---------------------------------------------------------------------------

invariant re_extra15.escape.dot_in_word:
  description: "re.escape('hello.world') == 'hello\\\\.world' — dot metachar escaped"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["hello.world"]
  expected: "hello\\.world"

invariant re_extra15.escape.dollar_sign:
  description: "re.escape('price$') == 'price\\\\$' — dollar metachar escaped"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["price$"]
  expected: "price\\$"

# ---------------------------------------------------------------------------
# Table: split behavioral vectors
#
# No prior spec provides a table of split() results.
# Groups whitespace and comma split vectors in one indexed table.
# ---------------------------------------------------------------------------

table re_extra15.split_vectors:
  description: "re.split behavioral vectors — whitespace and comma delimiters"
  kind: python_call_eq
  category: split
  id_prefix: sp

  columns: [id, function, args, expected]
  rows:
    - [ws3,    split, ["\\s+", "hello world foo"], ["hello", "world", "foo"]]
    - [comma3, split, [",",    "a,b,c"],           ["a", "b", "c"]]
