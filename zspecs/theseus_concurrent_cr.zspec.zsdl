spec: theseus_concurrent_cr
version: ">=3.9"
backend: python_cleanroom(theseus_concurrent_cr)
blocks: concurrent

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
  notes:
    - "Clean-room concurrent.futures-like executor. Do NOT import concurrent, threading, or multiprocessing."
    - "Future: result holder with result() method and done() predicate."
    - "SynchronousExecutor: executes callables synchronously (no threads needed)."
    - "submit(fn, *args) -> Future: wraps fn(*args) call in a Future."
    - "map(fn, iterable): applies fn to each item, returns results in order."
    - "concurrent_future_result(): submit(lambda: 42).result() == 42."
    - "concurrent_map(): list(map(str, [1,2,3])) == ['1','2','3']."
    - "concurrent_done(): submitted future.done() == True after completion."
    - "Export: Future, SynchronousExecutor (or Executor) class."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_concurrent_cr.future_result:
  description: "submit(fn).result() returns fn's return value"
  category: future
  kind: python_call_eq
  function: concurrent_future_result
  args: []
  expected: 42

invariant theseus_concurrent_cr.map_results:
  description: "list(executor.map(str, [1,2,3])) == ['1','2','3']"
  category: map
  kind: python_call_eq
  function: concurrent_map_results
  args: []
  expected: ["1", "2", "3"]

invariant theseus_concurrent_cr.future_done:
  description: "completed future.done() == True"
  category: done
  kind: python_call_eq
  function: concurrent_future_done
  args: []
  expected: true
