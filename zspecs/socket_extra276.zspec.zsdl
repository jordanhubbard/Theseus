spec: socket_extra276
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl through socket_extra275.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra270.zspec.zsdl covers: socket.socket __init__/__repr__/__str__ method identity; socket.timeout/error identity; socket.socket.family/type property descriptors."
    - "socket_extra275.zspec.zsdl covers: __module__ attribute for pure-Python socket functions; has_dualstack_ipv6/__name__; getaddrinfo/__name__; IPPROTO_ICMP value; getfqdn/__name__; module __name__."
    - "This spec focuses on: socket.socket I/O method __qualname__ values for connect/bind/listen/accept; socket.socket.send/__qualname__ and recv/__qualname__; the method descriptor class name for these I/O methods."
    - "socket.socket.connect is a C-level method_descriptor; its __qualname__ is 'socket.connect' (class name dot method name). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — C method descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.listen.__qualname__ == 'socket.listen' — C method descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.accept.__qualname__ == 'socket.accept' — C method descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.send.__qualname__ == 'socket.send' — C method descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.recv.__qualname__ == 'socket.recv' — C method descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.connect.__class__.__name__ == 'method_descriptor' — these I/O methods are C-level method_descriptor objects, not pure-Python functions. This contrasts with socket.socket.__init__ which is a pure-Python 'function'."
    - "socket.socket.connect.__name__ == 'connect'; socket.socket.bind.__name__ == 'bind'; socket.socket.listen.__name__ == 'listen'; socket.socket.accept.__name__ == 'accept' — all verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "socket.socket I/O methods raise OSError subclasses on network failures. Attribute access on the class object is stateless and never raises."
  stderr: "null"
  stickiness: "N/A — all tested invariants are pure attribute lookups on the class object."
  codes: {}

# ---------------------------------------------------------------------------
# socket.socket I/O method __qualname__ values
# socket_extra270 covers __init__/__repr__/__str__ which are pure-Python
# methods (class 'function'). No prior spec covers the __qualname__ of the
# core I/O methods: connect, bind, listen, accept.
# These are C-level method_descriptor objects from the _socket C extension.
# Their __qualname__ follows the pattern '<class_name>.<method_name>' where
# <class_name> is 'socket' (the C class underlying socket.socket).
# ---------------------------------------------------------------------------

table socket_extra276.socket_io_method_qualnames:
  description: "socket.socket I/O method __qualname__ values — connect/bind/listen/accept are C-level method_descriptors with qualname pattern 'socket.<method>'; novel coverage; socket_extra270 covers __init__/__repr__/__str__; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iomq276

  columns: [id, function, args, expected]
  rows:
    - [connect, socket.connect.__qualname__.__eq__, ["socket.connect"], true]
    - [bind,    socket.bind.__qualname__.__eq__,    ["socket.bind"],    true]
    - [listen,  socket.listen.__qualname__.__eq__,  ["socket.listen"],  true]
    - [accept,  socket.accept.__qualname__.__eq__,  ["socket.accept"],  true]

# ---------------------------------------------------------------------------
# socket.socket I/O method __name__ values
# __qualname__ and __name__ are distinct attributes; __name__ is the short
# method name without the class prefix. Both are novel for connect/bind/
# listen/accept (no prior spec checks either attribute for these methods).
# ---------------------------------------------------------------------------

table socket_extra276.socket_io_method_names:
  description: "socket.socket I/O method __name__ values — connect/__name__=='connect'; bind/'bind'; listen/'listen'; accept/'accept'; novel __name__ coverage for these C-level methods; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: method_names
  id_prefix: iomn276

  columns: [id, function, args, expected]
  rows:
    - [connect, socket.connect.__name__.__eq__, ["connect"], true]
    - [bind,    socket.bind.__name__.__eq__,    ["bind"],    true]
    - [listen,  socket.listen.__name__.__eq__,  ["listen"],  true]
    - [accept,  socket.accept.__name__.__eq__,  ["accept"],  true]

# ---------------------------------------------------------------------------
# socket.socket I/O method class name — method_descriptor
# socket_extra270 notes that socket.socket.__init__ is a 'function' (pure-
# Python). In contrast, connect/bind/listen/accept are C-level methods and
# their __class__.__name__ == 'method_descriptor'. This difference between
# pure-Python __init__ and C-level I/O methods is a behavioral invariant.
# ---------------------------------------------------------------------------

invariant socket_extra276.connect.class_name:
  description: "socket.socket.connect.__class__.__name__ == 'method_descriptor' — connect is a C-level method_descriptor, not a pure-Python function; contrasts with socket.socket.__init__.__class__.__name__=='function'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: method_class
  kind: python_call_eq
  function: socket.connect.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant socket_extra276.bind.class_name:
  description: "socket.socket.bind.__class__.__name__ == 'method_descriptor' — bind is a C-level method_descriptor; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: method_class
  kind: python_call_eq
  function: socket.bind.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.send and recv __qualname__
# send and recv are core data-transfer methods; their __qualname__ follows
# the same pattern as connect/bind/listen/accept: 'socket.<name>'.
# No prior spec covers send or recv __qualname__.
# ---------------------------------------------------------------------------

invariant socket_extra276.send.qualname:
  description: "socket.socket.send.__qualname__ == 'socket.send' — C method_descriptor; qualname pattern 'socket.<name>'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: method_qualnames
  kind: python_call_eq
  function: socket.send.__qualname__.__eq__
  args: ["socket.send"]
  expected: true

invariant socket_extra276.recv.qualname:
  description: "socket.socket.recv.__qualname__ == 'socket.recv' — C method_descriptor; qualname pattern 'socket.<name>'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: method_qualnames
  kind: python_call_eq
  function: socket.recv.__qualname__.__eq__
  args: ["socket.recv"]
  expected: true
