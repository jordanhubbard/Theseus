  columns: [id, function, args, expected]
  rows:
    - ["io3061001", operator.contains, [io.IOBase.__dict__,          "__aexit__"], false]
    - ["io3061002", operator.contains, [io.RawIOBase.__dict__,       "__aexit__"], false]
