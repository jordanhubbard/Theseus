spec: io3061
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (io3061): __aexit__, __await__, __anext__ dict-presence for io types."
    - "io stream types are synchronous; none define __aexit__ in their own __dict__."
    - "None of the io stream classes define __await__ or __anext__ in their own __dict__; coroutine and async iteration protocols are absent from the io stream interface."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# io stream types do not implement the async context manager protocol;
# none define __aexit__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

table io3061.aexit:
  description: "io types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  category: dict_contains
