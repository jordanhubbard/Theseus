spec: arch
version: ">=3.0.0"
backend: node(arch)

docs: https://github.com/feross/arch#readme

provenance:
  derived_from:
    - "arch README — https://github.com/feross/arch#readme"
    - "Test vectors verified with arch via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "arch source"
  notes:
    - "Detect actual operating-system architecture — handles 32-bit Node on 64-bit OS correctly."
    - "Install: npm install arch"
    - "v3 CJS; module export IS the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant arch.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant arch.factory_arity_zero:
  description: "arch() takes no args — function.length 0"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 0

invariant arch.returns_string:
  description: "arch() returns a String"
  category: usage
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"

invariant arch.returns_known_arch:
  description: "Result matches a known arch name (regex result is non-null — full match + capture group, length 2)"
  category: usage
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: match, args: ["^(x64|x86|arm|arm64|ia32|ppc|ppc64|s390|s390x|mips|mipsel|riscv64|loong64)$"]}
    - {get: length}
  expected: 2
