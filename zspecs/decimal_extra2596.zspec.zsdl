spec: decimal_extra2596
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2581.zspec.zsdl — covers __call__ dict-presence"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence."
    - "Neither decimal.Decimal nor decimal.Context defines __get__, __set__, or __delete__ in its own __dict__."
    - "decimal.Decimal is a numeric type implementing arithmetic operators; it is NOT a descriptor."
    - "decimal.Context is a rounding/precision configuration object; it is NOT a descriptor."
    - "decimal exception classes (DecimalException, InvalidOperation, DivisionByZero, Overflow) are also not descriptors."
    - "Although decimal.Context defines __setattr__ and __delattr__ (for controlled attribute mutation), it does NOT define __set__ or __delete__ (descriptor protocol methods)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2596.no_get_in_decimal_classes:
  description: "__get__ is absent from decimal.Decimal, decimal.Context, and decimal exception class __dict__s"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2596

  columns: [id, function, args, expected]
  rows:
    - ["dc2596001", "decimal.Decimal.__dict__.__contains__",          ["__get__"], false]
    - ["dc2596002", "decimal.Context.__dict__.__contains__",          ["__get__"], false]
    - ["dc2596003", "decimal.DecimalException.__dict__.__contains__", ["__get__"], false]
    - ["dc2596004", "decimal.InvalidOperation.__dict__.__contains__", ["__get__"], false]
    - ["dc2596005", "decimal.DivisionByZero.__dict__.__contains__",   ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2596.no_set_in_decimal_classes:
  description: "__set__ is absent from decimal class __dict__s — decimal types do not implement the data descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2596

  columns: [id, function, args, expected]
  rows:
    - ["dc2596006", "decimal.Decimal.__dict__.__contains__",          ["__set__"], false]
    - ["dc2596007", "decimal.Context.__dict__.__contains__",          ["__set__"], false]
    - ["dc2596008", "decimal.DecimalException.__dict__.__contains__", ["__set__"], false]
    - ["dc2596009", "decimal.Overflow.__dict__.__contains__",         ["__set__"], false]
    - ["dc2596010", "decimal.Underflow.__dict__.__contains__",        ["__set__"], false]

# ---------------------------------------------------------------------------
# __delete__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2596.no_delete_in_decimal_classes:
  description: "__delete__ is absent from decimal class __dict__s — decimal types do not implement the deletion descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2596

  columns: [id, function, args, expected]
  rows:
    - ["dc2596011", "decimal.Decimal.__dict__.__contains__",          ["__delete__"], false]
    - ["dc2596012", "decimal.Context.__dict__.__contains__",          ["__delete__"], false]
    - ["dc2596013", "decimal.DecimalException.__dict__.__contains__", ["__delete__"], false]
    - ["dc2596014", "decimal.InvalidOperation.__dict__.__contains__", ["__delete__"], false]
    - ["dc2596015", "decimal.Inexact.__dict__.__contains__",          ["__delete__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal HAS arithmetic operators but NOT descriptor methods
# Confirms Decimal is a rich numeric type, not a descriptor
# ---------------------------------------------------------------------------

table decimal_extra2596.decimal_arithmetic_not_descriptor:
  description: "decimal.Decimal defines __add__, __mul__, real/imag but NOT __get__/__set__/__delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2596

  columns: [id, function, args, expected]
  rows:
    - ["dc2596016", "decimal.Decimal.__dict__.__contains__", ["__new__"],    true]
    - ["dc2596017", "decimal.Decimal.__dict__.__contains__", ["__add__"],    true]
    - ["dc2596018", "decimal.Decimal.__dict__.__contains__", ["__repr__"],   true]
    - ["dc2596019", "decimal.Decimal.__dict__.__contains__", ["real"],       true]
    - ["dc2596020", "decimal.Decimal.__dict__.__contains__", ["__get__"],    false]
    - ["dc2596021", "decimal.Context.__dict__.__contains__", ["prec"],       true]
    - ["dc2596022", "decimal.Context.__dict__.__contains__", ["rounding"],   true]
    - ["dc2596023", "decimal.Context.__dict__.__contains__", ["__setattr__"], true]
    - ["dc2596024", "decimal.Context.__dict__.__contains__", ["__set__"],    false]
