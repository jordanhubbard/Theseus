spec: io_extra44
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra43.zspec.zsdl — covers IOBase.truncate/readline/readlines/writelines/fileno/isatty __qualname__.__len__(); StringIO.__init__(17)/__new__(16)/close(14) __qualname__.__len__()."
    - "io_extra42.zspec.zsdl — covers BufferedRandom method __qualname__.__len__() for all main methods; IncrementalNewlineDecoder method __qualname__.__len__()."
    - "io_extra41.zspec.zsdl — covers StringIO.readline(17)/BytesIO.tell(12) __qualname__.__len__(); TextIOWrapper.tell/flush/close/readable/writable/seekable __qualname__.__len__(); BufferedWriter.tell/seek/writable __qualname__.__len__()."
    - "io_extra39.zspec.zsdl — covers FileIO.read(11)/write(12)/seek(11)/readinto(15) and BufferedReader.read(19)/readline(23)/readinto(23)/peek(19) __qualname__.__len__()."
    - "io_extra38.zspec.zsdl — covers StringIO/BytesIO method __qualname__.__len__() for read/write/getvalue/seek/readline."
    - "io_extra36.zspec.zsdl — covers FileIO.readinto(15) __qualname__.__len__()."
  notes:
    - "This spec extends io_extra43.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for all ten classes; __bases__[0].__name__/__len__() for all ten classes; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper/BufferedReader/BufferedWriter/FileIO/BufferedRandom method __qualname__.__len__() for all primary methods; IOBase full method __qualname__.__len__() including truncate/readline/readlines/writelines/fileno/isatty; IncrementalNewlineDecoder method __qualname__.__len__(); StringIO.__init__/__new__/close __qualname__.__len__()."
    - "This spec covers: io module-level attribute __name__.__len__()==2 (NOVEL — prior specs cover class-level __name__/__module__ lengths but NOT io.__name__.__len__()); io.__file__.__class__.__name__.__len__()==3 (NOVEL); BytesIO lifecycle and IO-status methods: __init__(16)/__new__(15)/close(13)/readline(16)/readlines(17)/writelines(18)/truncate(16)/isatty(14)/readable(16)/writable(16)/seekable(16)/flush(13) (NOVEL — io_extra38 covers BytesIO read/write/getvalue/seek; io_extra41 covers BytesIO.tell; no prior io spec checks any of these twelve BytesIO methods); FileIO navigation and status methods: tell(11)/close(12)/readable(15)/writable(15)/seekable(15)/fileno(13)/truncate(15)/__init__(15) (NOVEL — io_extra39 covers FileIO.read/write/seek/readinto; io_extra36 covers FileIO.readinto; no prior io spec checks tell/close/readable/writable/seekable/fileno/truncate or __init__ for FileIO)."
    - "io.__name__ == 'io' — len 2. Prior io specs check class/function __name__ lengths but NOT the module __name__ attribute itself. Novel module-level invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.__file__.__class__.__name__ == 'str' — len 3. io.__file__ is a .py file path (io is a pure Python wrapper over _io C extension). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' — len 16. No prior io spec checks BytesIO.__init__.__qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.__new__.__qualname__ == 'BytesIO.__new__' — len 15. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.close.__qualname__ == 'BytesIO.close' — len 13. io_extra30 checks StringIO.close equality but not BytesIO.close length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.readline.__qualname__ == 'BytesIO.readline' — len 16. io_extra38 covers BytesIO read/write/getvalue/seek; io_extra41 covers BytesIO.tell; neither covers readline. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.readlines.__qualname__ == 'BytesIO.readlines' — len 17. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.writelines.__qualname__ == 'BytesIO.writelines' — len 18. Longest BytesIO method qualname. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.truncate.__qualname__ == 'BytesIO.truncate' — len 16. Equals BytesIO.readline/readable/writable/seekable (16). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.isatty.__qualname__ == 'BytesIO.isatty' — len 14. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.readable.__qualname__ == 'BytesIO.readable' — len 16. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.writable.__qualname__ == 'BytesIO.writable' — len 16. Equals readable (16). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.seekable.__qualname__ == 'BytesIO.seekable' — len 16. Equals readable/writable (16). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.flush.__qualname__ == 'BytesIO.flush' — len 13. Equals BytesIO.close (13). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.tell.__qualname__ == 'FileIO.tell' — len 11. Equals FileIO.read/seek (11). io_extra39 covers FileIO.read/write/seek/readinto but not tell. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.close.__qualname__ == 'FileIO.close' — len 12. Equals FileIO.write (12). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.readable.__qualname__ == 'FileIO.readable' — len 15. Equals FileIO.writable/seekable/truncate/__init__ (15). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.writable.__qualname__ == 'FileIO.writable' — len 15. Equals FileIO.readable/seekable/truncate/__init__ (15). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.seekable.__qualname__ == 'FileIO.seekable' — len 15. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.fileno.__qualname__ == 'FileIO.fileno' — len 13. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.truncate.__qualname__ == 'FileIO.truncate' — len 15. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__init__.__qualname__ == 'FileIO.__init__' — len 15. Equals FileIO.readable/writable/seekable/truncate (15). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module-level attribute __name__ and __file__ type name lengths
#
# Prior io specs check class-level __name__/__module__/__qualname__ lengths
# for all ten io classes (io_extra35), but no prior io spec checks the
# module's own __name__ attribute length, nor the type name of __file__.
#
#   io.__name__                         == 'io'  -> len 2
#   io.__file__.__class__.__name__      == 'str' -> len 3
#
# io.__file__ is a .py path because io.py is the pure Python wrapper that
# imports from _io (the C extension). The path string's type is 'str'.
# Both are novel module-level invariants.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra44.module_name_len:
  description: "len(io.__name__) == 2 — 'io' has 2 characters; prior specs check class __name__ lengths but not the module __name__ attribute; novel"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 2

invariant io_extra44.module_file_class_name_len:
  description: "len(io.__file__.__class__.__name__) == 3 — io.__file__ is a str path to io.py; 'str' has 3 characters; novel"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# io.BytesIO lifecycle and IO-status method __qualname__.__len__()
#
# io_extra38 covers BytesIO.read(12)/write(13)/getvalue(16)/seek(12).
# io_extra41 covers BytesIO.tell(12). No prior io spec checks __qualname__.__len__()
# for any of the following twelve BytesIO methods: __init__, __new__, close,
# readline, readlines, writelines, truncate, isatty, readable, writable,
# seekable, flush. All twelve are novel.
#
# Notable clusters (by length):
#   len 13 — close, flush          (6-char names, 'BytesIO.' prefix 8 chars)
#   len 14 — isatty                (7-char name)
#   len 15 — __new__               (7-char dunder with underscores)
#   len 16 — __init__, readline,   (8-char names)
#             truncate, readable,
#             writable, seekable
#   len 17 — readlines             (9-char name)
#   len 18 — writelines            (10-char name, longest)
#
# writelines is the longest BytesIO method qualname at 18 chars.
# close/flush share the shortest length at 13 (matching BytesIO.tell from extra41).
# All verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra44.BytesIO_lifecycle_method_qualname_lens:
  description: "io.BytesIO lifecycle and IO-status method __qualname__.__len__() — __init__(16)/__new__(15)/close(13)/readline(16)/readlines(17)/writelines(18)/truncate(16)/isatty(14)/readable(16)/writable(16)/seekable(16)/flush(13); all novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: bylmq44

  columns: [id, function, args, expected]
  rows:
    - [dunder_init, BytesIO.__init__.__qualname__.__len__,  [], 16]
    - [dunder_new,  BytesIO.__new__.__qualname__.__len__,   [], 15]
    - [close,       BytesIO.close.__qualname__.__len__,     [], 13]
    - [readline,    BytesIO.readline.__qualname__.__len__,  [], 16]
    - [readlines,   BytesIO.readlines.__qualname__.__len__, [], 17]
    - [writelines,  BytesIO.writelines.__qualname__.__len__,[], 18]
    - [truncate,    BytesIO.truncate.__qualname__.__len__,  [], 16]
    - [isatty,      BytesIO.isatty.__qualname__.__len__,    [], 14]
    - [readable,    BytesIO.readable.__qualname__.__len__,  [], 16]
    - [writable,    BytesIO.writable.__qualname__.__len__,  [], 16]
    - [seekable,    BytesIO.seekable.__qualname__.__len__,  [], 16]
    - [flush,       BytesIO.flush.__qualname__.__len__,     [], 13]

# ---------------------------------------------------------------------------
# io.FileIO navigation and status method __qualname__.__len__()
#
# io_extra39 covers FileIO.read(11)/write(12)/seek(11)/readinto(15).
# io_extra36 covers FileIO.readinto(15). No prior io spec checks
# __qualname__.__len__() for FileIO.tell, close, readable, writable,
# seekable, fileno, truncate, or __init__. All eight are novel.
#
# Notable clusters:
#   len 11 — tell, (read, seek from extra39)  (4-char names)
#   len 12 — close, (write from extra39)       (5-char name)
#   len 13 — fileno                            (6-char name)
#   len 15 — readable, writable, seekable,     (7-char and 8-char names)
#             truncate, __init__
#
# readable/writable/seekable/truncate/__init__ all share len 15 — the longest
# cluster among FileIO method qualnames. All verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra44.FileIO_nav_status_method_qualname_lens:
  description: "io.FileIO navigation and status method __qualname__.__len__() — tell(11)/close(12)/fileno(13)/readable(15)/writable(15)/seekable(15)/truncate(15)/__init__(15); all novel; io_extra39 covers read/write/seek/readinto"
  kind: python_call_eq
  category: method_identity
  id_prefix: fiomq44

  columns: [id, function, args, expected]
  rows:
    - [tell,        FileIO.tell.__qualname__.__len__,     [], 11]
    - [close,       FileIO.close.__qualname__.__len__,    [], 12]
    - [fileno,      FileIO.fileno.__qualname__.__len__,   [], 13]
    - [readable,    FileIO.readable.__qualname__.__len__, [], 15]
    - [writable,    FileIO.writable.__qualname__.__len__, [], 15]
    - [seekable,    FileIO.seekable.__qualname__.__len__, [], 15]
    - [truncate,    FileIO.truncate.__qualname__.__len__, [], 15]
    - [dunder_init, FileIO.__init__.__qualname__.__len__, [], 15]
