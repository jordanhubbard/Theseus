spec: asyncio_extra346
version: ">=3.8"
backend: python_module(asyncio.exceptions)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio.exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.exceptions module identity
# ---------------------------------------------------------------------------

invariant asyncio_extra346.module.name:
  description: "asyncio.exceptions.__name__ == 'asyncio.exceptions'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra346.module.package:
  description: "asyncio.exceptions.__package__ == 'asyncio'"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["asyncio"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError — name, module, and base class
#
# asyncio.exceptions.CancelledError is defined directly in this submodule.
# Its first base is BaseException (not Exception).
# ---------------------------------------------------------------------------

invariant asyncio_extra346.CancelledError.name:
  description: "asyncio.exceptions.CancelledError.__name__ == 'CancelledError'"
  category: cancelled_error
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra346.CancelledError.module:
  description: "asyncio.exceptions.CancelledError.__module__ == 'asyncio.exceptions'"
  category: cancelled_error
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra346.CancelledError.base:
  description: "asyncio.exceptions.CancelledError.__bases__[0].__name__ == 'BaseException'"
  category: cancelled_error
  kind: python_call_eq
  function: CancelledError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# InvalidStateError — name, module, and base class
#
# asyncio.exceptions.InvalidStateError inherits from Exception.
# ---------------------------------------------------------------------------

invariant asyncio_extra346.InvalidStateError.name:
  description: "asyncio.exceptions.InvalidStateError.__name__ == 'InvalidStateError'"
  category: invalid_state_error
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant asyncio_extra346.InvalidStateError.module:
  description: "asyncio.exceptions.InvalidStateError.__module__ == 'asyncio.exceptions'"
  category: invalid_state_error
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra346.InvalidStateError.base:
  description: "asyncio.exceptions.InvalidStateError.__bases__[0].__name__ == 'Exception'"
  category: invalid_state_error
  kind: python_call_eq
  function: InvalidStateError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# TimeoutError — builtin alias
#
# asyncio.exceptions.TimeoutError is the same object as the built-in
# TimeoutError. Its __module__ is 'builtins', not 'asyncio.exceptions'.
# ---------------------------------------------------------------------------

invariant asyncio_extra346.TimeoutError.name:
  description: "asyncio.exceptions.TimeoutError.__name__ == 'TimeoutError'"
  category: timeout_error
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant asyncio_extra346.TimeoutError.module:
  description: "asyncio.exceptions.TimeoutError.__module__ == 'builtins' — it is the builtin alias"
  category: timeout_error
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# SendfileNotAvailableError — name, module, and base class
#
# asyncio.exceptions.SendfileNotAvailableError inherits from RuntimeError.
# ---------------------------------------------------------------------------

invariant asyncio_extra346.SendfileNotAvailableError.name:
  description: "asyncio.exceptions.SendfileNotAvailableError.__name__ == 'SendfileNotAvailableError'"
  category: sendfile_error
  kind: python_call_eq
  function: SendfileNotAvailableError.__name__.__eq__
  args: ["SendfileNotAvailableError"]
  expected: true

invariant asyncio_extra346.SendfileNotAvailableError.module:
  description: "asyncio.exceptions.SendfileNotAvailableError.__module__ == 'asyncio.exceptions'"
  category: sendfile_error
  kind: python_call_eq
  function: SendfileNotAvailableError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra346.SendfileNotAvailableError.base:
  description: "asyncio.exceptions.SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError'"
  category: sendfile_error
  kind: python_call_eq
  function: SendfileNotAvailableError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RuntimeError"
