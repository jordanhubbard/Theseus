spec: uuid_extra1996
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
    - "CPython source: Lib/uuid.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "uuid.UUID is not a numeric type; it defines no integer or floating-point conversion protocols in its own __dict__."
    - "uuid.SafeUUID is an IntEnum subclass; it inherits numeric methods from int but defines none in its own __dict__."
    - "All five numeric dunder methods are absent from both uuid.UUID.__dict__ and uuid.SafeUUID.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1996.uuid_index_protocol:
  description: "uuid.UUID __index__ dict-presence checks (UUID is not an integer type)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1996

  columns: [id, function, args, expected]
  rows:
    - ["uu1996001", "uuid.UUID.__dict__.__contains__", ["__index__"], false]
    - ["uu1996002", "uuid.UUID.__dict__.__contains__", ["__complex__"], false]
    - ["uu1996003", "uuid.UUID.__dict__.__contains__", ["__float__"], false]
    - ["uu1996004", "uuid.UUID.__dict__.__contains__", ["__round__"], false]
    - ["uu1996005", "uuid.UUID.__dict__.__contains__", ["__abs__"], false]

table uuid_extra1996.safeuuid_index_protocol:
  description: "uuid.SafeUUID __index__ dict-presence checks (inherits from IntEnum, not defined in own dict)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1996

  columns: [id, function, args, expected]
  rows:
    - ["uu1996006", "uuid.SafeUUID.__dict__.__contains__", ["__index__"], false]
    - ["uu1996007", "uuid.SafeUUID.__dict__.__contains__", ["__complex__"], false]
    - ["uu1996008", "uuid.SafeUUID.__dict__.__contains__", ["__float__"], false]
    - ["uu1996009", "uuid.SafeUUID.__dict__.__contains__", ["__round__"], false]
    - ["uu1996010", "uuid.SafeUUID.__dict__.__contains__", ["__abs__"], false]

table uuid_extra1996.uuid_float_round_checks:
  description: "uuid.UUID __float__ and __round__ absence confirming non-numeric type"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1996

  columns: [id, function, args, expected]
  rows:
    - ["uu1996011", "uuid.UUID.__dict__.__contains__", ["__float__"], false]
    - ["uu1996012", "uuid.UUID.__dict__.__contains__", ["__round__"], false]
    - ["uu1996013", "uuid.UUID.__dict__.__contains__", ["__complex__"], false]
    - ["uu1996014", "uuid.UUID.__dict__.__contains__", ["__abs__"], false]

table uuid_extra1996.safeuuid_float_round_checks:
  description: "uuid.SafeUUID __float__ and __round__ absence (not defined in own dict, only inherited)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1996

  columns: [id, function, args, expected]
  rows:
    - ["uu1996015", "uuid.SafeUUID.__dict__.__contains__", ["__float__"], false]
    - ["uu1996016", "uuid.SafeUUID.__dict__.__contains__", ["__round__"], false]
    - ["uu1996017", "uuid.SafeUUID.__dict__.__contains__", ["__complex__"], false]
    - ["uu1996018", "uuid.SafeUUID.__dict__.__contains__", ["__abs__"], false]

table uuid_extra1996.full_numeric_matrix:
  description: "Full numeric protocol absence matrix for uuid.UUID and uuid.SafeUUID"
  kind: python_call_eq
