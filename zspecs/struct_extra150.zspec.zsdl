spec: struct_extra150
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra149.zspec.zsdl — covers struct.Struct.pack_into/__qualname__ / Struct.unpack_from/__qualname__ / Struct.iter_unpack/__qualname__ / Struct.size/__class__.__name__.__eq__('getset_descriptor') / Struct.format/__class__.__name__.__eq__('getset_descriptor') (table + invariants)."
    - "struct_extra148.zspec.zsdl — covers struct.Struct.__name__/__module__/__bases__[0].__name__ / Struct.pack/__qualname__ / Struct.unpack/__qualname__ / struct.error.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "struct_extra143.zspec.zsdl — covers struct.pack.__module__.__eq__('_struct') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra149."
    - "Wave 336 theme: struct module __spec__ attributes and module-level pack/unpack/calcsize function identity — struct.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('struct') / struct.__name__.__eq__('struct') / pack.__module__.__eq__('_struct') / pack.__class__.__name__.__eq__('builtin_function_or_method') / unpack.__module__.__eq__('_struct') / unpack.__class__.__name__.__eq__('builtin_function_or_method') / calcsize.__module__.__eq__('_struct')."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.pack.__module__ == '_struct' (7 chars). The module-level pack() function is the C extension implementation from _struct, re-exported through the struct public module. This is the same module as struct.Struct.__module__ (extra148 anchors this). pack() packs Python values according to a format string and returns a bytes object. calcsize() and unpack() similarly have __module__ == '_struct'."
    - "Note: struct.pack.__class__.__name__ == 'builtin_function_or_method' (26 chars). The module-level pack, unpack, and calcsize functions are all C extension callables of type builtin_function_or_method, just like hashlib.sha256 (extra155). This contrasts with the Struct class instance methods (Struct.pack, Struct.unpack) which are method_descriptor objects — those carry 'Struct.' prefix qualnames (extra148). The module-level functions do NOT have a 'Struct.' prefix in their qualname."
    - "Note: struct.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars). Like hashlib, struct is a fully-specified module with a ModuleSpec. struct.__spec__.name == 'struct' (6 chars) — the module's canonical import name. struct.__name__ == 'struct' (6 chars). Both __spec__.name and __name__ agree on 'struct'."
    - "Note: struct.calcsize.__module__ == '_struct' (7 chars). calcsize() returns the size in bytes of a struct described by the format string. It is implemented in the _struct C extension module, like pack() and unpack(). calcsize() takes a single format string argument and returns an integer. struct_extra147 anchors calcsize return values for specific format strings; this spec anchors calcsize.__module__ identity."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
# struct.__spec__.name.__eq__('struct')
# struct.__name__.__eq__('struct')
# struct.pack.__module__.__eq__('_struct')
#
# Wave 336 theme: struct __spec__ attributes and pack() module identity.
#
# struct.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars). __spec__.name == 'struct'
# (6 chars). struct.__name__ == 'struct' (6 chars). struct.pack.__module__ == '_struct'
# (7 chars; C extension). No prior struct spec anchors __spec__ attributes or pack.__module__
# as a table under structspec150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra150.spec_and_pack_module_identity:
  description: "struct.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('struct')==True / __name__.__eq__('struct')==True / pack.__module__.__eq__('_struct')==True — __spec__ is ModuleSpec (10 chars; importlib spec); __spec__.name is 'struct' (6 chars; canonical import name); __name__ is 'struct' (6 chars; both agree); pack.__module__ is '_struct' (7 chars; C extension with underscore; contrast with __spec__.name='struct' without underscore); first structspec150 anchor for __spec__ and pack.__module__"
  kind: python_call_eq
  category: identity
  id_prefix: structspec150

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_ModuleSpec,  "__spec__.__class__.__name__.__eq__", ["ModuleSpec"], true, "struct.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib module spec; same type as hashlib.__spec__)"]
    - [spec_name_struct,       "__spec__.name.__eq__",               ["struct"],     true, "struct.__spec__.name == 'struct' (6 chars; canonical import name stored in the ModuleSpec object)"]
    - [name_struct,            "__name__.__eq__",                    ["struct"],     true, "struct.__name__ == 'struct' (6 chars; __spec__.name and __name__ agree; both are 'struct' without underscore)"]
    - [pack_module_struct,     "pack.__module__.__eq__",             ["_struct"],    true, "struct.pack.__module__ == '_struct' (7 chars; C extension; underscore-prefixed; same as Struct.__module__, extra148)"]

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.unpack.__module__.__eq__('_struct')
# struct.unpack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.calcsize.__module__.__eq__('_struct')
#
# Wave 336 theme: pack/unpack/calcsize are all builtin_function_or_method from _struct.
#
# pack.__class__.__name__ == 'builtin_function_or_method' (26 chars). unpack.__module__ ==
# '_struct' (7 chars). unpack.__class__.__name__ == 'builtin_function_or_method' (26 chars).
# calcsize.__module__ == '_struct' (7 chars). All three module-level functions are C callables.
# extra143 anchors pack.__module__=='_struct'; no prior struct spec anchors pack/__class__.__name__
# or unpack/__module__ as a table under structspec150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra150.pack_unpack_calcsize_class_identity:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method')==True / unpack.__module__.__eq__('_struct')==True / unpack.__class__.__name__.__eq__('builtin_function_or_method')==True / calcsize.__module__.__eq__('_struct')==True — pack/unpack/calcsize are all 'builtin_function_or_method' (26 chars; C extension callables; same type as hashlib.sha256 from extra155); all have __module__=='_struct' (7 chars); extra143 anchors pack.__module__; first structspec150 anchor for pack class name and unpack/calcsize identities"
  kind: python_call_eq
  category: identity
  id_prefix: structspec150

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class_builtin,     "pack.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "struct.pack.__class__.__name__ == 'builtin_function_or_method' (26 chars; C extension callable; same type as hashlib.sha256)"]
    - [unpack_module_struct,   "unpack.__module__.__eq__",          ["_struct"],                    true, "struct.unpack.__module__ == '_struct' (7 chars; C extension; returns tuple of values from packed bytes)"]
    - [unpack_class_builtin,   "unpack.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "struct.unpack.__class__.__name__ == 'builtin_function_or_method' (26 chars; C extension callable from _struct)"]
    - [calcsize_module_struct, "calcsize.__module__.__eq__",        ["_struct"],                    true, "struct.calcsize.__module__ == '_struct' (7 chars; C extension; returns byte size for a given format string)"]

# ---------------------------------------------------------------------------
# struct.calcsize.__class__.__name__.__eq__('builtin_function_or_method')
# struct.__spec__.name.__len__()==6
# struct.pack.__module__.__len__()==7
# struct.pack.__class__.__name__.__len__()==26
#
# Wave 336 theme: calcsize class name and length checks for spec/pack attributes.
#
# calcsize.__class__.__name__ == 'builtin_function_or_method' (26 chars). '__spec__.name'
# length is 6 ('struct'). pack.__module__ length is 7 ('_struct'). pack class name length
# is 26 ('builtin_function_or_method'). No prior struct spec anchors these lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra150.calcsize_class_and_length_checks:
  description: "struct.calcsize.__class__.__name__.__eq__('builtin_function_or_method')==True / __spec__.name.__len__()==6 / pack.__module__.__len__()==7 / pack.__class__.__name__.__len__()==26 — calcsize is 'builtin_function_or_method' (26 chars; tied with pack and unpack); __spec__.name is 6 chars ('struct'); pack.__module__ is 7 chars ('_struct'; 1 more than 'struct' due to underscore prefix); pack class name is 26 chars ('builtin_function_or_method'; same as hashlib.sha256 class name length); first structspec150 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: structspec150

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_class_builtin,     "calcsize.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' (26 chars; all three module-level functions share this class)"]
    - [spec_name_len_6,            "__spec__.name.__len__",               [],                             6,    "struct.__spec__.name.__len__() is 6 ('struct' = 6 chars; same length as 'socket' and 'object')"]
    - [pack_module_len_7,          "pack.__module__.__len__",             [],                             7,    "struct.pack.__module__.__len__() is 7 ('_struct' = 7 chars; 1 more than __spec__.name due to underscore prefix)"]
    - [pack_class_name_len_26,     "pack.__class__.__name__.__len__",     [],                             26,   "struct.pack.__class__.__name__.__len__() is 26 ('builtin_function_or_method' = 26 chars; same as hashlib.sha256 class name)"]

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# struct.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). Like hashlib (see
# hashlib_extra157), struct has a standard ModuleSpec from the Python import system.
# struct is a hybrid module: the public API is accessible via 'import struct', but the
# implementation is in the _struct C extension. The ModuleSpec stores the origin path
# (pointing to the struct.py wrapper or _struct.so), the loader, and the module name.
# struct.__spec__.name == 'struct' (6 chars) — the canonical public module name.
# This contrasts with the private C extension name '_struct' (7 chars) used in
# pack.__module__, Struct.__module__, etc. No prior struct spec anchors
# __spec__.__class__.__name__ as a standalone under structspec150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra150.spec_class_name_ModuleSpec:
  description: "struct.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 10 chars; importlib module spec; same type as hashlib.__spec__ (hashlib_extra157); hybrid module: public API via 'struct', implementation in '_struct' C extension; __spec__.name=='struct' (6 chars) uses public name not '_struct'; no prior struct spec anchors __spec__.__class__.__name__ as a standalone; first standalone under structspec150"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack.__class__.__name__ is 'builtin_function_or_method' (26 chars). The module-
# level struct.pack() function is a C extension callable from _struct, exposed directly
# in the struct namespace. This contrasts with struct.Struct.pack, which is a
# method_descriptor (the instance method version). struct.pack() takes a format string
# as its first argument and Python values to pack, returning a bytes object. As a
# builtin_function_or_method, it shares the same class type as hashlib.sha256, hashlib.md5,
# and other C extension callables (both are 26 chars; extra155 anchors sha256's class name).
# extra143 anchors pack.__module__=='_struct'; no prior struct spec anchors pack's own
# __class__.__name__ as a standalone under structspec150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra150.pack_class_name_builtin_function:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — 26 chars; C extension callable from _struct; module-level pack() differs from Struct.pack (method_descriptor); takes format string + values, returns bytes; same class type as hashlib.sha256 (extra155); extra143 anchors pack.__module__=='_struct'; no prior struct spec anchors pack class name as a standalone; first standalone under structspec150"
  category: identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__module__.__eq__('_struct') — standalone
#
# struct.calcsize.__module__ is '_struct' (7 chars). calcsize() is the struct module
# function that returns the size in bytes corresponding to a format string. For example,
# calcsize('I') == 4 (unsigned int, 4 bytes on most platforms), calcsize('Q') == 8
# (unsigned long long, 8 bytes). Like pack() and unpack(), calcsize() is implemented in
# the _struct C extension module and has __module__ == '_struct'. calcsize is useful for
# computing offsets and sizes before allocating buffers for struct.pack_into().
# struct_extra147 anchors calcsize return values for specific format strings ('B','H','I',
# 'Q','f','d','?'); no prior struct spec anchors calcsize.__module__ as a standalone.
# First standalone under structspec150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra150.calcsize_module_struct:
  description: "struct.calcsize.__module__.__eq__('_struct') == True — 7 chars; C extension callable from _struct; returns size in bytes for format string (e.g., calcsize('I')==4, calcsize('Q')==8); __class__.__name__=='builtin_function_or_method' (26 chars); used to compute buffer sizes for pack_into(); struct_extra147 anchors calcsize return values; no prior struct spec anchors calcsize.__module__ as a standalone; first standalone under structspec150"
  category: identity
  kind: python_call_eq
  function: calcsize.__module__.__eq__
  args: ["_struct"]
  expected: true
