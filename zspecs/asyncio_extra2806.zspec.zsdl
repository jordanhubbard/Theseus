spec: asyncio_extra2806
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronisation primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task and future documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "asyncio_extra.zspec.zsdl — covers __name__ and __module__ checks for Queue, Task, Future, Lock, Event, Semaphore, Condition"
    - "asyncio_extra2.zspec.zsdl — covers module checks for event loop classes and exception classes"
    - "asyncio_extra2791.zspec.zsdl — covers __iand__, __ior__, __ixor__ dict-presence checks"
  notes:
    - "Wave 634 theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place shift/power operators)."
    - "None of the asyncio synchronisation or task primitives define __ilshift__, __irshift__, or __ipow__ in their __dict__."
    - "Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier are async coordination primitives, not numeric shift/power types."
    - "asyncio.Barrier was added in Python 3.11; version constraint >=3.9 applies to all other types."
    - "All eight types checked: Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue, asyncio.Task, asyncio.Future — __ilshift__/__irshift__/__ipow__
# dict-presence checks
#
# Queue is an async FIFO queue; Task wraps a coroutine; Future is a low-level
# awaitable. None of them define in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2806.queue_task_future_operator_dict:
  description: "asyncio.Queue, Task, Future __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2806qtf

  columns: [id, function, args, expected]
  rows:
    - ["as2806qtf_q_ils",  Queue.__dict__.__contains__,  ["__ilshift__"],  false]
    - ["as2806qtf_q_irs",  Queue.__dict__.__contains__,  ["__irshift__"],  false]
    - ["as2806qtf_q_ipo",  Queue.__dict__.__contains__,  ["__ipow__"],     false]
    - ["as2806qtf_t_ils",  Task.__dict__.__contains__,   ["__ilshift__"],  false]
    - ["as2806qtf_t_irs",  Task.__dict__.__contains__,   ["__irshift__"],  false]
    - ["as2806qtf_t_ipo",  Task.__dict__.__contains__,   ["__ipow__"],     false]
    - ["as2806qtf_f_ils",  Future.__dict__.__contains__, ["__ilshift__"],  false]
    - ["as2806qtf_f_irs",  Future.__dict__.__contains__, ["__irshift__"],  false]
    - ["as2806qtf_f_ipo",  Future.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# asyncio.Lock, asyncio.Event, asyncio.Semaphore — __ilshift__/__irshift__/__ipow__
# dict-presence checks
#
# Lock, Event, and Semaphore are async synchronisation primitives defined in
# asyncio.locks. They do not implement in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2806.lock_event_semaphore_operator_dict:
  description: "asyncio.Lock, Event, Semaphore __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2806les

  columns: [id, function, args, expected]
  rows:
    - ["as2806les_l_ils",  Lock.__dict__.__contains__,      ["__ilshift__"],  false]
    - ["as2806les_l_irs",  Lock.__dict__.__contains__,      ["__irshift__"],  false]
    - ["as2806les_l_ipo",  Lock.__dict__.__contains__,      ["__ipow__"],     false]
    - ["as2806les_e_ils",  Event.__dict__.__contains__,     ["__ilshift__"],  false]
    - ["as2806les_e_irs",  Event.__dict__.__contains__,     ["__irshift__"],  false]
    - ["as2806les_e_ipo",  Event.__dict__.__contains__,     ["__ipow__"],     false]
    - ["as2806les_s_ils",  Semaphore.__dict__.__contains__, ["__ilshift__"],  false]
    - ["as2806les_s_irs",  Semaphore.__dict__.__contains__, ["__irshift__"],  false]
    - ["as2806les_s_ipo",  Semaphore.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# asyncio.Condition and asyncio.Barrier — __ilshift__/__irshift__/__ipow__
# dict-presence checks
#
# Condition is a combination lock/condition variable. Barrier (added in 3.11)
# is a synchronisation barrier. Neither defines in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2806.condition_barrier_operator_dict:
  description: "asyncio.Condition and Barrier __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2806cb

  columns: [id, function, args, expected]
  rows:
    - ["as2806cb_c_ils",  Condition.__dict__.__contains__, ["__ilshift__"],  false]
    - ["as2806cb_c_irs",  Condition.__dict__.__contains__, ["__irshift__"],  false]
    - ["as2806cb_c_ipo",  Condition.__dict__.__contains__, ["__ipow__"],     false]
    - ["as2806cb_b_ils",  Barrier.__dict__.__contains__,   ["__ilshift__"],  false]
    - ["as2806cb_b_irs",  Barrier.__dict__.__contains__,   ["__irshift__"],  false]
    - ["as2806cb_b_ipo",  Barrier.__dict__.__contains__,   ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# Full 8×3 cross-type matrix — all asyncio types, all three in-place shift/power operator dunders
#
# Consolidates the full 8×3 dict-presence check in one table.
# Every cell is False: Queue, Task, Future, Lock, Event, Semaphore, Condition,
# and Barrier do not define <<=, >>=, or **= operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2806.all_types_ilshift_irshift_ipow_matrix:
  description: "Full 8×3 dict-presence matrix for asyncio types vs __ilshift__/__irshift__/__ipow__ — all 24 results are False; verified with Python 3.14.4"
