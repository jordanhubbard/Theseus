    - ["as2806mx_f_irs",  Future.__dict__.__contains__,     ["__irshift__"],  false]
    - ["as2806mx_f_ipo",  Future.__dict__.__contains__,     ["__ipow__"],     false]
    - ["as2806mx_l_ils",  Lock.__dict__.__contains__,       ["__ilshift__"],  false]
    - ["as2806mx_l_irs",  Lock.__dict__.__contains__,       ["__irshift__"],  false]
    - ["as2806mx_l_ipo",  Lock.__dict__.__contains__,       ["__ipow__"],     false]
    - ["as2806mx_e_ils",  Event.__dict__.__contains__,      ["__ilshift__"],  false]
    - ["as2806mx_e_irs",  Event.__dict__.__contains__,      ["__irshift__"],  false]
    - ["as2806mx_e_ipo",  Event.__dict__.__contains__,      ["__ipow__"],     false]
    - ["as2806mx_s_ils",  Semaphore.__dict__.__contains__,  ["__ilshift__"],  false]
