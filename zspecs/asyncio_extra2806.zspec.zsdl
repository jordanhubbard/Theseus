    - ["as2806mx_s_ipo",  Semaphore.__dict__.__contains__,  ["__ipow__"],     false]
    - ["as2806mx_c_ils",  Condition.__dict__.__contains__,  ["__ilshift__"],  false]
    - ["as2806mx_c_irs",  Condition.__dict__.__contains__,  ["__irshift__"],  false]
    - ["as2806mx_c_ipo",  Condition.__dict__.__contains__,  ["__ipow__"],     false]
    - ["as2806mx_b_ils",  Barrier.__dict__.__contains__,    ["__ilshift__"],  false]
    - ["as2806mx_b_irs",  Barrier.__dict__.__contains__,    ["__irshift__"],  false]
