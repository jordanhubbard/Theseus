spec: uuid_extra40
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/NAMESPACE_DNS __class__.__qualname__.__eq__ and UUID/uuid4/NAMESPACE_DNS __class__.__module__.__eq__."
    - "uuid_extra38.zspec.zsdl — covers UUID.__class__.__name__.__eq__('type'), uuid4/uuid1/uuid3/uuid5/getnode.__class__.__name__.__eq__('function'), NAMESPACE_DNS.__class__.__name__.__eq__('UUID')."
    - "uuid_extra37.zspec.zsdl — covers UUID property fget __name__.__eq__ string values for time/variant/bytes/hex/urn/node/version/clock_seq."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values."
    - "uuid_extra26.zspec.zsdl — covers UUID.hex/urn/variant/version __class__.__name__.__len__()==8 (property); UUID.int/is_safe __class__.__name__.__len__()==17 (member_descriptor)."
    - "uuid_extra22.zspec.zsdl — covers UUID.hex.__class__.__name__.__eq__('property') and UUID.__bases__[0].__name__.__eq__('object')."
  notes:
    - "This spec extends uuid through uuid_extra39; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior uuid spec checks __class__.__qualname__.__eq__ for UUID property descriptors accessed directly on the class (UUID.hex, UUID.int, UUID.bytes, etc.). uuid_extra22 covers UUID.hex.__class__.__name__.__eq__('property') (__name__ axis only). uuid_extra26 covers __class__.__name__.__len__()==8 (__len__ axis on __name__ only). The __class__.__qualname__ axis is entirely novel for all UUID property descriptors. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.__class__.__qualname__ == 'property'. UUID.hex accessed on the class (not an instance) yields the property descriptor object; its __class__ is the built-in property type, whose __qualname__ is 'property'. uuid_extra22 covers __class__.__name__.__eq__('property') but NOT __class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__qualname__ == 'property'. UUID.int is a property descriptor on the class. No prior spec checks UUID.int.__class__.__qualname__.__eq__('property'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.__class__.__qualname__ == 'property'. UUID.bytes is a property descriptor. No prior spec checks UUID.bytes.__class__.__qualname__.__eq__('property'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.__class__.__qualname__ == 'property'. UUID.version is a property descriptor. No prior spec checks UUID.version.__class__.__qualname__.__eq__('property'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.__class__.__qualname__ == 'property'. UUID.urn is a property descriptor. No prior spec checks UUID.urn.__class__.__qualname__.__eq__('property'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.__class__.__qualname__ == 'property'. UUID.variant is a property descriptor. No prior spec checks UUID.variant.__class__.__qualname__.__eq__('property'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.__class__.__qualname__ == 'property'. UUID.node is a property descriptor. No prior spec checks UUID.node.__class__.__qualname__.__eq__('property'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.__class__.__qualname__ == 'property'. UUID.time is a property descriptor. No prior spec checks UUID.time.__class__.__qualname__.__eq__('property'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.__class__.__qualname__.__len__() == 8. len('property') == 8. uuid_extra26 covers __class__.__name__.__len__()==8 for hex (same value, different attribute chain). No prior spec checks __class__.__qualname__.__len__() for any UUID property descriptor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__qualname__.__len__() == 8. len('property') == 8. No prior spec checks __class__.__qualname__.__len__() for UUID.int (the property descriptor). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID property descriptor __class__.__qualname__.__eq__('property')
#
# Accessing UUID.hex, UUID.int, UUID.bytes, etc. on the CLASS (not an instance)
# returns the property descriptor object. Its __class__ is the built-in property
# type. For built-in types, __qualname__ == __name__ == 'property'.
#
# uuid_extra22 covers UUID.hex.__class__.__name__.__eq__('property') (__name__ axis).
# uuid_extra26 covers UUID.hex/urn/variant/version __class__.__name__.__len__()==8.
# No prior spec checks .__class__.__qualname__.__eq__ for any UUID property descriptor.
# ---------------------------------------------------------------------------

table uuid_extra40.property_class_qualnames:
  description: "uuid.UUID.hex/int/bytes/version/urn/variant/node/time __class__.__qualname__.__eq__('property') — each is a property descriptor on the UUID class; its __class__ is the built-in property type whose __qualname__ is 'property'; novel __class__.__qualname__ axis; no prior uuid spec checks __class__.__qualname__ for any UUID property descriptor"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidprop40

  columns: [id, function, args, expected]
  rows:
    - [hex_class_qualname_eq,     UUID.hex.__class__.__qualname__.__eq__,     ["property"], true]
    - [int_class_qualname_eq,     UUID.int.__class__.__qualname__.__eq__,     ["property"], true]
    - [bytes_class_qualname_eq,   UUID.bytes.__class__.__qualname__.__eq__,   ["property"], true]
    - [version_class_qualname_eq, UUID.version.__class__.__qualname__.__eq__, ["property"], true]
    - [urn_class_qualname_eq,     UUID.urn.__class__.__qualname__.__eq__,     ["property"], true]
    - [variant_class_qualname_eq, UUID.variant.__class__.__qualname__.__eq__, ["property"], true]
    - [node_class_qualname_eq,    UUID.node.__class__.__qualname__.__eq__,    ["property"], true]
    - [time_class_qualname_eq,    UUID.time.__class__.__qualname__.__eq__,    ["property"], true]

# ---------------------------------------------------------------------------
# uuid.UUID property descriptor __class__.__qualname__.__len__()
#
# The __qualname__ of the built-in property type is 'property' (8 chars).
# uuid_extra26 covers __class__.__name__.__len__()==8 for UUID.hex/urn/variant/version
# via the __name__ attribute chain. No prior spec checks __class__.__qualname__.__len__()
# for any UUID property descriptor — the .__qualname__ attribute chain is distinct.
# Two representative properties confirm the length independently.
# ---------------------------------------------------------------------------

table uuid_extra40.property_class_qualname_lengths:
  description: "uuid.UUID.hex/__class__.__qualname__.__len__()==8 and UUID.int/__class__.__qualname__.__len__()==8 — len('property')==8; novel __class__.__qualname__.__len__() axis; uuid_extra26 covers __class__.__name__.__len__()==8 (different attribute chain); no prior uuid spec checks __class__.__qualname__.__len__() for any UUID property descriptor"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidpropquallen40

  columns: [id, function, args, expected]
  rows:
    - [hex_class_qualname_len, UUID.hex.__class__.__qualname__.__len__, [], 8]
    - [int_class_qualname_len, UUID.int.__class__.__qualname__.__len__, [], 8]
