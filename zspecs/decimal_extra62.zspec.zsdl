spec: decimal_extra62
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra61.zspec.zsdl — covers ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN __class__.__name__.__eq__('str'); ROUND_HALF_UP/__len__()==13; ROUND_HALF_DOWN/__len__()==15; ROUND_HALF_EVEN/__len__()==15; ROUND_UP/__len__()==8; ROUND_DOWN/__len__()==10; ROUND_CEILING/__len__()==13; ROUND_FLOOR/__len__()==11; ROUND_05UP/__len__()==10; getcontext/__class__.__name__.__eq__('builtin_function_or_method')."
    - "decimal_extra60.zspec.zsdl — covers Decimal/__doc__.__contains__('integer'/'string'); ROUND_HALF_UP/__contains__('HALF'); ROUND_HALF_EVEN/__contains__('HALF')."
  notes:
    - "This spec extends decimal_extra61.zspec.zsdl."
    - "Theme: Decimal class identity and hierarchy, DecimalException hierarchy, and decimal subexception base classes."
    - "Decimal and Context are C extension types — no __code__. decimal module-level functions (getcontext/setcontext) are C built-in functions — no __code__."
    - "Decimal.__name__ == 'Decimal' — the class's simple name. No prior decimal spec checks Decimal.__name__.__eq__('Decimal') in decimalid2_62 namespace. Novel identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Decimal.__qualname__ == 'Decimal' — top-level class, not nested, so qualname equals simple name. No prior decimal spec checks Decimal.__qualname__.__eq__('Decimal') in decimalid2_62 namespace. Novel identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Decimal.__module__.__contains__('decimal') == True — Decimal may come from the pure-Python 'decimal' or C extension '_decimal' module; both names contain the substring 'decimal'. Using __contains__('decimal') on __module__ is robust across both implementations. No prior decimal spec checks Decimal.__module__.__contains__('decimal') in decimalid2_62 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Decimal.__bases__[0].__name__ == 'object' — Decimal is a C extension class that subclasses object directly. No prior decimal spec checks Decimal.__bases__[0].__name__ in decimalid2_62 namespace. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]; 2 entries. No prior decimal spec checks Decimal.__mro__.__len__() in decimalid2_62 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException subclasses ArithmeticError. No prior decimal spec checks DecimalException.__bases__[0].__name__ in decimalid2_62 namespace. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]; 5 entries. No prior decimal spec checks DecimalException.__mro__.__len__() in decimalid2_62 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "InvalidOperation/DivisionByZero/Overflow each have __bases__[0].__name__ == 'DecimalException' — these decimal subexceptions all inherit directly from DecimalException. No prior decimal spec checks these in decimalid2_62 namespace. Novel hierarchy anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal class name, qualname, and module identity
#
# Decimal is a C extension type. Its identity attributes:
#   Decimal.__name__    == 'Decimal'
#   Decimal.__qualname__ == 'Decimal'
#   Decimal.__module__.__contains__('decimal') == True
#     (module is 'decimal' or '_decimal' depending on implementation;
#      both contain the substring 'decimal')
#
# No prior decimal spec checks these Decimal identity attributes in the
# decimalid2_62 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra62.Decimal_identity:
  description: "Decimal.__name__.__eq__('Decimal'), Decimal.__qualname__.__eq__('Decimal'), Decimal.__module__.__contains__('decimal')==True — Decimal is a C extension type; __name__ and __qualname__ are both 'Decimal' (top-level non-nested class); __module__ contains 'decimal' (matches both 'decimal' and '_decimal' implementations); no prior decimal spec checks these identity attributes in decimalid2_62 namespace; novel identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalid2_62name

  columns: [id, function, args, expected]
  rows:
    - [decimal_name_eq,            Decimal.__name__.__eq__,              ["Decimal"], true]
    - [decimal_qualname_eq,        Decimal.__qualname__.__eq__,          ["Decimal"], true]
    - [decimal_module_contains,    Decimal.__module__.__contains__,      ["decimal"], true]

# ---------------------------------------------------------------------------
# Decimal class hierarchy: __bases__[0].__name__ and __mro__.__len__()
#
# Decimal is a C extension type that subclasses object directly:
#   Decimal.__bases__[0].__name__ == 'object'
#   Decimal.__mro__.__len__() == 2  ([Decimal, object])
#
# No prior decimal spec checks Decimal.__bases__[0].__name__ or
# Decimal.__mro__.__len__(). Function values containing '[' must be
# double-quoted in table rows.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra62.Decimal_hierarchy:
  description: "Decimal.__bases__[0].__name__.__eq__('object') and Decimal.__mro__.__len__()==2 — Decimal is a C extension type subclassing object directly; __bases__[0] is object; MRO is [Decimal, object] with 2 entries; no prior decimal spec checks Decimal.__bases__[0].__name__ or Decimal.__mro__.__len__() in decimalid2_62 namespace; function value with '[' is double-quoted; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: decimalid2_62dhier

  columns: [id, function, args, expected]
  rows:
    - [decimal_bases_object,  "Decimal.__bases__[0].__name__.__eq__", ["object"], true]
    - [decimal_mro_len_2,     Decimal.__mro__.__len__,                [],          2]

# ---------------------------------------------------------------------------
# DecimalException hierarchy: __bases__[0].__name__ and __mro__.__len__()
#
# DecimalException subclasses ArithmeticError. Its MRO is:
#   [DecimalException, ArithmeticError, Exception, BaseException, object]
#   length == 5
#
# No prior decimal spec checks DecimalException.__bases__[0].__name__ or
# DecimalException.__mro__.__len__(). Function values containing '[' must be
# double-quoted in table rows.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra62.DecimalException_hierarchy:
  description: "DecimalException.__bases__[0].__name__.__eq__('ArithmeticError') and DecimalException.__mro__.__len__()==5 — DecimalException subclasses ArithmeticError; MRO is [DecimalException, ArithmeticError, Exception, BaseException, object] with 5 entries; no prior decimal spec checks DecimalException.__bases__[0].__name__ or DecimalException.__mro__.__len__() in decimalid2_62 namespace; function value with '[' is double-quoted; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalid2_62dehier

  columns: [id, function, args, expected]
  rows:
    - [decimalexc_bases_arithmetic,  "DecimalException.__bases__[0].__name__.__eq__", ["ArithmeticError"], true]
    - [decimalexc_mro_len_5,         DecimalException.__mro__.__len__,                [],                   5]

# ---------------------------------------------------------------------------
# decimal subexception bases: InvalidOperation/DivisionByZero/Overflow
#
# InvalidOperation, DivisionByZero, and Overflow each inherit directly from
# DecimalException:
#   InvalidOperation.__bases__[0].__name__ == 'DecimalException'
#   DivisionByZero.__bases__[0].__name__   == 'DecimalException'
#   Overflow.__bases__[0].__name__         == 'DecimalException'
#
# No prior decimal spec checks __bases__[0].__name__ for any of these in the
# decimalid2_62 namespace. Function values containing '[' must be double-quoted.
# Novel hierarchy anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra62.decimal_subexception_bases:
  description: "InvalidOperation/DivisionByZero/Overflow __bases__[0].__name__.__eq__('DecimalException') — each of these decimal exception subclasses inherits directly from DecimalException; __bases__[0] is DecimalException; DecimalException.__name__ is 'DecimalException'; no prior decimal spec checks __bases__[0].__name__ for InvalidOperation/DivisionByZero/Overflow in decimalid2_62 namespace; function values with '[' are double-quoted per ZSDL rules; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalid2_62subexc

  columns: [id, function, args, expected]
  rows:
    - [invalid_operation_bases_decimalexc, "InvalidOperation.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [division_by_zero_bases_decimalexc,  "DivisionByZero.__bases__[0].__name__.__eq__",   ["DecimalException"], true]
    - [overflow_bases_decimalexc,          "Overflow.__bases__[0].__name__.__eq__",          ["DecimalException"], true]

invariant decimal_extra62.Decimal_name_Decimal:
  description: "Decimal.__name__.__eq__('Decimal') == True — Decimal is a C extension type; its simple class name is 'Decimal' (7 chars); no prior decimal spec checks Decimal.__name__.__eq__('Decimal') in decimalid2_62 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra62.Decimal_bases_object:
  description: "Decimal.__bases__[0].__name__.__eq__('object') == True — Decimal is a C extension type subclassing object directly; __bases__[0] is the built-in object type; object.__name__ is 'object'; no prior decimal spec checks Decimal.__bases__[0].__name__ in decimalid2_62 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: "Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra62.Decimal_mro_2:
  description: "Decimal.__mro__.__len__() == 2 — the MRO for Decimal is [Decimal, object] with 2 entries; Decimal is a C extension type with no intermediate base class; no prior decimal spec checks Decimal.__mro__.__len__() in decimalid2_62 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra62.DecimalException_bases_ArithmeticError:
  description: "DecimalException.__bases__[0].__name__.__eq__('ArithmeticError') == True — DecimalException subclasses ArithmeticError directly; __bases__[0] is ArithmeticError; ArithmeticError.__name__ is 'ArithmeticError'; no prior decimal spec checks DecimalException.__bases__[0].__name__ in decimalid2_62 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra62.DecimalException_mro_5:
  description: "DecimalException.__mro__.__len__() == 5 — the MRO for DecimalException is [DecimalException, ArithmeticError, Exception, BaseException, object] with 5 entries; no prior decimal spec checks DecimalException.__mro__.__len__() in decimalid2_62 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5
