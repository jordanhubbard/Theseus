spec: warnings
version: ">=3.2"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/warnings.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
    - "warnings source: Lib/warnings.py (PSF; source inspection permitted)"
  not_derived_from:
    - "warnings source: _warnings C extension internals"
  notes:
    - "warnings.warn is implemented in the _warnings C extension; warn.__module__ == '_warnings'."
    - "warnings.defaultaction == 'default' in a fresh interpreter."
    - "warnings.filters is a list of (action, message, category, module, lineno) tuples."
    - "warnings.catch_warnings is a context manager class defined in warnings.py."
    - "Warning category classes (UserWarning, DeprecationWarning, etc.) are in builtins, not in the warnings module namespace."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "warnings.warn raises TypeError for non-string/Warning messages; invalid action strings raise ValueError in simplefilter/filterwarnings."
  stderr: "null"
  stickiness: "N/A — warnings state is global but each invariant checks static properties."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks — verify __name__ of top-level warnings functions
# ---------------------------------------------------------------------------

table warnings.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [warn,            warn.__name__.__eq__,            ["warn"],            true]
    - [simplefilter,    simplefilter.__name__.__eq__,    ["simplefilter"],    true]
    - [filterwarnings,  filterwarnings.__name__.__eq__,  ["filterwarnings"],  true]
    - [resetwarnings,   resetwarnings.__name__.__eq__,   ["resetwarnings"],   true]
    - [showwarning,     showwarning.__name__.__eq__,     ["showwarning"],     true]
    - [formatwarning,   formatwarning.__name__.__eq__,   ["formatwarning"],   true]

# ---------------------------------------------------------------------------
# catch_warnings — class name check
# ---------------------------------------------------------------------------

invariant warnings.catch_warnings.class_name:
  description: "warnings.catch_warnings.__name__ == 'catch_warnings'"
  category: classes
  kind: python_call_eq
  function: catch_warnings.__name__.__eq__
  args: ["catch_warnings"]
  expected: true

invariant warnings.WarningMessage.class_name:
  description: "warnings.WarningMessage.__name__ == 'WarningMessage'"
  category: classes
  kind: python_call_eq
  function: WarningMessage.__name__.__eq__
  args: ["WarningMessage"]
  expected: true

# ---------------------------------------------------------------------------
# defaultaction — action applied when no filter matches; default is 'default'
# ---------------------------------------------------------------------------

invariant warnings.defaultaction_value:
  description: "warnings.defaultaction == 'default'"
  category: constants
  kind: python_call_eq
  function: defaultaction.__eq__
  args: ["default"]
  expected: true

invariant warnings.defaultaction_is_str:
  description: "warnings.defaultaction.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: defaultaction.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# filters — mutable list of active filter tuples
# ---------------------------------------------------------------------------

invariant warnings.filters_is_list:
  description: "warnings.filters.__class__.__name__ == 'list'"
  category: constants
  kind: python_call_eq
  function: filters.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# onceregistry — dict tracking already-shown warnings for 'once' filters
# ---------------------------------------------------------------------------

invariant warnings.onceregistry_is_dict:
  description: "warnings.onceregistry.__class__.__name__ == 'dict'"
  category: constants
  kind: python_call_eq
  function: onceregistry.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# Callable checks — confirm core functions are callable
# ---------------------------------------------------------------------------

invariant warnings.warn_callable:
  description: "warnings.warn is callable — checking via __call__ attribute presence"
  category: functions
  kind: python_call_eq
  function: simplefilter.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant warnings.filterwarnings_callable:
  description: "warnings.filterwarnings is a function"
  category: functions
  kind: python_call_eq
  function: filterwarnings.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant warnings.formatwarning_callable:
  description: "warnings.formatwarning is a function"
  category: functions
  kind: python_call_eq
  function: formatwarning.__class__.__name__.__eq__
  args: ["function"]
  expected: true
