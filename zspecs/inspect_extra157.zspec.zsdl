docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getdoc.__code__.co_argcount 1, co_name 'getdoc'; inspect.getmodule.__code__.co_argcount 2, co_name 'getmodule'; inspect.isclass.__code__.co_argcount 1, co_name 'isclass'; inspect.isfunction.__code__.co_argcount 1, co_name 'isfunction' (Wave 286)."
    - "inspect.getdoc.__code__.co_argcount == 1 — getdoc(object) takes exactly 1 positional-or-keyword argument; it retrieves and cleans up the docstring for an object. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_name == 'getdoc' — the code object co_name equals the function name 'getdoc'. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_argcount == 2 — getmodule(object, _filename=None) takes 2 positional-or-keyword arguments including the optional _filename hint. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_name == 'getmodule' — the code object co_name equals the function name 'getmodule'. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_argcount == 1 — isclass(object) takes exactly 1 argument; it is a predicate testing whether the object is a class. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_name == 'isclass' — the code object co_name equals the function name 'isclass'. Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_argcount == 1 — isfunction(object) takes exactly 1 argument; it is a predicate testing whether the object is a Python function. Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_name == 'isfunction' — the code object co_name equals the function name 'isfunction'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getdoc and inspect.getmodule code attributes
#
# Wave 286 theme: inspect.getdoc and inspect.getmodule __code__ co_name and
# co_argcount.
#
# inspect.getdoc.__code__.co_argcount == 1
# inspect.getdoc.__code__.co_name == 'getdoc'
# inspect.getmodule.__code__.co_argcount == 2
# inspect.getmodule.__code__.co_name == 'getmodule'
#
# inspect.getdoc(object) retrieves the docstring for an object and cleans it
# up by processing tabs and indentation; it takes 1 argument. inspect.getmodule
# takes 2 arguments (object, _filename=None) where _filename is an optional
# hint used to narrow the search for the module. New to extra157.
# ---------------------------------------------------------------------------

table inspect_extra157.getdoc_and_getmodule_code_attrs:
  description: "inspect.getdoc: co_argcount 1, co_name 'getdoc'; inspect.getmodule: co_argcount 2, co_name 'getmodule'; wave 286; new to extra157"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgdgmca157

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_co_argcount_eq_1,
       "getdoc.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc(object) takes exactly 1 positional-or-keyword argument; it retrieves and cleans up the docstring for an object by processing tabs and indentation; co_argcount is 1; int.__eq__(1) returns True; new to extra157"]
    - [getdoc_co_name_eq,
       "getdoc.__code__.co_name.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — getdoc is a Python function in Lib/inspect.py; its code object co_name is 'getdoc'; str.__eq__('getdoc') returns True; new to extra157"]
    - [getmodule_co_argcount_eq_2,
       "getmodule.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule(object, _filename=None) takes 2 positional-or-keyword arguments; the optional _filename parameter provides a hint to narrow the module search; co_argcount is 2; int.__eq__(2) returns True; new to extra157"]
    - [getmodule_co_name_eq,
       "getmodule.__code__.co_name.__eq__",
       ["getmodule"],
       true,
       "inspect.getmodule.__code__.co_name.__eq__('getmodule') == True — getmodule is a Python function in Lib/inspect.py that tries to determine the module an object was defined in; its code object co_name is 'getmodule'; str.__eq__('getmodule') returns True; new to extra157"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isclass and inspect.isfunction code attributes
#
# Wave 286 theme: inspect predicate functions isclass and isfunction __code__
# co_name and co_argcount.
#
# inspect.isclass.__code__.co_argcount == 1
# inspect.isclass.__code__.co_name == 'isclass'
# inspect.isfunction.__code__.co_argcount == 1
# inspect.isfunction.__code__.co_name == 'isfunction'
#
# isclass(object) and isfunction(object) are Python predicate functions in
# Lib/inspect.py. Both take exactly 1 argument and return a bool. isclass tests
# whether the object is a class (isinstance(object, type)); isfunction tests
# whether the object is a Python function (isinstance(object, types.FunctionType)).
# New to extra157.
# ---------------------------------------------------------------------------

table inspect_extra157.isclass_and_isfunction_code_attrs:
  description: "inspect.isclass: co_argcount 1, co_name 'isclass'; inspect.isfunction: co_argcount 1, co_name 'isfunction'; wave 286; new to extra157"
  kind: python_call_eq
  category: identity
  id_prefix: inspecticicfca157

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_co_argcount_eq_1,
       "isclass.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass(object) is a predicate that tests whether the object is a class using isinstance(object, type); it takes exactly 1 argument; co_argcount is 1; int.__eq__(1) returns True; new to extra157"]
    - [isclass_co_name_eq,
       "isclass.__code__.co_name.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__code__.co_name.__eq__('isclass') == True — isclass is a Python predicate function in Lib/inspect.py; its code object co_name is 'isclass'; str.__eq__('isclass') returns True; new to extra157"]
    - [isfunction_co_argcount_eq_1,
       "isfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction(object) is a predicate that tests whether the object is a Python function using isinstance(object, types.FunctionType); it takes exactly 1 argument; co_argcount is 1; int.__eq__(1) returns True; new to extra157"]
    - [isfunction_co_name_eq,
       "isfunction.__code__.co_name.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — isfunction is a Python predicate function in Lib/inspect.py; its code object co_name is 'isfunction'; str.__eq__('isfunction') returns True; new to extra157"]

