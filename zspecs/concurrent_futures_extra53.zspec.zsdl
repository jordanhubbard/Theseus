spec: concurrent_futures_extra53
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ThreadPoolExecutor — ThreadPoolExecutor documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Future — Future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra52.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__.__module__=='builtins' tables (extra47/extra49), ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins') (extra52), as_completed/__class__.__module__.__eq__('builtins') (extra52), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function') (extra52)."
    - "This spec covers: concurrent.futures class __repr__.__class__.__name__ — no prior concurrent.futures spec has captured any __repr__.__class__ attribute. Future defines __repr__ directly in Lib/concurrent/futures/_base.py as a plain Python function, so Future.__repr__.__class__.__name__ == 'function'. ThreadPoolExecutor, ProcessPoolExecutor, and Executor do not define __repr__ themselves and inherit it from object; object.__repr__ is a C-level slot wrapper, so their __repr__.__class__.__name__ == 'wrapper_descriptor'. Also: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __weakref__.__class__.__name__ — all four are pure-Python classes with __weakref__ getset_descriptor; no prior concurrent.futures spec captured __weakref__.__class__.__name__. Also: CancelledError/TimeoutError/BrokenExecutor __repr__.__class__.__name__ — exception classes inherit __repr__ from BaseException (C type); therefore __repr__.__class__.__name__ == 'wrapper_descriptor'."
    - "concurrent.futures.Future.__repr__.__class__.__name__ == 'function'. Future defines __repr__ directly in Lib/concurrent/futures/_base.py as a plain Python function. Plain Python functions are objects of the built-in 'function' type, so Future.__repr__.__class__.__name__ == 'function'. No prior concurrent.futures spec has captured any __repr__.__class__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor'. ThreadPoolExecutor does not define __repr__ itself; it inherits object.__repr__, which is a C-level slot wrapper (wrapper_descriptor). Therefore __repr__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor'. ProcessPoolExecutor inherits object.__repr__ (C-level slot wrapper); __repr__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__repr__.__class__.__name__ == 'wrapper_descriptor'. Executor is an abstract base class that inherits object.__repr__ (C-level slot wrapper); __repr__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__weakref__.__class__.__name__ == 'getset_descriptor'. ThreadPoolExecutor is a pure-Python class defined in Lib/concurrent/futures/thread.py; Python automatically provides a __weakref__ getset_descriptor. No prior concurrent.futures spec captured __weakref__.__class__.__name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__weakref__.__class__.__name__ == 'getset_descriptor'. ProcessPoolExecutor is a pure-Python class in Lib/concurrent/futures/process.py; its __weakref__ is a getset_descriptor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__weakref__.__class__.__name__ == 'getset_descriptor'. Future is a pure-Python class in Lib/concurrent/futures/_base.py; its __weakref__ is a getset_descriptor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__weakref__.__class__.__name__ == 'getset_descriptor'. Executor is a pure-Python class in Lib/concurrent/futures/_base.py; its __weakref__ is a getset_descriptor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__repr__.__class__.__name__ == 'wrapper_descriptor'. CancelledError is a subclass of BaseException (C type); it inherits BaseException.__repr__ which is a C-level slot wrapper (wrapper_descriptor). No prior concurrent.futures spec captured exception __repr__.__class__.__name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__repr__.__class__.__name__ == 'wrapper_descriptor'. TimeoutError is a subclass of BaseException (C type); it inherits BaseException.__repr__ (wrapper_descriptor). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor'. BrokenExecutor is a subclass of RuntimeError which is a subclass of BaseException (C type); it inherits BaseException.__repr__ (wrapper_descriptor). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __repr__.__class__.__name__ string equality — extra53
#
# Future defines __repr__ directly as a Python function, so:
#   Future.__repr__.__class__.__name__ == 'function'
#
# ThreadPoolExecutor, ProcessPoolExecutor, and Executor do not define __repr__
# and inherit the C-level object.__repr__ slot wrapper:
#   ThreadPoolExecutor.__repr__.__class__.__name__  == 'wrapper_descriptor'
#   ProcessPoolExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor'
#   Executor.__repr__.__class__.__name__            == 'wrapper_descriptor'
#
# No prior concurrent.futures spec has captured any __repr__.__class__ attribute.
# Extra53 introduces this dimension in the cfrepr53 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra53.repr_class_name_eq:
  description: "concurrent.futures class __repr__.__class__.__name__ in cfrepr53 namespace — Future defines __repr__ as Python function ('function'); ThreadPoolExecutor/ProcessPoolExecutor/Executor inherit object.__repr__ C slot ('wrapper_descriptor'); no prior cf spec captured any __repr__.__class__ attribute"
  kind: python_call_eq
  category: class_names
  id_prefix: cfrepr53clsrepr

  columns: [id, function, args, expected, description]
  rows:
    - [Future,              Future.__repr__.__class__.__name__.__eq__,              ["function"],          true, "Future.__repr__.__class__.__name__ == 'function' — Future defines __repr__ directly in Lib/concurrent/futures/_base.py as a plain Python function; first __repr__.__class__.__name__ check in any concurrent.futures spec"]
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "ThreadPoolExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor' — ThreadPoolExecutor does not define __repr__; inherits object.__repr__ which is a C-level slot wrapper (wrapper_descriptor)"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "ProcessPoolExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor' — ProcessPoolExecutor inherits object.__repr__ C-level slot wrapper (wrapper_descriptor)"]
    - [Executor,            Executor.__repr__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true, "Executor.__repr__.__class__.__name__ == 'wrapper_descriptor' — Executor is an abstract base class inheriting object.__repr__ C-level slot wrapper (wrapper_descriptor)"]

# ---------------------------------------------------------------------------
# concurrent.futures class __weakref__.__class__.__name__ string equality — extra53
#
# All four executor/future classes are defined in pure Python and automatically
# receive a __weakref__ getset_descriptor for weakref support:
#   ThreadPoolExecutor.__weakref__.__class__.__name__  == 'getset_descriptor'
#   ProcessPoolExecutor.__weakref__.__class__.__name__ == 'getset_descriptor'
#   Future.__weakref__.__class__.__name__              == 'getset_descriptor'
#   Executor.__weakref__.__class__.__name__            == 'getset_descriptor'
#
# No prior concurrent.futures spec has captured __weakref__.__class__.__name__.
# Extra53 introduces this dimension in the cfrepr53 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra53.weakref_class_name_eq:
  description: "concurrent.futures class __weakref__.__class__.__name__ in cfrepr53 namespace — ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor are pure-Python classes with __weakref__ getset_descriptor; no prior cf spec captured __weakref__.__class__.__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: cfrepr53clsweakref

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true, "ThreadPoolExecutor.__weakref__.__class__.__name__ == 'getset_descriptor' — ThreadPoolExecutor is a pure-Python class in Lib/concurrent/futures/thread.py; Python provides a __weakref__ getset_descriptor; first __weakref__.__class__.__name__ check in any concurrent.futures spec"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true, "ProcessPoolExecutor.__weakref__.__class__.__name__ == 'getset_descriptor' — ProcessPoolExecutor is a pure-Python class in Lib/concurrent/futures/process.py; its __weakref__ is a getset_descriptor"]
    - [Future,              Future.__weakref__.__class__.__name__.__eq__,              ["getset_descriptor"], true, "Future.__weakref__.__class__.__name__ == 'getset_descriptor' — Future is a pure-Python class in Lib/concurrent/futures/_base.py; its __weakref__ is a getset_descriptor"]
    - [Executor,            Executor.__weakref__.__class__.__name__.__eq__,            ["getset_descriptor"], true, "Executor.__weakref__.__class__.__name__ == 'getset_descriptor' — Executor is a pure-Python abstract base class in Lib/concurrent/futures/_base.py; its __weakref__ is a getset_descriptor"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __repr__.__class__.__name__ string equality — extra53
#
# CancelledError, TimeoutError, and BrokenExecutor all inherit (directly or
# indirectly) from BaseException, which is implemented in C. BaseException
# defines __repr__ as a C-level slot wrapper (wrapper_descriptor). Since none
# of these exception classes override __repr__ in Python, they all inherit the
# C-level slot:
#   CancelledError.__repr__.__class__.__name__  == 'wrapper_descriptor'
#   TimeoutError.__repr__.__class__.__name__    == 'wrapper_descriptor'
#   BrokenExecutor.__repr__.__class__.__name__  == 'wrapper_descriptor'
#
# No prior concurrent.futures spec has captured exception __repr__.__class__.__name__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra53.exception_repr_class_name_eq:
  description: "concurrent.futures exception __repr__.__class__.__name__ in cfrepr53 namespace — CancelledError/TimeoutError/BrokenExecutor inherit BaseException.__repr__ C-level slot wrapper ('wrapper_descriptor'); no prior cf spec captured exception __repr__.__class__.__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: cfrepr53excrepr

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError,  CancelledError.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "CancelledError.__repr__.__class__.__name__ == 'wrapper_descriptor' — CancelledError inherits BaseException.__repr__ which is a C-level slot wrapper (wrapper_descriptor); no prior concurrent.futures spec captured exception __repr__.__class__.__name__"]
    - [TimeoutError,    TimeoutError.__repr__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true, "TimeoutError.__repr__.__class__.__name__ == 'wrapper_descriptor' — TimeoutError inherits BaseException.__repr__ C-level slot wrapper (wrapper_descriptor)"]
    - [BrokenExecutor,  BrokenExecutor.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "BrokenExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor' — BrokenExecutor is a subclass of RuntimeError → BaseException; inherits BaseException.__repr__ C-level slot wrapper (wrapper_descriptor)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra53
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra53.Future_repr_class_name_eq:
  description: "concurrent.futures.Future.__repr__.__class__.__name__ == 'function' — Future defines __repr__ directly in Lib/concurrent/futures/_base.py as a plain Python function; the 'function' type is the built-in function type; first __repr__.__class__.__name__ check in any concurrent.futures spec"
  category: class_names
  kind: python_call_eq
  function: Future.__repr__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra53.ThreadPoolExecutor_repr_class_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor' — ThreadPoolExecutor inherits object.__repr__ which is a C-level slot wrapper; __repr__.__class__.__name__ == 'wrapper_descriptor'; contrasts with Future which defines its own Python __repr__"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant concurrent_futures_extra53.ThreadPoolExecutor_weakref_class_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__weakref__.__class__.__name__ == 'getset_descriptor' — ThreadPoolExecutor is a pure-Python class; Python provides a __weakref__ getset_descriptor for weakref support; first __weakref__.__class__.__name__ check in any concurrent.futures spec"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__weakref__.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant concurrent_futures_extra53.Future_weakref_class_name_eq:
  description: "concurrent.futures.Future.__weakref__.__class__.__name__ == 'getset_descriptor' — Future is a pure-Python class in Lib/concurrent/futures/_base.py; its __weakref__ slot is managed by a getset_descriptor"
  category: class_names
  kind: python_call_eq
  function: Future.__weakref__.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant concurrent_futures_extra53.CancelledError_repr_class_name_eq:
  description: "concurrent.futures.CancelledError.__repr__.__class__.__name__ == 'wrapper_descriptor' — CancelledError inherits BaseException.__repr__ which is a C-level slot wrapper (wrapper_descriptor); exception classes implemented in C expose __repr__ as wrapper_descriptor"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant concurrent_futures_extra53.BrokenExecutor_repr_class_name_eq:
  description: "concurrent.futures.BrokenExecutor.__repr__.__class__.__name__ == 'wrapper_descriptor' — BrokenExecutor subclasses RuntimeError → BaseException; inherits BaseException.__repr__ C-level slot wrapper (wrapper_descriptor)"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
