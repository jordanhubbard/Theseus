spec: struct_extra257
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct_extra256.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct.zspec.zsdl covers: pack/unpack vectors for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize for H/I/Q/HI/HIQ/q/h/b/?/e; roundtrip for >q/>Q/>H/<I/>BHI; error cases."
    - "struct.zspec.zsdl also covers: calcsize('?')==1; pack('?',True)==0x01; pack('?',False)==0x00; unpack('?', 0x01)==(True,); unpack('?', 0x00)==(False,); pack('3x')==0x000000."
    - "struct_extra.zspec.zsdl covers: Struct format/size attrs; calcsize for f/d/B/4s/BHI; pack_into/__name__; unpack_from; iter_unpack; error class."
    - "struct_extra256.zspec.zsdl covers: calcsize for 'c' and 's'; pack/unpack 'c' and '4s' format; error on wrong-size input."
    - "Theme: 'x' (single pad byte), '2x' (two pad bytes), and compound network-order formats '!BHI' and '!bhi' — NEW calcsize and pack vectors not covered in prior specs."
    - "struct.pack('x').hex() == '00' — single pad byte is always zero; does not consume any value argument."
    - "struct.pack('2x').hex() == '0000' — two pad bytes write two zero bytes."
    - "struct.calcsize('x') == 1; struct.calcsize('2x') == 2 — pad byte count matches repeat prefix."
    - "struct.calcsize('!BHI') == 7 (1 + 2 + 4 bytes, no alignment padding in network order)."
    - "struct.calcsize('!bhi') == 7 (signed variants have same size as unsigned: 1 + 2 + 4 bytes)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# calcsize — 'x', '2x', '!BHI', '!bhi' format strings
# (calcsize('?')==1 is already in struct.zspec.zsdl; not repeated here)
# ---------------------------------------------------------------------------

table struct_extra257.calcsize.pad_compound:
  description: "calcsize for single pad 'x', double pad '2x', and network-order compound '!BHI'/'!bhi' formats"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: calcsize

  columns: [id, args, expected]
  rows:
    - [pad_x,        ["x"],    1]
    - [pad_2x,       ["2x"],   2]
    - [net_BHI,      ["!BHI"], 7]
    - [net_bhi,      ["!bhi"], 7]

# ---------------------------------------------------------------------------
# pack 'x' (pad byte) — always writes zero byte, takes no value argument
# (pack('3x') is in struct.zspec.zsdl; 'x' and '2x' are new here)
# ---------------------------------------------------------------------------

invariant struct_extra257.pack.pad_x:
  description: "struct.pack('x').hex() == '00' — single pad byte 'x' always writes a zero byte"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: ["x"]
  method: hex
  method_args: []
  expected: "00"

invariant struct_extra257.pack.pad_2x:
  description: "struct.pack('2x').hex() == '0000' — two pad bytes each write a zero byte"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: ["2x"]
  method: hex
  method_args: []
  expected: "0000"

# ---------------------------------------------------------------------------
# pack '!BHI' — compound network-order format (unsigned: 1+2+4 = 7 bytes)
# pack('!BHI', 1, 2, 3) == b'\x01\x00\x02\x00\x00\x00\x03'
# ---------------------------------------------------------------------------

invariant struct_extra257.pack.net_BHI:
  description: "struct.pack('!BHI', 1, 2, 3).hex() == '01000200000003' — big-endian B=1 H=2 I=3"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: ["!BHI", 1, 2, 3]
  method: hex
  method_args: []
  expected: "01000200000003"

# ---------------------------------------------------------------------------
# unpack '!BHI' — compound network-order format roundtrip
# ---------------------------------------------------------------------------

invariant struct_extra257.unpack.net_BHI:
  description: "struct.unpack('!BHI', b'\\x01\\x00\\x02\\x00\\x00\\x00\\x03') == (1, 2, 3)"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: ["!BHI", !hex 01000200000003]
  expected: [1, 2, 3]
