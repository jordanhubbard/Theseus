spec: concurrent_futures_extra49
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra48.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__ tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future/ThreadPoolExecutor method __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor lengths, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, executor __name__ equality, executor __module__ equality, Executor/__name__/__module__ equality, exception identity/MRO depths, class __qualname__ equality tables (extra41), module string equality for thread/process/builtins (extra42), Future/__module__ lengths (extra43), class __class__.__name__=='type'/'function' tables (extra44), class __class__.__qualname__ equality tables (extra45), FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__=='str', __class__.__qualname__=='str', __len__() lengths, and string value equality (extra46), class __doc__.__class__.__name__=='str'/__qualname__=='str'/__module__=='builtins' tables (extra47), ThreadPoolExecutor.shutdown/ProcessPoolExecutor.submit-shutdown/Future.result-cancel-exception/Executor.map qualname string equality (extra48). ThreadPoolExecutor/ProcessPoolExecutor __module__ equality (extra42). wait/as_completed __class__.__name__=='function' (extra44). wait/as_completed __class__.__qualname__=='function' (extra45). BrokenExecutor/InvalidStateError __module__=='concurrent.futures._base' (extra37). CancelledError/__module__=='concurrent.futures._base', BrokenExecutor/__module__=='concurrent.futures._base' (extra7). CancelledError/__mro__.__len__()==5, InvalidStateError/__mro__.__len__()==5, BrokenExecutor/__mro__.__len__()==5 (extra38)."
    - "This spec covers: wait.__doc__.__class__.__name__=='str'; as_completed.__doc__.__class__.__name__=='str'; wait.__doc__.__class__.__qualname__=='str'; as_completed.__doc__.__class__.__qualname__=='str'; wait.__doc__.__class__.__module__=='builtins'; as_completed.__doc__.__class__.__module__=='builtins'. Also: wait.__name__.__eq__('wait'); as_completed.__name__.__eq__('as_completed'); wait.__name__.__len__()==4; as_completed.__name__.__len__()==12."
    - "concurrent.futures.wait.__doc__.__class__.__name__ == 'str'. wait is a plain Python function in Lib/concurrent/futures/_base.py with a docstring. Python stores docstrings as plain str instances; __class__.__name__ == 'str'. Prior specs surveyed __doc__.__class__.__name__ for classes (extra47) but never for the module-level functions wait and as_completed. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__doc__.__class__.__name__ == 'str'. as_completed is a generator function in _base.py with a docstring describing its behavior. The docstring is a plain Python string; __class__.__name__ == 'str'. This completes the __doc__ survey for all public concurrent.futures callables. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__doc__.__class__.__qualname__ == 'str'. The built-in str type has no enclosing class or function, so __qualname__ == __name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__doc__.__class__.__qualname__ == 'str'. Same reasoning: as_completed's docstring is a str instance; str.__qualname__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__doc__.__class__.__module__ == 'builtins'. The str type is a built-in type defined in the builtins module; every str instance's __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__doc__.__class__.__module__ == 'builtins'. Same reasoning as wait: str is in builtins; as_completed's docstring is a str; __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__name__ == 'wait'. wait is a module-level function; its __name__ attribute is the bare function name 'wait' (4 chars). This is the string equality complement to the __name__.__len__()==4 check in extra30. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__name__ == 'as_completed'. as_completed is a module-level generator function; its __name__ attribute is 'as_completed' (12 chars). This is the string equality complement to the __name__.__len__()==12 check in extra30. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed __doc__.__class__.__name__ — extra49
#
# Prior spec extra47 surveyed __doc__.__class__.__name__ for concurrent.futures
# classes and exceptions (ThreadPoolExecutor, ProcessPoolExecutor, Future,
# Executor, CancelledError, BrokenExecutor) and for the module itself. Extra49
# extends the __doc__ survey to cover the two module-level public functions
# that were omitted from extra47:
#   wait.__doc__.__class__.__name__         == 'str'
#   as_completed.__doc__.__class__.__name__ == 'str'
#
# Both are plain Python functions with docstrings; Python stores all docstrings
# as plain str instances, giving __class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra49.func_doc_class_name_eq:
  description: "concurrent.futures wait and as_completed __doc__.__class__.__name__ string equality in extra49 namespace — function docstrings are str instances"
  kind: python_call_eq
  category: class_names
  id_prefix: cfmod49funcdocname

  columns: [id, function, args, expected, description]
  rows:
    - [wait,         wait.__doc__.__class__.__name__.__eq__,         ["str"], true, "wait.__doc__.__class__.__name__ == 'str' — wait is a plain Python function in _base.py with a docstring stored as str"]
    - [as_completed, as_completed.__doc__.__class__.__name__.__eq__, ["str"], true, "as_completed.__doc__.__class__.__name__ == 'str' — as_completed is a generator function in _base.py with a docstring stored as str"]

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed __doc__.__class__.__qualname__ — extra49
#
# The built-in str type has __qualname__ == __name__ == 'str' (no enclosing
# class or function scope). Therefore the docstrings of wait and as_completed
# both have __doc__.__class__.__qualname__ == 'str'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra49.func_doc_class_qualname_eq:
  description: "concurrent.futures wait and as_completed __doc__.__class__.__qualname__ string equality in extra49 namespace — str type has __qualname__ == 'str'"
  kind: python_call_eq
  category: class_names
  id_prefix: cfmod49funcdocqual

  columns: [id, function, args, expected, description]
  rows:
    - [wait,         wait.__doc__.__class__.__qualname__.__eq__,         ["str"], true, "wait.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]
    - [as_completed, as_completed.__doc__.__class__.__qualname__.__eq__, ["str"], true, "as_completed.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed __doc__.__class__.__module__ — extra49
#
# The str type is defined in the builtins module. Every str instance's
# __class__.__module__ == 'builtins'. This is consistent with the observation
# in extra47 for class docstrings.
# ---------------------------------------------------------------------------

table concurrent_futures_extra49.func_doc_class_module_eq:
  description: "concurrent.futures wait and as_completed __doc__.__class__.__module__ string equality in extra49 namespace — str is a built-in type; __class__.__module__ == 'builtins'"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfmod49funcdocmodule

  columns: [id, function, args, expected, description]
  rows:
    - [wait,         wait.__doc__.__class__.__module__.__eq__,         ["builtins"], true, "wait.__doc__.__class__.__module__ == 'builtins' — str is a built-in type defined in builtins; every str instance has __class__.__module__ == 'builtins'"]
    - [as_completed, as_completed.__doc__.__class__.__module__.__eq__, ["builtins"], true, "as_completed.__doc__.__class__.__module__ == 'builtins' — str is a built-in type defined in builtins; every str instance has __class__.__module__ == 'builtins'"]

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed __name__ string equality — extra49
#
# Prior spec extra30 captured the __name__.__len__() for both functions:
#   wait.__name__.__len__()         == 4   ('wait')
#   as_completed.__name__.__len__() == 12  ('as_completed')
# Extra49 captures the complementary string equality checks. These are the
# bare function names as they appear in the defining source file _base.py.
# ---------------------------------------------------------------------------

table concurrent_futures_extra49.func_name_eq:
  description: "concurrent.futures wait and as_completed __name__ string equality in extra49 namespace — complementing the __len__() checks in extra30"
  kind: python_call_eq
  category: method_names
  id_prefix: cfmod49funcname

  columns: [id, function, args, expected, description]
  rows:
    - [wait,         wait.__name__.__eq__,         ["wait"],         true, "wait.__name__ == 'wait' — 4-char function name; string equality complement to __name__.__len__()==4 in extra30"]
    - [as_completed, as_completed.__name__.__eq__, ["as_completed"], true, "as_completed.__name__ == 'as_completed' — 12-char function name; string equality complement to __name__.__len__()==12 in extra30"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra49
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra49.wait_doc_class_name_eq:
  description: "concurrent.futures.wait.__doc__.__class__.__name__ == 'str' — wait is a plain Python function with a docstring; Python stores docstrings as plain str instances; __class__.__name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: wait.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra49.as_completed_doc_class_name_eq:
  description: "concurrent.futures.as_completed.__doc__.__class__.__name__ == 'str' — as_completed is a generator function with a docstring; Python stores docstrings as plain str instances; __class__.__name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: as_completed.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra49.wait_doc_class_qualname_eq:
  description: "concurrent.futures.wait.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'; no enclosing scope"
  category: class_names
  kind: python_call_eq
  function: wait.__doc__.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra49.as_completed_doc_class_qualname_eq:
  description: "concurrent.futures.as_completed.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'; no enclosing scope"
  category: class_names
  kind: python_call_eq
  function: as_completed.__doc__.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra49.wait_doc_class_module_eq:
  description: "concurrent.futures.wait.__doc__.__class__.__module__ == 'builtins' — str is a built-in type; every str instance has __class__.__module__ == 'builtins'"
  category: module_identity
  kind: python_call_eq
  function: wait.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra49.as_completed_doc_class_module_eq:
  description: "concurrent.futures.as_completed.__doc__.__class__.__module__ == 'builtins' — str is a built-in type; every str instance has __class__.__module__ == 'builtins'"
  category: module_identity
  kind: python_call_eq
  function: as_completed.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra49.wait_name_eq:
  description: "concurrent.futures.wait.__name__ == 'wait' — bare function name (4 chars); string equality complement to __name__.__len__()==4 from extra30"
  category: method_names
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra49.as_completed_name_eq:
  description: "concurrent.futures.as_completed.__name__ == 'as_completed' — bare function name (12 chars); string equality complement to __name__.__len__()==12 from extra30"
  category: method_names
  kind: python_call_eq
  function: as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true
