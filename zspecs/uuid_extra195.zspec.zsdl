spec: uuid_extra195
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__.__code__.co_name/co_argcount, UUID.__str__/__repr__/__eq__/__hash__/__lt__ qualname equality and lengths (table + invariants)."
  notes:
    - "uuid.__dict__.__contains__('UUID') == True — UUID is a top-level name in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('uuid1') == True — uuid1 is a top-level name in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('uuid3') == True — uuid3 is a top-level name in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('uuid4') == True — uuid4 is a top-level name in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('uuid5') == True — uuid5 is a top-level name in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('SafeUUID') == True — SafeUUID is a top-level name in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('NAMESPACE_DNS') == True — NAMESPACE_DNS constant is in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('NAMESPACE_URL') == True — NAMESPACE_URL constant is in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('NAMESPACE_OID') == True — NAMESPACE_OID constant is in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__dict__.__contains__('NAMESPACE_X500') == True — NAMESPACE_X500 constant is in the uuid module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__mro__.__len__() == 2 — UUID inherits directly from object (UUID, object). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__mro__[0].__name__ == 'UUID' — the first MRO entry is UUID itself. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module __dict__.__contains__ for UUID class and factory functions
# ---------------------------------------------------------------------------

table uuid_extra195.module_dict_uuid_class_and_factories:
  description: "uuid.__dict__.__contains__ checks for UUID, uuid1, uuid3, uuid4 — the main UUID class and version-specific factory functions in the uuid module namespace"
  kind: python_call_eq
  category: module_dict
  id_prefix: uuiddict195

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_UUID,   __dict__.__contains__, ["UUID"],   true, "uuid.__dict__.__contains__('UUID') — UUID class is in uuid module namespace"]
    - [dict_has_uuid1,  __dict__.__contains__, ["uuid1"],  true, "uuid.__dict__.__contains__('uuid1') — uuid1() factory is in uuid module namespace"]
    - [dict_has_uuid3,  __dict__.__contains__, ["uuid3"],  true, "uuid.__dict__.__contains__('uuid3') — uuid3() factory is in uuid module namespace"]
    - [dict_has_uuid4,  __dict__.__contains__, ["uuid4"],  true, "uuid.__dict__.__contains__('uuid4') — uuid4() factory is in uuid module namespace"]

# ---------------------------------------------------------------------------
# uuid module __dict__.__contains__ for uuid5, SafeUUID and NAMESPACE constants
# ---------------------------------------------------------------------------

table uuid_extra195.module_dict_uuid5_safeuuid_namespaces:
  description: "uuid.__dict__.__contains__ checks for uuid5, SafeUUID, NAMESPACE_DNS, NAMESPACE_URL — uuid5 factory, SafeUUID enum, and predefined namespace UUIDs"
  kind: python_call_eq
  category: module_dict
  id_prefix: uuiddict195

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_uuid5,          __dict__.__contains__, ["uuid5"],          true, "uuid.__dict__.__contains__('uuid5') — uuid5() factory is in uuid module namespace"]
    - [dict_has_SafeUUID,       __dict__.__contains__, ["SafeUUID"],       true, "uuid.__dict__.__contains__('SafeUUID') — SafeUUID enum is in uuid module namespace"]
    - [dict_has_NAMESPACE_DNS,  __dict__.__contains__, ["NAMESPACE_DNS"],  true, "uuid.__dict__.__contains__('NAMESPACE_DNS') — NAMESPACE_DNS constant UUID is in uuid module namespace"]
    - [dict_has_NAMESPACE_URL,  __dict__.__contains__, ["NAMESPACE_URL"],  true, "uuid.__dict__.__contains__('NAMESPACE_URL') — NAMESPACE_URL constant UUID is in uuid module namespace"]

# ---------------------------------------------------------------------------
# uuid module __dict__.__contains__ for remaining NAMESPACE constants
# and UUID.__mro__ length and first entry name
# ---------------------------------------------------------------------------

table uuid_extra195.module_dict_namespaces_and_mro:
  description: "uuid.__dict__.__contains__ for NAMESPACE_OID and NAMESPACE_X500; uuid.UUID.__mro__.__len__()==2 and UUID.__mro__[0].__name__=='UUID'"
  kind: python_call_eq
  category: module_dict
  id_prefix: uuiddict195

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_NAMESPACE_OID,   __dict__.__contains__,        ["NAMESPACE_OID"],  true, "uuid.__dict__.__contains__('NAMESPACE_OID') — NAMESPACE_OID constant UUID is in uuid module namespace"]
    - [dict_has_NAMESPACE_X500,  __dict__.__contains__,        ["NAMESPACE_X500"], true, "uuid.__dict__.__contains__('NAMESPACE_X500') — NAMESPACE_X500 constant UUID is in uuid module namespace"]
    - [mro_len,                  UUID.__mro__.__len__,         [],                 2,    "uuid.UUID.__mro__.__len__() == 2 — UUID inherits from object only (UUID, object)"]
    - ["mro0_name",              "UUID.__mro__[0].__name__.__eq__", ["UUID"],      true, "uuid.UUID.__mro__[0].__name__ == 'UUID' — first MRO entry is UUID itself"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant uuid_extra195.dict_has_UUID:
  description: "uuid.__dict__.__contains__('UUID') == True — UUID class is a top-level name in the uuid module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["UUID"]
  expected: true

invariant uuid_extra195.dict_has_uuid4:
  description: "uuid.__dict__.__contains__('uuid4') == True — uuid4() factory function is a top-level name in the uuid module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["uuid4"]
  expected: true

invariant uuid_extra195.dict_has_SafeUUID:
  description: "uuid.__dict__.__contains__('SafeUUID') == True — SafeUUID enum is a top-level name in the uuid module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra195.dict_has_NAMESPACE_DNS:
  description: "uuid.__dict__.__contains__('NAMESPACE_DNS') == True — predefined DNS namespace UUID constant is in the uuid module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["NAMESPACE_DNS"]
  expected: true

invariant uuid_extra195.dict_has_NAMESPACE_X500:
  description: "uuid.__dict__.__contains__('NAMESPACE_X500') == True — predefined X.500 namespace UUID constant is in the uuid module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["NAMESPACE_X500"]
  expected: true

invariant uuid_extra195.UUID_mro_len:
  description: "uuid.UUID.__mro__.__len__() == 2 — UUID's MRO is (UUID, object); it has no intermediate base classes"
  category: class_mro
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2

invariant uuid_extra195.UUID_mro0_name_UUID:
  description: "uuid.UUID.__mro__[0].__name__ == 'UUID' — the first entry in UUID's MRO is UUID itself"
  category: class_mro
  kind: python_call_eq
  function: "UUID.__mro__[0].__name__.__eq__"
  args: ["UUID"]
  expected: true

invariant uuid_extra195.dict_has_uuid5:
  description: "uuid.__dict__.__contains__('uuid5') == True — uuid5() factory function is a top-level name in the uuid module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["uuid5"]
  expected: true

