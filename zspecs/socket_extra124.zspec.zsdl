spec: socket_extra124
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() (gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout) / socket.SocketIO class identity (__class__.__name__=='ABCMeta' / __module__=='socket' / __bases__[0].__name__=='RawIOBase' / __qualname__.__len__()==8) (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket method __qualname__.__len__() for connect/bind/listen/send/recv/__init__/accept/close/makefile/getsockname/getpeername/setsockopt/getsockopt/settimeout/gettimeout/shutdown (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__ / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW __class__.__name__ / AddressFamily/SocketKind __bases__[0].__name__=='IntEnum' / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout/getaddrinfo/create_connection class names (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/recv/send/etc. (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier socket specs."
    - "Wave 273 theme: socket.socket method __qualname__ string equality for connect/bind/listen/accept/recv/close/setsockopt — not yet covered by prior socket specs."
    - "socket.socket.connect.__qualname__.__eq__('socket.connect') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__.__eq__('socket.bind') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__.__eq__('socket.listen') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__.__eq__('socket.accept') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__.__eq__('socket.recv') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__.__eq__('socket.close') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra97 anchors send/sendall/fileno __qualname__.__eq__; extra98 anchors __qualname__.__len__() for all these methods. This spec first anchors __qualname__ string equality for connect/bind/listen/accept/recv/close/setsockopt."
    - "Note: socket.socket.__qualname__ is 'socket' (the class name; 6 chars) and the socket module name is also 'socket'. Method qualnames use 'socket.' (7 chars = class-name 6 + dot 1) as prefix. connect: 'socket.connect' (14), bind: 'socket.bind' (11), listen: 'socket.listen' (13), accept: 'socket.accept' (13), recv: 'socket.recv' (11), close: 'socket.close' (12), setsockopt: 'socket.setsockopt' (17)."
    - "Note: connect, bind, listen, recv, setsockopt are C-level method_descriptor methods (from _socket.socket). accept and close are Python-level function methods (from Lib/socket.py)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__eq__('socket.connect')
# socket.socket.bind.__qualname__.__eq__('socket.bind')
# socket.socket.listen.__qualname__.__eq__('socket.listen')
# socket.socket.accept.__qualname__.__eq__('socket.accept')
# socket.socket.recv.__qualname__.__eq__('socket.recv')
#
# Wave 273 theme: socket.socket C-level and Python-level method __qualname__ string equality.
#
# socket.socket is a Python class in Lib/socket.py that wraps _socket.socket (C).
# All methods (both C-level method_descriptor and Python-level function) use
# 'socket.' as their qualname prefix (7 chars = class name 'socket' (6) + '.' (1)).
# extra97 anchors send/sendall/fileno __qualname__.__eq__; extra98 anchors
# __qualname__.__len__() for connect/bind/listen/accept/recv; no prior socket spec
# anchors connect/bind/listen/accept/recv __qualname__ string equality as a group
# under sockqeq124. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra124.socket_socket_qualname_eq_group1:
  description: "socket.socket.connect/__qualname__.__eq__('socket.connect')==True / bind/__qualname__.__eq__('socket.bind')==True / listen/__qualname__.__eq__('socket.listen')==True / accept/__qualname__.__eq__('socket.accept')==True / recv/__qualname__.__eq__('socket.recv')==True — all use 'socket.' prefix (7 chars = class name 'socket' 6 + dot 1); connect/bind/listen/recv are C-level method_descriptor; accept is Python-level function; extra97 anchors send/sendall/fileno; extra98 anchors __len__(); first sockqeq124 anchor for these qualname string equality values"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: sockqeq124

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qeq, "socket.connect.__qualname__.__eq__", ["socket.connect"], true, "socket.socket.connect.__qualname__ is 'socket.connect' (14 chars; C-level method_descriptor)"]
    - [bind_qeq,    "socket.bind.__qualname__.__eq__",    ["socket.bind"],    true, "socket.socket.bind.__qualname__ is 'socket.bind' (11 chars; C-level method_descriptor)"]
    - [listen_qeq,  "socket.listen.__qualname__.__eq__",  ["socket.listen"],  true, "socket.socket.listen.__qualname__ is 'socket.listen' (13 chars; C-level method_descriptor)"]
    - [accept_qeq,  "socket.accept.__qualname__.__eq__",  ["socket.accept"],  true, "socket.socket.accept.__qualname__ is 'socket.accept' (13 chars; Python-level function)"]
    - [recv_qeq,    "socket.recv.__qualname__.__eq__",    ["socket.recv"],    true, "socket.socket.recv.__qualname__ is 'socket.recv' (11 chars; C-level method_descriptor)"]

# ---------------------------------------------------------------------------
# socket.socket.close.__qualname__.__eq__('socket.close')
# socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt')
# socket.socket.connect.__qualname__.__len__().__eq__(14)
# socket.socket.listen.__qualname__.__len__().__eq__(13)
# socket.socket.setsockopt.__qualname__.__len__().__eq__(17)
#
# Wave 273 theme: additional socket.socket method qualname string equality.
#
# close (Python-level function) and setsockopt (C-level method_descriptor)
# complete the set of 7 methods with anchored qualname string equality.
# close.__qualname__ is 'socket.close' (12 chars), setsockopt.__qualname__
# is 'socket.setsockopt' (17 chars). extra98 anchors all these via __len__();
# no prior socket spec anchors close or setsockopt qualname __eq__ as a group
# under sockqeq124. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra124.socket_socket_qualname_eq_group2:
  description: "socket.socket.close/__qualname__.__eq__('socket.close')==True / setsockopt/__qualname__.__eq__('socket.setsockopt')==True / connect/__qualname__.__len__()==14 (__eq__ call) / listen/__qualname__.__len__()==13 (__eq__ call) / setsockopt/__qualname__.__len__()==17 (__eq__ call) — close is Python-level function; setsockopt is C-level method_descriptor; extra97 anchors send/sendall/fileno; extra98 anchors __len__(); first sockqeq124 anchor for close/setsockopt qualname equality"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: sockqeq124

  columns: [id, function, args, expected, description]
  rows:
    - [close_qeq,         "socket.close.__qualname__.__eq__",              ["socket.close"],      true, "socket.socket.close.__qualname__ is 'socket.close' (12 chars; Python-level function)"]
    - [setsockopt_qeq,    "socket.setsockopt.__qualname__.__eq__",         ["socket.setsockopt"], true, "socket.socket.setsockopt.__qualname__ is 'socket.setsockopt' (17 chars; C-level method_descriptor)"]
    - [connect_qlen_eq,   "socket.connect.__qualname__.__len__().__eq__",  [14],                  true, "socket.socket.connect.__qualname__.__len__() == 14 (cross-check via __eq__)"]
    - [listen_qlen_eq,    "socket.listen.__qualname__.__len__().__eq__",   [13],                  true, "socket.socket.listen.__qualname__.__len__() == 13 (cross-check via __eq__)"]
    - [setsockopt_qlen_eq, "socket.setsockopt.__qualname__.__len__().__eq__", [17],               true, "socket.socket.setsockopt.__qualname__.__len__() == 17 (cross-check via __eq__)"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__class__.__name__.__eq__('method_descriptor')
# socket.socket.bind.__class__.__name__.__eq__('method_descriptor')
# socket.socket.listen.__class__.__name__.__eq__('method_descriptor')
# socket.socket.recv.__class__.__name__.__eq__('method_descriptor')
# socket.socket.setsockopt.__class__.__name__.__eq__('method_descriptor')
#
# Wave 273 theme: socket.socket C-level method __class__.__name__ cross-check.
#
# connect, bind, listen, recv, and setsockopt are all C-level method_descriptor
# objects inherited from _socket.socket. extra93 anchors method_descriptor class
# names for bind/connect/recv/send etc. as a group; this table cross-checks
# specific methods relevant to this spec under sockqeq124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra124.socket_socket_c_method_class_names:
  description: "socket.socket.connect/__class__.__name__.__eq__('method_descriptor')==True / bind/__class__.__name__.__eq__('method_descriptor')==True / listen/__class__.__name__.__eq__('method_descriptor')==True / recv/__class__.__name__.__eq__('method_descriptor')==True / setsockopt/__class__.__name__.__eq__('method_descriptor')==True — all 5 are C-level method_descriptor from _socket.socket; extra93 anchors method_descriptor class names; this table cross-checks under sockqeq124; first sockqeq124 anchor for these class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockqeq124

  columns: [id, function, args, expected, description]
  rows:
    - [connect_class, "socket.connect.__class__.__name__.__eq__",    ["method_descriptor"], true, "socket.socket.connect is a C-level method_descriptor from _socket.socket"]
    - [bind_class,    "socket.bind.__class__.__name__.__eq__",       ["method_descriptor"], true, "socket.socket.bind is a C-level method_descriptor from _socket.socket"]
    - [listen_class,  "socket.listen.__class__.__name__.__eq__",     ["method_descriptor"], true, "socket.socket.listen is a C-level method_descriptor from _socket.socket"]
    - [recv_class,    "socket.recv.__class__.__name__.__eq__",       ["method_descriptor"], true, "socket.socket.recv is a C-level method_descriptor from _socket.socket"]
    - [setsockopt_class, "socket.setsockopt.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.setsockopt is a C-level method_descriptor from _socket.socket"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__eq__('socket.connect') — standalone
#
# socket.socket.connect.__qualname__ is 'socket.connect'. connect is the
# primary method for initiating a TCP/IP connection to a remote address.
# It is a C-level method_descriptor inherited from _socket.socket (socketmodule.c).
# Its __qualname__ uses the class name 'socket' (the socket.socket class name,
# which is just 'socket') as prefix. extra97 anchors send/sendall/fileno qualname
# equality; extra98 anchors connect __qualname__.__len__()==14; no prior socket
# spec anchors connect.__qualname__.__eq__ as a standalone under sockqeq124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra124.connect_qualname_eq:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — connect.__qualname__ is 'socket.connect' (14 chars); connect is a C-level method_descriptor from _socket.socket; extra97 anchors send/sendall/fileno qualname equality; extra98 anchors connect __len__(); first standalone for connect qualname equality under sockqeq124"
  category: qualname_equality
  kind: python_call_eq
  function: "socket.connect.__qualname__.__eq__"
  args: ["socket.connect"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept') — standalone
#
# socket.socket.accept.__qualname__ is 'socket.accept'. accept is a Python-level
# function (not a C-level method_descriptor) defined in Lib/socket.py. It waits
# for an incoming connection and returns a (conn, address) pair. Its __qualname__
# still uses 'socket.' prefix because it is defined as a method of the socket
# class. extra97 anchors accept.__class__.__name__=='function' and __module__=='socket';
# extra98 anchors accept.__qualname__.__len__()==13; no prior socket spec anchors
# accept.__qualname__.__eq__ as a standalone under sockqeq124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra124.accept_qualname_eq:
  description: "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — accept.__qualname__ is 'socket.accept' (13 chars); accept is a Python-level function (Lib/socket.py), not a C-level method_descriptor; extra97 anchors accept class name and __module__; extra98 anchors accept __len__(); first standalone for accept qualname equality under sockqeq124"
  category: qualname_equality
  kind: python_call_eq
  function: "socket.accept.__qualname__.__eq__"
  args: ["socket.accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') — standalone
#
# socket.socket.setsockopt.__qualname__ is 'socket.setsockopt' (17 chars).
# setsockopt is a C-level method_descriptor from _socket.socket used to set
# socket options at the socket, protocol, or platform level (e.g., SO_REUSEADDR,
# TCP_NODELAY). Its 17-char qualname equals the 17-char qualname of getsockopt,
# settimeout, and gettimeout (all share length 17 with 10-char method names
# under the 7-char prefix). extra98 anchors setsockopt.__qualname__.__len__()==17;
# no prior socket spec anchors setsockopt.__qualname__.__eq__ as a standalone
# under sockqeq124. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra124.setsockopt_qualname_eq:
  description: "socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') == True — setsockopt.__qualname__ is 'socket.setsockopt' (17 chars; 'socket.'7 + 'setsockopt'10); C-level method_descriptor from _socket.socket; extra98 anchors __len__()==17; first standalone for setsockopt qualname equality under sockqeq124"
  category: qualname_equality
  kind: python_call_eq
  function: "socket.setsockopt.__qualname__.__eq__"
  args: ["socket.setsockopt"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.close.__qualname__.__eq__('socket.close') — standalone
#
# socket.socket.close.__qualname__ is 'socket.close' (12 chars). close is a
# Python-level function defined in Lib/socket.py that closes the socket and
# releases the file descriptor. Like accept, it is a pure-Python function
# (class 'function') rather than a C-level method_descriptor. Its qualname
# 'socket.close' = 'socket.' (7) + 'close' (5) = 12 chars. extra97 anchors
# close.__class__.__name__=='function' and __module__=='socket'; extra98
# anchors close.__qualname__.__len__()==12; no prior socket spec anchors
# close.__qualname__.__eq__ as a standalone under sockqeq124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra124.close_qualname_eq:
  description: "socket.socket.close.__qualname__.__eq__('socket.close') == True — close.__qualname__ is 'socket.close' (12 chars; 'socket.'7 + 'close'5); Python-level function from Lib/socket.py; extra97 anchors close class name and __module__; extra98 anchors close __len__(); first standalone for close qualname equality under sockqeq124"
  category: qualname_equality
  kind: python_call_eq
  function: "socket.close.__qualname__.__eq__"
  args: ["socket.close"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.listen.__qualname__.__eq__('socket.listen') — standalone
#
# socket.socket.listen.__qualname__ is 'socket.listen' (13 chars). listen is a
# C-level method_descriptor from _socket.socket that marks the socket as a
# passive socket ready to accept incoming connections. listen shares qualname
# length 13 with accept ('socket.accept'). extra98 anchors listen.__qualname__
# .__len__()==13; no prior socket spec anchors listen.__qualname__.__eq__ as a
# standalone under sockqeq124. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra124.listen_qualname_eq:
  description: "socket.socket.listen.__qualname__.__eq__('socket.listen') == True — listen.__qualname__ is 'socket.listen' (13 chars; same length as accept); C-level method_descriptor from _socket.socket; marks socket as passive for incoming connections; extra98 anchors listen __len__(); first standalone for listen qualname equality under sockqeq124"
  category: qualname_equality
  kind: python_call_eq
  function: "socket.listen.__qualname__.__eq__"
  args: ["socket.listen"]
  expected: true
