spec: threading_extra97
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra96

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra96.zspec.zsdl."
    - "This spec covers: threading Semaphore/BoundedSemaphore/Event/Condition method class names (all 'function'); threading.__all__ class name, length, membership (Wave 254)."
    - "threading.Semaphore.__init__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Semaphore.__enter__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Semaphore.__exit__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__init__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.acquire.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.release.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Event.__init__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Event.is_set.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Event.set.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Event.clear.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Event.wait.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.__init__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.wait.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.notify.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition does NOT have acquire or release in its own class (not found via getattr). Verified with Python 3.14.3."
    - "threading.__all__.__class__.__name__ == 'list'. Verified with Python 3.14.3."
    - "threading.__all__.__len__() == 28. Verified with Python 3.14.3."
    - "'Thread' in threading.__all__ == True. Verified with Python 3.14.3."
    - "'Lock' in threading.__all__ == True. Verified with Python 3.14.3."
    - "'Event' in threading.__all__ == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Semaphore and BoundedSemaphore method class names (all 'function')
#
# Wave 254 theme: threading.Semaphore and BoundedSemaphore Python method class names.
#
# threading.Semaphore.__init__.__class__.__name__ == 'function'
# threading.Semaphore.acquire.__class__.__name__ == 'function'
# threading.Semaphore.release.__class__.__name__ == 'function'
# threading.Semaphore.__enter__.__class__.__name__ == 'function'
# threading.Semaphore.__exit__.__class__.__name__ == 'function'
# threading.BoundedSemaphore.__init__.__class__.__name__ == 'function'
# threading.BoundedSemaphore.acquire.__class__.__name__ == 'function'
# threading.BoundedSemaphore.release.__class__.__name__ == 'function'
#
# Both Semaphore and BoundedSemaphore are pure-Python classes; all their
# methods are Python functions ('function'). New to extra97.
# ---------------------------------------------------------------------------

table threading_extra97.semaphore_method_class_names:
  description: "threading.Semaphore and BoundedSemaphore method class names (all 'function'); pure-Python class methods; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsynccls97

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_init_class_name_eq_function,
       "Semaphore.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Semaphore.__init__.__class__.__name__.__eq__('function') == True — Semaphore is a pure-Python class in Lib/threading.py; __init__ is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [semaphore_acquire_class_name_eq_function,
       "Semaphore.acquire.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Semaphore.acquire.__class__.__name__.__eq__('function') == True — Semaphore.acquire is a Python function implementing the semaphore acquire operation; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [semaphore_release_class_name_eq_function,
       "Semaphore.release.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Semaphore.release.__class__.__name__.__eq__('function') == True — Semaphore.release is a Python function implementing the semaphore release operation; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [semaphore_enter_class_name_eq_function,
       "Semaphore.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Semaphore.__enter__.__class__.__name__.__eq__('function') == True — Semaphore.__enter__ supports the context manager protocol; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [semaphore_exit_class_name_eq_function,
       "Semaphore.__exit__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Semaphore.__exit__.__class__.__name__.__eq__('function') == True — Semaphore.__exit__ supports the context manager protocol; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [boundedsemaphore_init_class_name_eq_function,
       "BoundedSemaphore.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.BoundedSemaphore.__init__.__class__.__name__.__eq__('function') == True — BoundedSemaphore is a pure-Python class inheriting from Semaphore; __init__ is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [boundedsemaphore_acquire_class_name_eq_function,
       "BoundedSemaphore.acquire.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.BoundedSemaphore.acquire.__class__.__name__.__eq__('function') == True — BoundedSemaphore.acquire overrides Semaphore.acquire to enforce the upper bound; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [boundedsemaphore_release_class_name_eq_function,
       "BoundedSemaphore.release.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.BoundedSemaphore.release.__class__.__name__.__eq__('function') == True — BoundedSemaphore.release overrides Semaphore.release to enforce the upper bound; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 2: Event method class names (all 'function')
#
# Wave 254 theme: threading.Event Python method class names.
#
# threading.Event.__init__.__class__.__name__ == 'function'
# threading.Event.is_set.__class__.__name__ == 'function'
# threading.Event.set.__class__.__name__ == 'function'
# threading.Event.clear.__class__.__name__ == 'function'
# threading.Event.wait.__class__.__name__ == 'function'
#
# Event is a pure-Python class; all its methods are Python functions.
# New to extra97.
# ---------------------------------------------------------------------------

table threading_extra97.event_method_class_names:
  description: "threading.Event method class names: __init__/is_set/set/clear/wait all 'function'; pure-Python class; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsynccls97

  columns: [id, function, args, expected, description]
  rows:
    - [event_init_class_name_eq_function,
       "Event.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.__init__.__class__.__name__.__eq__('function') == True — Event is a pure-Python class in Lib/threading.py; __init__ initializes the internal Condition; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [event_is_set_class_name_eq_function,
       "Event.is_set.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.is_set.__class__.__name__.__eq__('function') == True — Event.is_set returns True if the internal flag is set; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [event_set_class_name_eq_function,
       "Event.set.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.set.__class__.__name__.__eq__('function') == True — Event.set sets the internal flag and notifies waiting threads; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [event_clear_class_name_eq_function,
       "Event.clear.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.clear.__class__.__name__.__eq__('function') == True — Event.clear resets the internal flag; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [event_wait_class_name_eq_function,
       "Event.wait.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.wait.__class__.__name__.__eq__('function') == True — Event.wait blocks until the internal flag is set; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 3: Condition method class names (all 'function')
#
# Wave 254 theme: threading.Condition Python method class names.
#
# threading.Condition.__init__.__class__.__name__ == 'function'
# threading.Condition.wait.__class__.__name__ == 'function'
# threading.Condition.wait_for.__class__.__name__ == 'function'
# threading.Condition.notify.__class__.__name__ == 'function'
# threading.Condition.notify_all.__class__.__name__ == 'function'
# threading.Condition.__enter__.__class__.__name__ == 'function'
# threading.Condition.__exit__.__class__.__name__ == 'function'
#
# Condition is a pure-Python class; acquire and release are not defined on
# Condition itself (verified: getattr returns None). New to extra97.
# ---------------------------------------------------------------------------

table threading_extra97.condition_method_class_names:
  description: "threading.Condition method class names: __init__/wait/wait_for/notify/notify_all/__enter__/__exit__ all 'function'; pure-Python class; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsynccls97

  columns: [id, function, args, expected, description]
  rows:
    - [condition_init_class_name_eq_function,
       "Condition.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.__init__.__class__.__name__.__eq__('function') == True — Condition is a pure-Python class in Lib/threading.py; __init__ sets up the underlying lock; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [condition_wait_class_name_eq_function,
       "Condition.wait.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.wait.__class__.__name__.__eq__('function') == True — Condition.wait releases the lock and waits for notification; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [condition_wait_for_class_name_eq_function,
       "Condition.wait_for.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.wait_for.__class__.__name__.__eq__('function') == True — Condition.wait_for waits until a predicate returns True; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [condition_notify_class_name_eq_function,
       "Condition.notify.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.notify.__class__.__name__.__eq__('function') == True — Condition.notify wakes up one waiting thread; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [condition_notify_all_class_name_eq_function,
       "Condition.notify_all.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.notify_all.__class__.__name__.__eq__('function') == True — Condition.notify_all wakes up all waiting threads; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [condition_enter_class_name_eq_function,
       "Condition.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.__enter__.__class__.__name__.__eq__('function') == True — Condition supports the context manager protocol via __enter__; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]
    - [condition_exit_class_name_eq_function,
       "Condition.__exit__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.__exit__.__class__.__name__.__eq__('function') == True — Condition supports the context manager protocol via __exit__; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 4: threading.__all__ class name, length, and membership
#
# Wave 254 theme: threading.__all__ type identity and key membership.
#
# threading.__all__.__class__.__name__ == 'list'
# threading.__all__.__len__() == 28
# threading.__all__.__contains__('Thread') == True
# threading.__all__.__contains__('Lock') == True
# threading.__all__.__contains__('Event') == True
#
# threading.__all__ is a list with 28 entries in Python 3.14.3. New to extra97.
# ---------------------------------------------------------------------------

table threading_extra97.threading_all_class_and_membership:
  description: "threading.__all__ class name 'list', length 28, membership checks for Thread/Lock/Event; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsynccls97

  columns: [id, function, args, expected, description]
  rows:
    - [threading_all_class_name_eq_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "threading.__all__.__class__.__name__.__eq__('list') == True — threading defines __all__ as a list in Lib/threading.py; __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra97"]
    - [threading_all_len_eq_28,
       "__all__.__len__",
       [],
       28,
       "threading.__all__.__len__() == 28 — threading.__all__ contains 28 public names in Python 3.14.3 including Thread, Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier, Timer, and others; list.__len__() returns 28; verified with Python 3.14.3; new to extra97"]
    - [threading_all_contains_Thread,
       "__all__.__contains__",
       ["Thread"],
       true,
       "threading.__all__.__contains__('Thread') == True — 'Thread' is listed in threading.__all__ as the primary thread class; list.__contains__('Thread') returns True; new to extra97"]
    - [threading_all_contains_Lock,
       "__all__.__contains__",
       ["Lock"],
       true,
       "threading.__all__.__contains__('Lock') == True — 'Lock' is listed in threading.__all__ as the basic mutex primitive; list.__contains__('Lock') returns True; new to extra97"]
    - [threading_all_contains_Event,
       "__all__.__contains__",
       ["Event"],
       true,
       "threading.__all__.__contains__('Event') == True — 'Event' is listed in threading.__all__ as the event synchronization primitive; list.__contains__('Event') returns True; new to extra97"]
    - [threading_all_contains_Semaphore,
       "__all__.__contains__",
       ["Semaphore"],
       true,
       "threading.__all__.__contains__('Semaphore') == True — 'Semaphore' is listed in threading.__all__ as the counting semaphore primitive; list.__contains__('Semaphore') returns True; new to extra97"]
    - [threading_all_contains_Condition,
       "__all__.__contains__",
       ["Condition"],
       true,
       "threading.__all__.__contains__('Condition') == True — 'Condition' is listed in threading.__all__ as the condition variable synchronization primitive; list.__contains__('Condition') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra97
# ---------------------------------------------------------------------------

invariant threading_extra97.semaphore_acquire_class_name_eq_function:
  description: "threading.Semaphore.acquire.__class__.__name__ == 'function' — pure-Python method; wave 254; new to extra97"
  kind: python_call_eq
  function: Semaphore.acquire.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra97.boundedsemaphore_release_class_name_eq_function:
  description: "threading.BoundedSemaphore.release.__class__.__name__ == 'function' — overrides Semaphore.release to enforce upper bound; wave 254; new to extra97"
  kind: python_call_eq
  function: BoundedSemaphore.release.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra97.event_wait_class_name_eq_function:
  description: "threading.Event.wait.__class__.__name__ == 'function' — pure-Python blocking wait method; wave 254; new to extra97"
  kind: python_call_eq
  function: Event.wait.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra97.condition_notify_all_class_name_eq_function:
  description: "threading.Condition.notify_all.__class__.__name__ == 'function' — pure-Python broadcast notification; wave 254; new to extra97"
  kind: python_call_eq
  function: Condition.notify_all.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra97.threading_all_len_eq_28:
  description: "threading.__all__.__len__() == 28 — public API list length in Python 3.14.3; wave 254; new to extra97"
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 28
