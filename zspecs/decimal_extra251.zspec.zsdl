spec: decimal_extra251
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal additional signal classes: Inexact, Rounded, Subnormal, FloatOperation, Overflow, Underflow."
    - "decimal.Inexact.__bases__ == (DecimalException,) — single base."
    - "decimal.Rounded.__bases__ == (DecimalException,) — single base."
    - "decimal.Subnormal.__bases__ == (DecimalException,) — single base."
    - "decimal.FloatOperation.__bases__ == (DecimalException, TypeError) — two bases; it is both a signal and a TypeError."
    - "decimal.Overflow.__bases__ == (Inexact, Rounded) — two bases; Overflow is both Inexact and Rounded."
    - "decimal.Underflow.__bases__ == (Inexact, Rounded, Subnormal) — three bases; Underflow is Inexact, Rounded, and Subnormal."
    - "All __module__ values are 'decimal' — the signal classes are defined in the C extension."
    - "All __class__.__name__ values are 'type' — these are class objects."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal single-base signal class identity
#
# Inexact, Rounded, and Subnormal each have exactly one base: DecimalException.
# __name__, __module__, __class__.__name__, and __bases__[0].__name__ are checked.
# ---------------------------------------------------------------------------

table decimal_extra251.single_base_signal_identity:
  description: "decimal Inexact, Rounded, Subnormal signal class identity — single DecimalException base; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: decxsbs251

  columns: [id, function, args, expected, description]
  rows:
    - [inexact_name,
       "Inexact.__name__.__eq__",
       ["Inexact"],
       true,
       "decimal.Inexact.__name__.__eq__('Inexact') == True — Inexact is the signal raised whenever a result is not exact (digits were lost); its __name__ is 'Inexact'; str.__eq__('Inexact') returns True; new to extra251"]
    - [inexact_module,
       "Inexact.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Inexact.__module__.__eq__('decimal') == True — Inexact is defined in the decimal C extension; its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra251"]
    - [inexact_base,
       "Inexact.__bases__.__getitem__",
       [0],
       "DecimalException",
       "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact inherits directly from DecimalException, the base for all decimal signals; __getitem__(0).__name__ is 'DecimalException'; new to extra251"]
    - [inexact_is_type,
       "Inexact.__class__.__name__.__eq__",
       ["type"],
       true,
       "decimal.Inexact.__class__.__name__.__eq__('type') == True — Inexact is a class object; its __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra251"]
    - [rounded_name,
       "Rounded.__name__.__eq__",
       ["Rounded"],
       true,
       "decimal.Rounded.__name__.__eq__('Rounded') == True — Rounded is the signal raised when a result has been rounded (some digits discarded); its __name__ is 'Rounded'; str.__eq__('Rounded') returns True; new to extra251"]
    - [rounded_module,
       "Rounded.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Rounded.__module__.__eq__('decimal') == True — Rounded is defined in the decimal C extension; its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra251"]
    - [rounded_base,
       "Rounded.__bases__.__getitem__",
       [0],
       "DecimalException",
       "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded inherits directly from DecimalException; __getitem__(0).__name__ is 'DecimalException'; new to extra251"]
    - [subnormal_name,
       "Subnormal.__name__.__eq__",
       ["Subnormal"],
       true,
       "decimal.Subnormal.__name__.__eq__('Subnormal') == True — Subnormal is the signal raised when a result is subnormal (too small to be represented with full precision); its __name__ is 'Subnormal'; str.__eq__('Subnormal') returns True; new to extra251"]
    - [subnormal_module,
       "Subnormal.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Subnormal.__module__.__eq__('decimal') == True — Subnormal is defined in the decimal C extension; its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra251"]
    - [subnormal_base,
       "Subnormal.__bases__.__getitem__",
       [0],
       "DecimalException",
       "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal inherits directly from DecimalException; __getitem__(0).__name__ is 'DecimalException'; new to extra251"]

# ---------------------------------------------------------------------------
# Table 2: decimal.FloatOperation signal class identity
#
# FloatOperation has two bases: (DecimalException, TypeError).
# It is both a decimal signal and a TypeError, used when floats are mixed
# into decimal operations in a strict context.
# __bases__.__len__() == 2 is verified, then each base by index.
# ---------------------------------------------------------------------------

table decimal_extra251.float_operation_identity:
  description: "decimal.FloatOperation class identity — dual inheritance from DecimalException and TypeError; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: decxfoi251

  columns: [id, function, args, expected, description]
  rows:
    - [name,
       "FloatOperation.__name__.__eq__",
       ["FloatOperation"],
       true,
       "decimal.FloatOperation.__name__.__eq__('FloatOperation') == True — FloatOperation is the signal raised when a float is mixed with a Decimal in a strict arithmetic context; its __name__ is 'FloatOperation'; str.__eq__('FloatOperation') returns True; new to extra251"]
    - [module,
       "FloatOperation.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.FloatOperation.__module__.__eq__('decimal') == True — FloatOperation is defined in the decimal C extension; its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra251"]
    - [bases_len,
       "FloatOperation.__bases__.__len__",
       [],
       2,
       "decimal.FloatOperation.__bases__.__len__() == 2 — FloatOperation has exactly two base classes: DecimalException and TypeError; tuple.__len__() returns 2; new to extra251"]
    - [base0_name,
       "FloatOperation.__bases__.__getitem__",
       [0],
       "DecimalException",
       "decimal.FloatOperation.__bases__[0].__name__ == 'DecimalException' — the first base of FloatOperation is DecimalException, the base for all decimal signals; __getitem__(0).__name__ is 'DecimalException'; new to extra251"]
    - [base1_name,
       "FloatOperation.__bases__.__getitem__",
       [1],
       "TypeError",
       "decimal.FloatOperation.__bases__[1].__name__ == 'TypeError' — the second base of FloatOperation is the built-in TypeError; this allows it to be caught as a type error as well as a decimal signal; __getitem__(1).__name__ is 'TypeError'; new to extra251"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Overflow and decimal.Underflow multi-base hierarchy
#
# Overflow inherits from (Inexact, Rounded) — 2 bases.
# Underflow inherits from (Inexact, Rounded, Subnormal) — 3 bases.
# These represent the full MRO relationships for overflow and underflow.
# ---------------------------------------------------------------------------

table decimal_extra251.overflow_underflow_hierarchy:
  description: "decimal.Overflow and Underflow multi-base class hierarchy; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: decxouh251

  columns: [id, function, args, expected, description]
  rows:
    - [overflow_name,
       "Overflow.__name__.__eq__",
       ["Overflow"],
       true,
       "decimal.Overflow.__name__.__eq__('Overflow') == True — Overflow is the signal raised when an exponent is larger than the context's Emax; its __name__ is 'Overflow'; str.__eq__('Overflow') returns True; new to extra251"]
    - [overflow_module,
       "Overflow.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Overflow.__module__.__eq__('decimal') == True — Overflow is defined in the decimal C extension; its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra251"]
    - [overflow_bases_len,
       "Overflow.__bases__.__len__",
       [],
       2,
       "decimal.Overflow.__bases__.__len__() == 2 — Overflow inherits from exactly two base classes: Inexact and Rounded; tuple.__len__() returns 2; new to extra251"]
    - [overflow_base0,
       "Overflow.__bases__.__getitem__",
       [0],
       "Inexact",
       "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — the first base of Overflow is Inexact (result cannot be represented exactly); __getitem__(0).__name__ is 'Inexact'; new to extra251"]
    - [overflow_base1,
       "Overflow.__bases__.__getitem__",
       [1],
       "Rounded",
       "decimal.Overflow.__bases__[1].__name__ == 'Rounded' — the second base of Overflow is Rounded (digits were discarded during overflow); __getitem__(1).__name__ is 'Rounded'; new to extra251"]
    - [underflow_name,
       "Underflow.__name__.__eq__",
       ["Underflow"],
       true,
       "decimal.Underflow.__name__.__eq__('Underflow') == True — Underflow is the signal raised when a subnormal result has been rounded to zero; its __name__ is 'Underflow'; str.__eq__('Underflow') returns True; new to extra251"]
    - [underflow_module,
       "Underflow.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Underflow.__module__.__eq__('decimal') == True — Underflow is defined in the decimal C extension; its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra251"]
    - [underflow_bases_len,
       "Underflow.__bases__.__len__",
       [],
       3,
       "decimal.Underflow.__bases__.__len__() == 3 — Underflow inherits from exactly three base classes: Inexact, Rounded, and Subnormal; tuple.__len__() returns 3; new to extra251"]
    - [underflow_base0,
       "Underflow.__bases__.__getitem__",
       [0],
       "Inexact",
       "decimal.Underflow.__bases__[0].__name__ == 'Inexact' — the first base of Underflow is Inexact; __getitem__(0).__name__ is 'Inexact'; new to extra251"]
    - [underflow_base1,
       "Underflow.__bases__.__getitem__",
       [1],
       "Rounded",
       "decimal.Underflow.__bases__[1].__name__ == 'Rounded' — the second base of Underflow is Rounded; __getitem__(1).__name__ is 'Rounded'; new to extra251"]
    - [underflow_base2,
       "Underflow.__bases__.__getitem__",
       [2],
       "Subnormal",
       "decimal.Underflow.__bases__[2].__name__ == 'Subnormal' — the third base of Underflow is Subnormal (the result is subnormal before rounding to zero); __getitem__(2).__name__ is 'Subnormal'; new to extra251"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra251
# ---------------------------------------------------------------------------

invariant decimal_extra251.inexact_name:
  description: "decimal.Inexact.__name__ == 'Inexact' — signal for inexact (non-exact) results; new to extra251"
  kind: python_call_eq
  function: Inexact.__name__.__eq__
  args: ["Inexact"]
  expected: true

invariant decimal_extra251.inexact_module:
  description: "decimal.Inexact.__module__ == 'decimal' — Inexact is defined in the decimal C extension; new to extra251"
  kind: python_call_eq
  function: Inexact.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra251.inexact_base_is_decimalexception:
  description: "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact inherits from DecimalException; new to extra251"
  kind: python_call_eq
  function: "Inexact.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra251.rounded_name:
  description: "decimal.Rounded.__name__ == 'Rounded' — signal for rounded results; new to extra251"
  kind: python_call_eq
  function: Rounded.__name__.__eq__
  args: ["Rounded"]
  expected: true

invariant decimal_extra251.rounded_base_is_decimalexception:
  description: "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded inherits from DecimalException; new to extra251"
  kind: python_call_eq
  function: "Rounded.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra251.subnormal_name:
  description: "decimal.Subnormal.__name__ == 'Subnormal' — signal for subnormal results; new to extra251"
  kind: python_call_eq
  function: Subnormal.__name__.__eq__
  args: ["Subnormal"]
  expected: true

invariant decimal_extra251.subnormal_base_is_decimalexception:
  description: "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal inherits from DecimalException; new to extra251"
  kind: python_call_eq
  function: "Subnormal.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra251.float_operation_name:
  description: "decimal.FloatOperation.__name__ == 'FloatOperation' — signal for float mixed with decimal in strict context; new to extra251"
  kind: python_call_eq
  function: FloatOperation.__name__.__eq__
  args: ["FloatOperation"]
  expected: true

invariant decimal_extra251.float_operation_module:
  description: "decimal.FloatOperation.__module__ == 'decimal' — FloatOperation is defined in the decimal C extension; new to extra251"
  kind: python_call_eq
  function: FloatOperation.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra251.float_operation_bases_len:
  description: "decimal.FloatOperation.__bases__.__len__() == 2 — FloatOperation has two bases: DecimalException and TypeError; new to extra251"
  kind: python_call_eq
  function: FloatOperation.__bases__.__len__
  args: []
  expected: 2

invariant decimal_extra251.float_operation_base0_is_decimalexception:
  description: "decimal.FloatOperation.__bases__[0].__name__ == 'DecimalException' — first base of FloatOperation is DecimalException; new to extra251"
  kind: python_call_eq
  function: "FloatOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra251.float_operation_base1_is_typeerror:
  description: "decimal.FloatOperation.__bases__[1].__name__ == 'TypeError' — second base of FloatOperation is TypeError; new to extra251"
  kind: python_call_eq
  function: "FloatOperation.__bases__[1].__name__.__eq__"
  args: ["TypeError"]
  expected: true

invariant decimal_extra251.overflow_name:
  description: "decimal.Overflow.__name__ == 'Overflow' — signal for exponent exceeding Emax; new to extra251"
  kind: python_call_eq
  function: Overflow.__name__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra251.overflow_bases_len:
  description: "decimal.Overflow.__bases__.__len__() == 2 — Overflow has two bases: Inexact and Rounded; new to extra251"
  kind: python_call_eq
  function: Overflow.__bases__.__len__
  args: []
  expected: 2

invariant decimal_extra251.overflow_base0_is_inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — first base of Overflow is Inexact; new to extra251"
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra251.overflow_base1_is_rounded:
  description: "decimal.Overflow.__bases__[1].__name__ == 'Rounded' — second base of Overflow is Rounded; new to extra251"
  kind: python_call_eq
  function: "Overflow.__bases__[1].__name__.__eq__"
  args: ["Rounded"]
  expected: true

invariant decimal_extra251.underflow_name:
  description: "decimal.Underflow.__name__ == 'Underflow' — signal for subnormal result rounded to zero; new to extra251"
  kind: python_call_eq
  function: Underflow.__name__.__eq__
  args: ["Underflow"]
  expected: true

invariant decimal_extra251.underflow_bases_len:
  description: "decimal.Underflow.__bases__.__len__() == 3 — Underflow has three bases: Inexact, Rounded, Subnormal; new to extra251"
  kind: python_call_eq
  function: Underflow.__bases__.__len__
  args: []
  expected: 3

invariant decimal_extra251.underflow_base0_is_inexact:
  description: "decimal.Underflow.__bases__[0].__name__ == 'Inexact' — first base of Underflow is Inexact; new to extra251"
  kind: python_call_eq
  function: "Underflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra251.underflow_base1_is_rounded:
  description: "decimal.Underflow.__bases__[1].__name__ == 'Rounded' — second base of Underflow is Rounded; new to extra251"
  kind: python_call_eq
  function: "Underflow.__bases__[1].__name__.__eq__"
  args: ["Rounded"]
  expected: true

invariant decimal_extra251.underflow_base2_is_subnormal:
  description: "decimal.Underflow.__bases__[2].__name__ == 'Subnormal' — third base of Underflow is Subnormal; new to extra251"
  kind: python_call_eq
  function: "Underflow.__bases__[2].__name__.__eq__"
  args: ["Subnormal"]
  expected: true
