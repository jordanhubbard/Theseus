       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra151"]
    - [lru_cache_doc_len_eq_743,
       "lru_cache.__doc__.__len__",
       [],
       743,
       "functools.lru_cache.__doc__.__len__() == 743 — the lru_cache docstring has 743 characters; len(__doc__) == 743; verified with Python 3.14.3; new to extra151"]
    - [lru_cache_co_argcount_eq_2,
       "lru_cache.__code__.co_argcount.__eq__",
