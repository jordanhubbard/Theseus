  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.total_ordering decorator (Python function) — __qualname__ 'total_ordering' len 14, __module__ 'functools', __doc__ len 54, co_argcount 1, co_varnames len 6; functools.__spec__ (ModuleSpec) — __class__.__name__ 'ModuleSpec', name 'functools' len 9; functools.lru_cache (Python function) — __qualname__ 'lru_cache' len 9, __module__ 'functools', __doc__ len 743, co_argcount 2, co_varnames len 5 (Wave 274)."
    - "functools.total_ordering is a Python function defined in Lib/functools.py; __qualname__ == 'total_ordering' (len 14); __module__ == 'functools'; __doc__ len == 54; co_argcount == 1; co_varnames len == 6. Verified with Python 3.14.3."
    - "functools.__spec__ is a ModuleSpec instance; __spec__.__class__.__name__ == 'ModuleSpec'; __spec__.name == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.lru_cache is a Python function defined in Lib/functools.py; __qualname__ == 'lru_cache' (len 9); __module__ == 'functools'; __doc__ len == 743; co_argcount == 2; co_varnames len == 5. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.total_ordering — Python function identity and code attrs
#
# Wave 274 theme: functools.total_ordering — a class decorator that fills in
# missing ordering methods given __eq__ and one of __lt__, __le__, __gt__,
# or __ge__.
#
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__qualname__ == 'total_ordering' (len 14)
# functools.total_ordering.__module__ == 'functools' (len 9)
# len(functools.total_ordering.__doc__) == 54
# functools.total_ordering.__code__.co_argcount == 1
# len(functools.total_ordering.__code__.co_varnames) == 6
#
# total_ordering(cls) fills in missing comparison methods on cls.
# New to extra151.
# ---------------------------------------------------------------------------

table functools_extra151.total_ordering_attrs:
  description: "functools.total_ordering: Python function, __qualname__ 'total_ordering' len 14, __module__ 'functools', __doc__ len 54, co_argcount 1, co_varnames len 6; wave 274; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolstotord151

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_class_eq_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a Python function defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra151"]
    - [total_ordering_qualname_eq,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — the function's __qualname__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra151"]
    - [total_ordering_qualname_len_eq_14,
       "total_ordering.__qualname__.__len__",
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — __qualname__ is 'total_ordering' which has 14 characters; len('total_ordering') == 14; new to extra151"]
    - [total_ordering_module_eq_functools,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra151"]
    - [total_ordering_doc_len_eq_54,
       "total_ordering.__doc__.__len__",
       [],
       54,
       "functools.total_ordering.__doc__.__len__() == 54 — the total_ordering docstring has 54 characters; len(__doc__) == 54; verified with Python 3.14.3; new to extra151"]
    - [total_ordering_co_argcount_eq_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering takes 1 positional-or-keyword argument: cls; co_argcount is 1; int.__eq__(1) returns True; new to extra151"]
    - [total_ordering_co_varnames_len_eq_6,
       "total_ordering.__code__.co_varnames.__len__",
       [],
       6,
       "functools.total_ordering.__code__.co_varnames.__len__() == 6 — co_varnames has 6 entries; len() == 6; verified with Python 3.14.3; new to extra151"]

# ---------------------------------------------------------------------------
# Table 2: functools.__spec__ — ModuleSpec identity
#
# Wave 274 theme: functools.__spec__ — the ModuleSpec object created by the
# import machinery when the module is loaded.
#
# functools.__spec__.__class__.__name__ == 'ModuleSpec'
# functools.__spec__.name == 'functools' (len 9)
#
# __spec__ is set on every module by the import system; its class is
# importlib.machinery.ModuleSpec. New to extra151.
# ---------------------------------------------------------------------------

table functools_extra151.module_spec_attrs:
  description: "functools.__spec__: ModuleSpec, __class__.__name__=='ModuleSpec', name=='functools' len 9; wave 274; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsspec151

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_eq_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is set by the import machinery; its class is importlib.machinery.ModuleSpec; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra151"]
    - [spec_name_eq_functools,
       "__spec__.name.__eq__",
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — the ModuleSpec name attribute is the fully-qualified module name 'functools'; str.__eq__('functools') returns True; new to extra151"]
    - [spec_name_len_eq_9,
       "__spec__.name.__len__",
       [],
       9,
       "functools.__spec__.name.__len__() == 9 — __spec__.name is 'functools' which has 9 characters; len('functools') == 9; new to extra151"]
    - [spec_class_name_len_eq_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "functools.__spec__.__class__.__name__.__len__() == 10 — __class__.__name__ is 'ModuleSpec' which has 10 characters; len('ModuleSpec') == 10; new to extra151"]

# ---------------------------------------------------------------------------
# Table 3: functools.lru_cache — Python function identity and code attrs
#
# Wave 274 theme: functools.lru_cache — the least-recently-used cache
# decorator that memoizes function calls with bounded memory.
#
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__qualname__ == 'lru_cache' (len 9)
# functools.lru_cache.__module__ == 'functools' (len 9)
# len(functools.lru_cache.__doc__) == 743
# functools.lru_cache.__code__.co_argcount == 2
# len(functools.lru_cache.__code__.co_varnames) == 5
#
# lru_cache(maxsize=128, typed=False) memoizes up to maxsize recent calls.
# Defined in Lib/functools.py. New to extra151.
# ---------------------------------------------------------------------------

table functools_extra151.lru_cache_attrs:
  description: "functools.lru_cache: Python function, __qualname__ 'lru_cache' len 9, __module__ 'functools', __doc__ len 743, co_argcount 2, co_varnames len 5; wave 274; new to extra151"
