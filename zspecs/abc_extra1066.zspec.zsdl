spec: abc_extra1066
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABC, ABCMeta, get_cache_token, and _dump_registry documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABC __init_subclass__/__class_getitem__ qualnames, abc.get_cache_token module and qualname, abc.ABCMeta._dump_registry qualname — behaviors not covered by extra1036 or extra1051"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1066.abc_init_subclass_class_getitem:
  description: "abc.ABC __init_subclass__ and __class_getitem__ qualname identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab1066ai
  columns: [id, function, args, expected]
  rows:
    - [ab1066ai001, abc.ABC.__init_subclass__.__func__.__qualname__.__eq__,    ["object.__init_subclass__"],  true]
    - [ab1066ai002, abc.ABC.__class_getitem__.__func__.__qualname__.__eq__,    ["object.__class_getitem__"],  true]
    - [ab1066ai003, abc.ABC.__init_subclass__.__class__.__name__.__eq__,       ["classmethod_descriptor"],    true]
    - [ab1066ai004, abc.ABC.__class_getitem__.__class__.__name__.__eq__,       ["classmethod_descriptor"],    true]
    - [ab1066ai005, abc.ABC.__name__.__eq__,                                   ["ABC"],                       true]
    - [ab1066ai006, abc.ABC.__weakref__.__class__.__name__.__eq__,             ["getset_descriptor"],         true]
    - [ab1066ai007, abc.ABC.__class__.__qualname__.__eq__,                     ["ABCMeta"],                   true]

table abc_extra1066.get_cache_token_identity:
  description: "abc.get_cache_token module, qualname, and class identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: ab1066gc
  columns: [id, function, args, expected]
  rows:
    - [ab1066gc001, abc.get_cache_token.__module__.__eq__,         ["abc"],                       true]
    - [ab1066gc002, abc.get_cache_token.__qualname__.__eq__,       ["get_cache_token"],            true]
    - [ab1066gc003, abc.get_cache_token.__name__.__eq__,           ["get_cache_token"],            true]
    - [ab1066gc004, abc.get_cache_token.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1066gc005, abc.get_cache_token.__doc__.__class__.__name__.__eq__, ["str"],               true]
    - [ab1066gc006, abc.__spec__.__name__.__eq__,                  ["abc"],                        true]
    - [ab1066gc007, abc.__loader__.__class__.__name__.__eq__,      ["_frozen_importlib.BuiltinImporter"], true]

table abc_extra1066.abcmeta_dump_registry_qualname:
  description: "abc.ABCMeta._dump_registry and _get_dump qualname identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab1066dr
  columns: [id, function, args, expected]
  rows:
    - [ab1066dr001, abc.ABCMeta._dump_registry.__qualname__.__eq__,    ["ABCMeta._dump_registry"],    true]
    - [ab1066dr002, abc.ABCMeta._dump_registry.__class__.__name__.__eq__, ["function"],               true]
    - [ab1066dr003, abc.ABCMeta._dump_registry.__module__.__eq__,      ["abc"],                       true]
    - [ab1066dr004, abc.ABCMeta.__new__.__qualname__.__eq__,            ["ABCMeta.__new__"],           true]
    - [ab1066dr005, abc.ABCMeta.__init__.__qualname__.__eq__,           ["ABCMeta.__init__"],          true]
    - [ab1066dr006, abc.ABCMeta.__subclasshook__.__qualname__.__eq__,   ["ABCMeta.__subclasshook__"],  true]
    - [ab1066dr007, abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__, ["function"],              true]
