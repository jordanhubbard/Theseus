spec: uuid_extra265
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra264.zspec.zsdl — covers UUID.__module__/__name__/__bases__ identity and UUID(int=0) instance attributes."
    - "uuid_extra263.zspec.zsdl — covers uuid.UUID __slots__/__init__ identity and comparison operator qualnames."
    - "uuid_extra262.zspec.zsdl — covers uuid module __spec__/__loader__ identity and UUID.__slots__/__hash__ identity."
  notes:
    - "uuid.uuid4().__class__.__name__ == 'UUID' — uuid4() returns a UUID instance; the class is always named 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').hex == '886313e13b8a53729b900c9aee199e5d' — deterministic RFC 4122 version-5 UUID for 'python.org' under the DNS namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').version == 5 — version-5 UUIDs are SHA-1-based name UUIDs per RFC 4122. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — the predefined namespace constants are UUID instances. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.NAMESPACE_DNS.hex == '6ba7b8109dad11d180b400c04fd430c8' — the DNS namespace UUID hex value as defined in RFC 4122 Appendix C. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').hex == '6fa459eaee8a3ca4894edb77e160355e' — deterministic RFC 4122 version-3 UUID for 'python.org' under the DNS namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').version == 3 — version-3 UUIDs are MD5-based name UUIDs per RFC 4122. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid4(), uuid.uuid5(), and uuid.NAMESPACE_DNS basic properties
# uuid4() is random but always returns a UUID instance.
# uuid5(NAMESPACE_DNS, 'python.org') is deterministic: RFC 4122 specifies
# the computation as SHA-1(namespace || name), giving a fixed hex value.
# NAMESPACE_DNS itself is a UUID constant defined in RFC 4122 Appendix C.
# ---------------------------------------------------------------------------

table uuid_extra265.uuid4_uuid5_class_and_version:
  description: "uuid.uuid4/uuid5/NAMESPACE_DNS instance identity — uuid4().__class__.__name__=='UUID'; uuid5(NAMESPACE_DNS,'python.org').hex=='886313e13b8a53729b900c9aee199e5d'; version==5; NAMESPACE_DNS class name; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: uuids265

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_cls,       uuid4_class_name.__eq__,        ["UUID"],                              true, "uuid.uuid4().__class__.__name__ == 'UUID' — uuid4() always returns a UUID instance"]
    - [uuid5_hex,       uuid5_dns_python_hex.__eq__,    ["886313e13b8a53729b900c9aee199e5d"],   true, "uuid.uuid5(NAMESPACE_DNS, 'python.org').hex — deterministic RFC 4122 v5 value"]
    - [uuid5_version,   uuid5_dns_python_version.__eq__, [5],                                  true, "uuid.uuid5(NAMESPACE_DNS, 'python.org').version == 5 — SHA-1-based name UUID"]
    - [ns_dns_cls,      NAMESPACE_DNS_class_name.__eq__, ["UUID"],                             true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — namespace constants are UUID instances"]
    - [ns_dns_hex,      NAMESPACE_DNS_hex.__eq__,       ["6ba7b8109dad11d180b400c04fd430c8"],   true, "uuid.NAMESPACE_DNS.hex == RFC 4122 Appendix C DNS namespace hex value"]

# ---------------------------------------------------------------------------
# uuid.uuid3() deterministic name UUID (MD5-based)
# uuid3(NAMESPACE_DNS, 'python.org') is the MD5-based name UUID for
# 'python.org' under the DNS namespace — a fixed value per RFC 4122.
# uuid5 and uuid3 both produce deterministic UUIDs but differ in hash
# algorithm (SHA-1 vs MD5) and version number (5 vs 3).
# ---------------------------------------------------------------------------

table uuid_extra265.uuid3_deterministic_name_uuid:
  description: "uuid.uuid3 deterministic name UUID — uuid3(NAMESPACE_DNS,'python.org').hex=='6fa459eaee8a3ca4894edb77e160355e'; version==3; __class__.__name__=='UUID'; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: uuid3265

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_hex,      uuid3_dns_python_hex.__eq__,     ["6fa459eaee8a3ca4894edb77e160355e"],   true, "uuid.uuid3(NAMESPACE_DNS, 'python.org').hex — deterministic RFC 4122 v3 value"]
    - [uuid3_version,  uuid3_dns_python_version.__eq__,  [3],                                   true, "uuid.uuid3(NAMESPACE_DNS, 'python.org').version == 3 — MD5-based name UUID"]
    - [uuid3_cls,      uuid3_class_name.__eq__,          ["UUID"],                              true, "uuid.uuid3(NAMESPACE_DNS, 'python.org').__class__.__name__ == 'UUID'"]
    - [ns_url_cls,     NAMESPACE_URL_class_name.__eq__,  ["UUID"],                              true, "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — URL namespace is also a UUID instance"]
    - [ns_oid_cls,     NAMESPACE_OID_class_name.__eq__,  ["UUID"],                              true, "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — OID namespace is also a UUID instance"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid4/uuid5/uuid3 and namespace constants
# ---------------------------------------------------------------------------

invariant uuid_extra265.uuid4_class_name_eq:
  description: "uuid.uuid4().__class__.__name__ == 'UUID' — the uuid4() factory always returns an instance of the UUID class regardless of the random value generated; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: uuid4_class_name.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra265.uuid5_dns_python_hex_eq:
  description: "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').hex == '886313e13b8a53729b900c9aee199e5d' — deterministic RFC 4122 version-5 (SHA-1-based) name UUID for 'python.org' in the DNS namespace; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: uuid5_dns_python_hex.__eq__
  args: ["886313e13b8a53729b900c9aee199e5d"]
  expected: true

invariant uuid_extra265.uuid5_dns_python_version_eq:
  description: "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').version == 5 — version-5 UUIDs are SHA-1-based name UUIDs per RFC 4122 Section 4.3; version field is embedded in the UUID bits; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: uuid5_dns_python_version.__eq__
  args: [5]
  expected: true

invariant uuid_extra265.NAMESPACE_DNS_class_name_eq:
  description: "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — the predefined namespace constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID) are all UUID instances; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS_class_name.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra265.NAMESPACE_DNS_hex_eq:
  description: "uuid.NAMESPACE_DNS.hex == '6ba7b8109dad11d180b400c04fd430c8' — the DNS namespace UUID is defined as 6ba7b810-9dad-11d1-80b4-00c04fd430c8 in RFC 4122 Appendix C; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: NAMESPACE_DNS_hex.__eq__
  args: ["6ba7b8109dad11d180b400c04fd430c8"]
  expected: true

invariant uuid_extra265.uuid3_dns_python_hex_eq:
  description: "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').hex == '6fa459eaee8a3ca4894edb77e160355e' — deterministic RFC 4122 version-3 (MD5-based) name UUID for 'python.org' in the DNS namespace; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: uuid3_dns_python_hex.__eq__
  args: ["6fa459eaee8a3ca4894edb77e160355e"]
  expected: true

invariant uuid_extra265.uuid3_dns_python_version_eq:
  description: "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').version == 3 — version-3 UUIDs are MD5-based name UUIDs per RFC 4122 Section 4.3; distinct from version-5 which uses SHA-1; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: uuid3_dns_python_version.__eq__
  args: [3]
  expected: true

invariant uuid_extra265.uuid_invalid_string_raises:
  description: "uuid.UUID('not-a-uuid') raises ValueError — UUID constructor rejects strings that are not valid 32-hex-character UUID representations; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: UUID
  args: ["not-a-uuid"]
  raises: ValueError
