spec: functools_extra2446
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave (_extra2446): __enter__/__exit__ context manager protocol dict-presence checks."
    - "functools.partial does not define __enter__ or __exit__ in its own __dict__ — it is not a context manager."
    - "functools.partialmethod does not define __enter__ or __exit__ in its own __dict__ — it is not a context manager."
    - "functools.cached_property does not define __enter__ or __exit__ in its own __dict__ — it is a descriptor, not a context manager."
    - "functools.singledispatchmethod does not define __enter__ or __exit__ in its own __dict__ — not a context manager."
    - "functools.RLock (which is _thread.RLock) DOES define __enter__ and __exit__ in its own __dict__ — it IS a context manager."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table functools_extra2446.enter_protocol:
  description: "functools types __enter__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2446
  columns: [id, function, args, expected]
  rows:
    - ["ft2446001", "functools.partial.__dict__.__contains__",            ["__enter__"], false]
    - ["ft2446002", "functools.partialmethod.__dict__.__contains__",      ["__enter__"], false]
    - ["ft2446003", "functools.cached_property.__dict__.__contains__",    ["__enter__"], false]
    - ["ft2446004", "functools.singledispatchmethod.__dict__.__contains__", ["__enter__"], false]
    - ["ft2446005", "functools.RLock.__dict__.__contains__",              ["__enter__"], true]

table functools_extra2446.exit_protocol:
  description: "functools types __exit__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2446
  columns: [id, function, args, expected]
  rows:
    - ["ft2446006", "functools.partial.__dict__.__contains__",            ["__exit__"], false]
    - ["ft2446007", "functools.partialmethod.__dict__.__contains__",      ["__exit__"], false]
    - ["ft2446008", "functools.cached_property.__dict__.__contains__",    ["__exit__"], false]
    - ["ft2446009", "functools.singledispatchmethod.__dict__.__contains__", ["__exit__"], false]
    - ["ft2446010", "functools.RLock.__dict__.__contains__",              ["__exit__"], true]

table functools_extra2446.non_cm_own_attrs:
  description: "functools non-context-manager types define their own callable attrs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2446
  columns: [id, function, args, expected]
  rows:
    - ["ft2446011", "functools.partial.__dict__.__contains__",            ["__call__"],    true]
    - ["ft2446012", "functools.partial.__dict__.__contains__",            ["func"],        true]
    - ["ft2446013", "functools.partial.__dict__.__contains__",            ["args"],        true]
    - ["ft2446014", "functools.cached_property.__dict__.__contains__",    ["__get__"],     true]
    - ["ft2446015", "functools.cached_property.__dict__.__contains__",    ["__set_name__"], true]
    - ["ft2446016", "functools.partialmethod.__dict__.__contains__",      ["__get__"],     true]
    - ["ft2446017", "functools.singledispatchmethod.__dict__.__contains__", ["__get__"],   true]
    - ["ft2446018", "functools.RLock.__dict__.__contains__",              ["acquire"],     true]
    - ["ft2446019", "functools.RLock.__dict__.__contains__",              ["release"],     true]
    - ["ft2446020", "functools.RLock.__dict__.__contains__",              ["locked"],      true]
