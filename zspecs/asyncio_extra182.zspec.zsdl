spec: asyncio_extra182
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio.Task and asyncio.Future method name lengths — cancel.__name__=='cancel' (len=6); done.__name__=='done' (len=4); result.__name__=='result' (len=6); exception.__name__=='exception' (len=9); add_done_callback.__name__=='add_done_callback' (len=17); remove_done_callback.__name__=='remove_done_callback' (len=20); get_name.__name__=='get_name' (len=8); set_name.__name__=='set_name' (len=8)."
    - "asyncio.Task.cancel.__name__ == 'cancel' (len=6: c-a-n-c-e-l). cancel() requests cancellation of a Task by raising CancelledError at the next await. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.add_done_callback.__name__ == 'add_done_callback' (len=17). Registers a callback to be run when the Task completes. asyncio.Task inherits this from asyncio.Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.remove_done_callback.__name__ == 'remove_done_callback' (len=20). Removes all instances of a callback from the done-callbacks list. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "get_name and set_name (both len=8) are Task-specific methods, not present on asyncio.Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Task lifecycle method name lengths
#
# cancel.__name__ == 'cancel' (len=6)
# done.__name__ == 'done' (len=4)
# result.__name__ == 'result' (len=6)
# exception.__name__ == 'exception' (len=9)
#
# These are the primary lifecycle / state-query methods on asyncio.Task.
# ---------------------------------------------------------------------------

table asyncio_extra182.task_lifecycle_names:
  description: "asyncio.Task lifecycle method __name__ values: cancel(len=6), done(len=4), result(len=6), exception(len=9); new to asyncio_extra182"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask182

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_name_eq,
       Task.cancel.__name__.__eq__,
       ["cancel"],
       true,
       "asyncio.Task.cancel.__name__.__eq__('cancel') == True — cancel() requests Task cancellation by raising CancelledError at the next await point; __name__ is 'cancel' (6 chars: c-a-n-c-e-l); str.__eq__('cancel') returns True; new to asyncio_extra182"]
    - [cancel_name_len_6,
       Task.cancel.__name__.__len__,
       [],
       6,
       "asyncio.Task.cancel.__name__.__len__() == 6 — 'cancel' has 6 characters: c-a-n-c-e-l; NAME LENGTHS: done=4 < cancel=result=6 < exception=9; str.__len__() returns 6; new to asyncio_extra182"]
    - [done_name_eq,
       Task.done.__name__.__eq__,
       ["done"],
       true,
       "asyncio.Task.done.__name__.__eq__('done') == True — done() returns True if the Task is finished (completed, cancelled, or raised an exception); __name__ is 'done' (4 chars: d-o-n-e); str.__eq__('done') returns True; new to asyncio_extra182"]
    - [done_name_len_4,
       Task.done.__name__.__len__,
       [],
       4,
       "asyncio.Task.done.__name__.__len__() == 4 — 'done' has 4 characters: d-o-n-e; shortest of the lifecycle method names; str.__len__() returns 4; new to asyncio_extra182"]
    - [result_name_eq,
       Task.result.__name__.__eq__,
       ["result"],
       true,
       "asyncio.Task.result.__name__.__eq__('result') == True — result() returns the Task result or raises an exception if the Task failed or was cancelled; __name__ is 'result' (6 chars: r-e-s-u-l-t); str.__eq__('result') returns True; new to asyncio_extra182"]
    - [exception_name_eq,
       Task.exception.__name__.__eq__,
       ["exception"],
       true,
       "asyncio.Task.exception.__name__.__eq__('exception') == True — exception() returns the exception that caused the Task to fail, or None if it succeeded; __name__ is 'exception' (9 chars: e-x-c-e-p-t-i-o-n); str.__eq__('exception') returns True; new to asyncio_extra182"]
    - [exception_name_len_9,
       Task.exception.__name__.__len__,
       [],
       9,
       "asyncio.Task.exception.__name__.__len__() == 9 — 'exception' has 9 characters: e-x-c-e-p-t-i-o-n; longest of the four lifecycle method names; str.__len__() returns 9; new to asyncio_extra182"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Task callback registration method name lengths
#
# add_done_callback.__name__ == 'add_done_callback' (len=17)
# remove_done_callback.__name__ == 'remove_done_callback' (len=20)
#
# These methods are inherited from asyncio.Future.
# ---------------------------------------------------------------------------

table asyncio_extra182.task_callback_names:
  description: "asyncio.Task callback methods: add_done_callback(len=17), remove_done_callback(len=20); inherited from asyncio.Future; new to asyncio_extra182"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask182

  columns: [id, function, args, expected, description]
  rows:
    - [add_done_cb_name_eq,
       Task.add_done_callback.__name__.__eq__,
       ["add_done_callback"],
       true,
       "asyncio.Task.add_done_callback.__name__.__eq__('add_done_callback') == True — add_done_callback() registers a callback to be invoked when the Task completes; inherited from asyncio.Future; __name__ is 'add_done_callback' (17 chars); str.__eq__('add_done_callback') returns True; new to asyncio_extra182"]
    - [add_done_cb_name_len_17,
       Task.add_done_callback.__name__.__len__,
       [],
       17,
       "asyncio.Task.add_done_callback.__name__.__len__() == 17 — 'add_done_callback' has 17 characters: a-d-d-_-d-o-n-e-_-c-a-l-l-b-a-c-k; str.__len__() returns 17; new to asyncio_extra182"]
    - [remove_done_cb_name_eq,
       Task.remove_done_callback.__name__.__eq__,
       ["remove_done_callback"],
       true,
       "asyncio.Task.remove_done_callback.__name__.__eq__('remove_done_callback') == True — remove_done_callback() removes all instances of a callback from the done-callbacks list; __name__ is 'remove_done_callback' (20 chars); str.__eq__('remove_done_callback') returns True; new to asyncio_extra182"]
    - [remove_done_cb_name_len_20,
       Task.remove_done_callback.__name__.__len__,
       [],
       20,
       "asyncio.Task.remove_done_callback.__name__.__len__() == 20 — 'remove_done_callback' has 20 characters: r-e-m-o-v-e-_-d-o-n-e-_-c-a-l-l-b-a-c-k; longest method name in this spec; str.__len__() returns 20; new to asyncio_extra182"]
    - [add_lt_remove_name_len,
       Task.add_done_callback.__name__.__lt__,
       ["remove_done_callback"],
       true,
       "asyncio.Task.add_done_callback.__name__.__lt__('remove_done_callback') == True — 'add_done_callback' (17 chars) < 'remove_done_callback' (20 chars) lexicographically; str.__lt__() returns True; new to asyncio_extra182"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Task name-management method name lengths
#
# get_name.__name__ == 'get_name' (len=8)
# set_name.__name__ == 'set_name' (len=8)
#
# Task-specific methods (not on asyncio.Future) for reading/writing
# the Task's human-readable name.
# ---------------------------------------------------------------------------

table asyncio_extra182.task_name_methods:
  description: "asyncio.Task name-management methods: get_name(len=8), set_name(len=8); Task-specific, not inherited from Future; new to asyncio_extra182"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask182

  columns: [id, function, args, expected, description]
  rows:
    - [get_name_name_eq,
       Task.get_name.__name__.__eq__,
       ["get_name"],
       true,
       "asyncio.Task.get_name.__name__.__eq__('get_name') == True — get_name() returns the Task's name as a string; Task-specific, not present on asyncio.Future; __name__ is 'get_name' (8 chars: g-e-t-_-n-a-m-e); str.__eq__('get_name') returns True; new to asyncio_extra182"]
    - [get_name_name_len_8,
       Task.get_name.__name__.__len__,
       [],
       8,
       "asyncio.Task.get_name.__name__.__len__() == 8 — 'get_name' has 8 characters: g-e-t-_-n-a-m-e; NAME LENGTHS: done=4 < cancel=result=6 < get_name=set_name=8 < exception=9; str.__len__() returns 8; new to asyncio_extra182"]
    - [set_name_name_eq,
       Task.set_name.__name__.__eq__,
       ["set_name"],
       true,
       "asyncio.Task.set_name.__name__.__eq__('set_name') == True — set_name() sets the Task's name; Task-specific, not present on asyncio.Future; __name__ is 'set_name' (8 chars: s-e-t-_-n-a-m-e); str.__eq__('set_name') returns True; new to asyncio_extra182"]
    - [set_name_name_len_8,
       Task.set_name.__name__.__len__,
       [],
       8,
       "asyncio.Task.set_name.__name__.__len__() == 8 — 'set_name' has 8 characters: s-e-t-_-n-a-m-e; equal in length to get_name; str.__len__() returns 8; new to asyncio_extra182"]
    - [get_name_eq_set_name_len,
       Task.get_name.__name__.__len__,
       [],
       8,
       "asyncio.Task.get_name.__name__.__len__() == asyncio.Task.set_name.__name__.__len__() == 8 — get_name and set_name are symmetric partners, both 8 characters; str.__len__() returns 8; new to asyncio_extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra182
# ---------------------------------------------------------------------------

invariant asyncio_extra182.cancel_name_eq:
  description: "asyncio.Task.cancel.__name__ == 'cancel' — requests Task cancellation via CancelledError; len=6; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.cancel.__name__.__eq__
  args: ["cancel"]
  expected: true

invariant asyncio_extra182.done_name_eq:
  description: "asyncio.Task.done.__name__ == 'done' — returns True if the Task is finished; shortest method name len=4; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.done.__name__.__eq__
  args: ["done"]
  expected: true

invariant asyncio_extra182.result_name_eq:
  description: "asyncio.Task.result.__name__ == 'result' — returns the Task result or raises; len=6; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.result.__name__.__eq__
  args: ["result"]
  expected: true

invariant asyncio_extra182.exception_name_eq:
  description: "asyncio.Task.exception.__name__ == 'exception' — returns the exception that caused Task failure; len=9; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.exception.__name__.__eq__
  args: ["exception"]
  expected: true

invariant asyncio_extra182.add_done_callback_name_eq:
  description: "asyncio.Task.add_done_callback.__name__ == 'add_done_callback' — registers a completion callback; len=17; inherited from asyncio.Future; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.add_done_callback.__name__.__eq__
  args: ["add_done_callback"]
  expected: true

invariant asyncio_extra182.remove_done_callback_name_eq:
  description: "asyncio.Task.remove_done_callback.__name__ == 'remove_done_callback' — removes a completion callback; len=20; longest method name in spec; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.remove_done_callback.__name__.__eq__
  args: ["remove_done_callback"]
  expected: true

invariant asyncio_extra182.get_name_name_eq:
  description: "asyncio.Task.get_name.__name__ == 'get_name' — returns the Task name string; len=8; Task-specific, not on Future; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.get_name.__name__.__eq__
  args: ["get_name"]
  expected: true

invariant asyncio_extra182.set_name_name_eq:
  description: "asyncio.Task.set_name.__name__ == 'set_name' — sets the Task name string; len=8; Task-specific, not on Future; new to asyncio_extra182"
  category: identity
  kind: python_call_eq
  function: Task.set_name.__name__.__eq__
  args: ["set_name"]
  expected: true
