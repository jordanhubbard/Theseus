spec: pathlib_extra2191
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "pathlib.PurePath is the abstract base for all path classes; its __dict__ does NOT define any context manager, lock, or wrapper protocol methods."
    - "pathlib.Path (concrete path) does NOT define __enter__ or __exit__ in its own __dict__ as of Python 3.12+. Prior to 3.12 Path was a context manager that deprecated open-then-close usage; that support was removed."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath inherit from PurePath and add no context manager methods to their own __dict__."
    - "pathlib.PosixPath inherits from Path and adds no context manager methods to its own __dict__."
    - "No pathlib class defines __aenter__, __aexit__, acquire, release, __wrapped__, or __closure__ in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2191.purepath_context_protocol:
  description: "pathlib.PurePath dict-presence checks for context manager and lock protocol keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2191

  columns: [id, function, args, expected]
  rows:
    - ["pl2191001", "pathlib.PurePath.__dict__.__contains__", ["__enter__"], false]
    - ["pl2191002", "pathlib.PurePath.__dict__.__contains__", ["__exit__"], false]
    - ["pl2191003", "pathlib.PurePath.__dict__.__contains__", ["__aenter__"], false]
    - ["pl2191004", "pathlib.PurePath.__dict__.__contains__", ["__aexit__"], false]
    - ["pl2191005", "pathlib.PurePath.__dict__.__contains__", ["acquire"], false]
    - ["pl2191006", "pathlib.PurePath.__dict__.__contains__", ["release"], false]
    - ["pl2191007", "pathlib.PurePath.__dict__.__contains__", ["__wrapped__"], false]
    - ["pl2191008", "pathlib.PurePath.__dict__.__contains__", ["__closure__"], false]

