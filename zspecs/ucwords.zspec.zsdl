spec: ucwords
version: ">=1.0.5"
backend: node(ucwords)

docs: https://www.npmjs.com/package/ucwords

provenance:
  derived_from:
    - "ucwords README — https://www.npmjs.com/package/ucwords"
    - "Test vectors verified with ucwords via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "ucwords source"
  notes:
    - "ucwords is an npm package. Install: npm install ucwords"
    - "Capitalizes the first letter of each word in a string (PHP ucwords equivalent)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ucwords.convert:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: ucw

  columns: [id, args, expected]
  rows:
    - [simple,   ["hello world"],  "Hello World"]
    - [multi,    ["foo bar baz"],  "Foo Bar Baz"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:01:06Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
