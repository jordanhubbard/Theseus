spec: sqlite3_extra18
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra17.zspec.zsdl."
    - "sqlite3_extra17 covers: register_adapter/__module__; register_converter/__module__; enable_callback_tracebacks/__module__; paramstyle/__class__.__name__; apilevel/__class__.__name__; threadsafety/__class__.__name__; sqlite_version_info/__class__.__name__."
    - "sqlite3_extra14 covers: Cursor/Connection/Row __qualname__ values; connect/__qualname__."
    - "sqlite3_extra5 covers: Error/__qualname__; OperationalError/__qualname__."
    - "Focus: __qualname__.__class__.__name__ type axis for Connection, Cursor, Row, Error, OperationalError, connect; and __class__.__qualname__ type axis for sqlite_version and sqlite_version_info."
    - "No prior sqlite3 spec checks __qualname__.__class__.__name__ for any class or function."
    - "No prior sqlite3 spec checks sqlite_version.__class__.__qualname__ or sqlite_version_info.__class__.__qualname__."
    - "sqlite3.Connection.__qualname__.__class__.__name__ == 'str' — qualname is always a string; no prior spec checks this axis."
    - "sqlite3.Cursor.__qualname__.__class__.__name__ == 'str' — qualname is always a string."
    - "sqlite3.Row.__qualname__.__class__.__name__ == 'str' — qualname is always a string."
    - "sqlite3.Error.__qualname__.__class__.__name__ == 'str' — qualname is always a string."
    - "sqlite3.OperationalError.__qualname__.__class__.__name__ == 'str' — qualname is always a string."
    - "sqlite3.connect.__qualname__.__class__.__name__ == 'str' — qualname of builtin_function_or_method is still a str."
    - "sqlite3.sqlite_version.__class__.__qualname__ == 'str' — class object's qualname for the str type."
    - "sqlite3.sqlite_version_info.__class__.__qualname__ == 'tuple' — class object's qualname for the tuple type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__.__class__.__name__ — type of the qualname string
#
# sqlite3_extra14 checks __qualname__ values for Connection, Cursor, Row.
# sqlite3_extra5 checks __qualname__ for Error and OperationalError.
# No prior sqlite3 spec checks __qualname__.__class__.__name__ for any class.
# All qualname attributes are plain str objects.
# ---------------------------------------------------------------------------

table sqlite3_extra18.class_qualname_type:
  description: "sqlite3 classes — __qualname__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_attrs
  id_prefix: sqt18

  columns: [id, function, args, expected]
  rows:
    - [Connection_qn_type,      Connection.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [Cursor_qn_type,          Cursor.__qualname__.__class__.__name__.__eq__,          ["str"], true]
    - [Row_qn_type,             Row.__qualname__.__class__.__name__.__eq__,             ["str"], true]
    - [Error_qn_type,           Error.__qualname__.__class__.__name__.__eq__,           ["str"], true]
    - [OperationalError_qn_type, OperationalError.__qualname__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# sqlite3.connect.__qualname__.__class__.__name__
#
# sqlite3_extra14 checks connect.__qualname__ == 'connect'. No prior spec
# checks the type of the qualname attribute for connect. Even for a
# builtin_function_or_method, __qualname__ is a plain str.
# ---------------------------------------------------------------------------

invariant sqlite3_extra18.connect.qualname_type:
  description: "sqlite3.connect.__qualname__.__class__.__name__ == 'str' — qualname of builtin function is a string"
  category: function_attrs
  kind: python_call_eq
  function: connect.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.sqlite_version and sqlite_version_info — __class__.__qualname__
#
# sqlite3_extra17 checks sqlite_version_info.__class__.__name__ == 'tuple'.
# sqlite3_extra15 checks sqlite_version.__class__.__name__ == 'str'.
# No prior spec checks __class__.__qualname__ for either attribute.
# For built-in types, __qualname__ == __name__ == the simple type name.
# ---------------------------------------------------------------------------

invariant sqlite3_extra18.sqlite_version.class_qualname:
  description: "sqlite3.sqlite_version.__class__.__qualname__ == 'str' — version string's type qualname"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra18.sqlite_version_info.class_qualname:
  description: "sqlite3.sqlite_version_info.__class__.__qualname__ == 'tuple' — version tuple's type qualname"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version_info.__class__.__qualname__.__eq__
  args: ["tuple"]
  expected: true
