spec: uuid_extra55
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra54.zspec.zsdl — covers uuid4.__defaults__.__class__.__name__.__eq__('NoneType') / uuid1.__defaults__.__class__.__name__.__eq__('tuple') / uuid4.__code__.__class__.__name__.__eq__('code') / uuid1.__code__.__class__.__name__.__eq__('code') / UUID.__doc__.__contains__('bytes') / uuid4.__closure__.__class__.__name__.__eq__('NoneType') (table + invariants)."
    - "uuid_extra53.zspec.zsdl — covers uuid4/uuid1/uuid3/uuid5 __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / uuid4.__globals__.__class__.__name__.__eq__('dict') / uuid4.__globals__.__contains__('UUID') / UUID.__doc__.__contains__('UUID') (table + invariants)."
    - "uuid_extra52.zspec.zsdl — covers UUID.__setattr__/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__.__eq__ string values (table + invariants)."
    - "uuid_extra51.zspec.zsdl — covers uuid.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / UUID.__ne__.__qualname__.__eq__('object.__ne__') (table + invariants)."
    - "uuid_extra50.zspec.zsdl — covers uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version .fget.__qualname__.__eq__."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values for time/node/clock_seq/time_hi_version/clock_seq_hi_variant."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__.__qualname__.__eq__ and __qualname__.__len__()."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra54; it does NOT duplicate invariants present in those files."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension types."
    - "uuid4.__code__.co_name == 'uuid4' — uuid4 is defined in Lib/uuid.py as 'def uuid4():'. The code object co_name matches the function definition name exactly. No prior uuid spec checks uuid4.__code__.co_name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_name == 'uuid1' — uuid1 is defined in Lib/uuid.py as 'def uuid1(node=None, clock_seq=None):'. The code object co_name matches the function definition name exactly. No prior uuid spec checks uuid1.__code__.co_name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__code__.co_argcount == 0 — uuid4() takes no arguments. co_argcount counts positional-or-keyword parameters, which is 0 for uuid4. No prior uuid spec checks uuid4.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_argcount == 2 — uuid1(node=None, clock_seq=None) has two positional-with-default parameters. co_argcount counts positional-or-keyword parameters including those with defaults, so co_argcount is 2. No prior uuid spec checks uuid1.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__ contains 'hex' — the UUID class docstring describes the constructor keyword arguments including 'hex' (as in UUID(hex=...)). uuid_extra54 checks __contains__('bytes') (wave 229). uuid_extra53 checks __contains__('UUID') (wave 228). This spec checks 'hex', a different keyword not yet covered in any prior uuid spec. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__ contains 'int' — the UUID class docstring describes the constructor keyword arguments including 'int' (as in UUID(int=...)). uuid_extra41 checks UUID.int property fget __qualname__ (property axis, not docstring content). No prior uuid spec checks UUID.__doc__.__contains__('int') (docstring content axis). These are orthogonal checks. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__.co_name deep chain
#
# Wave 230 theme: __code__ deep chains for Python functions.
#
# uuid4 and uuid1 are pure Python functions in Lib/uuid.py. Their code
# objects have co_name matching the function definition names exactly:
# 'uuid4' and 'uuid1'. No prior uuid spec checks __code__.co_name for any
# uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra55.uuid_func_code_co_name:
  description: "uuid4.__code__.co_name.__eq__('uuid4') and uuid1.__code__.co_name.__eq__('uuid1') — both are pure Python functions in Lib/uuid.py whose co_name matches the definition name exactly; no prior uuid spec checks __code__.co_name for any uuid function; first co_name anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode2_55

  columns: [id, function, args, expected]
  rows:
    - [uuid4_code_co_name_eq, uuid4.__code__.co_name.__eq__, ["uuid4"], true]
    - [uuid1_code_co_name_eq, uuid1.__code__.co_name.__eq__, ["uuid1"], true]

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__.co_argcount deep chain
#
# Wave 230 theme: __code__ deep chains for Python functions.
#
# uuid4() takes no arguments — co_argcount is 0.
# uuid1(node=None, clock_seq=None) has two positional-with-default parameters
# — co_argcount is 2. co_argcount counts positional-or-keyword parameters
# (with or without defaults), not varargs or keyword-only parameters.
#
# No prior uuid spec checks __code__.co_argcount for any uuid function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra55.uuid_func_code_co_argcount:
  description: "uuid4.__code__.co_argcount==0 and uuid1.__code__.co_argcount==2 — uuid4() takes no arguments so co_argcount is 0; uuid1(node=None, clock_seq=None) has 2 positional-with-default params so co_argcount is 2; no prior uuid spec checks __code__.co_argcount for any uuid function; first co_argcount anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode2_55

  columns: [id, function, args, expected]
  rows:
    - [uuid4_code_co_argcount_eq, uuid4.__code__.co_argcount.__eq__, [0], true]
    - [uuid1_code_co_argcount_eq, uuid1.__code__.co_argcount.__eq__, [2], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__ content checks — 'hex' and 'int'
#
# Wave 230 theme: docstring content checks.
#
# uuid.UUID.__doc__ is a multi-line docstring listing the constructor keyword
# arguments: int, bytes, bytes_le, fields, str, hex. uuid_extra53 checks
# __contains__('UUID') (wave 228). uuid_extra54 checks __contains__('bytes')
# (wave 229). This spec checks 'hex' and 'int', two additional keywords
# present in the docstring that have not been checked in any prior uuid spec.
# uuid_extra41 checks UUID.int property fget __qualname__ (property axis,
# orthogonal to docstring content). Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table uuid_extra55.UUID_doc_contains_hex_int:
  description: "uuid.UUID.__doc__.__contains__('hex') and __contains__('int') — UUID class docstring lists 'hex' and 'int' as constructor keyword arguments (UUID(hex=...) and UUID(int=...)); uuid_extra53 checks __contains__('UUID') (wave 228); uuid_extra54 checks __contains__('bytes') (wave 229); uuid_extra41 checks UUID.int property fget __qualname__ (property axis, not docstring content); no prior uuid spec checks UUID.__doc__.__contains__('hex') or __contains__('int')"
  kind: python_call_eq
  category: docstrings
  id_prefix: uuidcode2_55

  columns: [id, function, args, expected]
  rows:
    - [UUID_doc_contains_hex, "UUID.__doc__.__contains__", ["hex"], true]
    - [UUID_doc_contains_int, "UUID.__doc__.__contains__", ["int"], true]

# ---------------------------------------------------------------------------
# uuid4.__code__.co_name.__eq__('uuid4') — standalone
#
# uuid4 is defined in Lib/uuid.py as 'def uuid4():'. The code object's
# co_name captures the function definition name, which is 'uuid4'. This
# confirms that uuid4 is not an alias or renamed function — the definition
# name matches the attribute name. uuid_extra54 checks
# uuid4.__code__.__class__.__name__.__eq__('code') (code object class identity
# axis). No prior uuid spec checks uuid4.__code__.co_name in any form. First
# co_name anchor for any uuid function. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra55.uuid4_code_co_name_uuid4:
  description: "uuid.uuid4.__code__.co_name.__eq__('uuid4') == True — uuid4 is defined as 'def uuid4():' in Lib/uuid.py; co_name matches the definition name exactly; uuid_extra54 checks uuid4.__code__.__class__.__name__.__eq__('code') (code class identity axis); no prior uuid spec checks uuid4.__code__.co_name; first co_name anchor for any uuid function"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_name.__eq__
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4.__code__.co_argcount.__eq__(0) — standalone
#
# uuid4() takes no arguments at all — no positional, no keyword, no defaults.
# co_argcount == 0. This complements uuid_extra54's check on
# uuid4.__code__.__class__.__name__.__eq__('code') (class identity axis) by
# adding a co_argcount axis. No prior uuid spec checks uuid4.__code__.co_argcount.
# First co_argcount anchor for any uuid function. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra55.uuid4_code_co_argcount_zero:
  description: "uuid.uuid4.__code__.co_argcount.__eq__(0) == True — uuid4() takes no arguments so co_argcount is 0; uuid_extra54 checks uuid4.__code__.__class__.__name__.__eq__('code') (class identity axis); no prior uuid spec checks uuid4.__code__.co_argcount; first co_argcount anchor for any uuid function"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_argcount.__eq__
  args: [0]
  expected: true
