spec: hashlib_extra121
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra120.zspec.zsdl — covers sha3_256/sha3_512 module/class identity and cross-equality (table + invariants)."
    - "hashlib_extra119.zspec.zsdl — covers hashlib.md5 and hashlib.sha1 __name__/__qualname__/__module__/__class__.__name__ equality and lengths (table + invariants)."
    - "hashlib_extra111.zspec.zsdl — covers blake2b.__class__.__name__.__eq__('type') and blake2b.__module__.__eq__('_blake2') in a table (Wave 277); extra50 covers blake2b.__class__.__module__.__eq__('builtins'); extra28 covers blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__; extra6 covers __module__.__eq__('_blake2'); extra4 covers blake2s.__class__.__name__.__eq__('type') and blake2s.__class__.__module__.__eq__('builtins')."
    - "hashlib_extra99.zspec.zsdl — covers blake2b/blake2s __name__/__qualname__ lengths and blake2b.__module__.__len__()==7."
    - "hashlib_extra4.zspec.zsdl — covers blake2s.__class__.__name__.__eq__('type') and blake2s.__class__.__module__.__eq__('builtins')."
  notes:
    - "This spec extends hashlib through hashlib_extra120; it does NOT duplicate invariants present in those files."
    - "Wave 278 theme: hashlib.blake2b and hashlib.blake2s class identity not yet covered — __class__.__name__.__len__(), __class__.__module__.__len__(), cross-equality for module and class name between blake2b and blake2s, blake2s.__module__.__len__()==7 standalone. Prior specs anchor the equality values but NOT the length of 'type' (4) or 'builtins' (8) for blake2b/blake2s specifically."
    - "hashlib.blake2b.__class__.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__module__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__module__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__.__eq__(hashlib.blake2s.__module__) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__name__.__eq__(hashlib.blake2s.__class__.__name__) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__module__.__eq__(hashlib.blake2s.__class__.__module__) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__name__ == 'type' (4 chars). blake2b and blake2s are C extension types from the _blake2 module; their metaclass is the built-in 'type'. This contrasts with sha256/sha3_256 which are builtin_function_or_method (26 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__module__ == 'builtins' (8 chars). The metaclass 'type' has its __module__ set to 'builtins'. This is the same value as sha3_256.__class__.__module__ (anchored in extra120), but the TYPE of blake2b is 'type' rather than 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2' (7 chars). blake2b and blake2s share the same module, distinct from sha256/sha3_256 which use '_hashlib'. No prior spec anchors blake2b/blake2s cross-module equality. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__len__() == 4
# hashlib.blake2s.__class__.__name__.__len__() == 4
# hashlib.blake2b.__class__.__module__.__len__() == 8
# hashlib.blake2s.__class__.__module__.__len__() == 8
# hashlib.blake2b.__module__.__eq__(hashlib.blake2s.__module__) == True
#
# Wave 278 theme: blake2b and blake2s metaclass name and module lengths.
#
# 'type' is 4 chars — the shortest Python metaclass name. 'builtins' is 8 chars.
# blake2b and blake2s are C extension types (not builtin functions); their metaclass
# is the built-in 'type' (4 chars) whose __module__ is 'builtins' (8 chars). Prior
# specs anchor __class__.__name__=='type' and __class__.__module__=='builtins' as
# equality checks, but no prior spec anchors len('type')==4 or len('builtins')==8
# for blake2b/blake2s class attributes as a grouped table. Their __module__ equality
# (both '_blake2') is also not yet anchored as a grouped table. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlib_extra121.blake2_metaclass_lengths_and_cross_equality:
  description: "blake2b.__class__.__name__.__len__()==4 / blake2s.__class__.__name__.__len__()==4 / blake2b.__class__.__module__.__len__()==8 / blake2s.__class__.__module__.__len__()==8 / blake2b.__module__.__eq__('_blake2')==True — 'type'=4 chars (metaclass of C extension types; minimal metaclass name); 'builtins'=8 chars (module of the built-in type metaclass); blake2b and blake2s share the same _blake2 module; prior specs anchor equality values but not these lengths; first hashlibblake121 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake121

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_class_name_len,   "blake2b.__class__.__name__.__len__",   [], 4, "blake2b.__class__.__name__.__len__() is 4 (len('type')==4; metaclass of C extension types)"]
    - [blake2s_class_name_len,   "blake2s.__class__.__name__.__len__",   [], 4, "blake2s.__class__.__name__.__len__() is 4 (same as blake2b; both are C extension types with metaclass 'type')"]
    - [blake2b_class_mod_len,    "blake2b.__class__.__module__.__len__", [], 8, "blake2b.__class__.__module__.__len__() is 8 (len('builtins')==8; the built-in type metaclass lives in builtins)"]
    - [blake2s_class_mod_len,    "blake2s.__class__.__module__.__len__", [], 8, "blake2s.__class__.__module__.__len__() is 8 (same as blake2b; 'builtins' is 8 chars)"]
    - [blake2b_module_eq,        "blake2b.__module__.__eq__",            ["_blake2"], true, "blake2b.__module__ is '_blake2' (BLAKE2-specific C extension; distinct from '_hashlib' used by sha256/sha3_256)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__eq__(hashlib.blake2s.__class__.__name__) == True
# hashlib.blake2b.__class__.__module__.__eq__(hashlib.blake2s.__class__.__module__) == True
# hashlib.blake2s.__module__.__eq__('_blake2') == True
# hashlib.blake2s.__class__.__name__.__eq__('type') == True
# hashlib.blake2s.__class__.__module__.__eq__('builtins') == True
#
# Wave 278 theme: blake2b and blake2s cross-equality for class name and module.
#
# blake2b and blake2s are both C extension types from the _blake2 module. Their
# __class__.__name__ is 'type' for both (they are instances of the 'type' metaclass).
# Their __class__.__module__ is 'builtins' for both (the 'type' metaclass lives in
# builtins). Cross-equality between blake2b.__class__.__name__ and blake2s.__class__
# .__name__ is not yet anchored as a grouped table. Their shared _blake2 module is
# not yet anchored in a cross-equality group. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table hashlib_extra121.blake2b_blake2s_cross_equality:
  description: "blake2b.__class__.__name__.__eq__(blake2s.__class__.__name__)==True (both 'type') / blake2b.__class__.__module__.__eq__(blake2s.__class__.__module__)==True (both 'builtins') / blake2s.__module__.__eq__('_blake2')==True / blake2s.__class__.__name__.__eq__('type')==True / blake2s.__class__.__module__.__eq__('builtins')==True — blake2b and blake2s share identical class identity (both C extension types from _blake2 with metaclass 'type'); cross-equality not yet in grouped table; first hashlibblake121 anchor for cross-equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake121

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_class_eq_blake2s,   "blake2b.__class__.__name__.__eq__",   ["type"],    true, "blake2b.__class__.__name__ is 'type' (C extension type metaclass; cross-check with blake2s)"]
    - [blake2b_cls_mod_eq_builtins,"blake2b.__class__.__module__.__eq__", ["builtins"],true, "blake2b.__class__.__module__ is 'builtins' (the 'type' metaclass lives in builtins; cross-check with blake2s)"]
    - [blake2s_module_eq,          "blake2s.__module__.__eq__",           ["_blake2"], true, "blake2s.__module__ is '_blake2' (same BLAKE2 C extension as blake2b; distinct from _hashlib)"]
    - [blake2s_class_name_eq,      "blake2s.__class__.__name__.__eq__",   ["type"],    true, "blake2s.__class__.__name__ is 'type' (same metaclass as blake2b; both are C extension type objects)"]
    - [blake2s_class_mod_eq,       "blake2s.__class__.__module__.__eq__", ["builtins"],true, "blake2s.__class__.__module__ is 'builtins' (same as blake2b; 'type' metaclass module is 'builtins')"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') == True
# hashlib.blake2s.__name__.__eq__('blake2s') == True
# hashlib.blake2b.__qualname__.__len__() == 7
# hashlib.blake2s.__qualname__.__len__() == 7
# hashlib.blake2b.__class__.__name__.__len__() == 4
#
# Wave 278 theme: blake2b and blake2s name equality with class name length.
#
# blake2b.__name__=='blake2b' and blake2s.__name__=='blake2s' are separately anchored
# in extra6/extra28/etc. but grouping name equality with class name length in one table
# is not yet done. 'type' (4 chars) is the shortest metaclass name in Python — shorter
# than 'builtin_function_or_method' (26 chars) used for OpenSSL-backed hash constructors.
# Pairing name equality with class name length highlights the blake2b/blake2s identity
# distinction from OpenSSL-backed constructors. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table hashlib_extra121.blake2_name_and_class_name_length:
  description: "blake2b.__name__.__eq__('blake2b')==True / blake2s.__name__.__eq__('blake2s')==True / blake2b.__qualname__.__len__()==7 / blake2s.__qualname__.__len__()==7 / blake2b.__class__.__name__.__len__()==4 — 'blake2b' and 'blake2s' are 7-char names (no 'openssl_' prefix unlike sha3 functions); metaclass 'type' name is 4 chars (much shorter than 'builtin_function_or_method'=26); this grouping not yet in a single table; first hashlibblake121 anchor for name+class-len group"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake121

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_eq,          "blake2b.__name__.__eq__",          ["blake2b"], true, "blake2b.__name__ is 'blake2b' (7 chars; no 'openssl_' prefix; BLAKE2b = 512-bit variant of BLAKE2)"]
    - [blake2s_name_eq,          "blake2s.__name__.__eq__",          ["blake2s"], true, "blake2s.__name__ is 'blake2s' (7 chars; no 'openssl_' prefix; BLAKE2s = 256-bit variant of BLAKE2)"]
    - [blake2b_qualname_len,     "blake2b.__qualname__.__len__",     [],          7,    "blake2b.__qualname__.__len__() is 7 (len('blake2b')==7; __qualname__==__name__ for top-level C types)"]
    - [blake2s_qualname_len,     "blake2s.__qualname__.__len__",     [],          7,    "blake2s.__qualname__.__len__() is 7 (len('blake2s')==7; same as blake2b; both are top-level C types)"]
    - [blake2b_class_name_len2,  "blake2b.__class__.__name__.__len__",[], 4,           "blake2b.__class__.__name__.__len__() is 4 (len('type')==4; far shorter than 'builtin_function_or_method'=26)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__len__() == 4 — standalone
#
# hashlib.blake2b.__class__.__name__.__len__() is 4. 'type' has 4 chars. The
# 'type' metaclass is the smallest type name in Python's runtime — it is the
# base of all class creation in CPython. blake2b is a C extension type object
# (not a function), so its __class__ is 'type'. This contrasts with sha256,
# sha3_256, md5, and sha1 which are builtin_function_or_method objects (26 chars).
# The key distinction: blake2b() calls type.__call__; sha256() calls
# builtin_function_or_method.__call__. No prior spec anchors blake2b
# __class__.__name__.__len__() as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra121.blake2b_class_name_len_4:
  description: "hashlib.blake2b.__class__.__name__.__len__() == 4 — len('type')==4 (the shortest metaclass name; base of all class creation; blake2b is a C extension type so its class is 'type'; contrasts with sha256.__class__.__name__=='builtin_function_or_method'=26 chars); no prior spec anchors blake2b class name length as standalone; first standalone under hashlibblake121"
  category: type_identity
  kind: python_call_eq
  function: blake2b.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# hashlib.blake2s.__class__.__name__.__len__() == 4 — standalone
#
# hashlib.blake2s.__class__.__name__.__len__() is 4. blake2s (BLAKE2s, the 256-bit
# variant) is a C extension type from the _blake2 module, just like blake2b
# (BLAKE2b, the 512-bit variant). Both have __class__.__name__=='type' (4 chars).
# BLAKE2s is designed for 8- to 32-bit platforms and produces digests up to 256
# bits. BLAKE2b is optimized for 64-bit platforms and produces digests up to 512
# bits. Despite targeting different platforms and output sizes, both use the same
# C type infrastructure in CPython. No prior spec anchors blake2s
# __class__.__name__.__len__() as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra121.blake2s_class_name_len_4:
  description: "hashlib.blake2s.__class__.__name__.__len__() == 4 — len('type')==4 (same metaclass as blake2b; blake2s is 256-bit BLAKE2 variant for 8-to-32-bit platforms; blake2b is 512-bit for 64-bit platforms; both are C extension types from _blake2 with metaclass 'type'); no prior spec anchors blake2s class name length as standalone; first standalone under hashlibblake121"
  category: type_identity
  kind: python_call_eq
  function: blake2s.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__module__.__len__() == 8 — standalone
#
# hashlib.blake2b.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# The 'type' metaclass has its __module__ set to 'builtins' because it is a
# fundamental CPython runtime object defined in Objects/typeobject.c. The module
# name 'builtins' (8 chars) is the same length as '_hashlib' (8 chars), though
# the two names differ entirely: one is the public builtins namespace and the other
# is a private C extension. No prior hashlib spec anchors blake2b.__class__.__module__
# .__len__() as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra121.blake2b_class_module_len_8:
  description: "hashlib.blake2b.__class__.__module__.__len__() == 8 — len('builtins')==8 (the 'type' metaclass __module__ is 'builtins'; fundamental CPython runtime object from Objects/typeobject.c); coincidentally same length as '_hashlib'=8 chars (though entirely different names); no prior spec anchors blake2b class module length as standalone; first standalone under hashlibblake121"
  category: type_identity
  kind: python_call_eq
  function: blake2b.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.blake2s.__class__.__module__.__len__() == 8 — standalone
#
# hashlib.blake2s.__class__.__module__.__len__() is 8. 'builtins' has 8 chars,
# the same as blake2b.__class__.__module__.__len__(). blake2s shares the same
# metaclass ('type') and metaclass module ('builtins') as blake2b. They are
# symmetrically structured C extension types from the _blake2 module. The '_blake2'
# module itself is 7 chars (1 underscore + 'blake2'=6), which is 1 char less than
# 'builtins' (8 chars). No prior spec anchors blake2s.__class__.__module__.__len__()
# as a standalone under hashlibblake121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra121.blake2s_class_module_len_8:
  description: "hashlib.blake2s.__class__.__module__.__len__() == 8 — len('builtins')==8 (same as blake2b; blake2s shares the 'type' metaclass from 'builtins'; '_blake2' module itself is 7 chars vs 'builtins'=8 chars — length differs by 1); no prior spec anchors blake2s class module length as standalone; first standalone under hashlibblake121"
  category: type_identity
  kind: python_call_eq
  function: blake2s.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__(hashlib.blake2s.__module__) == True — standalone
#
# hashlib.blake2b.__module__ and hashlib.blake2s.__module__ are both '_blake2'.
# The BLAKE2 algorithm (RFC 7693, published 2015) provides two variants: BLAKE2b
# (optimized for 64-bit platforms) and BLAKE2s (optimized for 8-to-32-bit platforms).
# CPython groups both in a single C extension module '_blake2' (Modules/_blake2/).
# This contrasts with the SHA family (sha256, sha512, sha3_256, sha3_512) which are
# all in '_hashlib' (via OpenSSL EVP). blake2b.__module__.__eq__(blake2s.__module__)
# is True. No prior spec anchors this cross-equality as a standalone invariant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra121.blake2b_module_eq_blake2s_module:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — both blake2b and blake2s have __module__=='_blake2' (RFC 7693 BLAKE2 algorithm; CPython groups both variants in Modules/_blake2/; contrasts with SHA family in '_hashlib' via OpenSSL EVP); cross-equality blake2b.__module__==blake2s.__module__ follows from both being '_blake2'; no prior spec anchors this cross-equality as standalone; first standalone under hashlibblake121"
  category: function_identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true
