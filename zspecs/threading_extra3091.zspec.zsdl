spec: th3091
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (th3091): __hash__, __eq__, __bool__ dict-presence checks for threading types."
    - "None of the threading types define __hash__, __eq__, or __bool__ in their own __dict__."
    - "threading synchronization types inherit identity-based hash and equality from object; none override them."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3091.hash:
  description: "threading types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3091
  columns: [id, function, args, expected]
  rows:
    - ["th3091001", operator.contains, [threading.Thread.__dict__,           "__hash__"], false]
    - ["th3091002", operator.contains, [type(threading.Lock()).__dict__,     "__hash__"], false]
    - ["th3091003", operator.contains, [type(threading.RLock()).__dict__,    "__hash__"], false]
    - ["th3091004", operator.contains, [threading.Event.__dict__,            "__hash__"], false]
    - ["th3091005", operator.contains, [threading.Condition.__dict__,        "__hash__"], false]
    - ["th3091006", operator.contains, [threading.Semaphore.__dict__,        "__hash__"], false]
    - ["th3091007", operator.contains, [threading.BoundedSemaphore.__dict__, "__hash__"], false]
    - ["th3091008", operator.contains, [threading.Timer.__dict__,            "__hash__"], false]
    - ["th3091009", operator.contains, [threading.Barrier.__dict__,          "__hash__"], false]
    - ["th3091010", operator.contains, [threading.local.__dict__,            "__hash__"], false]

