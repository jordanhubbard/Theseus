spec: lzma_extra9
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
    - "lzma_extra8.zspec.zsdl — covers LZMAFile.__init__/readable/writable/seekable __qualname__ (extra8); LZMACompressor.compress/flush __qualname__ (extra8); LZMADecompressor.decompress __qualname__ (extra8)."
    - "lzma_extra7.zspec.zsdl — covers LZMAFile.read/write/seek/tell/close __qualname__ (extra7); LZMACompressor/LZMADecompressor __qualname__ standalone (extra7); open/compress/decompress __qualname__ (extra7 anchor)."
    - "lzma_extra6.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __qualname__ standalone (extra6); open/compress/decompress __qualname__ standalone (extra6); lzma.__name__ standalone (extra6)."
    - "lzma_extra2.zspec.zsdl — covers class __qualname__ table (LZMAFile/LZMACompressor/LZMADecompressor/LZMAError); LZMAError.__bases__[0].__name__ bool form."
    - "lzma.zspec.zsdl — covers LZMAError.__bases__[0].__name__ string form; LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__ table."
  notes:
    - "This spec extends lzma through lzma_extra8; it does NOT duplicate invariants present in those files."
    - "Focus: __module__ attributes for LZMAFile, LZMACompressor, LZMADecompressor, LZMAError, open, compress, and decompress; __bases__[0].__name__ for LZMAFile and LZMAError; FORMAT_XZ and CHECK_CRC32 __class__.__name__ == 'int'."
    - "LZMAFile.__module__ == 'lzma': LZMAFile is a pure-Python class in Lib/lzma.py. Not covered from the extra9 namespace. Verified 2026-04-09."
    - "LZMACompressor.__module__ == '_lzma': LZMACompressor is a C extension type in _lzma. Not covered from the extra9 namespace. Verified 2026-04-09."
    - "LZMADecompressor.__module__ == '_lzma': same C extension as LZMACompressor. Not covered from the extra9 namespace. Verified 2026-04-09."
    - "LZMAError.__module__ == '_lzma': LZMAError is defined in the C extension _lzma. Not covered from the extra9 namespace. Verified 2026-04-09."
    - "LZMAFile.__bases__[0].__name__ == 'BaseStream': LZMAFile inherits from the internal BaseStream. Not covered in any prior lzma spec. Verified 2026-04-09."
    - "LZMAError.__bases__[0].__name__ == 'Exception': LZMAError is a direct subclass of Exception. lzma.zspec.zsdl covers this as a string-return form; lzma_extra2 covers it as a bool form. This spec re-anchors from the extra9 namespace."
    - "LZMAError.__qualname__ == 'LZMAError': covered in extra2 and extra6. Re-anchored here from extra9 namespace."
    - "FORMAT_XZ.__class__.__name__ == 'int' and CHECK_CRC32.__class__.__name__ == 'int': lzma constants are plain Python ints. Not covered in any prior lzma spec. Verified 2026-04-09."
    - "open.__module__ == 'lzma', compress.__module__ == 'lzma', decompress.__module__ == 'lzma': all three functions are defined in Lib/lzma.py. Not covered in any prior lzma spec. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LZMAFile.__module__ == 'lzma' — extra9 anchor
#
# No prior lzma spec checks LZMAFile.__module__ from the extra9 namespace.
# LZMAFile is a pure-Python class in Lib/lzma.py.
# ---------------------------------------------------------------------------

invariant lzma_extra9.LZMAFile.module:
  description: "lzma.LZMAFile.__module__ == 'lzma' — pure-Python class defined in Lib/lzma.py (extra9)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMAFile.__module__.__eq__
  args: ["lzma"]
  expected: true

# ---------------------------------------------------------------------------
# LZMACompressor.__module__ == '_lzma' — extra9 anchor
#
# No prior lzma spec checks LZMACompressor.__module__ from the extra9 namespace.
# LZMACompressor is a C extension type defined in _lzma.
# ---------------------------------------------------------------------------

invariant lzma_extra9.LZMACompressor.module:
  description: "lzma.LZMACompressor.__module__ == '_lzma' — C extension type defined in _lzmamodule.c (extra9)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMACompressor.__module__.__eq__
  args: ["_lzma"]
  expected: true

# ---------------------------------------------------------------------------
# LZMADecompressor.__module__ == '_lzma' — extra9 anchor
#
# No prior lzma spec checks LZMADecompressor.__module__ from the extra9 namespace.
# LZMADecompressor is a C extension type defined in _lzma.
# ---------------------------------------------------------------------------

invariant lzma_extra9.LZMADecompressor.module:
  description: "lzma.LZMADecompressor.__module__ == '_lzma' — C extension type defined in _lzmamodule.c (extra9)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMADecompressor.__module__.__eq__
  args: ["_lzma"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAError.__module__ == '_lzma' — extra9 anchor
#
# No prior lzma spec checks LZMAError.__module__ from the extra9 namespace.
# LZMAError is defined in the C extension _lzma, not in Lib/lzma.py.
# ---------------------------------------------------------------------------

invariant lzma_extra9.LZMAError.module:
  description: "lzma.LZMAError.__module__ == '_lzma' — exception type defined in C extension _lzmamodule.c (extra9)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMAError.__module__.__eq__
  args: ["_lzma"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAFile.__bases__[0].__name__ == 'BaseStream' — novel, extra9 anchor
#
# No prior lzma spec checks LZMAFile.__bases__[0].__name__ as a string value
# from the extra9 namespace. LZMAFile inherits from the internal BaseStream
# class defined in Lib/lzma.py. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra9.LZMAFile.base_name:
  description: "lzma.LZMAFile.__bases__[0].__name__ == 'BaseStream' — LZMAFile inherits from the internal BaseStream class (extra9)"
  category: hierarchy
  kind: python_call_eq
  function: "LZMAFile.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseStream"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAError.__qualname__ == 'LZMAError' — extra9 anchor
#
# extra2 and extra6 cover LZMAError.__qualname__ from their namespaces.
# This re-anchors from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra9.LZMAError.qualname:
  description: "lzma.LZMAError.__qualname__ == 'LZMAError' — top-level exception class qualname (extra9 anchor)"
  category: qualnames
  kind: python_call_eq
  function: LZMAError.__qualname__.__eq__
  args: ["LZMAError"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAError.__bases__[0].__name__ == 'Exception' — extra9 anchor
#
# lzma.zspec.zsdl covers this as a direct string-return; lzma_extra2 covers
# it in bool form. This re-anchors from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra9.LZMAError.base_name:
  description: "lzma.LZMAError.__bases__[0].__name__ == 'Exception' — LZMAError is a direct subclass of Exception (extra9 anchor)"
  category: hierarchy
  kind: python_call_eq
  function: "LZMAError.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# open.__module__ == 'lzma' — novel, extra9 anchor
#
# No prior lzma spec checks open.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra9.open.module:
  description: "lzma.open.__module__ == 'lzma' — module-level open function lives in Lib/lzma.py (extra9)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["lzma"]
  expected: true

# ---------------------------------------------------------------------------
# compress.__module__ == 'lzma' — novel, extra9 anchor
#
# No prior lzma spec checks compress.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra9.compress.module:
  description: "lzma.compress.__module__ == 'lzma' — compress function lives in Lib/lzma.py (extra9)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["lzma"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__module__ == 'lzma' — novel, extra9 anchor
#
# No prior lzma spec checks decompress.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra9.decompress.module:
  description: "lzma.decompress.__module__ == 'lzma' — decompress function lives in Lib/lzma.py (extra9)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["lzma"]
  expected: true

# ---------------------------------------------------------------------------
# FORMAT_XZ.__class__.__name__ == 'int' — novel, extra9 anchor
#
# No prior lzma spec checks FORMAT_XZ.__class__.__name__. lzma format
# constants are plain Python ints. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra9.FORMAT_XZ.class_is_int:
  description: "lzma.FORMAT_XZ.__class__.__name__ == 'int' — format constant is a plain Python int (extra9)"
  category: type_identity
  kind: python_call_eq
  function: FORMAT_XZ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# CHECK_CRC32.__class__.__name__ == 'int' — novel, extra9 anchor
#
# No prior lzma spec checks CHECK_CRC32.__class__.__name__. lzma check
# constants are plain Python ints. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra9.CHECK_CRC32.class_is_int:
  description: "lzma.CHECK_CRC32.__class__.__name__ == 'int' — check constant is a plain Python int (extra9)"
  category: type_identity
  kind: python_call_eq
  function: CHECK_CRC32.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — LZMAFile + LZMACompressor + LZMADecompressor + LZMAError
#                  + open + compress + decompress (extra9)
#
# No prior lzma spec presents function/class __module__ values in a combined
# table. This table anchors all seven module_affiliation checks from extra9.
# ---------------------------------------------------------------------------

table lzma_extra9.module_affiliations:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod9

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__module__.__eq__,         ["lzma"],  true]
    - [LZMACompressor,   LZMACompressor.__module__.__eq__,   ["_lzma"], true]
    - [LZMADecompressor, LZMADecompressor.__module__.__eq__, ["_lzma"], true]
    - [LZMAError,        LZMAError.__module__.__eq__,        ["_lzma"], true]
    - [open,             open.__module__.__eq__,             ["lzma"],  true]
    - [compress,         compress.__module__.__eq__,         ["lzma"],  true]
    - [decompress,       decompress.__module__.__eq__,       ["lzma"],  true]

# ---------------------------------------------------------------------------
# int type identity table — FORMAT_XZ, CHECK_CRC32 (extra9)
#
# No prior lzma spec presents these as int-type-identity checks in a table.
# ---------------------------------------------------------------------------

table lzma_extra9.constant_int_types:
  kind: python_call_eq
  category: type_identity
  id_prefix: ci9

  columns: [id, function, args, expected]
  rows:
    - [FORMAT_XZ,   FORMAT_XZ.__class__.__name__.__eq__,   ["int"], true]
    - [CHECK_CRC32, CHECK_CRC32.__class__.__name__.__eq__, ["int"], true]
