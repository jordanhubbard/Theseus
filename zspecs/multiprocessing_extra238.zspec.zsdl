    - [imap_name_len,  pool.IMapIterator.__name__.__len__,                  [],                         12,   "multiprocessing.pool.IMapIterator.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [imap_mod_eq,    pool.IMapIterator.__module__.__eq__,                 ["multiprocessing.pool"],   true, "multiprocessing.pool.IMapIterator.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [imap_mod_len,   pool.IMapIterator.__module__.__len__,                [],                         20,   "multiprocessing.pool.IMapIterator.__module__.__len__() == 20; verified with Python 3.14.3"]
    - [imap_base_eq,   "pool.IMapIterator.__bases__[0].__name__.__eq__",    ["object"],                 true, "multiprocessing.pool.IMapIterator.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra238
# ---------------------------------------------------------------------------

invariant multiprocessing_extra238.basecontext_name_eq:
  description: "multiprocessing.context.BaseContext.__name__.__eq__('BaseContext') returns True — the class is named 'BaseContext' (len=11); it lives in multiprocessing.context (len=23); BaseContext.__bases__[0].__name__ == 'object' (root of context hierarchy); SpawnProcess.__name__ == 'SpawnProcess' (len=12, one longer); IMapIterator.__name__ == 'IMapIterator' (len=12, same as SpawnProcess); multiprocessing.Value and multiprocessing.Array are bound methods, not classes; NEW in extra238: first standalone BaseContext name equality invariant in mp238ctx namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: context.BaseContext.__name__.__eq__
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra238.spawnprocess_base_is_baseprocess:
  description: "multiprocessing.context.SpawnProcess.__bases__[0].__name__.__eq__('BaseProcess') returns True — SpawnProcess inherits from BaseProcess (not from BaseContext — the context and process class hierarchies are separate); SpawnProcess is the process class for the 'spawn' start method; SpawnProcess.__module__ == 'multiprocessing.context' (len=23); SpawnProcess.__name__ == 'SpawnProcess' (len=12); BaseContext.__bases__[0].__name__ == 'object' (BaseContext does NOT inherit from BaseProcess); NEW in extra238: first standalone SpawnProcess base invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "context.SpawnProcess.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra238.basecontext_single_base_raises_indexerror:
  description: "multiprocessing.context.BaseContext.__bases__[1] raises IndexError — BaseContext has exactly one direct base class (object); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms single-inheritance: BaseContext -> object; BaseContext.__name__ == 'BaseContext' (len=11); BaseContext.__module__ == 'multiprocessing.context' (len=23); NEW in extra238: first standalone BaseContext single-base IndexError invariant; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "context.BaseContext.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError

invariant multiprocessing_extra238.imapiterator_module_eq:
  description: "multiprocessing.pool.IMapIterator.__module__.__eq__('multiprocessing.pool') returns True — IMapIterator is defined in Lib/multiprocessing/pool.py; __module__ == 'multiprocessing.pool' (len=20); contrast with context classes: BaseContext.__module__ == 'multiprocessing.context' (len=23, longer); IMapIterator.__bases__[0].__name__ == 'object'; IMapIterator.__name__ == 'IMapIterator' (len=12); IMapIterator is the iterator returned by Pool.imap() and Pool.imap_unordered(); NEW in extra238: first standalone IMapIterator module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.IMapIterator.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true
