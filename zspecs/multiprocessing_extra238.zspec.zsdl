# BaseContext.__name__ == 'BaseContext' (len=11)
# BaseContext.__module__ == 'multiprocessing.context' (len=23)
# BaseContext.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table multiprocessing_extra238.basecontext_identity:
  description: "multiprocessing.context.BaseContext class identity — BaseContext.__name__.__eq__('BaseContext')==True (len=11); BaseContext.__module__.__eq__('multiprocessing.context')==True (len=23); BaseContext.__bases__[0].__name__.__eq__('object')==True (BaseContext inherits directly from object — it is the root of the context hierarchy); BaseContext.__name__.__len__()==11; BaseContext.__module__.__len__()==23; contrast: IMapIterator lives in multiprocessing.pool (len=20); SpawnProcess shares multiprocessing.context (len=23) with BaseContext; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp238ctx

  columns: [id, function, args, expected, description]
  rows:
    - [bc_name_eq,   context.BaseContext.__name__.__eq__,                   ["BaseContext"],               true, "multiprocessing.context.BaseContext.__name__ == 'BaseContext'; verified with Python 3.14.3"]
    - [bc_name_len,  context.BaseContext.__name__.__len__,                  [],                            11,   "multiprocessing.context.BaseContext.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [bc_mod_eq,    context.BaseContext.__module__.__eq__,                 ["multiprocessing.context"],   true, "multiprocessing.context.BaseContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [bc_mod_len,   context.BaseContext.__module__.__len__,                [],                            23,   "multiprocessing.context.BaseContext.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [bc_base_eq,   "context.BaseContext.__bases__[0].__name__.__eq__",    ["object"],                    true, "multiprocessing.context.BaseContext.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]

