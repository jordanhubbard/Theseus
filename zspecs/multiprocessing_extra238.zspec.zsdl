spec: multiprocessing_extra238
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#contexts-and-start-methods — Contexts section"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool.imap section"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py (internal implementation)"
    - "CPython source: Lib/multiprocessing/pool.py (internal implementation)"
  notes:
    - "multiprocessing.Value and multiprocessing.Array are bound methods (type(multiprocessing.Value).__name__ == 'method'), not classes directly."
    - "multiprocessing.context.BaseContext.__name__ == 'BaseContext' (len=11); __module__ == 'multiprocessing.context' (len=23); __bases__[0].__name__ == 'object'."
    - "multiprocessing.context.SpawnProcess.__name__ == 'SpawnProcess' (len=12); __module__ == 'multiprocessing.context' (len=23); __bases__[0].__name__ == 'BaseProcess'."
    - "SpawnProcess inherits from BaseProcess (not BaseContext); it represents the process class used by the spawn start method."
    - "multiprocessing.pool.IMapIterator.__name__ == 'IMapIterator' (len=12, same length as SpawnProcess); __module__ == 'multiprocessing.pool' (len=20); __bases__[0].__name__ == 'object'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

