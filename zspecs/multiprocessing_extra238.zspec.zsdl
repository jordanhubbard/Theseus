table multiprocessing_extra238.spawnprocess_identity:
  description: "multiprocessing.context.SpawnProcess class identity — SpawnProcess.__name__.__eq__('SpawnProcess')==True (len=12); SpawnProcess.__module__.__eq__('multiprocessing.context')==True (len=23, same module as BaseContext); SpawnProcess.__bases__[0].__name__.__eq__('BaseProcess')==True (SpawnProcess inherits from BaseProcess, not from BaseContext — it is the process class used when the spawn start method is selected); SpawnProcess.__name__.__len__()==12; contrast: BaseContext.__name__.__len__()==11 (one shorter); IMapIterator.__name__.__len__()==12 (same length as SpawnProcess); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp238sp

  columns: [id, function, args, expected, description]
  rows:
    - [sp_name_eq,   context.SpawnProcess.__name__.__eq__,                  ["SpawnProcess"],              true, "multiprocessing.context.SpawnProcess.__name__ == 'SpawnProcess'; verified with Python 3.14.3"]
    - [sp_name_len,  context.SpawnProcess.__name__.__len__,                 [],                            12,   "multiprocessing.context.SpawnProcess.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [sp_mod_eq,    context.SpawnProcess.__module__.__eq__,                ["multiprocessing.context"],   true, "multiprocessing.context.SpawnProcess.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [sp_mod_len,   context.SpawnProcess.__module__.__len__,               [],                            23,   "multiprocessing.context.SpawnProcess.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [sp_base_eq,   "context.SpawnProcess.__bases__[0].__name__.__eq__",   ["BaseProcess"],               true, "multiprocessing.context.SpawnProcess.__bases__[0].__name__ == 'BaseProcess'; verified with Python 3.14.3"]

