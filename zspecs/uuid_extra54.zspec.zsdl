spec: uuid_extra54
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra53.zspec.zsdl — covers uuid4/uuid1/uuid3/uuid5 __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / uuid4.__globals__.__class__.__name__.__eq__('dict') / uuid4.__globals__.__contains__('UUID') / UUID.__doc__.__contains__('UUID') (table + invariants)."
    - "uuid_extra52.zspec.zsdl — covers UUID.__setattr__/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__.__eq__ string values (table + invariants)."
    - "uuid_extra51.zspec.zsdl — covers uuid.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / UUID.__ne__.__qualname__.__eq__('object.__ne__') (table + invariants)."
    - "uuid_extra50.zspec.zsdl — covers uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version .fget.__qualname__.__eq__."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values for time/node/clock_seq/time_hi_version/clock_seq_hi_variant."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__.__qualname__.__eq__ and __qualname__.__len__()."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra53; it does NOT duplicate invariants present in those files."
    - "Wave 229 theme: __defaults__ and __code__ checks for Python functions + __doc__ content checks."
    - "uuid4() takes no arguments and has no defaults — uuid4.__defaults__ is None (NoneType). uuid4.__defaults__.__class__.__name__ == 'NoneType'. No prior uuid spec checks uuid4.__defaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1(node=None, clock_seq=None) has two keyword-defaulted positional parameters — uuid1.__defaults__ is (None, None), a tuple of length 2. uuid1.__defaults__.__class__.__name__ == 'tuple'. No prior uuid spec checks uuid1.__defaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__code__ and uuid1.__code__ are Python code objects (type name 'code'). Both uuid4 and uuid1 are pure Python functions in Lib/uuid.py with bytecode. No prior uuid spec checks __code__.__class__.__name__.__eq__('code') for any uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__ is a multi-line docstring. It contains the word 'bytes' — the UUID constructor accepts a 'bytes' keyword argument (one of int/bytes/bytes_le/fields/str). uuid_extra53 checks UUID.__doc__.__contains__('UUID') (wave 228). This spec checks __contains__('bytes'), a different keyword not yet checked in any prior uuid spec. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__closure__ is None (NoneType). uuid4 is not a closure — it does not capture any variables from an enclosing scope. uuid4.__closure__.__class__.__name__ == 'NoneType'. No prior uuid spec checks uuid4.__closure__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __defaults__ class identity
#
# Wave 229 theme: __defaults__ checks for Python functions.
#
# uuid4() takes no arguments — __defaults__ is None (NoneType).
# uuid1(node=None, clock_seq=None) has two defaults — __defaults__ is a tuple.
#
# No prior uuid spec checks __defaults__.__class__.__name__ for any uuid
# function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra54.uuid_func_defaults_class_name:
  description: "uuid4.__defaults__.__class__.__name__.__eq__('NoneType') and uuid1.__defaults__.__class__.__name__.__eq__('tuple') — uuid4 has no arguments so __defaults__ is None (NoneType); uuid1(node=None, clock_seq=None) has two positional defaults so __defaults__ is a tuple; no prior uuid spec checks __defaults__.__class__.__name__ for any uuid function; first __defaults__ class identity anchor for uuid"
  kind: python_call_eq
  category: defaults
  id_prefix: uuidcode54

  columns: [id, function, args, expected]
  rows:
    - [uuid4_defaults_class_name_eq, uuid4.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [uuid1_defaults_class_name_eq, uuid1.__defaults__.__class__.__name__.__eq__, ["tuple"],    true]

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__ class identity
#
# Wave 229 theme: __code__ checks for Python functions.
#
# uuid4 and uuid1 are pure Python functions in Lib/uuid.py. Both have a
# __code__ attribute that is a Python code object (type name 'code'). No prior
# uuid spec checks __code__.__class__.__name__.__eq__('code') for any uuid
# function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra54.uuid_func_code_class_name:
  description: "uuid4.__code__.__class__.__name__.__eq__('code') and uuid1.__code__.__class__.__name__.__eq__('code') — both are pure Python functions in Lib/uuid.py with code objects; no prior uuid spec checks __code__.__class__.__name__.__eq__('code') for any uuid function; first __code__ class identity anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode54

  columns: [id, function, args, expected]
  rows:
    - [uuid4_code_class_name_eq, uuid4.__code__.__class__.__name__.__eq__, ["code"], true]
    - [uuid1_code_class_name_eq, uuid1.__code__.__class__.__name__.__eq__, ["code"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__ content check — 'bytes'
#
# Wave 229 theme: __doc__ content checks.
#
# uuid.UUID.__doc__ is a multi-line docstring. The UUID constructor accepts
# keyword arguments including 'bytes' (as in UUID(bytes=...)). The word
# 'bytes' appears in the docstring listing the accepted keyword arguments.
# uuid_extra53 checks UUID.__doc__.__contains__('UUID') (wave 228). This spec
# adds the complementary check for 'bytes', a different keyword.
# uuid_extra41 checks UUID.__doc__.__class__.__name__.__eq__('str') (type
# identity axis). No prior uuid spec checks __doc__.__contains__('bytes').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra54.UUID_doc_contains_bytes:
  description: "uuid.UUID.__doc__.__contains__('bytes') — UUID class docstring lists 'bytes' as one of the constructor keyword arguments (UUID(bytes=...)); uuid_extra53 checks __contains__('UUID') (wave 228); uuid_extra41 checks __doc__.__class__.__name__.__eq__('str') (type identity axis); no prior uuid spec checks UUID.__doc__.__contains__('bytes'); complementary doc content check"
  kind: python_call_eq
  category: docstrings
  id_prefix: uuidcode54

  columns: [id, function, args, expected]
  rows:
    - [UUID_doc_contains_bytes, "UUID.__doc__.__contains__", ["bytes"], true]

# ---------------------------------------------------------------------------
# uuid4.__closure__ class identity
#
# Wave 229 theme: __closure__ checks for Python functions.
#
# uuid4 is not a closure — it does not capture variables from an enclosing
# scope. uuid4.__closure__ is None (NoneType). uuid4.__closure__.__class__.__name__
# == 'NoneType'. No prior uuid spec checks uuid4.__closure__ in any form.
# First __closure__ anchor for any uuid function. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra54.uuid4_closure_class_name:
  description: "uuid4.__closure__.__class__.__name__.__eq__('NoneType') — uuid4 is not a closure; __closure__ is None so __class__.__name__ is 'NoneType'; no prior uuid spec checks uuid4.__closure__.__class__.__name__ in any form; first __closure__ class identity anchor for any uuid function"
  kind: python_call_eq
  category: closure
  id_prefix: uuidcode54

  columns: [id, function, args, expected]
  rows:
    - [uuid4_closure_class_name_eq, uuid4.__closure__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# uuid4.__defaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# uuid4() takes no arguments. Its __defaults__ is None (NoneType). The chain
# __defaults__.__class__.__name__.__eq__('NoneType') confirms the None type
# identity. No prior uuid spec checks uuid4.__defaults__ in any form. First
# __defaults__ class identity anchor for any uuid function. Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra54.uuid4_defaults_class_name_nonetype:
  description: "uuid.uuid4.__defaults__.__class__.__name__.__eq__('NoneType') == True — uuid4 takes no arguments so __defaults__ is None; None.__class__.__name__ == 'NoneType'; no prior uuid spec checks uuid4.__defaults__.__class__.__name__; first __defaults__ class identity anchor for any uuid function"
  category: defaults
  kind: python_call_eq
  function: uuid4.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4.__code__.__class__.__name__.__eq__('code') — standalone
#
# uuid4 is a pure Python function in Lib/uuid.py. Its __code__ attribute is a
# Python code object with class name 'code'. No prior uuid spec checks
# uuid4.__code__.__class__.__name__.__eq__('code') in any form. First __code__
# class identity anchor for any uuid function. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra54.uuid4_code_class_name_code:
  description: "uuid.uuid4.__code__.__class__.__name__.__eq__('code') == True — uuid4 is a pure Python function in Lib/uuid.py; __code__ is a Python code object with class name 'code'; no prior uuid spec checks uuid4.__code__.__class__.__name__.__eq__('code'); first __code__ class identity anchor for any uuid function"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true
