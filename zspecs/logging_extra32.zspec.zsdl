spec: logging_extra32
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra31.zspec.zsdl — covers __all__.__len__()==45; level constants DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET/WARN/FATAL values and __class__.__name__.__len__(); Logger/Handler/Formatter/Filter/LogRecord __dict__.__class__.__name__.__len__()==12; getLevelName/getLogger/makeLogRecord/basicConfig __qualname__.__len__()."
    - "logging_extra30.zspec.zsdl — covers Logger/Handler/Formatter/LogRecord __mro__.__len__() and __bases__[0].__name__.__len__(); Logger.debug(12)/Logger.info(11)/Logger.warning(14)/Logger.error(12) __qualname__.__len__(); Handler.emit(12) __qualname__.__len__(); LogRecord.getMessage(20)/LogRecord.__init__(18) __qualname__.__len__(); Formatter.format(16) __qualname__.__len__()."
    - "logging_extra29.zspec.zsdl — covers __module__.__len__()==7 for module-level functions and FileHandler/StreamHandler classes; __name__.__len__() and __qualname__.__len__() for FileHandler/StreamHandler."
    - "logging_extra28.zspec.zsdl — covers __module__.__len__()==7 and __name__.__len__() for Logger/Handler/Formatter/Filter/LogRecord."
  notes:
    - "This spec extends logging_extra31.zspec.zsdl."
    - "This spec covers NEW angles not in any prior spec: Logger.critical/__qualname__.__len__()==15; Logger.exception/__qualname__.__len__()==16; Logger.addHandler/__qualname__.__len__()==17; Logger.setLevel/__qualname__.__len__()==15; Logger.removeHandler/__qualname__.__len__()==20; Logger.hasHandlers/__qualname__.__len__()==18; Handler.format/__qualname__.__len__()==14; Handler.setFormatter/__qualname__.__len__()==20; Handler.handle/__qualname__.__len__()==14; Handler.setLevel/__qualname__.__len__()==16; module-level warning(7)/error(5)/info(4)/debug(5)/critical(8)/exception(9)/log(3) __qualname__.__len__(); StreamHandler.__mro__.__len__()==4 and __bases__[0].__name__.__len__()==7; NullHandler.__mro__.__len__()==4 and __bases__[0].__name__.__len__()==7; FileHandler.__mro__.__len__()==5 and __bases__[0].__name__.__len__()==13; Logger/Handler/Formatter/Filter/LogRecord __qualname__.__len__()."
    - "logging.Logger.critical.__qualname__ == 'Logger.critical' (len 15). Verified Python 3.12."
    - "logging.Logger.exception.__qualname__ == 'Logger.exception' (len 16). Verified Python 3.12."
    - "logging.Logger.addHandler.__qualname__ == 'Logger.addHandler' (len 17). Verified Python 3.12."
    - "logging.Logger.setLevel.__qualname__ == 'Logger.setLevel' (len 15). Verified Python 3.12."
    - "logging.Logger.removeHandler.__qualname__ == 'Logger.removeHandler' (len 20). Verified Python 3.12."
    - "logging.Logger.hasHandlers.__qualname__ == 'Logger.hasHandlers' (len 18). Verified Python 3.12."
    - "logging.Handler.format.__qualname__ == 'Handler.format' (len 14). Verified Python 3.12."
    - "logging.Handler.setFormatter.__qualname__ == 'Handler.setFormatter' (len 20). Verified Python 3.12."
    - "logging.Handler.handle.__qualname__ == 'Handler.handle' (len 14). Verified Python 3.12."
    - "logging.Handler.setLevel.__qualname__ == 'Handler.setLevel' (len 16). Verified Python 3.12."
    - "logging.StreamHandler.__mro__ = [StreamHandler, Handler, Filterer, object] — len 4. __bases__[0].__name__ == 'Handler' (len 7). Verified Python 3.12."
    - "logging.NullHandler.__mro__ = [NullHandler, Handler, Filterer, object] — len 4. __bases__[0].__name__ == 'Handler' (len 7). Verified Python 3.12."
    - "logging.FileHandler.__mro__ = [FileHandler, StreamHandler, Handler, Filterer, object] — len 5. __bases__[0].__name__ == 'StreamHandler' (len 13). Verified Python 3.12."
    - "logging.Logger.__qualname__ == 'Logger' (len 6). logging.Handler.__qualname__ == 'Handler' (len 7). logging.Formatter.__qualname__ == 'Formatter' (len 9). logging.Filter.__qualname__ == 'Filter' (len 6). logging.LogRecord.__qualname__ == 'LogRecord' (len 9). Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Logger method __qualname__.__len__() — critical, exception, addHandler,
# setLevel, removeHandler, hasHandlers
#
# Prior specs covered debug(12)/info(11)/warning(14)/error(12) in extra30.
# This spec adds the remaining commonly-used Logger methods:
#   Logger.critical      -> 'Logger.critical'      -> 15
#   Logger.exception     -> 'Logger.exception'     -> 16
#   Logger.addHandler    -> 'Logger.addHandler'    -> 17
#   Logger.setLevel      -> 'Logger.setLevel'      -> 15
#   Logger.removeHandler -> 'Logger.removeHandler' -> 20
#   Logger.hasHandlers   -> 'Logger.hasHandlers'   -> 18
# ---------------------------------------------------------------------------

table logging_extra32.Logger_method_qualname_lens:
  description: "logging.Logger method __qualname__ lengths — critical (15), exception (16), addHandler (17), setLevel (15), removeHandler (20), hasHandlers (18)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: llm32

  columns: [id, function, args, expected]
  rows:
    - [critical,      Logger.critical.__qualname__.__len__,      [], 15]
    - [exception,     Logger.exception.__qualname__.__len__,     [], 16]
    - [addHandler,    Logger.addHandler.__qualname__.__len__,    [], 17]
    - [setLevel,      Logger.setLevel.__qualname__.__len__,      [], 15]
    - [removeHandler, Logger.removeHandler.__qualname__.__len__, [], 20]
    - [hasHandlers,   Logger.hasHandlers.__qualname__.__len__,   [], 18]

# ---------------------------------------------------------------------------
# Handler method __qualname__.__len__() — format, setFormatter, handle, setLevel
#
# Prior spec covered Handler.emit(12) in extra30.
# This spec adds:
#   Handler.format       -> 'Handler.format'       -> 14
#   Handler.setFormatter -> 'Handler.setFormatter' -> 20
#   Handler.handle       -> 'Handler.handle'       -> 14
#   Handler.setLevel     -> 'Handler.setLevel'     -> 16
# ---------------------------------------------------------------------------

table logging_extra32.Handler_method_qualname_lens:
  description: "logging.Handler method __qualname__ lengths — format (14), setFormatter (20), handle (14), setLevel (16)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: lhm32

  columns: [id, function, args, expected]
  rows:
    - [format,        Handler.format.__qualname__.__len__,       [], 14]
    - [setFormatter,  Handler.setFormatter.__qualname__.__len__, [], 20]
    - [handle,        Handler.handle.__qualname__.__len__,       [], 14]
    - [setLevel,      Handler.setLevel.__qualname__.__len__,     [], 16]

# ---------------------------------------------------------------------------
# Module-level function __qualname__.__len__()
#
# All prior specs covered getLevelName(12)/getLogger(9)/makeLogRecord(13)/basicConfig(11)
# in extra31. This spec covers the remaining module-level convenience functions:
#   warning   -> 'warning'   -> 7
#   error     -> 'error'     -> 5
#   info      -> 'info'      -> 4
#   debug     -> 'debug'     -> 5
#   critical  -> 'critical'  -> 8
#   exception -> 'exception' -> 9
#   log       -> 'log'       -> 3
# ---------------------------------------------------------------------------

table logging_extra32.module_level_qualname_lens:
  description: "logging module-level convenience function __qualname__ lengths — warning (7), error (5), info (4), debug (5), critical (8), exception (9), log (3)"
  kind: python_call_eq
  category: function_identity
  id_prefix: lml32

  columns: [id, function, args, expected]
  rows:
    - [warning_ql,   warning.__qualname__.__len__,   [], 7]
    - [error_ql,     error.__qualname__.__len__,     [], 5]
    - [info_ql,      info.__qualname__.__len__,      [], 4]
    - [debug_ql,     debug.__qualname__.__len__,     [], 5]
    - [critical_ql,  critical.__qualname__.__len__,  [], 8]
    - [exception_ql, exception.__qualname__.__len__, [], 9]
    - [log_ql,       log.__qualname__.__len__,       [], 3]

# ---------------------------------------------------------------------------
# StreamHandler and NullHandler __mro__.__len__() and __bases__[0].__name__.__len__()
#
# StreamHandler -> Handler -> Filterer -> object — MRO len 4; base 'Handler' (len 7).
# NullHandler   -> Handler -> Filterer -> object — MRO len 4; base 'Handler' (len 7).
# No prior logging spec checks __mro__.__len__() or __bases__[0].__name__.__len__()
# for StreamHandler or NullHandler.
# ---------------------------------------------------------------------------

invariant logging_extra32.StreamHandler.mro_len:
  description: "logging.StreamHandler.__mro__.__len__() == 4 — MRO: [StreamHandler, Handler, Filterer, object]"
  category: class_introspection
  kind: python_call_eq
  function: StreamHandler.__mro__.__len__
  args: []
  expected: 4

invariant logging_extra32.StreamHandler.bases_name_len:
  description: "logging.StreamHandler.__bases__[0].__name__.__len__() == 7 — base class is 'Handler'"
  category: class_introspection
  kind: python_call_eq
  function: "StreamHandler.__bases__[0].__name__.__len__"
  args: []
  expected: 7

invariant logging_extra32.NullHandler.mro_len:
  description: "logging.NullHandler.__mro__.__len__() == 4 — MRO: [NullHandler, Handler, Filterer, object]"
  category: class_introspection
  kind: python_call_eq
  function: NullHandler.__mro__.__len__
  args: []
  expected: 4

invariant logging_extra32.NullHandler.bases_name_len:
  description: "logging.NullHandler.__bases__[0].__name__.__len__() == 7 — base class is 'Handler'"
  category: class_introspection
  kind: python_call_eq
  function: "NullHandler.__bases__[0].__name__.__len__"
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# FileHandler __mro__.__len__() and __bases__[0].__name__.__len__()
#
# FileHandler -> StreamHandler -> Handler -> Filterer -> object — MRO len 5.
# FileHandler.__bases__[0].__name__ == 'StreamHandler' (len 13).
# No prior logging spec checks __mro__.__len__() or __bases__[0].__name__.__len__()
# for FileHandler.
# ---------------------------------------------------------------------------

invariant logging_extra32.FileHandler.mro_len:
  description: "logging.FileHandler.__mro__.__len__() == 5 — MRO: [FileHandler, StreamHandler, Handler, Filterer, object]"
  category: class_introspection
  kind: python_call_eq
  function: FileHandler.__mro__.__len__
  args: []
  expected: 5

invariant logging_extra32.FileHandler.bases_name_len:
  description: "logging.FileHandler.__bases__[0].__name__.__len__() == 13 — base class is 'StreamHandler'"
  category: class_introspection
  kind: python_call_eq
  function: "FileHandler.__bases__[0].__name__.__len__"
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# logging class __qualname__.__len__() for Logger, Handler, Formatter, Filter, LogRecord
#
# All logging class qualnames equal their names (all are module-level definitions).
# Logger(6), Handler(7), Formatter(9), Filter(6), LogRecord(9).
# No prior logging spec checks __qualname__.__len__() for any of these core classes.
# ---------------------------------------------------------------------------

table logging_extra32.class_qualname_lens:
  description: "logging core class __qualname__ lengths — Logger (6), Handler (7), Formatter (9), Filter (6), LogRecord (9)"
  kind: python_call_eq
  category: class_identity
  id_prefix: lcq32

  columns: [id, function, args, expected]
  rows:
    - [Logger,    Logger.__qualname__.__len__,    [], 6]
    - [Handler,   Handler.__qualname__.__len__,   [], 7]
    - [Formatter, Formatter.__qualname__.__len__, [], 9]
    - [Filter,    Filter.__qualname__.__len__,    [], 6]
    - [LogRecord, LogRecord.__qualname__.__len__, [], 9]
