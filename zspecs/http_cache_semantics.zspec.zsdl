spec: http_cache_semantics
version: ">=4.0.0"
backend: node(http-cache-semantics)

docs: https://github.com/kornelski/http-cache-semantics#readme

provenance:
  derived_from:
    - "http-cache-semantics README — https://github.com/kornelski/http-cache-semantics#readme"
    - "RFC 9111 — HTTP Caching"
    - "Test vectors verified with http-cache-semantics via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "http-cache-semantics source"
  notes:
    - "Implements RFC 9111 cache validation — used by got, cacheable-request, undici, etc."
    - "Install: npm install http-cache-semantics"
    - "v4 CJS; module export IS the CachePolicy class. Constructor takes (req, res, [options])."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on missing req/res arguments."
  stderr: "null"
  stickiness: "Each CachePolicy carries the request/response captured at construction time."
  codes: {}

invariant http_cache_semantics.module_is_class:
  description: "Module export is a class (Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant http_cache_semantics.module_name:
  description: "Class name is 'CachePolicy'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "CachePolicy"

invariant http_cache_semantics.proto_has_storable:
  description: "CachePolicy.prototype.storable is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.storable.constructor.name"}
  expected: "Function"

invariant http_cache_semantics.proto_has_satisfiesWithoutRevalidation:
  description: "CachePolicy.prototype.satisfiesWithoutRevalidation is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.satisfiesWithoutRevalidation.constructor.name"}
  expected: "Function"

invariant http_cache_semantics.proto_has_age:
  description: "CachePolicy.prototype.age is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.age.constructor.name"}
  expected: "Function"

invariant http_cache_semantics.proto_has_maxAge:
  description: "CachePolicy.prototype.maxAge is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.maxAge.constructor.name"}
  expected: "Function"

invariant http_cache_semantics.proto_has_timeToLive:
  description: "CachePolicy.prototype.timeToLive is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.timeToLive.constructor.name"}
  expected: "Function"

invariant http_cache_semantics.proto_has_revalidatedPolicy:
  description: "CachePolicy.prototype.revalidatedPolicy is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.revalidatedPolicy.constructor.name"}
  expected: "Function"
