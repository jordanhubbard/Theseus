spec: abc_extra152
version: ">=3.10"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.__spec__ and abc.__loader__ module metadata attributes, and abc.update_abstractmethods function identity (added in Python 3.10). abc.__spec__.name.__eq__('abc')==True (the module spec name is 'abc'); abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (the spec object is an importlib.machinery.ModuleSpec); abc.__loader__.__class__.__name__.__eq__('type')==True (abc's loader's class is 'type' — the built-in type metaclass, because abc is a frozen importlib bootstrap module loaded by the frozen importer whose loader class resolves to 'type'); abc.update_abstractmethods.__module__.__eq__('abc')==True (update_abstractmethods is defined in the abc module); abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods')==True (co_name matches function name, len=22); abc.update_abstractmethods.__code__.co_argcount==1 (single arg: cls); abc.update_abstractmethods.__name__.__eq__('update_abstractmethods')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__loader__.__class__.__name__=='type' — the abc module is a frozen module loaded by Python's frozen importer; the loader for abc resolves to an object whose __class__.__name__ is 'type' (the built-in metaclass); this is because frozen module loaders in CPython are implemented as instances of built-in types, and the specific loader's class name is 'type'; this is different from regular .py modules whose loader's class might be 'SourceFileLoader'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods was added in Python 3.10 (bpo-44460) — update_abstractmethods(cls) recalculates the set of abstract methods on a class after dynamic modifications; it is useful when you add or remove abstract methods programmatically after class creation; update_abstractmethods.__code__.co_argcount==1 (single positional arg: cls — the class to update); update_abstractmethods.__code__.co_name=='update_abstractmethods' (len=22: 'update'=6+'_'=1+'abstract'=8+'_'=1+'methods'=7=23... wait: len('update_abstractmethods')='u'+'p'+'d'+'a'+'t'+'e'=6+'_'=1+'a'+'b'+'s'+'t'+'r'+'a'+'c'+'t'=8+'m'+'e'+'t'+'h'+'o'+'d'+'s'=7=22); len('update_abstractmethods')==22. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__spec__ is an importlib.machinery.ModuleSpec instance — every Python module has a __spec__ attribute set at import time; __spec__.name gives the fully-qualified module name ('abc'); __spec__.__class__.__name__=='ModuleSpec' (the class is importlib.machinery.ModuleSpec, len=10: 'Module'=6+'Spec'=4=10); __spec__.name=='abc' (len=3) is the shortest module name in the abc spec series. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__spec__ module metadata — extra152
#
# abc.__spec__.name.__eq__('abc')                          == True
# abc.__spec__.__class__.__name__.__eq__('ModuleSpec')     == True
# ---------------------------------------------------------------------------

table abc_extra152.abc_module_spec_attrs:
  description: "abc.__spec__ module metadata attribute checks in abcspec152 namespace — abc.__spec__.name.__eq__('abc')==True (every Python module's __spec__.name gives the fully-qualified module name; for abc, this is simply 'abc' (len=3) — the shortest possible module name); abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (abc.__spec__ is an importlib.machinery.ModuleSpec instance; ModuleSpec is the class that holds module metadata including name, loader, origin, submodule_search_locations, etc.; __class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10)); __spec__ is set on all modules at import time by importlib machinery; abc.__spec__.name=='abc' confirms the module is named 'abc' at the top level (no package prefix); compare: abc.__name__=='abc' (same value — __name__ and __spec__.name are equivalent for non-package modules); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcspec152

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,   abc.__spec__.name.__eq__,                  ["abc"],         true,  "abc.__spec__.name == 'abc' (len=3; module name from ModuleSpec); verified with Python 3.14.3"]
    - [spec_cls_eq,    abc.__spec__.__class__.__name__.__eq__,    ["ModuleSpec"],   true,  "abc.__spec__.__class__.__name__ == 'ModuleSpec' (len=10; importlib.machinery.ModuleSpec); verified with Python 3.14.3"]
    - [spec_cls_len,   abc.__spec__.__class__.__name__.__len__,   [],               10,    "abc.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'); verified with Python 3.14.3"]
    - [spec_name_len,  abc.__spec__.name.__len__,                 [],               3,     "abc.__spec__.name.__len__() == 3 ('abc'; shortest possible module name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__loader__ class identity — extra152
#
# abc.__loader__.__class__.__name__.__eq__('type')  == True
# ---------------------------------------------------------------------------

table abc_extra152.abc_loader_class_identity:
  description: "abc.__loader__ class identity checks in abcloader152 namespace — abc.__loader__.__class__.__name__.__eq__('type')==True (the abc module is a frozen module; its loader's __class__.__name__ is 'type' — the built-in type metaclass; frozen importlib bootstrap modules use a loader whose class resolves to 'type' in CPython); abc.__loader__.__class__.__name__=='type' (len=4; the string 'type'); this is different from regular .py source modules whose loader's class name is 'SourceFileLoader' (len=16) or bytecode-only modules with 'SourcelessFileLoader'; compare: abc.__spec__.__class__.__name__=='ModuleSpec' (len=10; different from loader class name 'type'=4); len('type')==4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcloader152

  columns: [id, function, args, expected, description]
  rows:
    - [loader_cls_eq,   abc.__loader__.__class__.__name__.__eq__,   ["type"],  true,  "abc.__loader__.__class__.__name__ == 'type' (frozen module loader class is 'type'); verified with Python 3.14.3"]
    - [loader_cls_len,  abc.__loader__.__class__.__name__.__len__,  [],        4,     "abc.__loader__.__class__.__name__.__len__() == 4 ('type'); verified with Python 3.14.3"]
    - [spec_name_eq2,   abc.__spec__.name.__eq__,                   ["abc"],   true,  "abc.__spec__.name == 'abc' (cross-reference: spec name matches module name); verified with Python 3.14.3"]
    - [spec_cls_eq2,    abc.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"], true, "abc.__spec__.__class__.__name__ == 'ModuleSpec' (cross-reference with loader class 'type'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods function identity — extra152
#
# abc.update_abstractmethods.__module__.__eq__('abc')                              == True
# abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods')     == True
# abc.update_abstractmethods.__code__.co_argcount                                  == 1
# abc.update_abstractmethods.__name__.__eq__('update_abstractmethods')             == True
# ---------------------------------------------------------------------------

table abc_extra152.abc_update_abstractmethods_identity:
  description: "abc.update_abstractmethods function identity checks in abcupdabs152 namespace — abc.update_abstractmethods.__module__.__eq__('abc')==True (update_abstractmethods is defined in the abc module itself; __module__=='abc' (len=3)); abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods')==True (co_name=='update_abstractmethods' (len=22: 'update'=6+'_'=1+'abstractmethods'... wait: 'abstract'=8+'methods'=7=15; 'update_abstractmethods'=6+1+8+7=22)); abc.update_abstractmethods.__code__.co_argcount==1 (single positional arg: cls — the class whose abstract methods are to be recalculated); abc.update_abstractmethods.__name__.__eq__('update_abstractmethods')==True (function __name__ matches co_name); update_abstractmethods was added in Python 3.10 (bpo-44460); co_name length==22 is the longest in the abc spec series; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcupdabs152

  columns: [id, function, args, expected, description]
  rows:
    - [uam_module_eq,   abc.update_abstractmethods.__module__.__eq__,              ["abc"],                    true,  "abc.update_abstractmethods.__module__ == 'abc' (defined in abc module); verified with Python 3.14.3"]
    - [uam_coname_eq,   abc.update_abstractmethods.__code__.co_name.__eq__,        ["update_abstractmethods"], true,  "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods' (len=22); verified with Python 3.14.3"]
    - [uam_argcnt_eq,   abc.update_abstractmethods.__code__.co_argcount.__eq__,    [1],                        true,  "abc.update_abstractmethods.__code__.co_argcount == 1 (single arg: cls); verified with Python 3.14.3"]
    - [uam_name_eq,     abc.update_abstractmethods.__name__.__eq__,                ["update_abstractmethods"], true,  "abc.update_abstractmethods.__name__ == 'update_abstractmethods' (name matches co_name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra152
# ---------------------------------------------------------------------------

invariant abc_extra152.abc_spec_name_eq:
  description: "abc.__spec__.name.__eq__('abc') returns True — every Python module has a __spec__ attribute of type importlib.machinery.ModuleSpec that stores the module's import metadata; abc.__spec__.name=='abc' (len=3; the fully-qualified module name; for a top-level module like abc there is no package prefix); __spec__.name is set at import time by importlib and is the authoritative source of the module's name (used internally by the import system); compare: abc.__name__=='abc' (the __name__ attribute is set from __spec__.name; both equal 'abc'); abc.__spec__.__class__.__name__=='ModuleSpec' (the spec class); abc.__spec__.name (len=3) is the shortest module name in the abc spec series; NEW in extra152: first standalone abc.__spec__.name identity invariant in abcspec152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.name.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra152.abc_spec_class_is_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc.__spec__ is an instance of importlib.machinery.ModuleSpec; ModuleSpec.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); ModuleSpec stores all import-related metadata for a module: name, loader, origin (file path), submodule_search_locations, has_location, cached, parent, and spec-level __init_subclass__ hooks; abc.__spec__.__class__.__name__=='ModuleSpec' confirms the type of the spec object; compare: abc.__loader__.__class__.__name__=='type' (len=4; the loader class name is 'type', much shorter than 'ModuleSpec'=10); ModuleSpec(10) vs type(4): spec class name is 6 chars longer; NEW in extra152: first standalone abc.__spec__.__class__.__name__ identity invariant in abcspec152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra152.abc_loader_class_is_type:
  description: "abc.__loader__.__class__.__name__.__eq__('type') returns True — abc is a frozen module (it is part of Python's frozen importlib bootstrap); the loader for abc is an object whose __class__.__name__ is 'type' (len=4); 'type' is the built-in Python metaclass — the class of all classes; for frozen modules in CPython, the loader object is an instance of the built-in type machinery, resolving to 'type' as the class name; this distinguishes abc from regular .py files (whose loaders have class names like 'SourceFileLoader') or .pyc files ('SourcelessFileLoader'); abc.__loader__.__class__.__name__=='type' (len=4; the shortest possible class name identifier after 'int', 'str', etc.); NEW in extra152: first standalone abc.__loader__.__class__.__name__ identity invariant in abcloader152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra152.abc_update_abstractmethods_coname_eq:
  description: "abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods') returns True — abc.update_abstractmethods is a pure Python function added in Python 3.10 (bpo-44460); its code object has co_name=='update_abstractmethods' (len=22: 'update'=6+'_'=1+'abstract'=8+'methods'=7=22); update_abstractmethods(cls) recalculates __abstractmethods__ for a class after dynamic changes to its methods; it is useful when abstract methods are added or removed programmatically after class creation (e.g. when using class decorators that modify methods); co_name 'update_abstractmethods' (len=22) is the longest co_name in the abc spec series so far — compare: ABCMeta.register co_name 'register' (len=8) and abc.ABC co_name (shorter); co_argcount==1 (single arg: cls); __module__=='abc'; NEW in extra152: first standalone abc.update_abstractmethods.__code__.co_name identity invariant in abcupdabs152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_name.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra152.abc_update_abstractmethods_argcount_eq:
  description: "abc.update_abstractmethods.__code__.co_argcount.__eq__(1) returns True — abc.update_abstractmethods.__code__.co_argcount==1; the single positional-or-keyword parameter is cls (the class whose abstract method set is to be recalculated); co_argcount==1 places update_abstractmethods in the same single-arg category as asyncio.iscoroutine (co_argcount==1) and abc.ABCMeta.register differs (co_argcount==2: self + subclass); update_abstractmethods(cls) updates cls.__abstractmethods__ by scanning the class's MRO for any methods decorated with @abstractmethod or assigned abstractmethod=True; it returns cls unchanged; __name__=='update_abstractmethods'; __module__=='abc'; added in Python 3.10 — this spec version annotation is '>=3.10'; NEW in extra152: first standalone abc.update_abstractmethods.__code__.co_argcount invariant in abcupdabs152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_argcount.__eq__
  args: [1]
  expected: true
