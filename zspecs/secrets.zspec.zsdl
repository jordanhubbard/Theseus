spec: secrets
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified by running Python 3.12 secrets module on macOS/Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
  notes:
    - "secrets generates cryptographically strong random values; exact values cannot be predicted."
    - "All invariants test structural properties (lengths, types) rather than exact values."
    - "token_bytes(n).__len__() == n — always exactly n bytes."
    - "token_hex(n).__len__() == 2*n — hex encoding doubles the byte count."
    - "token_urlsafe(0).__len__() == 0 — zero-byte token encodes to empty string."
    - "token_urlsafe(16).__len__() == 22 — base64url of 16 bytes is 22 chars (no padding)."
    - "choice([x]) always returns x when the list has only one element."
    - "randbelow(1) always returns 0 — the only non-negative integer less than 1."
    - "SystemRandom.__name__ == 'SystemRandom' — the class name attribute confirms identity."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token_bytes() — length checks
# ---------------------------------------------------------------------------

invariant secrets.token_bytes.len_1:
  description: "token_bytes(1).__len__() == 1 — always returns exactly 1 byte"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [1]
  method: __len__
  expected: 1

invariant secrets.token_bytes.len_16:
  description: "token_bytes(16).__len__() == 16 — always returns exactly 16 bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __len__
  expected: 16

invariant secrets.token_bytes.len_32:
  description: "token_bytes(32).__len__() == 32 — always returns exactly 32 bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [32]
  method: __len__
  expected: 32

invariant secrets.token_bytes.type_is_bytes:
  description: "token_bytes(16).hex().__len__() == 32 — bytes objects have .hex(); the 32-char result confirms the return type is bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: hex
  method_chain: __len__
  expected: 32

# ---------------------------------------------------------------------------
# token_hex() — length checks (2 * n hex chars per n bytes)
# ---------------------------------------------------------------------------

invariant secrets.token_hex.len_8:
  description: "token_hex(8).__len__() == 16 — 8 bytes encode to 16 hex chars"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __len__
  expected: 16

invariant secrets.token_hex.len_16:
  description: "token_hex(16).__len__() == 32 — 16 bytes encode to 32 hex chars"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [16]
  method: __len__
  expected: 32

invariant secrets.token_hex.type_is_str:
  description: "token_hex(16).upper().__len__() == 32 — str objects have .upper(); the 32-char result confirms the return type is str"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [16]
  method: upper
  method_chain: __len__
  expected: 32

# ---------------------------------------------------------------------------
# token_urlsafe() — length checks
# ---------------------------------------------------------------------------

invariant secrets.token_urlsafe.len_0:
  description: "token_urlsafe(0).__len__() == 0 — zero bytes encodes to empty string"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [0]
  method: __len__
  expected: 0

invariant secrets.token_urlsafe.len_16:
  description: "token_urlsafe(16).__len__() == 22 — 16 bytes in base64url encodes to 22 chars (no padding)"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [16]
  method: __len__
  expected: 22

# ---------------------------------------------------------------------------
# choice() — single-element list is always deterministic
# ---------------------------------------------------------------------------

invariant secrets.choice.single_element_99:
  description: "choice([99]) == 99 — single-element list always returns that element"
  category: choice
  kind: python_call_eq
  function: choice
  args: [[99]]
  expected: 99

invariant secrets.choice.single_element_42:
  description: "choice([42]) == 42 — single-element list always returns that element"
  category: choice
  kind: python_call_eq
  function: choice
  args: [[42]]
  expected: 42

# ---------------------------------------------------------------------------
# randbelow() — type and deterministic edge case
# ---------------------------------------------------------------------------

invariant secrets.randbelow.bit_length_is_int:
  description: "randbelow(100).bit_length() is callable — int objects have .bit_length(); confirms return type is int"
  category: randbelow
  kind: python_call_eq
  function: randbelow
  args: [1]
  method: bit_length
  expected: 0

invariant secrets.randbelow.zero_below_one:
  description: "randbelow(1) == 0 — the only non-negative integer less than 1 is 0"
  category: randbelow
  kind: python_call_eq
  function: randbelow
  args: [1]
  expected: 0

# ---------------------------------------------------------------------------
# SystemRandom class — constructor and type
# ---------------------------------------------------------------------------

invariant secrets.SystemRandom.class_name:
  description: "SystemRandom.__name__ == 'SystemRandom' — class attribute confirms the class identity"
  category: SystemRandom
  kind: python_call_eq
  function: SystemRandom.__name__.__eq__
  args: ["SystemRandom"]
  expected: true
