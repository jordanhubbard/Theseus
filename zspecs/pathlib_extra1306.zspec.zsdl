spec: pathlib_extra1306
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and invalid path operations."
    - "pathlib.PurePosixPath(42) raises TypeError: argument should be str or os.PathLike, not int."
    - "pathlib.Path(None) raises TypeError: argument should be str or os.PathLike, not NoneType."
    - "pathlib.PurePath().relative_to('unrelated') raises ValueError: path is not relative to 'unrelated'."
    - "pathlib.PurePath().with_suffix('no_dot') raises ValueError: invalid suffix 'no_dot' (must start with '.')."
    - "pathlib.PurePath().with_name('') raises ValueError: the name argument must not be empty."
    - "pathlib.PurePosixPath(object()) raises TypeError: argument should be str or os.PathLike."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra1306.constructor_type_errors:
  description: "pathlib path constructors raise TypeError when given non-string, non-PathLike arguments"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: pl1306ct
  columns: [id, function, args, exception]
  rows:
    - [pl1306ct001, pathlib.PurePosixPath, [42],              "TypeError"]
    - [pl1306ct002, pathlib.PurePosixPath, [3.14],            "TypeError"]
    - [pl1306ct003, pathlib.PurePosixPath, [[]],              "TypeError"]
    - [pl1306ct004, pathlib.Path,          [null],            "TypeError"]
    - [pl1306ct005, pathlib.PureWindowsPath, [42],            "TypeError"]
    - [pl1306ct006, pathlib.PurePosixPath, [true],            "TypeError"]

table pathlib_extra1306.relative_to_errors:
  description: "PurePath.relative_to raises ValueError when the path is not relative to the given base"
  kind: python_call_raises
  category: value_errors
  id_prefix: pl1306re
  columns: [id, function, args, exception]
  rows:
    - [pl1306re001, pathlib.PurePosixPath("/a/b").relative_to, ["unrelated"],      "ValueError"]
    - [pl1306re002, pathlib.PurePosixPath("/a/b").relative_to, ["/c"],             "ValueError"]
    - [pl1306re003, pathlib.PurePosixPath("/a/b").relative_to, ["/a/b/c"],         "ValueError"]
    - [pl1306re004, pathlib.PurePosixPath("a/b").relative_to,  ["/a/b"],           "ValueError"]
    - [pl1306re005, pathlib.PurePosixPath("/x").relative_to,   ["/y"],             "ValueError"]
    - [pl1306re006, pathlib.PurePosixPath("/a").relative_to,   ["/a/b/c/d"],       "ValueError"]

table pathlib_extra1306.with_name_suffix_errors:
  description: "PurePath.with_name and with_suffix raise ValueError on invalid arguments"
  kind: python_call_raises
  category: value_errors
  id_prefix: pl1306ws
  columns: [id, function, args, exception]
  rows:
    - [pl1306ws001, pathlib.PurePosixPath("a/b.txt").with_suffix,  ["no_dot"],     "ValueError"]
    - [pl1306ws002, pathlib.PurePosixPath("a/b.txt").with_suffix,  [".a.b"],       "ValueError"]
    - [pl1306ws003, pathlib.PurePosixPath("a/b.txt").with_name,    [""],           "ValueError"]
    - [pl1306ws004, pathlib.PurePosixPath("a/b.txt").with_name,    ["/abs"],       "ValueError"]
    - [pl1306ws005, pathlib.PurePosixPath(".").with_name,          [""],           "ValueError"]
    - [pl1306ws006, pathlib.PurePosixPath("a/b.txt").with_stem,    [""],           "ValueError"]
