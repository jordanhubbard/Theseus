spec: numbers_extra19
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra18.zspec.zsdl."
    - "Prior specs covered: Number/Complex/Real/Rational/Integral __name__/__module__/__qualname__, bases, ABCMeta.__name__, abstractmethods __class__.__name__, len(Integral.__abstractmethods__)==34, Number/Complex module length, __qualname__.__eq__ for all 5 ABCs."
    - "This spec covers: numbers.Number.__name__.__len__(), numbers.Complex.__name__.__len__(), numbers.Real.__name__.__len__(), numbers.Rational.__name__.__len__(), numbers.Integral.__name__.__len__(), numbers.Number.__module__.__len__(), numbers.Complex.__module__.__len__(), numbers.Real.__module__.__len__(), numbers.Rational.__module__.__len__(), numbers.Integral.__module__.__len__(), numbers.Number.__qualname__.__len__(), numbers.Integral.__qualname__.__len__()."
    - "numbers_extra18 records Number.__module__.__len__()==7 and Complex.__module__.__len__()==7 as standalone invariants; Real/Rational/Integral module lengths are new here."
    - "numbers_extra18 records __qualname__.__len__() for all 5 ABCs as standalone invariants; Number and Integral are recorded here in table form for series continuity."
    - "All five ABCs have __module__ == 'numbers' (7 chars)."
    - "Name lengths: Number=6, Complex=7, Real=4, Rational=8, Integral=8."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for all 5 ABCs
#
# No prior spec records __name__.__len__() for any of the five ABCs.
# (Prior specs record __name__.__eq__() equality checks.)
# Name lengths: Number=6, Complex=7, Real=4, Rational=8, Integral=8.
# ---------------------------------------------------------------------------

table numbers_extra19.abc_name_lengths:
  kind: python_call_eq
  category: class_identity
  id_prefix: name_len

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   Number.__name__.__len__,   [], 6, "len(numbers.Number.__name__) == 6 — 'Number' is 6 chars"]
    - [Complex,  Complex.__name__.__len__,  [], 7, "len(numbers.Complex.__name__) == 7 — 'Complex' is 7 chars"]
    - [Real,     Real.__name__.__len__,     [], 4, "len(numbers.Real.__name__) == 4 — 'Real' is 4 chars"]
    - [Rational, Rational.__name__.__len__, [], 8, "len(numbers.Rational.__name__) == 8 — 'Rational' is 8 chars"]
    - [Integral, Integral.__name__.__len__, [], 8, "len(numbers.Integral.__name__) == 8 — 'Integral' is 8 chars"]

# ---------------------------------------------------------------------------
# __name__.__len__() standalone invariants for Number and Integral
#
# Standalone forms for the boundary members of the hierarchy.
# ---------------------------------------------------------------------------

invariant numbers_extra19.Number.name_len:
  description: "len(numbers.Number.__name__) == 6 — 'Number' is 6 chars"
  category: class_identity
  kind: python_call_eq
  function: Number.__name__.__len__
  args: []
  expected: 6

invariant numbers_extra19.Integral.name_len:
  description: "len(numbers.Integral.__name__) == 8 — 'Integral' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Integral.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# __module__.__len__() for Real, Rational, Integral
#
# numbers_extra18 records Number.__module__.__len__()==7 and
# Complex.__module__.__len__()==7.  The remaining three ABCs share the same
# module string 'numbers' (7 chars); recorded here to complete the set.
# ---------------------------------------------------------------------------

invariant numbers_extra19.Real.module_len:
  description: "len(numbers.Real.__module__) == 7 — 'numbers' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Real.__module__.__len__
  args: []
  expected: 7

invariant numbers_extra19.Rational.module_len:
  description: "len(numbers.Rational.__module__) == 7 — 'numbers' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Rational.__module__.__len__
  args: []
  expected: 7

invariant numbers_extra19.Integral.module_len:
  description: "len(numbers.Integral.__module__) == 7 — 'numbers' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Integral.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for all 5 ABCs
#
# Consolidates all five module length checks in tabular form.
# numbers_extra18 covers Number and Complex as standalone invariants;
# this table provides a unified view across the full hierarchy.
# ---------------------------------------------------------------------------

table numbers_extra19.abc_module_lengths:
  kind: python_call_eq
  category: class_identity
  id_prefix: module_len

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   Number.__module__.__len__,   [], 7, "len(numbers.Number.__module__) == 7 — 'numbers' is 7 chars"]
    - [Complex,  Complex.__module__.__len__,  [], 7, "len(numbers.Complex.__module__) == 7 — 'numbers' is 7 chars"]
    - [Real,     Real.__module__.__len__,     [], 7, "len(numbers.Real.__module__) == 7 — 'numbers' is 7 chars"]
    - [Rational, Rational.__module__.__len__, [], 7, "len(numbers.Rational.__module__) == 7 — 'numbers' is 7 chars"]
    - [Integral, Integral.__module__.__len__, [], 7, "len(numbers.Integral.__module__) == 7 — 'numbers' is 7 chars"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Number and Integral (standalone invariants)
#
# numbers_extra18 records __qualname__.__len__() for all 5 ABCs as standalone
# invariants.  Recorded here for Number and Integral as complementary forms
# alongside the new __name__.__len__() table, establishing that for top-level
# ABCs __qualname__.__len__() == __name__.__len__().
# ---------------------------------------------------------------------------

invariant numbers_extra19.Number.qualname_len:
  description: "len(numbers.Number.__qualname__) == 6 — 'Number' is 6 chars (equals __name__.__len__())"
  category: class_identity
  kind: python_call_eq
  function: Number.__qualname__.__len__
  args: []
  expected: 6

invariant numbers_extra19.Integral.qualname_len:
  description: "len(numbers.Integral.__qualname__) == 8 — 'Integral' is 8 chars (equals __name__.__len__())"
  category: class_identity
  kind: python_call_eq
  function: Integral.__qualname__.__len__
  args: []
  expected: 8
