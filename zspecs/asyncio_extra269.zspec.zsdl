spec: asyncio_extra269
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Lock, Event, Condition, Semaphore, BoundedSemaphore are all defined in asyncio.locks."
    - "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin' — Lock inherits from _ContextManagerMixin and _LoopBoundMixin."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore."
    - "asyncio.Lock methods acquire, release, locked are plain Python functions; __class__.__name__ == 'function'."
    - "asyncio.Condition has no acquire/release; its methods are notify, notify_all, wait, wait_for."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Lock, Event, Condition, Semaphore, BoundedSemaphore __name__ — table
#
# Five synchronization classes: Lock, Event, Condition, Semaphore,
# BoundedSemaphore. All are defined in asyncio.locks submodule.
# ---------------------------------------------------------------------------

table asyncio_extra269.lock_class_names:
  description: "asyncio synchronization classes report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: clsname

  columns: [id, function, args, expected, description]
  rows:
    - [Lock,             Lock.__name__.__eq__,             ["Lock"],             true, "asyncio.Lock.__name__ == 'Lock'"]
    - [Event,            Event.__name__.__eq__,            ["Event"],            true, "asyncio.Event.__name__ == 'Event'"]
    - [Condition,        Condition.__name__.__eq__,        ["Condition"],        true, "asyncio.Condition.__name__ == 'Condition'"]
    - [Semaphore,        Semaphore.__name__.__eq__,        ["Semaphore"],        true, "asyncio.Semaphore.__name__ == 'Semaphore'"]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore'"]

# ---------------------------------------------------------------------------
# Lock, Event, Condition, Semaphore, BoundedSemaphore __module__ — table
#
# All five synchronization classes report __module__ == 'asyncio.locks'.
# ---------------------------------------------------------------------------

table asyncio_extra269.lock_class_modules:
  description: "asyncio synchronization classes report __module__ == 'asyncio.locks'"
  kind: python_call_eq
  category: identity
  id_prefix: clsmod

  columns: [id, function, args, expected, description]
  rows:
    - [Lock,             Lock.__module__.__eq__,             ["asyncio.locks"], true, "asyncio.Lock.__module__ == 'asyncio.locks'"]
    - [Event,            Event.__module__.__eq__,            ["asyncio.locks"], true, "asyncio.Event.__module__ == 'asyncio.locks'"]
    - [Condition,        Condition.__module__.__eq__,        ["asyncio.locks"], true, "asyncio.Condition.__module__ == 'asyncio.locks'"]
    - [Semaphore,        Semaphore.__module__.__eq__,        ["asyncio.locks"], true, "asyncio.Semaphore.__module__ == 'asyncio.locks'"]
    - [BoundedSemaphore, BoundedSemaphore.__module__.__eq__, ["asyncio.locks"], true, "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'"]

# ---------------------------------------------------------------------------
# Lock.__bases__[0] is _ContextManagerMixin — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra269.Lock.bases0_name:
  description: "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'"
  category: identity
  kind: python_call_eq
  function: "Lock.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

# ---------------------------------------------------------------------------
# BoundedSemaphore.__bases__[0] is Semaphore — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra269.BoundedSemaphore.bases0_name:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

# ---------------------------------------------------------------------------
# Lock.acquire, release, locked __name__ — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra269.Lock.acquire_name:
  description: "asyncio.Lock.acquire.__name__ == 'acquire'"
  category: identity
  kind: python_call_eq
  function: Lock.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant asyncio_extra269.Lock.release_name:
  description: "asyncio.Lock.release.__name__ == 'release'"
  category: identity
  kind: python_call_eq
  function: Lock.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant asyncio_extra269.Lock.locked_name:
  description: "asyncio.Lock.locked.__name__ == 'locked'"
  category: identity
  kind: python_call_eq
  function: Lock.locked.__name__.__eq__
  args: ["locked"]
  expected: true
