spec: io_extra108
version: ">=3.9"
backend: python_module(io)
extends: io_extra107

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra107.zspec.zsdl."
    - "This spec covers: io module __name__, __package__, __spec__ attrs and key constants."
    - "io is a frozen module: io.__spec__.has_location == False, io.__spec__.origin == 'frozen'."
    - "io.__loader__.__class__.__name__ == 'type' because io.__loader__ is the FrozenImporter class itself (not an instance)."
    - "io.__loader__.__name__ == 'FrozenImporter'."
    - "io.__package__ == '' (empty string, as io is not a package)."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; note: NOT 8192 — verified on Python 3.14.3)."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — all of type int."
    - "io.UnsupportedOperation has two base classes: OSError and ValueError (multiple inheritance)."
    - "io.UnsupportedOperation.__mro__.__len__() == 6 (UnsupportedOperation, OSError, ValueError, Exception, BaseException, object)."
    - "io.UnsupportedOperation.__name__.__len__() == 20 ('UnsupportedOperation' has 20 characters)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module identity: __name__, __package__, __spec__ attributes
# io is a frozen module, so has_location is False and origin is 'frozen'.
# __loader__ is the FrozenImporter class itself (not an instance), so its
# __class__.__name__ is 'type'.
# ---------------------------------------------------------------------------

table io_extra108.module_identity:
  description: "io module identity: __name__ ('io', len 2), __package__ ('', empty), __spec__.__class__.__name__ ('ModuleSpec'), __spec__.name ('io')"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomodid108

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,                 ["io"],         true,  "io.__name__ == 'io'"]
    - [name_len,       __name__.__len__,                [],             2,     "io.__name__.__len__() == 2 ('io' has 2 characters)"]
    - [pkg_eq,         __package__.__eq__,              [""],           true,  "io.__package__ == '' (io is a frozen module, not a package)"]
    - [spec_cls_name,  __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "io.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_name_eq,   __spec__.name.__eq__,            ["io"],         true,  "io.__spec__.name == 'io'"]
    - [spec_name_len,  __spec__.name.__len__,           [],             2,     "io.__spec__.name.__len__() == 2 ('io' has 2 characters)"]
    - [loader_cls,     __loader__.__class__.__name__.__eq__, ["type"],  true,  "io.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, not an instance)"]
    - [loader_name,    __loader__.__name__.__eq__,      ["FrozenImporter"], true, "io.__loader__.__name__ == 'FrozenImporter'"]

# ---------------------------------------------------------------------------
# io module __spec__ frozen-module attributes
# has_location is False because frozen modules have no on-disk file.
# origin is 'frozen'.
# spec_cls_name length is 10 ('ModuleSpec').
# ---------------------------------------------------------------------------

table io_extra108.spec_frozen_attrs:
  description: "io.__spec__ frozen-module attributes: has_location (False), __spec__.__class__.__name__.__len__() (10 for 'ModuleSpec')"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomodid108

  columns: [id, function, args, expected, description]
  rows:
    - [has_loc_false,    __spec__.has_location.__eq__,             [false],       true,  "io.__spec__.has_location == False (frozen modules have no on-disk file)"]
    - [spec_cls_len,     __spec__.__class__.__name__.__len__,      [],            10,    "io.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec' has 10 characters)"]
    - [pkg_not_io,       __package__.__eq__,                       ["io"],        false, "io.__package__ != 'io' (io is a module, not a package; __package__ is empty string)"]
    - [name_not_pkg,     __name__.__eq__,                          ["_io"],       false, "io.__name__ != '_io' (the public module name is 'io', not the internal C extension '_io')"]

# ---------------------------------------------------------------------------
# io module constants: DEFAULT_BUFFER_SIZE, SEEK_SET, SEEK_CUR, SEEK_END
# DEFAULT_BUFFER_SIZE is 131072 (128 KiB) on CPython 3.14.3, NOT 8192.
# SEEK_SET/SEEK_CUR/SEEK_END are plain int values 0/1/2.
# ---------------------------------------------------------------------------

table io_extra108.constants:
  description: "io module constants: DEFAULT_BUFFER_SIZE (131072), SEEK_SET (0), SEEK_CUR (1), SEEK_END (2); all of type int"
  kind: python_call_eq
  category: constants
  id_prefix: iomodid108

  columns: [id, function, args, expected, description]
  rows:
    - [dbs_val,       DEFAULT_BUFFER_SIZE.__eq__,             [131072], true,  "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; NOT 8192 — verified on Python 3.14.3)"]
    - [dbs_cls,       DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true, "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'"]
    - [seek_set_val,  SEEK_SET.__eq__,                        [0],     true,  "io.SEEK_SET == 0"]
    - [seek_cur_val,  SEEK_CUR.__eq__,                        [1],     true,  "io.SEEK_CUR == 1"]
    - [seek_end_val,  SEEK_END.__eq__,                        [2],     true,  "io.SEEK_END == 2"]
    - [seek_set_cls,  SEEK_SET.__class__.__name__.__eq__,     ["int"], true,  "io.SEEK_SET.__class__.__name__ == 'int'"]
    - [seek_not_3,    SEEK_END.__eq__,                        [3],     false, "io.SEEK_END != 3 (SEEK_END is 2, not 3)"]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation exception class identity
# UnsupportedOperation inherits from BOTH OSError and ValueError (multiple
# inheritance). MRO depth is 6.
# __name__.__len__() == 20 ('UnsupportedOperation').
# ---------------------------------------------------------------------------

table io_extra108.UnsupportedOperation_identity:
  description: "io.UnsupportedOperation: __name__ (20 chars), __module__ ('io'), __bases__[0].__name__ ('OSError'), __mro__.__len__() (6)"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomodid108

  columns: [id, function, args, expected, description]
  rows:
    - [uo_name_eq,     UnsupportedOperation.__name__.__eq__,             ["UnsupportedOperation"], true, "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"]
    - [uo_name_len,    UnsupportedOperation.__name__.__len__,            [],                       20,   "io.UnsupportedOperation.__name__.__len__() == 20 ('UnsupportedOperation' has 20 characters)"]
    - [uo_module_eq,   UnsupportedOperation.__module__.__eq__,           ["io"],                   true, "io.UnsupportedOperation.__module__ == 'io'"]
    - [uo_base0_eq,    "UnsupportedOperation.__bases__[0].__name__.__eq__", ["OSError"],            true, "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' (first base is OSError)"]
    - [uo_base1_eq,    "UnsupportedOperation.__bases__[1].__name__.__eq__", ["ValueError"],         true, "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' (second base is ValueError)"]
    - [uo_mro_len,     UnsupportedOperation.__mro__.__len__,             [],                       6,    "io.UnsupportedOperation.__mro__.__len__() == 6 (UnsupportedOperation, OSError, ValueError, Exception, BaseException, object)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra108.module_name_is_io:
  description: "io.__name__ == 'io' (the public module name is 'io', confirming the io module self-identifies correctly)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["io"]
  expected: true

invariant io_extra108.spec_has_location_false:
  description: "io.__spec__.has_location == False (io is a frozen module and has no on-disk source file; frozen modules report has_location as False)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true

invariant io_extra108.default_buffer_size_is_131072:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; this is the CPython 3.14.3 value; earlier documentation suggested 8192 but the actual value is 131072)"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra108.SEEK_END_is_2:
  description: "io.SEEK_END == 2 (the three SEEK_ constants are SEEK_SET=0, SEEK_CUR=1, SEEK_END=2; they are plain Python ints)"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra108.UnsupportedOperation.mro_len_6:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 (the full MRO is [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__len__
  args: []
  expected: 6

