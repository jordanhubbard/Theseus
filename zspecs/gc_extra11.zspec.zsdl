spec: gc_extra11
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra10.zspec.zsdl."
    - "gc_extra10 covers __module__ for all major gc functions via __module__.__eq__ method chain."
    - "gc_extra4 covers __name__ for collect/get_count/get_threshold/get_objects and other gc functions."
    - "No prior gc spec covers __qualname__ for any gc function."
    - "gc.collect.__qualname__ == 'collect' — C builtin; qualname equals name."
    - "gc.get_count.__qualname__ == 'get_count' — C builtin; qualname equals name."
    - "gc.get_threshold.__qualname__ == 'get_threshold' — C builtin; qualname equals name."
    - "gc.get_objects.__qualname__ == 'get_objects' — C builtin; qualname equals name."
    - "For top-level C builtin functions, __qualname__ == __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ — collect, get_count, get_threshold, get_objects
#
# gc_extra4 covers __name__ for all major gc functions. gc_extra10 covers
# __module__ for all major gc functions. No prior spec covers __qualname__ for
# any gc function. For top-level C builtin functions, __qualname__ == __name__.
# These invariants assert that via the __qualname__.__eq__ method chain pattern.
# ---------------------------------------------------------------------------

invariant gc_extra11.collect.qualname:
  description: "gc.collect.__qualname__ == 'collect' — C builtin; qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: collect.__qualname__.__eq__
  args: ["collect"]
  expected: true

invariant gc_extra11.get_count.qualname:
  description: "gc.get_count.__qualname__ == 'get_count' — C builtin; qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: get_count.__qualname__.__eq__
  args: ["get_count"]
  expected: true

invariant gc_extra11.get_threshold.qualname:
  description: "gc.get_threshold.__qualname__ == 'get_threshold' — C builtin; qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: get_threshold.__qualname__.__eq__
  args: ["get_threshold"]
  expected: true

invariant gc_extra11.get_objects.qualname:
  description: "gc.get_objects.__qualname__ == 'get_objects' — C builtin; qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: get_objects.__qualname__.__eq__
  args: ["get_objects"]
  expected: true
