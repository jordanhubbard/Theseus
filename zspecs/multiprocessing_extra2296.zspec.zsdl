spec: multiprocessing_extra2296
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "multiprocessing.Process reports __module__ as 'multiprocessing.context' (not 'multiprocessing.process')."
    - "multiprocessing.pool.Pool reports __module__ as 'multiprocessing.pool'."
    - "multiprocessing.queues.Queue, SimpleQueue, JoinableQueue report __module__ as 'multiprocessing.queues'."
    - "multiprocessing.managers.BaseManager and SyncManager report __module__ as 'multiprocessing.managers'."
    - "multiprocessing.pool.AsyncResult.__qualname__ is 'ApplyResult' (AsyncResult is an alias for ApplyResult)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2296.process_module:
  description: "multiprocessing.Process __module__ and __qualname__ — defined in multiprocessing.context"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp2296

  columns: [id, function, args, expected]
  rows:
    - ["mp2296001", "multiprocessing.Process.__module__", [], "multiprocessing.context"]
    - ["mp2296002", "multiprocessing.Process.__qualname__", [], "Process"]
    - ["mp2296003", "multiprocessing.Process.__name__", [], "Process"]

