    - ["mp2296005", "multiprocessing.pool.Pool.__qualname__", [], "Pool"]
    - ["mp2296006", "multiprocessing.pool.AsyncResult.__module__", [], "multiprocessing.pool"]
    - ["mp2296007", "multiprocessing.pool.AsyncResult.__qualname__", [], "ApplyResult"]
    - ["mp2296008", "multiprocessing.pool.MapResult.__module__", [], "multiprocessing.pool"]
    - ["mp2296009", "multiprocessing.pool.MapResult.__qualname__", [], "MapResult"]
