spec: concurrent_futures_extra135
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py, Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.thread.ThreadPoolExecutor, concurrent.futures.process.ProcessPoolExecutor, and concurrent.futures._base.Future — their __module__, __name__, and __qualname__ attributes. ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18); ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26); ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19); Future.__module__=='concurrent.futures._base' (len=24); Future.__name__=='Future' (len=6). Also thread.__name__=='concurrent.futures.thread' (len=25); process.__name__=='concurrent.futures.process' (len=26). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor.__bases__[0].__name__=='Executor'; ProcessPoolExecutor.__bases__[0].__name__=='Executor'; Future.__bases__[0].__name__=='object'. The thread module __name__ equals ThreadPoolExecutor.__module__ (both 'concurrent.futures.thread', len=25). The process module __name__ equals ProcessPoolExecutor.__module__ (both 'concurrent.futures.process', len=26). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor __name__, __qualname__, __module__ — extra135
#
# concurrent.futures.thread.ThreadPoolExecutor.__name__     == 'ThreadPoolExecutor' (len=18)
# concurrent.futures.thread.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18)
# concurrent.futures.thread.ThreadPoolExecutor.__module__   == 'concurrent.futures.thread' (len=25)
# ---------------------------------------------------------------------------

table concurrent_futures_extra135.tpe_identity:
  description: "concurrent.futures.thread.ThreadPoolExecutor class identity checks — TPE.__name__.__eq__('ThreadPoolExecutor')==True (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); TPE.__qualname__.__eq__('ThreadPoolExecutor')==True (len=18, same as __name__ — top-level class); TPE.__module__.__eq__('concurrent.futures.thread')==True (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25); TPE.__bases__[0].__name__.__eq__('Executor')==True (len=8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpe135

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,   concurrent.futures.thread.ThreadPoolExecutor.__name__.__eq__,     ["ThreadPoolExecutor"],       true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [name_len,  concurrent.futures.thread.ThreadPoolExecutor.__name__.__len__,     [],                          18,   "ThreadPoolExecutor.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [mod_eq,    concurrent.futures.thread.ThreadPoolExecutor.__module__.__eq__,   ["concurrent.futures.thread"], true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [mod_len,   concurrent.futures.thread.ThreadPoolExecutor.__module__.__len__,   [],                          25,   "ThreadPoolExecutor.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [base_name, "concurrent.futures.thread.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],        true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]

