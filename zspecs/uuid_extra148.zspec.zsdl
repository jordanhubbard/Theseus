spec: uuid_extra148
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra147.zspec.zsdl — covers uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') / UUID.__slots__.__contains__('int'/'is_safe'/'__weakref__') / UUID.__slots__.__len__()==3 / UUID.__hash__/__str__/__repr__/__eq__ qualname lengths (table + invariants)."
    - "uuid_extra146.zspec.zsdl — covers uuid.uuid1/uuid3/uuid4/uuid5 __module__/__code__.co_name/__code__.co_argcount (table + invariants)."
    - "uuid_extra145.zspec.zsdl — covers uuid.UUID.hex/__bytes/__version/__variant/__node/__time/__class__.__name__.__eq__('property') / UUID.int/__class__.__name__.__eq__('member_descriptor') / uuid4.__module__.__eq__('uuid') (table + invariants)."
    - "uuid_extra144.zspec.zsdl — covers uuid.UUID.__str__/__repr__/__hash__/__eq__/__int__ qualnames and qualname lengths (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra147."
    - "Wave 338 theme: uuid namespace constants class identity and uuid.SafeUUID module/name — uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') / NAMESPACE_URL/__class__.__name__.__eq__('UUID') / NAMESPACE_OID/__class__.__name__.__eq__('UUID') / NAMESPACE_X500/__class__.__name__.__eq__('UUID') / NAMESPACE_DNS.__str__.__qualname__.__eq__('UUID.__str__') / SafeUUID.__name__.__eq__('SafeUUID') / SafeUUID.__module__.__eq__('uuid')."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__str__.__qualname__ == 'UUID.__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. The four UUID namespace constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) are pre-defined UUID instances used with uuid3() and uuid5(). They are instances of the UUID class, so their __class__.__name__ is 'UUID' (4 chars). NAMESPACE_DNS = UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8') is the DNS namespace. NAMESPACE_URL = UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8') is the URL namespace."
    - "Note: uuid.NAMESPACE_DNS.__str__.__qualname__ == 'UUID.__str__'. Since NAMESPACE_DNS is an instance of UUID, its __str__ method is the UUID.__str__ method (inherited from the class). The __qualname__ of the bound/unbound method is 'UUID.__str__' (12 chars = 'UUID.'=5 + '__str__'=7). extra147 anchors UUID.__str__.__qualname__.__len__()==12; this spec anchors the qualname string value via NAMESPACE_DNS.__str__.__qualname__."
    - "Note: uuid.SafeUUID.__name__ == 'SafeUUID' (8 chars) and __module__ == 'uuid' (4 chars). SafeUUID is an IntEnum defined in Lib/uuid.py. It has values: SafeUUID.safe (0) when the uuid was generated safely (e.g., from /dev/urandom with host locking) and SafeUUID.unsafe (-1) when not. SafeUUID.__name__ == 'SafeUUID' (8 chars; matches the class name in the def statement). SafeUUID.__module__ == 'uuid' (4 chars; defined in pure Python Lib/uuid.py)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID')
#
# Wave 338 theme: all four UUID namespace constants are UUID instances.
#
# NAMESPACE_DNS/URL/OID/X500 are all pre-built UUID instances (__class__.__name__=='UUID').
# They serve as namespaces for uuid3() (MD5-based) and uuid5() (SHA-1-based).
# 'UUID' is 4 chars. No prior uuid spec anchors namespace constant class names as a table
# under uuidns148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra148.namespace_constants_class_identity:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL.__class__.__name__.__eq__('UUID')==True / NAMESPACE_OID.__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500.__class__.__name__.__eq__('UUID')==True — all four namespace constants are UUID instances ('UUID' = 4 chars); used as namespace arguments to uuid3() and uuid5(); NAMESPACE_DNS='6ba7b810-9dad-11d1-80b4-00c04fd430c8' (DNS namespace); NAMESPACE_URL='6ba7b811-...' (URL namespace); NAMESPACE_OID='6ba7b812-...' (OID namespace); NAMESPACE_X500='6ba7b814-...' (X.500 DN namespace); all defined as pre-built UUID instances in Lib/uuid.py; first uuidns148 anchor for namespace constant class names"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns148

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class_UUID,   "NAMESPACE_DNS.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (4 chars; DNS namespace UUID instance; used with uuid3()/uuid5())"]
    - [ns_url_class_UUID,   "NAMESPACE_URL.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' (4 chars; URL namespace UUID instance; used with uuid3()/uuid5())"]
    - [ns_oid_class_UUID,   "NAMESPACE_OID.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' (4 chars; OID namespace UUID instance; used with uuid3()/uuid5())"]
    - [ns_x500_class_UUID,  "NAMESPACE_X500.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' (4 chars; X.500 DN namespace UUID instance; used with uuid3()/uuid5())"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__str__.__qualname__.__eq__('UUID.__str__')
# uuid.SafeUUID.__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__module__.__eq__('uuid')
#
# Wave 338 theme: NAMESPACE_DNS.__str__ qualname and SafeUUID class identity.
#
# NAMESPACE_DNS.__str__.__qualname__ == 'UUID.__str__' (12 chars; inherits from UUID class).
# SafeUUID.__name__ == 'SafeUUID' (8 chars; IntEnum subclass for generation safety flag).
# SafeUUID.__module__ == 'uuid' (4 chars; pure Python Lib/uuid.py).
# extra147 anchors UUID.__str__.__qualname__.__len__()==12 as a table row (length check);
# no prior uuid spec anchors NAMESPACE_DNS.__str__.__qualname__ string value or
# SafeUUID identity as a table under uuidns148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra148.ns_dns_str_qualname_and_safeuuid_identity:
  description: "uuid.NAMESPACE_DNS.__str__.__qualname__.__eq__('UUID.__str__')==True / SafeUUID.__name__.__eq__('SafeUUID')==True / SafeUUID.__module__.__eq__('uuid')==True / NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True — NAMESPACE_DNS.__str__.__qualname__ is 'UUID.__str__' (12 chars = 'UUID.'=5 + '__str__'=7; instance inherits __str__ from the UUID class; extra147 anchors __len__()==12 but not string value); SafeUUID.__name__ is 'SafeUUID' (8 chars; IntEnum; safe=0, unsafe=-1); SafeUUID.__module__ is 'uuid' (4 chars; defined in Lib/uuid.py); first uuidns148 anchor for NAMESPACE_DNS.__str__.__qualname__ string value and SafeUUID identity"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns148

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_str_qualname,  "NAMESPACE_DNS.__str__.__qualname__.__eq__", ["UUID.__str__"], true, "uuid.NAMESPACE_DNS.__str__.__qualname__ == 'UUID.__str__' (12 chars; instance inherits __str__ from UUID class)"]
    - [safeuuid_name,        "SafeUUID.__name__.__eq__",                  ["SafeUUID"],    true, "uuid.SafeUUID.__name__ == 'SafeUUID' (8 chars; IntEnum subclass; generation safety flag; safe=0, unsafe=-1)"]
    - [safeuuid_module,      "SafeUUID.__module__.__eq__",                ["uuid"],        true, "uuid.SafeUUID.__module__ == 'uuid' (4 chars; pure Python IntEnum in Lib/uuid.py)"]
    - [ns_dns_class_UUID_b,  "NAMESPACE_DNS.__class__.__name__.__eq__",   ["UUID"],        true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (4 chars; confirmed alongside SafeUUID identity; pre-built UUID instance)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__len__()==4
# uuid.SafeUUID.__name__.__len__()==8
# uuid.SafeUUID.__module__.__len__()==4
#
# Wave 338 theme: length checks for namespace constant class name and SafeUUID attributes.
#
# 'UUID' is 4 chars (namespace constant class name). 'SafeUUID' is 8 chars.
# 'uuid' is 4 chars (SafeUUID.__module__). 'UUID.__str__' is 12 chars (extra147 anchors length).
# Length ordering: 'UUID'==module(4) < 'SafeUUID'(8) < 'UUID.__str__'(12).
# No prior uuid spec anchors these length values as a combined table under uuidns148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra148.namespace_and_safeuuid_name_lengths:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__len__()==4 / SafeUUID.__name__.__len__()==8 / SafeUUID.__module__.__len__()==4 / NAMESPACE_DNS.__str__.__qualname__.__len__()==12 — 'UUID' class name is 4 chars (all four namespace constants share this); 'SafeUUID' name is 8 chars (IntEnum class name); 'uuid' module is 4 chars (SafeUUID.__module__; same length as 'UUID'); 'UUID.__str__' qualname is 12 chars (extra147 anchors this as a table row; confirmed here alongside other lengths); length ordering: 'UUID'==module(4) < 'SafeUUID'(8) < 'UUID.__str__'(12); first uuidns148 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns148

  columns: [id, function, args, expected, description]
  rows:
    - [ns_class_name_len_4,      "NAMESPACE_DNS.__class__.__name__.__len__",    [], 4,  "uuid.NAMESPACE_DNS.__class__.__name__.__len__() is 4 ('UUID' = 4 chars; same for all four namespace constants)"]
    - [safeuuid_name_len_8,      "SafeUUID.__name__.__len__",                   [], 8,  "uuid.SafeUUID.__name__.__len__() is 8 ('SafeUUID' = 8 chars; IntEnum subclass; 2 times length of 'UUID')"]
    - [safeuuid_module_len_4,    "SafeUUID.__module__.__len__",                 [], 4,  "uuid.SafeUUID.__module__.__len__() is 4 ('uuid' = 4 chars; same length as 'UUID' class name)"]
    - [ns_dns_str_qual_len_12,   "NAMESPACE_DNS.__str__.__qualname__.__len__",  [], 12, "uuid.NAMESPACE_DNS.__str__.__qualname__.__len__() is 12 ('UUID.__str__' = 'UUID.'=5 + '__str__'=7 = 12 chars)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_DNS is one of the
# four predefined UUID namespace constants in the uuid module. It is defined in Lib/uuid.py
# as NAMESPACE_DNS = UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8') — a pre-built UUID
# instance with the 128-bit value 0x6ba7b8109dad11d180b400c04fd430c8. Since NAMESPACE_DNS
# is an instance of UUID, its __class__.__name__ is 'UUID' (4 chars). It is used as the
# namespace argument to uuid3() and uuid5() when the name is a fully-qualified domain name.
# No prior uuid spec anchors NAMESPACE_DNS.__class__.__name__ as a standalone under
# uuidns148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra148.NAMESPACE_DNS_class_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars); NAMESPACE_DNS is a pre-built UUID instance defined as UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8') in Lib/uuid.py; DNS namespace for use with uuid3()/uuid5() when name is a FQDN; all four namespace constants are UUID instances; NAMESPACE_DNS.__str__.__qualname__=='UUID.__str__' (12 chars); no prior uuid spec anchors this as a standalone; first standalone under uuidns148"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID') — standalone
#
# uuid.SafeUUID.__name__ is 'SafeUUID' (8 chars). SafeUUID is an IntEnum subclass
# defined in Lib/uuid.py. It was added in Python 3.7 to indicate whether a UUID was
# generated in a safe manner (using a method that avoids duplicate values across
# multiple processes). SafeUUID has two values: SafeUUID.safe (value 0) for safely
# generated UUIDs and SafeUUID.unsafe (value -1) for UUIDs where safety is unknown.
# UUID instances carry an 'is_safe' attribute (anchored by extra147 as a __slots__ entry)
# of type SafeUUID. SafeUUID.__name__ == 'SafeUUID' (8 chars) matches the class name in
# the def statement. No prior uuid spec anchors SafeUUID.__name__ as a standalone under
# uuidns148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra148.SafeUUID_name_eq:
  description: "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True — 8 chars; IntEnum subclass in Lib/uuid.py (Python 3.7+); SafeUUID.safe=0 (safely generated, avoids duplicate values across processes); SafeUUID.unsafe=-1 (safety unknown); UUID.is_safe slot stores SafeUUID value (extra147 anchors 'is_safe' in __slots__); SafeUUID.__module__=='uuid' (4 chars); no prior uuid spec anchors this as a standalone; first standalone under uuidns148"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__str__.__qualname__.__eq__('UUID.__str__') — standalone
#
# uuid.NAMESPACE_DNS.__str__.__qualname__ is 'UUID.__str__' (12 chars). NAMESPACE_DNS
# is a UUID instance. Its __str__ bound method inherits from the UUID class, so
# __str__.__qualname__ is 'UUID.__str__' (the class method's qualname, not a per-instance
# qualname). 'UUID.__str__' = 'UUID.'=5 chars + '__str__'=7 chars = 12 chars.
# extra147 anchors UUID.__str__.__qualname__.__len__()==12 as a table row (length check)
# and UUID.__str__.__qualname__ as a standalone (via the class directly); this spec
# anchors the same qualname value but accessed via NAMESPACE_DNS (an instance), confirming
# that the bound method's __qualname__ matches the class method's __qualname__.
# No prior uuid spec anchors NAMESPACE_DNS.__str__.__qualname__ as a standalone under
# uuidns148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra148.NAMESPACE_DNS_str_qualname:
  description: "uuid.NAMESPACE_DNS.__str__.__qualname__.__eq__('UUID.__str__') == True — 'UUID.__str__' (12 chars = 'UUID.'=5 + '__str__'=7); NAMESPACE_DNS is a UUID instance so its __str__ is the class method (not per-instance); bound method __qualname__ matches class method __qualname__; extra147 anchors UUID.__str__.__qualname__.__len__()==12 and the string value via class directly; this anchors via instance access; confirms instance-accessed bound method qualname equals class-defined qualname; no prior uuid spec anchors this as a standalone; first standalone under uuidns148"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__str__.__qualname__.__eq__
  args: ["UUID.__str__"]
  expected: true

