spec: questionary_rust
version: ">=3.9"
backend: rust_module(questionary_rust)

docs: https://questionary.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://questionary.readthedocs.io/en/stable/ — questionary documentation"
  not_derived_from:
    - "questionary source: questionary/__init__.py"
  notes:
    - "questionary provides beautiful command line prompts."
    - "questionary.text is available."
    - "questionary.confirm is available."
    - "questionary.select is available."
    - "questionary.__version__ is a non-empty string."
    - "Expose questionary_has_text() -> bool: hasattr(questionary, 'text')."
    - "Expose questionary_has_confirm() -> bool: hasattr(questionary, 'confirm')."
    - "Expose questionary_version_nonempty() -> bool: len(questionary.__version__) > 0."
    - "All test vectors verified against questionary 2.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# questionary_has_text — text prompt present
invariant questionary_rust.module.has_text:
  description: "questionary.text is available"
  category: module
  kind: python_call_eq
  function: questionary_has_text
  args: []
  expected: true

# questionary_has_confirm — confirm prompt present
invariant questionary_rust.module.has_confirm:
  description: "questionary.confirm is available"
  category: module
  kind: python_call_eq
  function: questionary_has_confirm
  args: []
  expected: true

# questionary_version_nonempty — version non-empty
invariant questionary_rust.version.nonempty:
  description: "questionary.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: questionary_version_nonempty
  args: []
  expected: true

