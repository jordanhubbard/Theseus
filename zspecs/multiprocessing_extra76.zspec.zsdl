spec: multiprocessing_extra76
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Python multiprocessing Process documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra75.zspec.zsdl."
    - "This spec covers: wave 244 theme — multiprocessing Process.__init__ code attrs + Process method identity. NEW in extra76: Process.__init__.__code__.co_varnames.__class__.__name__=='tuple'; Process.__init__.__code__.co_flags.__class__.__name__=='int'; Process.terminate.__code__.co_name=='terminate'; Process.terminate.__code__.co_argcount==1; Process.kill.__code__.co_name=='kill'; Process.kill.__code__.co_argcount==1; Process.is_alive.__code__.co_name=='is_alive'; Process.is_alive.__code__.co_argcount==1; multiprocessing.Process.__module__=='multiprocessing.context' (NOT multiprocessing.process — the class is accessed through the context dispatch layer); multiprocessing.ProcessError.__qualname__=='ProcessError'. NOTE: Process.__module__ is 'multiprocessing.context' (not 'multiprocessing.process') because multiprocessing.Process is actually retrieved from the context; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython code objects. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_flags.__class__.__name__ == 'int'. co_flags is always an int in CPython code objects. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.terminate.__code__.co_name == 'terminate'. Process.terminate is a Python method in multiprocessing/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.terminate.__code__.co_argcount == 1. terminate takes only self as positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.kill.__code__.co_name == 'kill'. Process.kill was added in Python 3.7 and is a Python method in multiprocessing/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.kill.__code__.co_argcount == 1. kill takes only self as positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.is_alive.__code__.co_name == 'is_alive'. Process.is_alive is a Python method in multiprocessing/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.is_alive.__code__.co_argcount == 1. is_alive takes only self as positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context'. The multiprocessing.Process attribute is retrieved through the context dispatch layer, so its __module__ is 'multiprocessing.context' not 'multiprocessing.process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__qualname__ == 'ProcessError'. ProcessError has a simple qualname (not nested inside another class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process.__init__ code attributes — extra76
#
# Wave 244 theme: Process.__init__ code attrs + Process method identity.
#
# Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'
# Process.__init__.__code__.co_flags.__class__.__name__ == 'int'
# ---------------------------------------------------------------------------

table multiprocessing_extra76.Process_init_code_attrs:
  description: "multiprocessing Process.__init__ code attribute checks in mpmore76 namespace — wave 244 theme: Process.__init__ code attrs; Process.__init__.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple in CPython); Process.__init__.__code__.co_flags.__class__.__name__=='int' (co_flags is always an int in CPython); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpmore76

  columns: [id, function, args, expected, description]
  rows:
    - [proc_init_varnames_cls, Process.__init__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true, "Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; verified with Python 3.14.3"]
    - [proc_init_flags_cls,    Process.__init__.__code__.co_flags.__class__.__name__.__eq__,    ["int"],   true, "Process.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int in CPython; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.terminate and kill code attributes — extra76
#
# Process.terminate.__code__.co_name == 'terminate'
# Process.terminate.__code__.co_argcount == 1
# Process.kill.__code__.co_name == 'kill'
# Process.kill.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table multiprocessing_extra76.Process_terminate_and_kill_code_attrs:
  description: "multiprocessing Process.terminate and kill code attribute checks in mpmore76 namespace — wave 244 theme: Process method identity; Process.terminate.__code__.co_name=='terminate'; Process.terminate.__code__.co_argcount==1 (only self); Process.kill.__code__.co_name=='kill' (added in Python 3.7); Process.kill.__code__.co_argcount==1 (only self); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpmore76a

  columns: [id, function, args, expected, description]
  rows:
    - [proc_terminate_co_name,     Process.terminate.__code__.co_name.__eq__,     ["terminate"], true, "Process.terminate.__code__.co_name == 'terminate' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [proc_terminate_co_argcount, Process.terminate.__code__.co_argcount.__eq__,  [1],           true, "Process.terminate.__code__.co_argcount == 1 — terminate takes only self as positional parameter; verified with Python 3.14.3"]
    - [proc_kill_co_name,          Process.kill.__code__.co_name.__eq__,           ["kill"],      true, "Process.kill.__code__.co_name == 'kill' — Process.kill added in Python 3.7; verified with Python 3.14.3"]
    - [proc_kill_co_argcount,      Process.kill.__code__.co_argcount.__eq__,        [1],           true, "Process.kill.__code__.co_argcount == 1 — kill takes only self as positional parameter; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.is_alive code attributes — extra76
#
# Process.is_alive.__code__.co_name == 'is_alive'
# Process.is_alive.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table multiprocessing_extra76.Process_is_alive_code_attrs:
  description: "multiprocessing Process.is_alive code attribute checks in mpmore76 namespace — wave 244 theme: Process.is_alive code attributes; Process.is_alive.__code__.co_name=='is_alive'; Process.is_alive.__code__.co_argcount==1 (only self); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpmore76b

  columns: [id, function, args, expected, description]
  rows:
    - [proc_is_alive_co_name,     Process.is_alive.__code__.co_name.__eq__,     ["is_alive"], true, "Process.is_alive.__code__.co_name == 'is_alive' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [proc_is_alive_co_argcount, Process.is_alive.__code__.co_argcount.__eq__,  [1],          true, "Process.is_alive.__code__.co_argcount == 1 — is_alive takes only self as positional parameter; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.__module__ and ProcessError.__qualname__ — extra76
# ---------------------------------------------------------------------------

table multiprocessing_extra76.Process_module_and_ProcessError_qualname:
  description: "multiprocessing Process.__module__ and ProcessError.__qualname__ checks in mpmore76 namespace — wave 244 theme: Process module identity; Process.__module__=='multiprocessing.context' (Process is accessed through the context dispatch layer, so __module__ is multiprocessing.context, not multiprocessing.process); ProcessError.__qualname__=='ProcessError' (simple qualname, not nested); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore76c

  columns: [id, function, args, expected, description]
  rows:
    - [proc_module,               Process.__module__.__eq__,             ["multiprocessing.context"], true, "Process.__module__ == 'multiprocessing.context' — Process is accessed through the context dispatch layer; verified with Python 3.14.3"]
    - [proc_error_qualname,       ProcessError.__qualname__.__eq__,      ["ProcessError"],             true, "ProcessError.__qualname__ == 'ProcessError' — simple qualname (not nested inside another class); verified with Python 3.14.3"]
    - [proc_terminate_name_cross, Process.terminate.__code__.co_name.__eq__, ["terminate"],             true, "Process.terminate.__code__.co_name == 'terminate' — cross-check; verified with Python 3.14.3"]
    - [proc_is_alive_name_cross,  Process.is_alive.__code__.co_name.__eq__,  ["is_alive"],              true, "Process.is_alive.__code__.co_name == 'is_alive' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra76
# ---------------------------------------------------------------------------

invariant multiprocessing_extra76.Process_init_varnames_class_name:
  description: "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is always a tuple in CPython code objects; NEW in extra76: first standalone co_varnames.__class__.__name__ invariant for Process.__init__ in mpmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra76.Process_init_flags_class_name:
  description: "multiprocessing.Process.__init__.__code__.co_flags.__class__.__name__.__eq__('int') returns True — co_flags is always an int in CPython code objects; NEW in extra76: first standalone co_flags.__class__.__name__ invariant for Process.__init__ in mpmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant multiprocessing_extra76.Process_terminate_co_argcount:
  description: "multiprocessing.Process.terminate.__code__.co_argcount.__eq__(1) returns True — terminate takes only self as a positional parameter; NEW in extra76: first standalone co_argcount invariant for Process.terminate in mpmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.terminate.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant multiprocessing_extra76.Process_kill_co_name:
  description: "multiprocessing.Process.kill.__code__.co_name.__eq__('kill') returns True — Process.kill was added in Python 3.7 and is a Python method in multiprocessing/process.py; NEW in extra76: first standalone co_name invariant for Process.kill in mpmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.kill.__code__.co_name.__eq__
  args: ["kill"]
  expected: true

invariant multiprocessing_extra76.Process_module:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.context') returns True — the multiprocessing.Process attribute is retrieved through the context dispatch layer so its __module__ is 'multiprocessing.context', not 'multiprocessing.process'; NEW in extra76: first standalone __module__ invariant for Process in mpmore76 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true
