spec: multiprocessing_extra317
version: ">=3.3"
backend: python_module(multiprocessing.connection)

docs: https://docs.python.org/3/library/multiprocessing.html#module-multiprocessing.connection

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers multiprocessing.connection module class/function identity: __name__, __module__, __bases__[0].__name__."
    - "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection'."
    - "multiprocessing.connection.Connection.__bases__[0].__name__ == '_ConnectionBase' — Connection subclasses the private _ConnectionBase."
    - "multiprocessing.connection.Listener.__module__ == 'multiprocessing.connection'."
    - "multiprocessing.connection.Listener.__bases__[0].__name__ == 'object' — Listener inherits directly from object."
    - "multiprocessing.connection.Client.__module__ == 'multiprocessing.connection' — Client is a function, not a class."
    - "multiprocessing.connection.Pipe.__module__ == 'multiprocessing.connection' — Pipe is a function."
    - "multiprocessing.connection.wait.__module__ == 'multiprocessing.connection' — wait is a function."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Connection — name, module, and base class
#
# multiprocessing.connection.Connection is the object representing one end of
# a pipe-based connection. It subclasses the private _ConnectionBase class,
# which provides the core framing logic.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra317.Connection.name:
  description: "multiprocessing.connection.Connection.__name__ == 'Connection'"
  category: connection_classes
  kind: python_call_eq
  function: Connection.__name__.__eq__
  args: ["Connection"]
  expected: true

invariant multiprocessing_extra317.Connection.module:
  description: "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection'"
  category: connection_classes
  kind: python_call_eq
  function: Connection.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

invariant multiprocessing_extra317.Connection.base:
  description: "multiprocessing.connection.Connection.__bases__[0].__name__ == '_ConnectionBase'"
  category: connection_classes
  kind: python_call_eq
  function: Connection.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_ConnectionBase"

# ---------------------------------------------------------------------------
# Listener — name, module, and base class
#
# multiprocessing.connection.Listener accepts incoming connections on a bound
# address. It is a plain Python class that inherits directly from object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra317.Listener.name:
  description: "multiprocessing.connection.Listener.__name__ == 'Listener'"
  category: connection_classes
  kind: python_call_eq
  function: Listener.__name__.__eq__
  args: ["Listener"]
  expected: true

invariant multiprocessing_extra317.Listener.module:
  description: "multiprocessing.connection.Listener.__module__ == 'multiprocessing.connection'"
  category: connection_classes
  kind: python_call_eq
  function: Listener.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

invariant multiprocessing_extra317.Listener.base:
  description: "multiprocessing.connection.Listener.__bases__[0].__name__ == 'object'"
  category: connection_classes
  kind: python_call_eq
  function: Listener.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Client — name and module
#
# multiprocessing.connection.Client is a module-level function (not a class)
# that connects to an address served by a Listener and returns a Connection.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra317.Client.name:
  description: "multiprocessing.connection.Client.__name__ == 'Client'"
  category: connection_functions
  kind: python_call_eq
  function: Client.__name__.__eq__
  args: ["Client"]
  expected: true

invariant multiprocessing_extra317.Client.module:
  description: "multiprocessing.connection.Client.__module__ == 'multiprocessing.connection'"
  category: connection_functions
  kind: python_call_eq
  function: Client.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

# ---------------------------------------------------------------------------
# Pipe — name and module
#
# multiprocessing.connection.Pipe is a function that creates a pair of
# Connection objects representing the two ends of a pipe.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra317.Pipe.name:
  description: "multiprocessing.connection.Pipe.__name__ == 'Pipe'"
  category: connection_functions
  kind: python_call_eq
  function: Pipe.__name__.__eq__
  args: ["Pipe"]
  expected: true

invariant multiprocessing_extra317.Pipe.module:
  description: "multiprocessing.connection.Pipe.__module__ == 'multiprocessing.connection'"
  category: connection_functions
  kind: python_call_eq
  function: Pipe.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

# ---------------------------------------------------------------------------
# wait — name and module
#
# multiprocessing.connection.wait polls a list of connection/socket objects
# for readability. It is a module-level function defined in
# multiprocessing.connection.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra317.wait.name:
  description: "multiprocessing.connection.wait.__name__ == 'wait'"
  category: connection_functions
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant multiprocessing_extra317.wait.module:
  description: "multiprocessing.connection.wait.__module__ == 'multiprocessing.connection'"
  category: connection_functions
  kind: python_call_eq
  function: wait.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true
