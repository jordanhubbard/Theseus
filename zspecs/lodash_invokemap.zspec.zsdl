spec: lodash_invokemap
version: ">=4.0.0"
backend: node(lodash.invokemap)

docs: https://lodash.com/docs/#invokeMap

provenance:
  derived_from:
    - "lodash.invokemap README — https://www.npmjs.com/package/lodash.invokemap"
    - "Test vectors verified with lodash.invokemap@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.invokemap exports the _.invokeMap function directly as module.exports."
    - "invokeMap(collection, path, args) invokes a named method on each element."
    - "String path calls the method with that name on each element."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of results from invoking the method on each element."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_invokemap.invokemap:
  kind: node_module_call_eq
  function: ~
  category: invokemap
  id_prefix: lim

  columns: [id, args, expected]
  rows:
    - [join_dash,   [[[1, 2, 3], [4, 5, 6]], "join", "-"],    ["1-2-3", "4-5-6"]]
    - [to_upper,    [["hello", "world"], "toUpperCase"],       ["HELLO", "WORLD"]]
    - [join_comma,  [[[1, 2], [3, 4]], "join", ","],          ["1,2", "3,4"]]
