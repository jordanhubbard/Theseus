spec: romanize
version: ">=1.1.1"
backend: node(romanize)

docs: https://www.npmjs.com/package/romanize

provenance:
  derived_from:
    - "romanize README — https://www.npmjs.com/package/romanize"
    - "Test vectors verified with romanize via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "romanize source"
  notes:
    - "romanize is an npm package. Install: npm install romanize"
    - "Converts an integer to its Roman numeral string representation."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table romanize.convert:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: rom

  columns: [id, args, expected]
  rows:
    - [one,    [1],    "I"]
    - [four,   [4],    "IV"]
    - [nine,   [9],    "IX"]
    - [forty2, [42],   "XLII"]
    - [y2025,  [2025], "MMXXV"]
