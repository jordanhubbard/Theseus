spec: abc_extra126
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 255 theme — abc.ABCMeta.__instancecheck__, __subclasscheck__, and abc.get_cache_token module identity. NEW in extra126: abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25); abc.ABCMeta.__instancecheck__.__class__.__name__=='function' (Python-defined in abc.py); abc.ABCMeta.__instancecheck__.__code__.co_argcount==2 (cls, instance); abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25); abc.ABCMeta.__subclasscheck__.__class__.__name__=='function'; abc.ABCMeta.__subclasscheck__.__code__.co_argcount==2 (cls, subclass); abc.abstractmethod.__module__=='abc' (len=3); abc.get_cache_token.__module__=='_abc' (len=4, C extension); abc.ABCMeta.__name__.__len__()==7; abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25. 'ABCMeta.__instancecheck__' is 25 chars: 'ABCMeta.'=8 + '__instancecheck__'=17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__.__class__.__name__ == 'function'. Unlike ABCMeta.__init__ which is inherited from type (class='wrapper_descriptor'), __instancecheck__ and __subclasscheck__ are Python-defined in Lib/abc.py (class='function'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__module__ == '_abc'. get_cache_token is a C extension function in Modules/_abc.c; its module is '_abc' (len=4, underscore-prefixed C extension) not 'abc' (len=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__subclasshook__.__qualname__.__len__() == 20. 'ABC.__subclasshook__' is 20 chars: 'ABC.'=4+'__subclasshook__'=16. ABC inherits __subclasshook__ as a built-in classmethod. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__instancecheck__ and __subclasscheck__ identity — extra126
#
# Wave 255 theme: abc ABCMeta __instancecheck__ and __subclasscheck__ identity.
#
# abc.ABCMeta.__instancecheck__.__qualname__      == 'ABCMeta.__instancecheck__' (len=25)
# abc.ABCMeta.__instancecheck__.__class__.__name__ == 'function'
# abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2
# abc.ABCMeta.__instancecheck__.__module__        == 'abc'
# abc.ABCMeta.__subclasscheck__.__qualname__      == 'ABCMeta.__subclasscheck__' (len=25)
# abc.ABCMeta.__subclasscheck__.__class__.__name__ == 'function'
# abc.ABCMeta.__subclasscheck__.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table abc_extra126.abc_abcmeta_instancecheck_subclasscheck:
  description: "abc.ABCMeta.__instancecheck__ and __subclasscheck__ method identity checks in abccheck126 namespace — wave 255 theme: ABCMeta.__instancecheck__ and __subclasscheck__ are both Python-defined in Lib/abc.py (class='function'), unlike ABCMeta.__init__ which is inherited from type (class='wrapper_descriptor'); abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__('function')==True; abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25: 'ABCMeta.'=8+'__instancecheck__'=17); abc.ABCMeta.__instancecheck__.__qualname__.__len__()==25; abc.ABCMeta.__instancecheck__.__code__.co_argcount==2 (cls, instance); abc.ABCMeta.__instancecheck__.__module__.__eq__('abc')==True (Python-defined, module is 'abc'); abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function')==True; abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__')==True (len=25: same length as __instancecheck__ — 'ABCMeta.'=8+'__subclasscheck__'=17); abc.ABCMeta.__subclasscheck__.__qualname__.__len__()==25; abc.ABCMeta.__subclasscheck__.__code__.co_argcount==2 (cls, subclass); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abccheck126

  columns: [id, function, args, expected, description]
  rows:
    - [ic_cls,       abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,      ["function"],                   true, "abc.ABCMeta.__instancecheck__.__class__.__name__ == 'function' (Python-defined in abc.py); verified with Python 3.14.3"]
    - [ic_qn_eq,     abc.ABCMeta.__instancecheck__.__qualname__.__eq__,             ["ABCMeta.__instancecheck__"],  true, "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25); verified with Python 3.14.3"]
    - [ic_qn_len,    abc.ABCMeta.__instancecheck__.__qualname__.__len__,            [],                             25,   "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 ('ABCMeta.'=8+'__instancecheck__'=17); verified with Python 3.14.3"]
    - [ic_args,      abc.ABCMeta.__instancecheck__.__code__.co_argcount.__eq__,     [2],                            true, "abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2 (cls, instance); verified with Python 3.14.3"]
    - [ic_module,    abc.ABCMeta.__instancecheck__.__module__.__eq__,               ["abc"],                        true, "abc.ABCMeta.__instancecheck__.__module__ == 'abc' (Python-defined); verified with Python 3.14.3"]
    - [sc_cls,       abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,       ["function"],                   true, "abc.ABCMeta.__subclasscheck__.__class__.__name__ == 'function' (Python-defined in abc.py); verified with Python 3.14.3"]
    - [sc_qn_eq,     abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,             ["ABCMeta.__subclasscheck__"],  true, "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25); verified with Python 3.14.3"]
    - [sc_qn_len,    abc.ABCMeta.__subclasscheck__.__qualname__.__len__,            [],                             25,   "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 (same length as __instancecheck__); verified with Python 3.14.3"]
    - [sc_args,      abc.ABCMeta.__subclasscheck__.__code__.co_argcount.__eq__,     [2],                            true, "abc.ABCMeta.__subclasscheck__.__code__.co_argcount == 2 (cls, subclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta name length and abc.get_cache_token module — extra126
#
# abc.ABCMeta.__name__.__len__()           == 7    ('ABCMeta')
# abc.abstractmethod.__module__.__len__()  == 3    ('abc')
# abc.get_cache_token.__module__           == '_abc' (len=4, C extension)
# abc.get_cache_token.__class__.__name__   == 'builtin_function_or_method'
# abc.get_cache_token.__qualname__         == 'get_cache_token'   (len=15)
# ---------------------------------------------------------------------------

table abc_extra126.abc_name_lengths_and_modules:
  description: "abc.ABCMeta name length, abc.abstractmethod module, and abc.get_cache_token module identity checks in abccheck126 namespace — wave 255 theme: abc.ABCMeta.__name__.__len__()==7 ('ABCMeta' is 7 chars: 'ABC'=3+'Meta'=4); abc.abstractmethod.__module__.__eq__('abc')==True (abstractmethod is Python-defined in Lib/abc.py, module='abc', len=3); abc.abstractmethod.__module__.__len__()==3; abc.get_cache_token.__module__.__eq__('_abc')==True (get_cache_token is C-implemented in Modules/_abc.c, module='_abc' with underscore prefix, len=4); abc.get_cache_token.__module__.__len__()==4; abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (C function, not Python function); abc.get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15: module-level function, qualname equals name); abc.get_cache_token.__qualname__.__len__()==15; the module difference between abstractmethod ('abc') and get_cache_token ('_abc') reflects that get_cache_token is implemented in C while abstractmethod is in Python; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abccheck126a

  columns: [id, function, args, expected, description]
  rows:
    - [meta_nm_len,  abc.ABCMeta.__name__.__len__,                         [],        7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'); verified with Python 3.14.3"]
    - [absm_mod_eq,  abc.abstractmethod.__module__.__eq__,                  ["abc"],   true, "abc.abstractmethod.__module__ == 'abc' (Python-defined in abc.py); verified with Python 3.14.3"]
    - [absm_mod_len, abc.abstractmethod.__module__.__len__,                 [],        3,    "abc.abstractmethod.__module__.__len__() == 3 ('abc'); verified with Python 3.14.3"]
    - [gct_mod_eq,   abc.get_cache_token.__module__.__eq__,                 ["_abc"],  true, "abc.get_cache_token.__module__ == '_abc' (C extension, underscore prefix, len=4); verified with Python 3.14.3"]
    - [gct_mod_len,  abc.get_cache_token.__module__.__len__,                [],        4,    "abc.get_cache_token.__module__.__len__() == 4 ('_abc', one more than 'abc'=3); verified with Python 3.14.3"]
    - [gct_cls,      abc.get_cache_token.__class__.__name__.__eq__,         ["builtin_function_or_method"], true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (C function); verified with Python 3.14.3"]
    - [gct_qn_eq,    abc.get_cache_token.__qualname__.__eq__,               ["get_cache_token"],            true, "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15, module-level function); verified with Python 3.14.3"]
    - [gct_qn_len,   abc.get_cache_token.__qualname__.__len__,              [],                             15,   "abc.get_cache_token.__qualname__.__len__() == 15; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__ identity — extra126
#
# abc.ABC.__subclasshook__.__qualname__             == 'ABC.__subclasshook__'  (len=20)
# abc.ABC.__subclasshook__.__class__.__name__       == 'builtin_function_or_method'
# abc.ABC.__init_subclass__.__qualname__.__len__()  == 21
# abc.ABCMeta.__name__.__len__()                    == 7
# abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25  (longest in this spec)
# abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25  (tied for longest)
# ---------------------------------------------------------------------------

table abc_extra126.abc_subclasshook_and_qualname_summary:
  description: "abc.ABC.__subclasshook__ identity and qualname length summary checks in abccheck126 namespace — wave 255 theme: abc.ABC.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True (ABC inherits __subclasshook__ as a built-in classmethod — implemented in C); abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')==True (len=20: 'ABC.'=4+'__subclasshook__'=16); abc.ABC.__subclasshook__.__qualname__.__len__()==20; abc.ABC.__init_subclass__.__qualname__.__len__()==21 (one longer than __subclasshook__ because '__init_subclass__'=17 vs '__subclasshook__'=16 — both have 'ABC.'=4 prefix); abc.ABCMeta.__name__.__len__()==7 ('ABCMeta'); abc.ABCMeta.__instancecheck__.__qualname__.__len__()==25 (the longest qualname in this spec); abc.ABCMeta.__subclasscheck__.__qualname__.__len__()==25 (tied with __instancecheck__ for longest); abc.abstractmethod.__module__.__len__()==3 (shortest module name, 'abc'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abccheck126b

  columns: [id, function, args, expected, description]
  rows:
    - [hook_cls,      abc.ABC.__subclasshook__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' (inherited built-in classmethod); verified with Python 3.14.3"]
    - [hook_qn_eq,    abc.ABC.__subclasshook__.__qualname__.__eq__,           ["ABC.__subclasshook__"],       true, "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [hook_qn_len,   abc.ABC.__subclasshook__.__qualname__.__len__,          [],                             20,   "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.'=4+'__subclasshook__'=16); verified with Python 3.14.3"]
    - [initsub_len,   abc.ABC.__init_subclass__.__qualname__.__len__,         [],                             21,   "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.'=4+'__init_subclass__'=17); verified with Python 3.14.3"]
    - [meta_nm_len7,  abc.ABCMeta.__name__.__len__,                          [],                             7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'); verified with Python 3.14.3"]
    - [ic_len25,      abc.ABCMeta.__instancecheck__.__qualname__.__len__,     [],                             25,   "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 (longest in spec); verified with Python 3.14.3"]
    - [sc_len25,      abc.ABCMeta.__subclasscheck__.__qualname__.__len__,     [],                             25,   "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 (tied for longest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra126
# ---------------------------------------------------------------------------

invariant abc_extra126.ABCMeta_instancecheck_qualname_len_25:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — ABCMeta.__instancecheck__.__qualname__ is 'ABCMeta.__instancecheck__' (25 chars: 'ABCMeta.'=8 + '__instancecheck__'=17); this is the longest method qualname in this spec (tied with __subclasscheck__); ABCMeta.__instancecheck__ is Python-defined in Lib/abc.py (class='function'), unlike ABCMeta.__init__ which is inherited from type (class='wrapper_descriptor'); __instancecheck__ is called when isinstance(obj, cls) is used on an ABCMeta-metaclassed class; ABCMeta.__instancecheck__.__code__.co_argcount is 2 (cls, instance); ABCMeta.__instancecheck__.__module__ is 'abc'; compare qualname lengths: register=16, __subclasshook__ in extra99=24, __instancecheck__=25 (NEW longest); NEW in extra126: first standalone ABCMeta.__instancecheck__ qualname length invariant in abccheck126 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra126.ABCMeta_subclasscheck_is_function:
  description: "abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function') returns True — ABCMeta.__subclasscheck__ is Python-defined in Lib/abc.py; its class is 'function' (a pure-Python function), not 'wrapper_descriptor' (which would indicate inheritance from a C extension); ABCMeta.__subclasscheck__ is called when issubclass(cls, abstract_cls) is used; __subclasscheck__.__qualname__ is 'ABCMeta.__subclasscheck__' (len=25, tied with __instancecheck__ for longest qualname in this spec); __subclasscheck__.__code__.co_argcount is 2 (cls, subclass); the pair __instancecheck__ and __subclasscheck__ customize isinstance() and issubclass() respectively for abstract base classes; NEW in extra126: first standalone ABCMeta.__subclasscheck__ class name invariant in abccheck126 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra126.get_cache_token_module_is_abc_c:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token is implemented in CPython's C extension Modules/_abc.c; its __module__ is '_abc' (len=4, underscore-prefixed C extension module), not 'abc' (len=3); this parallels asyncio.Task.__module__=='_asyncio' (also a C extension with underscore prefix); get_cache_token returns an opaque token that changes each time a new class is registered as a virtual subclass of any ABC; abc.get_cache_token.__class__.__name__ is 'builtin_function_or_method' (C function); abc.get_cache_token.__qualname__ is 'get_cache_token' (len=15); contrast with abc.abstractmethod.__module__=='abc' (Python-defined, no underscore); NEW in extra126: first standalone get_cache_token module invariant in abccheck126 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra126.ABC_subclasshook_qualname_len_20:
  description: "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — ABC.__subclasshook__.__qualname__ is 'ABC.__subclasshook__' (20 chars: 'ABC.'=4 + '__subclasshook__'=16); abc.ABC.__subclasshook__.__class__.__name__ is 'builtin_function_or_method' (inherited built-in classmethod from object); compare ABC qualname lengths: ABC.__subclasshook__=20, ABC.__init_subclass__=21 (one longer because '__init_subclass__'=17 vs '__subclasshook__'=16); compare ABCMeta qualname lengths: ABCMeta.__instancecheck__=25, ABCMeta.__subclasscheck__=25 (both longer than the ABC.* variants because 'ABCMeta.'=8 prefix vs 'ABC.'=4 prefix); NEW in extra126: first standalone ABC.__subclasshook__ qualname length invariant in abccheck126 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra126.abstractmethod_module_len_is_3:
  description: "abc.abstractmethod.__module__.__len__() == 3 — abc.abstractmethod.__module__ is 'abc' (3 chars); abc.abstractmethod is Python-defined in Lib/abc.py; this is the shortest module name length in this spec — contrast with get_cache_token.__module__=='_abc' (len=4, C extension) which is one char longer due to the underscore prefix; the 3-char 'abc' module name also equals abc.ABC.__qualname__.__len__()==3 and abc.__name__.__len__()==3 (all three are 3); abc.abstractmethod.__class__.__name__ is 'function'; abc.abstractmethod.__qualname__ is 'abstractmethod' (len=14); abc.abstractmethod.__code__.co_argcount is 1 (funcobj); NEW in extra126: first standalone abstractmethod module length invariant in abccheck126 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__module__.__len__
  args: []
  expected: 3
