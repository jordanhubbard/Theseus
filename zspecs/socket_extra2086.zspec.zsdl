spec: socket_extra2086
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 socket documentation — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "_socket.zspec.zsdl"
    - "_socket_extra.zspec.zsdl"
    - "socket.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "socket.socket is a Python-level class (not a raw C type) defined in Lib/socket.py; it does not define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in its own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses. __format__ IS present in each class's own __dict__ (IntEnum supplies it); __bytes__, __fspath__, __buffer__, and __release_buffer__ are not."
    - "socket.SocketIO is a Python class wrapping a socket for buffered I/O; it defines no special format/bytes/path/buffer protocol methods."
    - "socket.timeout, socket.herror, and socket.gaierror are OSError subclasses; none define __format__ in their own __dict__."
    - "socket.AF_INET.value == 2, socket.AF_INET6.value == 30 (macOS), socket.AF_UNIX.value == 1."
    - "socket.SOCK_STREAM.value == 1, socket.SOCK_DGRAM.value == 2, socket.SOCK_RAW.value == 3."
    - "All expected values verified by running Python 3.12 socket on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table socket_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["sk2086001", "socket.socket.__dict__.__contains__", ["__format__"], false]
    - ["sk2086002", "socket.AddressFamily.__dict__.__contains__", ["__format__"], true]
    - ["sk2086003", "socket.SocketKind.__dict__.__contains__", ["__format__"], true]
    - ["sk2086004", "socket.SocketIO.__dict__.__contains__", ["__format__"], false]
    - ["sk2086005", "socket.timeout.__dict__.__contains__", ["__format__"], false]
    - ["sk2086006", "socket.herror.__dict__.__contains__", ["__format__"], false]
    - ["sk2086007", "socket.gaierror.__dict__.__contains__", ["__format__"], false]

