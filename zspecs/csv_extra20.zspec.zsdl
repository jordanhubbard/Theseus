spec: csv_extra20
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra19.zspec.zsdl."
    - "csv_extra19 covers: __qualname__.__class__.__name__ type axis for reader, writer, DictReader, DictWriter, Dialect, Sniffer, Error; QUOTE_ALL/__class__.__qualname__; QUOTE_MINIMAL/__class__.__qualname__."
    - "csv_extra18 covers: DictReader/DictWriter/Sniffer/excel/excel_tab/Dialect __qualname__ table; get_dialect/__module__; list_dialects/__module__."
    - "csv_extra5 covers: reader/__qualname__; writer/__qualname__; Error/__qualname__."
    - "Focus: __qualname__ for DictReader, DictWriter, and Sniffer instance methods."
    - "No prior csv spec checks DictReader.__next__.__qualname__."
    - "No prior csv spec checks DictReader.__iter__.__qualname__."
    - "No prior csv spec checks DictWriter.writerow.__qualname__."
    - "No prior csv spec checks DictWriter.writeheader.__qualname__."
    - "No prior csv spec checks Sniffer.sniff.__qualname__."
    - "No prior csv spec checks Sniffer.has_header.__qualname__."
    - "csv.DictReader.__next__.__qualname__ == 'DictReader.__next__' — compound dunder method qualname."
    - "csv.DictReader.__iter__.__qualname__ == 'DictReader.__iter__' — compound dunder method qualname."
    - "csv.DictWriter.writerow.__qualname__ == 'DictWriter.writerow' — compound method qualname."
    - "csv.DictWriter.writeheader.__qualname__ == 'DictWriter.writeheader' — compound method qualname."
    - "csv.Sniffer.sniff.__qualname__ == 'Sniffer.sniff' — compound method qualname."
    - "csv.Sniffer.has_header.__qualname__ == 'Sniffer.has_header' — compound method qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DictReader method __qualname__ values
#
# csv_extra18 checks DictReader.__qualname__ == 'DictReader' for the class.
# No prior csv spec checks __qualname__ for any instance method of DictReader.
# For a pure-Python method defined in class DictReader, __qualname__ uses the
# compound dotted form 'DictReader.method'.
# ---------------------------------------------------------------------------

invariant csv_extra20.DictReader.__next__.qualname:
  description: "csv.DictReader.__next__.__qualname__ == 'DictReader.__next__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "DictReader.__next__.__qualname__.__eq__"
  args: ["DictReader.__next__"]
  expected: true

invariant csv_extra20.DictReader.__iter__.qualname:
  description: "csv.DictReader.__iter__.__qualname__ == 'DictReader.__iter__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "DictReader.__iter__.__qualname__.__eq__"
  args: ["DictReader.__iter__"]
  expected: true

# ---------------------------------------------------------------------------
# DictWriter method __qualname__ values
#
# csv_extra18 checks DictWriter.__qualname__ == 'DictWriter' for the class.
# No prior csv spec checks __qualname__ for any instance method of DictWriter.
# ---------------------------------------------------------------------------

invariant csv_extra20.DictWriter.writerow.qualname:
  description: "csv.DictWriter.writerow.__qualname__ == 'DictWriter.writerow' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "DictWriter.writerow.__qualname__.__eq__"
  args: ["DictWriter.writerow"]
  expected: true

invariant csv_extra20.DictWriter.writeheader.qualname:
  description: "csv.DictWriter.writeheader.__qualname__ == 'DictWriter.writeheader' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "DictWriter.writeheader.__qualname__.__eq__"
  args: ["DictWriter.writeheader"]
  expected: true

# ---------------------------------------------------------------------------
# Sniffer method __qualname__ values
#
# csv_extra18 checks Sniffer.__qualname__ == 'Sniffer' for the class.
# No prior csv spec checks __qualname__ for any instance method of Sniffer.
# ---------------------------------------------------------------------------

invariant csv_extra20.Sniffer.sniff.qualname:
  description: "csv.Sniffer.sniff.__qualname__ == 'Sniffer.sniff' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Sniffer.sniff.__qualname__.__eq__
  args: ["Sniffer.sniff"]
  expected: true

invariant csv_extra20.Sniffer.has_header.qualname:
  description: "csv.Sniffer.has_header.__qualname__ == 'Sniffer.has_header' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Sniffer.has_header.__qualname__.__eq__
  args: ["Sniffer.has_header"]
  expected: true

# ---------------------------------------------------------------------------
# DictReader, DictWriter, and Sniffer method __qualname__ table
#
# Consolidates all six method qualname checks into a single table.
# All six are first covered in this spec (csv_extra20).
# ---------------------------------------------------------------------------

table csv_extra20.method_qualnames:
  description: "csv DictReader/DictWriter/Sniffer method __qualname__ — compound dotted names"
  kind: python_call_eq
  category: method_attrs
  id_prefix: cmq20

  columns: [id, function, args, expected]
  rows:
    - [DictReader_next_qn,      "DictReader.__next__.__qualname__.__eq__",   ["DictReader.__next__"],    true]
    - [DictReader_iter_qn,      "DictReader.__iter__.__qualname__.__eq__",   ["DictReader.__iter__"],    true]
    - [DictWriter_writerow_qn,  "DictWriter.writerow.__qualname__.__eq__",   ["DictWriter.writerow"],    true]
    - [DictWriter_writeheader_qn, "DictWriter.writeheader.__qualname__.__eq__", ["DictWriter.writeheader"], true]
    - [Sniffer_sniff_qn,        Sniffer.sniff.__qualname__.__eq__,           ["Sniffer.sniff"],          true]
    - [Sniffer_has_header_qn,   Sniffer.has_header.__qualname__.__eq__,      ["Sniffer.has_header"],     true]
