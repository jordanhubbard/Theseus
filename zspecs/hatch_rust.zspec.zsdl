spec: hatch_rust
version: ">=3.9"
backend: rust_module(hatch_rust)

docs: https://hatch.pypa.io/

provenance:
  derived_from:
    - "https://hatch.pypa.io/ — hatch build tool"
  notes:
    - "Hatch is a modern Python project manager."
    - "hatch.cli is importable."
    - "hatch.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant hatch_rust.has_cli:
  description: "hatch.cli is importable"
  category: presence
  kind: python_call_eq
  function: hatch_has_cli
  args: []
  expected: true

invariant hatch_rust.has_project:
  description: "hatch.project is importable"
  category: presence
  kind: python_call_eq
  function: hatch_has_project
  args: []
  expected: true

invariant hatch_rust.version_nonempty:
  description: "hatch.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: hatch_version_nonempty
  args: []
  expected: true

