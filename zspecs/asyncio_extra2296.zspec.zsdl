  id_prefix: as2296

  columns: [id, function, args, expected]
  rows:
    - ["as2296011", "asyncio.Queue.__module__", [], "asyncio.queues"]
    - ["as2296012", "asyncio.Queue.__qualname__", [], "Queue"]

