  rows:
    - ["as2296013", "asyncio.AbstractEventLoop.__module__", [], "asyncio.events"]
    - ["as2296014", "asyncio.AbstractEventLoop.__qualname__", [], "AbstractEventLoop"]
    - ["as2296015", "asyncio.BaseEventLoop.__module__", [], "asyncio.base_events"]
    - ["as2296016", "asyncio.BaseEventLoop.__qualname__", [], "BaseEventLoop"]

