spec: asyncio_extra2296
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "asyncio.Task and asyncio.Future report __module__ as '_asyncio' (C extension), not 'asyncio.tasks' or 'asyncio.futures'."
    - "asyncio.Event, Lock, Semaphore report __module__ as 'asyncio.locks'."
    - "asyncio.Queue reports __module__ as 'asyncio.queues'."
    - "asyncio.AbstractEventLoop reports __module__ as 'asyncio.events'."
    - "asyncio.BaseEventLoop reports __module__ as 'asyncio.base_events'."
    - "asyncio.StreamReader reports __module__ as 'asyncio.streams'."
    - "asyncio.Protocol reports __module__ as 'asyncio.protocols'."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2296.task_future_module:
  description: "asyncio.Task and asyncio.Future __module__ and __qualname__ — C extension classes"
  kind: python_call_eq
  category: module_identity
  id_prefix: as2296

  columns: [id, function, args, expected]
  rows:
    - ["as2296001", "asyncio.Task.__module__", [], "_asyncio"]
    - ["as2296002", "asyncio.Task.__qualname__", [], "Task"]
    - ["as2296003", "asyncio.Future.__module__", [], "_asyncio"]
    - ["as2296004", "asyncio.Future.__qualname__", [], "Future"]

table asyncio_extra2296.locks_module:
  description: "asyncio.Event, Lock, Semaphore __module__ and __qualname__"
  kind: python_call_eq
  category: module_identity
  id_prefix: as2296

  columns: [id, function, args, expected]
  rows:
    - ["as2296005", "asyncio.Event.__module__", [], "asyncio.locks"]
    - ["as2296006", "asyncio.Event.__qualname__", [], "Event"]
    - ["as2296007", "asyncio.Lock.__module__", [], "asyncio.locks"]
    - ["as2296008", "asyncio.Lock.__qualname__", [], "Lock"]
    - ["as2296009", "asyncio.Semaphore.__module__", [], "asyncio.locks"]
    - ["as2296010", "asyncio.Semaphore.__qualname__", [], "Semaphore"]

table asyncio_extra2296.queue_module:
  description: "asyncio.Queue __module__ and __qualname__"
  kind: python_call_eq
