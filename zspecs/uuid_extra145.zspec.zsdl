spec: uuid_extra145
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra144.zspec.zsdl — covers uuid.UUID.__str__/__repr__/__hash__/__eq__/__int__ qualnames and qualname lengths (table + invariants)."
    - "uuid_extra143.zspec.zsdl — covers uuid.RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE string equality and lengths (table + invariants)."
    - "uuid_extra142.zspec.zsdl — covers uuid.SafeUUID.__dict__.__len__()==19 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / UUID.__dict__.__contains__('__setattr__'/'is_safe') (table + invariants)."
    - "uuid_extra140.zspec.zsdl — covers uuid.UUID.__setattr__/__getstate__/__setstate__ qualnames (table + invariants)."
    - "uuid_extra138.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') / uuid.UUID.__name__.__eq__('UUID') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra144."
    - "Wave 335 theme: uuid.UUID class property descriptor types — UUID.hex/__class__.__name__=='property' / UUID.int/__class__.__name__=='member_descriptor' / UUID.bytes/__class__.__name__=='property' / UUID.version/__class__.__name__=='property' / UUID.variant/__class__.__name__=='property' / UUID.node/__class__.__name__=='property' / UUID.time/__class__.__name__=='property'. Also uuid.uuid4.__module__=='uuid'."
    - "uuid.UUID.hex.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__name__ == 'member_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int.__class__.__name__ == 'member_descriptor' (17 chars), NOT 'property'. The UUID.int attribute is a __slots__ slot (the UUID class stores its state in __slots__ = ('int', 'is_safe', '__weakref__')). Slots create member_descriptor objects, not properties. All other UUID attributes (hex, bytes, bytes_le, fields, time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node, time, clock_seq, variant, version, urn, is_safe) that appear as properties are defined using @property. UUID.int is special — it is the single __slots__ entry holding the raw 128-bit integer."
    - "Note: uuid.UUID.hex, uuid.UUID.bytes, uuid.UUID.version, uuid.UUID.variant, uuid.UUID.node, uuid.UUID.time are all Python @property descriptors (__class__.__name__ == 'property', 8 chars). They are computed from the underlying self.int slot value. For example, UUID.hex returns self.int as a 32-char lowercase hex string; UUID.bytes returns self.int as a 16-byte big-endian bytes object."
    - "Note: uuid.uuid4.__module__ == 'uuid' (4 chars). uuid4 is a pure Python function defined in Lib/uuid.py that generates a random UUID. Its __module__ is 'uuid' — the public module. This contrasts with hashlib constructors whose __module__ is '_hashlib' (the C extension). uuid4 generates UUID4 (random UUIDs) by calling os.urandom(16) and setting the version bits."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property')
# uuid.UUID.bytes.__class__.__name__.__eq__('property')
# uuid.UUID.version.__class__.__name__.__eq__('property')
# uuid.UUID.variant.__class__.__name__.__eq__('property')
#
# Wave 335 theme: UUID computed attributes are Python @property descriptors.
#
# UUID.hex, UUID.bytes, UUID.version, and UUID.variant are all @property descriptors.
# Their __class__.__name__ is 'property' (8 chars). These attributes are computed from
# the underlying UUID.int (the __slots__ value). No prior uuid spec anchors these
# four property class names as a table under uuidprop145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra145.UUID_property_descriptors_hex_bytes_version_variant:
  description: "uuid.UUID.hex.__class__.__name__.__eq__('property')==True / UUID.bytes.__class__.__name__.__eq__('property')==True / UUID.version.__class__.__name__.__eq__('property')==True / UUID.variant.__class__.__name__.__eq__('property')==True — all four are Python @property descriptors (8 chars); computed from self.int (the __slots__ value); hex returns 32-char lowercase hex string; bytes returns 16-byte big-endian bytes; version returns UUID version int; variant returns one of the four RESERVED_*/RFC_4122 strings; first uuidprop145 anchor for these property class names"
  kind: python_call_eq
  category: identity
  id_prefix: uuidprop145

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_hex_class_property,      "UUID.hex.__class__.__name__.__eq__",     ["property"], true, "uuid.UUID.hex.__class__.__name__ == 'property' (8 chars; @property returning 32-char lowercase hex string)"]
    - [UUID_bytes_class_property,    "UUID.bytes.__class__.__name__.__eq__",   ["property"], true, "uuid.UUID.bytes.__class__.__name__ == 'property' (8 chars; @property returning 16-byte big-endian bytes)"]
    - [UUID_version_class_property,  "UUID.version.__class__.__name__.__eq__", ["property"], true, "uuid.UUID.version.__class__.__name__ == 'property' (8 chars; @property returning UUID version integer 1-5)"]
    - [UUID_variant_class_property,  "UUID.variant.__class__.__name__.__eq__", ["property"], true, "uuid.UUID.variant.__class__.__name__ == 'property' (8 chars; @property returning one of four variant strings)"]

# ---------------------------------------------------------------------------
# uuid.UUID.node.__class__.__name__.__eq__('property')
# uuid.UUID.time.__class__.__name__.__eq__('property')
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor')
#
# Wave 335 theme: UUID.node and UUID.time are properties; UUID.int is a member_descriptor.
#
# UUID.node and UUID.time are @property descriptors ('property', 8 chars).
# UUID.int is a __slots__ slot — a member_descriptor (17 chars), NOT a property.
# UUID.int stores the raw 128-bit integer. No prior uuid spec anchors UUID.node, UUID.time,
# or UUID.int class names as a table under uuidprop145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra145.UUID_node_time_property_int_member:
  description: "uuid.UUID.node.__class__.__name__.__eq__('property')==True / UUID.time.__class__.__name__.__eq__('property')==True / UUID.int.__class__.__name__.__eq__('member_descriptor')==True — UUID.node and UUID.time are @property descriptors (8 chars); UUID.int is a __slots__ member_descriptor (17 chars); UUID stores state as __slots__=('int','is_safe','__weakref__'); UUID.int is the raw 128-bit integer from which all properties are computed; 'member_descriptor' is 17 chars vs 'property' (8 chars); first uuidprop145 anchor for UUID.node/time/int class names"
  kind: python_call_eq
  category: identity
  id_prefix: uuidprop145

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_node_class_property,         "UUID.node.__class__.__name__.__eq__",  ["property"],         true, "uuid.UUID.node.__class__.__name__ == 'property' (8 chars; @property returning 48-bit node component of UUID1)"]
    - [UUID_time_class_property,         "UUID.time.__class__.__name__.__eq__",  ["property"],         true, "uuid.UUID.time.__class__.__name__ == 'property' (8 chars; @property returning 60-bit timestamp for UUID1)"]
    - [UUID_int_class_member_descriptor, "UUID.int.__class__.__name__.__eq__",   ["member_descriptor"], true, "uuid.UUID.int.__class__.__name__ == 'member_descriptor' (17 chars; __slots__ entry, NOT a @property)"]
    - [UUID_int_class_name_len_17,       "UUID.int.__class__.__name__.__len__",  [],                   17,   "uuid.UUID.int.__class__.__name__.__len__() is 17 ('member_descriptor' = 17 chars; longer than 'property'=8)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__module__.__eq__('uuid')
# uuid.UUID.hex.__class__.__name__.__len__()==8
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor')
#
# Wave 335 theme: uuid4 module identity and property/member_descriptor class name lengths.
#
# uuid.uuid4.__module__ == 'uuid' (4 chars). UUID.hex class name is 'property' (8 chars).
# UUID.int class name is 'member_descriptor' (17 chars). The difference: 17 - 8 = 9 chars.
# No prior uuid spec anchors uuid4.__module__ or these class name lengths as a table under
# uuidprop145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra145.uuid4_module_and_class_name_lengths:
  description: "uuid.uuid4.__module__.__eq__('uuid')==True / UUID.hex.__class__.__name__.__len__()==8 / UUID.int.__class__.__name__.__len__()==17 / uuid4.__module__.__len__()==4 — uuid4 is a pure Python function in uuid module (4 chars; not '_uuid' C extension); property class name is 'property' (8 chars); member_descriptor class name is 17 chars; length difference is 9; first uuidprop145 anchor for uuid4.__module__ and these class name length values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidprop145

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_module_uuid,              "uuid4.__module__.__eq__",              ["uuid"], true, "uuid.uuid4.__module__ == 'uuid' (4 chars; pure Python function in Lib/uuid.py; uses os.urandom(16) for randomness)"]
    - [UUID_hex_class_name_len_8,      "UUID.hex.__class__.__name__.__len__",  [],       8,   "uuid.UUID.hex.__class__.__name__.__len__() is 8 ('property' = 8 chars; all @property descriptors are 8 chars)"]
    - [UUID_int_class_name_len_17,     "UUID.int.__class__.__name__.__len__",  [],       17,  "uuid.UUID.int.__class__.__name__.__len__() is 17 ('member_descriptor' = 17 chars; __slots__ slot descriptor)"]
    - [uuid4_module_len_4,             "uuid4.__module__.__len__",             [],       4,   "uuid.uuid4.__module__.__len__() is 4 ('uuid' = 4 chars; contrasts with hashlib constructors' '_hashlib' = 8)"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property') — standalone
#
# uuid.UUID.hex.__class__.__name__ is 'property' (8 chars). UUID.hex is a Python @property
# that computes and returns the UUID as a 32-character lowercase hexadecimal string (without
# hyphens). For example, for UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8'), UUID.hex returns
# '6ba7b8109dad11d180b400c04fd430c8'. UUID.hex is computed from self.int (the __slots__
# value) as '%032x' % self.int. The class name 'property' (8 chars) identifies it as a
# Python-level descriptor, not a C extension type like 'member_descriptor' or 'getset_descriptor'.
# No prior uuid spec anchors UUID.hex.__class__.__name__ as a standalone under uuidprop145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra145.UUID_hex_class_property:
  description: "uuid.UUID.hex.__class__.__name__.__eq__('property') == True — 'property' (8 chars); Python @property returning 32-char lowercase hex string; computed as '%032x' % self.int; UUID('6ba7b810-...').hex == '6ba7b8109dad11d180b4...'; contrast with UUID.int which is 'member_descriptor' (17 chars); no prior uuid spec anchors this as a standalone; first standalone under uuidprop145"
  category: identity
  kind: python_call_eq
  function: UUID.hex.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') — standalone
#
# uuid.UUID.int.__class__.__name__ is 'member_descriptor' (17 chars). UUID.int is the
# single __slots__ entry that stores the 128-bit integer representation of a UUID. The
# UUID class defines __slots__ = ('int', 'is_safe', '__weakref__'), making UUID.int a
# slot descriptor (member_descriptor), not a property. The slot is the raw storage for
# the UUID value — all computed properties (hex, bytes, version, variant, node, time, etc.)
# derive their values from self.int. The 'member_descriptor' type (17 chars) is 9 chars
# longer than 'property' (8 chars). This is distinct from 'getset_descriptor' (15 chars)
# seen on C extension types like struct.Struct.size. No prior uuid spec anchors
# UUID.int.__class__.__name__ as a standalone under uuidprop145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra145.UUID_int_class_member_descriptor:
  description: "uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') == True — 17 chars; __slots__ slot descriptor (not @property); UUID.__slots__=('int','is_safe','__weakref__'); raw 128-bit integer storage; all UUID properties computed from self.int; 'member_descriptor' (17 chars) is 9 longer than 'property' (8 chars); distinct from 'getset_descriptor' (15 chars) seen on C extension types; no prior uuid spec anchors this as a standalone; first standalone under uuidprop145"
  category: identity
  kind: python_call_eq
  function: UUID.int.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__module__.__eq__('uuid') — standalone
#
# uuid.uuid4.__module__ is 'uuid' (4 chars). uuid4 is the function that generates a random
# UUID (version 4). It is defined in Lib/uuid.py as a pure Python function. Its __module__
# is 'uuid' — the public Python module name (4 chars). This contrasts with hashlib hash
# constructors whose __module__ is '_hashlib' (the C extension, 8 chars). uuid4 generates
# randomness via os.urandom(16) and sets the version bits (4) and variant bits (10) to
# produce a valid RFC 4122 version 4 UUID. No prior uuid spec anchors uuid4.__module__
# as a standalone under uuidprop145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra145.uuid4_module_eq_uuid:
  description: "uuid.uuid4.__module__.__eq__('uuid') == True — 4 chars; pure Python function in Lib/uuid.py; generates random UUID via os.urandom(16); version 4 and variant bits (10) set per RFC 4122; __module__=='uuid' (4 chars) contrasts with hashlib constructors (__module__=='_hashlib', 8 chars); no prior uuid spec anchors this as a standalone; first standalone under uuidprop145"
  category: identity
  kind: python_call_eq
  function: uuid4.__module__.__eq__
  args: ["uuid"]
  expected: true

