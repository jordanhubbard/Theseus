spec: theseus_genericpath_cr
version: ">=3.0"
backend: python_cleanroom(theseus_genericpath_cr)
blocks: genericpath

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.path.html"
  not_derived_from:
    - "CPython source: Lib/genericpath.py"
  notes:
    - "Clean-room genericpath module. Do NOT import genericpath."

error_model: python_exceptions

invariant theseus_genericpath_cr.genpath2_exists:
  description: "exists() correctly tests file existence"
  category: behavior
  kind: python_call_eq
  function: genpath2_exists
  args: []
  expected: true

invariant theseus_genericpath_cr.genpath2_commonprefix:
  description: "commonprefix() finds common path prefix"
  category: behavior
  kind: python_call_eq
  function: genpath2_commonprefix
  args: []
  expected: true

invariant theseus_genericpath_cr.genpath2_getsize:
  description: "getsize() returns file size"
  category: behavior
  kind: python_call_eq
  function: genpath2_getsize
  args: []
  expected: true
