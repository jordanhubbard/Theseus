spec: signal_extra12
version: ">=3.8"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra11.zspec.zsdl."
    - "signal_extra covers: SIG_DFL/SIG_IGN/SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM __class__.__name__."
    - "signal_extra10 covers: function __qualname__.__len__; Signals/Handlers __mro__ length and member names."
    - "signal_extra11 covers: SIGTERM/SIGHUP/SIGKILL __class__.__qualname__; SIG_DFL/SIG_IGN __class__.__qualname__; Signals/Handlers __qualname__.__len__()."
    - "This spec adds: signal.signal/__qualname__ and __module__; signal.getsignal/__qualname__ and __module__; signal.raise_signal/__qualname__ and __module__ (Python 3.8+, note __module__=='_signal' not 'signal'); signal.Signals/__module__ and signal.Handlers/__module__; signal.Signals/__bases__[0].__name__ and signal.Handlers/__bases__[0].__name__; signal.NSIG value (32 on macOS) and signal.NSIG/__class__.__name__. No prior signal spec checks __module__ on signal/getsignal/raise_signal, nor __module__ on Signals/Handlers enum classes, nor __bases__[0].__name__ on those enum classes, nor the NSIG value or type."
    - "signal.signal.__qualname__ == 'signal' — the built-in function's qualname is its simple name. signal_extra10 checks __qualname__.__len__() for signal/getsignal/etc. but no prior spec checks __qualname__.__eq__ on these functions as standalone invariants."
    - "signal.signal.__module__ == 'signal' — the built-in is exposed from the 'signal' module namespace. No prior spec checks __module__ on any signal-module function."
    - "signal.getsignal.__qualname__ == 'getsignal' — same pattern as signal.signal."
    - "signal.getsignal.__module__ == 'signal' — same module as signal.signal."
    - "signal.raise_signal.__qualname__ == 'raise_signal' — available since Python 3.8."
    - "signal.raise_signal.__module__ == '_signal' — raise_signal comes from the C extension _signal, not from the Python-level signal module. This is a notable behavioral difference from signal and getsignal."
    - "signal.Signals.__module__ == 'signal' — the Signals IntEnum class is defined in the Python-level signal module."
    - "signal.Handlers.__module__ == 'signal' — same as Signals."
    - "signal.Signals.__bases__[0].__name__ == 'IntEnum' — both enum classes inherit from IntEnum."
    - "signal.Handlers.__bases__[0].__name__ == 'IntEnum' — same as Signals."
    - "signal.NSIG == 32 — on macOS/Darwin 25.4.0 the signal number sentinel is 32. No prior signal spec checks the integer value of NSIG."
    - "signal.NSIG.__class__.__name__ == 'int' — NSIG is a plain Python int. No prior spec checks its type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# signal.signal and signal.getsignal __qualname__ and __module__
#
# signal_extra10 checks __qualname__.__len__() for signal/getsignal/etc.
# No prior spec checks __qualname__.__eq__ or __module__.__eq__ for these
# two functions as standalone invariants. Both are exposed from the 'signal'
# Python namespace, so __module__ == 'signal'.
# ---------------------------------------------------------------------------

table signal_extra12.signal_getsignal_qualnames:
  description: "signal.signal and getsignal __qualname__.__eq__ — no prior spec checks these as __eq__ invariants"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: sgqname12

  columns: [id, function, args, expected]
  rows:
    - [signal,    signal.__qualname__.__eq__,    ["signal"],    true]
    - [getsignal, getsignal.__qualname__.__eq__, ["getsignal"], true]

table signal_extra12.signal_getsignal_modules:
  description: "signal.signal and getsignal __module__ == 'signal' — no prior signal spec checks __module__ on any function"
  kind: python_call_eq
  category: function_modules
  id_prefix: sgmod12

  columns: [id, function, args, expected]
  rows:
    - [signal,    signal.__module__.__eq__,    ["signal"], true]
    - [getsignal, getsignal.__module__.__eq__, ["signal"], true]

# ---------------------------------------------------------------------------
# signal.raise_signal __qualname__ and __module__
#
# raise_signal was added in Python 3.8. Its __qualname__ is 'raise_signal'
# (simple name, matching signal and getsignal), but its __module__ is
# '_signal' — it comes from the C extension module _signal, not from the
# Python-level signal wrapper. No prior signal spec checks raise_signal's
# __qualname__ or __module__.
# ---------------------------------------------------------------------------

invariant signal_extra12.raise_signal.qualname:
  description: "signal.raise_signal.__qualname__ == 'raise_signal' — Python 3.8+, no prior spec checks this"
  category: function_qualnames
  kind: python_call_eq
  function: raise_signal.__qualname__.__eq__
  args: ["raise_signal"]
  expected: true

invariant signal_extra12.raise_signal.module:
  description: "signal.raise_signal.__module__ == '_signal' — comes from the C extension, distinct from signal/getsignal"
  category: function_modules
  kind: python_call_eq
  function: raise_signal.__module__.__eq__
  args: ["_signal"]
  expected: true

# ---------------------------------------------------------------------------
# signal.Signals and signal.Handlers __module__
#
# No prior signal spec checks __module__ on the Signals or Handlers enum
# classes. Both are defined in the Python-level 'signal' module.
# ---------------------------------------------------------------------------

table signal_extra12.enum_class_modules:
  description: "signal.Signals and signal.Handlers __module__ == 'signal' — no prior spec checks enum class __module__"
  kind: python_call_eq
  category: enum_identity
  id_prefix: ecmod12

  columns: [id, function, args, expected]
  rows:
    - [Signals,  Signals.__module__.__eq__,  ["signal"], true]
    - [Handlers, Handlers.__module__.__eq__, ["signal"], true]

# ---------------------------------------------------------------------------
# signal.Signals and signal.Handlers __bases__[0].__name__
#
# No prior signal spec checks __bases__[0].__name__ for either enum class.
# Both Signals and Handlers inherit from IntEnum.
# ---------------------------------------------------------------------------

table signal_extra12.enum_class_bases:
  description: "signal.Signals and Handlers __bases__[0].__name__ == 'IntEnum' — no prior spec checks this"
  kind: python_call_eq
  category: enum_identity
  id_prefix: ecbase12

  columns: [id, function, args, expected]
  rows:
    - [Signals,  "Signals.__bases__[0].__name__.__eq__",  ["IntEnum"], true]
    - [Handlers, "Handlers.__bases__[0].__name__.__eq__", ["IntEnum"], true]

# ---------------------------------------------------------------------------
# signal.NSIG value and type
#
# No prior signal spec checks the integer value of NSIG or its type. On
# macOS/Darwin the value is 32. NSIG is a plain Python int.
# ---------------------------------------------------------------------------

invariant signal_extra12.NSIG.value:
  description: "signal.NSIG == 32 on macOS/Darwin — no prior spec checks the NSIG integer value"
  category: module_constants
  kind: python_call_eq
  function: NSIG.__eq__
  args: [32]
  expected: true

invariant signal_extra12.NSIG.type:
  description: "signal.NSIG.__class__.__name__ == 'int' — NSIG is a plain Python int; no prior spec checks its type"
  category: module_constants
  kind: python_call_eq
  function: NSIG.__class__.__name__.__eq__
  args: ["int"]
  expected: true
