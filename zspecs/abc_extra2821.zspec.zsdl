spec: abc_extra2821
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra.zspec.zsdl — covers abstractmethod.__isabstractmethod__, ABC.__subclasshook__, ABC.__abstractmethods__, ABCMeta.__instancecheck__, get_cache_token"
    - "abc_extra2.zspec.zsdl — covers __name__, __module__, __qualname__, metaclass identity for ABC, ABCMeta, abstractmethod"
    - "abc_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "None of the abc public objects define __radd__, __rsub__, or __rmul__ in their __dict__."
    - "ABCMeta is a metaclass (type of type); ABC is the abstract base class helper; abstractmethod is a decorator."
    - "abc.abstractproperty was removed in Python 3.13; it is not covered in this spec."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta — __radd__/__rsub__/__rmul__ dict-presence checks
#
# ABCMeta is the metaclass for abstract base classes. Its __dict__ contains
# metaclass machinery (__instancecheck__, __subclasscheck__, register, etc.)
# but no reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2821.abcmeta_operator_dict:
  description: "abc.ABCMeta __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2821am

  columns: [id, function, args, expected]
  rows:
    - ["ab2821am_rad",  abc.ABCMeta.__dict__.__contains__, ["__radd__"],  false]
    - ["ab2821am_rsb",  abc.ABCMeta.__dict__.__contains__, ["__rsub__"],  false]
    - ["ab2821am_rml",  abc.ABCMeta.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# abc.ABC — __radd__/__rsub__/__rmul__ dict-presence checks
#
# ABC is the convenience helper class for creating abstract base classes via
# inheritance. Its __dict__ is minimal (only __doc__ and __abstractmethods__).
# It does not define reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2821.abc_operator_dict:
  description: "abc.ABC __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2821abc

  columns: [id, function, args, expected]
  rows:
    - ["ab2821abc_rad",  abc.ABC.__dict__.__contains__, ["__radd__"],  false]
    - ["ab2821abc_rsb",  abc.ABC.__dict__.__contains__, ["__rsub__"],  false]
    - ["ab2821abc_rml",  abc.ABC.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# abc.abstractmethod — __radd__/__rsub__/__rmul__ dict-presence checks
#
# abstractmethod is a pure-Python decorator function. Its __dict__ holds only
# __isabstractmethod__ == True and the usual function attributes. It does not
# implement reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2821.abstractmethod_operator_dict:
  description: "abc.abstractmethod __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2821abm

  columns: [id, function, args, expected]
  rows:
    - ["ab2821abm_rad",  abc.abstractmethod.__dict__.__contains__, ["__radd__"],  false]
    - ["ab2821abm_rsb",  abc.abstractmethod.__dict__.__contains__, ["__rsub__"],  false]
    - ["ab2821abm_rml",  abc.abstractmethod.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# Full cross-type matrix — ABCMeta, ABC, abstractmethod × three reflected arithmetic operator dunders
#
# Consolidates the 3×3 dict-presence check (excluding deprecated abstractproperty)
# in one table. Every cell is False: ABCMeta, ABC, and abstractmethod do not
# define +, -, or * reflected operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table abc_extra2821.all_types_radd_rsub_rmul_matrix:
  description: "Full 3×3 dict-presence matrix for abc.ABCMeta, abc.ABC, abc.abstractmethod vs __radd__/__rsub__/__rmul__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2821mx

  columns: [id, function, args, expected]
  rows:
    - ["ab2821mx_am_rad",  abc.ABCMeta.__dict__.__contains__,        ["__radd__"],  false]
    - ["ab2821mx_am_rsb",  abc.ABCMeta.__dict__.__contains__,        ["__rsub__"],  false]
    - ["ab2821mx_am_rml",  abc.ABCMeta.__dict__.__contains__,        ["__rmul__"],  false]
    - ["ab2821mx_ac_rad",  abc.ABC.__dict__.__contains__,            ["__radd__"],  false]
    - ["ab2821mx_ac_rsb",  abc.ABC.__dict__.__contains__,            ["__rsub__"],  false]
    - ["ab2821mx_ac_rml",  abc.ABC.__dict__.__contains__,            ["__rmul__"],  false]
    - ["ab2821mx_ab_rad",  abc.abstractmethod.__dict__.__contains__, ["__radd__"],  false]
    - ["ab2821mx_ab_rsb",  abc.abstractmethod.__dict__.__contains__, ["__rsub__"],  false]
    - ["ab2821mx_ab_rml",  abc.abstractmethod.__dict__.__contains__, ["__rmul__"],  false]
