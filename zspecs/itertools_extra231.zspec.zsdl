spec: itertools_extra231
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.starmap, itertools.compress, and itertools.filterfalse identity contracts."
    - "itertools.starmap.__name__ == 'starmap' — C extension type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' — starmap reports its module as 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__class__.__name__ == 'type' — starmap is a C extension type. Verified with Python 3.14.3."
    - "itertools.compress.__name__ == 'compress' — C extension type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools' — compress reports its module as 'itertools'. Verified with Python 3.14.3."
    - "itertools.compress.__class__.__name__ == 'type' — compress is a C extension type. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' — C extension type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools' — filterfalse reports its module as 'itertools'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__class__.__name__ == 'type' — filterfalse is a C extension type. Verified with Python 3.14.3."
    - "itertools.starmap.__name__.__len__() == 7 — 'starmap' has 7 characters. Verified with Python 3.14.3."
    - "itertools.compress.__name__.__len__() == 8 — 'compress' has 8 characters. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__.__len__() == 11 — 'filterfalse' has 11 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.starmap identity contracts
#
# itertools.starmap.__name__ == 'starmap'
# itertools.starmap.__qualname__ == 'starmap'
# itertools.starmap.__module__ == 'itertools'
# itertools.starmap.__name__.__len__() == 7
# itertools.starmap.__class__.__name__ == 'type'
#
# New to extra231.
# ---------------------------------------------------------------------------

table itertools_extra231.starmap_identity:
  description: "itertools.starmap identity contracts: __name__, __qualname__, __module__, name length, class type; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra231starmapid

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_name_eq,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__ == 'starmap' — starmap is a C extension type in itertoolsmodule.c that maps a function over an iterable unpacking each element as args; __name__.__eq__('starmap') returns True; new to extra231"]
    - [starmap_qualname_eq,
       starmap.__qualname__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__qualname__ == 'starmap' — starmap is a top-level C type with unqualified qualname 'starmap'; __qualname__.__eq__('starmap') returns True; new to extra231"]
    - [starmap_module_eq,
       starmap.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.starmap.__module__ == 'itertools' — starmap reports its module as 'itertools'; __module__.__eq__('itertools') returns True; new to extra231"]
    - [starmap_name_len_7,
       starmap.__name__.__len__,
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — 'starmap' has exactly 7 characters (s-t-a-r-m-a-p); __len__() returns 7; new to extra231"]
    - [starmap_class_is_type,
       starmap.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.starmap.__class__.__name__ == 'type' — starmap is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra231"]

# ---------------------------------------------------------------------------
# Table 2: itertools.compress identity contracts
#
# itertools.compress.__name__ == 'compress'
# itertools.compress.__qualname__ == 'compress'
# itertools.compress.__module__ == 'itertools'
# itertools.compress.__name__.__len__() == 8
# itertools.compress.__class__.__name__ == 'type'
#
# New to extra231.
# ---------------------------------------------------------------------------

table itertools_extra231.compress_identity:
  description: "itertools.compress identity contracts: __name__, __qualname__, __module__, name length, class type; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra231compressid

  columns: [id, function, args, expected, description]
  rows:
    - [compress_name_eq,
       compress.__name__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__name__ == 'compress' — compress is a C extension type in itertoolsmodule.c that filters elements by a boolean selector iterable; __name__.__eq__('compress') returns True; new to extra231"]
    - [compress_qualname_eq,
       compress.__qualname__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__qualname__ == 'compress' — compress is a top-level C type with unqualified qualname 'compress'; __qualname__.__eq__('compress') returns True; new to extra231"]
    - [compress_module_eq,
       compress.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.compress.__module__ == 'itertools' — compress reports its module as 'itertools'; __module__.__eq__('itertools') returns True; new to extra231"]
    - [compress_name_len_8,
       compress.__name__.__len__,
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — 'compress' has exactly 8 characters (c-o-m-p-r-e-s-s); __len__() returns 8; new to extra231"]
    - [compress_class_is_type,
       compress.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.compress.__class__.__name__ == 'type' — compress is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra231"]

# ---------------------------------------------------------------------------
# Table 3: itertools.filterfalse identity contracts
