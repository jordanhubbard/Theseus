table itertools_extra231.filterfalse_identity:
  description: "itertools.filterfalse identity contracts: __name__, __qualname__, __module__, name length, class type; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra231filterfalseid

  columns: [id, function, args, expected, description]
  rows:
    - [filterfalse_name_eq,
       filterfalse.__name__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__ == 'filterfalse' — filterfalse is a C extension type in itertoolsmodule.c that returns elements where predicate is False; __name__.__eq__('filterfalse') returns True; new to extra231"]
    - [filterfalse_qualname_eq,
       filterfalse.__qualname__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__ == 'filterfalse' — filterfalse is a top-level C type with unqualified qualname 'filterfalse'; __qualname__.__eq__('filterfalse') returns True; new to extra231"]
    - [filterfalse_module_eq,
       filterfalse.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.filterfalse.__module__ == 'itertools' — filterfalse reports its module as 'itertools'; __module__.__eq__('itertools') returns True; new to extra231"]
    - [filterfalse_name_len_11,
       filterfalse.__name__.__len__,
       [],
       11,
       "itertools.filterfalse.__name__.__len__() == 11 — 'filterfalse' has exactly 11 characters (f-i-l-t-e-r-f-a-l-s-e); __len__() returns 11; new to extra231"]
    - [filterfalse_class_is_type,
       filterfalse.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.filterfalse.__class__.__name__ == 'type' — filterfalse is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra231"]

