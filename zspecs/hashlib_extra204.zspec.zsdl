spec: hashlib_extra204
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "hashlib.__name__ == 'hashlib' — the module's own name."
    - "hashlib.__package__ == '' — top-level module, empty string package."
    - "hashlib.__spec__.name == 'hashlib' — the ModuleSpec name matches the module name."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — hashlib is a Python source file (Lib/hashlib.py)."
    - "hashlib.__doc__.__class__.__name__ == 'str' — the module docstring is a str object."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module-level dunder identity attributes — __name__ and __package__
# ---------------------------------------------------------------------------

table hashlib_extra204.module_name_attrs:
  description: "hashlib module __name__ and __package__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmod204name

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,    ["hashlib"], true, "hashlib.__name__ == 'hashlib'"]
    - [package_eq,     __package__.__eq__, [""],        true, "hashlib.__package__ == '' — top-level module has empty package string"]
    - [name_is_str,    __name__.__class__.__name__.__eq__,    ["str"], true, "hashlib.__name__ is a str object"]
    - [package_is_str, __package__.__class__.__name__.__eq__, ["str"], true, "hashlib.__package__ is a str object"]

# ---------------------------------------------------------------------------
# hashlib module-level dunder spec attributes — __spec__.name
# ---------------------------------------------------------------------------

table hashlib_extra204.module_spec_attrs:
  description: "hashlib module __spec__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmod204spec

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,       __spec__.name.__eq__,               ["hashlib"],          true, "hashlib.__spec__.name == 'hashlib'"]
    - [spec_name_is_str,   __spec__.name.__class__.__name__.__eq__, ["str"],          true, "hashlib.__spec__.name is a str object"]
    - [spec_name_eq_name,  __spec__.name.__eq__,               ["hashlib"],          true, "hashlib.__spec__.name equals hashlib.__name__"]
    - [spec_not_none,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"],        true, "hashlib.__spec__ is a ModuleSpec object"]

# ---------------------------------------------------------------------------
# hashlib module-level dunder loader and doc attributes
# ---------------------------------------------------------------------------

table hashlib_extra204.module_loader_doc_attrs:
  description: "hashlib module __loader__ and __doc__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmod204loader

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,  __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — hashlib is a Python source module"]
    - [doc_class_eq,     __doc__.__class__.__name__.__eq__,    ["str"],              true, "hashlib.__doc__.__class__.__name__ == 'str' — module docstring is a str"]
    - [doc_is_truthy,    __doc__.__class__.__name__.__eq__,    ["str"],              true, "hashlib.__doc__ is a non-None str"]
    - [loader_is_obj,    __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "hashlib.__loader__ is a SourceFileLoader instance"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant hashlib_extra204.name_eq:
  description: "hashlib.__name__ == 'hashlib'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra204.package_eq:
  description: "hashlib.__package__ == '' — top-level module, empty package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant hashlib_extra204.spec_name_eq:
  description: "hashlib.__spec__.name == 'hashlib'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra204.loader_class_name_eq:
  description: "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — hashlib is implemented as a pure-Python source file"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant hashlib_extra204.doc_class_name_eq:
  description: "hashlib.__doc__.__class__.__name__ == 'str' — the module docstring is a str"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra204.name_is_str:
  description: "hashlib.__name__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra204.package_is_str:
  description: "hashlib.__package__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __package__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra204.spec_name_is_str:
  description: "hashlib.__spec__.name.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
