spec: ssl_extra8
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl, _ssl.zspec.zsdl, _ssl_extra.zspec.zsdl, ssl_extra.zspec.zsdl, ssl_extra2.zspec.zsdl, ssl_extra3.zspec.zsdl, ssl_extra4.zspec.zsdl, ssl_extra5.zspec.zsdl, ssl_extra6.zspec.zsdl, and ssl_extra7.zspec.zsdl."
    - "Focus: __qualname__ checks for ssl classes and functions, TLSVersion enum identity checks."
    - "ssl.TLSVersion is an IntEnum; its __bases__[0].__name__ == 'IntEnum'."
    - "ssl.TLSVersion.__name__ == 'TLSVersion' — the enum class name."
    - "Exact TLSVersion .value integers depend on the OpenSSL version linked at build time and are deliberately avoided here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# qualname — major ssl classes (table)
# ---------------------------------------------------------------------------

table ssl_extra8.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [SSLContext,              SSLContext.__qualname__.__eq__,              ["SSLContext"],              true]
    - [SSLSocket,               SSLSocket.__qualname__.__eq__,               ["SSLSocket"],               true]
    - [SSLError,                SSLError.__qualname__.__eq__,                ["SSLError"],                true]
    - [create_default_context,  create_default_context.__qualname__.__eq__,  ["create_default_context"],  true]

# ---------------------------------------------------------------------------
# qualname — additional exception classes
# ---------------------------------------------------------------------------

invariant ssl_extra8.SSLCertVerificationError.qualname:
  description: "ssl.SSLCertVerificationError.__qualname__ == 'SSLCertVerificationError'"
  category: qualnames
  kind: python_call_eq
  function: SSLCertVerificationError.__qualname__.__eq__
  args: ["SSLCertVerificationError"]
  expected: true

invariant ssl_extra8.SSLZeroReturnError.qualname:
  description: "ssl.SSLZeroReturnError.__qualname__ == 'SSLZeroReturnError'"
  category: qualnames
  kind: python_call_eq
  function: SSLZeroReturnError.__qualname__.__eq__
  args: ["SSLZeroReturnError"]
  expected: true

# ---------------------------------------------------------------------------
# qualname — module-level functions
# ---------------------------------------------------------------------------

invariant ssl_extra8.wrap_socket.qualname:
  description: "ssl.wrap_socket.__qualname__ == 'wrap_socket'"
  category: qualnames
  kind: python_call_eq
  function: wrap_socket.__qualname__.__eq__
  args: ["wrap_socket"]
  expected: true

# ---------------------------------------------------------------------------
# TLSVersion enum — identity checks (no exact .value checks due to OpenSSL variance)
# ---------------------------------------------------------------------------

invariant ssl_extra8.TLSVersion.name:
  description: "ssl.TLSVersion.__name__ == 'TLSVersion'"
  category: TLSVersion
  kind: python_call_eq
  function: TLSVersion.__name__.__eq__
  args: ["TLSVersion"]
  expected: true

invariant ssl_extra8.TLSVersion.base_is_IntEnum:
  description: "ssl.TLSVersion.__bases__[0].__name__ == 'IntEnum'"
  category: TLSVersion
  kind: python_call_eq
  function: TLSVersion.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"
