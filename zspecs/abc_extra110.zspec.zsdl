spec: abc_extra110
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra109.zspec.zsdl."
    - "This spec covers: wave 255 theme — abc module function __kwdefaults__, __globals__ class name, and co_varnames attributes not covered in extra101-extra109. Prior specs covered: abstractmethod.__code__.co_qualname (extra101), abstractmethod.__code__.co_name (extra101), abstractmethod.__code__.co_argcount (extra101), update_abstractmethods.__code__.co_qualname (extra109), get_cache_token.__qualname__ string (extra97, extra101). NOT previously covered: abstractmethod.__kwdefaults__.__class__.__name__, abstractmethod.__globals__.__class__.__name__, abstractmethod.__code__.co_varnames, update_abstractmethods.__code__.co_varnames, update_abstractmethods.__kwdefaults__.__class__.__name__, update_abstractmethods.__globals__.__class__.__name__, get_cache_token.__module__.__len__(), get_cache_token.__qualname__.__len__(). NEW in extra110: abstractmethod.__kwdefaults__.__class__.__name__=='NoneType'; abstractmethod.__globals__.__class__.__name__=='dict'; abstractmethod.__code__.co_varnames.__len__()==1 (('funcobj',)); update_abstractmethods.__kwdefaults__.__class__.__name__=='NoneType'; update_abstractmethods.__globals__.__class__.__name__=='dict'; update_abstractmethods.__code__.co_varnames.__len__()==5 (('cls', 'abstracts', 'scls', 'name', 'value')); get_cache_token.__module__.__len__()==4 ('_abc'); get_cache_token.__qualname__.__len__()==15 ('get_cache_token'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__kwdefaults__ is None (no keyword-only default arguments — abstractmethod takes one positional argument 'funcobj' with no keyword defaults). abc.abstractmethod.__globals__.__class__.__name__ == 'dict' (the function's global namespace is a dict — the module-level globals for abc.py). abc.abstractmethod.__code__.co_varnames == ('funcobj',) (len=1: single local variable, the parameter name). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__code__.co_varnames == ('cls', 'abstracts', 'scls', 'name', 'value') (len=5: 1 parameter 'cls' plus 4 local variables 'abstracts', 'scls', 'name', 'value'). abc.update_abstractmethods.__kwdefaults__ is None (no keyword-only defaults). abc.get_cache_token.__module__ == '_abc' (C builtin from Modules/_abc.c; module name is '_abc' with underscore prefix, len=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token is a builtin_function_or_method (C extension, no __code__). abc.get_cache_token.__qualname__.__len__()==15 ('get_cache_token'=15). abc.get_cache_token.__module__.__len__()==4 ('_abc'=4). Compare: get_cache_token.__qualname__.__len__()==15 == abstractmethod.__qualname__.__len__()==14... wait: 'get_cache_token'=15 chars, 'abstractmethod'=14 chars. get_cache_token is 1 char longer than abstractmethod. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod __kwdefaults__, __globals__ class, and co_varnames — extra110
#
# Wave 255 theme: abstractmethod function attribute classes and co_varnames.
#
# abc.abstractmethod.__kwdefaults__.__class__.__name__  == 'NoneType'
# abc.abstractmethod.__globals__.__class__.__name__     == 'dict'
# abc.abstractmethod.__code__.co_varnames.__len__()     == 1
# ---------------------------------------------------------------------------

table abc_extra110.abc_abstractmethod_attrs:
  description: "abc.abstractmethod function attribute checks in abcattr110 namespace — wave 255 theme: abc.abstractmethod.__kwdefaults__.__class__.__name__.__eq__('NoneType')==True (abstractmethod has no keyword-only default arguments — __kwdefaults__ is None, and None.__class__.__name__=='NoneType'; this is the normal case for simple functions with no keyword-only params); abc.abstractmethod.__globals__.__class__.__name__.__eq__('dict')==True (abstractmethod.__globals__ is the module-level globals dict for abc.py — a plain dict containing all module-level names; __globals__.__class__.__name__=='dict'); abc.abstractmethod.__code__.co_varnames.__len__()==1 (co_varnames is a tuple of local variable names, including parameters; abstractmethod has exactly 1 local: 'funcobj' — the single parameter; co_varnames==('funcobj',)); abc.abstractmethod.__code__.co_varnames.__class__.__name__.__eq__('tuple')==True (co_varnames is always a tuple); abc.abstractmethod.__code__.co_argcount.__eq__(1)==True (single positional parameter — consistent with co_varnames len=1: one parameter, no other locals); abc.abstractmethod.__code__.co_name.__eq__('abstractmethod')==True (len=14); abc.abstractmethod.__code__.co_qualname.__eq__('abstractmethod')==True (co_qualname==co_name for module-level functions); abc.abstractmethod.__name__.__eq__('abstractmethod')==True (len=14); compare: co_varnames len=1 (abstractmethod has 1 local) vs update_abstractmethods co_varnames len=5 (5 locals); all abstractmethod attrs verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcattr110

  columns: [id, function, args, expected, description]
  rows:
    - [am_kwd_cls,    abc.abstractmethod.__kwdefaults__.__class__.__name__.__eq__,        ["NoneType"], true, "abstractmethod.__kwdefaults__.__class__.__name__ == 'NoneType' (no kw defaults); verified with Python 3.14.3"]
    - [am_glob_cls,   abc.abstractmethod.__globals__.__class__.__name__.__eq__,           ["dict"],     true, "abstractmethod.__globals__.__class__.__name__ == 'dict' (module globals dict); verified with Python 3.14.3"]
    - [am_var_len,    abc.abstractmethod.__code__.co_varnames.__len__,                    [],           1,    "abstractmethod.__code__.co_varnames.__len__() == 1 (single local: 'funcobj'); verified with Python 3.14.3"]
    - [am_var_cls,    abc.abstractmethod.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"],    true, "abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [am_argc,       abc.abstractmethod.__code__.co_argcount.__eq__,                     [1],          true, "abstractmethod.__code__.co_argcount == 1 (funcobj); verified with Python 3.14.3"]
    - [am_co_name,    abc.abstractmethod.__code__.co_name.__eq__,                         ["abstractmethod"], true, "abstractmethod.__code__.co_name == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_co_qn,      abc.abstractmethod.__code__.co_qualname.__eq__,                     ["abstractmethod"], true, "abstractmethod.__code__.co_qualname == 'abstractmethod' (co_qualname==co_name for module-level); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods __kwdefaults__, __globals__, and co_varnames — extra110
#
# Wave 255 theme: update_abstractmethods attribute classes and co_varnames.
#
# abc.update_abstractmethods.__kwdefaults__.__class__.__name__  == 'NoneType'
# abc.update_abstractmethods.__globals__.__class__.__name__     == 'dict'
# abc.update_abstractmethods.__code__.co_varnames.__len__()     == 5
# ---------------------------------------------------------------------------

table abc_extra110.abc_uam_attrs:
  description: "abc.update_abstractmethods function attribute checks in abcattr110 namespace — wave 255 theme: abc.update_abstractmethods.__kwdefaults__.__class__.__name__.__eq__('NoneType')==True (update_abstractmethods has no keyword-only defaults — __kwdefaults__ is None, same as abstractmethod; both abc module functions use positional-only args with no keyword defaults); abc.update_abstractmethods.__globals__.__class__.__name__.__eq__('dict')==True (same global namespace dict as abstractmethod — both are in abc.py, sharing the same module globals; __globals__.__class__.__name__=='dict'); abc.update_abstractmethods.__code__.co_varnames.__len__()==5 (co_varnames==('cls', 'abstracts', 'scls', 'name', 'value'): 1 parameter 'cls' plus 4 local variables 'abstracts', 'scls', 'name', 'value'); abc.update_abstractmethods.__code__.co_varnames.__class__.__name__.__eq__('tuple')==True; abc.update_abstractmethods.__code__.co_argcount.__eq__(1)==True (single parameter 'cls'; co_argcount counts only positional parameters, not the 4 local variables); abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods')==True (len=22); abc.update_abstractmethods.__code__.co_qualname.__eq__('update_abstractmethods')==True (co_qualname==co_name for module-level functions; from extra109); abc.update_abstractmethods.__name__.__eq__('update_abstractmethods')==True (len=22); compare: uam co_varnames len=5 vs abstractmethod co_varnames len=1 (uam has 5x more locals because it contains a loop over abstract method names); compare: uam co_argcount=1 == abstractmethod co_argcount=1 (both take exactly one positional param); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcattr110a

  columns: [id, function, args, expected, description]
  rows:
    - [uam_kwd_cls,   abc.update_abstractmethods.__kwdefaults__.__class__.__name__.__eq__,        ["NoneType"], true, "update_abstractmethods.__kwdefaults__.__class__.__name__ == 'NoneType' (no kw defaults); verified with Python 3.14.3"]
    - [uam_glob_cls,  abc.update_abstractmethods.__globals__.__class__.__name__.__eq__,           ["dict"],     true, "update_abstractmethods.__globals__.__class__.__name__ == 'dict' (shared module globals dict); verified with Python 3.14.3"]
    - [uam_var_len,   abc.update_abstractmethods.__code__.co_varnames.__len__,                    [],           5,    "update_abstractmethods.__code__.co_varnames.__len__() == 5 (cls, abstracts, scls, name, value); verified with Python 3.14.3"]
    - [uam_var_cls,   abc.update_abstractmethods.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"],    true, "update_abstractmethods.__code__.co_varnames.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [uam_argc,      abc.update_abstractmethods.__code__.co_argcount.__eq__,                     [1],          true, "update_abstractmethods.__code__.co_argcount == 1 (cls only; 4 locals not counted); verified with Python 3.14.3"]
    - [uam_co_name,   abc.update_abstractmethods.__code__.co_name.__eq__,                         ["update_abstractmethods"], true, "update_abstractmethods.__code__.co_name == 'update_abstractmethods' (len=22); verified with Python 3.14.3"]
    - [uam_name_len,  abc.update_abstractmethods.__name__.__len__,                                [],           22,   "update_abstractmethods.__name__.__len__() == 22 ('update_abstractmethods'=22); verified with Python 3.14.3"]
    - [uam_var5_gt1,  abc.update_abstractmethods.__code__.co_varnames.__len__,                    [],           5,    "update_abstractmethods co_varnames len=5 vs abstractmethod co_varnames len=1 (uam has more locals); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token module and qualname length — extra110
#
# Wave 255 theme: get_cache_token __module__.__len__() and __qualname__.__len__().
#
# abc.get_cache_token.__module__.__len__()  == 4  ('_abc')
# abc.get_cache_token.__qualname__.__len__() == 15 ('get_cache_token')
# ---------------------------------------------------------------------------

table abc_extra110.abc_get_cache_token_attrs:
  description: "abc.get_cache_token module and qualname length checks in abcattr110 namespace — wave 255 theme: abc.get_cache_token.__module__.__len__()==4 ('_abc'=4: get_cache_token is implemented in C in Modules/_abc.c and belongs to the '_abc' C extension module — note the underscore prefix, unlike abc.abstractmethod which has __module__=='abc' (len=3)); abc.get_cache_token.__module__.__eq__('_abc')==True (len=4); abc.get_cache_token.__qualname__.__len__()==15 ('get_cache_token'=15: the qualname equals the function name since it is a module-level C builtin); abc.get_cache_token.__qualname__.__eq__('get_cache_token')==True; abc.get_cache_token.__name__.__eq__('get_cache_token')==True (len=15); abc.get_cache_token.__name__.__len__()==15; type(abc.get_cache_token).__name__.__eq__('builtin_function_or_method')==True (C extension, no __code__ attribute); compare module lengths: abstractmethod.__module__=='abc' (len=3) < get_cache_token.__module__=='_abc' (len=4, 1 char longer because of underscore prefix); compare qualname lengths: abstractmethod.__qualname__.__len__()==14 < get_cache_token.__qualname__.__len__()==15 (1 char longer: 'get_cache_token'=15 > 'abstractmethod'=14); compare: update_abstractmethods.__qualname__.__len__()==22 (longest among abc module-level functions); the abc.get_cache_token function returns an opaque object that increases every time the set of abstract base classes changes (used to detect stale cache in ABCMeta implementations); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcattr110b

  columns: [id, function, args, expected, description]
  rows:
    - [gct_mod_eq,    abc.get_cache_token.__module__.__eq__,                    ["_abc"],              true, "get_cache_token.__module__ == '_abc' (C extension, underscore prefix, len=4); verified with Python 3.14.3"]
    - [gct_mod_len,   abc.get_cache_token.__module__.__len__,                   [],                    4,    "get_cache_token.__module__.__len__() == 4 ('_abc'=4); verified with Python 3.14.3"]
    - [gct_qn_eq,     abc.get_cache_token.__qualname__.__eq__,                  ["get_cache_token"],   true, "get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_qn_len,    abc.get_cache_token.__qualname__.__len__,                 [],                    15,   "get_cache_token.__qualname__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]
    - [gct_name_eq,   abc.get_cache_token.__name__.__eq__,                      ["get_cache_token"],   true, "get_cache_token.__name__ == 'get_cache_token' (len=15, name equals qualname); verified with Python 3.14.3"]
    - [gct_name_len,  abc.get_cache_token.__name__.__len__,                     [],                    15,   "get_cache_token.__name__.__len__() == 15 (same as __qualname__ len); verified with Python 3.14.3"]
    - [gct_type,      type(abc.get_cache_token).__name__.__eq__,                ["builtin_function_or_method"], true, "type(get_cache_token).__name__ == 'builtin_function_or_method' (C extension, no __code__); verified with Python 3.14.3"]
    - [am_mod_len,    abc.abstractmethod.__module__.__len__,                     [],                    3,    "abstractmethod.__module__.__len__() == 3 ('abc'=3); compare: get_cache_token module len=4 vs abstractmethod module len=3; verified with Python 3.14.3"]
    - [am_qn_len,     abc.abstractmethod.__qualname__.__len__,                  [],                    14,   "abstractmethod.__qualname__.__len__() == 14 ('abstractmethod'=14); compare: get_cache_token qn len=15 vs abstractmethod qn len=14; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra110
# ---------------------------------------------------------------------------

invariant abc_extra110.abstractmethod_kwdefaults_class_NoneType:
  description: "abc.abstractmethod.__kwdefaults__.__class__.__name__.__eq__('NoneType') returns True — abc.abstractmethod.__kwdefaults__ is None (no keyword-only default arguments); None.__class__.__name__=='NoneType'; abstractmethod is a simple single-parameter decorator function (parameter: 'funcobj') with no keyword-only params and hence __kwdefaults__==None; abc.abstractmethod.__code__.co_argcount==1 (only 'funcobj'); abc.abstractmethod.__code__.co_varnames==('funcobj',) (len=1); abc.abstractmethod.__globals__.__class__.__name__=='dict' (module globals); compare: abc.update_abstractmethods.__kwdefaults__.__class__.__name__=='NoneType' (same — both abc module functions have no keyword-only defaults); abstractmethod.__kwdefaults__ being None is consistent with its role as a decorator that simply sets funcobj.__isabstractmethod__ = True and returns funcobj; first standalone abstractmethod.__kwdefaults__ class name invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractmethod.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant abc_extra110.abstractmethod_co_varnames_len_1:
  description: "abc.abstractmethod.__code__.co_varnames.__len__() == 1 — co_varnames==('funcobj',); abstractmethod has exactly 1 local variable (the single parameter 'funcobj'); abc.abstractmethod.__code__.co_argcount==1 (co_argcount matches co_varnames len because there are no additional local variables beyond the parameter); abc.abstractmethod.__code__.co_qualname=='abstractmethod' (Python 3.11+, from extra101); abc.abstractmethod.__code__.co_name=='abstractmethod' (len=14); abc.abstractmethod.__globals__.__class__.__name__=='dict'; abc.abstractmethod.__kwdefaults__.__class__.__name__=='NoneType'; compare: abc.update_abstractmethods.__code__.co_varnames.__len__()==5 (5x more locals than abstractmethod: 'cls' + 4 loop-scope locals 'abstracts', 'scls', 'name', 'value'); co_varnames len=1 reflects the simplicity of abstractmethod: it just sets __isabstractmethod__=True on the function and returns it; first standalone abstractmethod co_varnames length invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant abc_extra110.uam_co_varnames_len_5:
  description: "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5 — co_varnames==('cls', 'abstracts', 'scls', 'name', 'value'); update_abstractmethods has 5 local variables: parameter 'cls' plus loop-scope locals 'abstracts' (set of abstract method names), 'scls' (superclass in MRO iteration), 'name' (method name), 'value' (method object); abc.update_abstractmethods.__code__.co_argcount==1 (only 'cls' is a positional parameter; the 4 others are local loop variables); abc.update_abstractmethods.__code__.co_qualname=='update_abstractmethods' (len=22, from extra109); abc.update_abstractmethods.__name__.__len__()==22; abc.update_abstractmethods.__globals__.__class__.__name__=='dict'; abc.update_abstractmethods.__kwdefaults__.__class__.__name__=='NoneType'; compare: abstractmethod co_varnames len=1 << update_abstractmethods co_varnames len=5 (5x more); the 5 locals reflect update_abstractmethods complexity: it iterates over the MRO of the class to find and reconcile abstract method names; first standalone update_abstractmethods co_varnames length invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_varnames.__len__
  args: []
  expected: 5

invariant abc_extra110.get_cache_token_module_len_4:
  description: "abc.get_cache_token.__module__.__len__() == 4 — '__module__=='_abc' (len=4: '_abc'=4 chars with underscore prefix); abc.get_cache_token is a C builtin from Modules/_abc.c whose module is '_abc', not 'abc' (unlike abc.abstractmethod whose module is 'abc' with len=3); compare: abstractmethod.__module__.__len__()==3 < get_cache_token.__module__.__len__()==4 (get_cache_token module name is 1 char longer due to underscore); type(abc.get_cache_token).__name__=='builtin_function_or_method' (no __code__); abc.get_cache_token.__qualname__.__len__()==15; abc.get_cache_token.__name__.__len__()==15; get_cache_token is the only abc public API function whose __module__ is '_abc' (with underscore) rather than 'abc'; abc.ABCMeta.__module__.__len__()==3 ('abc'); abc.ABC.__module__.__len__()==3 ('abc'); get_cache_token.__module__='_abc' uniquely identifies it as a C extension while the Python-defined functions all use __module__='abc'; first standalone get_cache_token module length invariant in abcattr110 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__len__
  args: []
  expected: 4

invariant abc_extra110.abstractmethod_globals_class_dict:
  description: "abc.abstractmethod.__globals__.__class__.__name__.__eq__('dict') returns True — abc.abstractmethod.__globals__ is the module-level globals dict for abc.py; its class is 'dict' (plain Python dict, __class__.__name__=='dict'); abc.update_abstractmethods.__globals__.__class__.__name__=='dict' (same — both functions are defined in abc.py and share the same module globals object); abc.abstractmethod.__kwdefaults__.__class__.__name__=='NoneType' (no keyword-only defaults); abc.abstractmethod.__code__.co_varnames.__len__()==1 (single local 'funcobj'); abc.abstractmethod.__code__.co_qualname=='abstractmethod' (Python 3.11+); the module globals dict contains all names defined at module level in abc.py: ABCMeta, ABC, abstractmethod, abstractclassmethod, abstractstaticmethod, abstractproperty, update_abstractmethods, get_cache_token, etc.; type(abc.abstractmethod.__globals__).__name__=='dict' gives the same result as __class__.__name__=='dict'; first standalone abstractmethod globals class name invariant in abcattr110 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractmethod.__globals__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

