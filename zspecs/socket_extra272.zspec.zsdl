spec: socket_extra272
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "socket_extra271.zspec.zsdl — covers socket module __spec__/__loader__ identity and AddressFamily enum identity."
    - "socket_extra270.zspec.zsdl — covers socket.socket __init__/__repr__/__str__ method identity and socket.timeout/error exception identity."
    - "socket_extra269.zspec.zsdl — covers socket.inet_aton/inet_ntoa/inet_pton/inet_ntop function identity."
  notes:
    - "socket.AF_INET == 2 — the IPv4 address family constant is 2 on all POSIX platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_STREAM == 1 — the stream socket type constant is 1 on all POSIX platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_DGRAM == 2 — the datagram socket type constant is 2 on all POSIX platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.IPPROTO_TCP == 6 — the TCP protocol number is 6 per IANA assignment. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.IPPROTO_UDP == 17 — the UDP protocol number is 17 per IANA assignment. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOL_SOCKET == 65535 — the socket-level option constant is 65535 on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AF_INET6 == 30 — the IPv6 address family constant is 30 on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SocketKind.__name__ == 'SocketKind' — the IntEnum subclass for socket kinds. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SocketKind.__module__ == 'socket' — SocketKind is defined in the socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' — SocketKind inherits from IntEnum, like AddressFamily. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Well-known socket address family and socket type constants
# AF_INET == 2 and SOCK_STREAM == 1 are universal POSIX values.
# SOCK_DGRAM == 2, IPPROTO_TCP == 6, IPPROTO_UDP == 17 are also universal.
# SOL_SOCKET == 65535 and AF_INET6 == 30 are macOS/Darwin-specific values.
# ---------------------------------------------------------------------------

table socket_extra272.socket_constant_values:
  description: "socket constant integer values — AF_INET==2; SOCK_STREAM==1; SOCK_DGRAM==2; IPPROTO_TCP==6; IPPROTO_UDP==17; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: behavior
  id_prefix: sockconst272

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet,       AF_INET.__eq__,      [2],  true, "socket.AF_INET == 2 — POSIX IPv4 address family constant"]
    - [sock_stream,   SOCK_STREAM.__eq__,  [1],  true, "socket.SOCK_STREAM == 1 — POSIX stream socket type constant"]
    - [sock_dgram,    SOCK_DGRAM.__eq__,   [2],  true, "socket.SOCK_DGRAM == 2 — POSIX datagram socket type constant"]
    - [ipproto_tcp,   IPPROTO_TCP.__eq__,  [6],  true, "socket.IPPROTO_TCP == 6 — IANA TCP protocol number"]
    - [ipproto_udp,   IPPROTO_UDP.__eq__,  [17], true, "socket.IPPROTO_UDP == 17 — IANA UDP protocol number"]

# ---------------------------------------------------------------------------
# socket.SocketKind IntEnum identity
# SocketKind is a Python IntEnum subclass defined in socket.py (like
# AddressFamily). SOCK_STREAM and SOCK_DGRAM are SocketKind instances.
# SOL_SOCKET and AF_INET6 are macOS/Darwin-specific integer values.
# ---------------------------------------------------------------------------

table socket_extra272.SocketKind_identity_and_extra_constants:
  description: "socket.SocketKind IntEnum identity and macOS constants — SocketKind.__name__/'SocketKind'; SocketKind.__module__/'socket'; SocketKind.__bases__[0].__name__/'IntEnum'; SOL_SOCKET==65535; AF_INET6==30; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: identity
  id_prefix: sockkind272

  columns: [id, function, args, expected, description]
  rows:
    - [sk_name,      SocketKind.__name__.__eq__,                  ["SocketKind"], true, "socket.SocketKind.__name__ == 'SocketKind' — the IntEnum subclass name for socket types"]
    - [sk_module,    SocketKind.__module__.__eq__,                ["socket"],     true, "socket.SocketKind.__module__ == 'socket' — SocketKind is defined in the socket module"]
    - [sk_bases0,    "SocketKind.__bases__[0].__name__.__eq__",   ["IntEnum"],    true, "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' — SocketKind inherits from IntEnum"]
    - [sol_socket,   SOL_SOCKET.__eq__,                           [65535],        true, "socket.SOL_SOCKET == 65535 — macOS/Darwin socket-level option constant"]
    - [af_inet6,     AF_INET6.__eq__,                             [30],           true, "socket.AF_INET6 == 30 — macOS/Darwin IPv6 address family constant"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket constants and SocketKind identity
# ---------------------------------------------------------------------------

invariant socket_extra272.AF_INET_eq:
  description: "socket.AF_INET == 2 — the IPv4 address family; universally 2 on all POSIX platforms; well-known constant from sys/socket.h; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra272.SOCK_STREAM_eq:
  description: "socket.SOCK_STREAM == 1 — the stream socket type (TCP); universally 1 on all POSIX platforms; well-known constant from sys/socket.h; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

invariant socket_extra272.SOCK_DGRAM_eq:
  description: "socket.SOCK_DGRAM == 2 — the datagram socket type (UDP); universally 2 on all POSIX platforms; well-known constant from sys/socket.h; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true

invariant socket_extra272.IPPROTO_TCP_eq:
  description: "socket.IPPROTO_TCP == 6 — the TCP protocol number; fixed by IANA assignment; universally 6 on all platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant socket_extra272.IPPROTO_UDP_eq:
  description: "socket.IPPROTO_UDP == 17 — the UDP protocol number; fixed by IANA assignment; universally 17 on all platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true

invariant socket_extra272.SocketKind_name_eq:
  description: "socket.SocketKind.__name__ == 'SocketKind' — the IntEnum subclass for socket kinds; mirrors AddressFamily pattern; defined in Lib/socket.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: SocketKind.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra272.SocketKind_module_eq:
  description: "socket.SocketKind.__module__ == 'socket' — SocketKind is defined in the socket module's Lib/socket.py; same as AddressFamily.__module__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: SocketKind.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra272.SocketKind_bases0_name_eq:
  description: "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' — SocketKind inherits from IntEnum, allowing integer comparisons with socket type constants; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "SocketKind.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

invariant socket_extra272.SOL_SOCKET_eq:
  description: "socket.SOL_SOCKET == 65535 — the socket-level option constant on macOS/Darwin; used as the level argument to getsockopt/setsockopt; value is platform-specific; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: SOL_SOCKET.__eq__
  args: [65535]
  expected: true

invariant socket_extra272.AF_INET6_eq:
  description: "socket.AF_INET6 == 30 — the IPv6 address family constant on macOS/Darwin; value 30 is macOS-specific (Linux uses 10); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true
