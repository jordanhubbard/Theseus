spec: pathlib_extra93
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra92

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra92."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path.__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/etc __code__ attributes; Path.__dict__.__contains__ for read_text/write_text/read_bytes/write_bytes/mkdir/iterdir/glob/exists/is_dir/stat; Path.__dict__.__class__.__name__; Path.__qualname__/__name__/__module__; PurePath.__dict__.__contains__ for many methods; Path.__mro__.__len__() == 3; PurePosixPath/PureWindowsPath hierarchy; PosixPath hierarchy; Path/PurePath/PosixPath __qualname__ equality; Path glob/rglob/walk/match/relative_to/with_name/with_suffix __code__ attributes."
    - "This spec covers: pathlib.Path.__dict__.__contains__ for file I/O methods (exists, stat, open, read_text, write_text, read_bytes, write_bytes); pathlib.Path.__dict__.__contains__ for directory methods (mkdir, rmdir); pathlib.Path.__dict__.__contains__ for modification methods (unlink, rename, replace); pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'."
    - "pathlib.Path.__dict__.__contains__('exists') == True — Path defines exists as a method."
    - "pathlib.Path.__dict__.__contains__('stat') == True — Path defines stat as a method."
    - "pathlib.Path.__dict__.__contains__('open') == True — Path defines open as a method."
    - "pathlib.Path.__dict__.__contains__('read_text') == True — Path defines read_text as a method."
    - "pathlib.Path.__dict__.__contains__('write_text') == True — Path defines write_text as a method."
    - "pathlib.Path.__dict__.__contains__('read_bytes') == True — Path defines read_bytes as a method."
    - "pathlib.Path.__dict__.__contains__('write_bytes') == True — Path defines write_bytes as a method."
    - "pathlib.Path.__dict__.__contains__('mkdir') == True — Path defines mkdir as a method."
    - "pathlib.Path.__dict__.__contains__('rmdir') == True — Path defines rmdir as a method."
    - "pathlib.Path.__dict__.__contains__('unlink') == True — Path defines unlink as a method."
    - "pathlib.Path.__dict__.__contains__('rename') == True — Path defines rename as a method."
    - "pathlib.Path.__dict__.__contains__('replace') == True — Path defines replace as a method."
    - "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — Path.__dict__ is a read-only mappingproxy."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__contains__ for file I/O methods
# exists, stat, open, read_text, write_text, read_bytes, write_bytes are all
# defined directly on Path (not inherited from PurePath).
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra93.Path_dict_file_io_methods:
  description: "pathlib.Path.__dict__.__contains__ for exists/stat/open/read_text/write_text/read_bytes/write_bytes"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdictmem93

  columns: [id, function, args, expected]
  rows:
    - [path_exists,      Path.__dict__.__contains__, ["exists"],      true]
    - [path_stat,        Path.__dict__.__contains__, ["stat"],        true]
    - [path_open,        Path.__dict__.__contains__, ["open"],        true]
    - [path_read_text,   Path.__dict__.__contains__, ["read_text"],   true]
    - [path_write_text,  Path.__dict__.__contains__, ["write_text"],  true]
    - [path_read_bytes,  Path.__dict__.__contains__, ["read_bytes"],  true]
    - [path_write_bytes, Path.__dict__.__contains__, ["write_bytes"], true]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__contains__ for directory methods
# mkdir and rmdir are defined on Path (not PurePath).
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra93.Path_dict_directory_methods:
  description: "pathlib.Path.__dict__.__contains__ for mkdir/rmdir (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdictmem93

  columns: [id, function, args, expected]
  rows:
    - [path_mkdir, Path.__dict__.__contains__, ["mkdir"], true]
    - [path_rmdir, Path.__dict__.__contains__, ["rmdir"], true]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__contains__ for modification methods
# unlink, rename, replace are defined on Path (not PurePath).
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra93.Path_dict_modification_methods:
  description: "pathlib.Path.__dict__.__contains__ for unlink/rename/replace (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdictmem93

  columns: [id, function, args, expected]
  rows:
    - [path_unlink,  Path.__dict__.__contains__, ["unlink"],  true]
    - [path_rename,  Path.__dict__.__contains__, ["rename"],  true]
    - [path_replace, Path.__dict__.__contains__, ["replace"], true]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__class__.__name__ and extra dict membership
# Path.__dict__ is a mappingproxy (read-only view of the class namespace).
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra93.Path_dict_class_and_extra:
  description: "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'; extra dict membership"
  kind: python_call_eq
  category: dict_identity
  id_prefix: pathlibdictmem93

  columns: [id, function, args, expected]
  rows:
    - [dict_cls_name, "Path.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra93.Path_dict.contains_exists:
  description: "pathlib.Path.__dict__.__contains__('exists') == True (Path defines exists as a method)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["exists"]
  expected: true

invariant pathlib_extra93.Path_dict.contains_read_text:
  description: "pathlib.Path.__dict__.__contains__('read_text') == True (Path defines read_text as a method)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["read_text"]
  expected: true

invariant pathlib_extra93.Path_dict.contains_mkdir:
  description: "pathlib.Path.__dict__.__contains__('mkdir') == True (Path defines mkdir as a method)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["mkdir"]
  expected: true

invariant pathlib_extra93.Path_dict.contains_rename:
  description: "pathlib.Path.__dict__.__contains__('rename') == True (Path defines rename as a method)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["rename"]
  expected: true

invariant pathlib_extra93.Path_dict.class_name_is_mappingproxy:
  description: "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' (Path.__dict__ is a read-only mappingproxy)"
  category: dict_identity
  kind: python_call_eq
  function: "Path.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true
