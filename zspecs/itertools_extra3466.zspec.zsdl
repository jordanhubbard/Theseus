spec: it3466
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (it3466): __iter__, __next__, __len__ dict-presence checks for itertools types."
    - "All 18 itertools iterator types define __iter__ and __next__ in their own __dict__ (true): itertools types implement the full iterator protocol — they are both iterable and iterators."
    - "No itertools type defines __len__ in its own __dict__ (false): itertools iterators are lazy sequences with unbounded or unknown length."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

