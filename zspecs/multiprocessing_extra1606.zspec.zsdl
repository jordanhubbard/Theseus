spec: multiprocessing_extra1606
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "multiprocessing.Process is pure Python and does NOT declare __slots__; instances have __dict__ via BaseProcess which holds the __dict__ getset_descriptor"
    - "multiprocessing.pool.Pool is pure Python with no __slots__; it has __dict__ and __weakref__ descriptors in its own class dict"
    - "All multiprocessing exception classes inherit from Exception hierarchy and do not declare __slots__"
    - "Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

table multiprocessing_extra1606.process_slots:
  description: "multiprocessing.Process and pool.Pool: no __slots__; instances have __dict__ via BaseProcess or own __dict__ descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1606pr

  columns: [id, function, args, expected]
  rows:
    - ["mp1606pr001", "multiprocessing.Process.__dict__.__contains__", ["__slots__"], false]
    - ["mp1606pr002", "multiprocessing.Process.__dict__.__contains__", ["__dict__"], false]
    - ["mp1606pr003", "multiprocessing.Process.__module__.__eq__", ["multiprocessing.context"], true]
    - ["mp1606pr004", "multiprocessing.Process.__name__.__eq__", ["Process"], true]
    - ["mp1606pr005", "multiprocessing.Process.__bases__.__len__", [], 1]
    - ["mp1606pr006", "multiprocessing.process.BaseProcess.__name__.__eq__", ["BaseProcess"], true]
    - ["mp1606pr007", "multiprocessing.Process.__dict__.__contains__", ["_start_method"], true]
    - ["mp1606pr008", "multiprocessing.Process.__dict__.__contains__", ["_Popen"], true]
    - ["mp1606pr009", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__slots__"], false]
    - ["mp1606pr010", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__dict__"], true]
    - ["mp1606pr011", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__weakref__"], true]
    - ["mp1606pr012", "type(multiprocessing.process.BaseProcess.__dict__[\"__dict__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["mp1606pr013", "type(multiprocessing.process.BaseProcess.__dict__[\"__weakref__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["mp1606pr014", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["start"], true]
    - ["mp1606pr015", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["run"], true]
    - ["mp1606pr016", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["join"], true]
    - ["mp1606pr017", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["terminate"], true]
    - ["mp1606pr018", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["is_alive"], true]
    - ["mp1606pr019", "multiprocessing.pool.Pool.__dict__.__contains__", ["__slots__"], false]
    - ["mp1606pr020", "multiprocessing.pool.Pool.__dict__.__contains__", ["__dict__"], true]
    - ["mp1606pr021", "multiprocessing.pool.Pool.__dict__.__contains__", ["__weakref__"], true]
    - ["mp1606pr022", "type(multiprocessing.pool.Pool.__dict__[\"__dict__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["mp1606pr023", "type(multiprocessing.pool.Pool.__dict__[\"__weakref__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["mp1606pr024", "multiprocessing.pool.Pool.__dict__.__contains__", ["apply"], true]
    - ["mp1606pr025", "multiprocessing.pool.Pool.__dict__.__contains__", ["map"], true]
    - ["mp1606pr026", "multiprocessing.pool.Pool.__dict__.__contains__", ["close"], true]
    - ["mp1606pr027", "multiprocessing.pool.Pool.__dict__.__contains__", ["terminate"], true]
    - ["mp1606pr028", "multiprocessing.pool.Pool.__dict__.__contains__", ["join"], true]
    - ["mp1606pr029", "multiprocessing.pool.Pool.__module__.__eq__", ["multiprocessing.pool"], true]
    - ["mp1606pr030", "issubclass(multiprocessing.Process, multiprocessing.process.BaseProcess).__bool__", [], true]

table multiprocessing_extra1606.exceptions_no_slots:
  description: "multiprocessing exception classes are pure Python and do not declare __slots__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1606xc

  columns: [id, function, args, expected]
  rows:
    - ["mp1606xc001", "multiprocessing.ProcessError.__dict__.__contains__", ["__slots__"], false]
    - ["mp1606xc002", "multiprocessing.ProcessError.__name__.__eq__", ["ProcessError"], true]
    - ["mp1606xc003", "issubclass(multiprocessing.ProcessError, Exception).__bool__", [], true]
    - ["mp1606xc004", "multiprocessing.ProcessError.__dict__.__contains__", ["__dict__"], false]
    - ["mp1606xc005", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__slots__"], false]
    - ["mp1606xc006", "multiprocessing.AuthenticationError.__name__.__eq__", ["AuthenticationError"], true]
    - ["mp1606xc007", "issubclass(multiprocessing.AuthenticationError, multiprocessing.ProcessError).__bool__", [], true]
    - ["mp1606xc008", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__dict__"], false]
    - ["mp1606xc009", "multiprocessing.TimeoutError.__dict__.__contains__", ["__slots__"], false]
    - ["mp1606xc010", "multiprocessing.TimeoutError.__name__.__eq__", ["TimeoutError"], true]
    - ["mp1606xc011", "issubclass(multiprocessing.TimeoutError, multiprocessing.ProcessError).__bool__", [], true]
    - ["mp1606xc012", "multiprocessing.TimeoutError.__dict__.__contains__", ["__dict__"], false]
    - ["mp1606xc013", "multiprocessing.BufferTooShort.__dict__.__contains__", ["__slots__"], false]
    - ["mp1606xc014", "multiprocessing.BufferTooShort.__name__.__eq__", ["BufferTooShort"], true]
    - ["mp1606xc015", "issubclass(multiprocessing.BufferTooShort, multiprocessing.ProcessError).__bool__", [], true]
    - ["mp1606xc016", "multiprocessing.BufferTooShort.__dict__.__contains__", ["__dict__"], false]
    - ["mp1606xc017", "multiprocessing.ProcessError.__bases__.__len__", [], 1]
    - ["mp1606xc018", "multiprocessing.AuthenticationError.__bases__.__len__", [], 1]
    - ["mp1606xc019", "multiprocessing.TimeoutError.__bases__.__len__", [], 1]
    - ["mp1606xc020", "multiprocessing.BufferTooShort.__bases__.__len__", [], 1]
    - ["mp1606xc021", "multiprocessing.ProcessError.__dict__.__contains__", ["__static_attributes__"], true]
    - ["mp1606xc022", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__static_attributes__"], true]
    - ["mp1606xc023", "multiprocessing.TimeoutError.__dict__.__contains__", ["__static_attributes__"], true]
    - ["mp1606xc024", "multiprocessing.BufferTooShort.__dict__.__contains__", ["__static_attributes__"], true]
    - ["mp1606xc025", "multiprocessing.ProcessError.__dict__.__contains__", ["__firstlineno__"], true]
