spec: object_hash
version: ">=3.0.0"
backend: node(object-hash)

docs: https://github.com/puleos/object-hash#readme

provenance:
  derived_from:
    - "object-hash README — https://github.com/puleos/object-hash#readme"
    - "Test vectors verified with object-hash@3.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-hash source"
  notes:
    - "object-hash exports the hash function as module.exports."
    - "hash(value) produces a deterministic SHA1 hex digest of any JS value."
    - "Key order is normalized, so {a:1,b:2} and {b:2,a:1} produce the same hash."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns hex string. No errors for valid JS values."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_hash.hash:
  kind: node_module_call_eq
  function: ~
  category: hash
  id_prefix: oh

  columns: [id, args, expected]
  rows:
    - [empty_obj,  [{}],       "323217f643c3e3f1fe7532e72ac01bb0748c97be"]
    - [with_key,   [{"a": 1}], "ca1a41f90da606b052ecf10c8286817813bc8861"]
    - [string,     ["hello"],  "f3584f1b4c5b81a19f1849be114ddbc532dc77f7"]
