spec: object_hash
version: ">=3.0.0"
backend: node(object-hash)

docs: https://www.npmjs.com/package/object-hash

provenance:
  derived_from:
    - "object-hash README — https://www.npmjs.com/package/object-hash"
    - "Test vectors verified with object-hash via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-hash source"
  notes:
    - "object-hash is an npm package. Install: npm install object-hash"
    - "hash(value) returns a deterministic SHA1 hash of any JavaScript value."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns hex SHA1 hash string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_hash.hash:
  kind: node_module_call_eq
  function: ~
  category: hash
  id_prefix: objhash

  columns: [id, args, expected]
  rows:
    - [object, [{"a": 1, "b": 2}], "214e9967a58b9eb94f4348d001233ab1b8b67a17"]
    - [array,  [[1, 2, 3]],         "a2fc48da101b2469cbb9b3e4c38e01e0c45ba127"]
    - [string, ["hello"],           "f3584f1b4c5b81a19f1849be114ddbc532dc77f7"]

