spec: unidecode_rust
version: ">=3.9"
backend: rust_module(unidecode_rust)

docs: https://pypi.org/project/Unidecode/

provenance:
  derived_from:
    - "https://pypi.org/project/Unidecode/ — Unidecode library documentation"
  not_derived_from:
    - "unidecode source: unidecode/__init__.py"
  notes:
    - "Unidecode transliterates Unicode text to closest ASCII representation."
    - "unidecode('café') == 'cafe' — accent removal."
    - "unidecode('Ångström') == 'Angstrom'."
    - "unidecode('Привет') == 'Privet' — Cyrillic to Latin."
    - "unidecode('こんにちは') — Japanese hiragana to ASCII phonetic."
    - "unidecode('München') == 'Munchen'."
    - "unidecode('naïve') == 'naive'."
    - "All test vectors verified against Unidecode 1.3.8."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# unidecode — transliterate Unicode to ASCII
table unidecode_rust.transliterate.vectors:
  kind: python_call_eq
  category: transliterate
  id_prefix: uni_tr
  function: unidecode

  columns: [id, args, expected]
  rows:
    - [cafe,     ["café"],     "cafe"]
    - [naive,    ["naïve"],    "naive"]
    - [munchen,  ["München"],  "Munchen"]
    - [angstrom, ["Ångström"], "Angstrom"]

# is_ascii after unidecode
table unidecode_rust.ascii.check:
  kind: python_call_eq
  category: ascii
  id_prefix: uni_ascii
  function: unidecode_is_ascii

  columns: [id, args, expected]
  rows:
    - [cafe,    ["café"],  true]
    - [hello,   ["hello"], true]
    - [cyrillic,["Привет"],true]

# unidecode length is reasonable
invariant unidecode_rust.length.cafe:
  description: "unidecode('café') has len 4"
  category: length
  kind: python_call_eq
  function: unidecode_len
  args: ["café"]
  expected: 4

invariant unidecode_rust.length.naive:
  description: "unidecode('naïve') has len 5"
  category: length
  kind: python_call_eq
  function: unidecode_len
  args: ["naïve"]
  expected: 5

