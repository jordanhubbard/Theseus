spec: threading_extra2266
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of threading classes."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.local, threading.Barrier, threading.Timer: all protocol keys absent from class __dict__."
    - "threading.Lock is a factory function (type) — its __dict__ also has no pickling/copy keys."
    - "threading.RLock is a factory function (type) — its __dict__ also has no pickling/copy keys."
    - "The actual lock primitive types (_thread.lock and _thread.RLock) likewise have no pickle or copy protocol keys in their __dict__."
    - "No threading synchronization primitive or thread management class defines any pickle/copy/sizeof protocol in its class __dict__; they rely entirely on object-inherited defaults."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra2266.thread_event_condition_pickle:
  description: "threading.Thread, threading.Event, threading.Condition pickle/copy protocol dict-presence — all absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2266

  columns: [id, function, args, expected]
  rows:
    - ["th2266001", "threading.Thread.__dict__.__contains__", ["__reduce__"], false]
    - ["th2266002", "threading.Thread.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2266003", "threading.Thread.__dict__.__contains__", ["__getstate__"], false]
    - ["th2266004", "threading.Thread.__dict__.__contains__", ["__setstate__"], false]
