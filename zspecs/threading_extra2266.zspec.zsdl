    - ["th2266014", "threading.Event.__dict__.__contains__", ["__setstate__"], false]
    - ["th2266015", "threading.Event.__dict__.__contains__", ["__copy__"], false]
    - ["th2266016", "threading.Event.__dict__.__contains__", ["__deepcopy__"], false]
    - ["th2266017", "threading.Condition.__dict__.__contains__", ["__reduce__"], false]
    - ["th2266018", "threading.Condition.__dict__.__contains__", ["__getstate__"], false]
    - ["th2266019", "threading.Condition.__dict__.__contains__", ["__setstate__"], false]
    - ["th2266020", "threading.Condition.__dict__.__contains__", ["__copy__"], false]
    - ["th2266021", "threading.Condition.__dict__.__contains__", ["__deepcopy__"], false]

