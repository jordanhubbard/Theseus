spec: re_extra112
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra111.zspec.zsdl."
    - "This spec covers: re.Match method class names and qualnames for group, groups, groupdict, start, end, and span."
    - "All re.Match methods at the class level have type 'method_descriptor' (C extension methods from _sre.c)."
    - "re.Match.group.__qualname__ == 'Match.group' (len 11); type 'method_descriptor'."
    - "re.Match.groups.__qualname__ == 'Match.groups' (len 12); type 'method_descriptor'."
    - "re.Match.groupdict.__qualname__ == 'Match.groupdict' (len 15); type 'method_descriptor'."
    - "re.Match.start.__qualname__ == 'Match.start' (len 11); type 'method_descriptor'."
    - "re.Match.end.__qualname__ == 'Match.end' (len 9; shortest Match method qualname); type 'method_descriptor'."
    - "re.Match.span.__qualname__ == 'Match.span' (len 10); type 'method_descriptor'."
    - "group and start share the same qualname length of 11 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match class-level method descriptor types
# All re.Match methods (group, groups, groupdict, start, end, span) are
# 'method_descriptor' at the class level — C extension tp_methods entries.
# This is the same pattern seen for re.Pattern methods in re_extra111.
# ---------------------------------------------------------------------------

table re_extra112.Match_class_method_types:
  description: "re.Match class-level method types: group/groups/groupdict/start/end/span are all 'method_descriptor' when accessed on the class"
  kind: python_call_eq
  category: class_names
  id_prefix: rematch112a

  columns: [id, function, args, expected, description]
  rows:
    - [match_group_type,     "Match.group.__class__.__name__.__eq__",     ["method_descriptor"], true,  "type(re.Match.group).__name__ == 'method_descriptor' (C extension unbound descriptor on the class)"]
    - [match_groups_type,    "Match.groups.__class__.__name__.__eq__",    ["method_descriptor"], true,  "type(re.Match.groups).__name__ == 'method_descriptor'"]
    - [match_groupdict_type, "Match.groupdict.__class__.__name__.__eq__", ["method_descriptor"], true,  "type(re.Match.groupdict).__name__ == 'method_descriptor'"]
    - [match_start_type,     "Match.start.__class__.__name__.__eq__",     ["method_descriptor"], true,  "type(re.Match.start).__name__ == 'method_descriptor'"]
    - [match_end_type,       "Match.end.__class__.__name__.__eq__",       ["method_descriptor"], true,  "type(re.Match.end).__name__ == 'method_descriptor'"]
    - [match_span_type,      "Match.span.__class__.__name__.__eq__",      ["method_descriptor"], true,  "type(re.Match.span).__name__ == 'method_descriptor'"]
    - [match_group_not_func, "Match.group.__class__.__name__.__eq__",     ["function"],          false, "type(re.Match.group).__name__ != 'function' (Match.group is a C extension method_descriptor, not a Python function)"]
    - [match_end_not_builtin,"Match.end.__class__.__name__.__eq__",       ["builtin_function_or_method"], false, "type(re.Match.end).__name__ != 'builtin_function_or_method' (unbound descriptors on C types are 'method_descriptor', not 'builtin_function_or_method')"]

# ---------------------------------------------------------------------------
# re.Match.group, groups, groupdict qualnames and lengths
# group: 'Match.group' (11 chars).
# groups: 'Match.groups' (12 chars).
# groupdict: 'Match.groupdict' (15 chars).
# All use 'Match.' prefix reflecting the _sre.SRE_Match / Match C type.
# ---------------------------------------------------------------------------

table re_extra112.Match_group_groups_groupdict_qualnames:
  description: "re.Match group/groups/groupdict __qualname__: group='Match.group'(11), groups='Match.groups'(12), groupdict='Match.groupdict'(15)"
  kind: python_call_eq
  category: qualnames
  id_prefix: rematch112b

  columns: [id, function, args, expected, description]
  rows:
    - [group_qn_eq,      "Match.group.__qualname__.__eq__",      ["Match.group"],     true,  "re.Match.group.__qualname__ == 'Match.group' (returns one or more subgroups of the match)"]
    - [group_qn_len,     "Match.group.__qualname__.__len__",     [],                  11,    "re.Match.group.__qualname__.__len__() == 11 ('Match.group' has 11 chars)"]
    - [groups_qn_eq,     "Match.groups.__qualname__.__eq__",     ["Match.groups"],    true,  "re.Match.groups.__qualname__ == 'Match.groups' (returns a tuple of all subgroups)"]
    - [groups_qn_len,    "Match.groups.__qualname__.__len__",    [],                  12,    "re.Match.groups.__qualname__.__len__() == 12 ('Match.groups' has 12 chars; one longer than group)"]
    - [groupdict_qn_eq,  "Match.groupdict.__qualname__.__eq__",  ["Match.groupdict"], true,  "re.Match.groupdict.__qualname__ == 'Match.groupdict' (returns dict of all named subgroups)"]
    - [groupdict_qn_len, "Match.groupdict.__qualname__.__len__", [],                  15,    "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 chars; longest group-related method qualname)"]
    - [group_lt_groups,  "Match.group.__qualname__.__len__.__lt__",  [12],            true,  "len('Match.group') < len('Match.groups') (11 < 12)"]
    - [groups_lt_groupdict, "Match.groups.__qualname__.__len__.__lt__", [15],         true,  "len('Match.groups') < len('Match.groupdict') (12 < 15)"]

# ---------------------------------------------------------------------------
# re.Match.start, end, span qualnames and lengths
# start: 'Match.start' (11 chars; same length as group).
# end: 'Match.end' (9 chars; shortest Match method qualname).
# span: 'Match.span' (10 chars).
# All use 'Match.' prefix.
# ---------------------------------------------------------------------------

table re_extra112.Match_start_end_span_qualnames:
  description: "re.Match start/end/span __qualname__: start='Match.start'(11), end='Match.end'(9), span='Match.span'(10); end is the shortest Match method qualname"
  kind: python_call_eq
  category: qualnames
  id_prefix: rematch112c

  columns: [id, function, args, expected, description]
  rows:
    - [start_qn_eq,     "Match.start.__qualname__.__eq__",     ["Match.start"],  true,  "re.Match.start.__qualname__ == 'Match.start' (returns the start index of the match or group)"]
    - [start_qn_len,    "Match.start.__qualname__.__len__",    [],               11,    "re.Match.start.__qualname__.__len__() == 11 ('Match.start' has 11 chars; same length as Match.group)"]
    - [end_qn_eq,       "Match.end.__qualname__.__eq__",       ["Match.end"],    true,  "re.Match.end.__qualname__ == 'Match.end' (returns the end index of the match or group; shortest Match method qualname)"]
    - [end_qn_len,      "Match.end.__qualname__.__len__",      [],               9,     "re.Match.end.__qualname__.__len__() == 9 ('Match.end' has 9 chars; shortest Match method qualname)"]
    - [span_qn_eq,      "Match.span.__qualname__.__eq__",      ["Match.span"],   true,  "re.Match.span.__qualname__ == 'Match.span' (returns a tuple (start, end) of the match)"]
    - [span_qn_len,     "Match.span.__qualname__.__len__",     [],               10,    "re.Match.span.__qualname__.__len__() == 10 ('Match.span' has 10 chars)"]
    - [start_eq_group_len, "Match.start.__qualname__.__len__.__eq__", [11],      true,  "len('Match.start') == len('Match.group') == 11 (start and group share identical qualname length)"]
    - [end_lt_span,     "Match.end.__qualname__.__len__.__lt__", [10],           true,  "len('Match.end') < len('Match.span') (9 < 10; end is the shortest Match method qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra112.Match.group_type_method_descriptor:
  description: "type(re.Match.group).__name__ == 'method_descriptor' (when accessed on the class, Match.group is a C extension method_descriptor from _sre.c; when accessed on an instance m.group it becomes a 'builtin_method' — a bound C extension method; this mirrors the same type distinction seen for Pattern methods)"
  category: class_names
  kind: python_call_eq
  function: "Match.group.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

invariant re_extra112.Match.group_qualname_len:
  description: "re.Match.group.__qualname__.__len__() == 11 ('Match.group' has 11 characters; the 'Match.' prefix is 6 chars and 'group' adds 5; group shares this length with Match.start at 11 chars; contrast with Match.end at 9 (shortest) and Match.groupdict at 15 (longest group-method))"
  category: qualnames
  kind: python_call_eq
  function: "Match.group.__qualname__.__len__"
  args: []
  expected: 11

invariant re_extra112.Match.end_qualname_len:
  description: "re.Match.end.__qualname__.__len__() == 9 ('Match.end' has 9 characters; it is the shortest Match method qualname among the six examined — group(11)/groups(12)/groupdict(15)/start(11)/end(9)/span(10); 'Match.' (6) + 'end' (3) == 9)"
  category: qualnames
  kind: python_call_eq
  function: "Match.end.__qualname__.__len__"
  args: []
  expected: 9

invariant re_extra112.Match.groupdict_qualname_len:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 characters; it is the longest Match method qualname among the six examined; 'Match.' (6) + 'groupdict' (9) == 15; groupdict returns a dict mapping group names to their captured strings)"
  category: qualnames
  kind: python_call_eq
  function: "Match.groupdict.__qualname__.__len__"
  args: []
  expected: 15

invariant re_extra112.Match.span_qualname_len:
  description: "re.Match.span.__qualname__.__len__() == 10 ('Match.span' has 10 characters; 'Match.' (6) + 'span' (4) == 10; span is between end (9 chars, shortest) and group/start (11 chars) in length; span returns a 2-tuple of (start, end) indices)"
  category: qualnames
  kind: python_call_eq
  function: "Match.span.__qualname__.__len__"
  args: []
  expected: 10
