spec: uuid_extra1321
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for uuid types."
    - "uuid.UUID.__repr__ is defined as a pure-Python function in Lib/uuid.py."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' and __class__.__name__ == 'function'."
    - "uuid.UUID.__str__ is also defined in Lib/uuid.py: __qualname__ == 'UUID.__str__', class 'function'."
    - "uuid.UUID.__hash__ is defined in Lib/uuid.py: __qualname__ == 'UUID.__hash__', class 'function'."
    - "uuid.SafeUUID is an Enum subclass; it inherits __repr__ from Enum: __qualname__ == 'Enum.__repr__'."
    - "uuid.SafeUUID.__repr__.__class__.__name__ == 'function' (Enum.__repr__ is a pure-Python function)."
    - "uuid.SafeUUID.__str__.__qualname__ == 'Enum.__str__' (inherited from Enum, also a Python function)."
    - "repr(uuid.UUID).__class__.__name__ == 'str' — repr of class object always returns str."
    - "repr(uuid.SafeUUID).__class__.__name__ == 'str' — same for Enum subclass."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra1321.UUID_repr_str_qualnames:
  description: "uuid.UUID __repr__ and __str__ qualname identity checks: both are pure-Python functions defined in Lib/uuid.py"
  kind: python_call_eq
  category: identity
  id_prefix: uu1321rq
  columns: [id, function, args, expected]
  rows:
    - [uu1321rq001, uuid.UUID.__repr__.__qualname__.__eq__,       ["UUID.__repr__"],  true]
    - [uu1321rq002, uuid.UUID.__repr__.__class__.__name__.__eq__, ["function"],       true]
    - [uu1321rq003, uuid.UUID.__str__.__qualname__.__eq__,        ["UUID.__str__"],   true]
    - [uu1321rq004, uuid.UUID.__str__.__class__.__name__.__eq__,  ["function"],       true]
    - [uu1321rq005, uuid.UUID.__hash__.__qualname__.__eq__,       ["UUID.__hash__"],  true]
    - [uu1321rq006, uuid.UUID.__hash__.__class__.__name__.__eq__, ["function"],       true]

table uuid_extra1321.SafeUUID_repr_str_inheritance:
  description: "uuid.SafeUUID __repr__ and __str__ inherited from Enum: qualname and class checks"
  kind: python_call_eq
  category: identity
  id_prefix: uu1321sq
  columns: [id, function, args, expected]
  rows:
    - [uu1321sq001, uuid.SafeUUID.__repr__.__qualname__.__eq__,       ["Enum.__repr__"],  true]
    - [uu1321sq002, uuid.SafeUUID.__repr__.__class__.__name__.__eq__, ["function"],       true]
    - [uu1321sq003, uuid.SafeUUID.__str__.__qualname__.__eq__,        ["Enum.__str__"],   true]
    - [uu1321sq004, uuid.SafeUUID.__str__.__class__.__name__.__eq__,  ["function"],       true]
    - [uu1321sq005, uuid.UUID.__repr__.__qualname__.__eq__,           ["UUID.__repr__"],  true]
    - [uu1321sq006, uuid.UUID.__str__.__qualname__.__eq__,            ["UUID.__str__"],   true]

table uuid_extra1321.repr_of_class_objects_returns_str:
  description: "repr() called on uuid class objects always returns a str instance"
  kind: python_call_eq
  category: identity
  id_prefix: uu1321ro
  columns: [id, function, args, expected]
  rows:
    - [uu1321ro001, repr(uuid.UUID).__class__.__name__.__eq__,     ["str"], true]
    - [uu1321ro002, repr(uuid.SafeUUID).__class__.__name__.__eq__, ["str"], true]
    - [uu1321ro003, uuid.UUID.__repr__.__class__.__name__.__eq__,  ["function"], true]
    - [uu1321ro004, uuid.UUID.__str__.__class__.__name__.__eq__,   ["function"], true]
    - [uu1321ro005, uuid.SafeUUID.__repr__.__class__.__name__.__eq__, ["function"], true]
    - [uu1321ro006, uuid.SafeUUID.__str__.__class__.__name__.__eq__,  ["function"], true]
