spec: threading_extra1291
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec extends threading_extra129.zspec.zsdl and prior extras."
    - "Wave 533 theme: __init__ and __new__ method presence and qualname checks for threading classes."
    - "threading.Thread, Barrier, Timer, Condition, Event, Semaphore are all Python classes defined in Lib/threading.py."
    - "All six classes define __init__; none define __new__ (all inherit object.__new__)."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15); __init__.__class__.__name__ == 'function'. Verified with Python 3.12."
    - "threading.Barrier.__init__.__qualname__ == 'Barrier.__init__' (len 16); __init__.__class__.__name__ == 'function'. Verified with Python 3.12."
    - "threading.Timer.__init__.__qualname__ == 'Timer.__init__' (len 14); __init__.__class__.__name__ == 'function'. Timer subclasses Thread. Verified with Python 3.12."
    - "threading.Condition.__init__.__qualname__ == 'Condition.__init__' (len 18); __init__.__class__.__name__ == 'function'. Verified with Python 3.12."
    - "threading.Event.__init__.__qualname__ == 'Event.__init__' (len 14); __init__.__class__.__name__ == 'function'. Verified with Python 3.12."
    - "threading.Semaphore.__init__.__qualname__ == 'Semaphore.__init__' (len 18); __init__.__class__.__name__ == 'function'. Verified with Python 3.12."
    - "All six have __new__.__qualname__ == 'object.__new__' (len 14); __new__.__class__.__name__ == 'builtin_function_or_method'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and threading.Timer __init__ qualname and class name
#
# Wave 533 theme: Thread and Timer both define __init__ as Python functions.
#
# Thread.__init__.__qualname__ == 'Thread.__init__' (len 15)
# Thread.__init__.__class__.__name__ == 'function'
# '__init__' in Thread.__dict__ == True
# Thread.__new__.__qualname__ == 'object.__new__' (len 14)
#
# Timer is a subclass of Thread; Timer.__init__.__qualname__ == 'Timer.__init__'
# (len 14); Timer defines its own __init__ that calls Thread.__init__ via super.
#
# New to extra1291.
# ---------------------------------------------------------------------------

table threading_extra1291.Thread_Timer_init_new:
  description: "threading.Thread __init__.__qualname__=='Thread.__init__'(15), class='function', in dict; threading.Timer __init__.__qualname__=='Timer.__init__'(14), in dict; both inherit object.__new__; wave 533; new to extra1291"
  kind: python_call_eq
  category: string_identity
  id_prefix: th1291tt

  columns: [id, function, args, expected, description]
  rows:
    - [th1291tt001,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread is a Python class that defines __init__ in Lib/threading.py; the method __qualname__ is 'Thread.__init__' following the dotted class.method convention; str.__eq__('Thread.__init__') returns True; new to extra1291"]
    - [th1291tt002,
       "Thread.__init__.__qualname__.__len__",
       [],
       15,
       "threading.Thread.__init__.__qualname__.__len__() == 15 — 'Thread.__init__' has 15 characters: 'Thread' (6) + '.' (1) + '__init__' (8) = 15; new to extra1291"]
    - [th1291tt003,
       "Thread.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.__init__.__class__.__name__.__eq__('function') == True — Thread.__init__ is a Python function defined with def in Lib/threading.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra1291"]
    - [th1291tt004,
       "Thread.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Thread.__dict__.__contains__('__init__') == True — Thread explicitly defines __init__ in its class body in Lib/threading.py; dict.__contains__('__init__') returns True; new to extra1291"]
    - [th1291tt005,
       "Thread.__new__.__qualname__.__eq__",
       ["object.__new__"],
       true,
       "threading.Thread.__new__.__qualname__.__eq__('object.__new__') == True — Thread does not define __new__; it inherits object.__new__ whose __qualname__ is 'object.__new__'; str.__eq__('object.__new__') returns True; new to extra1291"]
    - [th1291tt006,
       "Thread.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Thread.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — object.__new__ is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra1291"]
    - [th1291tt007,
       "Timer.__init__.__qualname__.__eq__",
       ["Timer.__init__"],
       true,
       "threading.Timer.__init__.__qualname__.__eq__('Timer.__init__') == True — Timer is a subclass of Thread that defines its own __init__ in Lib/threading.py; __qualname__ is 'Timer.__init__' (len 14); str.__eq__('Timer.__init__') returns True; new to extra1291"]
    - [th1291tt008,
       "Timer.__init__.__qualname__.__len__",
       [],
       14,
       "threading.Timer.__init__.__qualname__.__len__() == 14 — 'Timer.__init__' has 14 characters: 'Timer' (5) + '.' (1) + '__init__' (8) = 14; one character shorter than Thread.__init__.__qualname__ (len 15); new to extra1291"]
    - [th1291tt009,
       "Timer.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Timer.__dict__.__contains__('__init__') == True — Timer defines its own __init__ (distinct from Thread.__init__) to accept the interval and function args; dict.__contains__('__init__') returns True; new to extra1291"]

