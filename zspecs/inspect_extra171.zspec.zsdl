spec: inspect_extra171
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getattr_static.__name__ 'getattr_static'; inspect.getattr_static.__module__ 'inspect'; inspect.classify_class_attrs.__name__ 'classify_class_attrs'; inspect.classify_class_attrs.__module__ 'inspect'; inspect.getmro.__name__ 'getmro'; inspect.getmro.__module__ 'inspect'; inspect.unwrap.__name__ 'unwrap'; inspect.unwrap.__module__ 'inspect' (Wave 300)."
    - "inspect.getattr_static.__name__ == 'getattr_static' — inspect.getattr_static is a Python function defined in Lib/inspect.py that retrieves attributes without triggering dynamic lookup through the descriptor protocol; its __name__ is 'getattr_static'. Verified with Python 3.14.3."
    - "inspect.getattr_static.__module__ == 'inspect' — getattr_static is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — inspect.classify_class_attrs is a Python function defined in Lib/inspect.py that returns a list of (name, kind, defining_class, object) namedtuples for all attributes of a class; its __name__ is 'classify_class_attrs'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__module__ == 'inspect' — classify_class_attrs is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getmro.__name__ == 'getmro' — inspect.getmro is a Python function defined in Lib/inspect.py that returns a tuple of the base classes (including the class itself) in method resolution order; its __name__ is 'getmro'. Verified with Python 3.14.3."
    - "inspect.getmro.__module__ == 'inspect' — getmro is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.unwrap.__name__ == 'unwrap' — inspect.unwrap is a Python function defined in Lib/inspect.py that follows the chain of __wrapped__ attributes returning the innermost callable (undoing functools.wraps); its __name__ is 'unwrap'. Verified with Python 3.14.3."
    - "inspect.unwrap.__module__ == 'inspect' — unwrap is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getattr_static Python function identity — __name__,
# __module__, __class__.__name__
#
# Wave 300 theme: inspect.getattr_static Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.getattr_static.__name__ == 'getattr_static'
# inspect.getattr_static.__module__ == 'inspect'
# inspect.getattr_static.__class__.__name__ == 'function'
# inspect.getattr_static.__name__ != 'getattr'
#
# inspect.getattr_static(obj, attr, default=None) retrieves an attribute
# without triggering dynamic lookup through the descriptor protocol. It does
# not call __getattr__ or __getattribute__, does not resolve data descriptors,
# and is therefore useful for examining the raw class and instance namespaces.
# New to extra171.
# ---------------------------------------------------------------------------

table inspect_extra171.getattr_static_identity:
  description: "inspect.getattr_static: __name__ 'getattr_static', __module__ 'inspect', __class__.__name__ 'function'; wave 300; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgasi171

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_name_eq,
       "getattr_static.__name__.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__name__.__eq__('getattr_static') == True — inspect.getattr_static is a Python function defined in Lib/inspect.py that retrieves attributes without triggering dynamic lookup through the descriptor protocol; its __name__ attribute is 'getattr_static'; str.__eq__('getattr_static') returns True; new to extra171"]
    - [getattr_static_module_inspect,
       "getattr_static.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getattr_static.__module__.__eq__('inspect') == True — inspect.getattr_static is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra171"]
    - [getattr_static_class_function,
       "getattr_static.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.getattr_static.__class__.__name__.__eq__('function') == True — inspect.getattr_static is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra171"]
    - [getattr_static_name_ne_getattr,
       "getattr_static.__name__.__eq__",
       ["getattr"],
       false,
       "inspect.getattr_static.__name__.__eq__('getattr') == False — getattr_static.__name__ is 'getattr_static', not 'getattr'; getattr_static bypasses the descriptor protocol while builtin getattr does not; they are completely distinct; str.__eq__('getattr') returns False; new to extra171"]

# ---------------------------------------------------------------------------
# Table 2: inspect.classify_class_attrs Python function identity — __name__,
# __module__, __class__.__name__
#
# Wave 300 theme: inspect.classify_class_attrs Python function identity —
# __name__, __module__, and __class__.__name__.
#
# inspect.classify_class_attrs.__name__ == 'classify_class_attrs'
# inspect.classify_class_attrs.__module__ == 'inspect'
# inspect.classify_class_attrs.__class__.__name__ == 'function'
# inspect.classify_class_attrs.__name__ != 'getattr_static'
#
# inspect.classify_class_attrs(cls) returns a list of
# (name, kind, defining_class, object) named four-tuples that classify each
# attribute of cls. The kind is one of 'class method', 'static method',
# 'property', 'method', or 'data'. New to extra171.
# ---------------------------------------------------------------------------

table inspect_extra171.classify_class_attrs_identity:
  description: "inspect.classify_class_attrs: __name__ 'classify_class_attrs', __module__ 'inspect', __class__.__name__ 'function'; wave 300; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: inspectccai171

  columns: [id, function, args, expected, description]
  rows:
    - [classify_name_eq,
       "classify_class_attrs.__name__.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__eq__('classify_class_attrs') == True — inspect.classify_class_attrs is a Python function defined in Lib/inspect.py that returns a list of (name, kind, defining_class, object) four-tuples classifying each attribute of a class; its __name__ attribute is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra171"]
    - [classify_module_inspect,
       "classify_class_attrs.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — inspect.classify_class_attrs is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra171"]
    - [classify_class_function,
       "classify_class_attrs.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.classify_class_attrs.__class__.__name__.__eq__('function') == True — inspect.classify_class_attrs is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra171"]
    - [classify_name_ne_getattr_static,
       "classify_class_attrs.__name__.__eq__",
       ["getattr_static"],
       false,
       "inspect.classify_class_attrs.__name__.__eq__('getattr_static') == False — classify_class_attrs.__name__ is 'classify_class_attrs', not 'getattr_static'; classify_class_attrs returns a classification of all class attributes while getattr_static retrieves a single attribute without descriptor protocol; they are distinct functions; str.__eq__('getattr_static') returns False; new to extra171"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getmro Python function identity — __name__, __module__,
# __class__.__name__, name length
#
# Wave 300 theme: inspect.getmro Python function identity — __name__,
# __module__, __class__.__name__, and __name__.__len__().
#
# inspect.getmro.__name__ == 'getmro'
# inspect.getmro.__module__ == 'inspect'
# inspect.getmro.__class__.__name__ == 'function'
# inspect.getmro.__name__.__len__() == 6
#
# inspect.getmro(cls) returns a tuple of base classes (including cls itself)
# in method resolution order, consistent with C3 linearization. The __mro__
# attribute of a class is usually equivalent; getmro is the inspect-module
# equivalent. New to extra171.
# ---------------------------------------------------------------------------

table inspect_extra171.getmro_identity:
  description: "inspect.getmro: __name__ 'getmro', __module__ 'inspect', __class__.__name__ 'function', name len 6; wave 300; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgmroi171

  columns: [id, function, args, expected, description]
  rows:
    - [getmro_name_eq,
       "getmro.__name__.__eq__",
       ["getmro"],
       true,
       "inspect.getmro.__name__.__eq__('getmro') == True — inspect.getmro is a Python function defined in Lib/inspect.py that returns a tuple of a class's base classes (including the class itself) in method resolution order; its __name__ attribute is 'getmro'; str.__eq__('getmro') returns True; new to extra171"]
    - [getmro_module_inspect,
       "getmro.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmro.__module__.__eq__('inspect') == True — inspect.getmro is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra171"]
    - [getmro_class_function,
       "getmro.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.getmro.__class__.__name__.__eq__('function') == True — inspect.getmro is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra171"]
    - [getmro_name_len_6,
       "getmro.__name__.__len__",
       [],
       6,
       "inspect.getmro.__name__.__len__() == 6 — the string 'getmro' has exactly 6 characters: g-e-t-m-r-o; str.__len__() returns 6; new to extra171"]

# ---------------------------------------------------------------------------
# Table 4: inspect.unwrap Python function identity — __name__, __module__,
# __class__.__name__; cross-checks with getmro
#
# Wave 300 theme: inspect.unwrap Python function identity — __name__,
# __module__, and __class__.__name__; plus cross-checks confirming unwrap and
# getmro are distinct.
#
# inspect.unwrap.__name__ == 'unwrap'
# inspect.unwrap.__module__ == 'inspect'
# inspect.unwrap.__class__.__name__ == 'function'
# inspect.unwrap.__name__ != 'getmro'
#
# inspect.unwrap(func, *, stop=None) follows the chain of __wrapped__ attributes
# (set by functools.wraps) returning the innermost callable. This is the inverse
# of the functools.wraps decoration chain. Raises ValueError if a cycle is detected.
# New to extra171.
# ---------------------------------------------------------------------------

table inspect_extra171.unwrap_identity:
  description: "inspect.unwrap: __name__ 'unwrap', __module__ 'inspect', __class__.__name__ 'function'; cross-checks with getmro; wave 300; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: inspectuwi171

  columns: [id, function, args, expected, description]
  rows:
    - [unwrap_name_eq,
       "unwrap.__name__.__eq__",
       ["unwrap"],
       true,
       "inspect.unwrap.__name__.__eq__('unwrap') == True — inspect.unwrap is a Python function defined in Lib/inspect.py that follows the chain of __wrapped__ attributes returning the innermost callable; its __name__ attribute is 'unwrap'; str.__eq__('unwrap') returns True; new to extra171"]
    - [unwrap_module_inspect,
       "unwrap.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.unwrap.__module__.__eq__('inspect') == True — inspect.unwrap is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra171"]
    - [unwrap_class_function,
       "unwrap.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.unwrap.__class__.__name__.__eq__('function') == True — inspect.unwrap is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra171"]
    - [unwrap_name_ne_getmro,
       "unwrap.__name__.__eq__",
       ["getmro"],
       false,
       "inspect.unwrap.__name__.__eq__('getmro') == False — unwrap.__name__ is 'unwrap', not 'getmro'; unwrap follows __wrapped__ chains to find the original callable while getmro returns the method resolution order tuple; they are distinct functions; str.__eq__('getmro') returns False; new to extra171"]

# ---------------------------------------------------------------------------
# Table 5: name length and cross-module checks — getattr_static,
# classify_class_attrs, getmro, unwrap
#
# Wave 300 theme: __name__.__len__() for getattr_static (14),
# classify_class_attrs (20), getmro (6), and unwrap (6).
#
# inspect.getattr_static.__name__.__len__() == 14
# inspect.classify_class_attrs.__name__.__len__() == 20
# inspect.getmro.__name__.__len__() == 6
# inspect.unwrap.__name__.__len__() == 6
#
# Length ordering: getmro(6) == unwrap(6) < getattr_static(14) < classify_class_attrs(20).
# New to extra171.
# ---------------------------------------------------------------------------

table inspect_extra171.name_lengths:
  description: "inspect: getattr_static name len 14, classify_class_attrs len 20, getmro len 6, unwrap len 6; wave 300; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: inspectnl171

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_name_len_14,
       "getattr_static.__name__.__len__",
       [],
       14,
       "inspect.getattr_static.__name__.__len__() == 14 — the string 'getattr_static' has exactly 14 characters: g-e-t-a-t-t-r-_-s-t-a-t-i-c; str.__len__() returns 14; new to extra171"]
    - [classify_name_len_20,
       "classify_class_attrs.__name__.__len__",
       [],
       20,
       "inspect.classify_class_attrs.__name__.__len__() == 20 — the string 'classify_class_attrs' has exactly 20 characters: c-l-a-s-s-i-f-y-_-c-l-a-s-s-_-a-t-t-r-s; the longest name among the four functions in this spec; str.__len__() returns 20; new to extra171"]
    - [getmro_name_len_6,
       "getmro.__name__.__len__",
       [],
       6,
       "inspect.getmro.__name__.__len__() == 6 — the string 'getmro' has exactly 6 characters: g-e-t-m-r-o; same length as 'unwrap'; str.__len__() returns 6; new to extra171"]
    - [unwrap_name_len_6,
       "unwrap.__name__.__len__",
       [],
       6,
       "inspect.unwrap.__name__.__len__() == 6 — the string 'unwrap' has exactly 6 characters: u-n-w-r-a-p; same length as 'getmro' though entirely different names; str.__len__() returns 6; new to extra171"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra171
# ---------------------------------------------------------------------------

invariant inspect_extra171.getattr_static_name_eq:
  description: "inspect.getattr_static.__name__ == 'getattr_static' — Python function retrieving attributes without triggering the descriptor protocol; wave 300; new to extra171"
  kind: python_call_eq
  function: getattr_static.__name__.__eq__
  args: ["getattr_static"]
  expected: true

invariant inspect_extra171.getattr_static_module_inspect:
  description: "inspect.getattr_static.__module__ == 'inspect' — getattr_static is defined in Lib/inspect.py; wave 300; new to extra171"
  kind: python_call_eq
  function: getattr_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra171.classify_class_attrs_name_eq:
  description: "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — Python function returning classified (name, kind, defining_class, object) tuples for all class attributes; wave 300; new to extra171"
  kind: python_call_eq
  function: classify_class_attrs.__name__.__eq__
  args: ["classify_class_attrs"]
  expected: true

invariant inspect_extra171.classify_class_attrs_module_inspect:
  description: "inspect.classify_class_attrs.__module__ == 'inspect' — classify_class_attrs is defined in Lib/inspect.py; wave 300; new to extra171"
  kind: python_call_eq
  function: classify_class_attrs.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra171.getmro_name_eq:
  description: "inspect.getmro.__name__ == 'getmro' — Python function returning the method resolution order tuple for a class; wave 300; new to extra171"
  kind: python_call_eq
  function: getmro.__name__.__eq__
  args: ["getmro"]
  expected: true

invariant inspect_extra171.getmro_module_inspect:
  description: "inspect.getmro.__module__ == 'inspect' — getmro is defined in Lib/inspect.py; wave 300; new to extra171"
  kind: python_call_eq
  function: getmro.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra171.unwrap_name_eq:
  description: "inspect.unwrap.__name__ == 'unwrap' — Python function following __wrapped__ attributes to return the innermost callable; wave 300; new to extra171"
  kind: python_call_eq
  function: unwrap.__name__.__eq__
  args: ["unwrap"]
  expected: true

invariant inspect_extra171.unwrap_module_inspect:
  description: "inspect.unwrap.__module__ == 'inspect' — unwrap is defined in Lib/inspect.py; wave 300; new to extra171"
  kind: python_call_eq
  function: unwrap.__module__.__eq__
  args: ["inspect"]
  expected: true
