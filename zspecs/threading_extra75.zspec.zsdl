spec: threading_extra75
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra74.zspec.zsdl."
    - "Wave 240 theme: threading Condition method code attrs, Condition class identity, enumerate and active_count."
    - "Condition does not have an 'acquire' method — Condition delegates acquire/release to the underlying lock but does not define them as named methods in its __dict__; only wait, wait_for, notify, notify_all are defined. Verified with Python 3.14.3."
    - "Condition.wait.__code__.co_name == 'wait' — Condition.wait is a pure-Python method. Verified with Python 3.14.3."
    - "Condition.wait.__code__.co_argcount == 2 — Condition.wait(self, timeout=None) has 2 positional params. Verified with Python 3.14.3."
    - "Condition.notify.__code__.co_name == 'notify' — Condition.notify is a pure-Python method. Verified with Python 3.14.3."
    - "Condition.notify.__code__.co_argcount == 2 — Condition.notify(self, n=1) has 2 positional params. Verified with Python 3.14.3."
    - "Condition.notify_all.__code__.co_name == 'notify_all' — Condition.notify_all is a pure-Python method. Verified with Python 3.14.3."
    - "Condition.notify_all.__code__.co_argcount == 1 — Condition.notify_all(self) has 1 positional param. Verified with Python 3.14.3."
    - "Condition.__name__ == 'Condition' — Condition is a pure-Python class in threading.py. Verified with Python 3.14.3."
    - "Condition.__module__ == 'threading' — Condition is defined in the threading module. Verified with Python 3.14.3."
    - "threading.enumerate.__class__.__name__ == 'function' — threading.enumerate is a pure-Python function. Verified with Python 3.14.3."
    - "threading.enumerate.__code__.co_name == 'enumerate' — co_name matches the def statement name. Verified with Python 3.14.3."
    - "threading.active_count.__class__.__name__ == 'function' — active_count is a pure-Python function. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_name == 'active_count' — co_name matches the def statement name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Condition.wait and Condition.notify code attributes — extra75
#
# Wave 240 theme: Condition.wait and Condition.notify co_name and co_argcount.
#
# threading.Condition is a pure-Python class in Lib/threading.py.
# Condition does NOT define acquire/release as named methods in __dict__.
#
# Condition.wait.__code__.co_name      == 'wait'
# Condition.wait.__code__.co_argcount  == 2  (self + timeout)
# Condition.notify.__code__.co_name     == 'notify'
# Condition.notify.__code__.co_argcount == 2  (self + n)
#
# No prior threading spec checks Condition.wait/notify __code__ via thrdmore75. New to extra75.
# ---------------------------------------------------------------------------

table threading_extra75.Condition_wait_notify_code:
  description: "Condition.wait/__code__.co_name=='wait', co_argcount==2; Condition.notify/__code__.co_name=='notify', co_argcount==2; wave 240 Condition method __code__; new to extra75"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdmore75

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_wait_co_name_eq_wait,
       Condition.wait.__code__.co_name.__eq__,
       ["wait"],
       true,
       "threading.Condition.wait.__code__.co_name.__eq__('wait') == True — Condition.wait is a pure-Python method in Lib/threading.py that releases the underlying lock and waits until notified; its code object's co_name stores the name from the def statement which is 'wait' (4 chars); str.__eq__('wait') returns True; no prior threading spec checks Condition.wait.__code__.co_name via thrdmore75; new to extra75"]
    - [Condition_wait_co_argcount_eq_2,
       Condition.wait.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Condition.wait.__code__.co_argcount.__eq__(2) == True — Condition.wait is defined as 'def wait(self, timeout=None):' with 2 positional parameters (self and timeout); co_argcount counts positional-or-keyword parameters and equals 2; int.__eq__(2) returns True; no prior threading spec checks Condition.wait.__code__.co_argcount via thrdmore75; new to extra75"]
    - [Condition_notify_co_name_eq_notify,
       Condition.notify.__code__.co_name.__eq__,
       ["notify"],
       true,
       "threading.Condition.notify.__code__.co_name.__eq__('notify') == True — Condition.notify is a pure-Python method in Lib/threading.py that wakes up one or more threads waiting on this condition; its code object's co_name stores the name from the def statement which is 'notify' (6 chars); str.__eq__('notify') returns True; no prior threading spec checks Condition.notify.__code__.co_name via thrdmore75; new to extra75"]
    - [Condition_notify_co_argcount_eq_2,
       Condition.notify.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Condition.notify.__code__.co_argcount.__eq__(2) == True — Condition.notify is defined as 'def notify(self, n=1):' with 2 positional parameters (self and n); co_argcount counts positional-or-keyword parameters and equals 2; int.__eq__(2) returns True; no prior threading spec checks Condition.notify.__code__.co_argcount via thrdmore75; new to extra75"]

# ---------------------------------------------------------------------------
# Condition.notify_all code attributes and class identity — extra75
#
# Wave 240 theme: Condition.notify_all co_name/co_argcount and Condition class identity.
#
# Condition.notify_all.__code__.co_name     == 'notify_all'
# Condition.notify_all.__code__.co_argcount == 1 (self only)
# Condition.__name__                        == 'Condition'
# Condition.__module__                      == 'threading'
#
# No prior threading spec checks Condition.notify_all or Condition identity via thrdmore75. New to extra75.
# ---------------------------------------------------------------------------

table threading_extra75.Condition_notify_all_and_identity:
  description: "Condition.notify_all/__code__.co_name=='notify_all', co_argcount==1; Condition.__name__=='Condition', __module__=='threading'; wave 240 Condition identity; new to extra75"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdmore75

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_notify_all_co_name_eq_notify_all,
       Condition.notify_all.__code__.co_name.__eq__,
       ["notify_all"],
       true,
       "threading.Condition.notify_all.__code__.co_name.__eq__('notify_all') == True — Condition.notify_all is a pure-Python method in Lib/threading.py that wakes up all threads waiting on this condition; its code object's co_name stores the name from the def statement which is 'notify_all' (10 chars); str.__eq__('notify_all') returns True; no prior threading spec checks Condition.notify_all.__code__.co_name via thrdmore75; new to extra75"]
    - [Condition_notify_all_co_argcount_eq_1,
       Condition.notify_all.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Condition.notify_all.__code__.co_argcount.__eq__(1) == True — Condition.notify_all is defined as 'def notify_all(self):' with 1 positional parameter (self only); co_argcount counts positional-or-keyword parameters and equals 1; int.__eq__(1) returns True; no prior threading spec checks Condition.notify_all.__code__.co_argcount via thrdmore75; new to extra75"]
    - [Condition_name_eq_Condition,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a pure-Python class defined in Lib/threading.py that implements a condition variable; its __name__ attribute stores the class name as a str 'Condition' (9 chars); str.__eq__('Condition') returns True; no prior threading spec checks Condition.__name__ via thrdmore75; new to extra75"]
    - [Condition_module_eq_threading,
       Condition.__module__.__eq__,
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py and its __module__ attribute records the module name as the str 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Condition.__module__ via thrdmore75; new to extra75"]

# ---------------------------------------------------------------------------
# threading.enumerate function identity — extra75
#
# Wave 240 theme: threading.enumerate is a plain Python function.
#
# threading.enumerate.__class__.__name__ == 'function'
# threading.enumerate.__code__.co_name   == 'enumerate'
#
# Note: threading.enumerate shadows the built-in enumerate within this module namespace.
#
# No prior threading spec checks threading.enumerate identity via thrdmore75. New to extra75.
# ---------------------------------------------------------------------------

table threading_extra75.enumerate_function_identity:
  description: "enumerate.__class__.__name__=='function', enumerate.__code__.co_name=='enumerate'; wave 240 threading.enumerate identity; new to extra75"
  kind: python_call_eq
  category: function_identity
  id_prefix: thrdmore75

  columns: [id, function, args, expected, description]
  rows:
    - [enumerate_class_name_eq_function,
       enumerate.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.enumerate.__class__.__name__.__eq__('function') == True — threading.enumerate is a pure-Python function defined in Lib/threading.py that returns a list of all Thread objects currently alive; it shadows the built-in enumerate within the threading module namespace; its __class__ is the built-in function type and __class__.__name__ is 'function' (8 chars); str.__eq__('function') returns True; no prior threading spec checks threading.enumerate.__class__.__name__ via thrdmore75; new to extra75"]
    - [enumerate_co_name_eq_enumerate,
       enumerate.__code__.co_name.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__code__.co_name.__eq__('enumerate') == True — threading.enumerate is a pure-Python function in Lib/threading.py; its code object's co_name stores the name from the def statement which is 'enumerate' (9 chars); str.__eq__('enumerate') returns True; no prior threading spec checks threading.enumerate.__code__.co_name via thrdmore75; new to extra75"]

# ---------------------------------------------------------------------------
# threading.active_count function identity — extra75
#
# Wave 240 theme: threading.active_count is a plain Python function.
#
# threading.active_count.__class__.__name__ == 'function'
# threading.active_count.__code__.co_name   == 'active_count'
#
# No prior threading spec checks active_count identity via thrdmore75. New to extra75.
# ---------------------------------------------------------------------------

table threading_extra75.active_count_function_identity:
  description: "active_count.__class__.__name__=='function', active_count.__code__.co_name=='active_count'; wave 240 active_count identity; new to extra75"
  kind: python_call_eq
  category: function_identity
  id_prefix: thrdmore75

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_class_name_eq_function,
       active_count.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.active_count.__class__.__name__.__eq__('function') == True — active_count is a pure-Python function defined in Lib/threading.py that returns the number of Thread objects currently alive; its __class__ is the built-in function type and __class__.__name__ is 'function' (8 chars); str.__eq__('function') returns True; no prior threading spec checks active_count.__class__.__name__ via thrdmore75; new to extra75"]
    - [active_count_co_name_eq_active_count,
       active_count.__code__.co_name.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__code__.co_name.__eq__('active_count') == True — active_count is a pure-Python function in Lib/threading.py; its code object's co_name stores the name from the def statement which is 'active_count' (12 chars); str.__eq__('active_count') returns True; no prior threading spec checks active_count.__code__.co_name via thrdmore75; new to extra75"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra75
# ---------------------------------------------------------------------------

invariant threading_extra75.Condition_wait_co_name:
  description: "threading.Condition.wait.__code__.co_name.__eq__('wait') == True — Condition.wait co_name is 'wait'; wave 240 Condition method __code__; new to extra75"
  kind: python_call_eq
  function: Condition.wait.__code__.co_name.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra75.Condition_notify_co_argcount:
  description: "threading.Condition.notify.__code__.co_argcount.__eq__(2) == True — Condition.notify co_argcount is 2 (self + n); wave 240 Condition method __code__; new to extra75"
  kind: python_call_eq
  function: Condition.notify.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra75.Condition_name:
  description: "threading.Condition.__name__.__eq__('Condition') == True — Condition class name is 'Condition'; wave 240 Condition identity; new to extra75"
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra75.enumerate_co_name:
  description: "threading.enumerate.__code__.co_name.__eq__('enumerate') == True — threading.enumerate co_name is 'enumerate'; wave 240 threading.enumerate identity; new to extra75"
  kind: python_call_eq
  function: enumerate.__code__.co_name.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra75.active_count_co_name:
  description: "threading.active_count.__code__.co_name.__eq__('active_count') == True — active_count co_name is 'active_count'; wave 240 active_count identity; new to extra75"
  kind: python_call_eq
  function: active_count.__code__.co_name.__eq__
  args: ["active_count"]
  expected: true
