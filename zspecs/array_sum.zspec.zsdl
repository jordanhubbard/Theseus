spec: array_sum
version: ">=1.0.0"
backend: node(array-sum)

docs: https://www.npmjs.com/package/array-sum

provenance:
  derived_from:
    - "array-sum README — https://www.npmjs.com/package/array-sum"
    - "Test vectors verified with array-sum via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "array-sum source"
  notes:
    - "array-sum is an npm package. Install: npm install array-sum"
    - "Returns the sum of all numbers in an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_sum.sum:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: asum

  columns: [id, args, expected]
  rows:
    - [five,    [[1, 2, 3, 4, 5]],  15]
    - [tens,    [[10, 20, 30]],     60]
    - [single,  [[42]],             42]

