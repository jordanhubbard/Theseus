spec: lodash_intersection
version: ">=4.0.0"
backend: node(lodash.intersection)

docs: https://lodash.com/docs/#intersection

provenance:
  derived_from:
    - "lodash.intersection README — https://www.npmjs.com/package/lodash.intersection"
    - "Test vectors verified with lodash.intersection@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.intersection exports the _.intersection function directly as module.exports."
    - "intersection(...arrays) returns values present in all given arrays."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of shared values. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_intersection.intersect:
  kind: node_module_call_eq
  function: ~
  category: intersect
  id_prefix: linter

  columns: [id, args, expected]
  rows:
    - [two,   [[1, 2, 3], [2, 3, 4]],  [2, 3]]
    - [none,  [[1, 2], [3, 4]],         []]
    - [all,   [[1, 2, 3], [1, 2, 3]],  [1, 2, 3]]
