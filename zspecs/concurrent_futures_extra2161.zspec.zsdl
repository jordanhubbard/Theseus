spec: concurrent_futures_extra2161
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Theme: descriptor protocol dict-presence — checks for __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__ in class __dict__."
    - "concurrent.futures.Future does not define any descriptor protocol methods in its own __dict__."
    - "concurrent.futures.Executor does not define any descriptor protocol methods in its own __dict__."
    - "concurrent.futures.ThreadPoolExecutor does not define any descriptor protocol methods in its own __dict__."
    - "concurrent.futures.ProcessPoolExecutor does not define any descriptor protocol methods in its own __dict__."
    - "These executor and future classes manage thread/process pools but do not implement the descriptor protocol."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

