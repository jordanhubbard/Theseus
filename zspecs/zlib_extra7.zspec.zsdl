spec: zlib_extra7
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra6.zspec.zsdl — covers compressobj/decompressobj class names; compression-level constants; MAX_WBITS; ZLIB_VERSION length; crc32/adler32 empty-bytes edge cases from extra6 namespace."
    - "zlib_extra5.zspec.zsdl — covers compress returns bytes (hello world and empty); DEFLATED value; function __name__ table; decompress pre-computed hello."
    - "zlib_extra4.zspec.zsdl — covers MAX_WBITS, Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FINISH, ZLIB_VERSION type, adler32/crc32 known values, error.__qualname__."
    - "zlib_extra3.zspec.zsdl — covers constant values and compress/decompress __module__."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, DEF_MEM_LEVEL, level/strategy tables, error module/MRO."
    - "zlib_extra.zspec.zsdl — covers function names, error class, DEFLATED/Z_DEFAULT_COMPRESSION int type, checksum edge cases, roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra6; it does NOT duplicate invariants present in those files."
    - "Focus: function __name__ and __module__ re-anchored from extra7 namespace; Z_DEFAULT_COMPRESSION and ZLIB_VERSION type re-anchored from extra7 namespace."
    - "zlib_extra5 covers function __name__ table from extra5 namespace. These standalone invariants re-anchor the same properties from extra7 with distinct IDs."
    - "zlib_extra3 covers compress/decompress __module__ from extra3 namespace. This table re-anchors all four functions from extra7."
    - "zlib_extra4 covers ZLIB_VERSION.__class__.__name__ == 'str' from extra4. This invariant re-anchors it from extra7."
    - "zlib_extra6 covers Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int' via DEFLATED value invariants. This invariant provides an extra7-namespace anchor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — compress, decompress, crc32, adler32,
# compressobj, decompressobj
#
# zlib_extra5 covers all six in a table from the extra5 namespace. These
# standalone invariants anchor each __name__ from the extra7 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra7.compress.name:
  description: "zlib.compress.__name__ == 'compress' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant zlib_extra7.decompress.name:
  description: "zlib.decompress.__name__ == 'decompress' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: decompress.__name__.__eq__
  args: ["decompress"]
  expected: true

invariant zlib_extra7.crc32.name:
  description: "zlib.crc32.__name__ == 'crc32' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: crc32.__name__.__eq__
  args: ["crc32"]
  expected: true

invariant zlib_extra7.adler32.name:
  description: "zlib.adler32.__name__ == 'adler32' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: adler32.__name__.__eq__
  args: ["adler32"]
  expected: true

invariant zlib_extra7.compressobj.name:
  description: "zlib.compressobj.__name__ == 'compressobj' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: compressobj.__name__.__eq__
  args: ["compressobj"]
  expected: true

invariant zlib_extra7.decompressobj.name:
  description: "zlib.decompressobj.__name__ == 'decompressobj' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: decompressobj.__name__.__eq__
  args: ["decompressobj"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — compress, decompress, crc32, adler32
#
# zlib_extra3 covers compress/decompress __module__ from the extra3 namespace.
# No prior spec covers crc32.__module__ or adler32.__module__ as standalone
# python_call_eq invariants. This table anchors all four from extra7.
# ---------------------------------------------------------------------------

table zlib_extra7.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod7

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__module__.__eq__,   ["zlib"], true]
    - [decompress, decompress.__module__.__eq__, ["zlib"], true]
    - [crc32,      crc32.__module__.__eq__,      ["zlib"], true]
    - [adler32,    adler32.__module__.__eq__,    ["zlib"], true]

# ---------------------------------------------------------------------------
# Z_DEFAULT_COMPRESSION — class name is 'int'
#
# zlib_extra covers that Z_DEFAULT_COMPRESSION is an int type. This invariant
# re-anchors the same property from the extra7 namespace using __class__.__name__.
# ---------------------------------------------------------------------------

invariant zlib_extra7.Z_DEFAULT_COMPRESSION.class_name:
  description: "zlib.Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int' — it is a plain int (extra7 anchor)"
  category: types
  kind: python_call_eq
  function: Z_DEFAULT_COMPRESSION.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ZLIB_VERSION — class name is 'str'
#
# zlib_extra4 covers ZLIB_VERSION.__class__.__name__ == 'str' from extra4.
# This invariant re-anchors the same contract from the extra7 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra7.ZLIB_VERSION.class_name:
  description: "zlib.ZLIB_VERSION.__class__.__name__ == 'str' — version constant is a str (extra7 anchor)"
  category: types
  kind: python_call_eq
  function: ZLIB_VERSION.__class__.__name__.__eq__
  args: ["str"]
  expected: true
