spec: inspect_extra1471
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks for inspect classes."
    - "inspect.Parameter: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "inspect.Signature: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "inspect.BoundArguments: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "Despite Signature exposing parameter access via signature.parameters (an OrderedDict), Signature itself does not implement __getitem__ or __len__ directly."
    - "BoundArguments exposes bound argument access via .arguments (an OrderedDict) but does not itself implement __getitem__ or __len__."
    - "Parameter is a slot-based immutable class; it does not implement sequence or mapping protocols."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — __len__ and __getitem__ absence checks
#
# Wave 545 theme: inspect.Parameter — represents a parameter in a callable's
# signature.
#
# inspect.Parameter.__dict__.__contains__("__len__") == False
# inspect.Parameter.__dict__.__contains__("__getitem__") == False
# inspect.Parameter.__dict__.__contains__("__setitem__") == False
# inspect.Parameter.__dict__.__contains__("__delitem__") == False
#
# Parameter is a Python class using __slots__ for immutable parameter storage.
# It has __eq__ and __hash__ but no sequence or mapping protocol methods.
# New to extra1471.
# ---------------------------------------------------------------------------

table inspect_extra1471.parameter_len_getitem_absence:
  description: "inspect.Parameter has no __len__, __getitem__, __setitem__, __delitem__ in __dict__; slot-based immutable parameter class; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1471pa

  columns: [id, function, args, expected, description]
  rows:
    - [in1471pa001,
       "Parameter.__dict__.__contains__",
       ["__len__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__len__') == False — Parameter is a slot-based immutable class representing one parameter in a callable signature; it does not implement the sequence protocol; __len__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471pa002,
       "Parameter.__dict__.__contains__",
       ["__getitem__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__getitem__') == False — Parameter does not support index access; its attributes (name, default, annotation, kind) are accessed by name, not index; __getitem__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471pa003,
       "Parameter.__dict__.__contains__",
       ["__setitem__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__setitem__') == False — Parameter is immutable; item assignment is not supported; __setitem__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471pa004,
       "Parameter.__dict__.__contains__",
       ["__delitem__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__delitem__') == False — Parameter is immutable; item deletion is not supported; __delitem__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471pa005,
       "Parameter.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__eq__') == True — Parameter defines __eq__ for equality comparison between parameter objects; __eq__ IS in Parameter.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471pa006,
       "Parameter.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__hash__') == True — Parameter defines __hash__ since it is immutable and equality-comparable; __hash__ IS in Parameter.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature — __len__ and __getitem__ absence checks
#
# Wave 545 theme: inspect.Signature — represents the call signature of a callable,
# including its parameters and return annotation.
#
# inspect.Signature.__dict__.__contains__("__len__") == False
# inspect.Signature.__dict__.__contains__("__getitem__") == False
# inspect.Signature.__dict__.__contains__("__setitem__") == False
# inspect.Signature.__dict__.__contains__("__delitem__") == False
#
# Signature exposes its parameters via the .parameters attribute (an
# OrderedDict) but does NOT itself implement __getitem__ or __len__.
# To access a parameter by name, use sig.parameters["x"], not sig["x"].
# New to extra1471.
# ---------------------------------------------------------------------------

table inspect_extra1471.signature_len_getitem_absence:
  description: "inspect.Signature has no __len__, __getitem__, __setitem__, __delitem__ in __dict__; parameters accessed via .parameters dict; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1471sg

  columns: [id, function, args, expected, description]
  rows:
    - [in1471sg001,
       "Signature.__dict__.__contains__",
       ["__len__"],
       false,
       "inspect.Signature.__dict__.__contains__('__len__') == False — Signature represents a callable's full signature but does not expose a length; __len__ is not in Signature.__dict__; to count parameters use len(sig.parameters); verified with Python 3.12; new to extra1471"]
    - [in1471sg002,
       "Signature.__dict__.__contains__",
       ["__getitem__"],
       false,
       "inspect.Signature.__dict__.__contains__('__getitem__') == False — Signature does not support sig['param'] subscript notation; parameters are accessed via sig.parameters['param'] instead; __getitem__ is not in Signature.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471sg003,
       "Signature.__dict__.__contains__",
       ["__setitem__"],
       false,
       "inspect.Signature.__dict__.__contains__('__setitem__') == False — Signature is immutable; item assignment is not supported; __setitem__ is not in Signature.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471sg004,
       "Signature.__dict__.__contains__",
       ["__delitem__"],
       false,
       "inspect.Signature.__dict__.__contains__('__delitem__') == False — Signature is immutable; item deletion is not supported; __delitem__ is not in Signature.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471sg005,
       "Signature.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.Signature.__dict__.__contains__('__eq__') == True — Signature defines __eq__ for equality comparison between signature objects; __eq__ IS in Signature.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471sg006,
       "Signature.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.Signature.__dict__.__contains__('__hash__') == True — Signature defines __hash__ since it is immutable and equality-comparable; __hash__ IS in Signature.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments — __len__ and __getitem__ absence checks
#
# Wave 545 theme: inspect.BoundArguments — the result of Signature.bind(),
# mapping parameter names to argument values.
#
# inspect.BoundArguments.__dict__.__contains__("__len__") == False
# inspect.BoundArguments.__dict__.__contains__("__getitem__") == False
# inspect.BoundArguments.__dict__.__contains__("__setitem__") == False
# inspect.BoundArguments.__dict__.__contains__("__delitem__") == False
#
# BoundArguments exposes its argument mapping via .arguments (an OrderedDict).
# It does NOT itself implement __getitem__ or __len__; argument access goes
# through the .arguments attribute, not through the BoundArguments object itself.
# New to extra1471.
# ---------------------------------------------------------------------------

table inspect_extra1471.boundarguments_len_getitem_absence:
  description: "inspect.BoundArguments has no __len__, __getitem__, __setitem__, __delitem__ in __dict__; arguments accessed via .arguments dict; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1471ba

  columns: [id, function, args, expected, description]
  rows:
    - [in1471ba001,
       "BoundArguments.__dict__.__contains__",
       ["__len__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__len__') == False — BoundArguments holds bound argument values but does not expose a length directly; __len__ is not in BoundArguments.__dict__; to count bound args use len(ba.arguments); verified with Python 3.12; new to extra1471"]
    - [in1471ba002,
       "BoundArguments.__dict__.__contains__",
       ["__getitem__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__getitem__') == False — BoundArguments does not support ba['param'] subscript access; arguments are accessed via ba.arguments['param']; __getitem__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471ba003,
       "BoundArguments.__dict__.__contains__",
       ["__setitem__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__setitem__') == False — BoundArguments does not support item assignment on the object itself; mutation goes through .arguments; __setitem__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471ba004,
       "BoundArguments.__dict__.__contains__",
       ["__delitem__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__delitem__') == False — BoundArguments does not support item deletion on the object itself; __delitem__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471ba005,
       "BoundArguments.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__eq__') == True — BoundArguments defines __eq__ for equality comparison; __eq__ IS in BoundArguments.__dict__; verified with Python 3.12; new to extra1471"]
    - [in1471ba006,
       "BoundArguments.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__hash__') == True — BoundArguments defines __hash__; __hash__ IS in BoundArguments.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1471
# ---------------------------------------------------------------------------

invariant inspect_extra1471.parameter_no_len:
  description: "inspect.Parameter.__dict__ does not contain '__len__' — Parameter is slot-based and immutable, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant inspect_extra1471.parameter_no_getitem:
  description: "inspect.Parameter.__dict__ does not contain '__getitem__' — Parameter attributes are named, not indexed; wave 545; new to extra1471"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant inspect_extra1471.signature_no_len:
  description: "inspect.Signature.__dict__ does not contain '__len__' — use len(sig.parameters) instead; wave 545; new to extra1471"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant inspect_extra1471.signature_no_getitem:
  description: "inspect.Signature.__dict__ does not contain '__getitem__' — use sig.parameters['name'] instead of sig['name']; wave 545; new to extra1471"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant inspect_extra1471.boundarguments_no_len:
  description: "inspect.BoundArguments.__dict__ does not contain '__len__' — use len(ba.arguments) instead; wave 545; new to extra1471"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant inspect_extra1471.boundarguments_no_getitem:
  description: "inspect.BoundArguments.__dict__ does not contain '__getitem__' — use ba.arguments['name'] instead of ba['name']; wave 545; new to extra1471"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__getitem__"]
  expected: false
