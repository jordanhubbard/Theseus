spec: itertools_extra76
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra75.zspec.zsdl."
    - "This spec covers: itertools C type __dict__ content — confirming each has a __new__ method (Wave 242)."
    - "chain.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of chain is a mappingproxy. Verified with Python 3.14.3."
    - "chain.__dict__.__contains__('__new__') == True — C types define __new__. Verified with Python 3.14.3."
    - "chain.__dict__.__contains__('from_iterable') == True — chain has classmethod from_iterable in its __dict__. Verified with Python 3.14.3."
    - "islice.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of islice is a mappingproxy. Verified with Python 3.14.3."
    - "islice.__dict__.__contains__('__new__') == True — C types define __new__. Verified with Python 3.14.3."
    - "product.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of product is a mappingproxy. Verified with Python 3.14.3."
    - "product.__dict__.__contains__('__new__') == True — C types define __new__. Verified with Python 3.14.3."
    - "combinations.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of combinations is a mappingproxy. Verified with Python 3.14.3."
    - "combinations.__dict__.__contains__('__new__') == True — C types define __new__. Verified with Python 3.14.3."
    - "accumulate.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of accumulate is a mappingproxy. Verified with Python 3.14.3."
    - "accumulate.__dict__.__contains__('__new__') == True — C types define __new__. Verified with Python 3.14.3."
    - "cycle.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of cycle is a mappingproxy. Verified with Python 3.14.3."
    - "cycle.__dict__.__contains__('__new__') == True — C types define __new__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain __dict__ class name and __new__ + from_iterable — extra76
#
# Wave 242 theme: chain __dict__ is a mappingproxy; contains __new__ and from_iterable.
#
# itertools.chain.__dict__.__class__.__name__          == 'mappingproxy'
# itertools.chain.__dict__.__contains__('__new__')     == True
# itertools.chain.__dict__.__contains__('from_iterable') == True
#
# No prior itertools spec checks chain.__dict__ attrs via itertmore76. New to extra76.
# ---------------------------------------------------------------------------

table itertools_extra76.chain_dict_attrs:
  description: "chain.__dict__.__class__.__name__=='mappingproxy', __contains__('__new__')==True, __contains__('from_iterable')==True; wave 242 chain __dict__ content; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertmore76

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_class_name_eq_mappingproxy,
       chain.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.chain.__dict__.__class__.__name__.__eq__('mappingproxy') == True — chain is a C extension type; its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior itertools spec checks chain.__dict__.__class__.__name__ via itertmore76; new to extra76"]
    - [chain_dict_contains_new,
       chain.__dict__.__contains__,
       ["__new__"],
       true,
       "itertools.chain.__dict__.__contains__('__new__') == True — chain is a C extension type defined in Modules/itertoolsmodule.c; C types define __new__ in their type slot which appears as '__new__' in the class namespace mappingproxy; mappingproxy.__contains__('__new__') returns True; no prior itertools spec checks chain.__dict__.__contains__('__new__') via itertmore76; new to extra76"]
    - [chain_dict_contains_from_iterable,
       chain.__dict__.__contains__,
       ["from_iterable"],
       true,
       "itertools.chain.__dict__.__contains__('from_iterable') == True — chain defines from_iterable as a classmethod that takes a single iterable of iterables and chains them; this classmethod lives in chain's class namespace; mappingproxy.__contains__('from_iterable') returns True; no prior itertools spec checks chain.__dict__.__contains__('from_iterable') via itertmore76; new to extra76"]

