spec: cf3061
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (cf3061): __aexit__, __await__, __anext__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor."
    - "All four classes return false for __aexit__, __await__, and __anext__ in their own __dict__."
    - "concurrent.futures.Executor defines the synchronous __enter__/__exit__ protocol (confirmed in wave 650), but has no async context manager (__aexit__) support."
    - "concurrent.futures.Future is not awaitable in the asyncio sense — it does not define __await__; use asyncio.wrap_future() to bridge."
    - "No concurrent.futures class supports async iteration (__anext__)."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# No concurrent.futures class defines __aexit__ in its own __dict__; all false.
# concurrent.futures.Executor provides synchronous __enter__/__exit__ (wave 650)
# but does NOT provide the async counterpart __aexit__ — no async-with support.
# concurrent.futures.Future is not an async context manager.
# ---------------------------------------------------------------------------

table cf3061.aexit:
  description: "concurrent.futures types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3061

  columns: [id, function, args, expected]
  rows:
    - ["cf3061001", operator.contains, [concurrent.futures.Future.__dict__,              "__aexit__"], false]
    - ["cf3061002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__aexit__"], false]
    - ["cf3061003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__aexit__"], false]
    - ["cf3061004", operator.contains, [concurrent.futures.Executor.__dict__,            "__aexit__"], false]

# ---------------------------------------------------------------------------
# __await__ dict-presence — operator.contains(Cls.__dict__, '__await__')
#
# No concurrent.futures class defines __await__ in its own __dict__; all false.
# concurrent.futures.Future is NOT directly awaitable — use asyncio.wrap_future()
# to integrate with an asyncio event loop.
# Executor classes are not awaitable objects.
# ---------------------------------------------------------------------------

table cf3061.await:
  description: "concurrent.futures types __await__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3061

  columns: [id, function, args, expected]
  rows:
    - ["cf3061005", operator.contains, [concurrent.futures.Future.__dict__,              "__await__"], false]
    - ["cf3061006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__await__"], false]
    - ["cf3061007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__await__"], false]
    - ["cf3061008", operator.contains, [concurrent.futures.Executor.__dict__,            "__await__"], false]

# ---------------------------------------------------------------------------
# __anext__ dict-presence — operator.contains(Cls.__dict__, '__anext__')
#
# No concurrent.futures class defines __anext__ in its own __dict__; all false.
# concurrent.futures has no async iteration support anywhere in its class hierarchy.
# ---------------------------------------------------------------------------

