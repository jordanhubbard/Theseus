  columns: [id, function, args, expected]
  rows:
    - ["cf3061009",  operator.contains, [concurrent.futures.Future.__dict__,              "__anext__"], false]
    - ["cf3061010",  operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__anext__"], false]
    - ["cf3061011",  operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__anext__"], false]
    - ["cf3061012",  operator.contains, [concurrent.futures.Executor.__dict__,            "__anext__"], false]

# ---------------------------------------------------------------------------
# combined — __aexit__, __await__, __anext__ across all 4 cf subjects
#
# Covers the full matrix: 4 classes x 3 methods = 12 rows.
# __aexit__:  all false — no async context manager support.
# __await__:  all false — concurrent.futures.Future is not asyncio-awaitable.
# __anext__:  all false — no async iteration support.
# All three async protocol methods are absent from all four classes' own __dict__.
# ---------------------------------------------------------------------------

