spec: socket_extra247
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra100.zspec.zsdl — covers socket.socket method __name__ equality for connect/bind/listen/accept/close/send/recv/sendall/setsockopt/getsockopt/__init__/settimeout/gettimeout/fileno (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
  notes:
    - "Wave 293 theme: socket module constants integer values and socket class identity."
    - "socket.AF_INET == 2. Cross-platform (POSIX, macOS, Linux). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM == 1. Cross-platform. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM == 2. Cross-platform. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP == 6. Cross-platform (IANA assigned). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP == 17. Cross-platform (IANA assigned). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IP == 0. Cross-platform. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.name == 'AF_INET'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.name == 'SOCK_STREAM'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: AF_INET==2 and SOCK_STREAM==1 are cross-platform constants defined by POSIX; AF_INET6 is platform-dependent (30 on macOS, 10 on Linux) and is NOT included here."
    - "Note: IPPROTO_TCP==6 and IPPROTO_UDP==17 are IANA-assigned IP protocol numbers, identical on all platforms."
    - "Note: socket.AF_INET is an AddressFamily IntEnum; socket.SOCK_STREAM is a SocketKind IntEnum; socket.IPPROTO_TCP is a plain int. __eq__ works identically for both IntEnum and int."
    - "Note: socket.socket.__name__ == 'socket' and __module__ == 'socket'; socket.socket is the Python wrapper defined in Lib/socket.py that inherits from _socket.socket (a C type from socketmodule.c)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET/SOCK_STREAM/SOCK_DGRAM/IPPROTO_TCP/IPPROTO_UDP integer values
#
# Wave 293 theme: cross-platform socket constants integer values.
#
# AF_INET==2 (IPv4 address family), SOCK_STREAM==1 (TCP-style stream socket),
# SOCK_DGRAM==2 (UDP-style datagram socket), IPPROTO_TCP==6 (TCP protocol
# number per IANA), IPPROTO_UDP==17 (UDP protocol number per IANA) are
# consistent across all POSIX platforms. IPPROTO_IP==0 is also cross-platform.
# socket_extra96 anchors AF_INET/SOCK_STREAM/SOCK_DGRAM class names; no prior
# socket spec anchors the integer __eq__ values together as a grouped table
# under sockconst293. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra247.socket_constants_integer_values:
  description: "AF_INET.__eq__(2)==True / SOCK_STREAM.__eq__(1)==True / SOCK_DGRAM.__eq__(2)==True / IPPROTO_TCP.__eq__(6)==True / IPPROTO_UDP.__eq__(17)==True / IPPROTO_IP.__eq__(0)==True — cross-platform POSIX constants; AF_INET=2 (IPv4), SOCK_STREAM=1 (TCP stream), SOCK_DGRAM=2 (UDP datagram), IPPROTO_TCP=6 and IPPROTO_UDP=17 (IANA protocol numbers), IPPROTO_IP=0; AF_INET6 excluded (platform-dependent: 30 macOS, 10 Linux); extra96 anchors class names; first sockconst293 anchor for integer __eq__ values"
  kind: python_call_eq
  category: socket_constants
  id_prefix: sockconst293

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_eq,       AF_INET.__eq__,       [2],  true, "AF_INET == 2 (IPv4 address family; cross-platform POSIX constant)"]
    - [sock_stream_eq,   SOCK_STREAM.__eq__,   [1],  true, "SOCK_STREAM == 1 (TCP-style stream socket; cross-platform)"]
    - [sock_dgram_eq,    SOCK_DGRAM.__eq__,    [2],  true, "SOCK_DGRAM == 2 (UDP-style datagram socket; cross-platform)"]
    - [ipproto_tcp_eq,   IPPROTO_TCP.__eq__,   [6],  true, "IPPROTO_TCP == 6 (IANA-assigned TCP protocol number)"]
    - [ipproto_udp_eq,   IPPROTO_UDP.__eq__,   [17], true, "IPPROTO_UDP == 17 (IANA-assigned UDP protocol number)"]
    - [ipproto_ip_eq,    IPPROTO_IP.__eq__,    [0],  true, "IPPROTO_IP == 0 (IP protocol level; used with setsockopt)"]

# ---------------------------------------------------------------------------
# socket.AF_INET/SOCK_STREAM enum class names and member names
#
# Wave 293 theme: AddressFamily and SocketKind IntEnum type identity.
#
# AF_INET is an AddressFamily IntEnum (Python 3.4+ wraps AF_* constants in
# IntEnum). SOCK_STREAM is a SocketKind IntEnum. AF_INET.name is 'AF_INET'
# (the enum member name); SOCK_STREAM.name is 'SOCK_STREAM'; SOCK_DGRAM.name
# is 'SOCK_DGRAM'. socket_extra96 anchors AddressFamily/SocketKind __bases__;
# no prior socket spec anchors __class__.__name__ and .name together as a
# grouped table for AF_INET/SOCK_STREAM under sockconst293.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra247.socket_enum_identity:
  description: "AF_INET.__class__.__name__.__eq__('AddressFamily')==True / SOCK_STREAM.__class__.__name__.__eq__('SocketKind')==True / SOCK_DGRAM.__class__.__name__.__eq__('SocketKind')==True / AF_INET.name.__eq__('AF_INET')==True / SOCK_STREAM.name.__eq__('SOCK_STREAM')==True / SOCK_DGRAM.name.__eq__('SOCK_DGRAM')==True — AF_INET is AddressFamily IntEnum; SOCK_STREAM/SOCK_DGRAM are SocketKind IntEnum; .name gives the enum member name string; extra96 anchors AddressFamily/SocketKind __bases__; first sockconst293 anchor for __class__.__name__ and .name"
  kind: python_call_eq
  category: enum_identity
  id_prefix: sockconst293

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class,      "AF_INET.__class__.__name__.__eq__",      ["AddressFamily"], true, "type(AF_INET).__name__ is 'AddressFamily' (IntEnum subclass)"]
    - [sock_stream_class,  "SOCK_STREAM.__class__.__name__.__eq__",  ["SocketKind"],    true, "type(SOCK_STREAM).__name__ is 'SocketKind' (IntEnum subclass)"]
    - [sock_dgram_class,   "SOCK_DGRAM.__class__.__name__.__eq__",   ["SocketKind"],    true, "type(SOCK_DGRAM).__name__ is 'SocketKind' (IntEnum subclass)"]
    - [af_inet_name,       "AF_INET.name.__eq__",                    ["AF_INET"],       true, "AF_INET.name is 'AF_INET' (enum member name string)"]
    - [sock_stream_name,   "SOCK_STREAM.name.__eq__",                ["SOCK_STREAM"],   true, "SOCK_STREAM.name is 'SOCK_STREAM' (enum member name string)"]
    - [sock_dgram_name,    "SOCK_DGRAM.name.__eq__",                 ["SOCK_DGRAM"],    true, "SOCK_DGRAM.name is 'SOCK_DGRAM' (enum member name string)"]

# ---------------------------------------------------------------------------
# socket.socket class identity
#
# Wave 293 theme: socket.socket class __name__, __module__, and __qualname__.
#
# socket.socket is the main class for creating network socket objects. Its
# __name__, __module__, and __qualname__ are all relevant to its identity.
# __name__ == 'socket' (bare class name); __module__ == 'socket' (defined in
# Lib/socket.py); __qualname__ == 'socket' (same as __name__ for top-level
# classes). socket_extra96 anchors socket.__bases__ but does not anchor
# __name__/__module__/__qualname__ together as a grouped table under sockconst293.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra247.socket_class_identity:
  description: "socket.__name__.__eq__('socket')==True / socket.__module__.__eq__('socket')==True / socket.__qualname__.__eq__('socket')==True — socket.socket is the main network socket class; __name__==__qualname__=='socket' (4 chars; top-level class); __module__=='socket' (defined in Lib/socket.py); extra96 anchors socket.__bases__; first sockconst293 anchor for socket class __name__/__module__/__qualname__ grouped table"
  kind: python_call_eq
  category: class_identity
  id_prefix: sockconst293

  columns: [id, function, args, expected, description]
  rows:
    - [sock_name_eq,     "socket.__name__.__eq__",     ["socket"], true, "socket.socket.__name__ is 'socket' (bare class name; same as __qualname__)"]
    - [sock_module_eq,   "socket.__module__.__eq__",   ["socket"], true, "socket.socket.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [sock_qualname_eq, "socket.__qualname__.__eq__", ["socket"], true, "socket.socket.__qualname__ is 'socket' (top-level class; __qualname__==__name__)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) — standalone
#
# socket.AF_INET is 2. AF_INET is the address family constant for IPv4 sockets.
# On all POSIX systems (macOS, Linux, FreeBSD, etc.) its numeric value is 2.
# It is an AddressFamily IntEnum member, but because IntEnum subclasses int,
# __eq__(2) returns True. AF_INET==2 is one of the most fundamental socket
# constants — used whenever creating a TCP or UDP socket for IPv4 networking
# (socket.socket(socket.AF_INET, socket.SOCK_STREAM)). socket_extra96 anchors
# AF_INET.__class__.__name__; no prior socket spec anchors AF_INET.__eq__(2)
# as a standalone under sockconst293. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra247.AF_INET_eq_2:
  description: "socket.AF_INET.__eq__(2) == True — AF_INET is the IPv4 address family; numeric value 2 on all POSIX platforms; AddressFamily IntEnum member (IntEnum subclasses int so __eq__(2) is True); fundamental constant for IPv4 TCP/UDP sockets; extra96 anchors __class__.__name__; no prior socket spec anchors AF_INET.__eq__(2) as standalone; first standalone under sockconst293"
  category: socket_constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6) — standalone
#
# socket.IPPROTO_TCP is 6. IPPROTO_TCP is the IP protocol number for TCP
# (Transmission Control Protocol), as assigned by IANA in RFC 793. The value
# 6 is identical on all platforms because it is defined by the Internet
# standard. IPPROTO_TCP is used with setsockopt to configure TCP-level socket
# options (e.g., TCP_NODELAY). Unlike AF_INET which is an AddressFamily IntEnum,
# IPPROTO_TCP is a plain int on macOS/Python 3.14.3. No prior socket spec
# anchors IPPROTO_TCP.__eq__(6) as a standalone under sockconst293.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra247.IPPROTO_TCP_eq_6:
  description: "socket.IPPROTO_TCP.__eq__(6) == True — IPPROTO_TCP is IANA-assigned TCP protocol number (RFC 793); value 6 is identical on all platforms; plain int type on macOS/Python 3.14.3; used with setsockopt for TCP-level options (e.g., TCP_NODELAY); no prior socket spec anchors IPPROTO_TCP.__eq__(6) as standalone; first standalone under sockconst293"
  category: socket_constants
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_UDP.__eq__(17) — standalone
#
# socket.IPPROTO_UDP is 17. IPPROTO_UDP is the IP protocol number for UDP
# (User Datagram Protocol), as assigned by IANA in RFC 768. The value 17 is
# identical on all platforms because it is defined by the Internet standard.
# IPPROTO_UDP is used with setsockopt for UDP-level socket configuration.
# Like IPPROTO_TCP, it is a plain int (not IntEnum) on macOS/Python 3.14.3.
# No prior socket spec anchors IPPROTO_UDP.__eq__(17) as a standalone under
# sockconst293. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra247.IPPROTO_UDP_eq_17:
  description: "socket.IPPROTO_UDP.__eq__(17) == True — IPPROTO_UDP is IANA-assigned UDP protocol number (RFC 768); value 17 is identical on all platforms; plain int type on macOS/Python 3.14.3; used with setsockopt for UDP-level socket configuration; no prior socket spec anchors IPPROTO_UDP.__eq__(17) as standalone; first standalone under sockconst293"
  category: socket_constants
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket'. The socket class in Lib/socket.py is a
# Python-level wrapper around _socket.socket (a C type from socketmodule.c).
# The class is named 'socket' at the top level of the socket module, so
# __name__ == __qualname__ == 'socket'. This is the entry point for creating
# all network socket objects. socket_extra96 anchors socket.__bases__; no
# prior socket spec anchors socket.socket.__name__.__eq__ as a standalone
# under sockconst293. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra247.socket_socket_name_eq:
  description: "socket.socket.__name__.__eq__('socket') == True — socket.socket.__name__ is 'socket'; Python wrapper class defined in Lib/socket.py; inherits from _socket.socket (C type); __name__==__qualname__=='socket' (top-level class); entry point for creating all network socket objects; extra96 anchors socket.__bases__; first standalone for socket.__name__.__eq__ under sockconst293"
  category: class_identity
  kind: python_call_eq
  function: "socket.__name__.__eq__"
  args: ["socket"]
  expected: true
