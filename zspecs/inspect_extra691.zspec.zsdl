spec: inspect_extra691
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers inspect module source inspection function identity and qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra691.argspec_identity:
  description: "inspect.getfullargspec and getcallargs identity attributes"
  kind: python_call_eq
  category: argspec_identity
  id_prefix: in691as
  columns: [id, function, args, expected]
  rows:
    - [in691as001, inspect.getfullargspec.__qualname__.__eq__, ["getfullargspec"], true]
    - [in691as002, inspect.getfullargspec.__module__.__eq__, ["inspect"], true]
    - [in691as003, inspect.getcallargs.__qualname__.__eq__, ["getcallargs"], true]
    - [in691as004, inspect.getcallargs.__module__.__eq__, ["inspect"], true]

table inspect_extra691.class_inspection_identity:
  description: "inspect class inspection function identity attributes"
  kind: python_call_eq
  category: class_inspection_identity
  id_prefix: in691ci
  columns: [id, function, args, expected]
  rows:
    - [in691ci001, inspect.getmro.__qualname__.__eq__, ["getmro"], true]
    - [in691ci002, inspect.getmro.__module__.__eq__, ["inspect"], true]
    - [in691ci003, inspect.getattr_static.__qualname__.__eq__, ["getattr_static"], true]
    - [in691ci004, inspect.getattr_static.__module__.__eq__, ["inspect"], true]
    - [in691ci005, inspect.classify_class_attrs.__qualname__.__eq__, ["classify_class_attrs"], true]
    - [in691ci006, inspect.classify_class_attrs.__module__.__eq__, ["inspect"], true]

table inspect_extra691.source_functions_identity:
  description: "inspect source retrieval function identity attributes"
  kind: python_call_eq
  category: source_functions_identity
  id_prefix: in691sf
  columns: [id, function, args, expected]
  rows:
    - [in691sf001, inspect.getdoc.__module__.__eq__, ["inspect"], true]
    - [in691sf002, inspect.getsourcelines.__qualname__.__eq__, ["getsourcelines"], true]
    - [in691sf003, inspect.getsourcefile.__qualname__.__eq__, ["getsourcefile"], true]
