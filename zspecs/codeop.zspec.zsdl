spec: codeop
version: ">=3.0"
backend: python_module(codeop)

docs: https://docs.python.org/3/library/codeop.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/codeop.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "codeop source: Lib/codeop.py (PSF; source inspection permitted)"
  not_derived_from:
    - "codeop source: internal future-flag accumulation implementation details"
  notes:
    - "codeop.compile_command() compiles a source string; returns a code object if complete, None if incomplete, raises SyntaxError on error."
    - "codeop.CommandCompiler accumulates __future__ import flags across successive compile_command() calls."
    - "codeop.Compile is a callable class that compiles source remembering future import flags; used internally by CommandCompiler."
    - "CommandCompiler.__call__ and Compile.__call__ implement the callable interface."
    - "compile_command('x = 1') returns a code object whose __class__.__name__ is 'code'."
    - "compile_command('if True:') returns None because the statement is syntactically incomplete."
    - "codeop.CommandCompiler.__module__ == 'codeop'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name check
# ---------------------------------------------------------------------------

invariant codeop.names.compile_command:
  description: "codeop.compile_command.__name__ == 'compile_command'"
  category: names
  kind: python_call_eq
  function: compile_command.__name__.__eq__
  args: ["compile_command"]
  expected: true

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant codeop.names.CommandCompiler:
  description: "codeop.CommandCompiler.__name__ == 'CommandCompiler'"
  category: names
  kind: python_call_eq
  function: CommandCompiler.__name__.__eq__
  args: ["CommandCompiler"]
  expected: true

invariant codeop.names.Compile:
  description: "codeop.Compile.__name__ == 'Compile'"
  category: names
  kind: python_call_eq
  function: Compile.__name__.__eq__
  args: ["Compile"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

invariant codeop.modules.CommandCompiler_module:
  description: "codeop.CommandCompiler.__module__ == 'codeop'"
  category: modules
  kind: python_call_eq
  function: CommandCompiler.__module__.__eq__
  args: ["codeop"]
  expected: true

# ---------------------------------------------------------------------------
# Method name checks — __call__ on both callable classes
# ---------------------------------------------------------------------------

invariant codeop.methods.CommandCompiler_call:
  description: "codeop.CommandCompiler.__call__.__name__ == '__call__'"
  category: methods
  kind: python_call_eq
  function: CommandCompiler.__call__.__name__.__eq__
  args: ["__call__"]
  expected: true

invariant codeop.methods.Compile_call:
  description: "codeop.Compile.__call__.__name__ == '__call__'"
  category: methods
  kind: python_call_eq
  function: Compile.__call__.__name__.__eq__
  args: ["__call__"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: compile_command — complete statement returns a code object
# ---------------------------------------------------------------------------

invariant codeop.compile_command.complete_returns_code:
  description: "codeop.compile_command('x = 1').__class__.__name__ == 'code' — returns a code object for complete input"
  category: behavioral
  kind: python_call_eq
  function: compile_command
  args: ["x = 1"]
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: compile_command — incomplete statement returns None
# ---------------------------------------------------------------------------

invariant codeop.compile_command.incomplete_returns_none:
  description: "codeop.compile_command('if True:') == None — incomplete statement returns None"
  category: behavioral
  kind: python_call_eq
  function: compile_command
  args: ["if True:"]
  expected: null
