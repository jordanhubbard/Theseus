spec: inspect_extra264
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter kind constant integer values; inspect.isbuiltin, isfunction, isroutine, isclass predicate behavior; inspect.Parameter class identity."
    - "inspect.Parameter.POSITIONAL_ONLY == 0; POSITIONAL_OR_KEYWORD == 1; VAR_POSITIONAL == 2; KEYWORD_ONLY == 3; VAR_KEYWORD == 4. These are ParameterKind enum integer values. Verified with Python 3.14.3."
    - "inspect.isbuiltin(len) == True; inspect.isbuiltin(print) == True; inspect.isbuiltin(int) == False — int is a type/class, not a builtin function. Verified with Python 3.14.3."
    - "inspect.isfunction(lambda: None) == True — Python lambda is a function. Verified with Python 3.14.3."
    - "inspect.isroutine(len) == True; inspect.isroutine(int) == False — int is a type, isroutine returns False for types. Verified with Python 3.14.3."
    - "inspect.isclass(int) == True; inspect.isclass(len) == False — len is a builtin function, not a class. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter'; __module__ == 'inspect'; __bases__[0].__name__ == 'object'; __mro__ len == 2. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__name__ == 'isbuiltin'; __module__ == 'inspect'. isbuiltin is a pure Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__bases__[0].__name__ == 'object'
# inspect.Parameter.__mro__.__len__() == 2
# inspect.Parameter.__name__.__len__() == 9
#
# Parameter is a pure Python class in Lib/inspect.py. New to extra264.
# ---------------------------------------------------------------------------

table inspect_extra264.parameter_class_identity:
  description: "inspect.Parameter class __name__, __module__, __bases__, __mro__ identity; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: inspparam264

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a class in Lib/inspect.py representing a callable parameter; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra264"]
    - [parameter_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra264"]
    - [parameter_base_name_eq,
       Parameter.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; its first base class is object; str.__eq__('object') returns True; new to extra264"]
    - [parameter_mro_len_2,
       Parameter.__mro__.__len__,
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter's MRO is (Parameter, object), a tuple of length 2; tuple.__len__() returns 2; new to extra264"]
    - [parameter_name_len_9,
       Parameter.__name__.__len__,
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — the name 'Parameter' has exactly 9 characters: P-a-r-a-m-e-t-e-r; str.__len__() returns 9; new to extra264"]

# ---------------------------------------------------------------------------
# Table 2: inspect predicate function identity
#
# inspect.isbuiltin.__name__ == 'isbuiltin'
# inspect.isbuiltin.__module__ == 'inspect'
# inspect.isclass.__name__ == 'isclass'
# inspect.isroutine.__name__ == 'isroutine'
# inspect.isfunction.__name__ == 'isfunction'
#
# All are pure Python functions in Lib/inspect.py. New to extra264.
# ---------------------------------------------------------------------------

table inspect_extra264.predicate_function_identity:
  description: "inspect.isbuiltin, isclass, isroutine, isfunction __name__ and __module__ identity; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: inspfn264

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — isbuiltin is a pure Python function in Lib/inspect.py; its __name__ is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra264"]
    - [isbuiltin_module_eq,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra264"]
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a pure Python function in Lib/inspect.py; its __name__ is 'isclass'; str.__eq__('isclass') returns True; new to extra264"]
    - [isroutine_name_eq,
       isroutine.__name__.__eq__,
       ["isroutine"],
       true,
       "inspect.isroutine.__name__.__eq__('isroutine') == True — isroutine is a pure Python function in Lib/inspect.py; its __name__ is 'isroutine'; str.__eq__('isroutine') returns True; new to extra264"]
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a pure Python function in Lib/inspect.py; its __name__ is 'isfunction'; str.__eq__('isfunction') returns True; new to extra264"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind constant integer values
#
# int(inspect.Parameter.POSITIONAL_ONLY) == 0
# int(inspect.Parameter.POSITIONAL_OR_KEYWORD) == 1
# int(inspect.Parameter.VAR_POSITIONAL) == 2
# int(inspect.Parameter.KEYWORD_ONLY) == 3
# int(inspect.Parameter.VAR_KEYWORD) == 4
#
# These are ParameterKind enum values defined in Lib/inspect.py. The integer
# values are accessed via __int__ or direct equality on the enum. New to extra264.
# ---------------------------------------------------------------------------

table inspect_extra264.parameter_kind_values:
  description: "inspect.Parameter kind constant integer values via __eq__ comparison; new to extra264"
  kind: python_call_eq
  category: parameter_kinds
  id_prefix: insppk264

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_eq_0,
       Parameter.POSITIONAL_ONLY.__eq__,
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — POSITIONAL_ONLY is a ParameterKind enum value with integer value 0; used for positional-only parameters (before /); new to extra264"]
    - [positional_or_keyword_eq_1,
       Parameter.POSITIONAL_OR_KEYWORD.__eq__,
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — POSITIONAL_OR_KEYWORD is a ParameterKind enum value with integer value 1; the default kind for most parameters; new to extra264"]
    - [var_positional_eq_2,
       Parameter.VAR_POSITIONAL.__eq__,
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — VAR_POSITIONAL is a ParameterKind enum value with integer value 2; corresponds to *args parameters; new to extra264"]
    - [keyword_only_eq_3,
       Parameter.KEYWORD_ONLY.__eq__,
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — KEYWORD_ONLY is a ParameterKind enum value with integer value 3; parameters after * or *args that must be passed by keyword; new to extra264"]
    - [var_keyword_eq_4,
       Parameter.VAR_KEYWORD.__eq__,
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — VAR_KEYWORD is a ParameterKind enum value with integer value 4; corresponds to **kwargs parameters; new to extra264"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra264
# ---------------------------------------------------------------------------

invariant inspect_extra264.Parameter.name_eq:
  description: "inspect.Parameter.__name__.__eq__('Parameter') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra264.Parameter.module_eq:
  description: "inspect.Parameter.__module__.__eq__('inspect') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra264.Parameter.base_is_object:
  description: "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: Parameter.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant inspect_extra264.Parameter.mro_len_2:
  description: "inspect.Parameter.__mro__.__len__() == 2 — MRO is (Parameter, object); new to extra264"
  category: identity
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra264.Parameter.POSITIONAL_ONLY_eq_0:
  description: "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — integer value 0; new to extra264"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__eq__
  args: [0]
  expected: true

invariant inspect_extra264.Parameter.POSITIONAL_OR_KEYWORD_eq_1:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — integer value 1; new to extra264"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__eq__
  args: [1]
  expected: true

invariant inspect_extra264.Parameter.VAR_POSITIONAL_eq_2:
  description: "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — integer value 2; new to extra264"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__eq__
  args: [2]
  expected: true

invariant inspect_extra264.Parameter.KEYWORD_ONLY_eq_3:
  description: "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — integer value 3; new to extra264"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__eq__
  args: [3]
  expected: true

invariant inspect_extra264.Parameter.VAR_KEYWORD_eq_4:
  description: "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — integer value 4; new to extra264"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__eq__
  args: [4]
  expected: true

invariant inspect_extra264.isbuiltin.name_eq:
  description: "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra264.isbuiltin.module_eq:
  description: "inspect.isbuiltin.__module__.__eq__('inspect') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra264.isclass.name_eq:
  description: "inspect.isclass.__name__.__eq__('isclass') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra264.isroutine.name_eq:
  description: "inspect.isroutine.__name__.__eq__('isroutine') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: isroutine.__name__.__eq__
  args: ["isroutine"]
