# ---------------------------------------------------------------------------
# Table 1: functools.reduce.__class__ type-string lengths
#
# Wave 268 theme: functools.reduce is a C-extension builtin_function_or_method.
# Its type object (__class__) has __name__ == 'builtin_function_or_method'
# (26 chars — the longest standard type-name encountered in these specs) and
# __qualname__ == 'builtin_function_or_method' (also 26 chars — for top-level
# C types __qualname__ equals __name__). Both lengths are 26. The __module__
# of the type is 'builtins' (8 chars). Previously covered: __class__.__name__
# (equality), __class__.__module__ (equality), __class__.__qualname__
# (equality). New here: __class__.__name__.__len__ (26),
# __class__.__qualname__.__len__ (26), __class__.__module__.__len__ (8).
#
# reduce.__class__.__name__.__len__() == 26
# reduce.__class__.__qualname__.__len__() == 26
# reduce.__class__.__module__.__len__() == 8
#
# New to extra122.
# ---------------------------------------------------------------------------

table functools_extra122.reduce_class_string_lengths:
  description: "functools.reduce: __class__.__name__ len=26, __class__.__qualname__ len=26 (equal; 'builtin_function_or_method'), __class__.__module__ len=8 ('builtins'); longest standard type-name; wave 268; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsrcsl122

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_len,
       "reduce.__class__.__name__.__len__",
       [],
       26,
       "functools.reduce.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 chars: b-u-i-l-t-i-n(7)+_(1)+f-u-n-c-t-i-o-n(8)+_(1)+o-r(2)+_(1)+m-e-t-h-o-d(6); the longest standard type-name in these specs; str.__len__() returns 26; new to extra122"]
    - [reduce_class_qualname_len,
       "reduce.__class__.__qualname__.__len__",
       [],
       26,
       "functools.reduce.__class__.__qualname__.__len__() == 26 — __qualname__ is also 'builtin_function_or_method' (26 chars); for a top-level C type __qualname__ equals __name__; str.__len__() returns 26; new to extra122"]
    - [reduce_class_name_eq_qualname_len,
       "reduce.__class__.__qualname__.__len__",
       [],
       26,
       "functools.reduce.__class__.__qualname__.__len__() == 26 — confirming __class__.__qualname__ length equals __class__.__name__ length (both 26); top-level C types have equal __name__ and __qualname__; str.__len__() returns 26; new to extra122"]
    - [reduce_class_module_len,
       "reduce.__class__.__module__.__len__",
       [],
       8,
       "functools.reduce.__class__.__module__.__len__() == 8 — 'builtins' has 8 chars: b-u-i-l-t-i-n-s; the builtin_function_or_method type is defined in the builtins module; str.__len__() returns 8; new to extra122"]
    - [reduce_class_module_eq,
       "reduce.__class__.__module__.__eq__",
       ["builtins"],
       true,
       "functools.reduce.__class__.__module__.__eq__('builtins') == True — the type builtin_function_or_method is defined in 'builtins' (8 chars), not in '_functools' where reduce itself lives; str.__eq__('builtins') returns True; new to extra122"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce attribute __class__.__name__ on string attributes
#
# Wave 268 theme: functools.reduce's string attributes (__name__, __module__,
# __qualname__) are all plain Python str objects. Checking __class__.__name__
# on each confirms the type is 'str'. reduce.__module__.__class__.__name__
# is 'str' (the __module__ attribute '_functools' is a str). Similarly
# reduce.__name__.__class__.__name__ is 'str'. These string-type confirmations
# are new to extra122.
#
# reduce.__module__.__class__.__name__ == 'str'
# reduce.__name__.__class__.__name__ == 'str'
# reduce.__qualname__.__class__.__name__ == 'str' (already covered separately
#   but here we confirm via __len__)
#
# New to extra122.
# ---------------------------------------------------------------------------

table functools_extra122.reduce_string_attr_types:
  description: "functools.reduce string attribute types: __module__.__class__.__name__='str', __name__.__class__.__name__='str'; both string attrs are plain Python str; wave 268; new to extra122"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsrsat122

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_class_name,
       "reduce.__module__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__module__.__class__.__name__.__eq__('str') == True — the __module__ attribute '_functools' is a plain Python str; str.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra122"]
    - [reduce_name_class_name,
       "reduce.__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__name__.__class__.__name__.__eq__('str') == True — the __name__ attribute 'reduce' is a plain Python str; str.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra122"]
    - [reduce_module_class_name_len,
       "reduce.__module__.__class__.__name__.__len__",
       [],
       3,
       "functools.reduce.__module__.__class__.__name__.__len__() == 3 — 'str' has 3 chars: s-t-r; the type name for Python strings; str.__len__() returns 3; new to extra122"]
    - [reduce_name_class_name_len,
       "reduce.__name__.__class__.__name__.__len__",
       [],
       3,
       "functools.reduce.__name__.__class__.__name__.__len__() == 3 — 'str' has 3 chars; same as __module__.__class__.__name__.__len__(); all string attrs have type 'str'; str.__len__() returns 3; new to extra122"]
    - [reduce_class_module_class_name,
       "reduce.__class__.__module__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__class__.__module__.__class__.__name__.__eq__('str') == True — the __module__ of the class type is 'builtins', itself a str; str.__eq__('str') returns True; new to extra122"]

# ---------------------------------------------------------------------------
# Table 3: functools.reduce __class__.__name__ vs __module__ length comparison
#
# Wave 268 theme: functools.reduce lives in two different modules: __module__
# is '_functools' (10 chars, the C extension where reduce is defined) while
# __class__.__module__ is 'builtins' (8 chars, where builtin_function_or_method
# is defined). The __class__.__name__ length (26) is much longer than the
# __module__ length (10) or the __class__.__module__ length (8). All these
# length comparisons are new to extra122.
#
# reduce.__module__.__len__() == 10   (already covered, re-used for comparison)
# reduce.__class__.__module__.__len__() == 8   (new to extra122)
# reduce.__class__.__name__.__len__() == 26    (new to extra122)
# 26 > 10 > 8
#
# New to extra122.
# ---------------------------------------------------------------------------

table functools_extra122.reduce_length_comparison:
  description: "functools.reduce length hierarchy: __class__.__name__ len=26 > __module__ len=10 > __class__.__module__ len=8; 'builtin_function_or_method' vs '_functools' vs 'builtins'; wave 268; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsrlc122

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_26,
       "reduce.__class__.__name__.__len__",
       [],
       26,
       "functools.reduce.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' is 26 chars; the longest string in the reduce attribute chain; str.__len__() returns 26; new to extra122"]
    - [reduce_module_10,
       "reduce.__module__.__len__",
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — '_functools' has 10 chars: _(1)+f-u-n-c-t-o-o-l-s(9); the C extension where reduce is implemented; str.__len__() returns 10; new to extra122"]
    - [reduce_class_module_8,
       "reduce.__class__.__module__.__len__",
       [],
       8,
       "functools.reduce.__class__.__module__.__len__() == 8 — 'builtins' has 8 chars: b-u-i-l-t-i-n-s; where the builtin_function_or_method type lives; str.__len__() returns 8; new to extra122"]
    - [reduce_name_6,
       "reduce.__name__.__len__",
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 chars; shorter than __module__ (10) and much shorter than __class__.__name__ (26); str.__len__() returns 6; new to extra122"]
    - [reduce_class_module_not_functools,
       "reduce.__class__.__module__.__eq__",
       ["_functools"],
       false,
       "functools.reduce.__class__.__module__.__eq__('_functools') == False — the class type is in 'builtins', not '_functools'; the module of the type and the module of the function are different strings; str.__eq__('_functools') returns False; new to extra122"]

