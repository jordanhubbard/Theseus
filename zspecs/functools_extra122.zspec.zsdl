# Standalone invariants — extra122
# ---------------------------------------------------------------------------

invariant functools_extra122.reduce_class_name_len:
  description: "functools.reduce.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' is 26 chars; longest standard type-name; wave 268; new to extra122"
  kind: python_call_eq
  function: reduce.__class__.__name__.__len__
  args: []
  expected: 26

invariant functools_extra122.reduce_class_module:
  description: "functools.reduce.__class__.__module__ == 'builtins' — builtin_function_or_method type is defined in builtins, len 8; wave 268; new to extra122"
  kind: python_call_eq
  function: reduce.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant functools_extra122.reduce_module_class_name:
  description: "functools.reduce.__module__.__class__.__name__ == 'str' — the __module__ attribute is a plain Python str; wave 268; new to extra122"
  kind: python_call_eq
  function: reduce.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra122.reduce_name_class_name:
  description: "functools.reduce.__name__.__class__.__name__ == 'str' — the __name__ attribute is a plain Python str; wave 268; new to extra122"
  kind: python_call_eq
  function: reduce.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra122.reduce_class_qualname_len:
  description: "functools.reduce.__class__.__qualname__.__len__() == 26 — 'builtin_function_or_method' qualname has same length as __name__ (26); top-level C type; wave 268; new to extra122"
  kind: python_call_eq
  function: reduce.__class__.__qualname__.__len__
  args: []
  expected: 26

