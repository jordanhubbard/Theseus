  args: [16]
  expected: true

invariant re_extra188.verbose_eq_64:
  description: "re.VERBOSE == 64 — RegexFlag.VERBOSE integer value is 64 (bit 6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.VERBOSE.__eq__
  args: [64]
  expected: true

invariant re_extra188.ascii_eq_256:
  description: "re.ASCII == 256 — RegexFlag.ASCII integer value is 256 (bit 8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.ASCII.__eq__
  args: [256]
  expected: true

invariant re_extra188.unicode_eq_32:
  description: "re.UNICODE == 32 — RegexFlag.UNICODE integer value is 32 (bit 5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
