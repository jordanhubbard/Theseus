spec: re_extra188
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "re.__name__ == 're' (len=2)."
    - "re.IGNORECASE == 2 (RegexFlag.IGNORECASE, flag bit 1)."
    - "re.MULTILINE == 8 (RegexFlag.MULTILINE, flag bit 3)."
    - "re.DOTALL == 16 (RegexFlag.DOTALL, flag bit 4)."
    - "re.VERBOSE == 64 (RegexFlag.VERBOSE, flag bit 6)."
    - "re.ASCII == 256 (RegexFlag.ASCII, flag bit 8)."
    - "re.UNICODE == 32 (RegexFlag.UNICODE, flag bit 5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re module __name__ identity
# re.__name__ == 're', len == 2
# ---------------------------------------------------------------------------

table re_extra188.module_name:
  description: "re module __name__ identity: re.__name__ == 're' and len == 2"
  kind: python_call_eq
  category: identity
  id_prefix: reflags188

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    re.__name__.__eq__,   ["re"], true, "re.__name__ == 're' — the re module's __name__ attribute is the string 're'; confirmed Python 3.14.3 macOS"]
    - [name_len,   re.__name__.__len__,  [],     2,    "re.__name__.__len__() == 2 — 're' has 2 characters: r(1)e(2); confirmed Python 3.14.3 macOS"]
    - [name_len_eq, re.__name__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "re.__name__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re flags — IGNORECASE, MULTILINE, DOTALL, VERBOSE
# IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64
# ---------------------------------------------------------------------------

table re_extra188.flags_set1:
  description: "re regex flags integer values: IGNORECASE(2), MULTILINE(8), DOTALL(16), VERBOSE(64)"
  kind: python_call_eq
  category: identity
  id_prefix: reflags188

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_eq,  re.IGNORECASE.__eq__, [2],  true, "re.IGNORECASE == 2 — RegexFlag.IGNORECASE is bit 1, integer value 2; confirmed Python 3.14.3 macOS"]
    - [multiline_eq,   re.MULTILINE.__eq__,  [8],  true, "re.MULTILINE == 8 — RegexFlag.MULTILINE is bit 3, integer value 8; confirmed Python 3.14.3 macOS"]
    - [dotall_eq,      re.DOTALL.__eq__,     [16], true, "re.DOTALL == 16 — RegexFlag.DOTALL is bit 4, integer value 16; confirmed Python 3.14.3 macOS"]
    - [verbose_eq,     re.VERBOSE.__eq__,    [64], true, "re.VERBOSE == 64 — RegexFlag.VERBOSE is bit 6, integer value 64; confirmed Python 3.14.3 macOS"]
    - [ignorecase_lt_multiline, re.IGNORECASE.__lt__, [8], true, "re.IGNORECASE (2) < re.MULTILINE (8); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re flags — ASCII, UNICODE
# ASCII==256, UNICODE==32
# ---------------------------------------------------------------------------

table re_extra188.flags_set2:
  description: "re regex flags integer values: ASCII(256), UNICODE(32)"
  kind: python_call_eq
  category: identity
  id_prefix: reflags188

  columns: [id, function, args, expected, description]
  rows:
    - [ascii_eq,    re.ASCII.__eq__,   [256], true, "re.ASCII == 256 — RegexFlag.ASCII is bit 8, integer value 256; confirmed Python 3.14.3 macOS"]
    - [unicode_eq,  re.UNICODE.__eq__,  [32], true, "re.UNICODE == 32 — RegexFlag.UNICODE is bit 5, integer value 32; confirmed Python 3.14.3 macOS"]
    - [unicode_lt_ascii,  re.UNICODE.__lt__, [256], true, "re.UNICODE (32) < re.ASCII (256); confirmed Python 3.14.3 macOS"]
    - [ascii_gt_verbose,  re.ASCII.__gt__,   [64],  true, "re.ASCII (256) > re.VERBOSE (64); confirmed Python 3.14.3 macOS"]
    - [dotall_lt_verbose, re.DOTALL.__lt__,  [64],  true, "re.DOTALL (16) < re.VERBOSE (64); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra188.module_name_eq:
  description: "re.__name__ == 're' — the re module's __name__ attribute is the string 're'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra188.module_name_len_2:
  description: "re.__name__.__len__() == 2 — 're' has 2 characters: r(1)e(2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__name__.__len__
  args: []
  expected: 2

invariant re_extra188.ignorecase_eq_2:
  description: "re.IGNORECASE == 2 — RegexFlag.IGNORECASE integer value is 2 (bit 1); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.IGNORECASE.__eq__
  args: [2]
  expected: true

invariant re_extra188.multiline_eq_8:
