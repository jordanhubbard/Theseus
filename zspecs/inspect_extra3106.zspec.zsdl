spec: in3106
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (in3106): __lt__, __le__, __gt__ dict-presence checks for inspect types."
    - "No inspect type defines __lt__, __le__, or __gt__ in its own __dict__."
    - "inspect.Parameter defines __eq__ and __hash__ (wave 653), but not ordering operators; it is not sortable via <, <=, >."
    - "inspect.Signature defines __eq__ and __hash__ (wave 653), but not ordering operators."
    - "inspect.BoundArguments defines __eq__ and __hash__ = None (wave 653), but not ordering operators."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses; none define ordering operators in their own __dict__."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception classes; none define ordering operators in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3106.lt:
  description: "inspect types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3106
  columns: [id, function, args, expected]
  rows:
    - ["in3106001", operator.contains, [inspect.Parameter.__dict__,           "__lt__"], false]
    - ["in3106002", operator.contains, [inspect.Signature.__dict__,           "__lt__"], false]
    - ["in3106003", operator.contains, [inspect.BoundArguments.__dict__,      "__lt__"], false]
    - ["in3106004", operator.contains, [inspect.FrameInfo.__dict__,           "__lt__"], false]
    - ["in3106005", operator.contains, [inspect.ArgInfo.__dict__,             "__lt__"], false]
    - ["in3106006", operator.contains, [inspect.FullArgSpec.__dict__,         "__lt__"], false]
    - ["in3106007", operator.contains, [inspect.Attribute.__dict__,           "__lt__"], false]
    - ["in3106008", operator.contains, [inspect.ClassFoundException.__dict__, "__lt__"], false]
    - ["in3106009", operator.contains, [inspect.EndOfBlock.__dict__,          "__lt__"], false]

