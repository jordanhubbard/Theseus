spec: code_extra5
version: ">=3.9"
backend: python_module(code)

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/code.html — Python code module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/code.py"
  notes:
    - "This spec extends code.zspec.zsdl and code_extra through code_extra4.zspec.zsdl."
    - "code covers: interact/__name__, compile_command/__name__, InteractiveConsole/__name__, InteractiveInterpreter/__name__, CommandCompiler/__name__; InteractiveConsole.__module__, __bases__[0].__name__; method names on InteractiveInterpreter; behavioral compile_command tests."
    - "code_extra covers: all class/function __name__ and __module__, InteractiveInterpreter method names table."
    - "code_extra2 covers: InteractiveInterpreter.__bases__[0].__name__, compile_command/__module__, interact/__module__, class __qualname__ table."
    - "code_extra3 covers: __bases__.__len__ for InteractiveConsole/InteractiveInterpreter; CommandCompiler/__interact/compile_command __qualname__; InteractiveConsole.__bases__[0].__qualname__."
    - "code_extra4 covers: InteractiveInterpreter method __qualname__ checks; InteractiveConsole push/resetbuffer/raw_input __name__; CommandCompiler.__bases__[0].__name__; CommandCompiler.__bases__.__len__; InteractiveConsole push/resetbuffer __qualname__."
    - "This spec adds: interact.__code__.co_name (not in any prior code spec), compile_command.__code__.co_name (not in any prior code spec), interact.__code__.__class__.__name__ confirms pure-Python implementation, module __name__ attribute (code.__name__ == 'code'), InteractiveConsole.raw_input.__qualname__ (not in any prior code spec)."
    - "code.interact.__code__.co_name == 'interact' — the bytecode-level function name matches the Python-level name."
    - "code.interact.__code__.__class__.__name__ == 'code' — interact is a pure-Python function with a code object."
    - "code.__name__ == 'code' — the module's own __name__ attribute."
    - "code.InteractiveConsole.raw_input.__qualname__ == 'InteractiveConsole.raw_input'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# interact.__code__.co_name — bytecode-level name cross-check.
# No prior code spec checks code-object attributes for interact or compile_command.
# ---------------------------------------------------------------------------

invariant code_extra5.interact.co_name:
  description: "code.interact.__code__.co_name == 'interact' — bytecode name matches Python name"
  category: code_objects
  kind: python_call_eq
  function: interact.__code__.co_name.__eq__
  args: ["interact"]
  expected: true

invariant code_extra5.interact.code_class:
  description: "code.interact.__code__.__class__.__name__ == 'code' — interact is a pure-Python function"
  category: code_objects
  kind: python_call_eq
  function: interact.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# compile_command.__code__.co_name — compile_command is imported from codeop,
# but its code object still records the original function name.
# No prior code spec checks code-object attributes on compile_command.
# ---------------------------------------------------------------------------

invariant code_extra5.compile_command.co_name:
  description: "code.compile_command.__code__.co_name == 'compile_command' — bytecode name matches Python name"
  category: code_objects
  kind: python_call_eq
  function: compile_command.__code__.co_name.__eq__
  args: ["compile_command"]
  expected: true

# ---------------------------------------------------------------------------
# Module __name__ attribute — code.__name__ == 'code'.
# Prior specs check function.__name__ and class.__name__; this checks the
# module-level __name__ attribute, which is distinct and not covered anywhere.
# ---------------------------------------------------------------------------

invariant code_extra5.module.name:
  description: "code.__name__ == 'code' — the module's own __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# InteractiveConsole.raw_input.__qualname__ — code_extra4 adds raw_input.__name__
# but does not add raw_input.__qualname__. This spec fills that gap.
# ---------------------------------------------------------------------------

invariant code_extra5.InteractiveConsole.raw_input_qualname:
  description: "code.InteractiveConsole.raw_input.__qualname__ == 'InteractiveConsole.raw_input'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveConsole.raw_input.__qualname__.__eq__
  args: ["InteractiveConsole.raw_input"]
  expected: true
