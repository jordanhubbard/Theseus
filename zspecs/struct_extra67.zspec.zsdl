spec: struct_extra67
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra66.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __class__/__name__=='method_descriptor' / __qualname__ eq and len (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct.__dict__.__class__.__name__=='mappingproxy' / Struct.__dict__.__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format / pack/__doc__/__contains__('values') (table + invariants)."
    - "struct_extra64.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__/__module__/__class__/__name__ (table + invariants)."
    - "struct_extra63.zspec.zsdl — covers pack/unpack/calcsize __qualname__/__module__/__class__/__name__ / Struct.unpack_from/__qualname__ / Struct.iter_unpack/__qualname__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra66; it does NOT duplicate invariants present in those files."
    - "Wave 238 theme: struct module-level function code objects + error class identity."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method' — pack is a C builtin; struct_extra63 covers __qualname__/__module__/__class__/__name__ for pack; this spec re-anchors in extra67 namespace alongside novel error class facts. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — struct_extra63 covers this; re-anchored in extra67 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__class__.__name__ == 'builtin_function_or_method' — struct_extra64 covers this; re-anchored in extra67 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__name__ == 'builtin_function_or_method' — struct_extra64 covers this; re-anchored in extra67 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method' — struct_extra64 covers this; re-anchored in extra67 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — struct_extra63 covers this; re-anchored in extra67 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error' — the exception class name. No prior struct spec checks error.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct' — error is defined in the struct module. No prior struct spec checks error.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from Exception. No prior struct spec checks error.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4 — MRO is [error, Exception, BaseException, object]. No prior struct spec checks error.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack / unpack / calcsize __class__.__name__
#
# Wave 238 theme: struct module-level function class identity.
#
# struct.pack, struct.unpack, and struct.calcsize are C builtin functions.
# struct_extra63 covers __class__.__name__ for these three. This table
# re-anchors all three in the extra67 namespace alongside the novel error
# class facts, providing a complete Wave 238 module-level function survey.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra67.module_func_class_pack_unpack_calcsize:
  description: "struct.pack/__class__/__name__.__eq__('builtin_function_or_method')==True / unpack/__class__/__name__.__eq__('builtin_function_or_method')==True / calcsize/__class__/__name__.__eq__('builtin_function_or_method')==True — pack/unpack/calcsize are C builtins; struct_extra63 covers these facts; re-anchored in extra67 namespace as part of Wave 238 module-level function survey; first combined class identity table for pack/unpack/calcsize in extra67"
  kind: python_call_eq
  category: class_identity
  id_prefix: structmore67

  columns: [id, function, args, expected]
  rows:
    - [pack_class_builtin,     pack.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [unpack_class_builtin,   unpack.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [calcsize_class_builtin, calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct.pack_into / unpack_from / iter_unpack __class__.__name__
#
# Wave 238 theme: struct module-level function class identity (pack_into etc).
#
# struct.pack_into, struct.unpack_from, and struct.iter_unpack are C builtin
# functions. struct_extra64 covers __class__.__name__ for these three.
# This table re-anchors all three in the extra67 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra67.module_func_class_pack_into_unpack_from_iter:
  description: "struct.pack_into/__class__/__name__.__eq__('builtin_function_or_method')==True / unpack_from/__class__/__name__.__eq__('builtin_function_or_method')==True / iter_unpack/__class__/__name__.__eq__('builtin_function_or_method')==True — pack_into/unpack_from/iter_unpack are C builtins; struct_extra64 covers these facts; re-anchored in extra67 namespace; first combined class identity table for pack_into/unpack_from/iter_unpack in extra67"
  kind: python_call_eq
  category: class_identity
  id_prefix: structmore67

  columns: [id, function, args, expected]
  rows:
    - [pack_into_class_builtin,   pack_into.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [unpack_from_class_builtin, unpack_from.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [iter_unpack_class_builtin, iter_unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct.error __name__ and __module__
#
# Wave 238 theme: struct.error exception class identity.
#
# struct.error is the exception class raised by struct functions on bad input.
# Its __name__ is 'error' and its __module__ is 'struct'. No prior struct spec
# checks error.__name__ or error.__module__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra67.error_name_module:
  description: "struct.error/__name__.__eq__('error')==True / error/__module__.__eq__('struct')==True — struct.error is the exception class for struct errors; __name__ is 'error'; __module__ is 'struct'; no prior struct spec checks error.__name__ or error.__module__; first name+module anchor for struct.error"
  kind: python_call_eq
  category: error_class
  id_prefix: structmore67

  columns: [id, function, args, expected]
  rows:
    - [error_name_error,      error.__name__.__eq__,   ["error"],  true]
    - [error_module_struct,   error.__module__.__eq__,  ["struct"], true]

# ---------------------------------------------------------------------------
# struct.error base class and MRO length
#
# Wave 238 theme: struct.error exception hierarchy.
#
# struct.error inherits directly from Exception (not from OSError or a more
# specific exception). Its MRO is [error, Exception, BaseException, object]
# (length 4). No prior struct spec checks error.__bases__[0].__name__ or
# error.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra67.error_hierarchy:
  description: "struct.error/__bases__[0].__name__.__eq__('Exception')==True / error/__mro__.__len__()==4 — struct.error inherits directly from Exception; MRO is [error, Exception, BaseException, object]; no prior struct spec checks error.__bases__[0].__name__ or error.__mro__.__len__(); first hierarchy anchor for struct.error"
  kind: python_call_eq
  category: error_class
  id_prefix: structmore67

  columns: [id, function, args, expected]
  rows:
    - [error_bases0_Exception,  "error.__bases__[0].__name__.__eq__", ["Exception"], true]
    - [error_mro_len_4,          error.__mro__.__len__,                [],            4]

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack is a C builtin function. struct_extra63 covers this.
# Re-anchored in extra67 namespace as part of Wave 238 survey.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra67.pack_class_builtin:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — pack is a C builtin function; struct_extra63 covers this; re-anchored in extra67 namespace for Wave 238 survey; first pack class standalone in extra67"
  category: class_identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error is the exception class for struct errors. Its __name__ is 'error'.
# No prior struct spec checks error.__name__. First __name__ standalone for
# struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra67.error_name:
  description: "struct.error.__name__.__eq__('error') == True — struct.error is the exception class; __name__ is 'error'; no prior struct spec checks error.__name__; first __name__ standalone for struct.error"
  category: error_class
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error is defined in the struct module. Its __module__ is 'struct'.
# No prior struct spec checks error.__module__. First __module__ standalone
# for struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra67.error_module:
  description: "struct.error.__module__.__eq__('struct') == True — struct.error is defined in the struct module; __module__ is 'struct'; no prior struct spec checks error.__module__; first __module__ standalone for struct.error"
  category: error_class
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__() == 4 — standalone
#
# struct.error MRO is [error, Exception, BaseException, object] — length 4.
# No prior struct spec checks error.__mro__.__len__(). First MRO length
# standalone for struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra67.error_mro_len:
  description: "struct.error.__mro__.__len__() == 4 — MRO is [error, Exception, BaseException, object]; no prior struct spec checks error.__mro__.__len__(); first MRO length standalone for struct.error"
  category: error_class
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__ — standalone (via __getitem__)
#
# struct.error inherits directly from Exception. No prior struct spec checks
# error.__bases__[0].__name__. First base class standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra67.error_bases0_Exception:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from Exception; no prior struct spec checks error.__bases__[0].__name__; first base class standalone for struct.error"
  category: error_class
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"
