spec: hashlib_extra2011
version: ">=3.9"
backend: python_module(_hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "_hashlib.HASH is a cryptographic digest type, not an arithmetic type; it defines none of the addition, multiplication, or subtraction protocols."
    - "hashlib.blake2b and hashlib.blake2s are real type objects; they are also non-arithmetic."
    - "All nine arithmetic dunder methods are absent from all three hashlib hash type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2011.hash_add_protocol:
  description: "_hashlib.HASH __add__/__radd__/__iadd__ dict-presence checks (HASH is not arithmetic)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2011

  columns: [id, function, args, expected]
  rows:
    - ["hl2011001", "_hashlib.HASH.__dict__.__contains__", ["__add__"], false]
    - ["hl2011002", "_hashlib.HASH.__dict__.__contains__", ["__radd__"], false]
    - ["hl2011003", "_hashlib.HASH.__dict__.__contains__", ["__iadd__"], false]

