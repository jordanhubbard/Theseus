# ---------------------------------------------------------------------------
# combined — __hash__, __eq__, __lt__ across all 5 pathlib subjects
#
# 5 classes x 3 methods = 15 rows.
# pathlib.PurePath: __hash__ = true, __eq__ = true, __lt__ = true.
# This true/true/true pattern is the key finding of wave 675 for pathlib:
# PurePath defines the full set of hash/equality/ordering protocols in its
# own __dict__, enabling use in sets, dicts, and sorted containers.
# All subclasses (PurePosixPath, PureWindowsPath, Path, PosixPath) inherit
# these from PurePath and are false for all three in their own __dict__.
# ---------------------------------------------------------------------------

table pp3421.combined:
  description: "pathlib types combined __hash__/__eq__/__lt__; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
