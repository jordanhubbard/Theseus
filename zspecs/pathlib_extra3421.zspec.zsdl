spec: pp3421
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 675 (pp3421): __hash__, __eq__, __lt__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __hash__/__eq__/__lt__ dict-presence (hash(x), x==y, x<y)."
    - "pathlib.PurePath defines __hash__ (true): PurePath objects are hashable and can be used in sets/dicts."
    - "pathlib.PurePath defines __eq__ (true): PurePath objects support == comparison for path equality."
    - "pathlib.PurePath defines __lt__ (true): PurePath objects support < comparison for path ordering."
    - "PurePosixPath, PureWindowsPath, Path, PosixPath all inherit these from PurePath and do not define them in their own __dict__ (false)."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# pathlib.PurePath DOES define __hash__ in its own __dict__: true.
# PurePath objects are hashable and can be used as dict keys or set members.
# All subclasses (PurePosixPath, PureWindowsPath, Path, PosixPath) inherit
# __hash__ from PurePath and do not define it in their own __dict__: false.
# ---------------------------------------------------------------------------

table pp3421.hash:
  description: "pathlib types __hash__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3421

  columns: [id, function, args, expected]
  rows:
    - ["pp3421001", operator.contains, [pathlib.PurePath.__dict__,         "__hash__"], true]
    - ["pp3421002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__hash__"], false]
    - ["pp3421003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__hash__"], false]
    - ["pp3421004", operator.contains, [pathlib.Path.__dict__,             "__hash__"], false]
    - ["pp3421005", operator.contains, [pathlib.PosixPath.__dict__,        "__hash__"], false]

