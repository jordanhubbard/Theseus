spec: re_extra2386
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "Wave 2386 (re_extra2386): __str__ and __repr__ implementation type classification for re module types."
    - "re.Pattern and re.Match are C types implemented in _sre.c; their __repr__ and __str__ are C-level slot wrappers: 'wrapper_descriptor'."
    - "re.error (also accessible as re.PatternError in Python 3.13+) is a Python exception class; its __repr__ and __str__ are 'wrapper_descriptor' inherited from BaseException at the C level."
    - "re.RegexFlag is a Python IntFlag enum subclass; its __repr__ is a Python function defined by the enum machinery ('function'), but its __str__ inherits from int via the C layer ('wrapper_descriptor')."
    - "The mixed result on re.RegexFlag — 'function' for __repr__ vs 'wrapper_descriptor' for __str__ — reflects that IntFlag overrides __repr__ in Python but leaves __str__ to the C int type."
    - "re.error.__repr__ being 'wrapper_descriptor' (not 'function') reflects that BaseException defines __repr__ at the C level in CPython."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# re.Pattern — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table re_extra2386.pattern_str_repr:
  description: "re.Pattern.__repr__.__class__.__name__ and re.Pattern.__str__.__class__.__name__ — both are 'wrapper_descriptor'; re.Pattern is the C type for compiled regular expression objects (_sre.SRE_Pattern internally); __repr__ and __str__ are implemented as C-level slot wrappers in _sre.c"
  kind: python_call_eq
  category: classnames
  id_prefix: re2386

  columns: [id, function, args, expected]
  rows:
    - ["re2386001", "re.Pattern.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["re2386002", "re.Pattern.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# re.Match — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table re_extra2386.match_str_repr:
  description: "re.Match.__repr__.__class__.__name__ and re.Match.__str__.__class__.__name__ — both are 'wrapper_descriptor'; re.Match is the C type for match objects returned by Pattern.match/search/finditer; its __repr__ and __str__ are C-level slot wrappers"
  kind: python_call_eq
  category: classnames
  id_prefix: re2386

  columns: [id, function, args, expected]
  rows:
    - ["re2386003", "re.Match.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["re2386004", "re.Match.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# re.error — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table re_extra2386.error_str_repr:
  description: "re.error.__repr__.__class__.__name__ and re.error.__str__.__class__.__name__ — both are 'wrapper_descriptor'; re.error is a Python exception class but inherits __repr__ and __str__ from BaseException, which defines these at the C level in CPython; in Python 3.13+ re.error is also accessible as re.PatternError"
  kind: python_call_eq
  category: classnames
  id_prefix: re2386

  columns: [id, function, args, expected]
  rows:
    - ["re2386005", "re.error.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["re2386006", "re.error.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# re.RegexFlag — __repr__ and __str__ implementation type (mixed)
# ---------------------------------------------------------------------------

table re_extra2386.regexflag_str_repr:
  description: "re.RegexFlag.__repr__.__class__.__name__ == 'function' but re.RegexFlag.__str__.__class__.__name__ == 'wrapper_descriptor' — RegexFlag is an IntFlag subclass; Python's enum machinery overrides __repr__ as a Python function while __str__ is inherited from int (a C type) and remains a wrapper_descriptor"
  kind: python_call_eq
  category: classnames
  id_prefix: re2386

  columns: [id, function, args, expected]
  rows:
    - ["re2386007", "re.RegexFlag.__repr__.__class__.__name__.__eq__", ["function"],          true]
    - ["re2386008", "re.RegexFlag.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Negative cross-checks — confirm classification boundaries
#
# re.Pattern and re.Match are NOT 'function'; re.RegexFlag.__repr__ is NOT
# 'wrapper_descriptor'; re.RegexFlag.__str__ is NOT 'function'.
# ---------------------------------------------------------------------------

table re_extra2386.classification_boundaries:
  description: "Negative cross-checks for re type __repr__/__str__ classification — confirms re.Pattern.__repr__ is not 'function' (it is a C slot wrapper), re.Match.__repr__ is not 'function', re.error.__repr__ is not 'function' (BaseException __repr__ is C-level), re.RegexFlag.__repr__ is not 'wrapper_descriptor' (enum overrides in Python), and re.RegexFlag.__str__ is not 'function' (inherits int C slot)"
  kind: python_call_eq
  category: classnames
  id_prefix: re2386

  columns: [id, function, args, expected]
  rows:
    - ["re2386009",  "re.Pattern.__repr__.__class__.__name__.__eq__",   ["function"], false]
    - ["re2386010",  "re.Pattern.__str__.__class__.__name__.__eq__",    ["function"], false]
    - ["re2386011",  "re.Match.__repr__.__class__.__name__.__eq__",     ["function"], false]
    - ["re2386012",  "re.Match.__str__.__class__.__name__.__eq__",      ["function"], false]
    - ["re2386013",  "re.error.__repr__.__class__.__name__.__eq__",     ["function"], false]
    - ["re2386014",  "re.error.__str__.__class__.__name__.__eq__",      ["function"], false]
    - ["re2386015",  "re.RegexFlag.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["re2386016",  "re.RegexFlag.__str__.__class__.__name__.__eq__",  ["function"],            false]

# ---------------------------------------------------------------------------
# Summary: C types vs Python types in the re module
#
# C slot wrapper types: re.Pattern, re.Match, re.error (via BaseException)
# Python function __repr__: re.RegexFlag (enum machinery)
# Mixed: re.RegexFlag (__repr__=function, __str__=wrapper_descriptor)
# ---------------------------------------------------------------------------

table re_extra2386.c_types_uniformity:
  description: "re.Pattern and re.Match are uniformly C-typed for both __repr__ and __str__; verifies that both the repr and str slots of the two primary re C types are consistently wrapper_descriptor — there is no asymmetry between __repr__ and __str__ for these types"
  kind: python_call_eq
  category: classnames
  id_prefix: re2386

  columns: [id, function, args, expected]
  rows:
    - ["re2386017", "re.Pattern.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["re2386018", "re.Pattern.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - ["re2386019", "re.Match.__repr__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["re2386020", "re.Match.__str__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
