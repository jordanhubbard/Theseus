spec: box_rust
version: ">=3.9"
backend: rust_module(box_rust)

docs: https://github.com/cdgriffith/Box

provenance:
  derived_from:
    - "https://github.com/cdgriffith/Box — Python Box documentation"
  not_derived_from:
    - "box source: box/box.py"
  notes:
    - "Python Box provides dot-access to nested dict keys."
    - "Box({'a': 1}).a == 1."
    - "Box({'a': {'b': 2}}).a.b == 2."
    - "Box({'x': [1,2,3]}).x == [1,2,3]."
    - "Expose box_get_attr(d, attr) -> any: Box(d).attr."
    - "Expose box_get_nested(d, key1, key2) -> any: Box(d).key1.key2."
    - "Expose box_to_dict(d) -> dict: Box(d).to_dict() == d."
    - "Box({'name': 'Alice', 'age': 30}).name == 'Alice'."
    - "Box({'x': {'y': 99}}).x.y == 99."
    - "All test vectors verified against python-box 7.3.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# box_get_attr — dot access to top-level key
table box_rust.attr.get:
  kind: python_call_eq
  category: attr
  id_prefix: bx_attr
  function: box_get_attr

  columns: [id, args, expected]
  rows:
    - [name,    [{"name": "Alice"}, "name"],  "Alice"]
    - [age,     [{"age": 30},       "age"],   30]
    - [flag,    [{"ok": true},      "ok"],    true]

# box_get_nested — dot access to nested key
table box_rust.nested.get:
  kind: python_call_eq
  category: nested
  id_prefix: bx_nest
  function: box_get_nested

  columns: [id, args, expected]
  rows:
    - [x_y,  [{"x": {"y": 99}},   "x", "y"],  99]
    - [a_b,  [{"a": {"b": "hi"}}, "a", "b"],  "hi"]

# box_to_dict — roundtrip to dict
invariant box_rust.roundtrip.simple:
  description: "Box({'a': 1}).to_dict() == {'a': 1}"
  category: roundtrip
  kind: python_call_eq
  function: box_to_dict
  args: [{"a": 1, "b": 2}]
  expected: {"a": 1, "b": 2}

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:24:10Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
