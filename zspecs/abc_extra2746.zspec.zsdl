# ---------------------------------------------------------------------------
# Table 4: combined __round__/__divmod__/__pow__ checks for ABCMeta and
#          abstractproperty
#
# Wave 630 theme: ABCMeta is a metaclass that enforces abstract method
# contracts; abstractproperty is a deprecated decorator combining
# abstractmethod and property. Neither construct participates in numeric
# protocols, so all three arithmetic dunder methods are absent from
# their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2746.abcmeta_abstractproperty_arithmetic:
  description: "abc.ABCMeta and abc.abstractproperty combined __round__/__divmod__/__pow__ dict-presence checks — metaclass and deprecated decorator define no arithmetic protocols"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2746

  columns: [id, function, args, expected]
  rows:
    - ["ab2746013", "abc.ABCMeta.__dict__.__contains__",          ["__round__"],  false]
    - ["ab2746014", "abc.ABCMeta.__dict__.__contains__",          ["__divmod__"], false]
    - ["ab2746015", "abc.ABCMeta.__dict__.__contains__",          ["__pow__"],    false]
    - ["ab2746016", "abc.abstractproperty.__dict__.__contains__", ["__round__"],  false]
    - ["ab2746017", "abc.abstractproperty.__dict__.__contains__", ["__divmod__"], false]
    - ["ab2746018", "abc.abstractproperty.__dict__.__contains__", ["__pow__"],    false]
