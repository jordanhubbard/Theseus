spec: abc_extra2746
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 630 (_extra2746): __round__, __divmod__, __pow__ dict-presence checks."
    - "abc.ABCMeta is a metaclass; abc.ABC is a helper base class; abc.abstractmethod and abc.abstractproperty are decorators."
    - "None of these abc constructs define rounding, divmod, or power protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __round__ dict-presence checks
#
# Wave 630 theme: abc module types do not implement the round operator.
# __round__ does not appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2746.round_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod, abc.abstractproperty __round__ dict-presence checks — none define rounding in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2746

  columns: [id, function, args, expected]
  rows:
    - ["ab2746001", "abc.ABCMeta.__dict__.__contains__",          ["__round__"], false]
    - ["ab2746002", "abc.ABC.__dict__.__contains__",              ["__round__"], false]
    - ["ab2746003", "abc.abstractmethod.__dict__.__contains__",   ["__round__"], false]
    - ["ab2746004", "abc.abstractproperty.__dict__.__contains__", ["__round__"], false]

