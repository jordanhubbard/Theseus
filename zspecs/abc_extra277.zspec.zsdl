spec: abc_extra277
version: ">=3.3"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "https://docs.python.org/3/library/collections.abc.html#collections.abc.Mapping — Mapping class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
    - "abc_extra276.zspec.zsdl — covers collections.abc.Collection and Reversible class identity"
  notes:
    - "This spec covers: collections.abc.Mapping method __qualname__ string equality for get/items/keys/values; method __qualname__ lengths for get(11), items(13), keys(12), values(14); Mapping.__abstractmethods__ membership checks for __getitem__, __len__, __iter__; Mapping.__abstractmethods__.__len__()==3. NEW in extra277: Mapping.get.__qualname__=='Mapping.get' (len=11); Mapping.items.__qualname__=='Mapping.items' (len=13); Mapping.keys.__qualname__=='Mapping.keys' (len=12); Mapping.values.__qualname__=='Mapping.values' (len=14); Mapping.__abstractmethods__.__contains__('__getitem__')==True; Mapping.__abstractmethods__.__contains__('__len__')==True; Mapping.__abstractmethods__.__contains__('__iter__')==True; Mapping.__abstractmethods__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Mapping.values.__qualname__ == 'Mapping.values' (len=14) — the longest method qualname in this spec. compare: get=11, keys=12, items=13, values=14 (each one character longer than the previous). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Mapping.__abstractmethods__ == frozenset({'__getitem__', '__len__', '__iter__'}) — exactly 3 abstract methods; these are the minimum interface required to implement a read-only mapping. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Mapping is defined in Lib/_collections_abc.py; its __module__ is 'collections.abc' (len=15); Mapping inherits from Collection (abc_extra276: Collection.__mro__.__len__()==5); Mapping.__mro__.__len__()==6. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Mapping method __qualname__ string equality and length — extra277 namespace
#
# Mapping defines four concrete mixin methods (get, items, keys, values).
# All carry 'Mapping.' as their __qualname__ prefix.
#   Mapping.get.__qualname__    == 'Mapping.get'    (11)
#   Mapping.items.__qualname__  == 'Mapping.items'  (13)
#   Mapping.keys.__qualname__   == 'Mapping.keys'   (12)
#   Mapping.values.__qualname__ == 'Mapping.values' (14)
# The lengths form an ascending sequence: 11, 12, 13, 14 — each name is
# one character longer than the previous when sorted by length.
# No prior abc_extraN spec has covered Mapping method qualnames.
# ---------------------------------------------------------------------------

table abc_extra277.mapping_method_qualname:
  description: "collections.abc.Mapping method __qualname__ string equality and length checks in cabcmap277 namespace — all four Mapping mixin methods have 'Mapping.' as their qualname prefix; Mapping.get.__qualname__.__eq__('Mapping.get')==True (len=11); Mapping.keys.__qualname__.__eq__('Mapping.keys')==True (len=12); Mapping.items.__qualname__.__eq__('Mapping.items')==True (len=13); Mapping.values.__qualname__.__eq__('Mapping.values')==True (len=14, longest); the lengths form the strictly ascending sequence 11<12<13<14; prior abc_extra276 covered Collection and Reversible identity but not Mapping methods; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: cabcmap277

  columns: [id, function, args, expected, description]
  rows:
    - [get_qn_eq,     collections.abc.Mapping.get.__qualname__.__eq__,       ["Mapping.get"],    true,  "Mapping.get.__qualname__ == 'Mapping.get' (len=11); verified with Python 3.14.3"]
    - [get_qn_len,    collections.abc.Mapping.get.__qualname__.__len__,       [],                 11,    "Mapping.get.__qualname__.__len__() == 11 ('Mapping.get'=11, shortest in spec); verified with Python 3.14.3"]
    - [keys_qn_eq,    collections.abc.Mapping.keys.__qualname__.__eq__,       ["Mapping.keys"],   true,  "Mapping.keys.__qualname__ == 'Mapping.keys' (len=12); verified with Python 3.14.3"]
    - [keys_qn_len,   collections.abc.Mapping.keys.__qualname__.__len__,      [],                 12,    "Mapping.keys.__qualname__.__len__() == 12 ('Mapping.keys'=12); verified with Python 3.14.3"]
    - [items_qn_eq,   collections.abc.Mapping.items.__qualname__.__eq__,      ["Mapping.items"],  true,  "Mapping.items.__qualname__ == 'Mapping.items' (len=13); verified with Python 3.14.3"]
    - [items_qn_len,  collections.abc.Mapping.items.__qualname__.__len__,     [],                 13,    "Mapping.items.__qualname__.__len__() == 13 ('Mapping.items'=13); verified with Python 3.14.3"]
    - [values_qn_eq,  collections.abc.Mapping.values.__qualname__.__eq__,     ["Mapping.values"], true,  "Mapping.values.__qualname__ == 'Mapping.values' (len=14, longest in spec); verified with Python 3.14.3"]
    - [values_qn_len, collections.abc.Mapping.values.__qualname__.__len__,    [],                 14,    "Mapping.values.__qualname__.__len__() == 14 ('Mapping.values'=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Mapping.__abstractmethods__ membership — extra277 namespace
#
# Mapping.__abstractmethods__ == frozenset({'__getitem__', '__len__', '__iter__'})
# __len__() == 3 — exactly three methods must be implemented.
# This table confirms membership via __contains__ for each abstract method.
# ---------------------------------------------------------------------------

table abc_extra277.mapping_abstractmethods_membership:
  description: "collections.abc.Mapping.__abstractmethods__ membership checks in cabcmapabst277 namespace — Mapping.__abstractmethods__ is a frozenset of exactly 3 methods: __getitem__, __len__, __iter__; __contains__ returns True for each; these three abstract methods form the minimum interface for a read-only mapping; Mapping.__abstractmethods__.__len__()==3; __abstractmethods__.__class__.__name__ is 'frozenset'; no prior abc_extraN spec has verified Mapping.__abstractmethods__ contents; verified with Python 3.14.3"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: cabcmapabst277

  columns: [id, function, args, expected, description]
  rows:
    - [has_getitem, "collections.abc.Mapping.__abstractmethods__.__contains__", ["__getitem__"], true, "Mapping.__abstractmethods__.__contains__('__getitem__') == True; verified with Python 3.14.3"]
    - [has_len,     "collections.abc.Mapping.__abstractmethods__.__contains__", ["__len__"],     true, "Mapping.__abstractmethods__.__contains__('__len__') == True; verified with Python 3.14.3"]
    - [has_iter,    "collections.abc.Mapping.__abstractmethods__.__contains__", ["__iter__"],    true, "Mapping.__abstractmethods__.__contains__('__iter__') == True; verified with Python 3.14.3"]
    - [abst_len,    collections.abc.Mapping.__abstractmethods__.__len__,        [],              3,    "Mapping.__abstractmethods__.__len__() == 3 — exactly 3 abstract methods; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra277
# ---------------------------------------------------------------------------

invariant abc_extra277.Mapping_get_qualname_eq:
  description: "collections.abc.Mapping.get.__qualname__.__eq__('Mapping.get') returns True — Mapping.get is a concrete mixin method defined directly on Mapping; its __qualname__ is 'Mapping.get' (len=11: 'Mapping.'=8+'get'=3=11); Mapping.get provides a default implementation using __getitem__ with a fallback default; get.__qualname__.__len__()==11 is the shortest method qualname in this spec; compare qualname lengths: get=11, keys=12, items=13, values=14; Mapping.get.__module__ is 'collections.abc'; NEW in extra277: first standalone Mapping.get qualname invariant in cabcmap277 namespace; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: collections.abc.Mapping.get.__qualname__.__eq__
  args: ["Mapping.get"]
  expected: true

invariant abc_extra277.Mapping_values_qualname_eq:
  description: "collections.abc.Mapping.values.__qualname__.__eq__('Mapping.values') returns True — Mapping.values is a concrete mixin method defined directly on Mapping; its __qualname__ is 'Mapping.values' (len=14: 'Mapping.'=8+'values'=6=14); values.__qualname__.__len__()==14 is the longest method qualname in this spec; compare qualname lengths: get=11, keys=12, items=13, values=14 (strictly ascending by one per method); Mapping.values returns a KeysView wrapping the mapping's key-value pairs; NEW in extra277: first standalone Mapping.values qualname invariant in cabcmap277 namespace; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: collections.abc.Mapping.values.__qualname__.__eq__
  args: ["Mapping.values"]
  expected: true

invariant abc_extra277.Mapping_abstractmethods_len_is_3:
  description: "collections.abc.Mapping.__abstractmethods__.__len__() == 3 — Mapping.__abstractmethods__ is a frozenset of 3 abstract methods: __getitem__, __len__, __iter__; these are the minimum interface required to implement a read-only mapping; Mapping.__abstractmethods__.__class__.__name__ is 'frozenset'; len==3 means any class implementing these three methods can be registered as a Mapping subclass; compare: collections.abc.Set.__abstractmethods__ has only __contains__, __iter__, __len__ (also 3); NEW in extra277: first standalone Mapping.__abstractmethods__ length invariant in cabcmapabst277 namespace; verified with Python 3.14.3"
  category: abstract_methods
  kind: python_call_eq
  function: collections.abc.Mapping.__abstractmethods__.__len__
  args: []
  expected: 3

invariant abc_extra277.Mapping_abstractmethods_has_getitem:
  description: "collections.abc.Mapping.__abstractmethods__.__contains__('__getitem__') returns True — __getitem__ is one of the three abstract methods in Mapping.__abstractmethods__; implementing __getitem__ allows key-based lookup; __getitem__ is the primary access method that distinguishes mappings from other collections; Mapping.__abstractmethods__ == frozenset({'__getitem__', '__len__', '__iter__'}); all three must be implemented for a class to be a valid Mapping; Mapping.get is a concrete mixin that delegates to __getitem__; NEW in extra277: first standalone Mapping __getitem__ membership invariant in cabcmapabst277 namespace; verified with Python 3.14.3"
  category: abstract_methods
  kind: python_call_eq
  function: "collections.abc.Mapping.__abstractmethods__.__contains__"
  args: ["__getitem__"]
  expected: true

invariant abc_extra277.Mapping_keys_qualname_len_is_12:
  description: "collections.abc.Mapping.keys.__qualname__.__len__() == 12 — Mapping.keys.__qualname__ is 'Mapping.keys' (12 characters: 'Mapping.'=8+'keys'=4=12); keys.__qualname__.__len__()==12 sits between get (11) and items (13) in the ascending sequence of Mapping method qualname lengths (11, 12, 13, 14); Mapping.keys returns a KeysView providing a set-like view of the mapping's keys; Mapping.keys.__qualname__.__eq__('Mapping.keys') is True; NEW in extra277: first standalone Mapping.keys qualname length invariant in cabcmap277 namespace; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: collections.abc.Mapping.keys.__qualname__.__len__
  args: []
  expected: 12

invariant abc_extra277.Mapping_abstractmethods_is_frozenset:
  description: "collections.abc.Mapping.__abstractmethods__.__class__.__name__.__eq__('frozenset') returns True — Mapping.__abstractmethods__ is a frozenset (not a list or set); Python always stores __abstractmethods__ as a frozenset for immutability; Mapping.__abstractmethods__.__len__() is 3; the three members are '__getitem__', '__len__', '__iter__'; Mapping inherits from Collection (abc_extra276: Collection.__mro__.__len__()==5); Mapping.__mro__.__len__()==6; NEW in extra277: first standalone Mapping.__abstractmethods__ type invariant in cabcmapabst277 namespace; verified with Python 3.14.3"
  category: abstract_methods
  kind: python_call_eq
  function: collections.abc.Mapping.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true
