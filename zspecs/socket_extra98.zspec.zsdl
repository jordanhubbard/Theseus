spec: socket_extra98
version: ">=3.9"
backend: python_module(socket)
extends: socket_extra97

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / SocketIO class identity / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW __class__.__name__=='SocketKind' / AddressFamily/SocketKind __bases__[0].__name__=='IntEnum' / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/recv/send/etc. (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra97; it does NOT duplicate invariants present in those files."
    - "Wave 261 theme: socket.socket method __qualname__.__len__() values for both C-level and Python-level methods — connect/bind/listen/send/recv __qualname__.__len__() / __init__/accept/close/makefile __qualname__.__len__()."
    - "socket.socket.connect.__qualname__.__len__() == 14 ('socket.connect'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__.__len__() == 11 ('socket.bind'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__.__len__() == 13 ('socket.listen'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__.__len__() == 11 ('socket.send'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__.__len__() == 11 ('socket.recv'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__qualname__.__len__() == 15 ('socket.__init__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__.__len__() == 13 ('socket.accept'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__.__len__() == 12 ('socket.close'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__qualname__.__len__() == 15 ('socket.makefile'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The socket.socket class is named 'socket' (same as the module), so all method qualnames use the 'socket.' prefix (7 chars). __init__ qualname is 'socket.__init__' (15 chars: 7 + 8)."
    - "Note: send/recv/bind all have the same length of 11 because 'socket.' (7) + 4-char names = 11."
    - "Note: C-level methods (method_descriptor) and Python-level methods (function) share the same __qualname__ pattern with 'socket.' prefix; both inherit the class name 'socket' (the socket.socket class)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__len__()==14
# socket.socket.bind.__qualname__.__len__()==11
# socket.socket.listen.__qualname__.__len__()==13
# socket.socket.send.__qualname__.__len__()==11
# socket.socket.recv.__qualname__.__len__()==11
#
# Wave 261 theme: C-level socket.socket method __qualname__.__len__() values.
#
# socket.socket's C-level method_descriptor methods have __qualname__ 'socket.<name>'.
# The class name 'socket' (7 chars) serves as prefix for all method qualnames.
# connect: 'socket.connect' (14), bind: 'socket.bind' (11), listen: 'socket.listen' (13),
# send: 'socket.send' (11), recv: 'socket.recv' (11). socket_extra97 anchors
# send/sendall/fileno __qualname__.__eq__; socket_extra93 anchors the class names;
# this table first anchors __qualname__.__len__() for C-level methods under
# sockqlen98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra98.socket_socket_c_method_qualname_lengths:
  description: "socket.socket.connect/__qualname__/__len__()==14 / bind/__qualname__/__len__()==11 / listen/__qualname__/__len__()==13 / send/__qualname__/__len__()==11 / recv/__qualname__/__len__()==11 — C-level method_descriptor methods have __qualname__ 'socket.<name>'; class name 'socket' (7 chars) is the prefix; extra97 anchors send/sendall/fileno qualname.__eq__; extra93 anchors class names; this table first anchors C-level __qualname__.__len__() values; first sockqlen98 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockqlen98

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qlen, "socket.connect.__qualname__.__len__", [], 14, "'socket.connect' is 7 + 7 = 14 chars"]
    - [bind_qlen,    "socket.bind.__qualname__.__len__",    [], 11, "'socket.bind' is 7 + 4 = 11 chars"]
    - [listen_qlen,  "socket.listen.__qualname__.__len__",  [], 13, "'socket.listen' is 7 + 6 = 13 chars"]
    - [send_qlen,    "socket.send.__qualname__.__len__",    [], 11, "'socket.send' is 7 + 4 = 11 chars"]
    - [recv_qlen,    "socket.recv.__qualname__.__len__",    [], 11, "'socket.recv' is 7 + 4 = 11 chars"]

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__len__()==15
# socket.socket.accept.__qualname__.__len__()==13
# socket.socket.close.__qualname__.__len__()==12
# socket.socket.makefile.__qualname__.__len__()==15
#
# Wave 261 theme: Python-level socket.socket method __qualname__.__len__() values.
#
# socket.socket's Python-level function methods also have __qualname__ 'socket.<name>'.
# __init__: 'socket.__init__' (15), accept: 'socket.accept' (13),
# close: 'socket.close' (12), makefile: 'socket.makefile' (15). These four are
# pure-Python functions defined in Lib/socket.py; socket_extra97 anchors their
# __class__.__name__=='function' and __module__=='socket'; this table first
# anchors __qualname__.__len__() for Python-level methods under sockqlen98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra98.socket_socket_py_method_qualname_lengths:
  description: "socket.socket.__init__/__qualname__/__len__()==15 / accept/__qualname__/__len__()==13 / close/__qualname__/__len__()==12 / makefile/__qualname__/__len__()==15 — Python-level function methods defined in Lib/socket.py; all use 'socket.' prefix (7 chars); __init__ is 'socket.__init__' (7 + 8 = 15); extra97 anchors class names and __module__; this table first anchors Python-level __qualname__.__len__() values; first sockqlen98 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockqlen98

  columns: [id, function, args, expected, description]
  rows:
    - [init_qlen,     "socket.__init__.__qualname__.__len__",   [], 15, "'socket.__init__' is 7 + 8 = 15 chars"]
    - [accept_qlen,   "socket.accept.__qualname__.__len__",     [], 13, "'socket.accept' is 7 + 6 = 13 chars"]
    - [close_qlen,    "socket.close.__qualname__.__len__",      [], 12, "'socket.close' is 7 + 5 = 12 chars"]
    - [makefile_qlen, "socket.makefile.__qualname__.__len__",   [], 15, "'socket.makefile' is 7 + 8 = 15 chars"]

# ---------------------------------------------------------------------------
# socket.socket.getsockname/__qualname__/__len__()==18
# socket.socket.getpeername/__qualname__/__len__()==18
# socket.socket.setsockopt/__qualname__/__len__()==17
# socket.socket.getsockopt/__qualname__/__len__()==17
# socket.socket.settimeout/__qualname__/__len__()==17
# socket.socket.gettimeout/__qualname__.__len__()==17
# socket.socket.shutdown/__qualname__/__len__()==15
#
# Wave 261 supplemental: additional C-level socket.socket method qualname lengths.
#
# Further C-level methods: getsockname/getpeername (both 18), setsockopt/getsockopt/
# settimeout/gettimeout (all 17), shutdown (15). No prior socket spec anchors
# __qualname__.__len__() for these methods under sockqlen98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra98.socket_socket_additional_qualname_lengths:
  description: "socket.socket.getsockname/__qualname__/__len__()==18 / getpeername/__qualname__/__len__()==18 / setsockopt/__qualname__/__len__()==17 / getsockopt/__qualname__/__len__()==17 / settimeout/__qualname__/__len__()==17 / gettimeout/__qualname__/__len__()==17 / shutdown/__qualname__/__len__()==15 — further C-level method_descriptor methods with 'socket.' prefix; no prior socket spec anchors these qualname lengths; first sockqlen98 anchor for additional C-level method lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockqlen98

  columns: [id, function, args, expected, description]
  rows:
    - [getsockname_qlen, "socket.getsockname.__qualname__.__len__", [], 18, "'socket.getsockname' is 7 + 11 = 18 chars"]
    - [getpeername_qlen, "socket.getpeername.__qualname__.__len__", [], 18, "'socket.getpeername' is 7 + 11 = 18 chars"]
    - [setsockopt_qlen,  "socket.setsockopt.__qualname__.__len__",  [], 17, "'socket.setsockopt' is 7 + 10 = 17 chars"]
    - [getsockopt_qlen,  "socket.getsockopt.__qualname__.__len__",  [], 17, "'socket.getsockopt' is 7 + 10 = 17 chars"]
    - [settimeout_qlen,  "socket.settimeout.__qualname__.__len__",  [], 17, "'socket.settimeout' is 7 + 10 = 17 chars"]
    - [gettimeout_qlen,  "socket.gettimeout.__qualname__.__len__",  [], 17, "'socket.gettimeout' is 7 + 10 = 17 chars"]
    - [shutdown_qlen,    "socket.shutdown.__qualname__.__len__",    [], 15, "'socket.shutdown' is 7 + 8 = 15 chars"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__len__()==14 — standalone
#
# socket.socket.connect.__qualname__.__len__() is 14. connect.__qualname__ is
# 'socket.connect': the class name 'socket' (7 chars) plus '.' (1) plus
# 'connect' (7) = 14 + ... actually: 'socket.connect' has s-o-c-k-e-t (6) +
# '.' (1) + c-o-n-n-e-c-t (7) = 14 chars. connect is one of the most commonly
# used socket methods, initiating a connection to a remote address. As a C-level
# method_descriptor inherited from _socket.socket, it has no __module__. No prior
# spec anchors connect.__qualname__.__len__() as a standalone under sockqlen98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra98.socket_connect_qualname_len_14:
  description: "socket.socket.connect.__qualname__.__len__() == 14 — connect.__qualname__ is 'socket.connect': 'socket' (6) + '.' (1) + 'connect' (7) = 14; connect is a C-level method_descriptor from _socket.socket; no prior socket spec anchors connect.__qualname__.__len__() as a standalone; first standalone for socket.connect qualname length under sockqlen98"
  category: qualname_lengths
  kind: python_call_eq
  function: "socket.connect.__qualname__.__len__"
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__len__()==15 — standalone
#
# socket.socket.__init__.__qualname__.__len__() is 15. __init__.__qualname__ is
# 'socket.__init__': 'socket' (6) + '.' (1) + '__init__' (8) = 15 chars.
# socket.socket.__init__ is a Python-level function (not a C wrapper_descriptor)
# because socket.socket is defined in Lib/socket.py as a Python class. socket_extra97
# anchors __init__.__class__.__name__=='function' and __module__=='socket'; no prior
# spec anchors __init__.__qualname__.__len__() as a standalone under sockqlen98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra98.socket_init_qualname_len_15:
  description: "socket.socket.__init__.__qualname__.__len__() == 15 — __init__.__qualname__ is 'socket.__init__': 'socket' (6) + '.' (1) + '__init__' (8) = 15; socket.socket.__init__ is a Python function (Lib/socket.py); extra97 anchors class name and __module__; first standalone for socket.__init__ qualname length under sockqlen98"
  category: qualname_lengths
  kind: python_call_eq
  function: "socket.__init__.__qualname__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# socket.socket.bind.__qualname__.__len__()==11 — standalone
#
# socket.socket.bind.__qualname__.__len__() is 11. bind.__qualname__ is
# 'socket.bind': 'socket' (6) + '.' (1) + 'bind' (4) = 11. bind is the
# method that assigns a local address to the socket, typically called on server
# sockets before listen(). As a C-level method_descriptor, it inherits from
# _socket.socket. No prior spec anchors bind.__qualname__.__len__() as a
# standalone under sockqlen98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra98.socket_bind_qualname_len_11:
  description: "socket.socket.bind.__qualname__.__len__() == 11 — bind.__qualname__ is 'socket.bind': 'socket' (6) + '.' (1) + 'bind' (4) = 11; bind is a C-level method_descriptor used to assign a local address; no prior socket spec anchors bind.__qualname__.__len__() as a standalone; first standalone for socket.bind qualname length under sockqlen98"
  category: qualname_lengths
  kind: python_call_eq
  function: "socket.bind.__qualname__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# socket.socket.getsockname.__qualname__.__len__()==18 — standalone
#
# socket.socket.getsockname.__qualname__.__len__() is 18. getsockname.__qualname__
# is 'socket.getsockname': 'socket' (6) + '.' (1) + 'getsockname' (11) = 18.
# getsockname returns the socket's own address. It shares the length 18 with
# getpeername (which returns the remote address). Both have 11-char method names
# under the 7-char 'socket.' prefix. No prior spec anchors
# getsockname.__qualname__.__len__() as a standalone under sockqlen98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra98.socket_getsockname_qualname_len_18:
  description: "socket.socket.getsockname.__qualname__.__len__() == 18 — getsockname.__qualname__ is 'socket.getsockname': 'socket' (6) + '.' (1) + 'getsockname' (11) = 18; getsockname shares length 18 with getpeername; no prior socket spec anchors getsockname.__qualname__.__len__() as a standalone; first standalone for socket.getsockname qualname length under sockqlen98"
  category: qualname_lengths
  kind: python_call_eq
  function: "socket.getsockname.__qualname__.__len__"
  args: []
  expected: 18
