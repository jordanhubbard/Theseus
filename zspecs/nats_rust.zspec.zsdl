spec: nats_rust
version: ">=3.9"
backend: rust_module(nats_rust)

docs: https://nats-io.github.io/nats.py/

provenance:
  derived_from:
    - "https://nats-io.github.io/nats.py/ — NATS Python documentation"
  not_derived_from:
    - "nats source: nats/__init__.py"
  notes:
    - "nats.py is the Python client for NATS messaging."
    - "nats.connect is a coroutine function."
    - "nats.aio.client.Client is available."
    - "asyncio.iscoroutinefunction(nats.connect) == True."
    - "import nats; nats.aio is available."
    - "Expose nats_connect_is_coroutine() -> bool: asyncio.iscoroutinefunction(nats.connect)."
    - "Expose nats_has_aio() -> bool: hasattr(nats, 'aio')."
    - "Expose nats_client_name() -> str: nats.aio.client.Client.__name__."
    - "All test vectors verified against nats-py 2.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# nats_connect_is_coroutine — connect is async
invariant nats_rust.client.connect_is_coroutine:
  description: "nats.connect is a coroutine function"
  category: client
  kind: python_call_eq
  function: nats_connect_is_coroutine
  args: []
  expected: true

# nats_has_aio — aio module present
invariant nats_rust.module.has_aio:
  description: "nats.aio is available"
  category: module
  kind: python_call_eq
  function: nats_has_aio
  args: []
  expected: true

# nats_client_name — Client class name
invariant nats_rust.client.class_name:
  description: "nats.aio.client.Client.__name__ == 'Client'"
  category: client_name
  kind: python_call_eq
  function: nats_client_name
  args: []
  expected: "Client"

