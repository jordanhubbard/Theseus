spec: uuid_extra916
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ and __module__ attributes of uuid classes and generator functions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra916.class_qualnames:
  description: "uuid class __qualname__ identity"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: uu916cq
  columns: [id, function, args, expected]
  rows:
    - [uu916cq001, uuid.UUID.__qualname__.__eq__,      ["UUID"],      true]
    - [uu916cq002, uuid.SafeUUID.__qualname__.__eq__,  ["SafeUUID"],  true]

table uuid_extra916.generator_qualnames:
  description: "uuid generator function __qualname__ identity"
  kind: python_call_eq
  category: generator_qualnames
  id_prefix: uu916gq
  columns: [id, function, args, expected]
  rows:
    - [uu916gq001, uuid.uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uu916gq002, uuid.uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [uu916gq003, uuid.uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [uu916gq004, uuid.uuid5.__qualname__.__eq__, ["uuid5"], true]

table uuid_extra916.module_identity:
  description: "uuid module-level identity and __module__ checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: uu916mi
  columns: [id, function, args, expected]
  rows:
    - [uu916mi001, uuid.UUID.__module__.__eq__,     ["uuid"], true]
    - [uu916mi002, uuid.SafeUUID.__module__.__eq__, ["uuid"], true]
    - [uu916mi003, uuid.uuid1.__module__.__eq__,    ["uuid"], true]
    - [uu916mi004, uuid.uuid3.__module__.__eq__,    ["uuid"], true]
    - [uu916mi005, uuid.uuid4.__module__.__eq__,    ["uuid"], true]
    - [uu916mi006, uuid.uuid5.__module__.__eq__,    ["uuid"], true]
    - [uu916mi007, uuid.UUID.__class__.__name__.__eq__,     ["type"], true]
    - [uu916mi008, uuid.SafeUUID.__class__.__name__.__eq__, ["EnumType"], true]
    - [uu916mi009, uuid.uuid1.__class__.__name__.__eq__,    ["function"], true]
