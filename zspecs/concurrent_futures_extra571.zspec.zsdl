spec: concurrent_futures_extra571
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures class and exception identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers class and exception identity for core concurrent.futures types"
  created_at: "2026-04-12T00:00:00Z"

table concurrent_futures_extra571.class_identity:
  description: "Identity checks for concurrent.futures class objects via __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: CFEX571
  columns: [id, function, args, expected]
  rows:
    - [CFEX571001, concurrent.futures.Future.__class__.__name__.__eq__, ["type"], true]
    - [CFEX571002, concurrent.futures.Executor.__class__.__name__.__eq__, ["type"], true]
    - [CFEX571003, concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__, ["type"], true]
    - [CFEX571004, concurrent.futures.ProcessPoolExecutor.__class__.__name__.__eq__, ["type"], true]
table concurrent_futures_extra571.class_qualname:
  description: "Qualname checks for concurrent.futures class objects"
  kind: python_call_eq
  category: class_qualname
  id_prefix: CFEX571Q
  columns: [id, function, args, expected]
  rows:
    - [CFEX571Q001, concurrent.futures.Future.__qualname__.__eq__, ["Future"], true]
    - [CFEX571Q002, concurrent.futures.Executor.__qualname__.__eq__, ["Executor"], true]
    - [CFEX571Q003, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__, ["ThreadPoolExecutor"], true]
    - [CFEX571Q004, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true]
table concurrent_futures_extra571.exception_identity:
  description: "Identity checks for concurrent.futures exception types via __qualname__"
  kind: python_call_eq
  category: exception_identity
  id_prefix: CFEX571E
  columns: [id, function, args, expected]
  rows:
    - [CFEX571E001, concurrent.futures.CancelledError.__qualname__.__eq__, ["CancelledError"], true]
    - [CFEX571E002, concurrent.futures.TimeoutError.__qualname__.__eq__, ["TimeoutError"], true]
    - [CFEX571E003, concurrent.futures.BrokenExecutor.__qualname__.__eq__, ["BrokenExecutor"], true]