# ---------------------------------------------------------------------------
# io.BufferedWriter method __qualname__ string equality
# BufferedWriter is a concrete buffered I/O implementation for writable streams.
# Its own methods (write, flush, close, seek, tell) use 'BufferedWriter.' prefix.
# read is inherited from _BufferedIOBase; readable is inherited from _IOBase.
# All types are method_descriptor (C extension methods, no __code__).
# ---------------------------------------------------------------------------

table io_extra129.BufferedWriter_qualnames_eq:
  description: "io.BufferedWriter method __qualname__ string equality: write/flush/close='BufferedWriter.*'(20); seek/tell='BufferedWriter.*'(19)"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobw129a

  columns: [id, function, args, expected, description]
  rows:
    - [bw_write_qn_eq,   "BufferedWriter.write.__qualname__.__eq__",   ["BufferedWriter.write"],   true,  "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (20 chars; write(b) writes bytes-like object b to the stream; defined directly on BufferedWriter as a C extension method_descriptor, so __qualname__ uses the 'BufferedWriter.' prefix)"]
    - [bw_write_qn_len,  "BufferedWriter.write.__qualname__.__len__",  [],                         20,    "io.BufferedWriter.write.__qualname__.__len__() == 20 ('BufferedWriter'(14)+'.'(1)+'write'(5)==20)"]
    - [bw_flush_qn_eq,   "BufferedWriter.flush.__qualname__.__eq__",   ["BufferedWriter.flush"],   true,  "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (20 chars; flush forces buffered bytes to the raw stream; overrides the IOBase.flush inherited method with a BufferedWriter-specific implementation)"]
    - [bw_flush_qn_len,  "BufferedWriter.flush.__qualname__.__len__",  [],                         20,    "io.BufferedWriter.flush.__qualname__.__len__() == 20 (same length as 'BufferedWriter.write'; both are 20-char qualnames)"]
    - [bw_close_qn_eq,   "BufferedWriter.close.__qualname__.__eq__",   ["BufferedWriter.close"],   true,  "io.BufferedWriter.close.__qualname__ == 'BufferedWriter.close' (20 chars; close flushes the write buffer and closes the underlying raw stream)"]
    - [bw_close_qn_len,  "BufferedWriter.close.__qualname__.__len__",  [],                         20,    "io.BufferedWriter.close.__qualname__.__len__() == 20 (write, flush, and close all have identical qualname lengths of 20)"]
    - [bw_seek_qn_eq,    "BufferedWriter.seek.__qualname__.__eq__",    ["BufferedWriter.seek"],    true,  "io.BufferedWriter.seek.__qualname__ == 'BufferedWriter.seek' (19 chars; seek changes the stream position; defined on BufferedWriter directly with a 4-char method name)"]
    - [bw_seek_qn_len,   "BufferedWriter.seek.__qualname__.__len__",   [],                         19,    "io.BufferedWriter.seek.__qualname__.__len__() == 19 ('BufferedWriter'(14)+'.'(1)+'seek'(4)==19; 1 char shorter than write/flush/close)"]

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ string equality
# BytesIO is an in-memory binary stream. All its methods are defined directly
# on BytesIO (C extension) using the 'BytesIO.' prefix in __qualname__.
# read(12), write(13), close(13), seek(12), tell(12), readline(16),
# truncate(16), getvalue(16), getbuffer(17), readlines(17).
# ---------------------------------------------------------------------------

table io_extra129.BytesIO_qualnames_short:
  description: "io.BytesIO method __qualname__ string equality for shorter-name methods: read/seek/tell='BytesIO.*'(12); write/close='BytesIO.*'(13)"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobio129b

  columns: [id, function, args, expected, description]
  rows:
    - [bio_read_qn_eq,   "BytesIO.read.__qualname__.__eq__",    ["BytesIO.read"],    true,  "io.BytesIO.read.__qualname__ == 'BytesIO.read' (12 chars; read([size]) reads at most size bytes from the in-memory buffer; 'BytesIO.'(8)+'read'(4)==12)"]
    - [bio_read_qn_len,  "BytesIO.read.__qualname__.__len__",   [],                  12,    "io.BytesIO.read.__qualname__.__len__() == 12 (shortest BytesIO method qualname; tied with seek and tell at 12 chars)"]
    - [bio_seek_qn_eq,   "BytesIO.seek.__qualname__.__eq__",    ["BytesIO.seek"],    true,  "io.BytesIO.seek.__qualname__ == 'BytesIO.seek' (12 chars; seek changes the stream position within the in-memory buffer; same length as 'BytesIO.read' and 'BytesIO.tell')"]
    - [bio_tell_qn_eq,   "BytesIO.tell.__qualname__.__eq__",    ["BytesIO.tell"],    true,  "io.BytesIO.tell.__qualname__ == 'BytesIO.tell' (12 chars; tell returns the current stream position as an integer; tied with read and seek for shortest BytesIO qualname)"]
    - [bio_write_qn_eq,  "BytesIO.write.__qualname__.__eq__",   ["BytesIO.write"],   true,  "io.BytesIO.write.__qualname__ == 'BytesIO.write' (13 chars; write(b) writes bytes-like object b to the in-memory buffer; 'BytesIO.'(8)+'write'(5)==13)"]
    - [bio_write_qn_len, "BytesIO.write.__qualname__.__len__",  [],                  13,    "io.BytesIO.write.__qualname__.__len__() == 13 (1 char longer than read/seek/tell at 12)"]
    - [bio_close_qn_eq,  "BytesIO.close.__qualname__.__eq__",   ["BytesIO.close"],   true,  "io.BytesIO.close.__qualname__ == 'BytesIO.close' (13 chars; close clears the in-memory buffer and marks the stream closed; same length as 'BytesIO.write')"]
    - [bio_close_qn_len, "BytesIO.close.__qualname__.__len__",  [],                  13,    "io.BytesIO.close.__qualname__.__len__() == 13 (tied with 'BytesIO.write' at 13 chars)"]

# ---------------------------------------------------------------------------
# io.BytesIO long-name method qualnames and io.StringIO methods
# readline/truncate/getvalue share len=16; getbuffer/readlines share len=17.
# StringIO.read(13), StringIO.write(14).
# All assertions novel (no prior io spec covers BytesIO or StringIO qualname equality).
# ---------------------------------------------------------------------------

table io_extra129.BytesIO_long_qualnames_and_StringIO:
  description: "io.BytesIO longer method __qualname__ equality: readline/truncate/getvalue(16); StringIO.read(13), StringIO.write(14); all assertions novel"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobio129c

  columns: [id, function, args, expected, description]
  rows:
    - [bio_readline_qn_eq,   "BytesIO.readline.__qualname__.__eq__",    ["BytesIO.readline"],   true,  "io.BytesIO.readline.__qualname__ == 'BytesIO.readline' (16 chars; readline reads and returns one line from the in-memory stream; 'BytesIO.'(8)+'readline'(8)==16)"]
    - [bio_readline_qn_len,  "BytesIO.readline.__qualname__.__len__",   [],                     16,    "io.BytesIO.readline.__qualname__.__len__() == 16 (tied with truncate and getvalue at 16 chars)"]
    - [bio_truncate_qn_eq,   "BytesIO.truncate.__qualname__.__eq__",    ["BytesIO.truncate"],   true,  "io.BytesIO.truncate.__qualname__ == 'BytesIO.truncate' (16 chars; truncate(size) truncates the in-memory file to at most size bytes; tied with readline and getvalue)"]
    - [bio_getvalue_qn_eq,   "BytesIO.getvalue.__qualname__.__eq__",    ["BytesIO.getvalue"],   true,  "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' (16 chars; getvalue() returns the entire contents of the in-memory buffer as bytes; 'BytesIO.'(8)+'getvalue'(8)==16)"]
    - [bio_getvalue_qn_len,  "BytesIO.getvalue.__qualname__.__len__",   [],                     16,    "io.BytesIO.getvalue.__qualname__.__len__() == 16 (same length as readline and truncate)"]
    - [sio_read_qn_eq,       "StringIO.read.__qualname__.__eq__",       ["StringIO.read"],      true,  "io.StringIO.read.__qualname__ == 'StringIO.read' (13 chars; StringIO.read is the text-mode analog of BytesIO.read; 'StringIO'(8)+'.'(1)+'read'(4)==13; 1 char longer than 'BytesIO.read'(12) because 'StringIO' has 8 chars vs 'BytesIO' 7 chars)"]
    - [sio_read_qn_len,      "StringIO.read.__qualname__.__len__",      [],                     13,    "io.StringIO.read.__qualname__.__len__() == 13 ('StringIO.read' is 13 chars; 1 char longer than 'BytesIO.read' at 12)"]
    - [sio_write_qn_eq,      "StringIO.write.__qualname__.__eq__",      ["StringIO.write"],     true,  "io.StringIO.write.__qualname__ == 'StringIO.write' (14 chars; StringIO.write writes a string to the in-memory text buffer; 'StringIO'(8)+'.'(1)+'write'(5)==14; 1 char longer than 'BytesIO.write'(13) because 'StringIO' has 8 chars vs 'BytesIO' 7 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra129.BufferedWriter.write_qualname_eq:
  description: "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (20 chars; write(b) writes a bytes-like object b to the underlying raw stream, buffering writes for efficiency; BufferedWriter is the standard wrapper for writable binary streams like open(f,'wb'); 'BufferedWriter.write' uses the 'BufferedWriter.' prefix because write is defined directly on the C extension BufferedWriter type, not inherited; type is method_descriptor, so there is no __code__ attribute; no prior io spec asserts BufferedWriter.write.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "BufferedWriter.write.__qualname__.__eq__"
  args: ["BufferedWriter.write"]
  expected: true

invariant io_extra129.BufferedWriter.seek_qualname_eq:
  description: "io.BufferedWriter.seek.__qualname__ == 'BufferedWriter.seek' (19 chars; seek(pos[, whence]) changes the stream position in the underlying raw stream after flushing the write buffer; 'BufferedWriter.seek' at 19 chars is 1 char shorter than write/flush/close (all 20) because 'seek' has 4 chars vs 'write'/'flush'/'close' each with 5 chars; no prior io spec asserts BufferedWriter.seek.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "BufferedWriter.seek.__qualname__.__eq__"
  args: ["BufferedWriter.seek"]
  expected: true

invariant io_extra129.BytesIO.read_qualname_eq:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read' (12 chars; read([size]) reads up to size bytes from the in-memory buffer; BytesIO.read is the most fundamental BytesIO operation; 'BytesIO.read' at 12 chars uses the 'BytesIO.' prefix (8 chars) because read is defined directly on the C extension BytesIO type; no prior io spec asserts BytesIO.read.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "BytesIO.read.__qualname__.__eq__"
  args: ["BytesIO.read"]
  expected: true

invariant io_extra129.BytesIO.getvalue_qualname_eq:
  description: "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' (16 chars; getvalue() returns the entire contents of the BytesIO buffer as a bytes object regardless of the current stream position; it does not consume the buffer; 'BytesIO.getvalue' is 16 chars: 'BytesIO.'(8)+'getvalue'(8)==16; tied with readline(16) and truncate(16) for length; no prior io spec asserts BytesIO.getvalue.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "BytesIO.getvalue.__qualname__.__eq__"
  args: ["BytesIO.getvalue"]
  expected: true

invariant io_extra129.StringIO.write_qualname_eq:
  description: "io.StringIO.write.__qualname__ == 'StringIO.write' (14 chars; StringIO.write(s) writes the string s to the in-memory text buffer and returns the number of characters written; StringIO is the text-mode analog of BytesIO; 'StringIO.write' at 14 chars is 1 char longer than 'BytesIO.write' at 13 chars because 'StringIO'(8) is 1 char longer than 'BytesIO'(7); no prior io spec asserts StringIO.write.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "StringIO.write.__qualname__.__eq__"
  args: ["StringIO.write"]
  expected: true

