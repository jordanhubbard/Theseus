spec: re2896
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/re_extra2881.zspec.zsdl — wave 639 predecessor (covered __iadd__, __isub__, __imul__)"
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 640 theme: __itruediv__, __ifloordiv__, __imod__ dict-presence checks (in-place divide, floor-divide, modulo)."
    - "re.RegexFlag is an IntFlag subclass — IntFlag defines reflected and binary bitwise ops but NOT in-place division or modulo operators."
    - "re.RegexFlag.__itruediv__, __ifloordiv__, and __imod__ are ALL absent (False) — verified with Python 3.14.4."
    - "re.Pattern (type(re.compile(''))) does NOT define any in-place division operators — compiled patterns are not numeric operands."
    - "re.Match (type(re.match('',''))) does NOT define any in-place division operators — match objects are not numeric operands."
    - "IntFlag supports bitwise in-place ops (|=, &=, ^=) via inherited IntEnum machinery, but this does not extend to division or modulo."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __itruediv__ dict-presence
# RegexFlag: False; Pattern and Match: False — no division semantics on re types
# ---------------------------------------------------------------------------

table re2896.itruediv:
  description: "__itruediv__ is absent from re.RegexFlag (IntFlag has no in-place true-division), Pattern, and Match"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2896

  columns: [id, function, args, expected]
  rows:
    - ["re2896001", "re.RegexFlag.__dict__.__contains__",                    ["__itruediv__"], false]
    - ["re2896002", "type(re.compile('')).__dict__.__contains__",            ["__itruediv__"], false]
    - ["re2896003", "type(re.match('', '')).__dict__.__contains__",          ["__itruediv__"], false]
    - ["re2896004", "re.RegexFlag.__dict__.__contains__",                    ["__truediv__"],  false]
    - ["re2896005", "type(re.compile('')).__dict__.__contains__",            ["__truediv__"],  false]
    - ["re2896006", "type(re.match('', '')).__dict__.__contains__",          ["__truediv__"],  false]

