spec: dis_extra24
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra23.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/code_info/show_code __module__ (table); Instruction/__module__ and Bytecode/__module__ standalone; opmap.__len__()==154 standalone; stack_effect/__qualname__ and __module__; code_info/show_code __qualname__ standalone"
    - "dis_extra22.zspec.zsdl — covers Bytecode/__qualname__ standalone; Bytecode.from_traceback/__qualname__; Bytecode.__iter__/__qualname__; Instruction._fields class name; opname.__len__()==267; cmp_op/__class__.__name__ standalone; hascompare/__class__.__name__ standalone"
    - "dis_extra21.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __qualname__.__eq__ (table); Instruction/__qualname__.__eq__ standalone; opname/__class__.__name__=='list' standalone; opmap/__class__.__name__=='dict' standalone"
    - "dis_extra20.zspec.zsdl — covers __qualname__.__len__() for dis/disassemble/findlinestarts/findlabels/stack_effect/pretty_flags/print_instructions"
    - "dis_extra17.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __name__ and __module__; Instruction/__name__; opname/opmap class"
    - "dis_extra16.zspec.zsdl — covers Bytecode/__qualname__ and Instruction/__qualname__ in a class_qualnames table"
    - "dis_extra11.zspec.zsdl — covers opmap.__len__==154; hasconst/haslocal/hasname/hascompare/hasjrel/hasfree lengths"
    - "dis_extra5.zspec.zsdl — covers Bytecode/__qualname__; code_info/show_code/stack_effect/findlabels/distb __qualname__"
    - "dis_extra4.zspec.zsdl — covers Instruction/__qualname__; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
  notes:
    - "This spec extends dis_extra23.zspec.zsdl."
    - "Focus: Instruction._fields.__len__() and _fields[0]/_fields[1] string values; findlinestarts/__qualname__ and findlabels/__qualname__ standalone in dis_extra24 namespace; distb/__qualname__ standalone; Bytecode.__init__/__qualname__ and __module__."
    - "dis.Instruction._fields.__len__() == 12 — dis_extra22 covers _fields.__class__.__name__=='tuple'; no prior dis spec covers _fields.__len__() as a standalone __eq__ invariant."
    - "dis.Instruction._fields[0] == 'opname' — the first field of the Instruction namedtuple; no prior dis spec covers _fields[0] as a standalone __eq__ invariant."
    - "dis.Instruction._fields[1] == 'opcode' — the second field of the Instruction namedtuple; no prior dis spec covers _fields[1] as a standalone __eq__ invariant."
    - "dis.findlinestarts.__qualname__ == 'findlinestarts' — dis_extra21 covers this in a table; distinct standalone invariant in dis_extra24 namespace."
    - "dis.findlabels.__qualname__ == 'findlabels' — dis_extra21 covers this in a table; distinct standalone invariant in dis_extra24 namespace."
    - "dis.distb.__qualname__ == 'distb' — dis_extra5 covers this in its namespace; distinct standalone invariant in dis_extra24 namespace."
    - "dis.distb.__module__ == 'dis' — no prior dis spec covers distb.__module__ as a standalone __eq__ invariant."
    - "dis.Bytecode.__init__.__qualname__ == 'Bytecode.__init__' — no prior dis spec covers this method __qualname__."
    - "dis.Bytecode.__init__.__module__ == 'dis' — no prior dis spec covers Bytecode.__init__.__module__ as a standalone __eq__ invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Instruction._fields length and first two field name strings
# (dis_extra24 namespace)
#
# dis_extra22 covers _fields.__class__.__name__=='tuple'.
# No prior dis spec covers _fields.__len__() or _fields[0]/_fields[1] as
# standalone __eq__ invariants. Python 3.12 Instruction has 12 fields:
# opname, opcode, arg, argval, argrepr, offset, start_offset, starts_line,
# line_number, label, positions, cache_info.
# ---------------------------------------------------------------------------

invariant dis_extra24.Instruction_fields.len_is_12:
  description: "dis.Instruction._fields.__len__() == 12 — twelve named fields in the Instruction namedtuple on Python 3.12"
  category: sequence_lengths
  kind: python_call_eq
  function: Instruction._fields.__len__
  args: []
  expected: 12

invariant dis_extra24.Instruction_fields.first_is_opname:
  description: "dis.Instruction._fields[0] == 'opname' — first field of the Instruction namedtuple is opname"
  category: sequence_items
  kind: python_call_eq
  function: "Instruction._fields[0].__eq__"
  args: ["opname"]
  expected: true

invariant dis_extra24.Instruction_fields.second_is_opcode:
  description: "dis.Instruction._fields[1] == 'opcode' — second field of the Instruction namedtuple is opcode"
  category: sequence_items
  kind: python_call_eq
  function: "Instruction._fields[1].__eq__"
  args: ["opcode"]
  expected: true

# ---------------------------------------------------------------------------
# findlinestarts and findlabels __qualname__ — standalone invariants
# (dis_extra24 namespace)
#
# dis_extra21 covers these in a table (__qualname__.__eq__).
# dis_extra20 covers __qualname__.__len__() for findlinestarts/findlabels.
# These are distinct standalone invariants in the dis_extra24 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra24.findlinestarts.qualname:
  description: "dis.findlinestarts.__qualname__ == 'findlinestarts'"
  category: function_qualnames
  kind: python_call_eq
  function: findlinestarts.__qualname__.__eq__
  args: ["findlinestarts"]
  expected: true

invariant dis_extra24.findlabels.qualname:
  description: "dis.findlabels.__qualname__ == 'findlabels'"
  category: function_qualnames
  kind: python_call_eq
  function: findlabels.__qualname__.__eq__
  args: ["findlabels"]
  expected: true

# ---------------------------------------------------------------------------
# distb __qualname__ and __module__ — standalone invariants
# (dis_extra24 namespace)
#
# dis_extra5 covers distb/__qualname__ in its namespace.
# No prior dis spec covers distb.__module__ as a standalone __eq__ invariant.
# These are distinct standalone invariants in the dis_extra24 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra24.distb.qualname:
  description: "dis.distb.__qualname__ == 'distb'"
  category: function_qualnames
  kind: python_call_eq
  function: distb.__qualname__.__eq__
  args: ["distb"]
  expected: true

invariant dis_extra24.distb.module:
  description: "dis.distb.__module__ == 'dis'"
  category: function_modules
  kind: python_call_eq
  function: distb.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# Bytecode.__init__ __qualname__ and __module__ — standalone invariants
# (dis_extra24 namespace)
#
# dis_extra22 covers Bytecode/__qualname__ standalone and
# Bytecode.from_traceback/__qualname__ and Bytecode.__iter__/__qualname__.
# No prior dis spec covers Bytecode.__init__.__qualname__ or
# Bytecode.__init__.__module__ as standalone __eq__ invariants.
# ---------------------------------------------------------------------------

invariant dis_extra24.Bytecode_init.qualname:
  description: "dis.Bytecode.__init__.__qualname__ == 'Bytecode.__init__'"
  category: method_qualnames
  kind: python_call_eq
  function: Bytecode.__init__.__qualname__.__eq__
  args: ["Bytecode.__init__"]
  expected: true

invariant dis_extra24.Bytecode_init.module:
  description: "dis.Bytecode.__init__.__module__ == 'dis'"
  category: method_modules
  kind: python_call_eq
  function: Bytecode.__init__.__module__.__eq__
  args: ["dis"]
  expected: true
