spec: re_extra1681
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra1576.zspec.zsdl — covers __str__/__repr__/__bytes__ protocol, flag constants, flag __name__ attrs"
    - "re_extra1606.zspec.zsdl — covers __slots__, method presence for Pattern and Match"
    - "re_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol — which re types define __call__ in their own __dict__."
    - "re.Pattern is a C extension type; Pattern instances are NOT callable — no __call__ in Pattern.__dict__."
    - "re.Match is a C extension type; Match instances are NOT callable — no __call__ in Match.__dict__."
    - "re.error (PatternError) is a Python exception class; exception instances are NOT callable — no __call__."
    - "re.RegexFlag is an IntFlag enum subclass; flag members are NOT callable — no __call__ in RegexFlag.__dict__."
    - "re.Pattern does NOT define __iter__ or __contains__ in its own __dict__ — it is not iterable or a container."
    - "re.Match does NOT define __iter__ in its own __dict__ — not iterable, but supports __getitem__ for group access."
    - "re.Pattern defines __hash__ and __eq__ for identity comparison in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table re_extra1681.callable_protocol
# __call__ is absent from every re type's own __dict__.
# Compiled patterns and match objects are not callable; use .match()/.search()
# on Pattern instances to match, not by calling them directly.
# ---------------------------------------------------------------------------

table re_extra1681.callable_protocol:
  description: "re types __call__ dict-presence checks — no re type defines __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1681

  columns: [id, function, args, expected]
  rows:
    - ["re1681001", Pattern.__dict__.__contains__,    ["__call__"], false]
    - ["re1681002", Match.__dict__.__contains__,      ["__call__"], false]
    - ["re1681003", error.__dict__.__contains__,      ["__call__"], false]
    - ["re1681004", RegexFlag.__dict__.__contains__,  ["__call__"], false]

# ---------------------------------------------------------------------------
# Table re_extra1681.iteration_container_protocol
# re.Pattern does NOT define __iter__ or __contains__ in its own __dict__.
# re.Match does NOT define __iter__ in its own __dict__.
# Match defines __getitem__ for group access by index/name.
# ---------------------------------------------------------------------------

table re_extra1681.iteration_container_protocol:
  description: "Iteration and container protocol dict-presence checks for re types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1681

  columns: [id, function, args, expected]
  rows:
    - ["re1681005", Pattern.__dict__.__contains__,    ["__iter__"],     false]
    - ["re1681006", Pattern.__dict__.__contains__,    ["__contains__"], false]
    - ["re1681007", Pattern.__dict__.__contains__,    ["__len__"],      false]
    - ["re1681008", Match.__dict__.__contains__,      ["__iter__"],     false]
    - ["re1681009", Match.__dict__.__contains__,      ["__contains__"], false]
    - ["re1681010", Match.__dict__.__contains__,      ["__len__"],      false]
    - ["re1681011", Match.__dict__.__contains__,      ["__getitem__"],  true]
    - ["re1681012", error.__dict__.__contains__,      ["__iter__"],     false]
    - ["re1681013", RegexFlag.__dict__.__contains__,  ["__iter__"],     false]
    - ["re1681014", RegexFlag.__dict__.__contains__,  ["__contains__"], false]

# ---------------------------------------------------------------------------
# Table re_extra1681.comparison_hash_protocol
# re.Pattern defines __hash__ and __eq__ in its own __dict__ (structural equality).
# re.Match does NOT define __hash__ or __eq__ (unhashable, identity only).
# re.error and re.RegexFlag do not define __eq__ or __hash__ in their own __dict__.
# ---------------------------------------------------------------------------

table re_extra1681.comparison_hash_protocol:
  description: "Comparison and hash protocol dict-presence checks for re types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1681

  columns: [id, function, args, expected]
  rows:
    - ["re1681015", Pattern.__dict__.__contains__,    ["__hash__"],  true]
    - ["re1681016", Pattern.__dict__.__contains__,    ["__eq__"],    true]
    - ["re1681017", Pattern.__dict__.__contains__,    ["__lt__"],    false]
    - ["re1681018", Pattern.__dict__.__contains__,    ["__le__"],    false]
    - ["re1681019", Pattern.__dict__.__contains__,    ["__gt__"],    false]
    - ["re1681020", Match.__dict__.__contains__,      ["__hash__"],  false]
    - ["re1681021", Match.__dict__.__contains__,      ["__eq__"],    false]
    - ["re1681022", Match.__dict__.__contains__,      ["__lt__"],    false]
    - ["re1681023", error.__dict__.__contains__,      ["__hash__"],  false]
    - ["re1681024", error.__dict__.__contains__,      ["__eq__"],    false]
    - ["re1681025", RegexFlag.__dict__.__contains__,  ["__eq__"],    false]
    - ["re1681026", RegexFlag.__dict__.__contains__,  ["__hash__"],  false]
