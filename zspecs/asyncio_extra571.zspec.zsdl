spec: asyncio_extra571
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module class and exception identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers class and exception identity for core asyncio types"
  created_at: "2026-04-12T00:00:00Z"

table asyncio_extra571.class_identity:
  description: "Identity checks for asyncio class objects"
  kind: python_call_eq
  category: class_identity
  id_prefix: AEX571
  columns: [id, function, args, expected]
  rows:
    - [AEX571001, asyncio.AbstractEventLoop.__class__.__name__.__eq__, ["type"], true]
    - [AEX571002, asyncio.BaseEventLoop.__class__.__name__.__eq__, ["type"], true]
    - [AEX571003, asyncio.Future.__class__.__name__.__eq__, ["type"], true]
    - [AEX571004, asyncio.Task.__class__.__name__.__eq__, ["type"], true]
    - [AEX571005, asyncio.Queue.__class__.__name__.__eq__, ["type"], true]
    - [AEX571006, asyncio.Lock.__class__.__name__.__eq__, ["type"], true]
    - [AEX571007, asyncio.Semaphore.__class__.__name__.__eq__, ["type"], true]
    - [AEX571008, asyncio.Event.__class__.__name__.__eq__, ["type"], true]
table asyncio_extra571.exception_identity:
  description: "Identity checks for asyncio exception types via __qualname__"
  kind: python_call_eq
  category: exception_identity
  id_prefix: AEX571E
  columns: [id, function, args, expected]
  rows:
    - [AEX571E001, asyncio.CancelledError.__qualname__.__eq__, ["CancelledError"], true]
    - [AEX571E002, asyncio.TimeoutError.__qualname__.__eq__, ["TimeoutError"], true]
    - [AEX571E003, asyncio.InvalidStateError.__qualname__.__eq__, ["InvalidStateError"], true]
    - [AEX571E004, asyncio.QueueEmpty.__qualname__.__eq__, ["QueueEmpty"], true]
    - [AEX571E005, asyncio.QueueFull.__qualname__.__eq__, ["QueueFull"], true]