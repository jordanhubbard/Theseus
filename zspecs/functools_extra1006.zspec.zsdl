spec: functools_extra1006
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks qualnames of reduce, partial, partialmethod, cached_property methods and module __all__ class"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1006.reduce_qualnames:
  description: "functools.reduce method __qualname__ checks"
  kind: python_call_eq
  category: reduce_qualnames
  id_prefix: ft1006rq
  columns: [id, function, args, expected]
  rows:
    - [ft1006rq001, functools.reduce.__qualname__.__eq__,          ["reduce"],                  true]
    - [ft1006rq002, functools.reduce.__module__.__eq__,            ["functools"],               true]
    - [ft1006rq003, functools.reduce.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]

table functools_extra1006.partial_qualnames:
  description: "functools.partial and partialmethod method __qualname__ checks"
  kind: python_call_eq
  category: partial_qualnames
  id_prefix: ft1006pq
  columns: [id, function, args, expected]
  rows:
    - [ft1006pq001, functools.partial.__reduce__.__qualname__.__eq__,        ["partial.__reduce__"],        true]
    - [ft1006pq002, functools.partial.__repr__.__qualname__.__eq__,          ["partial.__repr__"],          true]
    - [ft1006pq003, functools.partial.__eq__.__qualname__.__eq__,            ["partial.__eq__"],            true]
    - [ft1006pq004, functools.partial.__hash__.__qualname__.__eq__,          ["partial.__hash__"],          true]
    - [ft1006pq005, functools.partialmethod.__reduce__.__qualname__.__eq__,  ["partialmethod.__reduce__"],  true]
    - [ft1006pq006, functools.partialmethod.__get__.__qualname__.__eq__,     ["partialmethod.__get__"],     true]
    - [ft1006pq007, functools.partialmethod.__repr__.__qualname__.__eq__,    ["partialmethod.__repr__"],    true]

table functools_extra1006.cached_property_qualnames:
  description: "functools.cached_property method __qualname__ checks"
  kind: python_call_eq
  category: cached_property_qualnames
  id_prefix: ft1006cp
  columns: [id, function, args, expected]
  rows:
    - [ft1006cp001, functools.cached_property.__init__.__qualname__.__eq__,   ["cached_property.__init__"],   true]
    - [ft1006cp002, functools.cached_property.__set_name__.__qualname__.__eq__, ["cached_property.__set_name__"], true]
    - [ft1006cp003, functools.cached_property.__get__.__qualname__.__eq__,    ["cached_property.__get__"],    true]
    - [ft1006cp004, functools.cached_property.__class__.__name__.__eq__,      ["type"],                       true]
    - [ft1006cp005, functools.__all__.__class__.__name__.__eq__,              ["list"],                       true]
