spec: decimal_extra751
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs:
  summary: Verifies decimal module rounding constant types and signal class qualnames
  tags: [decimal, constants, signals, stdlib]

provenance:
  derived_from:
    - https://docs.python.org/3/library/decimal.html#rounding-modes
    - https://docs.python.org/3/library/decimal.html#signals
  not_derived_from: []
  notes:
    - ROUND_* constants are plain strings in CPython; signal classes are exception subclasses whose qualnames must remain stable
  created_at: "2026-04-12"

table decimal_extra751.name:
  description: decimal module constant type checks and signal class qualname checks
  kind: python_call_eq
  category: constants
  id_prefix: dc751xx
  columns: [id, function, args, expected]
  rows:
    - [dc751xx001, decimal.ROUND_UP.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx002, decimal.ROUND_DOWN.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx003, decimal.ROUND_CEILING.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx004, decimal.ROUND_FLOOR.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx005, decimal.ROUND_HALF_UP.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx006, decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx007, decimal.ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx008, decimal.ROUND_05UP.__class__.__name__.__eq__, ["str"], true]
    - [dc751xx009, decimal.Overflow.__qualname__.__eq__, ["Overflow"], true]
    - [dc751xx010, decimal.Underflow.__qualname__.__eq__, ["Underflow"], true]
    - [dc751xx011, decimal.InvalidOperation.__qualname__.__eq__, ["InvalidOperation"], true]
    - [dc751xx012, decimal.DivisionByZero.__qualname__.__eq__, ["DivisionByZero"], true]
