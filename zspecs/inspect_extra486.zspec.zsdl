spec: inspect_extra486
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect.Parameter.kind enum values"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.Parameter.kind is a ParameterKind IntEnum; values 0-4 are stable across Python 3.x"
    - "Name identity verified via .name attribute of each enum member"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra486.parameter_kind_values:
  description: "inspect.Parameter.kind enum integer values"
  kind: python_call_eq
  category: enum_values
  id_prefix: pkv

  columns: [id, function, args, expected]
  rows:
    - [pkv001, inspect.Parameter.POSITIONAL_ONLY.value.__eq__, [0], true]
    - [pkv002, inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__, [1], true]
    - [pkv003, inspect.Parameter.VAR_POSITIONAL.value.__eq__, [2], true]
    - [pkv004, inspect.Parameter.KEYWORD_ONLY.value.__eq__, [3], true]
    - [pkv005, inspect.Parameter.VAR_KEYWORD.value.__eq__, [4], true]

table inspect_extra486.parameter_kind_names:
  description: "inspect.Parameter.kind enum member .name string identity"
  kind: python_call_eq
  category: enum_names
  id_prefix: pkn

  columns: [id, function, args, expected]
  rows:
    - [pkn001, inspect.Parameter.POSITIONAL_ONLY.name.__eq__, ["POSITIONAL_ONLY"], true]
    - [pkn002, inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__, ["POSITIONAL_OR_KEYWORD"], true]
    - [pkn003, inspect.Parameter.VAR_POSITIONAL.name.__eq__, ["VAR_POSITIONAL"], true]
    - [pkn004, inspect.Parameter.KEYWORD_ONLY.name.__eq__, ["KEYWORD_ONLY"], true]
    - [pkn005, inspect.Parameter.VAR_KEYWORD.name.__eq__, ["VAR_KEYWORD"], true]
