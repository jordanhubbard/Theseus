  derived_from:
    - "https://oauthlib.readthedocs.io/ — oauthlib library"
  notes:
    - "oauthlib provides OAuth 1 and 2 support."
    - "oauthlib.oauth2.BackendApplicationClient is a class."
    - "oauthlib.common.generate_token() returns a non-empty string."
    - "oauthlib.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant oauthlib_rust.has_backend_client:
  description: "oauthlib.oauth2.BackendApplicationClient is a class"
  category: presence
  kind: python_call_eq
  function: oauthlib_has_backend_client
  args: []
