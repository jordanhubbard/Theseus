invariant oauthlib_rust.token_nonempty:
  description: "oauthlib.common.generate_token() returns non-empty string"
  category: token
  kind: python_call_eq
  function: oauthlib_generate_token_nonempty
  args: []
  expected: true

invariant oauthlib_rust.version_nonempty:
  description: "oauthlib.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: oauthlib_version_nonempty
  args: []
  expected: true

