spec: json_extra24
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json_extra23.zspec.zsdl."
    - "Prior specs covered: JSONDecoder/JSONEncoder/__name__/__module__/__qualname__/__bases__[0].__name__, JSONDecodeError/__name__/__module__/__bases__[0].__name__, loads/dumps/load/dump __name__/__module__/__qualname__, JSONDecoder/JSONEncoder/JSONDecodeError __init__.__name__, __module__.__len__() and __name__.__len__() for JSONDecoder/JSONEncoder/JSONDecodeError/loads/dumps/load/dump."
    - "This spec covers: __qualname__.__len__() for JSONDecoder, JSONEncoder, JSONDecodeError; __qualname__.__len__() for JSONEncoder.encode/default/iterencode methods; __qualname__.__len__() for JSONDecoder.decode/raw_decode methods; __name__.__len__() for load/dump; __qualname__.__len__() for loads/dumps/load/dump."
    - "No prior json spec checks json.JSONDecoder.__qualname__.__len__()."
    - "No prior json spec checks json.JSONEncoder.__qualname__.__len__()."
    - "No prior json spec checks json.JSONDecodeError.__qualname__.__len__()."
    - "No prior json spec checks json.JSONEncoder.encode.__qualname__.__len__()."
    - "No prior json spec checks json.JSONEncoder.default.__qualname__.__len__()."
    - "No prior json spec checks json.JSONEncoder.iterencode.__qualname__.__len__()."
    - "No prior json spec checks json.JSONDecoder.decode.__qualname__.__len__()."
    - "No prior json spec checks json.JSONDecoder.raw_decode.__qualname__.__len__()."
    - "No prior json spec checks json.load.__name__.__len__()."
    - "No prior json spec checks json.dump.__name__.__len__()."
    - "No prior json spec checks json.loads.__qualname__.__len__()."
    - "No prior json spec checks json.dumps.__qualname__.__len__()."
    - "No prior json spec checks json.load.__qualname__.__len__()."
    - "No prior json spec checks json.dump.__qualname__.__len__()."
    - "json.JSONDecoder.__qualname__ == 'JSONDecoder' — len 11 (flat, same as __name__)."
    - "json.JSONEncoder.__qualname__ == 'JSONEncoder' — len 11 (flat, same as __name__)."
    - "json.JSONDecodeError.__qualname__ == 'JSONDecodeError' — len 15 (flat, same as __name__)."
    - "json.JSONEncoder.encode.__qualname__ == 'JSONEncoder.encode' — len 18."
    - "json.JSONEncoder.default.__qualname__ == 'JSONEncoder.default' — len 19."
    - "json.JSONEncoder.iterencode.__qualname__ == 'JSONEncoder.iterencode' — len 22."
    - "json.JSONDecoder.decode.__qualname__ == 'JSONDecoder.decode' — len 18."
    - "json.JSONDecoder.raw_decode.__qualname__ == 'JSONDecoder.raw_decode' — len 22."
    - "json.load.__name__ == 'load' — len 4."
    - "json.dump.__name__ == 'dump' — len 4."
    - "json.loads.__qualname__ == 'loads' — len 5 (flat, same as __name__)."
    - "json.dumps.__qualname__ == 'dumps' — len 5 (flat, same as __name__)."
    - "json.load.__qualname__ == 'load' — len 4 (flat, same as __name__)."
    - "json.dump.__qualname__ == 'dump' — len 4 (flat, same as __name__)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for JSONDecoder, JSONEncoder, JSONDecodeError
#
# All three classes have flat __qualname__ values equal to their __name__
# (no enclosing class scope). JSONDecoder.__qualname__ == 'JSONDecoder' (len
# 11), JSONEncoder.__qualname__ == 'JSONEncoder' (len 11), and
# JSONDecodeError.__qualname__ == 'JSONDecodeError' (len 15). No prior json
# spec checks the length of any class's __qualname__ string.
# ---------------------------------------------------------------------------

invariant json_extra24.JSONDecoder.qualname.len:
  description: "json.JSONDecoder.__qualname__.__len__() == 11 — 'JSONDecoder' has 11 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: JSONDecoder.__qualname__.__len__
  args: []
  expected: 11

invariant json_extra24.JSONEncoder.qualname.len:
  description: "json.JSONEncoder.__qualname__.__len__() == 11 — 'JSONEncoder' has 11 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: JSONEncoder.__qualname__.__len__
  args: []
  expected: 11

invariant json_extra24.JSONDecodeError.qualname.len:
  description: "json.JSONDecodeError.__qualname__.__len__() == 15 — 'JSONDecodeError' has 15 characters (flat qualname)"
  category: string_lengths
  kind: python_call_eq
  function: JSONDecodeError.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# __qualname__.__len__() for JSONEncoder methods
#
# JSONEncoder.encode.__qualname__ == 'JSONEncoder.encode' (len 18),
# JSONEncoder.default.__qualname__ == 'JSONEncoder.default' (len 19),
# JSONEncoder.iterencode.__qualname__ == 'JSONEncoder.iterencode' (len 22).
# The dotted qualname includes the class prefix, so each is longer than the
# plain __name__. No prior json spec checks any method's __qualname__ length.
# ---------------------------------------------------------------------------

invariant json_extra24.JSONEncoder.encode.qualname.len:
  description: "json.JSONEncoder.encode.__qualname__.__len__() == 18 — 'JSONEncoder.encode' has 18 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONEncoder.encode.__qualname__.__len__"
  args: []
  expected: 18

invariant json_extra24.JSONEncoder.default.qualname.len:
  description: "json.JSONEncoder.default.__qualname__.__len__() == 19 — 'JSONEncoder.default' has 19 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONEncoder.default.__qualname__.__len__"
  args: []
  expected: 19

invariant json_extra24.JSONEncoder.iterencode.qualname.len:
  description: "json.JSONEncoder.iterencode.__qualname__.__len__() == 22 — 'JSONEncoder.iterencode' has 22 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONEncoder.iterencode.__qualname__.__len__"
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# __qualname__.__len__() for JSONDecoder methods
#
# JSONDecoder.decode.__qualname__ == 'JSONDecoder.decode' (len 18),
# JSONDecoder.raw_decode.__qualname__ == 'JSONDecoder.raw_decode' (len 22).
# No prior json spec checks JSONDecoder method __qualname__ lengths.
# ---------------------------------------------------------------------------

invariant json_extra24.JSONDecoder.decode.qualname.len:
  description: "json.JSONDecoder.decode.__qualname__.__len__() == 18 — 'JSONDecoder.decode' has 18 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONDecoder.decode.__qualname__.__len__"
  args: []
  expected: 18

invariant json_extra24.JSONDecoder.raw_decode.qualname.len:
  description: "json.JSONDecoder.raw_decode.__qualname__.__len__() == 22 — 'JSONDecoder.raw_decode' has 22 characters"
  category: string_lengths
  kind: python_call_eq
  function: "JSONDecoder.raw_decode.__qualname__.__len__"
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# Consolidated table — class __qualname__ lengths
#
# Three classes with flat __qualname__ matching their __name__ strings.
# All three are first covered in this spec (json_extra24).
# ---------------------------------------------------------------------------

table json_extra24.class_qualname_lengths:
  description: "json class __qualname__.__len__() — JSONDecoder, JSONEncoder, JSONDecodeError"
  kind: python_call_eq
  category: string_lengths
  id_prefix: jfa24a

  columns: [id, function, args, expected]
  rows:
    - [JSONDecoder_qualname_len,    JSONDecoder.__qualname__.__len__,    [], 11]
    - [JSONEncoder_qualname_len,    JSONEncoder.__qualname__.__len__,    [], 11]
    - [JSONDecodeError_qualname_len, JSONDecodeError.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Consolidated table — method __qualname__ lengths and function __name__ /
# __qualname__ lengths
#
# JSONEncoder/JSONDecoder method qualnames carry the dotted class.method
# form. Top-level functions (load/dump/loads/dumps) have flat qualnames
# equal to their __name__. All values are first covered in this spec.
# ---------------------------------------------------------------------------

table json_extra24.method_and_function_qualname_lengths:
  description: "json method __qualname__ lengths (JSONEncoder/JSONDecoder) and function __name__/__qualname__ lengths (load/dump/loads/dumps)"
  kind: python_call_eq
  category: string_lengths
  id_prefix: jfa24b

  columns: [id, function, args, expected]
  rows:
    - [JSONEncoder_encode_qualname_len,     "JSONEncoder.encode.__qualname__.__len__",     [], 18]
    - [JSONEncoder_default_qualname_len,    "JSONEncoder.default.__qualname__.__len__",    [], 19]
    - [JSONEncoder_iterencode_qualname_len, "JSONEncoder.iterencode.__qualname__.__len__", [], 22]
    - [JSONDecoder_decode_qualname_len,     "JSONDecoder.decode.__qualname__.__len__",     [], 18]
    - [JSONDecoder_raw_decode_qualname_len, "JSONDecoder.raw_decode.__qualname__.__len__", [], 22]
    - [load_name_len,                       load.__name__.__len__,                         [],  4]
    - [dump_name_len,                       dump.__name__.__len__,                         [],  4]
    - [loads_qualname_len,                  loads.__qualname__.__len__,                    [],  5]
    - [dumps_qualname_len,                  dumps.__qualname__.__len__,                    [],  5]
    - [load_qualname_len,                   load.__qualname__.__len__,                     [],  4]
    - [dump_qualname_len,                   dump.__qualname__.__len__,                     [],  4]
