spec: decimal_extra1771
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal str/predicates/as_tuple/class name/getcontext/error cases"
    - "decimal_extra.zspec.zsdl — covers Decimal predicates/eng_string, Context/BasicContext/ExtendedContext names, ROUND_* constants"
  notes:
    - "Wave 565, theme: async protocol. All five async dunder methods are absent from decimal types."
    - "ROUND_HALF_UP, ROUND_DOWN are plain str constants; __class__.__name__ == 'str'."
    - "Decimal does not implement __complex__; complex(Decimal('1')) raises TypeError."
    - "Decimal does not implement __index__ — it cannot be used as a sequence index."
    - "Context.create_decimal and Context.create_decimal_from_float are defined in Context.__dict__."
    - "All expected values verified by running Python 3.14 decimal module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Async protocol — decimal types do NOT define any async dunder in their own __dict__
# Wave 565 theme: __aenter__, __aexit__, __aiter__, __anext__, __await__
# ---------------------------------------------------------------------------

table decimal_extra1771.async_protocol:
  kind: python_call_eq
  category: async_protocol
  id_prefix: dc1771

  columns: [id, function, args, expected]
  rows:
    - ["dc1771001", Decimal.__dict__.__contains__, ["__aenter__"], false]
    - ["dc1771002", Decimal.__dict__.__contains__, ["__aexit__"],  false]
    - ["dc1771003", Decimal.__dict__.__contains__, ["__aiter__"],  false]
    - ["dc1771004", Decimal.__dict__.__contains__, ["__anext__"],  false]
    - ["dc1771005", Decimal.__dict__.__contains__, ["__await__"],  false]
    - ["dc1771006", Context.__dict__.__contains__,  ["__aenter__"], false]
    - ["dc1771007", Context.__dict__.__contains__,  ["__aexit__"],  false]
    - ["dc1771008", Context.__dict__.__contains__,  ["__aiter__"],  false]
    - ["dc1771009", Context.__dict__.__contains__,  ["__anext__"],  false]
    - ["dc1771010", Context.__dict__.__contains__,  ["__await__"],  false]

# ---------------------------------------------------------------------------
# Complementary: Context defines create_decimal and create_decimal_from_float
# ---------------------------------------------------------------------------

table decimal_extra1771.context_dict_methods:
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc1771

  columns: [id, function, args, expected]
  rows:
    - ["dc1771011", Context.__dict__.__contains__, ["create_decimal"],            true]
    - ["dc1771012", Context.__dict__.__contains__, ["create_decimal_from_float"], true]

# ---------------------------------------------------------------------------
# Complementary: Decimal does NOT implement __complex__ or __index__
# ---------------------------------------------------------------------------

table decimal_extra1771.absent_numeric_protocols:
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc1771

  columns: [id, function, args, expected]
  rows:
    - ["dc1771013", Decimal.__dict__.__contains__, ["__complex__"], false]
    - ["dc1771014", Decimal.__dict__.__contains__, ["__index__"],   false]

# ---------------------------------------------------------------------------
# Complementary: ROUND_* constant type checks
# ---------------------------------------------------------------------------

table decimal_extra1771.rounding_constant_types:
  kind: python_call_eq
  category: rounding_modes
  id_prefix: dc1771

  columns: [id, function, args, expected]
  rows:
    - ["dc1771015", ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true]
    - ["dc1771016", ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true]
    - ["dc1771017", ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true]
    - ["dc1771018", ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true]
    - ["dc1771019", ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Complementary: Decimal class identity
# ---------------------------------------------------------------------------

invariant decimal_extra1771.Decimal.class_name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra1771.Context.class_name:
  description: "decimal.Context.__name__ == 'Context'"
  category: class_metadata
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra1771.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true
