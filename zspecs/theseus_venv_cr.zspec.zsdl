spec: theseus_venv_cr
version: ">=3.0"
backend: python_cleanroom(theseus_venv_cr)
blocks: venv

docs: https://docs.python.org/3/library/venv.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/venv.html"
  not_derived_from:
    - "CPython source: Lib/venv/__init__.py"
  notes:
    - "Clean-room venv module. Do NOT import venv."

error_model: python_exceptions

invariant theseus_venv_cr.venv2_builder:
  description: "EnvBuilder class exists and is instantiatable"
  category: behavior
  kind: python_call_eq
  function: venv2_builder
  args: []
  expected: true

invariant theseus_venv_cr.venv2_context:
  description: "EnvBuilder has setup_scripts and post_setup methods"
  category: behavior
  kind: python_call_eq
  function: venv2_context
  args: []
  expected: true

invariant theseus_venv_cr.venv2_create:
  description: "create() creates a virtual environment in a temp dir"
  category: behavior
  kind: python_call_eq
  function: venv2_create
  args: []
  expected: true
