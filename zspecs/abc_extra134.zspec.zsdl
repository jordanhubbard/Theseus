# abc.ABCMeta.register.__module__           == 'abc'              (len=3)
# abc.ABCMeta.register.__code__.co_argcount == 2
# abc.ABCMeta.register.__code__.co_varnames len == 2
# ---------------------------------------------------------------------------

table abc_extra134.abcmeta_register_identity:
  description: "abc.ABCMeta.register qualname, module, and code attribute checks — register.__qualname__.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16); register.__module__.__eq__('abc')==True (len=3); co_argcount==2 ('cls','subclass' are both positional); co_varnames.__len__()==2 ('cls','subclass' — no additional locals); 'subclass' is in co_varnames; len=16 is one more than ABCMeta.__new__ qualname len (15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetareg134

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        abc.ABCMeta.register.__qualname__.__eq__,           ["ABCMeta.register"], true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [qn_len,       abc.ABCMeta.register.__qualname__.__len__,           [],                  16,   "ABCMeta.register.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [mod_eq,       abc.ABCMeta.register.__module__.__eq__,             ["abc"],              true, "ABCMeta.register.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [argc,         abc.ABCMeta.register.__code__.co_argcount.__eq__,   [2],                  true, "ABCMeta.register.__code__.co_argcount == 2 ('cls','subclass'); verified with Python 3.14.3"]
    - [varnames_len, abc.ABCMeta.register.__code__.co_varnames.__len__,   [],                  2,    "ABCMeta.register.__code__.co_varnames.__len__() == 2 ('cls','subclass'); verified with Python 3.14.3"]
    - [subclass_in,  abc.ABCMeta.register.__code__.co_varnames.__contains__, ["subclass"],      true, "ABCMeta.register.__code__.co_varnames contains 'subclass'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
