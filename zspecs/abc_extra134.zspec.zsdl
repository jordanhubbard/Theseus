#
# abc.ABCMeta._abc_registry_clear.__qualname__ == 'ABCMeta._abc_registry_clear' (len=27)
# abc.ABCMeta._abc_caches_clear.__qualname__   == 'ABCMeta._abc_caches_clear'   (len=25)
# Both have co_argcount == 1 and co_varnames len == 1
# ---------------------------------------------------------------------------

table abc_extra134.abcmeta_clear_methods:
  description: "abc.ABCMeta._abc_registry_clear and _abc_caches_clear qualname and code attribute checks — _abc_registry_clear.__qualname__.__eq__('ABCMeta._abc_registry_clear')==True (len=27: 'ABCMeta'=7+'.'=1+'_abc_registry_clear'=19=27); _abc_registry_clear.__code__.co_argcount==1 ('cls' only); _abc_registry_clear.__code__.co_varnames.__len__()==1 ('cls' only). _abc_caches_clear.__qualname__.__eq__('ABCMeta._abc_caches_clear')==True (len=25: 'ABCMeta'=7+'.'=1+'_abc_caches_clear'=17=25); _abc_caches_clear.__code__.co_argcount==1; _abc_caches_clear.__code__.co_varnames.__len__()==1; registry_clear qualname len (27) is 2 more than caches_clear qualname len (25); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetaclear134

  columns: [id, function, args, expected, description]
  rows:
    - [regclr_qn_eq,    abc.ABCMeta._abc_registry_clear.__qualname__.__eq__,           ["ABCMeta._abc_registry_clear"], true, "ABCMeta._abc_registry_clear.__qualname__ == 'ABCMeta._abc_registry_clear' (len=27); verified with Python 3.14.3"]
    - [regclr_qn_len,   abc.ABCMeta._abc_registry_clear.__qualname__.__len__,           [],                             27,   "ABCMeta._abc_registry_clear.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [regclr_mod_eq,   abc.ABCMeta._abc_registry_clear.__module__.__eq__,             ["abc"],                         true, "ABCMeta._abc_registry_clear.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [regclr_argc,     abc.ABCMeta._abc_registry_clear.__code__.co_argcount.__eq__,   [1],                             true, "ABCMeta._abc_registry_clear.__code__.co_argcount == 1 ('cls' only); verified with Python 3.14.3"]
    - [cacheclr_qn_eq,  abc.ABCMeta._abc_caches_clear.__qualname__.__eq__,             ["ABCMeta._abc_caches_clear"],   true, "ABCMeta._abc_caches_clear.__qualname__ == 'ABCMeta._abc_caches_clear' (len=25); verified with Python 3.14.3"]
    - [cacheclr_qn_len, abc.ABCMeta._abc_caches_clear.__qualname__.__len__,             [],                             25,   "ABCMeta._abc_caches_clear.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [cacheclr_mod_eq, abc.ABCMeta._abc_caches_clear.__module__.__eq__,               ["abc"],                         true, "ABCMeta._abc_caches_clear.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [cacheclr_argc,   abc.ABCMeta._abc_caches_clear.__code__.co_argcount.__eq__,     [1],                             true, "ABCMeta._abc_caches_clear.__code__.co_argcount == 1 ('cls' only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod code object filename and firstlineno — extra134
#
# abc.abstractmethod.__code__.co_filename       == '<frozen abc>' (len=12)
# abc.abstractmethod.__code__.co_firstlineno    == 7
# 'abc' in co_filename                          == True
# 'frozen' in co_filename                       == True
# ---------------------------------------------------------------------------

table abc_extra134.abstractmethod_code_filename:
  description: "abc.abstractmethod.__code__ co_filename and co_firstlineno attribute checks — co_filename.__eq__('<frozen abc>')==True (len=12: the abc module is frozen into the interpreter in Python 3.14.3, so its source path is '<frozen abc>' rather than a filesystem path); co_filename.__class__.__name__.__eq__('str')==True (it is a str object despite the unusual value); 'abc' is in co_filename (True); 'frozen' is in co_filename (True); co_firstlineno==7 (abstractmethod class definition starts at line 7 of the frozen module); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabstrmethcode134

  columns: [id, function, args, expected, description]
  rows:
    - [filename_eq,     abc.abstractmethod.__code__.co_filename.__eq__,                ["<frozen abc>"], true, "abstractmethod.__code__.co_filename == '<frozen abc>' (len=12); verified with Python 3.14.3"]
    - [filename_len,    abc.abstractmethod.__code__.co_filename.__len__,                [],              12,   "abstractmethod.__code__.co_filename.__len__() == 12; verified with Python 3.14.3"]
    - [filename_cls,    abc.abstractmethod.__code__.co_filename.__class__.__name__.__eq__, ["str"],       true, "abstractmethod.__code__.co_filename.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [abc_in_filename, abc.abstractmethod.__code__.co_filename.__contains__,          ["abc"],          true, "abstractmethod.__code__.co_filename contains 'abc'; verified with Python 3.14.3"]
    - [frozen_in_fn,    abc.abstractmethod.__code__.co_filename.__contains__,          ["frozen"],       true, "abstractmethod.__code__.co_filename contains 'frozen'; verified with Python 3.14.3"]
    - [firstlineno,     abc.abstractmethod.__code__.co_firstlineno.__eq__,             [7],              true, "abstractmethod.__code__.co_firstlineno == 7; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra134
# ---------------------------------------------------------------------------

invariant abc_extra134.abcmeta_new_qualname_len_15:
  description: "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — ABCMeta.__new__.__qualname__ is 'ABCMeta.__new__' (15 chars: 'ABCMeta'=7+'.'=1+'__new__'=7=15); ABCMeta.__new__.__code__.co_argcount==4 (mcls,name,bases,namespace — the most positional args of any ABCMeta method in this spec); co_varnames.__len__()==6; qualname len (15) is one less than ABCMeta.register qualname len (16); NEW in extra134: first standalone ABCMeta.__new__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant abc_extra134.abcmeta_new_co_varnames_len_6:
  description: "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6 — ABCMeta.__new__.__code__.co_varnames is ('mcls','name','bases','namespace','kwargs','cls') (len=6); co_argcount==4 (first 4 are positional); 'kwargs' collects extra keyword arguments; 'cls' is a local variable assigned during execution; this is the largest co_varnames of any ABCMeta method in this spec (compare: register has len=2, registry_clear and caches_clear each have len=1); NEW in extra134: first standalone ABCMeta.__new__ co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant abc_extra134.abc_registry_clear_qualname_len_27:
  description: "abc.ABCMeta._abc_registry_clear.__qualname__.__len__() == 27 — ABCMeta._abc_registry_clear.__qualname__ is 'ABCMeta._abc_registry_clear' (27 chars: 'ABCMeta'=7+'.'=1+'_abc_registry_clear'=19=27); this is the longest qualname of any ABCMeta method in this spec (compare: register=16, __new__=15, _abc_caches_clear=25, _dump_registry=22 in extra133); _abc_registry_clear.__code__.co_argcount==1; co_varnames.__len__()==1; NEW in extra134: first standalone _abc_registry_clear qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta._abc_registry_clear.__qualname__.__len__
  args: []
  expected: 27

invariant abc_extra134.abstractmethod_co_filename_len_12:
  description: "abc.abstractmethod.__code__.co_filename.__len__() == 12 — abstractmethod.__code__.co_filename is '<frozen abc>' (12 chars: '<'=1+'frozen abc'=10+'>'=1=12); the abc module is frozen into CPython in Python 3.14.3 so its source path is a synthetic frozen path rather than a filesystem path; 'abc' and 'frozen' are both substrings of co_filename; co_firstlineno==7; NEW in extra134: first standalone abstractmethod co_filename length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_filename.__len__
  args: []
  expected: 12

invariant abc_extra134.abstractmethod_co_firstlineno_7:
  description: "abc.abstractmethod.__code__.co_firstlineno == 7 — abstractmethod class definition starts at line 7 in the frozen abc module; co_filename=='<frozen abc>' (len=12); abstractmethod.__qualname__=='abstractmethod' (len=14); abstractmethod.__code__.co_argcount==1 ('funcobj'); co_varnames.__len__()==1; NEW in extra134: first standalone abstractmethod co_firstlineno invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_firstlineno
  args: []
  expected: 7
