spec: abc_extra134
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABCMeta.__new__, abc.ABCMeta.register, abc.ABCMeta._abc_registry_clear, abc.ABCMeta._abc_caches_clear — Python-level methods with __code__. Also abc.abstractmethod.__code__.co_filename and co_firstlineno properties. ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15); ABCMeta.__new__.__code__.co_argcount==4 ('mcls','name','bases','namespace'); ABCMeta.__new__.__code__.co_varnames.__len__()==6. ABCMeta.register.__qualname__=='ABCMeta.register' (len=16); co_argcount==2 ('cls','subclass'); co_varnames.__len__()==2. ABCMeta._abc_registry_clear.__qualname__=='ABCMeta._abc_registry_clear' (len=27); co_argcount==1 ('cls'); co_varnames.__len__()==1. ABCMeta._abc_caches_clear.__qualname__=='ABCMeta._abc_caches_clear' (len=25); co_argcount==1. abstractmethod.__code__.co_filename=='<frozen abc>' (len=12); co_firstlineno==7. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__new__ has co_argcount==4 (mcls,name,bases,namespace are positional) and one keyword-only-via-**kwargs argument. co_varnames includes 'kwargs' and 'cls' (local) in addition to the 4 positional params, giving len=6 total. ABCMeta.register and ABCMeta._abc_registry_clear are Python functions (have __code__). abstractmethod.__code__.co_filename is '<frozen abc>' because the abc module is frozen into the interpreter in Python 3.14.3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ qualname, module, code — extra134
#
# abc.ABCMeta.__new__.__qualname__         == 'ABCMeta.__new__' (len=15)
# abc.ABCMeta.__new__.__module__           == 'abc'             (len=3)
# abc.ABCMeta.__new__.__code__.co_argcount == 4
# abc.ABCMeta.__new__.__code__.co_varnames len == 6
# ---------------------------------------------------------------------------

table abc_extra134.abcmeta_new_identity:
  description: "abc.ABCMeta.__new__ qualname, module, and code attribute checks — __new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15); __new__.__module__.__eq__('abc')==True (len=3); co_argcount==4 ('mcls','name','bases','namespace' are all positional); co_varnames.__len__()==6 ('mcls','name','bases','namespace','kwargs','cls' — kwargs collects keyword args and cls is a local); 'mcls' and 'bases' are in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetanew134

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        abc.ABCMeta.__new__.__qualname__.__eq__,           ["ABCMeta.__new__"], true, "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [qn_len,       abc.ABCMeta.__new__.__qualname__.__len__,           [],                 15,   "ABCMeta.__new__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [mod_eq,       abc.ABCMeta.__new__.__module__.__eq__,             ["abc"],             true, "ABCMeta.__new__.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_len,      abc.ABCMeta.__new__.__module__.__len__,             [],                 3,    "ABCMeta.__new__.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [argc,         abc.ABCMeta.__new__.__code__.co_argcount.__eq__,   [4],                 true, "ABCMeta.__new__.__code__.co_argcount == 4 ('mcls','name','bases','namespace'); verified with Python 3.14.3"]
    - [varnames_len, abc.ABCMeta.__new__.__code__.co_varnames.__len__,   [],                 6,    "ABCMeta.__new__.__code__.co_varnames.__len__() == 6 ('mcls','name','bases','namespace','kwargs','cls'); verified with Python 3.14.3"]
    - [mcls_in,      abc.ABCMeta.__new__.__code__.co_varnames.__contains__, ["mcls"],         true, "ABCMeta.__new__.__code__.co_varnames contains 'mcls'; verified with Python 3.14.3"]
    - [bases_in,     abc.ABCMeta.__new__.__code__.co_varnames.__contains__, ["bases"],        true, "ABCMeta.__new__.__code__.co_varnames contains 'bases'; verified with Python 3.14.3"]

