    - ["as3331005", operator.contains, [asyncio.Semaphore.__dict__,        "__iand__"], false]
    - ["as3331006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__iand__"], false]
    - ["as3331007", operator.contains, [asyncio.Condition.__dict__,        "__iand__"], false]
    - ["as3331008", operator.contains, [asyncio.Queue.__dict__,            "__iand__"], false]
    - ["as3331009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__iand__"], false]
    - ["as3331010", operator.contains, [asyncio.LifoQueue.__dict__,        "__iand__"], false]

# ---------------------------------------------------------------------------
# __ior__ dict-presence — operator.contains(Cls.__dict__, '__ior__')
#
# All 10 asyncio classes return false for __ior__.
# In-place bitwise OR (__ior__, |=) is the augmented assignment variant
#   of __or__. asyncio types define no __or__ (wave 661), so __ior__ is
#   equally absent.
# Note: Python 3.9 introduced __ior__ on the built-in dict type for
#   in-place dict merging (d |= other), but asyncio types are coroutine-based
#   concurrency primitives — not dict-like types. This dict-specific __ior__
#   is entirely irrelevant to asyncio.
# asyncio synchronization primitives (Event, Lock, Condition, Semaphore,
#   BoundedSemaphore) have no bitwise data model that |= could operate on.
# asyncio.Task/Future: coroutine result handles; |= is not defined for
#   pending result objects.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; in-place bitwise OR
#   is entirely absent — items are managed through put()/get() coroutines only.
# ---------------------------------------------------------------------------

table as3331.ior:
  description: "asyncio types __ior__ dict-presence checks; wave 669"
