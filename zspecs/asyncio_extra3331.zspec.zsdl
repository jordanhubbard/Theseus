    - ["as3331020", operator.contains, [asyncio.LifoQueue.__dict__,        "__ior__"], false]

# ---------------------------------------------------------------------------
# __ixor__ dict-presence — operator.contains(Cls.__dict__, '__ixor__')
#
# All 10 asyncio classes return false for __ixor__.
# In-place bitwise XOR (__ixor__, ^=) is the augmented assignment variant
#   of __xor__. asyncio types define no __xor__ (wave 661), so __ixor__ is
#   equally absent.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   primitives with no bitwise or in-place XOR semantics of any kind.
# asyncio.Task/Future: coroutine result handles; ^= is not defined for
#   pending result objects.
# asyncio.Queue/PriorityQueue/LifoQueue: queue types manage items through
#   put()/get() coroutine calls only — no __ixor__ is defined.
# ---------------------------------------------------------------------------

