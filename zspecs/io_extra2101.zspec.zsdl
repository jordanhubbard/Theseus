spec: io_extra2101
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2101 (io_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "io.IOBase is an abstract base class; io.RawIOBase, io.BufferedIOBase, io.TextIOBase extend it."
    - "io.StringIO and io.BytesIO are concrete in-memory stream classes; io.FileIO is a raw file I/O class."
    - "None of the io stream classes define __class_getitem__ in their own __dict__ — generic alias subscripting is not supported."
    - "None define __init_subclass__ in their own __dict__ — the hook is inherited from object."
    - "None define __subclasshook__ in their own __dict__ — ABC virtual subclass checking is not customized here."
    - "None define __mro_entries__ in their own __dict__ — MRO resolution protocol is absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2101.class_getitem_protocol:
  description: "io stream classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2101

  columns: [id, function, args, expected]
  rows:
    - ["io2101001", "io.IOBase.__dict__.__contains__", ["__class_getitem__"], false]
    - ["io2101002", "io.RawIOBase.__dict__.__contains__", ["__class_getitem__"], false]
    - ["io2101003", "io.BufferedIOBase.__dict__.__contains__", ["__class_getitem__"], false]
    - ["io2101004", "io.TextIOBase.__dict__.__contains__", ["__class_getitem__"], false]
    - ["io2101005", "io.StringIO.__dict__.__contains__", ["__class_getitem__"], false]
    - ["io2101006", "io.BytesIO.__dict__.__contains__", ["__class_getitem__"], false]
    - ["io2101007", "io.FileIO.__dict__.__contains__", ["__class_getitem__"], false]

