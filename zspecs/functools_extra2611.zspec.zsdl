spec: functools_extra2611
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 (_extra2611): __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks for functools types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__init_subclass__ is a classmethod defined on object; regular classes do not shadow it in their own __dict__. All functools types show False for dict-presence."
    - "__subclasshook__ is specific to ABCs (via ABCMeta). No functools type is an ABC, so none define it in their own __dict__."
    - "__class_getitem__ is defined on functools.partial, functools.partialmethod, and functools.cached_property (True); functools.lru_cache and functools.singledispatchmethod do NOT define it (False)."
    - "Note: functools.lru_cache is actually a plain function in CPython (its __init_subclass__.__qualname__ resolves as 'function.__init_subclass__'), not a class, so it has no meaningful __class_getitem__ support."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __init_subclass__ dict-presence for functools types
#
# __init_subclass__ is inherited from object as a classmethod hook called
# when a class is subclassed. None of the functools types define their own
# override — all return False for __dict__.__contains__.
# ---------------------------------------------------------------------------

table functools_extra2611.init_subclass_absent:
  description: "functools types do not define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2611

  columns: [id, function, args, expected]
  rows:
    - ["ft2611001", "functools.partial.__dict__.__contains__",            ["__init_subclass__"], false]
    - ["ft2611002", "functools.partialmethod.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["ft2611003", "functools.cached_property.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["ft2611004", "functools.lru_cache.__dict__.__contains__",          ["__init_subclass__"], false]
    - ["ft2611005", "functools.singledispatchmethod.__dict__.__contains__", ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: __subclasshook__ dict-presence for functools types
#
# __subclasshook__ is a classmethod defined on abc.ABCMeta-based classes to
# customise isinstance/issubclass checks. None of the functools types use
# ABCMeta, so none define __subclasshook__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2611.subclasshook_absent:
  description: "functools types do not define __subclasshook__ in their own __dict__ — none are ABCs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2611

  columns: [id, function, args, expected]
  rows:
    - ["ft2611006", "functools.partial.__dict__.__contains__",            ["__subclasshook__"], false]
    - ["ft2611007", "functools.partialmethod.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["ft2611008", "functools.cached_property.__dict__.__contains__",    ["__subclasshook__"], false]
    - ["ft2611009", "functools.lru_cache.__dict__.__contains__",          ["__subclasshook__"], false]
    - ["ft2611010", "functools.singledispatchmethod.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 3: __class_getitem__ dict-presence for functools types
#
# __class_getitem__ enables generic alias syntax (e.g. partial[int]).
# functools.partial, partialmethod, and cached_property define it (True).
# functools.lru_cache is a plain function at runtime, not a class, and
# functools.singledispatchmethod does not define it — both return False.
# ---------------------------------------------------------------------------

table functools_extra2611.class_getitem_checks:
  description: "functools __class_getitem__ dict-presence — partial/partialmethod/cached_property True; lru_cache/singledispatchmethod False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2611

  columns: [id, function, args, expected]
  rows:
    - ["ft2611011", "functools.partial.__dict__.__contains__",            ["__class_getitem__"], true]
    - ["ft2611012", "functools.partialmethod.__dict__.__contains__",      ["__class_getitem__"], true]
    - ["ft2611013", "functools.cached_property.__dict__.__contains__",    ["__class_getitem__"], true]
    - ["ft2611014", "functools.lru_cache.__dict__.__contains__",          ["__class_getitem__"], false]
    - ["ft2611015", "functools.singledispatchmethod.__dict__.__contains__", ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 4: Inherited hook accessibility via __qualname__
#
# Although __init_subclass__ is absent from each type's own __dict__, it is
# still accessible via normal attribute lookup (inherited from the MRO).
# The __qualname__ of the bound classmethod reflects the type it appears on,
# not 'object', because C-implemented types synthesise per-class descriptors.
# This table verifies the inherited __init_subclass__ is reachable and carries
# the expected qualname string, confirming the hook is live despite not being
# stored in the class's own dict.
# ---------------------------------------------------------------------------

table functools_extra2611.object_inherited_hooks:
  description: "functools types inherit __init_subclass__ via MRO — qualname reflects per-class binding"
  kind: python_call_eq
  category: qualname_eq
  id_prefix: ft2611

  columns: [id, function, args, expected]
  rows:
    - ["ft2611016", "functools.partial.__init_subclass__.__qualname__.__eq__",            ["partial.__init_subclass__"],            true]
    - ["ft2611017", "functools.partialmethod.__init_subclass__.__qualname__.__eq__",      ["partialmethod.__init_subclass__"],      true]
    - ["ft2611018", "functools.cached_property.__init_subclass__.__qualname__.__eq__",    ["cached_property.__init_subclass__"],    true]
    - ["ft2611019", "functools.lru_cache.__dict__.__contains__",                          ["__init_subclass__"],                    false]
    - ["ft2611020", "functools.singledispatchmethod.__init_subclass__.__qualname__.__eq__", ["singledispatchmethod.__init_subclass__"], true]
