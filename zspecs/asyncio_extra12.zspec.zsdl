spec: asyncio_extra12
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Futures"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl through asyncio_extra11.zspec.zsdl."
    - "asyncio_extra11 covers: __bases__[0].__name__ for Lock/Semaphore/Event/BoundedSemaphore/Condition/Queue; Queue method __qualname__ (put_nowait/get_nowait/empty/full/qsize); Lock.acquire/__qualname__/Lock.release/__qualname__; Semaphore.acquire/__qualname__/Semaphore.release/__qualname__."
    - "asyncio_extra10 covers: __qualname__ for Semaphore/BoundedSemaphore/Lock/Event/Condition/Queue/QueueEmpty/QueueFull/CancelledError/TimeoutError; run/wait/shield/wait_for __name__ and __module__; QueueEmpty/QueueFull __mro__[2].__name__."
    - "asyncio_extra3 covers: Task/Future/__qualname__; Lock/__qualname__."
    - "asyncio_extra covers: Task/__name__/Future/__name__/Queue/__name__/Lock/__name__ and their __module__."
    - "NOT yet covered in any prior asyncio spec: method __qualname__ for Task.cancel/Task.result/Task.done/Task.cancelled."
    - "NOT yet covered: method __qualname__ for Future.cancel/Future.result/Future.done/Future.cancelled/Future.running/Future.exception."
    - "NOT yet covered: Task.__class__.__name__ == 'type' and Future.__class__.__name__ == 'type' — metaclass-level check."
    - "NOT yet covered: Lock.__class__.__name__ == 'type' and Queue.__class__.__name__ == 'type'."
    - "asyncio.Task.cancel.__qualname__ == 'Task.cancel' — method qualname includes class prefix."
    - "asyncio.Task.result.__qualname__ == 'Task.result' — method qualname includes class prefix."
    - "asyncio.Task.done.__qualname__ == 'Task.done' — method qualname includes class prefix."
    - "asyncio.Task.cancelled.__qualname__ == 'Task.cancelled' — method qualname includes class prefix."
    - "asyncio.Future.cancel.__qualname__ == 'Future.cancel' — method qualname includes class prefix."
    - "asyncio.Future.result.__qualname__ == 'Future.result' — method qualname includes class prefix."
    - "asyncio.Future.done.__qualname__ == 'Future.done' — method qualname includes class prefix."
    - "asyncio.Future.cancelled.__qualname__ == 'Future.cancelled' — method qualname includes class prefix."
    - "asyncio.Future.running.__qualname__ == 'Future.running' — method qualname includes class prefix."
    - "asyncio.Future.exception.__qualname__ == 'Future.exception' — method qualname includes class prefix."
    - "asyncio.Task.__class__.__name__ == 'type' — Task is a plain Python class (not a metaclass-customised type)."
    - "asyncio.Future.__class__.__name__ == 'type' — Future is a plain Python class."
    - "asyncio.Lock.__class__.__name__ == 'type' — Lock is a plain Python class."
    - "asyncio.Queue.__class__.__name__ == 'type' — Queue is a plain Python class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Task method __qualname__ checks
#
# asyncio_extra11 covers Lock/Semaphore method __qualname__.
# asyncio_extra3 covers Task class-level __qualname__ == 'Task'.
# No prior asyncio spec checks __qualname__ for Task instance methods
# (cancel, result, done, cancelled). These are defined in asyncio/tasks.py
# and their __qualname__ is 'Task.<method>'.
# ---------------------------------------------------------------------------

table asyncio_extra12.Task_method_qualnames:
  description: "asyncio.Task methods have __qualname__ == 'Task.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: tskqname

  columns: [id, function, args, expected]
  rows:
    - [cancel,    Task.cancel.__qualname__.__eq__,    ["Task.cancel"],    true]
    - [result,    Task.result.__qualname__.__eq__,    ["Task.result"],    true]
    - [done,      Task.done.__qualname__.__eq__,      ["Task.done"],      true]
    - [cancelled, Task.cancelled.__qualname__.__eq__, ["Task.cancelled"], true]

# ---------------------------------------------------------------------------
# Future method __qualname__ checks
#
# asyncio_extra3 covers Future class-level __qualname__ == 'Future'.
# No prior asyncio spec checks __qualname__ for Future instance methods.
# Future methods are defined in asyncio/futures.py.
# ---------------------------------------------------------------------------

table asyncio_extra12.Future_method_qualnames:
  description: "asyncio.Future methods have __qualname__ == 'Future.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: futqname

  columns: [id, function, args, expected]
  rows:
    - [cancel,    Future.cancel.__qualname__.__eq__,    ["Future.cancel"],    true]
    - [result,    Future.result.__qualname__.__eq__,    ["Future.result"],    true]
    - [done,      Future.done.__qualname__.__eq__,      ["Future.done"],      true]
    - [cancelled, Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true]
    - [running,   Future.running.__qualname__.__eq__,   ["Future.running"],   true]
    - [exception, Future.exception.__qualname__.__eq__, ["Future.exception"], true]

# ---------------------------------------------------------------------------
# Class-level __class__.__name__ — metaclass type checks
#
# asyncio_extra covers Task.__name__, Future.__name__, Lock.__name__,
# Queue.__name__. asyncio_extra3 covers their __qualname__. asyncio_extra
# covers their __module__. No prior spec verifies the metaclass (__class__)
# of these types. For plain Python classes, __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table asyncio_extra12.class_metaclass_names:
  description: "asyncio classes have __class__.__name__ == 'type' — plain Python classes"
  kind: python_call_eq
  category: class_types
  id_prefix: cmeta

  columns: [id, function, args, expected]
  rows:
    - [Task,   Task.__class__.__name__.__eq__,   ["type"], true]
    - [Future, Future.__class__.__name__.__eq__,  ["type"], true]
    - [Lock,   Lock.__class__.__name__.__eq__,   ["type"], true]
    - [Queue,  Queue.__class__.__name__.__eq__,  ["type"], true]
