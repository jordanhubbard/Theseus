spec: threading_extra248
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
    - "threading_extra247.zspec.zsdl — covers Thread.name and Thread.native_id property identity"
    - "threading_extra246.zspec.zsdl — covers Thread.daemon and Thread.ident property identity"
  notes:
    - "This spec covers threading.excepthook, threading.get_ident, threading.get_native_id function identity."
    - "threading.excepthook is a builtin_function_or_method from _thread; its __name__ is '_excepthook' (len=11)."
    - "threading.excepthook.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.get_ident.__name__ == 'get_ident' (len=9). Verified with Python 3.14.3."
    - "threading.get_ident.__module__ == '_thread' — implemented in C, not pure Python. Verified with Python 3.14.3."
    - "threading.get_native_id.__name__ == 'get_native_id' (len=13). Verified with Python 3.14.3."
    - "threading.get_native_id.__module__ == '_thread' — implemented in C. Verified with Python 3.14.3."
    - "All three functions are builtin_function_or_method. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.get_ident function identity contracts
#
# threading.get_ident.__name__ == 'get_ident' (len=9)
# threading.get_ident.__module__ == '_thread'
# threading.get_ident.__class__.__name__ == 'builtin_function_or_method'
# threading.get_ident.__name__.__contains__('ident') == True
# threading.get_ident.__name__.__contains__('get') == True
#
# get_ident is a C builtin in _thread (Modules/_threadmodule.c). New to extra248.
# ---------------------------------------------------------------------------

table threading_extra248.thr248fns_getident_identity:
  description: "threading.get_ident function identity: name, module, class, content; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: thr248fns

  columns: [id, function, args, expected, description]
  rows:
    - [getident_name_eq,
       get_ident.__name__.__eq__,
       ["get_ident"],
       true,
       "threading.get_ident.__name__.__eq__('get_ident') == True — get_ident is a C builtin in _thread module; __name__ is 'get_ident' (len=9); new to extra248"]
    - [getident_name_len_9,
       get_ident.__name__.__len__,
       [],
       9,
       "threading.get_ident.__name__.__len__() == 9 — 'get_ident' has exactly 9 characters; str.__len__() returns 9; new to extra248"]
    - [getident_module_thread,
       get_ident.__module__.__eq__,
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — get_ident is implemented in C in _thread; __module__ is '_thread' (not 'threading'); new to extra248"]
    - [getident_class_builtin,
       get_ident.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "threading.get_ident.__class__.__name__.__eq__('builtin_function_or_method') == True — get_ident is a C-level builtin; __class__.__name__ is 'builtin_function_or_method'; new to extra248"]
    - [getident_name_contains_ident,
       get_ident.__name__.__contains__,
       ["ident"],
       true,
       "threading.get_ident.__name__.__contains__('ident') == True — 'get_ident' contains 'ident'; new to extra248"]

# ---------------------------------------------------------------------------
# Table 2: threading.get_ident extra checks and get_native_id identity
#
# threading.get_ident.__name__.__contains__('get') == True
# threading.get_ident.__module__.__len__() == 7
# threading.get_native_id.__name__ == 'get_native_id' (len=13)
# threading.get_native_id.__module__ == '_thread'
# threading.get_native_id.__class__.__name__ == 'builtin_function_or_method'
#
# New to extra248.
# ---------------------------------------------------------------------------

table threading_extra248.thr248fns_getident_getnativeid:
  description: "threading.get_ident extra checks and get_native_id identity; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: thr248fnsb

  columns: [id, function, args, expected, description]
  rows:
    - [getident_name_contains_get,
       get_ident.__name__.__contains__,
       ["get"],
       true,
       "threading.get_ident.__name__.__contains__('get') == True — 'get_ident' starts with 'get'; new to extra248"]
    - [getident_module_len_7,
       get_ident.__module__.__len__,
       [],
       7,
       "threading.get_ident.__module__.__len__() == 7 — '_thread' has exactly 7 characters; str.__len__() returns 7; new to extra248"]
    - [getnativeid_name_eq,
       get_native_id.__name__.__eq__,
       ["get_native_id"],
       true,
       "threading.get_native_id.__name__.__eq__('get_native_id') == True — get_native_id is a C builtin in _thread module; __name__ is 'get_native_id' (len=13); new to extra248"]
    - [getnativeid_module_thread,
       get_native_id.__module__.__eq__,
       ["_thread"],
       true,
       "threading.get_native_id.__module__.__eq__('_thread') == True — get_native_id is implemented in C in _thread; __module__ is '_thread'; new to extra248"]
    - [getnativeid_class_builtin,
       get_native_id.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "threading.get_native_id.__class__.__name__.__eq__('builtin_function_or_method') == True — get_native_id is a C-level builtin; __class__.__name__ is 'builtin_function_or_method'; new to extra248"]

# ---------------------------------------------------------------------------
# Table 3: threading.get_native_id extra checks
#
# threading.get_native_id.__name__.__len__() == 13
# threading.get_native_id.__name__.__contains__('native') == True
# threading.get_native_id.__name__.__contains__('get') == True
# threading.get_native_id.__name__.__contains__('id') == True
# threading.get_native_id.__module__.__len__() == 7
#
# get_native_id was added in Python 3.8. New to extra248.
# ---------------------------------------------------------------------------

table threading_extra248.thr248fns_getnativeid_extra:
  description: "threading.get_native_id extra checks: name length and content; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: thr248fnsc

  columns: [id, function, args, expected, description]
  rows:
    - [getnativeid_name_len_13,
       get_native_id.__name__.__len__,
       [],
       13,
       "threading.get_native_id.__name__.__len__() == 13 — 'get_native_id' has exactly 13 characters; str.__len__() returns 13; new to extra248"]
    - [getnativeid_name_contains_native,
       get_native_id.__name__.__contains__,
       ["native"],
       true,
       "threading.get_native_id.__name__.__contains__('native') == True — 'get_native_id' contains 'native'; new to extra248"]
    - [getnativeid_name_contains_get,
       get_native_id.__name__.__contains__,
       ["get"],
       true,
       "threading.get_native_id.__name__.__contains__('get') == True — 'get_native_id' starts with 'get'; new to extra248"]
    - [getnativeid_name_contains_id,
       get_native_id.__name__.__contains__,
       ["id"],
       true,
       "threading.get_native_id.__name__.__contains__('id') == True — 'get_native_id' ends with 'id'; new to extra248"]
    - [getnativeid_module_len_7,
       get_native_id.__module__.__len__,
       [],
       7,
       "threading.get_native_id.__module__.__len__() == 7 — '_thread' has exactly 7 characters; str.__len__() returns 7; new to extra248"]

# ---------------------------------------------------------------------------
# Table 4: threading.excepthook function identity contracts
#
# threading.excepthook.__name__ == '_excepthook' (len=11)
# threading.excepthook.__module__ == '_thread'
# threading.excepthook.__class__.__name__ == 'builtin_function_or_method'
# threading.excepthook.__name__.__contains__('hook') == True
# threading.excepthook.__name__.__contains__('except') == True
#
# threading.excepthook is backed by _thread._excepthook in C. New to extra248.
# ---------------------------------------------------------------------------

table threading_extra248.thr248fns_excepthook_identity:
  description: "threading.excepthook function identity: name, module, class, content; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: thr248fnsd

  columns: [id, function, args, expected, description]
  rows:
    - [excepthook_name_eq,
       excepthook.__name__.__eq__,
       ["_excepthook"],
       true,
       "threading.excepthook.__name__.__eq__('_excepthook') == True — threading.excepthook is backed by _thread._excepthook; __name__ is '_excepthook' (len=11); new to extra248"]
    - [excepthook_name_len_11,
       excepthook.__name__.__len__,
       [],
       11,
       "threading.excepthook.__name__.__len__() == 11 — '_excepthook' has exactly 11 characters; str.__len__() returns 11; new to extra248"]
    - [excepthook_module_thread,
       excepthook.__module__.__eq__,
       ["_thread"],
       true,
       "threading.excepthook.__module__.__eq__('_thread') == True — excepthook is implemented in C in _thread; __module__ is '_thread'; new to extra248"]
    - [excepthook_class_builtin,
       excepthook.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "threading.excepthook.__class__.__name__.__eq__('builtin_function_or_method') == True — excepthook is a C-level builtin; __class__.__name__ is 'builtin_function_or_method'; new to extra248"]
    - [excepthook_name_contains_hook,
       excepthook.__name__.__contains__,
       ["hook"],
       true,
       "threading.excepthook.__name__.__contains__('hook') == True — '_excepthook' contains 'hook'; new to extra248"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra248
# ---------------------------------------------------------------------------

invariant threading_extra248.getident_name_eq:
  description: "threading.get_ident.__name__ == 'get_ident' (len=9); new to extra248"
  kind: python_call_eq
  function: get_ident.__name__.__eq__
  args: ["get_ident"]
  expected: true

invariant threading_extra248.getident_module_thread:
  description: "threading.get_ident.__module__ == '_thread' — C builtin in _thread; new to extra248"
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra248.getident_class_builtin:
  description: "threading.get_ident.__class__.__name__ == 'builtin_function_or_method'; new to extra248"
  kind: python_call_eq
  function: get_ident.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra248.getident_name_len_9:
  description: "threading.get_ident.__name__.__len__() == 9 — 'get_ident' has 9 characters; new to extra248"
  kind: python_call_eq
  function: get_ident.__name__.__len__
  args: []
  expected: 9

invariant threading_extra248.getnativeid_name_eq:
  description: "threading.get_native_id.__name__ == 'get_native_id' (len=13); new to extra248"
  kind: python_call_eq
  function: get_native_id.__name__.__eq__
  args: ["get_native_id"]
  expected: true

invariant threading_extra248.getnativeid_module_thread:
  description: "threading.get_native_id.__module__ == '_thread' — C builtin in _thread; new to extra248"
  kind: python_call_eq
  function: get_native_id.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra248.getnativeid_name_len_13:
  description: "threading.get_native_id.__name__.__len__() == 13 — 'get_native_id' has 13 characters; new to extra248"
  kind: python_call_eq
  function: get_native_id.__name__.__len__
  args: []
  expected: 13

invariant threading_extra248.excepthook_name_eq:
  description: "threading.excepthook.__name__ == '_excepthook' (len=11); new to extra248"
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra248.excepthook_module_thread:
  description: "threading.excepthook.__module__ == '_thread' — C builtin in _thread; new to extra248"
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra248.excepthook_name_len_11:
  description: "threading.excepthook.__name__.__len__() == 11 — '_excepthook' has 11 characters; new to extra248"
  kind: python_call_eq
  function: excepthook.__name__.__len__
  args: []
  expected: 11

invariant threading_extra248.excepthook_name_contains_hook:
  description: "threading.excepthook.__name__.__contains__('hook') == True; new to extra248"
  kind: python_call_eq
  function: excepthook.__name__.__contains__
  args: ["hook"]
  expected: true

invariant threading_extra248.getnativeid_name_contains_native:
  description: "threading.get_native_id.__name__.__contains__('native') == True; new to extra248"
  kind: python_call_eq
  function: get_native_id.__name__.__contains__
  args: ["native"]
  expected: true
