spec: asyncio_extra200
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers __doc__.__class__.__name__ identity for eight asyncio classes: Task, Future, Queue, Lock, Event, Semaphore, Condition, Handle."
    - "asyncio.Task.__doc__.__class__.__name__ == 'str' (len=3) — Task has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "asyncio.Future.__doc__.__class__.__name__ == 'str' (len=3) — Future has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "asyncio.Queue.__doc__.__class__.__name__ == 'str' (len=3) — Queue has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "asyncio.Lock.__doc__.__class__.__name__ == 'str' (len=3) — Lock has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "asyncio.Event.__doc__.__class__.__name__ == 'str' (len=3) — Event has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "asyncio.Semaphore.__doc__.__class__.__name__ == 'str' (len=3) — Semaphore has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "asyncio.Condition.__doc__.__class__.__name__ == 'str' (len=3) — Condition has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "asyncio.Handle.__doc__.__class__.__name__ == 'str' (len=3) — Handle has a docstring; __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "All eight asyncio classes have non-None __doc__ strings; __doc__.__class__.__name__ == 'str' for all of them."
    - "The string 'str' has length 3; __doc__.__class__.__name__.__len__() == 3 for all eight classes."
    - "Prior asyncio specs cover __name__, __qualname__, __module__, __bases__, and name length checks. No prior spec covers __doc__.__class__.__name__ identity."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio Task and Future __doc__.__class__.__name__ identity
#
# asyncio.Task.__doc__.__class__.__name__ == 'str' (len=3)
# asyncio.Future.__doc__.__class__.__name__ == 'str' (len=3)
#
# Task and Future are the two primary awaitable types in asyncio. Both classes
# have non-None docstrings; the docstring type is the built-in str class.
# No prior asyncio spec covers the __doc__.__class__.__name__ attribute path.
# New to asyncio_extra200.
# ---------------------------------------------------------------------------

table asyncio_extra200.task_future_doc_class_names:
  description: "asyncio.Task and asyncio.Future __doc__.__class__.__name__ == 'str'; both classes have str docstrings; new to asyncio_extra200"
  kind: python_call_eq
  category: doc_identity
  id_prefix: asynciodocs200

  columns: [id, function, args, expected, description]
  rows:
    - [task_doc_class_name_eq_str,
       "Task.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "asyncio.Task.__doc__.__class__.__name__.__eq__('str') == True — Task has a non-None docstring; __doc__.__class__ is str; str.__eq__('str') returns True; new to asyncio_extra200"]
    - [task_doc_class_name_len_eq_3,
       "Task.__doc__.__class__.__name__.__len__",
       [],
       3,
       "asyncio.Task.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; new to asyncio_extra200"]
    - [future_doc_class_name_eq_str,
       "Future.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "asyncio.Future.__doc__.__class__.__name__.__eq__('str') == True — Future has a non-None docstring; __doc__.__class__ is str; str.__eq__('str') returns True; new to asyncio_extra200"]
    - [future_doc_class_name_len_eq_3,
       "Future.__doc__.__class__.__name__.__len__",
       [],
       3,
       "asyncio.Future.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; new to asyncio_extra200"]

