spec: itertools_extra418
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.__name__ == 'itertools' — the module's __name__ attribute is the string 'itertools'. Verified with Python 3.14.0."
    - "itertools.__package__ == '' — itertools is a top-level C extension module; its __package__ is the empty string. Verified with Python 3.14.0."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec object is an instance of importlib.machinery.ModuleSpec. Verified with Python 3.14.0."
    - "itertools.__loader__.__class__.__name__ == 'type' — the loader for the itertools C extension is a type object (the BuiltinImporter class itself acts as a type). Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module identity attributes
#
# itertools is a built-in C extension module. Its __name__, __package__,
# __spec__.__class__.__name__, and __loader__.__class__.__name__ reflect
# its identity as a top-level C module. All values verified with Python
# 3.14.0 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table itertools_extra418.module_identity:
  description: "itertools module identity attribute values — __name__, __package__, __spec__ class, __loader__ class; new to extra418"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmi418

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the module's __name__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra418"]
    - [module_package_eq,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level C extension module with empty __package__; str.__eq__('') returns True; new to extra418"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is an importlib.machinery.ModuleSpec instance; str.__eq__('ModuleSpec') returns True; new to extra418"]
    - [loader_class_name_eq,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — the loader for itertools C extension has __class__.__name__ == 'type'; str.__eq__('type') returns True; new to extra418"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra418
# ---------------------------------------------------------------------------

invariant itertools_extra418.module_name:
  description: "itertools.__name__ == 'itertools' — module's __name__ attribute is 'itertools'; new to extra418"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra418.module_package:
  description: "itertools.__package__ == '' — top-level C extension module has empty __package__; new to extra418"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra418.spec_class_name:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec instance; new to extra418"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra418.loader_class_name:
  description: "itertools.__loader__.__class__.__name__ == 'type' — the loader for the itertools C extension has __class__.__name__ == 'type'; new to extra418"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true
