spec: re_extra106
version: ">=3.9"
backend: python_module(re)
extends: re_extra105

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra105.zspec.zsdl."
    - "This spec covers: re.Pattern, re.Match, re.PatternError, re.RegexFlag __module__ and __name__ values, plus re module function __module__ values."
    - "re.Pattern.__module__ = 're' — Pattern is a C extension type exposed via the re module."
    - "re.Pattern.__name__ = 'Pattern' — bare type name without module prefix."
    - "re.Match.__module__ = 're' — Match is a C extension type exposed via the re module."
    - "re.Match.__name__ = 'Match' — bare type name without module prefix."
    - "re.PatternError.__module__ = 're' — PatternError (formerly error) is defined in the re module."
    - "re.PatternError.__name__ = 'PatternError' — canonical name as of Python 3.14."
    - "re.RegexFlag.__module__ = 're' — RegexFlag is an IntFlag enum defined in re."
    - "re.RegexFlag.__name__ = 'RegexFlag' — bare enum type name."
    - "re.compile.__module__ = 're', re.match.__module__ = 're', re.search.__module__ = 're'."
    - "re.sub.__module__ = 're', re.findall.__module__ = 're', re.split.__module__ = 're'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __module__ and __name__ values
# Both are C extension types exposed through the re module namespace.
# __module__ == 're' for both (despite being implemented in _sre).
# __name__ == 'Pattern' and 'Match' respectively (bare names, no prefix).
# ---------------------------------------------------------------------------

table re_extra106.Pattern_Match_module_name:
  description: "re.Pattern and re.Match __module__ and __name__ values: Pattern.__module__='re', Pattern.__name__='Pattern', Match.__module__='re', Match.__name__='Match'"
  kind: python_call_eq
  category: class_names
  id_prefix: remodname106a

  columns: [id, function, args, expected, description]
  rows:
    - [pat_mod_eq,      Pattern.__module__.__eq__,   ["re"],       true,  "re.Pattern.__module__ == 're'"]
    - [pat_mod_not_sre, Pattern.__module__.__eq__,   ["_sre"],     false, "re.Pattern.__module__ != '_sre' (exposed as 're' even though backed by _sre C extension)"]
    - [pat_name_eq,     Pattern.__name__.__eq__,     ["Pattern"],  true,  "re.Pattern.__name__ == 'Pattern'"]
    - [pat_name_not_qn, Pattern.__name__.__eq__,     ["re.Pattern"],false,"re.Pattern.__name__ != 're.Pattern' (no module prefix in __name__)"]
    - [match_mod_eq,    Match.__module__.__eq__,     ["re"],       true,  "re.Match.__module__ == 're'"]
    - [match_name_eq,   Match.__name__.__eq__,       ["Match"],    true,  "re.Match.__name__ == 'Match'"]
    - [match_name_not,  Match.__name__.__eq__,       ["re.Match"], false, "re.Match.__name__ != 're.Match' (bare name only)"]
    - [pat_mod_len,     Pattern.__module__.__len__,  [],           2,     "re.Pattern.__module__.__len__() == 2 ('re' has 2 characters)"]

# ---------------------------------------------------------------------------
# re.PatternError and re.RegexFlag __module__ and __name__ values
# PatternError is the renamed re.error exception (Python 3.14+).
# RegexFlag is an IntFlag enum for regex compilation flags.
# Both have __module__ == 're' and __name__ equal to their bare class name.
# ---------------------------------------------------------------------------

table re_extra106.PatternError_RegexFlag_module_name:
  description: "re.PatternError and re.RegexFlag __module__ and __name__ values: PatternError.__module__='re', PatternError.__name__='PatternError', RegexFlag.__module__='re', RegexFlag.__name__='RegexFlag'"
  kind: python_call_eq
  category: class_names
  id_prefix: remodname106b

  columns: [id, function, args, expected, description]
  rows:
    - [pe_mod_eq,     PatternError.__module__.__eq__,  ["re"],          true,  "re.PatternError.__module__ == 're'"]
    - [pe_name_eq,    PatternError.__name__.__eq__,    ["PatternError"],true,  "re.PatternError.__name__ == 'PatternError'"]
    - [pe_name_not_e, PatternError.__name__.__eq__,    ["error"],       false, "re.PatternError.__name__ != 'error' (renamed to PatternError in Python 3.14)"]
    - [rf_mod_eq,     RegexFlag.__module__.__eq__,     ["re"],          true,  "re.RegexFlag.__module__ == 're'"]
    - [rf_name_eq,    RegexFlag.__name__.__eq__,       ["RegexFlag"],   true,  "re.RegexFlag.__name__ == 'RegexFlag'"]
    - [rf_name_not,   RegexFlag.__name__.__eq__,       ["re.RegexFlag"],false, "re.RegexFlag.__name__ != 're.RegexFlag' (bare name only)"]
    - [pe_mod_len,    PatternError.__module__.__len__, [],              2,     "re.PatternError.__module__.__len__() == 2 ('re' has 2 characters)"]
    - [rf_mod_len,    RegexFlag.__module__.__len__,    [],              2,     "re.RegexFlag.__module__.__len__() == 2 ('re' has 2 characters)"]

# ---------------------------------------------------------------------------
# re module function __module__ values
# re.compile, re.match, re.search, re.sub, re.findall, re.split
# are all Python-level functions with __module__ == 're'.
# ---------------------------------------------------------------------------

table re_extra106.function_module_values:
  description: "re module functions __module__ == 're': compile, match, search, sub, findall, split"
  kind: python_call_eq
  category: class_names
  id_prefix: remodname106c

  columns: [id, function, args, expected, description]
  rows:
    - [compile_mod_eq,  compile.__module__.__eq__,  ["re"], true,  "re.compile.__module__ == 're'"]
    - [match_mod_eq,    match.__module__.__eq__,    ["re"], true,  "re.match.__module__ == 're'"]
    - [search_mod_eq,   search.__module__.__eq__,   ["re"], true,  "re.search.__module__ == 're'"]
    - [sub_mod_eq,      sub.__module__.__eq__,      ["re"], true,  "re.sub.__module__ == 're'"]
    - [findall_mod_eq,  findall.__module__.__eq__,  ["re"], true,  "re.findall.__module__ == 're'"]
    - [split_mod_eq,    split.__module__.__eq__,    ["re"], true,  "re.split.__module__ == 're'"]
    - [compile_not_sre, compile.__module__.__eq__,  ["sre_compile"], false, "re.compile.__module__ != 'sre_compile'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra106.Pattern.module_is_re:
  description: "re.Pattern.__module__ == 're' (Pattern is the compiled regex type; despite being implemented in the _sre C extension, its __module__ attribute reports 're')"
  category: class_names
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra106.Pattern.name_is_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' (the bare type name with no module prefix; re.Pattern.__name__ is 'Pattern', not 're.Pattern')"
  category: class_names
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra106.PatternError.name_is_PatternError:
  description: "re.PatternError.__name__ == 'PatternError' (the canonical name introduced in Python 3.14; re.error is a backward-compatible alias but __name__ reflects the new canonical name)"
  category: class_names
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra106.RegexFlag.module_is_re:
  description: "re.RegexFlag.__module__ == 're' (RegexFlag is an IntFlag enum defined in the re module to represent compilation flags like re.IGNORECASE, re.MULTILINE, etc.)"
  category: class_names
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra106.Pattern.module_len_2:
  description: "re.Pattern.__module__.__len__() == 2 ('re' has exactly 2 characters; the re module has the shortest name of any stdlib module used here)"
  category: class_names
  kind: python_call_eq
  function: Pattern.__module__.__len__
  args: []
  expected: 2

