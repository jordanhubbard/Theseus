    - [th1366ec003, threading.Event.__itemsize__.__class__.__name__.__eq__,      ["int"],  true]
    - [th1366ec004, threading.Semaphore.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [th1366ec005, threading.Semaphore.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [th1366ec006, threading.Condition.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [th1366ec007, threading.Condition.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [th1366ec008, threading.Condition.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]

table threading_extra1366.barrier_flags_basicsize_itemsize_cross_check:
  description: "threading.Barrier __flags__, __basicsize__, __itemsize__ type checks plus cross-check of all six classes confirming __flags__ is int"
