spec: threading_extra1366
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for threading classes."
    - "threading.Thread, Event, Semaphore, Barrier, Condition are pure Python classes; __flags__, __basicsize__, __itemsize__ are all ints."
    - "threading.Lock is actually _thread.lock, a C extension type; __flags__, __basicsize__, __itemsize__ are all ints."
    - "All type objects in CPython expose __flags__, __basicsize__, and __itemsize__ as C-level int attributes regardless of whether defined in C or Python."
    - "Exact integer values for __flags__ and __basicsize__ differ between C types and Python types, and vary by platform; only the type (int) is checked."
    - "__itemsize__ is 0 for all threading classes (no variable-length C struct tail)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra1366.thread_lock_flags_basicsize_itemsize:
  description: "threading.Thread and Lock __flags__, __basicsize__, __itemsize__ type checks; Thread is pure Python, Lock is a C type (_thread.lock), both carry int attributes"
  kind: python_call_eq
  category: flags_basicsize_itemsize_checks
  id_prefix: th1366tl
  columns: [id, function, args, expected]
  rows:
    - [th1366tl001, threading.Thread.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [th1366tl002, threading.Thread.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [th1366tl003, threading.Thread.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]
    - [th1366tl004, threading.Lock.__flags__.__class__.__name__.__eq__,       ["int"],  true]
    - [th1366tl005, threading.Lock.__basicsize__.__class__.__name__.__eq__,   ["int"],  true]
    - [th1366tl006, threading.Lock.__itemsize__.__class__.__name__.__eq__,    ["int"],  true]

