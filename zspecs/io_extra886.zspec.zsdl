spec: io_extra886
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from:
    - io module CPython source
    - Python documentation for io.FileIO and io.TextIOWrapper
  not_derived_from:
    - any third-party IO library
  notes:
    - Covers FileIO method qualnames and io module class doc types
    - TextIOWrapper module and qualname assertions included
  created_at: "2026-04-12"

table io_extra886.fileio_method_qualnames:
  description: io.FileIO method __qualname__ assertions
  kind: python_call_eq
  category: qualname
  id_prefix: io886fx
  columns: [id, function, args, expected]
  rows:
    - [io886fx001, io.FileIO.__init__.__qualname__.__eq__, ["FileIO.__init__"], true]
    - [io886fx002, io.FileIO.read.__qualname__.__eq__, ["FileIO.read"], true]
    - [io886fx003, io.FileIO.readall.__qualname__.__eq__, ["FileIO.readall"], true]
    - [io886fx004, io.FileIO.readinto.__qualname__.__eq__, ["FileIO.readinto"], true]
    - [io886fx005, io.FileIO.write.__qualname__.__eq__, ["FileIO.write"], true]
    - [io886fx006, io.FileIO.seek.__qualname__.__eq__, ["FileIO.seek"], true]
    - [io886fx007, io.FileIO.tell.__qualname__.__eq__, ["FileIO.tell"], true]
    - [io886fx008, io.FileIO.truncate.__qualname__.__eq__, ["FileIO.truncate"], true]

table io_extra886.class_meta:
  description: io module class __qualname__ and __module__ assertions
  kind: python_call_eq
  category: qualname
  id_prefix: io886cm
  columns: [id, function, args, expected]
  rows:
    - [io886cm001, io.TextIOWrapper.__qualname__.__eq__, ["TextIOWrapper"], true]
    - [io886cm002, io.TextIOWrapper.__module__.__eq__, ["io"], true]
    - [io886cm003, io.FileIO.__qualname__.__eq__, ["FileIO"], true]
    - [io886cm004, io.FileIO.__module__.__eq__, ["io"], true]
