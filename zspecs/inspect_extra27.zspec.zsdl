spec: inspect_extra27
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra26.zspec.zsdl."
    - "Prior specs covered: inspect.__name__/__package__, ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__name__ table, getmembers/__name__, signature/__name__, Parameter.__name__/__module__/__qualname__, Signature.__name__/__module__/__qualname__, Parameter.POSITIONAL_OR_KEYWORD/__class__.__name__, BoundArguments.__name__/__module__, stack/__name__, getfile/__name__, getsourcefile/__name__, getmodule/__name__, classify_class_attrs/__name__, getdoc/__name__, getcomments/__name__, cleandoc/__name__, FullArgSpec.__name__, ArgInfo.__name__, BlockFinder.__name__, Attribute/__qualname__/__module__, ArgInfo/_fields length, long predicate qualname lengths."
    - "This spec covers: inspect.Parameter.__bases__[0].__name__, inspect.Signature.__bases__[0].__name__, inspect.BoundArguments.__bases__[0].__name__, inspect.Parameter.POSITIONAL_ONLY/__class__.__name__, inspect.Parameter.VAR_POSITIONAL/__class__.__name__, inspect.Parameter.KEYWORD_ONLY/__class__.__name__, inspect.Parameter.VAR_KEYWORD/__class__.__name__, inspect.Parameter.empty/__class__.__name__, inspect.Signature.empty/__class__.__name__."
    - "Parameter, Signature, and BoundArguments all inherit directly from object; their __bases__[0].__name__ is 'object'."
    - "All four Parameter kind sentinels (POSITIONAL_ONLY, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD) have __class__.__name__ == '_ParameterKind' — an internal enum."
    - "Parameter.empty and Signature.empty are the same sentinel class (_empty); their __class__.__name__ is 'type' because the sentinel is a class object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter, Signature, BoundArguments __bases__[0].__name__ — table
#
# All three classes inherit directly from object; none has an explicit base
# class other than object. No prior inspect spec records these base class
# names together in a combined table in the extra27 namespace.
# ---------------------------------------------------------------------------

table inspect_extra27.class_base_names:
  description: "__bases__[0].__name__ for inspect.Parameter, Signature, BoundArguments"
  kind: python_call_eq
  category: class_attrs
  id_prefix: base_name

  columns: [id, function, args, expected]
  rows:
    - [Parameter,      "Parameter.__bases__[0].__name__.__eq__",      ["object"], true]
    - [Signature,      "Signature.__bases__[0].__name__.__eq__",      ["object"], true]
    - [BoundArguments, "BoundArguments.__bases__[0].__name__.__eq__", ["object"], true]

# ---------------------------------------------------------------------------
# inspect.Parameter kind sentinel __class__.__name__ == '_ParameterKind'
#
# POSITIONAL_ONLY, VAR_POSITIONAL, KEYWORD_ONLY, and VAR_KEYWORD are all
# members of the internal _ParameterKind enum. No prior inspect spec records
# any of these four sentinels' __class__.__name__ values in a combined table
# in the extra27 namespace.
# ---------------------------------------------------------------------------

table inspect_extra27.parameter_kind_class_names:
  description: "__class__.__name__ for inspect.Parameter kind sentinels — all are '_ParameterKind'"
  kind: python_call_eq
  category: class_attrs
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [POSITIONAL_ONLY, "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__", ["_ParameterKind"], true]
    - [VAR_POSITIONAL,  "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",  ["_ParameterKind"], true]
    - [KEYWORD_ONLY,    "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",    ["_ParameterKind"], true]
    - [VAR_KEYWORD,     "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",     ["_ParameterKind"], true]

# ---------------------------------------------------------------------------
# inspect.Parameter.empty and Signature.empty __class__.__name__ — combined table
#
# Parameter.empty and Signature.empty are the same sentinel class object
# (inspect._empty). Because the sentinel is itself a class, its __class__
# is 'type'. No prior inspect spec records these two empty-sentinel
# __class__.__name__ values in a combined table in the extra27 namespace.
# ---------------------------------------------------------------------------

table inspect_extra27.empty_sentinel_class_names:
  description: "__class__.__name__ for inspect.Parameter.empty and Signature.empty — both are 'type'"
  kind: python_call_eq
  category: sentinel_attrs
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [Parameter_empty,  "Parameter.empty.__class__.__name__.__eq__",  ["type"], true]
    - [Signature_empty,  "Signature.empty.__class__.__name__.__eq__",  ["type"], true]

# ---------------------------------------------------------------------------
# len('_ParameterKind') == 14 — standalone invariant
#
# The _ParameterKind enum class name has 14 characters. No prior inspect spec
# records the __len__() of the Parameter kind sentinel class name string in
# the extra27 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra27.ParameterKind.class_name_len:
  description: "len(inspect.Parameter.POSITIONAL_ONLY.__class__.__name__) == 14 — len('_ParameterKind') == 14"
  category: sentinel_attr_lengths
  kind: python_call_eq
  function: "Parameter.POSITIONAL_ONLY.__class__.__name__.__len__"
  args: []
  expected: 14
