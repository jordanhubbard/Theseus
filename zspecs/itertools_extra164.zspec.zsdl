invariant itertools_extra164.repeat_bases_0_object:
  description: "itertools.repeat.__bases__[0].__name__ == 'object' — repeat C extension type inherits directly from object; returns argument repeatedly; wave 293; new to extra164"
  kind: python_call_eq
