spec: itertools_extra164
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.count.__bases__[0].__name__ 'object'; itertools.cycle.__bases__[0].__name__ 'object'; itertools.repeat.__bases__[0].__name__ 'object'; itertools.count.__name__ 'count'; itertools.cycle.__name__ 'cycle'; itertools.repeat.__name__ 'repeat'; itertools.count.__module__ 'itertools'; itertools.cycle.__module__ 'itertools'; itertools.repeat.__module__ 'itertools' (Wave 293)."
    - "itertools.count.__bases__[0].__name__ == 'object' — itertools.count is a C extension type in itertoolsmodule.c that produces an infinite arithmetic sequence starting at start with step step; it inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "itertools.cycle.__bases__[0].__name__ == 'object' — itertools.cycle is a C extension type that cycles through an iterable indefinitely by saving a copy of its elements; it inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "itertools.repeat.__bases__[0].__name__ == 'object' — itertools.repeat is a C extension type that returns its argument repeatedly (optionally a fixed number of times); it inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "itertools.count.__name__ == 'count' — the C extension type __name__ for count is 'count'. Verified with Python 3.14.3."
    - "itertools.cycle.__name__ == 'cycle' — the C extension type __name__ for cycle is 'cycle'. Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat' — the C extension type __name__ for repeat is 'repeat'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.count and itertools.cycle class identity and __bases__
#
# Wave 293 theme: itertools.count and itertools.cycle C extension type
# identity — __bases__, __name__, and __module__.
#
# itertools.count.__bases__[0].__name__ == 'object'
# itertools.count.__name__ == 'count'
# itertools.count.__module__ == 'itertools'
# itertools.cycle.__bases__[0].__name__ == 'object'
# itertools.cycle.__name__ == 'cycle'
#
# itertools.count(start=0, step=1) produces an infinite arithmetic sequence:
# start, start+step, start+2*step, ... It is a C extension type defined in
# itertoolsmodule.c that inherits directly from object.
# itertools.cycle(iterable) returns elements from the iterable and then
# repeats indefinitely by saving a copy; it is also a C extension type
# inheriting from object. New to extra164.
# ---------------------------------------------------------------------------

table itertools_extra164.count_and_cycle_identity:
  description: "itertools: count.__bases__[0].__name__ 'object', count.__name__ 'count', count.__module__ 'itertools', cycle.__bases__[0].__name__ 'object', cycle.__name__ 'cycle'; wave 293; new to extra164"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscci164

  columns: [id, function, args, expected, description]
  rows:
    - ["count_bases_0_name_eq_object",
       "count.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__bases__[0].__name__.__eq__('object') == True — count is a C extension type in itertoolsmodule.c that produces an infinite arithmetic sequence start, start+step, start+2*step, ...; it inherits directly from object; its __bases__ tuple has a single element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra164"]
    - [count_name_eq_count,
       "count.__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C extension type in itertoolsmodule.c; its type __name__ attribute is 'count'; str.__eq__('count') returns True; new to extra164"]
    - [count_module_eq_itertools,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra164"]
    - ["cycle_bases_0_name_eq_object",
       "cycle.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__.__eq__('object') == True — cycle is a C extension type in itertoolsmodule.c that cycles through an iterable indefinitely by saving a copy of its elements; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra164"]
    - [cycle_name_eq_cycle,
       "cycle.__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — cycle is a C extension type in itertoolsmodule.c; its type __name__ attribute is 'cycle'; str.__eq__('cycle') returns True; new to extra164"]

# ---------------------------------------------------------------------------
# Table 2: itertools.repeat class identity and docstring types
#
# Wave 293 theme: itertools.repeat C extension type identity — __bases__,
# __name__, __module__, and __doc__ class for count, cycle, repeat.
#
# itertools.repeat.__bases__[0].__name__ == 'object'
# itertools.repeat.__name__ == 'repeat'
# itertools.repeat.__module__ == 'itertools'
# itertools.count.__doc__.__class__.__name__ == 'str'
# itertools.cycle.__module__ == 'itertools'
#
# itertools.repeat(object[, times]) returns object over and over again.
# If the optional times argument is supplied, it returns the object times
# times. When used with map() it is equivalent to enumerate(). It is a
# C extension type in itertoolsmodule.c that inherits directly from object.
# New to extra164.
# ---------------------------------------------------------------------------

table itertools_extra164.repeat_identity_and_doc_types:
  description: "itertools: repeat.__bases__[0].__name__ 'object', repeat.__name__ 'repeat', repeat.__module__ 'itertools', count/__doc__.__class__.__name__ 'str', cycle.__module__ 'itertools'; wave 293; new to extra164"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsridt164

  columns: [id, function, args, expected, description]
  rows:
    - ["repeat_bases_0_name_eq_object",
       "repeat.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__name__.__eq__('object') == True — repeat is a C extension type in itertoolsmodule.c that returns its argument repeatedly optionally a fixed number of times; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra164"]
    - [repeat_name_eq_repeat,
       "repeat.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — repeat is a C extension type in itertoolsmodule.c; its type __name__ attribute is 'repeat'; str.__eq__('repeat') returns True; new to extra164"]
    - [repeat_module_eq_itertools,
       "repeat.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — repeat is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra164"]
    - [count_doc_class_eq_str,
       "count.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — count is a C extension type with a C-level docstring; its __doc__ attribute is a plain Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra164"]
    - [cycle_module_eq_itertools,
       "cycle.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — cycle is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra164"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra164
# ---------------------------------------------------------------------------

invariant itertools_extra164.count_bases_0_object:
  description: "itertools.count.__bases__[0].__name__ == 'object' — count C extension type inherits directly from object; infinite arithmetic sequence; wave 293; new to extra164"
  kind: python_call_eq
  function: "count.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra164.count_name_count:
  description: "itertools.count.__name__ == 'count' — C extension type name for the count infinite counter; wave 293; new to extra164"
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra164.count_module_itertools:
  description: "itertools.count.__module__ == 'itertools' — count is declared in itertoolsmodule.c; wave 293; new to extra164"
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true

