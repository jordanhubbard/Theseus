spec: operator_extra9
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra8.zspec.zsdl."
    - "operator_extra.__name__ covers: itemgetter.__name__=='itemgetter', attrgetter.__name__=='attrgetter', methodcaller.__name__=='methodcaller'."
    - "operator_extra2 covers: attrgetter.__name__, itemgetter.__name__ (as invariants)."
    - "operator_extra4 covers: add/__qualname__, mul/__qualname__ (as table rows)."
    - "operator_extra5 covers: attrgetter/__qualname__, itemgetter/__qualname__ (as table rows)."
    - "operator_extra8 covers: add/__module__, mul/__module__ (as standalone invariants)."
    - "New axis: __name__ for comparison and logical operators not yet covered — gt, le, ge, and_, or_."
    - "operator.gt.__name__ == 'gt' — C builtin; __name__ equals the function name."
    - "operator.le.__name__ == 'le' — C builtin; __name__ equals the function name."
    - "operator.ge.__name__ == 'ge' — C builtin; __name__ equals the function name."
    - "operator.and_.__name__ == 'and_' — trailing underscore to avoid shadowing builtin 'and'."
    - "operator.or_.__name__ == 'or_' — trailing underscore to avoid shadowing builtin 'or'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — comparison and logical operators
#
# operator.zspec covers __name__ for core arithmetic operators via table.
# operator_extra/extra2 cover attrgetter/itemgetter/__name__.
# The comparison operators gt/le/ge and logical operators and_/or_ have not
# yet been asserted via __name__.__eq__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant operator_extra9.gt.name:
  description: "operator.gt.__name__ == 'gt' — C builtin greater-than operator"
  category: function_names
  kind: python_call_eq
  function: gt.__name__.__eq__
  args: ["gt"]
  expected: true

invariant operator_extra9.le.name:
  description: "operator.le.__name__ == 'le' — C builtin less-than-or-equal operator"
  category: function_names
  kind: python_call_eq
  function: le.__name__.__eq__
  args: ["le"]
  expected: true

invariant operator_extra9.ge.name:
  description: "operator.ge.__name__ == 'ge' — C builtin greater-than-or-equal operator"
  category: function_names
  kind: python_call_eq
  function: ge.__name__.__eq__
  args: ["ge"]
  expected: true

invariant operator_extra9.and_.name:
  description: "operator.and_.__name__ == 'and_' — trailing underscore avoids shadowing 'and'"
  category: function_names
  kind: python_call_eq
  function: and_.__name__.__eq__
  args: ["and_"]
  expected: true

invariant operator_extra9.or_.name:
  description: "operator.or_.__name__ == 'or_' — trailing underscore avoids shadowing 'or'"
  category: function_names
  kind: python_call_eq
  function: or_.__name__.__eq__
  args: ["or_"]
  expected: true
