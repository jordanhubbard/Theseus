spec: itertools_extra14
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra13.zspec.zsdl."
    - "itertools_extra13 covers: __qualname__.__eq__ for chain, cycle, repeat, count, zip_longest, product, permutations, combinations, combinations_with_replacement, groupby, islice; qualname_len cross-checks."
    - "No prior itertools spec covers __module__ for chain, cycle, repeat, count, accumulate, zip_longest, product, permutations, combinations, groupby, or islice."
    - "All itertools C-level types have __module__ == 'itertools' (not the underlying C extension name)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools C-level type __module__ attributes
#
# No prior itertools spec covers __module__ for any of these types.
# All itertools iterator types are implemented in C but their __module__
# is set to 'itertools' (not '_itertools' or 'builtins').
# ---------------------------------------------------------------------------

invariant itertools_extra14.chain.module:
  description: "itertools.chain.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra14.cycle.module:
  description: "itertools.cycle.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: cycle.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra14.repeat.module:
  description: "itertools.repeat.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra14.count.module:
  description: "itertools.count.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra14.accumulate.module:
  description: "itertools.accumulate.__module__ == 'itertools' — C-level type, module attribute"
