# ---------------------------------------------------------------------------
# __module__ length cross-checks
#
# 'itertools' has 9 characters. These complement the equality checks with
# a second behavioral axis: string length rather than string content.
# ---------------------------------------------------------------------------

invariant itertools_extra14.chain.module_len:
  description: "itertools.chain.__module__.__len__() == 9 — len('itertools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: chain.__module__.__len__
  args: []
  expected: 9

invariant itertools_extra14.accumulate.module_len:
  description: "itertools.accumulate.__module__.__len__() == 9 — len('itertools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: accumulate.__module__.__len__
  args: []
  expected: 9
