spec: asyncio_extra205
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio Exceptions"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "asyncio.Task.__mro__ has len=3 (Task, Future, object); Task inherits from Future which in turn inherits from object."
    - "asyncio.Future.__mro__ has len=2 (Future, object); Future directly inherits from object."
    - "asyncio.CancelledError.__mro__ has len=3 (CancelledError, BaseException, object); CancelledError is a BaseException subclass (not Exception)."
    - "asyncio.Task.__mro__[0].__name__ == 'Task' (len=4); first MRO entry is always the class itself."
    - "asyncio.Task.__mro__[1].__name__ == 'Future' (len=6); Task's direct base is asyncio.Future."
    - "asyncio.Task.__mro__[2].__name__ == 'object' (len=6); object is the ultimate base of all Python classes."
    - "asyncio.Future.__mro__[0].__name__ == 'Future' (len=6); Future is a top-level class in asyncio."
    - "asyncio.CancelledError.__mro__[0].__name__ == 'CancelledError' (len=14); first MRO entry is the class itself."
    - "asyncio.CancelledError.__mro__[1].__name__ == 'BaseException' (len=13); CancelledError is a direct BaseException subclass."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

