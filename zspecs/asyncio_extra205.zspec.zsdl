invariant asyncio_extra205.task_mro_is_tuple:
  description: "asyncio.Task.__mro__.__class__.__name__.__eq__('tuple') == True — __mro__ is always a tuple in Python; Task.__mro__ is a tuple of 3 class objects [Task, Future, object]; tuple.__eq__ returns True when names match; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Task_mro
  kind: python_call_eq
  function: Task.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra205.task_mro_len_3:
  description: "asyncio.Task.__mro__.__len__() == 3 — MRO is (Task, Future, object); Task inherits from Future, which inherits from object, creating a 3-step chain; Task.__mro__.__len__(3) > Future.__mro__.__len__(2) by 1 — Task has one extra step due to its Future base; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Task_mro
  kind: python_call_eq
  function: Task.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra205.task_mro0_name_eq:
  description: "asyncio.Task.__mro__[0].__name__.__eq__('Task') returns True — Task.__mro__[0].__name__=='Task' (len=4: T(1)a(2)s(3)k(4)); the first entry in any Python MRO is always the class itself; Task.__mro__[0].__name__ (4: 'Task') < Task.__mro__[1].__name__ (6: 'Future') by 2 — the class name is shorter than its base name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Task_mro
  kind: python_call_eq
  function: "asyncio.Task.__mro__.__getitem__(0).__name__.__eq__"
  args: ["Task"]
  expected: true

invariant asyncio_extra205.task_mro1_name_eq:
  description: "asyncio.Task.__mro__[1].__name__.__eq__('Future') returns True — Task.__mro__[1].__name__=='Future' (len=6: F-u-t-u-r-e); the second entry in Task's MRO is its direct base asyncio.Future; Task.__mro__[1].__name__ (6: 'Future') == Future.__mro__[0].__name__ (6: 'Future') — both refer to the same class; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Task_mro
  kind: python_call_eq
  function: "asyncio.Task.__mro__.__getitem__(1).__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra205.future_mro_len_2:
  description: "asyncio.Future.__mro__.__len__() == 2 — MRO is (Future, object); Future directly inherits from object with no intermediate bases, giving the minimal 2-step MRO; Future.__mro__.__len__(2) < Task.__mro__.__len__(3) by 1 — Future's chain is shorter because it has no additional base; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Future_mro
  kind: python_call_eq
  function: Future.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra205.future_mro0_name_eq:
  description: "asyncio.Future.__mro__[0].__name__.__eq__('Future') returns True — Future.__mro__[0].__name__=='Future' (len=6); the first entry in Future's MRO is Future itself; Future.__mro__[0].__name__ (6: 'Future') == Task.__mro__[1].__name__ (6: 'Future') — the same class appears at index 0 of its own MRO and at index 1 of Task's MRO; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Future_mro
  kind: python_call_eq
  function: "asyncio.Future.__mro__.__getitem__(0).__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra205.cancelled_mro_len_3:
  description: "asyncio.CancelledError.__mro__.__len__() == 3 — MRO is (CancelledError, BaseException, object); CancelledError is a direct subclass of BaseException, not Exception; this is a deliberate design choice so that cancellation is not silently caught by 'except Exception'; CancelledError.__mro__.__len__(3) == Task.__mro__.__len__(3) — both have 3-entry MROs; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: CancelledError_mro
  kind: python_call_eq
  function: CancelledError.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra205.cancelled_mro1_name_eq:
  description: "asyncio.CancelledError.__mro__[1].__name__.__eq__('BaseException') returns True — CancelledError.__mro__[1].__name__=='BaseException' (len=13: B-a-s-e-E-x-c-e-p-t-i-o-n); this confirms that CancelledError extends BaseException, not Exception; CancelledError.__mro__[1].__name__ (13: 'BaseException') != 'Exception' (9) — these are different classes; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: CancelledError_mro
  kind: python_call_eq
  function: "asyncio.CancelledError.__mro__.__getitem__(1).__name__.__eq__"
  args: ["BaseException"]
  expected: true

