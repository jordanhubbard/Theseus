spec: socket_extra232
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.error is OSError — socket.error is an alias for the built-in OSError."
    - "socket.error.__name__ == 'OSError' — the name of the aliased class is 'OSError'."
    - "socket.error.__module__ == 'builtins' — OSError lives in the builtins module."
    - "socket.gaierror.__mro__[0].__name__ == 'gaierror' — MRO head is gaierror itself."
    - "socket.gaierror.__mro__[1].__name__ == 'OSError' — gaierror inherits from OSError."
    - "socket.gaierror.__mro__[2].__name__ == 'Exception' — OSError inherits from Exception."
    - "socket.gaierror.__mro__[3].__name__ == 'BaseException' — Exception inherits from BaseException."
    - "socket.gaierror.__mro__[4].__name__ == 'object' — root of gaierror MRO."
    - "len(socket.gaierror.__mro__) == 5 — gaierror MRO has 5 entries."
    - "socket.herror.__mro__[0].__name__ == 'herror' — MRO head is herror itself."
    - "socket.herror.__mro__[1].__name__ == 'OSError' — herror also inherits from OSError."
    - "len(socket.herror.__mro__) == 5 — herror MRO has 5 entries (same depth as gaierror)."
    - "socket.gaierror.__name__ == 'gaierror' — class name is 'gaierror' (8 characters)."
    - "socket.herror.__name__ == 'herror' — class name is 'herror' (6 characters)."
    - "socket.gaierror.__module__ == 'socket' — gaierror is defined in the socket module."
    - "socket.herror.__module__ == 'socket' — herror is defined in the socket module."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.error alias contracts
#
# socket.error.__name__   == 'OSError'
# socket.error.__module__ == 'builtins'
#
# socket.error is a direct alias for the built-in OSError class. It is not
# a subclass; it IS the same class object. Therefore socket.error.__name__
# is 'OSError' (not 'error'), and __module__ is 'builtins'.
# ---------------------------------------------------------------------------

table socket_extra232.socket_error_alias:
  description: "socket.error.__name__=='OSError'; socket.error.__module__=='builtins'; socket.error is OSError alias contracts; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: socket232

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,
       "error.__name__.__eq__",
       ["OSError"],
       true,
       "socket.error.__name__.__eq__('OSError') == True — socket.error is an alias for the built-in OSError; __name__ is 'OSError' not 'error'; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [error_module_eq,
       "error.__module__.__eq__",
       ["builtins"],
       true,
       "socket.error.__module__.__eq__('builtins') == True — socket.error is OSError which lives in the builtins module; __module__ is 'builtins'; new anchor in extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.gaierror class identity and MRO contracts
#
# socket.gaierror.__name__           == 'gaierror'
# socket.gaierror.__module__         == 'socket'
# socket.gaierror.__mro__[0].__name__ == 'gaierror'
# socket.gaierror.__mro__[1].__name__ == 'OSError'
# socket.gaierror.__mro__[2].__name__ == 'Exception'
# socket.gaierror.__mro__[3].__name__ == 'BaseException'
# socket.gaierror.__mro__[4].__name__ == 'object'
# len(socket.gaierror.__mro__)        == 5
#
# gaierror is raised by getaddrinfo() and getnameinfo() on address resolution
# failures. It inherits directly from OSError and is defined in Lib/socket.py.
# ---------------------------------------------------------------------------

table socket_extra232.gaierror_identity:
  description: "gaierror.__name__=='gaierror'; gaierror.__module__=='socket'; gaierror class identity contracts; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: socket232a

  columns: [id, function, args, expected, description]
  rows:
    - [gaierror_name_eq,
       "gaierror.__name__.__eq__",
       ["gaierror"],
       true,
       "socket.gaierror.__name__.__eq__('gaierror') == True — gaierror is raised on address resolution failures; __name__ is 'gaierror' (8 characters); new anchor in extra232 namespace; verified Python 3.14.3"]
    - [gaierror_module_eq,
       "gaierror.__module__.__eq__",
       ["socket"],
       true,
       "socket.gaierror.__module__.__eq__('socket') == True — gaierror is defined in Lib/socket.py; __module__ is 'socket' (6 characters); new anchor in extra232 namespace; verified Python 3.14.3"]
    - [gaierror_mro_len_5,
       "gaierror.__mro__.__len__",
       [],
       5,
       "socket.gaierror.__mro__.__len__() == 5 — MRO is [gaierror, OSError, Exception, BaseException, object]; 5 entries; new anchor in extra232 namespace; verified Python 3.14.3"]

invariant socket_extra232.gaierror_mro_0:
  description: "socket.gaierror.__mro__[0].__name__ == 'gaierror' — MRO head is gaierror itself"
  category: gaierror_mro
  kind: python_call_eq
  function: gaierror.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "gaierror"

invariant socket_extra232.gaierror_mro_1:
  description: "socket.gaierror.__mro__[1].__name__ == 'OSError' — gaierror inherits directly from OSError"
  category: gaierror_mro
  kind: python_call_eq
  function: gaierror.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

invariant socket_extra232.gaierror_mro_2:
  description: "socket.gaierror.__mro__[2].__name__ == 'Exception' — OSError inherits from Exception"
  category: gaierror_mro
  kind: python_call_eq
  function: gaierror.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# socket.herror class identity and MRO contracts
#
# socket.herror.__name__           == 'herror'
# socket.herror.__module__         == 'socket'
# socket.herror.__mro__[0].__name__ == 'herror'
# socket.herror.__mro__[1].__name__ == 'OSError'
# len(socket.herror.__mro__)        == 5
#
# herror is raised by address-related errors in legacy BSD socket functions.
# Like gaierror, it inherits directly from OSError and has a 5-entry MRO.
# ---------------------------------------------------------------------------

table socket_extra232.herror_identity:
  description: "herror.__name__=='herror'; herror.__module__=='socket'; herror class identity contracts; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: socket232b

  columns: [id, function, args, expected, description]
  rows:
    - [herror_name_eq,
       "herror.__name__.__eq__",
       ["herror"],
       true,
       "socket.herror.__name__.__eq__('herror') == True — herror is raised by legacy BSD socket address functions; __name__ is 'herror' (6 characters); new anchor in extra232 namespace; verified Python 3.14.3"]
    - [herror_module_eq,
       "herror.__module__.__eq__",
       ["socket"],
       true,
       "socket.herror.__module__.__eq__('socket') == True — herror is defined in Lib/socket.py; __module__ is 'socket'; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [herror_mro_len_5,
       "herror.__mro__.__len__",
       [],
       5,
       "socket.herror.__mro__.__len__() == 5 — MRO is [herror, OSError, Exception, BaseException, object]; same depth as gaierror; 5 entries; new anchor in extra232 namespace; verified Python 3.14.3"]

invariant socket_extra232.herror_mro_0:
  description: "socket.herror.__mro__[0].__name__ == 'herror' — MRO head is herror itself"
  category: herror_mro
  kind: python_call_eq
  function: herror.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "herror"

invariant socket_extra232.herror_mro_1:
  description: "socket.herror.__mro__[1].__name__ == 'OSError' — herror inherits directly from OSError, same as gaierror"
  category: herror_mro
  kind: python_call_eq
  function: herror.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra232.error_name_eq:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error is not a subclass of OSError, it IS OSError; the alias was introduced to provide a socket-specific name for I/O errors, but since Python 3.3 it was unified with the built-in OSError; because socket.error is the same class object as OSError, its __name__ attribute is 'OSError' (not 'error'); __module__ is 'builtins' since OSError is a built-in exception; extra232 is the first namespace to anchor socket.error.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "error.__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant socket_extra232.gaierror_name_eq:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — gaierror (get address information error) is raised by getaddrinfo() and getnameinfo() when address resolution fails; unlike socket.error, gaierror is a real subclass (not an alias), so its __name__ is 'gaierror' (8 characters); it inherits from OSError which is socket.error; the MRO is [gaierror, OSError, Exception, BaseException, object] with 5 entries; extra232 is the first namespace to anchor socket.gaierror.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "gaierror.__name__.__eq__"
  args: ["gaierror"]
  expected: true

invariant socket_extra232.herror_module_eq:
  description: "socket.herror.__module__.__eq__('socket') == True — herror is a socket-specific exception class for address-related host errors from legacy BSD socket functions; it is defined in Lib/socket.py so __module__ is 'socket'; both gaierror and herror share this module, in contrast to socket.error (OSError) which has __module__=='builtins'; extra232 is the first namespace to anchor socket.herror.__module__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "herror.__module__.__eq__"
  args: ["socket"]
  expected: true
