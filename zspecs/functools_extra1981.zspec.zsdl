spec: functools_extra1981
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "functools.partial, functools.partialmethod, functools.cached_property do NOT define __sizeof__ in their own dict (inherited from object)."
    - "None of the functools classes define __length_hint__ — they are not iterators."
    - "None of the functools classes define __floor__, __ceil__, or __trunc__ — they are not numeric types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra1981.sizeof_protocol:
  description: "functools types __sizeof__ dict-presence checks — none define __sizeof__ in own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1981
  columns: [id, function, args, expected]
  rows:
    - ["ft1981001", "functools.partial.__dict__.__contains__",         ["__sizeof__"], false]
    - ["ft1981002", "functools.partialmethod.__dict__.__contains__",   ["__sizeof__"], false]
    - ["ft1981003", "functools.cached_property.__dict__.__contains__", ["__sizeof__"], false]

