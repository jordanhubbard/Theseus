    "notes": [
      "The module is imported as 'urllib.parse' but accessed via dotted function names (e.g. 'parse.urlparse').",
      "urlparse returns a ParseResult named-tuple; attributes are accessed via the 'method' field.",
      "urlencode with a dict sorts keys in Python 3.7+ guaranteed insertion order — use fixed-order dicts.",
      "quote() does not encode '/' by default (safe='/'); quote_plus() encodes '/' and ' ' as '+'.",
      "parse_qs returns lists for each key (multi-value aware); order within lists follows input order."
    ]
  },

  "library": {
    "backend": "python_module",
    "module_name": "urllib.parse",
    "soname_patterns": []
  },

  "constants": {},
  "types": {},
  "wire_formats": {},

  "functions": {
    "urlparse": {
      "description": "Parse a URL into a ParseResult named-tuple with scheme, netloc, path, params, query, fragment components.",
      "parameters": [{"name": "urlstring", "type": "str", "direction": "in"}],
      "return_type": "ParseResult"
    },
    "urlencode": {
      "description": "Encode a dict or sequence of two-element tuples into a percent-encoded query string.",
      "parameters": [{"name": "query", "type": "dict|sequence", "direction": "in"}],
      "return_type": "str"
    },
    "quote": {
      "description": "Percent-encode a string. '/' is in safe by default and not encoded.",
      "parameters": [
        {"name": "string", "type": "str", "direction": "in"},
        {"name": "safe", "type": "str", "direction": "in"}
      ],
      "return_type": "str"
    },
    "quote_plus": {
      "description": "Percent-encode a string, encoding spaces as '+' instead of '%20'.",
      "parameters": [{"name": "string", "type": "str", "direction": "in"}],
      "return_type": "str"
    },
    "unquote": {
      "description": "Replace %xx escapes with their single-character equivalent.",
      "parameters": [{"name": "string", "type": "str", "direction": "in"}],
      "return_type": "str"
    },
    "unquote_plus": {
      "description": "Like unquote(), but also replace '+' with a space.",
      "parameters": [{"name": "string", "type": "str", "direction": "in"}],
      "return_type": "str"
    },
    "urljoin": {
      "description": "Combine a base URL and a possibly relative URL to form an absolute URL.",
      "parameters": [
        {"name": "base", "type": "str", "direction": "in"},
        {"name": "url",  "type": "str", "direction": "in"}
      ],
      "return_type": "str"
    },
    "parse_qs": {
      "description": "Parse a query string into a dict mapping keys to lists of values.",
      "parameters": [{"name": "qs", "type": "str", "direction": "in"}],
      "return_type": "dict"
    }
  },

