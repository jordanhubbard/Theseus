spec: safe_regex
version: ">=2.0.0"
backend: node(safe-regex)

docs: https://www.npmjs.com/package/safe-regex

provenance:
  derived_from:
    - "safe-regex README — https://www.npmjs.com/package/safe-regex"
    - "Test vectors verified with safe-regex via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "safe-regex source"
  notes:
    - "safe-regex is an npm package. Install: npm install safe-regex"
    - "safe(pattern) returns false if the regex pattern is vulnerable to catastrophic backtracking."
    - "Accepts a string or RegExp. String input is treated as the regex pattern."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table safe_regex.safe:
  kind: node_module_call_eq
  function: ~
  category: validate
  id_prefix: safere

  columns: [id, args, expected]
  rows:
    - [simple,       ["hello"],     true]
    - [dotstar,      ["a.*b"],      true]
    - [anchored,     ["^[a-z]+$"],  true]
    - [catastrophic, ["(a+)+"],     false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:25:40Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
