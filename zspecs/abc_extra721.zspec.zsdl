spec: abc_extra721
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta and abstractmethod method qualnames and class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra721.abcmeta_method_qualnames:
  description: "abc.ABCMeta method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab721mq
  columns: [id, function, args, expected]
  rows:
    - [ab721mq001, abc.ABCMeta.__new__.__qualname__.__eq__,           ["ABCMeta.__new__"],           true]
    - [ab721mq002, abc.ABCMeta.__init__.__qualname__.__eq__,          ["ABCMeta.__init__"],          true]
    - [ab721mq003, abc.ABCMeta.register.__qualname__.__eq__,          ["ABCMeta.register"],          true]
    - [ab721mq004, abc.ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true]
    - [ab721mq005, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true]

table abc_extra721.abstractmethod_qualnames:
  description: "abc.abstractmethod method __qualname__ identity"
  kind: python_call_eq
  category: abstractmethod_qualnames
  id_prefix: ab721am
  columns: [id, function, args, expected]
  rows:
    - [ab721am001, abc.abstractmethod.__qualname__.__eq__,       ["abstractmethod"],          true]
    - [ab721am002, abc.abstractmethod.__init__.__qualname__.__eq__, ["abstractmethod.__init__"], true]
    - [ab721am003, abc.abstractmethod.__call__.__qualname__.__eq__, ["abstractmethod.__call__"], true]

table abc_extra721.class_identity:
  description: "abc.ABC and abc.ABCMeta class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab721ci
  columns: [id, function, args, expected]
  rows:
    - [ab721ci001, abc.ABC.__class__.__name__.__eq__,              ["ABCMeta"], true]
    - [ab721ci002, abc.ABCMeta.__class__.__name__.__eq__,          ["type"],    true]
    - [ab721ci003, abc.ABCMeta.__module__.__eq__,                  ["abc"],     true]
    - [ab721ci004, abc.ABC.__doc__.__class__.__name__.__eq__,      ["str"],     true]
