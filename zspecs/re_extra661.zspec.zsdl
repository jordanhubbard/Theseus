spec: re_extra661
backend: python_module(re)
description: "re module constant identity checks for RegexFlag members"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks RegexFlag class identity, value class identity, and name identity for re module flag constants"]
  created_at: "2026-04-12T00:00:00Z"

table re_extra661.flag_class_names:
  description: "re flag constant __class__.__name__ identity"
  kind: python_call_eq
  category: class_name_identity
  id_prefix: re661cn
  columns: [id, function, args, expected]
  rows:
    - [re661cn001, "re.IGNORECASE.__class__.__name__.__eq__", ["RegexFlag"], true]
    - [re661cn002, "re.MULTILINE.__class__.__name__.__eq__", ["RegexFlag"], true]
    - [re661cn003, "re.DOTALL.__class__.__name__.__eq__", ["RegexFlag"], true]
    - [re661cn004, "re.UNICODE.__class__.__name__.__eq__", ["RegexFlag"], true]
    - [re661cn005, "re.VERBOSE.__class__.__name__.__eq__", ["RegexFlag"], true]
    - [re661cn006, "re.ASCII.__class__.__name__.__eq__", ["RegexFlag"], true]
    - [re661cn007, "re.LOCALE.__class__.__name__.__eq__", ["RegexFlag"], true]

table re_extra661.flag_value_class_names:
  description: "re flag constant .value __class__.__name__ identity"
  kind: python_call_eq
  category: value_class_name_identity
  id_prefix: re661vc
  columns: [id, function, args, expected]
  rows:
    - [re661vc001, "re.IGNORECASE.value.__class__.__name__.__eq__", ["int"], true]
    - [re661vc002, "re.MULTILINE.value.__class__.__name__.__eq__", ["int"], true]
    - [re661vc003, "re.DOTALL.value.__class__.__name__.__eq__", ["int"], true]

table re_extra661.flag_names:
  description: "re flag constant .name identity"
  kind: python_call_eq
  category: flag_name_identity
  id_prefix: re661fn
  columns: [id, function, args, expected]
  rows:
    - [re661fn001, "re.IGNORECASE.name.__eq__", ["IGNORECASE"], true]
    - [re661fn002, "re.MULTILINE.name.__eq__", ["MULTILINE"], true]
    - [re661fn003, "re.DOTALL.name.__eq__", ["DOTALL"], true]
    - [re661fn004, "re.UNICODE.name.__eq__", ["UNICODE"], true]
