spec: io_extra2356
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra.zspec.zsdl — covers class names, module attributes, ABC membership"
  notes:
    - "Wave 2356, theme: __init__ and __new__ implementation type classification."
    - "All io classes listed here are C extension types implemented in _io."
    - "C extension types expose __init__ as 'wrapper_descriptor' — the slot is wrapped by the C type machinery."
    - "C extension types expose __new__ as 'builtin_function_or_method' — object.__new__ or a C-level tp_new slot."
    - "io.IOBase.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13, macOS)."
    - "io.FileIO.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13, macOS)."
    - "io.BytesIO.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13, macOS)."
    - "io.StringIO.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13, macOS)."
    - "io.TextIOWrapper.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13, macOS)."
    - "All __new__ attributes return 'builtin_function_or_method' across all tested io types."
    - "All expected values verified by running Python 3.13 io module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

