spec: syslog_extra3
version: ">=3.9"
backend: python_module(syslog)

docs: https://docs.python.org/3/library/syslog.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/syslog.html — Python syslog module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/syslogmodule.c"
  notes:
    - "This spec extends syslog.zspec.zsdl and syslog_extra2.zspec.zsdl."
    - "syslog.zspec.zsdl covers: function __name__ for syslog/openlog/closelog/setlogmask/LOG_MASK/LOG_UPTO; priority constants LOG_EMERG through LOG_DEBUG values; LOG_KERN/LOG_USER/LOG_DAEMON facility values."
    - "syslog_extra2.zspec.zsdl covers: module __name__; function __qualname__ and __module__; function class type (builtin_function_or_method); priority constant class types (all int); priority ordering (err<warning<info<debug); facility constants LOG_MAIL/LOG_AUTH/LOG_LPR/LOG_LOCAL0 values and types."
    - "This spec adds: LOG_ODELAY open flag; LOG_PID/LOG_CONS/LOG_NDELAY/LOG_NOWAIT/LOG_PERROR open-option flag values (POSIX); additional facility constants LOG_CRON/LOG_NEWS/LOG_SYSLOG/LOG_UUCP/LOG_FTP/LOG_AUTHPRIV values (macOS/POSIX); LOG_LOCAL1 through LOG_LOCAL7 values; LOG_MASK and LOG_UPTO __module__ and __qualname__."
    - "LOG_PID==1, LOG_CONS==2, LOG_NDELAY==8, LOG_NOWAIT==16, LOG_PERROR==32 — POSIX openlog() option flags."
    - "LOG_CRON==72, LOG_NEWS==56, LOG_SYSLOG==40, LOG_UUCP==64, LOG_FTP==88, LOG_AUTHPRIV==80 — POSIX/macOS facility codes."
    - "LOG_LOCAL1==136, LOG_LOCAL2==144, LOG_LOCAL3==152, LOG_LOCAL4==160, LOG_LOCAL5==168, LOG_LOCAL6==176, LOG_LOCAL7==184 on macOS."
    - "LOG_MASK and LOG_UPTO are C-level builtin_function_or_method objects in the syslog module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# openlog() option flag constants — POSIX standardized
#
# syslog.zspec.zsdl and syslog_extra2 do not cover the openlog() option flags.
# These constants are passed as the logopt argument to openlog().
# ---------------------------------------------------------------------------

table syslog_extra3.openlog_flags.values:
  kind: python_call_eq
  category: constants
  id_prefix: flag

  columns: [id, function, args, expected]
  rows:
    - [pid,    LOG_PID.__eq__,    [1],  true]
    - [cons,   LOG_CONS.__eq__,   [2],  true]
    - [ndelay, LOG_NDELAY.__eq__, [8],  true]
    - [nowait, LOG_NOWAIT.__eq__, [16], true]
    - [perror, LOG_PERROR.__eq__, [32], true]

table syslog_extra3.openlog_flags.types:
  kind: python_call_eq
  category: constants
  id_prefix: flag_type

  columns: [id, function, args, expected]
  rows:
    - [pid,    LOG_PID.__class__.__name__.__eq__,    ["int"], true]
    - [cons,   LOG_CONS.__class__.__name__.__eq__,   ["int"], true]
    - [ndelay, LOG_NDELAY.__class__.__name__.__eq__, ["int"], true]
    - [nowait, LOG_NOWAIT.__class__.__name__.__eq__, ["int"], true]
    - [perror, LOG_PERROR.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# Additional facility constants — POSIX/macOS facility codes
#
# syslog.zspec.zsdl covers LOG_KERN, LOG_USER, LOG_DAEMON.
# syslog_extra2 covers LOG_MAIL, LOG_AUTH, LOG_LPR, LOG_LOCAL0.
# This spec adds LOG_CRON, LOG_NEWS, LOG_SYSLOG, LOG_UUCP, LOG_FTP, LOG_AUTHPRIV.
# ---------------------------------------------------------------------------

table syslog_extra3.facility_extra.values:
  kind: python_call_eq
  category: constants
  id_prefix: fac2

  columns: [id, function, args, expected]
  rows:
    - [syslog,   LOG_SYSLOG.__eq__,   [40], true]
    - [news,     LOG_NEWS.__eq__,     [56], true]
    - [uucp,     LOG_UUCP.__eq__,     [64], true]
    - [cron,     LOG_CRON.__eq__,     [72], true]
    - [authpriv, LOG_AUTHPRIV.__eq__, [80], true]
    - [ftp,      LOG_FTP.__eq__,      [88], true]

table syslog_extra3.facility_extra.types:
  kind: python_call_eq
  category: constants
  id_prefix: fac2_type

  columns: [id, function, args, expected]
  rows:
    - [syslog,   LOG_SYSLOG.__class__.__name__.__eq__,   ["int"], true]
    - [news,     LOG_NEWS.__class__.__name__.__eq__,     ["int"], true]
    - [uucp,     LOG_UUCP.__class__.__name__.__eq__,     ["int"], true]
    - [cron,     LOG_CRON.__class__.__name__.__eq__,     ["int"], true]
    - [authpriv, LOG_AUTHPRIV.__class__.__name__.__eq__, ["int"], true]
    - [ftp,      LOG_FTP.__class__.__name__.__eq__,      ["int"], true]

# ---------------------------------------------------------------------------
# LOG_LOCAL1 through LOG_LOCAL7 — local-use facility constants
#
# syslog_extra2 covers LOG_LOCAL0 == 128.
# This spec adds LOG_LOCAL1 through LOG_LOCAL7 (each 8 more than the prior).
# ---------------------------------------------------------------------------

table syslog_extra3.local_facilities.values:
  kind: python_call_eq
  category: constants
  id_prefix: local

  columns: [id, function, args, expected]
  rows:
    - [local1, LOG_LOCAL1.__eq__, [136], true]
    - [local2, LOG_LOCAL2.__eq__, [144], true]
    - [local3, LOG_LOCAL3.__eq__, [152], true]
    - [local4, LOG_LOCAL4.__eq__, [160], true]
    - [local5, LOG_LOCAL5.__eq__, [168], true]
    - [local6, LOG_LOCAL6.__eq__, [176], true]
    - [local7, LOG_LOCAL7.__eq__, [184], true]

# ---------------------------------------------------------------------------
# LOG_MASK and LOG_UPTO — __module__ and __qualname__ checks
#
# syslog.zspec.zsdl checks LOG_MASK.__name__ and LOG_UPTO.__name__.
# syslog_extra2 checks __qualname__ and __module__ for syslog/openlog/closelog/setlogmask.
# No prior spec covers __module__ or __qualname__ for LOG_MASK and LOG_UPTO.
# ---------------------------------------------------------------------------

invariant syslog_extra3.LOG_MASK.module:
  description: "syslog.LOG_MASK.__module__ == 'syslog' — LOG_MASK is defined in the C syslog extension"
  category: function_modules
  kind: python_call_eq
  function: LOG_MASK.__module__.__eq__
  args: ["syslog"]
  expected: true

invariant syslog_extra3.LOG_MASK.qualname:
  description: "syslog.LOG_MASK.__qualname__ == 'LOG_MASK' — top-level C builtin function"
  category: function_qualnames
  kind: python_call_eq
  function: LOG_MASK.__qualname__.__eq__
  args: ["LOG_MASK"]
  expected: true

invariant syslog_extra3.LOG_UPTO.module:
  description: "syslog.LOG_UPTO.__module__ == 'syslog' — LOG_UPTO is defined in the C syslog extension"
  category: function_modules
  kind: python_call_eq
  function: LOG_UPTO.__module__.__eq__
  args: ["syslog"]
  expected: true

invariant syslog_extra3.LOG_UPTO.qualname:
  description: "syslog.LOG_UPTO.__qualname__ == 'LOG_UPTO' — top-level C builtin function"
  category: function_qualnames
  kind: python_call_eq
  function: LOG_UPTO.__qualname__.__eq__
  args: ["LOG_UPTO"]
  expected: true
