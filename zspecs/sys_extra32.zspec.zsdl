spec: sys_extra32
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys_extra31.zspec.zsdl."
    - "Prior specs covered: built-in function __name__/__module__ lengths; stdin/stdout/stderr __class__.__name__; version_info __class__.__name__ and __len__(); getrecursionlimit()==1000; __name__/__package__; __class__.__name__.__len__() and __eq__() for version/argv/path/modules/stdin/platform/version_info; maxsize/maxunicode values and class name lengths; float_info/int_info/hash_info/flags/builtin_module_names class name lengths; float_info.mant_dig/radix/dig/max_exp; int_info.bits_per_digit/sizeof_digit; hash_info.width/nan."
    - "This spec covers: sys.version.__class__.__name__.__len__()==3 ('str'); sys.version_info.__class__.__name__.__len__()==12 ('version_info' — SURPRISE: 12 not 11); sys.platform.__len__()==6 ('darwin' on macOS); sys.modules/__class__.__name__.__len__()==4 ('dict'); sys.path/__class__.__name__.__len__()==4 ('list'); sys.executable/__class__.__name__.__len__()==3 ('str'); sys.argv/__class__.__name__.__len__()==4 ('list'); sys.getdefaultencoding().__len__()==5 ('utf-8'); sys.getdefaultencoding/__qualname__.__len__()==18; sys.getfilesystemencoding/__qualname__.__len__()==21; sys.getrecursionlimit/__qualname__.__len__()==17; sys.getsizeof/__qualname__.__len__()==9."
    - "SURPRISE: sys.version_info.__class__.__name__ == 'version_info' (len 12). The prompt suggested 11 — actual length is 12. Verified at runtime."
    - "sys.version.__class__.__name__ == 'str' (len 3). Verified at runtime."
    - "sys.platform == 'darwin' on macOS; len == 6. Verified at runtime."
    - "sys.modules.__class__.__name__ == 'dict' (len 4). Verified at runtime."
    - "sys.path.__class__.__name__ == 'list' (len 4). Verified at runtime."
    - "sys.executable.__class__.__name__ == 'str' (len 3). Verified at runtime."
    - "sys.argv.__class__.__name__ == 'list' (len 4). Verified at runtime."
    - "sys.getdefaultencoding() == 'utf-8'; len == 5. Verified at runtime."
    - "sys.getdefaultencoding.__qualname__ == 'getdefaultencoding' (len 18). Verified at runtime."
    - "sys.getfilesystemencoding.__qualname__ == 'getfilesystemencoding' (len 21). Verified at runtime."
    - "sys.getrecursionlimit.__qualname__ == 'getrecursionlimit' (len 17). Verified at runtime."
    - "sys.getsizeof.__qualname__ == 'getsizeof' (len 9). Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: collection and sequence attribute __class__.__name__.__len__()
#
# sys exposes several collection/sequence attributes: modules (dict), path
# (list), argv (list), builtin_module_names (covered in extra31 — tuple).
# version, executable are str. No prior sys spec checks __class__.__name__.__len__()
# for modules, path, argv, executable. All verified at runtime.
# ---------------------------------------------------------------------------

table sys_extra32.collection_class_name_lengths:
  description: "sys collection/str attribute __class__.__name__.__len__() — modules (4,'dict'), path (4,'list'), argv (4,'list'), executable (3,'str'), version (3,'str')"
  kind: python_call_eq
  category: type_attrs
  id_prefix: s32ccnl

  columns: [id, function, args, expected]
  rows:
    - [modules,     modules.__class__.__name__.__len__,     [], 4]
    - [path,        path.__class__.__name__.__len__,        [], 4]
    - [argv,        argv.__class__.__name__.__len__,        [], 4]
    - [executable,  executable.__class__.__name__.__len__,  [], 3]
    - [version_str, version.__class__.__name__.__len__,     [], 3]

# ---------------------------------------------------------------------------
# Table: builtin function __qualname__.__len__() for encoding/limit/size functions
#
# No prior sys spec checks __qualname__.__len__() for any of these builtins.
# All are builtin_function_or_method objects; __qualname__ equals __name__.
# getdefaultencoding (18), getfilesystemencoding (21), getrecursionlimit (17),
# getsizeof (9). Verified at runtime.
# ---------------------------------------------------------------------------

table sys_extra32.builtin_qualname_lengths:
  description: "sys builtin function __qualname__.__len__() for getdefaultencoding/getfilesystemencoding/getrecursionlimit/getsizeof"
  kind: python_call_eq
  category: function_attrs
  id_prefix: s32bql

  columns: [id, function, args, expected]
  rows:
    - [getdefaultencoding,    getdefaultencoding.__qualname__.__len__,    [], 18]
    - [getfilesystemencoding, getfilesystemencoding.__qualname__.__len__, [], 21]
    - [getrecursionlimit,     getrecursionlimit.__qualname__.__len__,     [], 17]
    - [getsizeof,             getsizeof.__qualname__.__len__,             [], 9]

# ---------------------------------------------------------------------------
# Standalone: sys.version_info.__class__.__name__.__len__() == 12
#
# sys.version_info.__class__.__name__ == 'version_info'.
# len('version_info') == 12.
# SURPRISE: the suggested value was 11; actual value is 12.
# No prior sys spec checks __class__.__name__.__len__() for version_info.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant sys_extra32.version_info.class_name_len:
  description: "sys.version_info.__class__.__name__.__len__() == 12 — 'version_info' is 12 characters (not 11 as might be assumed)"
  category: type_attrs
  kind: python_call_eq
  function: version_info.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Standalone: sys.platform.__len__() == 6
#
# sys.platform == 'darwin' on macOS; len('darwin') == 6.
# No prior sys spec checks sys.platform.__len__() as a standalone invariant.
# Verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant sys_extra32.platform.len:
  description: "sys.platform.__len__() == 6 — 'darwin' has 6 characters on macOS"
  category: string_attrs
  kind: python_call_eq
  function: platform.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Standalone: sys.getdefaultencoding().__len__() == 5
#
# sys.getdefaultencoding() returns 'utf-8'; len('utf-8') == 5.
# No prior sys spec checks the length of the encoding name string returned
# by getdefaultencoding(). Verified at runtime.
# ---------------------------------------------------------------------------

invariant sys_extra32.getdefaultencoding.result_len:
  description: "sys.getdefaultencoding().__len__() == 5 — 'utf-8' has 5 characters"
  category: runtime
  kind: python_call_eq
  function: getdefaultencoding().__len__
  args: []
  expected: 5
