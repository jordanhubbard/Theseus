spec: functools_extra402
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.partial.func.__class__.__name__ == 'member_descriptor' — func is a C-level slot descriptor on the partial C type; __class__.__name__ is 'member_descriptor'. Verified with Python 3.14.4."
    - "functools.partial.args.__class__.__name__ == 'member_descriptor' — args is a C-level slot descriptor on the partial C type; __class__.__name__ is 'member_descriptor'. Verified with Python 3.14.4."
    - "functools.partial.keywords.__class__.__name__ == 'member_descriptor' — keywords is a C-level slot descriptor on the partial C type; __class__.__name__ is 'member_descriptor'. Verified with Python 3.14.4."
    - "functools.partial.__new__.__name__ == '__new__' — the __new__ slot method carries __name__ == '__new__'. Verified with Python 3.14.4."
    - "functools.partial.__repr__.__name__ == '__repr__' — the __repr__ slot wrapper carries __name__ == '__repr__'. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial instance attribute descriptor __class__.__name__
#
# functools.partial is a C type. Its per-instance attributes (func, args,
# keywords) are exposed via C-level member descriptors. When accessed on
# the class object (not an instance), each descriptor's __class__.__name__
# is 'member_descriptor'.
# ---------------------------------------------------------------------------

table functools_extra402.partial_attr_descriptor_class_name:
  description: "functools.partial.func/args/keywords __class__.__name__ — C-level member_descriptor on the partial C type; new to extra402"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspa402

  columns: [id, function, args, expected, description]
  rows:
    - [partial_func_class_name_eq,
       "partial.func.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "functools.partial.func.__class__.__name__.__eq__('member_descriptor') == True — func is a C-level slot descriptor on the partial C type; __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra402"]
    - [partial_args_class_name_eq,
       "partial.args.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "functools.partial.args.__class__.__name__.__eq__('member_descriptor') == True — args is a C-level slot descriptor on the partial C type; __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra402"]
    - [partial_keywords_class_name_eq,
       "partial.keywords.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — keywords is a C-level slot descriptor on the partial C type; __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra402"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial special method __name__ values
#
# functools.partial.__new__ and functools.partial.__repr__ are C-level
# slot wrappers. Their __name__ attribute returns the bare method name
# string ('__new__' and '__repr__' respectively).
# ---------------------------------------------------------------------------

table functools_extra402.partial_special_method_name:
  description: "functools.partial.__new__ and __repr__ __name__ values — C-level slot wrappers; new to extra402"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspm402

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_name_eq,
       "partial.__new__.__name__.__eq__",
       ["__new__"],
       true,
       "functools.partial.__new__.__name__.__eq__('__new__') == True — __new__ is a C-level slot wrapper on the partial C type; __name__ is '__new__'; str.__eq__('__new__') returns True; new to extra402"]
    - [partial_repr_name_eq,
       "partial.__repr__.__name__.__eq__",
       ["__repr__"],
       true,
       "functools.partial.__repr__.__name__.__eq__('__repr__') == True — __repr__ is a C-level slot wrapper on the partial C type; __name__ is '__repr__'; str.__eq__('__repr__') returns True; new to extra402"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra402
# ---------------------------------------------------------------------------

invariant functools_extra402.partial_func_class_name:
  description: "functools.partial.func.__class__.__name__ == 'member_descriptor' — C-level slot descriptor on partial C type; new to extra402"
  kind: python_call_eq
  function: partial.func.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra402.partial_args_class_name:
  description: "functools.partial.args.__class__.__name__ == 'member_descriptor' — C-level slot descriptor on partial C type; new to extra402"
  kind: python_call_eq
  function: partial.args.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra402.partial_keywords_class_name:
  description: "functools.partial.keywords.__class__.__name__ == 'member_descriptor' — C-level slot descriptor on partial C type; new to extra402"
  kind: python_call_eq
  function: partial.keywords.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra402.partial_new_name:
  description: "functools.partial.__new__.__name__ == '__new__' — C-level slot wrapper on partial C type; new to extra402"
  kind: python_call_eq
  function: partial.__new__.__name__.__eq__
  args: ["__new__"]
  expected: true

invariant functools_extra402.partial_repr_name:
  description: "functools.partial.__repr__.__name__ == '__repr__' — C-level slot wrapper on partial C type; new to extra402"
  kind: python_call_eq
  function: partial.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true
