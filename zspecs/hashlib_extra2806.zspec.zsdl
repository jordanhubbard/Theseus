spec: hashlib_extra2806
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for HASH, blake2b, blake2s."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "hashlib.HASH.__dict__.__contains__('__ilshift__') == False — HASH (the OpenSSL-backed C type) does not define in-place left-shift; cryptographic hash objects carry no shift arithmetic; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__irshift__') == False — HASH does not define in-place right-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__ipow__') == False — HASH does not define in-place power; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__ilshift__') == False — blake2b does not define in-place left-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__irshift__') == False — blake2b does not define in-place right-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__ipow__') == False — blake2b does not define in-place power; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__ilshift__') == False — blake2s does not define in-place left-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__irshift__') == False — blake2s does not define in-place right-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__ipow__') == False — blake2s does not define in-place power; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# HASH is the C type for OpenSSL-backed hash objects (sha256, md5, sha1, etc.).
# Hash digest objects are cryptographic primitives; in-place shift and power
# operators (<<=, >>=, **=) have no meaning for them and are not defined.
# ---------------------------------------------------------------------------

table hashlib_extra2806.hash_dict_ilshift_irshift_ipow:
  description: "hashlib.HASH.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — in-place left-shift, right-shift, and power operators are not defined on hash digest objects; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2806

  columns: [id, function, args, expected]
  rows:
    - ["hl2806-hash-ilshift", hashlib.HASH.__dict__.__contains__, ["__ilshift__"], false]
    - ["hl2806-hash-irshift", hashlib.HASH.__dict__.__contains__, ["__irshift__"], false]
    - ["hl2806-hash-ipow",    hashlib.HASH.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.blake2b.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# blake2b is the C type for BLAKE2b hash objects.
# Like HASH, it defines no in-place shift or power operators.
# ---------------------------------------------------------------------------

table hashlib_extra2806.blake2b_dict_ilshift_irshift_ipow:
  description: "hashlib.blake2b.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — the BLAKE2b hash type defines no in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2806

  columns: [id, function, args, expected]
  rows:
    - ["hl2806-b2b-ilshift", hashlib.blake2b.__dict__.__contains__, ["__ilshift__"], false]
    - ["hl2806-b2b-irshift", hashlib.blake2b.__dict__.__contains__, ["__irshift__"], false]
    - ["hl2806-b2b-ipow",    hashlib.blake2b.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2s.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# blake2s is the C type for BLAKE2s hash objects.
# Like HASH and blake2b, it defines no in-place shift or power operators.
# ---------------------------------------------------------------------------

table hashlib_extra2806.blake2s_dict_ilshift_irshift_ipow:
  description: "hashlib.blake2s.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — the BLAKE2s hash type defines no in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2806

  columns: [id, function, args, expected]
  rows:
    - ["hl2806-b2s-ilshift", hashlib.blake2s.__dict__.__contains__, ["__ilshift__"], false]
    - ["hl2806-b2s-irshift", hashlib.blake2s.__dict__.__contains__, ["__irshift__"], false]
    - ["hl2806-b2s-ipow",    hashlib.blake2s.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — all three hash types absent for all three dunders
# Consolidates one row per (type, dunder) pair for easy cross-type comparison.
# ---------------------------------------------------------------------------

table hashlib_extra2806.all_types_all_dunders_absent:
  description: "HASH, blake2b, and blake2s all lack __ilshift__, __irshift__, and __ipow__ in __dict__ — no hashlib hash type defines these in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2806

  columns: [id, function, args, expected]
  rows:
    - ["hl2806-x-hash-ilshift", hashlib.HASH.__dict__.__contains__,    ["__ilshift__"], false]
    - ["hl2806-x-hash-irshift", hashlib.HASH.__dict__.__contains__,    ["__irshift__"], false]
    - ["hl2806-x-hash-ipow",    hashlib.HASH.__dict__.__contains__,    ["__ipow__"],    false]
    - ["hl2806-x-b2b-ilshift",  hashlib.blake2b.__dict__.__contains__, ["__ilshift__"], false]
    - ["hl2806-x-b2b-irshift",  hashlib.blake2b.__dict__.__contains__, ["__irshift__"], false]
    - ["hl2806-x-b2b-ipow",     hashlib.blake2b.__dict__.__contains__, ["__ipow__"],    false]
    - ["hl2806-x-b2s-ilshift",  hashlib.blake2s.__dict__.__contains__, ["__ilshift__"], false]
    - ["hl2806-x-b2s-irshift",  hashlib.blake2s.__dict__.__contains__, ["__irshift__"], false]
    - ["hl2806-x-b2s-ipow",     hashlib.blake2s.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra2806.hash_no_ilshift:
  description: "hashlib.HASH.__dict__.__contains__('__ilshift__') == False — HASH (OpenSSL-backed C type) does not define in-place left-shift; hash objects are cryptographic primitives, not integer operands; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__ilshift__"]
  expected: false

invariant hashlib_extra2806.hash_no_irshift:
  description: "hashlib.HASH.__dict__.__contains__('__irshift__') == False — HASH does not define in-place right-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__irshift__"]
  expected: false

invariant hashlib_extra2806.hash_no_ipow:
  description: "hashlib.HASH.__dict__.__contains__('__ipow__') == False — HASH does not define in-place power; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__ipow__"]
  expected: false

