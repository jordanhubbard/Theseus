spec: threading_extra111
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra110.zspec.zsdl."
    - "This spec covers: threading.Condition method code attributes — notify, notify_all, wait, wait_for, __init__, __enter__, __exit__; all are pure-Python functions (type 'function'); qualnames follow 'Condition.method_name' pattern; co_argcount values reflect actual parameter counts; wave 262."
    - "type(threading.Condition.notify).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify'. Verified with Python 3.14.3."
    - "threading.Condition.notify.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "type(threading.Condition.notify_all).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all'. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "type(threading.Condition.wait).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait'. Verified with Python 3.14.3."
    - "threading.Condition.wait.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "type(threading.Condition.wait_for).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for'. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "type(threading.Condition.__init__).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.__init__.__qualname__ == 'Condition.__init__'. Verified with Python 3.14.3."
    - "threading.Condition.__init__.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "type(threading.Condition.__enter__).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__qualname__ == 'Condition.__enter__'. Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "type(threading.Condition.__exit__).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__qualname__ == 'Condition.__exit__'. Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading.Condition does NOT have acquire or release as class attributes (they are set dynamically on instances). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition notify and wait methods — type, qualname, co_argcount
#
# Wave 262 theme: threading.Condition is a pure-Python class defined in
# Lib/threading.py. Its methods are all plain Python 'function' objects when
# accessed unbound from the class. notify(self, n=1) has co_argcount 2 (self
# plus n with a default). notify_all(self) has co_argcount 1 (self only).
# wait(self, timeout=None) has co_argcount 2 (self plus timeout with a default).
# Qualnames follow the 'Condition.method_name' pattern.
#
# type(threading.Condition.notify).__name__ == 'function'
# threading.Condition.notify.__qualname__ == 'Condition.notify'
# threading.Condition.notify.__code__.co_argcount == 2
# type(threading.Condition.notify_all).__name__ == 'function'
# threading.Condition.notify_all.__qualname__ == 'Condition.notify_all'
# threading.Condition.notify_all.__code__.co_argcount == 1
# type(threading.Condition.wait).__name__ == 'function'
# threading.Condition.wait.__qualname__ == 'Condition.wait'
# threading.Condition.wait.__code__.co_argcount == 2
#
# New to extra111.
# ---------------------------------------------------------------------------

table threading_extra111.condition_notify_wait:
  description: "threading.Condition notify/notify_all/wait: type 'function'; qualnames 'Condition.notify'/'Condition.notify_all'/'Condition.wait'; co_argcount 2/1/2; wave 262; new to extra111"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingcn111

  columns: [id, function, args, expected, description]
  rows:
    - [condition_notify_type_function,
       "Condition.notify.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.notify.__class__.__name__.__eq__('function') == True — threading.Condition is a pure-Python class in Lib/threading.py; its notify method is a plain Python function accessed unbound from the class; type(threading.Condition.notify).__name__ is 'function'; str.__eq__('function') returns True; new to extra111"]
    - [condition_notify_qualname,
       "Condition.notify.__qualname__.__eq__",
       ["Condition.notify"],
       true,
       "threading.Condition.notify.__qualname__.__eq__('Condition.notify') == True — threading.Condition.notify is defined inside the Condition class body; its __qualname__ is 'Condition.notify' (dotted class prefix); str.__eq__('Condition.notify') returns True; new to extra111"]
    - [condition_notify_co_argcount_2,
       "Condition.notify.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Condition.notify.__code__.co_argcount.__eq__(2) == True — threading.Condition.notify(self, n=1) has 2 positional-or-keyword parameters: self and n (with default 1); co_argcount counts both including those with defaults; int.__eq__(2) returns True; new to extra111"]
    - [condition_notify_all_type_function,
       "Condition.notify_all.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.notify_all.__class__.__name__.__eq__('function') == True — threading.Condition.notify_all is a plain Python function accessed unbound; it calls self._notify(len(self._waiters)) to wake all waiting threads; str.__eq__('function') returns True; new to extra111"]
    - [condition_notify_all_qualname,
       "Condition.notify_all.__qualname__.__eq__",
       ["Condition.notify_all"],
       true,
       "threading.Condition.notify_all.__qualname__.__eq__('Condition.notify_all') == True — threading.Condition.notify_all is defined inside the Condition class body; its __qualname__ is 'Condition.notify_all'; str.__eq__('Condition.notify_all') returns True; new to extra111"]
    - [condition_notify_all_co_argcount_1,
       "Condition.notify_all.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Condition.notify_all.__code__.co_argcount.__eq__(1) == True — threading.Condition.notify_all(self) has 1 positional-or-keyword parameter: self only (no additional arguments); it wakes all waiting threads unconditionally; co_argcount is 1; int.__eq__(1) returns True; new to extra111"]
    - [condition_wait_type_function,
       "Condition.wait.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.wait.__class__.__name__.__eq__('function') == True — threading.Condition.wait is a plain Python function; it blocks the calling thread until notified or until the optional timeout; str.__eq__('function') returns True; new to extra111"]
    - [condition_wait_qualname,
       "Condition.wait.__qualname__.__eq__",
       ["Condition.wait"],
       true,
       "threading.Condition.wait.__qualname__.__eq__('Condition.wait') == True — threading.Condition.wait is defined inside the Condition class body; its __qualname__ is 'Condition.wait'; str.__eq__('Condition.wait') returns True; new to extra111"]
    - [condition_wait_co_argcount_2,
       "Condition.wait.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Condition.wait.__code__.co_argcount.__eq__(2) == True — threading.Condition.wait(self, timeout=None) has 2 positional-or-keyword parameters: self and timeout (with default None); co_argcount counts both; int.__eq__(2) returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition wait_for and context manager methods
#
# Wave 262 theme: threading.Condition.wait_for(self, predicate, timeout=None)
# has co_argcount 3 (self, predicate, timeout). The context manager methods
# __enter__(self) and __exit__(self) each have co_argcount 1 (self only, since
# __exit__ in Condition delegates to the underlying lock's __exit__ with fixed
# args). The qualnames follow the 'Condition.method_name' pattern.
#
# type(threading.Condition.wait_for).__name__ == 'function'
# threading.Condition.wait_for.__qualname__ == 'Condition.wait_for'
# threading.Condition.wait_for.__code__.co_argcount == 3
# type(threading.Condition.__enter__).__name__ == 'function'
# threading.Condition.__enter__.__qualname__ == 'Condition.__enter__'
# threading.Condition.__enter__.__code__.co_argcount == 1
# type(threading.Condition.__exit__).__name__ == 'function'
# threading.Condition.__exit__.__qualname__ == 'Condition.__exit__'
# threading.Condition.__exit__.__code__.co_argcount == 1
#
# New to extra111.
# ---------------------------------------------------------------------------

table threading_extra111.condition_wait_for_ctx:
  description: "threading.Condition wait_for/enter/exit: wait_for co_argcount 3 (self/predicate/timeout); __enter__ co_argcount 1; __exit__ co_argcount 1; all type 'function'; wave 262; new to extra111"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingcwf111

  columns: [id, function, args, expected, description]
  rows:
    - [condition_wait_for_type_function,
       "Condition.wait_for.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.wait_for.__class__.__name__.__eq__('function') == True — threading.Condition.wait_for is a pure-Python function that waits until a predicate becomes true; it calls self.wait() in a loop checking the predicate; accessed unbound it is a 'function' object; str.__eq__('function') returns True; new to extra111"]
    - [condition_wait_for_qualname,
       "Condition.wait_for.__qualname__.__eq__",
       ["Condition.wait_for"],
       true,
       "threading.Condition.wait_for.__qualname__.__eq__('Condition.wait_for') == True — threading.Condition.wait_for is defined inside the Condition class body; its __qualname__ is 'Condition.wait_for'; str.__eq__('Condition.wait_for') returns True; new to extra111"]
    - [condition_wait_for_co_argcount_3,
       "Condition.wait_for.__code__.co_argcount.__eq__",
       [3],
       true,
       "threading.Condition.wait_for.__code__.co_argcount.__eq__(3) == True — threading.Condition.wait_for(self, predicate, timeout=None) has 3 positional-or-keyword parameters: self, predicate (the callable to check), and timeout (optional, default None); co_argcount counts all 3 including those with defaults; int.__eq__(3) returns True; new to extra111"]
    - [condition_enter_type_function,
       "Condition.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.__enter__.__class__.__name__.__eq__('function') == True — threading.Condition implements the context manager protocol; __enter__ is a plain Python function that acquires the underlying lock; str.__eq__('function') returns True; new to extra111"]
    - [condition_enter_qualname,
       "Condition.__enter__.__qualname__.__eq__",
       ["Condition.__enter__"],
       true,
       "threading.Condition.__enter__.__qualname__.__eq__('Condition.__enter__') == True — threading.Condition.__enter__ is defined inside the Condition class body; its __qualname__ is 'Condition.__enter__'; str.__eq__('Condition.__enter__') returns True; new to extra111"]
    - [condition_enter_co_argcount_1,
       "Condition.__enter__.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Condition.__enter__.__code__.co_argcount.__eq__(1) == True — threading.Condition.__enter__(self) has 1 positional-or-keyword parameter: self only; it acquires the underlying lock and returns the condition object; co_argcount is 1; int.__eq__(1) returns True; new to extra111"]
    - [condition_exit_type_function,
       "Condition.__exit__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.__exit__.__class__.__name__.__eq__('function') == True — threading.Condition.__exit__ is a plain Python function that releases the underlying lock when leaving the with block; str.__eq__('function') returns True; new to extra111"]
    - [condition_exit_qualname,
       "Condition.__exit__.__qualname__.__eq__",
       ["Condition.__exit__"],
       true,
       "threading.Condition.__exit__.__qualname__.__eq__('Condition.__exit__') == True — threading.Condition.__exit__ is defined inside the Condition class body; its __qualname__ is 'Condition.__exit__'; str.__eq__('Condition.__exit__') returns True; new to extra111"]
    - [condition_exit_co_argcount_1,
       "Condition.__exit__.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Condition.__exit__.__code__.co_argcount.__eq__(1) == True — threading.Condition.__exit__(self, *args) — although __exit__ conceptually takes exc_type/exc_val/exc_tb, the Condition implementation uses *args; co_argcount counts only positional-or-keyword parameters (not *args), so co_argcount is 1 (just self); int.__eq__(1) returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition __init__ and co_name values
#
# Wave 262 theme: threading.Condition.__init__(self, lock=None) has
# co_argcount 2 (self and lock with a default). The co_name of each method
# equals the unqualified method name (the portion after the dot in the
# qualname). For example, Condition.notify.__code__.co_name == 'notify'.
# This table verifies co_name for notify, notify_all, wait, wait_for, and
# __init__.
#
# threading.Condition.__init__.__code__.co_argcount == 2
# threading.Condition.__init__.__qualname__ == 'Condition.__init__'
# threading.Condition.notify.__code__.co_name == 'notify'
# threading.Condition.notify_all.__code__.co_name == 'notify_all'
# threading.Condition.wait.__code__.co_name == 'wait'
# threading.Condition.wait_for.__code__.co_name == 'wait_for'
# threading.Condition.__init__.__code__.co_name == '__init__'
#
# New to extra111.
# ---------------------------------------------------------------------------

table threading_extra111.condition_init_co_names:
  description: "threading.Condition.__init__: co_argcount 2, qualname 'Condition.__init__'; co_name values for notify/notify_all/wait/wait_for/__init__ match unqualified method names; wave 262; new to extra111"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingci111

  columns: [id, function, args, expected, description]
  rows:
    - [condition_init_co_argcount_2,
       "Condition.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Condition.__init__.__code__.co_argcount.__eq__(2) == True — threading.Condition.__init__(self, lock=None) has 2 positional-or-keyword parameters: self and lock (with default None, allowing use without an explicit lock); co_argcount counts both; int.__eq__(2) returns True; new to extra111"]
    - [condition_init_qualname,
       "Condition.__init__.__qualname__.__eq__",
       ["Condition.__init__"],
       true,
       "threading.Condition.__init__.__qualname__.__eq__('Condition.__init__') == True — threading.Condition.__init__ is defined inside the Condition class body; its __qualname__ is 'Condition.__init__'; str.__eq__('Condition.__init__') returns True; new to extra111"]
    - [condition_notify_co_name,
       "Condition.notify.__code__.co_name.__eq__",
       ["notify"],
       true,
       "threading.Condition.notify.__code__.co_name.__eq__('notify') == True — for pure-Python methods defined inside a class body, __code__.co_name is the simple method name (the def-statement name), not the qualified form; Condition.notify.__code__.co_name is 'notify' (not 'Condition.notify'); str.__eq__('notify') returns True; new to extra111"]
    - [condition_notify_all_co_name,
       "Condition.notify_all.__code__.co_name.__eq__",
       ["notify_all"],
       true,
       "threading.Condition.notify_all.__code__.co_name.__eq__('notify_all') == True — Condition.notify_all.__code__.co_name is 'notify_all' (the simple def name); str.__eq__('notify_all') returns True; new to extra111"]
    - [condition_wait_co_name,
       "Condition.wait.__code__.co_name.__eq__",
       ["wait"],
       true,
       "threading.Condition.wait.__code__.co_name.__eq__('wait') == True — Condition.wait.__code__.co_name is 'wait' (the simple def name); str.__eq__('wait') returns True; new to extra111"]
    - [condition_wait_for_co_name,
       "Condition.wait_for.__code__.co_name.__eq__",
       ["wait_for"],
       true,
       "threading.Condition.wait_for.__code__.co_name.__eq__('wait_for') == True — Condition.wait_for.__code__.co_name is 'wait_for' (the simple def name); str.__eq__('wait_for') returns True; new to extra111"]
    - [condition_init_co_name,
       "Condition.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "threading.Condition.__init__.__code__.co_name.__eq__('__init__') == True — Condition.__init__.__code__.co_name is '__init__' (the dunder method name as written in the def statement); str.__eq__('__init__') returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra111
# ---------------------------------------------------------------------------

invariant threading_extra111.condition_notify_co_argcount:
  description: "threading.Condition.notify.__code__.co_argcount == 2 — notify(self, n=1); self plus n with default; wave 262; new to extra111"
  kind: python_call_eq
  function: Condition.notify.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra111.condition_notify_all_co_argcount:
  description: "threading.Condition.notify_all.__code__.co_argcount == 1 — notify_all(self); only self; wave 262; new to extra111"
  kind: python_call_eq
  function: Condition.notify_all.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra111.condition_wait_for_co_argcount:
  description: "threading.Condition.wait_for.__code__.co_argcount == 3 — wait_for(self, predicate, timeout=None); self/predicate/timeout; wave 262; new to extra111"
  kind: python_call_eq
  function: Condition.wait_for.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant threading_extra111.condition_wait_for_qualname:
  description: "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' — dotted class prefix; wave 262; new to extra111"
  kind: python_call_eq
  function: "Condition.wait_for.__qualname__.__eq__"
  args: ["Condition.wait_for"]
  expected: true

invariant threading_extra111.condition_notify_qualname:
  description: "threading.Condition.notify.__qualname__ == 'Condition.notify' — pure-Python method; dotted qualname pattern; wave 262; new to extra111"
  kind: python_call_eq
  function: "Condition.notify.__qualname__.__eq__"
  args: ["Condition.notify"]
  expected: true

