    - "struct.pack.__module__ == '_struct' — the C extension module name is '_struct'."
    - "struct.unpack.__name__ == 'unpack' — len=6; __module__ is '_struct'."
    - "struct.calcsize.__name__ == 'calcsize' — len=8; __module__ is '_struct'."
    - "struct.pack_into.__name__ == 'pack_into' — len=9; __module__ is '_struct'."
    - "struct.unpack_from.__name__ == 'unpack_from' — len=11; __module__ is '_struct'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.pack and struct.unpack — name and module identity
#
# struct.pack.__name__   == 'pack'     (len=4)
# struct.pack.__module__ == '_struct'
# struct.unpack.__name__ == 'unpack'   (len=6)
# struct.unpack.__module__ == '_struct'
#
# struct's core functions are implemented in the _struct C extension.
# Their __module__ attribute reflects the C module name '_struct', not the
# Python-level 'struct' wrapper. New to extra177.
# ---------------------------------------------------------------------------

table struct_extra177.pack_unpack_identity:
  description: "struct.pack and struct.unpack name/module identity; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: structfuncs177

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,
       "pack.__name__.__eq__",
       ["pack"],
       true,
       "struct.pack.__name__.__eq__('pack') == True — pack's __name__ is 'pack'; len=4; C extension builtin_function_or_method; new to extra177"]
    - [pack_module_eq,
       "pack.__module__.__eq__",
       ["_struct"],
       true,
       "struct.pack.__module__.__eq__('_struct') == True — pack is implemented in the _struct C extension; new to extra177"]
    - [unpack_name_eq,
       "unpack.__name__.__eq__",
       ["unpack"],
       true,
       "struct.unpack.__name__.__eq__('unpack') == True — unpack's __name__ is 'unpack'; len=6; new to extra177"]
    - [unpack_module_eq,
       "unpack.__module__.__eq__",
       ["_struct"],
       true,
       "struct.unpack.__module__.__eq__('_struct') == True — unpack is implemented in the _struct C extension; new to extra177"]

