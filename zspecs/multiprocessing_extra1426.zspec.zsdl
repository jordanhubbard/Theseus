spec: multiprocessing_extra1426
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing: Process-based parallelism"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — multiprocessing.pool.Pool documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — multiprocessing.queues documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py, Lib/multiprocessing/pool.py, Lib/multiprocessing/queues.py"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for multiprocessing classes."
    - "multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.queues.Queue, multiprocessing.queues.SimpleQueue, multiprocessing.queues.JoinableQueue all have __format__ with type 'method_descriptor'."
    - "All of these classes have __dir__ with type 'method_descriptor'."
    - "None define __format__ or __dir__ in their own __dict__ — both are inherited from object."
    - "multiprocessing.Process.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in multiprocessing.Process.__dict__."
    - "multiprocessing.pool.Pool.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in multiprocessing.pool.Pool.__dict__."
    - "multiprocessing.queues.Queue.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in multiprocessing.queues.Queue.__dict__."
    - "multiprocessing.queues.SimpleQueue.__dir__.__class__.__name__ == 'method_descriptor'; '__dir__' not in multiprocessing.queues.SimpleQueue.__dict__."
    - "multiprocessing.queues.JoinableQueue.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in multiprocessing.queues.JoinableQueue.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1426.format_class_name:
  description: "multiprocessing class __format__.__class__.__name__ identity checks — Process, pool.Pool, queues.Queue, queues.SimpleQueue, queues.JoinableQueue all inherit __format__ from object; type is 'method_descriptor' for all; none define __format__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: format_class_name
  id_prefix: mp1426fm
  columns: [id, function, args, expected]
  rows:
    - [mp1426fm001, multiprocessing.Process.__format__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [mp1426fm002, multiprocessing.pool.Pool.__format__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [mp1426fm003, multiprocessing.queues.Queue.__format__.__class__.__name__.__eq__,         ["method_descriptor"], true]
    - [mp1426fm004, multiprocessing.queues.SimpleQueue.__format__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [mp1426fm005, multiprocessing.queues.JoinableQueue.__format__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [mp1426fm006, multiprocessing.Process.__format__.__class__.__name__.__eq__,              ["method_descriptor"], true]

table multiprocessing_extra1426.format_not_in_dict:
  description: "multiprocessing class __format__ absence from own __dict__ — none of Process, pool.Pool, queues.Queue, queues.SimpleQueue, queues.JoinableQueue define __format__ directly; all inherit from object; __dict__.__contains__('__format__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: format_dict_membership
  id_prefix: mp1426fd
  columns: [id, function, args, expected]
  rows:
    - [mp1426fd001, multiprocessing.Process.__dict__.__contains__,              ["__format__"], false]
    - [mp1426fd002, multiprocessing.pool.Pool.__dict__.__contains__,            ["__format__"], false]
    - [mp1426fd003, multiprocessing.queues.Queue.__dict__.__contains__,         ["__format__"], false]
    - [mp1426fd004, multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__format__"], false]
    - [mp1426fd005, multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__format__"], false]
    - [mp1426fd006, multiprocessing.Process.__dict__.__contains__,              ["__dir__"], false]

table multiprocessing_extra1426.dir_class_name:
  description: "multiprocessing class __dir__.__class__.__name__ identity checks — all classes inherit __dir__ from object; type is 'method_descriptor'; none define __dir__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: dir_class_name
  id_prefix: mp1426dr
  columns: [id, function, args, expected]
  rows:
    - [mp1426dr001, multiprocessing.Process.__dir__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [mp1426dr002, multiprocessing.pool.Pool.__dir__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [mp1426dr003, multiprocessing.queues.Queue.__dir__.__class__.__name__.__eq__,         ["method_descriptor"], true]
    - [mp1426dr004, multiprocessing.queues.SimpleQueue.__dir__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [mp1426dr005, multiprocessing.queues.JoinableQueue.__dir__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [mp1426dr006, multiprocessing.pool.Pool.__dict__.__contains__,                        ["__dir__"], false]

table multiprocessing_extra1426.dir_not_in_dict:
  description: "multiprocessing class __dir__ absence from own __dict__ — none of Process, pool.Pool, queues.Queue, queues.SimpleQueue, queues.JoinableQueue define __dir__ directly; all inherit from object; verified with Python 3.14.3"
