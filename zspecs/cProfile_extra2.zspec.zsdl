spec: cProfile_extra2
version: ">=3.0"
backend: python_module(cProfile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_lsprof.c"
  notes:
    - "This spec extends cProfile.zspec.zsdl and cProfile_extra.zspec.zsdl."
    - "cProfile.zspec.zsdl covers: Profile/__name__/__module__, run/__name__, runctx/__name__, Profile method __name__ (enable/disable/clear/print_stats/dump_stats/runcall/runctx)."
    - "cProfile_extra covers: Profile/__qualname__, run/__qualname__/__module__, runctx/__qualname__/__module__."
    - "NEW in this spec: cProfile.Profile.__bases__[0].__name__=='Profiler' (C extension base); cProfile.Profile.__bases__[0].__module__=='_lsprof'; cProfile.Profile.__bases__[0].__qualname__=='Profiler'; cProfile.Profile.__bases__.__len__()==1; cProfile.Profile.__mro__ (length 3, entries: Profile/Profiler/object); cProfile.Profile.__class__.__name__=='type'; cProfile.run/__class__.__name__ and cProfile.runctx/__class__.__name__; cProfile.Profile.__name__=='Profile' and cProfile.Profile.__module__=='cProfile' via __eq__ predicate."
    - "cProfile.Profile.__bases__[0].__name__ == 'Profiler' — the C extension base class from _lsprof (verified runtime)."
    - "cProfile.Profile.__bases__[0].__module__ == '_lsprof' — the base class Profiler lives in the _lsprof C extension (verified runtime)."
    - "cProfile.Profile.__bases__[0].__qualname__ == 'Profiler' — qualname of the C extension base class (verified runtime)."
    - "cProfile.Profile.__bases__.__len__() == 1 — Profile has exactly one direct base class (verified runtime)."
    - "cProfile.Profile.__mro__.__len__() == 3 — MRO is [Profile, Profiler, object] (verified runtime)."
    - "cProfile.Profile.__module__ == 'cProfile' — NOT '_lsprof'; the Python wrapper class is defined in cProfile (verified runtime; the task description was inaccurate)."
    - "cProfile.Profile.__class__.__name__ == 'type' — Profile is a Python-level class object (verified runtime)."
    - "cProfile.run.__class__.__name__ == 'function' — run is a plain Python function (verified runtime)."
    - "cProfile.runctx.__class__.__name__ == 'function' — runctx is a plain Python function (verified runtime)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cProfile.Profile identity — __eq__ predicate form
# cProfile.zspec.zsdl checks Profile/__name__ and /__module__ as direct string values.
# cProfile_extra checks Profile/__qualname__ via __eq__ predicate.
# These invariants apply the __eq__ predicate form to __name__ and __module__
# specifically — not covered by any prior cProfile spec in this form.
# ---------------------------------------------------------------------------

invariant cProfile_extra2.Profile.name_eq:
  description: "cProfile.Profile.__name__.__eq__('Profile') == True"
  category: classes
  kind: python_call_eq
  function: Profile.__name__.__eq__
  args: ["Profile"]
  expected: true

invariant cProfile_extra2.Profile.module_eq:
  description: "cProfile.Profile.__module__.__eq__('cProfile') == True — wrapper class is defined in cProfile, not _lsprof"
  category: classes
  kind: python_call_eq
  function: Profile.__module__.__eq__
  args: ["cProfile"]
  expected: true

# ---------------------------------------------------------------------------
# cProfile.Profile.__class__.__name__ — metaclass verification
# No prior cProfile spec checks Profile.__class__.__name__.
# ---------------------------------------------------------------------------

invariant cProfile_extra2.Profile.class_name:
  description: "cProfile.Profile.__class__.__name__ == 'type' — Profile is a class object whose metaclass is type"
  category: classes
  kind: python_call_eq
  function: Profile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# cProfile.Profile base class — C extension Profiler from _lsprof
# No prior cProfile spec examines __bases__ at all.
# cProfile.Profile inherits from _lsprof.Profiler (a C extension type).
# ---------------------------------------------------------------------------

invariant cProfile_extra2.Profile.bases_len:
  description: "len(cProfile.Profile.__bases__) == 1 — Profile has exactly one direct base class (_lsprof.Profiler)"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__len__
  args: []
  expected: 1

invariant cProfile_extra2.Profile.base0_name:
  description: "cProfile.Profile.__bases__[0].__name__ == 'Profiler' — base class is the C extension _lsprof.Profiler"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Profiler"]
  expected: true

invariant cProfile_extra2.Profile.base0_module:
  description: "cProfile.Profile.__bases__[0].__module__ == '_lsprof' — base class Profiler lives in the _lsprof C extension"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__getitem__
  args: [0]
  method: __module__.__eq__
  method_args: ["_lsprof"]
  expected: true

invariant cProfile_extra2.Profile.base0_qualname:
  description: "cProfile.Profile.__bases__[0].__qualname__ == 'Profiler' — C extension class qualname equals name"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__getitem__
  args: [0]
  method: __qualname__.__eq__
  method_args: ["Profiler"]
  expected: true

# ---------------------------------------------------------------------------
# cProfile.Profile MRO — length and entry names
# No prior cProfile spec examines __mro__.
# MRO is [Profile, Profiler, object] — 3 entries.
# ---------------------------------------------------------------------------

invariant cProfile_extra2.Profile.mro_len:
  description: "len(cProfile.Profile.__mro__) == 3 — MRO is [Profile, _lsprof.Profiler, object]"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__mro__.__len__
  args: []
  expected: 3

table cProfile_extra2.Profile.mro_names:
  description: "cProfile.Profile.__mro__ entry names at indices 0..2"
  kind: python_call_eq
  category: hierarchy
  id_prefix: mro

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [mro0_name, Profile.__mro__.__getitem__, [0], __name__.__eq__, ["Profile"],  true]
    - [mro1_name, Profile.__mro__.__getitem__, [1], __name__.__eq__, ["Profiler"], true]
    - [mro2_name, Profile.__mro__.__getitem__, [2], __name__.__eq__, ["object"],   true]

# ---------------------------------------------------------------------------
# cProfile module-level function __class__.__name__ — type verification
# cProfile.zspec.zsdl and cProfile_extra confirm run and runctx __name__ and
# __qualname__ but do not check their runtime type (__class__.__name__).
# ---------------------------------------------------------------------------

invariant cProfile_extra2.run.class_name:
  description: "cProfile.run.__class__.__name__ == 'function' — run is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: run.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant cProfile_extra2.runctx.class_name:
  description: "cProfile.runctx.__class__.__name__ == 'function' — runctx is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: runctx.__class__.__name__.__eq__
  args: ["function"]
  expected: true
