spec: functools_extra130
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial class identity and method qualnames (Wave 257)."
    - "functools.partial.__name__ == 'partial' — partial is a C extension type defined in Modules/_functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — the C type sets its __module__ to 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object. Verified with Python 3.14.3."
    - "len(functools.partial.__mro__) == 2 — MRO is [partial, object]. Verified with Python 3.14.3."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16) — wrapper_descriptor on the C type. Verified with Python 3.14.3."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15) — builtin_function_or_method. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16) — wrapper_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__setstate__.__qualname__ == 'partial.__setstate__' (len 20) — method_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__qualname__ == 'partial.__reduce__' (len 18) — method_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial' (len 7). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial class name, module, qualname, MRO
#
# Wave 257 theme: functools.partial C extension type identity.
#
# functools.partial.__name__ == 'partial'
# functools.partial.__module__ == 'functools'
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__qualname__ == 'partial'
# len(functools.partial.__mro__) == 2
# functools.partial.__bases__[0].__name__ == 'object'
#
# partial is a C extension type (not a pure-Python class); its metaclass is
# 'type'; it inherits directly from object; MRO length is 2. New to extra130.
# ---------------------------------------------------------------------------

table functools_extra130.partial_type_identity:
  description: "functools.partial C extension type identity: __name__, __module__, __class__.__name__, __qualname__, MRO len, __bases__[0]; wave 257; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial130

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq_partial,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C extension type defined in Modules/_functoolsmodule.c; its __name__ attribute is set from the PyTypeObject tp_name field to 'partial'; str.__eq__('partial') returns True; new to extra130"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is a C extension type exposed through the functools module; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra130"]
    - [partial_class_name_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a proper C extension class whose metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra130"]
    - [partial_qualname_eq_partial,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is defined at module scope in the C extension; its __qualname__ is the simple type name 'partial'; str.__eq__('partial') returns True; new to extra130"]
    - [partial_qualname_len_eq_7,
       "partial.__qualname__.__len__",
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — __qualname__ is 'partial' which has exactly 7 characters; len('partial') == 7; new to extra130"]
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial inherits directly from object with no intermediate base classes; MRO is [partial, object]; len(__mro__) is 2; new to extra130"]
    - [partial_bases_first_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object; its only base class is the built-in object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra130"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial slot method qualnames
#
# Wave 257 theme: functools.partial __call__, __new__, __repr__ qualnames.
#
# functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16)
# functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15)
# functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16)
# functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method'
# functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor'
#
# Slot methods on C extension types have qualnames of the form 'typename.method'.
# __call__ and __repr__ are wrapper_descriptors; __new__ is a builtin_function_or_method.
# New to extra130.
# ---------------------------------------------------------------------------

table functools_extra130.partial_slot_qualnames:
  description: "functools.partial __call__, __new__, __repr__ qualnames and class names; C extension slot methods; wave 257; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial130

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_qualname_eq,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — the __call__ slot method on the partial C extension type has a qualname of the form 'typename.method'; __qualname__ is 'partial.__call__'; str.__eq__('partial.__call__') returns True; new to extra130"]
    - [partial_call_qualname_len_eq_16,
       "partial.__call__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — 'partial.__call__' has exactly 16 characters (7 + 1 + 8); len('partial.__call__') == 16; new to extra130"]
    - [partial_call_class_name_eq_wrapper_descriptor,
       "partial.__call__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — when accessed on the type (not an instance), __call__ on a C extension type is exposed as a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra130"]
    - [partial_new_qualname_eq,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — the __new__ method on partial has qualname 'partial.__new__'; str.__eq__('partial.__new__') returns True; new to extra130"]
    - [partial_new_qualname_len_eq_15,
       "partial.__new__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__new__.__qualname__.__len__() == 15 — 'partial.__new__' has exactly 15 characters (7 + 1 + 7); len('partial.__new__') == 15; new to extra130"]
    - [partial_repr_qualname_eq,
       "partial.__repr__.__qualname__.__eq__",
       ["partial.__repr__"],
       true,
       "functools.partial.__repr__.__qualname__.__eq__('partial.__repr__') == True — the __repr__ slot method on partial has qualname 'partial.__repr__'; str.__eq__('partial.__repr__') returns True; new to extra130"]
    - [partial_repr_qualname_len_eq_16,
       "partial.__repr__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__repr__.__qualname__.__len__() == 16 — 'partial.__repr__' has exactly 16 characters (7 + 1 + 8); len('partial.__repr__') == 16; new to extra130"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial __setstate__ and __reduce__ qualnames
#
# Wave 257 theme: functools.partial descriptor method qualnames.
#
# functools.partial.__setstate__.__qualname__ == 'partial.__setstate__' (len 20)
# functools.partial.__setstate__.__class__.__name__ == 'method_descriptor'
# functools.partial.__reduce__.__qualname__ == 'partial.__reduce__' (len 18)
# functools.partial.__reduce__.__class__.__name__ == 'method_descriptor'
#
# __setstate__ and __reduce__ are method_descriptors (not wrapper_descriptors);
# they are used by pickle to serialize and reconstruct partial objects.
# New to extra130.
# ---------------------------------------------------------------------------

table functools_extra130.partial_descriptor_qualnames:
  description: "functools.partial __setstate__ and __reduce__ qualnames and class names; method_descriptor methods; wave 257; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial130

  columns: [id, function, args, expected, description]
  rows:
    - [partial_setstate_qualname_eq,
       "partial.__setstate__.__qualname__.__eq__",
       ["partial.__setstate__"],
       true,
       "functools.partial.__setstate__.__qualname__.__eq__('partial.__setstate__') == True — __setstate__ is a method_descriptor on the partial C type used for pickle deserialization; its qualname follows the 'typename.method' pattern; str.__eq__('partial.__setstate__') returns True; new to extra130"]
    - [partial_setstate_qualname_len_eq_20,
       "partial.__setstate__.__qualname__.__len__",
       [],
       20,
       "functools.partial.__setstate__.__qualname__.__len__() == 20 — 'partial.__setstate__' has exactly 20 characters (7 + 1 + 12); len('partial.__setstate__') == 20; new to extra130"]
    - [partial_setstate_class_name_eq_method_descriptor,
       "partial.__setstate__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__setstate__.__class__.__name__.__eq__('method_descriptor') == True — __setstate__ on a C extension type is a method_descriptor (not a wrapper_descriptor); __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra130"]
    - [partial_reduce_qualname_eq,
       "partial.__reduce__.__qualname__.__eq__",
       ["partial.__reduce__"],
       true,
       "functools.partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True — __reduce__ is a method_descriptor on the partial C type used for pickling; its qualname is 'partial.__reduce__'; str.__eq__('partial.__reduce__') returns True; new to extra130"]
    - [partial_reduce_qualname_len_eq_18,
       "partial.__reduce__.__qualname__.__len__",
       [],
       18,
       "functools.partial.__reduce__.__qualname__.__len__() == 18 — 'partial.__reduce__' has exactly 18 characters (7 + 1 + 10); len('partial.__reduce__') == 18; new to extra130"]
    - [partial_reduce_class_name_eq_method_descriptor,
       "partial.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — __reduce__ on partial is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra130"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra130
# ---------------------------------------------------------------------------

invariant functools_extra130.partial_name:
  description: "functools.partial.__name__ == 'partial' — C extension type; tp_name field; wave 257; new to extra130"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra130.partial_module:
  description: "functools.partial.__module__ == 'functools' — C extension type exposed through functools; wave 257; new to extra130"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra130.partial_mro_len:
  description: "len(functools.partial.__mro__) == 2 — MRO is [partial, object]; inherits directly from object; wave 257; new to extra130"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra130.partial_call_qualname_len:
  description: "len(functools.partial.__call__.__qualname__) == 16 — 'partial.__call__' has 16 chars; wave 257; new to extra130"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__len__
  args: []
  expected: 16

invariant functools_extra130.partial_setstate_class_name:
  description: "functools.partial.__setstate__.__class__.__name__ == 'method_descriptor' — pickle helper method; wave 257; new to extra130"
  kind: python_call_eq
  function: partial.__setstate__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
