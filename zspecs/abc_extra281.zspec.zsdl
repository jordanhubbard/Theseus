spec: abc_extra281
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — abstract method counts and frozenset type of __abstractmethods__"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Sequence.__abstractmethods__ has 2 entries: __getitem__ and __len__"
    - "collections.abc.Mapping.__abstractmethods__ has 3 entries: __getitem__, __iter__, __len__"
    - "collections.abc.Set.__abstractmethods__ has 3 entries: __contains__, __iter__, __len__"
    - "__abstractmethods__ is always of type frozenset"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra281.abstractmethods_counts:
  description: "Abstract method counts for core ABC classes"
  kind: python_call_eq
  category: identity
  id_prefix: abc281c

  columns: [id, function, args, expected, description]
  rows:
    - [abc281c001, collections.abc.Sequence.__abstractmethods__.__len__, [], 2, "Sequence has 2 abstract methods: __getitem__, __len__"]
    - [abc281c002, collections.abc.Mapping.__abstractmethods__.__len__, [], 3, "Mapping has 3 abstract methods: __getitem__, __iter__, __len__"]
    - [abc281c003, collections.abc.Set.__abstractmethods__.__len__, [], 3, "Set has 3 abstract methods: __contains__, __iter__, __len__"]
    - [abc281c004, collections.abc.Iterable.__abstractmethods__.__len__, [], 1, "Iterable has 1 abstract method: __iter__"]
    - [abc281c005, collections.abc.Iterator.__abstractmethods__.__len__, [], 1, "Iterator has 1 abstract method: __next__"]
    - [abc281c006, collections.abc.Callable.__abstractmethods__.__len__, [], 1, "Callable has 1 abstract method: __call__"]
    - [abc281c007, collections.abc.Hashable.__abstractmethods__.__len__, [], 1, "Hashable has 1 abstract method: __hash__"]
    - [abc281c008, collections.abc.Sized.__abstractmethods__.__len__, [], 1, "Sized has 1 abstract method: __len__"]
    - [abc281c009, collections.abc.Container.__abstractmethods__.__len__, [], 1, "Container has 1 abstract method: __contains__"]

table abc_extra281.abstractmethods_type:
  description: "__abstractmethods__.__class__.__name__ == 'frozenset' for core ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc281t

  columns: [id, function, args, expected, description]
  rows:
    - [abc281t001, collections.abc.Sequence.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Sequence.__abstractmethods__ is a frozenset"]
    - [abc281t002, collections.abc.Mapping.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Mapping.__abstractmethods__ is a frozenset"]
    - [abc281t003, collections.abc.Set.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Set.__abstractmethods__ is a frozenset"]
    - [abc281t004, collections.abc.Iterable.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Iterable.__abstractmethods__ is a frozenset"]
    - [abc281t005, collections.abc.Iterator.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Iterator.__abstractmethods__ is a frozenset"]
    - [abc281t006, collections.abc.Callable.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Callable.__abstractmethods__ is a frozenset"]
    - [abc281t007, collections.abc.Hashable.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Hashable.__abstractmethods__ is a frozenset"]
    - [abc281t008, collections.abc.Sized.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Sized.__abstractmethods__ is a frozenset"]
    - [abc281t009, collections.abc.Container.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "Container.__abstractmethods__ is a frozenset"]

invariant abc_extra281.sequence_count_confirmed:
  description: "Sequence has exactly 2 abstract methods"
  category: identity
  kind: python_call_eq
  function: collections.abc.Sequence.__abstractmethods__.__len__
  args: []
  expected: 2

invariant abc_extra281.mapping_count_confirmed:
  description: "Mapping has exactly 3 abstract methods"
  category: identity
  kind: python_call_eq
  function: collections.abc.Mapping.__abstractmethods__.__len__
  args: []
  expected: 3

invariant abc_extra281.mutablesequence_count:
  description: "MutableSequence has exactly 2 abstract methods: __getitem__, __len__, __setitem__, __delitem__, insert -> actually 5"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableSequence.__abstractmethods__.__len__
  args: []
  expected: 5

invariant abc_extra281.set_count_confirmed:
  description: "Set has exactly 3 abstract methods: __contains__, __iter__, __len__"
  category: identity
  kind: python_call_eq
  function: collections.abc.Set.__abstractmethods__.__len__
  args: []
  expected: 3
