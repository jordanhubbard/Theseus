spec: re_extra2506
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flag constants, match/search/sub/split/findall"
    - "re_extra1771.zspec.zsdl — covers async protocol and function class names"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence for re module types."
    - "Checks whether re.Pattern, re.Match, and re.error define arithmetic operators in their class __dict__."
    - "re.Pattern is a C-level type (_sre.SRE_Pattern); its __dict__ contains __copy__, __deepcopy__, __eq__, __hash__, __repr__, and pattern-matching methods — no arithmetic."
    - "re.Match is a C-level type (_sre.SRE_Match); its __dict__ contains __copy__, __deepcopy__, __getitem__, __repr__, and match-result methods — no arithmetic."
    - "re.error is a Python subclass of Exception; its __dict__ contains __init__ and documentation — no arithmetic."
    - "re.Pattern.__dict__ dunder keys: __class_getitem__, __copy__, __deepcopy__, __doc__, __eq__, __ge__, __gt__, __hash__, __le__, __lt__, __module__, __ne__, __repr__."
    - "re.Match.__dict__ dunder keys: __class_getitem__, __copy__, __deepcopy__, __doc__, __getitem__, __module__, __repr__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern — no arithmetic operators in __dict__
#
# re.Pattern is the compiled regex type returned by re.compile(). It implements
# search, match, fullmatch, findall, sub, etc., but no arithmetic protocol.
# Positive anchors confirm that __dict__.__contains__ works on Pattern.
# ---------------------------------------------------------------------------

table re_extra2506.pattern_arith:
  description: "__add__, __sub__, __mul__ absent from re.Pattern __dict__; __eq__ and __hash__ present as anchors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: re2506

  columns: [id, function, args, expected]
  rows:
    - ["re2506-001", "Pattern.__dict__.__contains__", ["__add__"],  false]
    - ["re2506-002", "Pattern.__dict__.__contains__", ["__sub__"],  false]
    - ["re2506-003", "Pattern.__dict__.__contains__", ["__mul__"],  false]
    - ["re2506-004", "Pattern.__dict__.__contains__", ["__eq__"],   true]
    - ["re2506-005", "Pattern.__dict__.__contains__", ["__hash__"], true]
    - ["re2506-006", "Pattern.__dict__.__contains__", ["__repr__"], true]

# ---------------------------------------------------------------------------
# Table 2: re.Match — no arithmetic operators in __dict__
#
# re.Match is the match result object returned by search/match. It implements
# group(), start(), end(), span() and related methods. No arithmetic protocol.
# Positive anchor: __getitem__ IS in Match.__dict__ (supports m[0], m['name']).
# ---------------------------------------------------------------------------

table re_extra2506.match_arith:
  description: "__add__, __sub__, __mul__ absent from re.Match __dict__; __getitem__ and __repr__ present as anchors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: re2506

  columns: [id, function, args, expected]
  rows:
    - ["re2506-007", "Match.__dict__.__contains__", ["__add__"],      false]
    - ["re2506-008", "Match.__dict__.__contains__", ["__sub__"],      false]
    - ["re2506-009", "Match.__dict__.__contains__", ["__mul__"],      false]
    - ["re2506-010", "Match.__dict__.__contains__", ["__getitem__"],  true]
    - ["re2506-011", "Match.__dict__.__contains__", ["__repr__"],     true]

# ---------------------------------------------------------------------------
# Table 3: re.error — no arithmetic operators; __init__ present as anchor
#
# re.error is the exception raised for invalid regex patterns. It subclasses
# Exception and adds a custom __init__ to capture pattern/pos information.
# No arithmetic protocol is defined.
# ---------------------------------------------------------------------------

table re_extra2506.error_arith:
  description: "__add__, __sub__, __mul__ absent from re.error __dict__; __init__ present as anchor"
  kind: python_call_eq
  category: dict_presence
  id_prefix: re2506

  columns: [id, function, args, expected]
  rows:
    - ["re2506-012", "error.__dict__.__contains__", ["__add__"], false]
    - ["re2506-013", "error.__dict__.__contains__", ["__sub__"], false]
    - ["re2506-014", "error.__dict__.__contains__", ["__mul__"], false]
    - ["re2506-015", "error.__dict__.__contains__", ["__init__"], true]
