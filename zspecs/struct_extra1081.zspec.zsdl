spec: struct_extra1081
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.error __module__, __qualname__, __name__; struct.__spec__.name; struct.pack.__doc__.__class__.__name__; module __doc__.__class__.__name__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1081.error_class_attrs:
  description: "struct.error __module__, __qualname__, __name__ identity"
  kind: python_call_eq
  category: error_class_attrs
  id_prefix: st1081ec
  columns: [id, function, args, expected]
  rows:
    - [st1081ec001, struct.error.__module__.__eq__,                       ["struct"],       true]
    - [st1081ec002, struct.error.__qualname__.__eq__,                     ["error"],        true]
    - [st1081ec003, struct.error.__name__.__eq__,                         ["error"],        true]
    - [st1081ec004, struct.error.__module__.__class__.__name__.__eq__,    ["str"],          true]
    - [st1081ec005, struct.error.__qualname__.__class__.__name__.__eq__,  ["str"],          true]
    - [st1081ec006, struct.error.__name__.__class__.__name__.__eq__,      ["str"],          true]
    - [st1081ec007, struct.error.__class__.__name__.__eq__,               ["type"],         true]
    - [st1081ec008, struct.error.__doc__.__class__.__name__.__eq__,       ["str"],          true]

table struct_extra1081.module_spec_and_doc:
  description: "struct.__spec__.name and module/function __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: module_spec_doc
  id_prefix: st1081sd
  columns: [id, function, args, expected]
  rows:
    - [st1081sd001, struct.__spec__.name.__eq__,                           ["struct"],      true]
    - [st1081sd002, struct.__spec__.name.__class__.__name__.__eq__,        ["str"],         true]
    - [st1081sd003, struct.__doc__.__class__.__name__.__eq__,              ["str"],         true]
    - [st1081sd004, struct.pack.__doc__.__class__.__name__.__eq__,         ["str"],         true]
    - [st1081sd005, struct.unpack.__doc__.__class__.__name__.__eq__,       ["str"],         true]
    - [st1081sd006, struct.calcsize.__doc__.__class__.__name__.__eq__,     ["str"],         true]
    - [st1081sd007, struct.pack_into.__doc__.__class__.__name__.__eq__,    ["str"],         true]
    - [st1081sd008, struct.unpack_from.__doc__.__class__.__name__.__eq__,  ["str"],         true]
    - [st1081sd009, struct.iter_unpack.__doc__.__class__.__name__.__eq__,  ["str"],         true]

table struct_extra1081.struct_method_qualnames:
  description: "struct.Struct method __qualname__ identity for pack, unpack, pack_into, unpack_from, iter_unpack"
  kind: python_call_eq
  category: struct_method_qualnames
  id_prefix: st1081mq
  columns: [id, function, args, expected]
  rows:
    - [st1081mq001, struct.Struct.pack.__qualname__.__eq__,        ["Struct.pack"],        true]
    - [st1081mq002, struct.Struct.unpack.__qualname__.__eq__,      ["Struct.unpack"],      true]
    - [st1081mq003, struct.Struct.pack_into.__qualname__.__eq__,   ["Struct.pack_into"],   true]
    - [st1081mq004, struct.Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
    - [st1081mq005, struct.Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true]
    - [st1081mq006, struct.Struct.pack.__qualname__.__class__.__name__.__eq__,        ["str"], true]
    - [st1081mq007, struct.Struct.unpack.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [st1081mq008, struct.Struct.pack_into.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [st1081mq009, struct.Struct.unpack_from.__qualname__.__class__.__name__.__eq__, ["str"], true]
