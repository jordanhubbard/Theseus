    - ["sk1651034", "__dict__.__contains__", ["SO_REUSEADDR"],     true]
    - ["sk1651035", "__dict__.__contains__", ["IPPROTO_TCP"],      true]
    - ["sk1651036", "__dict__.__contains__", ["IPPROTO_UDP"],      true]
    - ["sk1651037", "__dict__.__contains__", ["TCP_NODELAY"],      true]
    - ["sk1651038", "__dict__.__contains__", ["gethostname"],      true]
    - ["sk1651039", "__dict__.__contains__", ["gethostbyname"],    true]
    - ["sk1651040", "__dict__.__contains__", ["getaddrinfo"],      true]
    - ["sk1651041", "__dict__.__contains__", ["getfqdn"],          true]
    - ["sk1651042", "__dict__.__contains__", ["inet_aton"],        true]
    - ["sk1651043", "__dict__.__contains__", ["inet_ntoa"],        true]
    - ["sk1651044", "__dict__.__contains__", ["setdefaulttimeout"],true]
    - ["sk1651045", "__dict__.__contains__", ["getdefaulttimeout"],true]
    - ["sk1651046", "__dict__.__contains__", ["create_connection"],true]
    - ["sk1651047", "__dict__.__contains__", ["create_server"],    true]
    - ["sk1651048", "__dict__.__contains__", ["error"],            true]
    - ["sk1651049", "__dict__.__contains__", ["timeout"],          true]
    - ["sk1651050", "__dict__.__contains__", ["herror"],           true]

# ---------------------------------------------------------------------------
# Table 3: socket constants value presence and error class attributes
#
# We verify that key socket constants are accessible via the module and that
# the exception classes (herror, gaierror, timeout, error) are present.
# Also checks absence of class-creation protocol hooks at module level and
# on the AddressFamily/SocketKind enum classes.
# ---------------------------------------------------------------------------

table socket_extra1651.socket_constants_present:
  description: "socket module exports exception classes, enum classes, and is free of class-creation hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1651

  columns: [id, function, args, expected]
  rows:
    - ["sk1651051", "__dict__.__contains__", ["gaierror"],          true]
    - ["sk1651052", "__dict__.__contains__", ["AddressFamily"],     true]
    - ["sk1651053", "__dict__.__contains__", ["SocketKind"],        true]
    - ["sk1651054", "__dict__.__contains__", ["__init_subclass__"], false]
    - ["sk1651055", "__dict__.__contains__", ["__set_name__"],      false]
    - ["sk1651056", "__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk1651057", "AddressFamily.__dict__.__contains__", ["__init_subclass__"], false]
    - ["sk1651058", "AddressFamily.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk1651059", "AddressFamily.__dict__.__contains__", ["__set_name__"],      false]
    - ["sk1651060", "SocketKind.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["sk1651061", "SocketKind.__dict__.__contains__",    ["__class_getitem__"], false]
    - ["sk1651062", "SocketKind.__dict__.__contains__",    ["__set_name__"],      false]
    - ["sk1651063", "AddressFamily.__dict__.__contains__", ["AF_INET"],           true]
    - ["sk1651064", "AddressFamily.__dict__.__contains__", ["AF_INET6"],          true]
    - ["sk1651065", "SocketKind.__dict__.__contains__",    ["SOCK_STREAM"],       true]
    - ["sk1651066", "SocketKind.__dict__.__contains__",    ["SOCK_DGRAM"],        true]
    - ["sk1651067", "error.__name__.__eq__",               ["OSError"],           true]
    - ["sk1651068", "timeout.__name__.__eq__",             ["TimeoutError"],      true]
    - ["sk1651069", "herror.__bases__.__getitem__",        [0],                   "OSError"]
    - ["sk1651070", "gaierror.__bases__.__getitem__",      [0],                   "OSError"]
    - ["sk1651071", "AddressFamily.__bases__.__getitem__", [0],                   "IntEnum"]
    - ["sk1651072", "SocketKind.__bases__.__getitem__",    [0],                   "IntEnum"]
    - ["sk1651073", "AF_INET.__class__.__name__.__eq__",   ["AddressFamily"],     true]
    - ["sk1651074", "SOCK_STREAM.__class__.__name__.__eq__",["SocketKind"],       true]
    - ["sk1651075", "__dict__.__contains__", ["htonl"],             true]
