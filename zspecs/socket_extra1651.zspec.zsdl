spec: socket_extra1651
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "behavioral invariants for __init_subclass__, __set_name__, and __class_getitem__ class creation and parameterization protocol"
    - "socket.socket is a Python class defined in Lib/socket.py; it does not define __init_subclass__ in its own __dict__ — inherited from object."
    - "socket.herror and socket.gaierror are concrete subclasses of OSError; their own __dict__ also lacks __init_subclass__."
    - "socket.socket does not define __set_name__ — it is not a descriptor."
    - "socket.socket does not define __class_getitem__ in its own __dict__ — it is not a generic type."
    - "socket.error is an alias for OSError (Python 3.3+); socket.timeout is an alias for TimeoutError (Python 3.3+)."
    - "socket.AF_UNIX is present on POSIX platforms (macOS/Darwin, Linux); may be absent on Windows."
    - "socket.SO_REUSEPORT is platform-dependent; present on macOS/Darwin and Linux kernel >= 3.9."
    - "socket.create_server was added in Python 3.8; socket.create_connection in Python 3.0."
    - "object.__init_subclass__ is always present as the universal no-op fallback hook."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: socket.socket and exception classes do not define __init_subclass__,
# __set_name__, or __class_getitem__ in their own __dict__.
#
# socket.socket is a plain Python class. socket.herror and socket.gaierror
# inherit from OSError. None of them are ABCs or generic types, so none define
# the class-creation protocol hooks in their own __dict__. The universal
# __init_subclass__ no-op lives on object and is inherited via the MRO.
# ---------------------------------------------------------------------------

table socket_extra1651.no_init_subclass:
  description: "socket.socket and exception classes do not define __init_subclass__, __set_name__, or __class_getitem__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1651

  columns: [id, function, args, expected]
  rows:
    - ["sk1651001", "socket.__dict__.__contains__", ["__init_subclass__"], false]
    - ["sk1651002", "herror.__dict__.__contains__", ["__init_subclass__"], false]
    - ["sk1651003", "gaierror.__dict__.__contains__",["__init_subclass__"], false]
    - ["sk1651004", "socket.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk1651005", "herror.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk1651006", "gaierror.__dict__.__contains__",["__class_getitem__"], false]
    - ["sk1651007", "socket.__dict__.__contains__", ["__set_name__"],      false]
    - ["sk1651008", "herror.__dict__.__contains__", ["__set_name__"],      false]
    - ["sk1651009", "gaierror.__dict__.__contains__",["__set_name__"],     false]
    - ["sk1651010", "object.__dict__.__contains__", ["__init_subclass__"], true]
    - ["sk1651011", "object.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk1651012", "object.__dict__.__contains__", ["__set_name__"],      false]
    - ["sk1651013", "socket.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["sk1651014", "socket.__dict__.__contains__", ["__instancecheck__"], false]
    - ["sk1651015", "socket.__dict__.__contains__", ["fileno"],            true]
    - ["sk1651016", "socket.__dict__.__contains__", ["bind"],              true]
    - ["sk1651017", "socket.__dict__.__contains__", ["connect"],           true]
    - ["sk1651018", "socket.__dict__.__contains__", ["close"],             true]
    - ["sk1651019", "socket.__dict__.__contains__", ["send"],              true]
    - ["sk1651020", "socket.__dict__.__contains__", ["recv"],              true]
    - ["sk1651021", "socket.__name__.__eq__",        ["socket"],           true]
    - ["sk1651022", "socket.__module__.__eq__",      ["socket"],           true]
    - ["sk1651023", "herror.__name__.__eq__",         ["herror"],          true]
    - ["sk1651024", "gaierror.__name__.__eq__",       ["gaierror"],        true]
    - ["sk1651025", "socket.__bases__.__getitem__",   [0],                 "object"]

# ---------------------------------------------------------------------------
# Table 2: socket module-level attribute presence
#
# The socket module exports a large set of constants, classes, and functions.
# We verify presence of socket constants, address families, socket kinds,
# protocol numbers, and utility functions via __dict__.__contains__.
# AF_UNIX is present on POSIX platforms; SO_REUSEPORT is platform-dependent.
# ---------------------------------------------------------------------------

table socket_extra1651.module_attr_presence:
  description: "socket module-level attributes are present in socket.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1651

  columns: [id, function, args, expected]
  rows:
    - ["sk1651026", "__dict__.__contains__", ["socket"],           true]
    - ["sk1651027", "__dict__.__contains__", ["AF_INET"],          true]
    - ["sk1651028", "__dict__.__contains__", ["AF_INET6"],         true]
    - ["sk1651029", "__dict__.__contains__", ["AF_UNIX"],          true]
    - ["sk1651030", "__dict__.__contains__", ["SOCK_STREAM"],      true]
    - ["sk1651031", "__dict__.__contains__", ["SOCK_DGRAM"],       true]
    - ["sk1651032", "__dict__.__contains__", ["SOCK_RAW"],         true]
