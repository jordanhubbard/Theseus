spec: fractions_extra10
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra9)."
    - "fractions_extra2: Fraction.__add__.__name__ == '__add__'."
    - "fractions_extra9: Fraction.limit_denominator.__name__ == 'limit_denominator'."
    - "No prior spec covers Fraction.__sub__.__name__ == '__sub__' as a standalone invariant."
    - "No prior spec covers Fraction.__mul__.__name__ == '__mul__' as a standalone invariant."
    - "No prior spec covers Fraction.__truediv__.__name__ == '__truediv__' as a standalone invariant."
    - "No prior spec covers Fraction.__neg__.__name__ == '__neg__' as a standalone invariant."
    - "No prior spec covers Fraction.__abs__.__name__ == '__abs__' as a standalone invariant."
    - "No prior spec covers Fraction(2, 5).numerator == 2 or .denominator == 5."
    - "No prior spec covers Fraction('7/8').numerator == 7 or .denominator == 8."
    - "No prior spec covers Fraction(3, 4).as_integer_ratio()[0] == 3 or [1] == 4."
    - "Fraction.__sub__.__name__ == '__sub__' — method name identity for subtraction operator."
    - "Fraction.__mul__.__name__ == '__mul__' — method name identity for multiplication operator."
    - "Fraction.__truediv__.__name__ == '__truediv__' — method name identity for true division."
    - "Fraction.__neg__.__name__ == '__neg__' — method name identity for negation."
    - "Fraction.__abs__.__name__ == '__abs__' — method name identity for absolute value."
    - "Fraction(2, 5).numerator == 2 — prime-to-each-other inputs, no reduction."
    - "Fraction(2, 5).denominator == 5 — prime-to-each-other inputs, no reduction."
    - "Fraction('7/8').numerator == 7 — string constructor with slash notation."
    - "Fraction('7/8').denominator == 8 — string constructor with slash notation."
    - "Fraction(3, 4).as_integer_ratio()[0] == 3 — returns (numerator, denominator)."
    - "Fraction(3, 4).as_integer_ratio()[1] == 4 — returns (numerator, denominator)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Arithmetic method name identities — __sub__, __mul__, __truediv__, __neg__, __abs__
#
# fractions_extra2 covers Fraction.__add__.__name__ == '__add__'.
# fractions_extra9 covers Fraction.limit_denominator.__name__.
# No prior spec covers the remaining arithmetic dunder method names as standalone
# invariants in the fractions_extra10 namespace.
# ---------------------------------------------------------------------------

table fractions_extra10.method_names:
  kind: python_call_eq
  category: method_identity
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [sub,      Fraction.__sub__.__name__.__eq__,      ["__sub__"],      true]
    - [mul,      Fraction.__mul__.__name__.__eq__,      ["__mul__"],      true]
    - [truediv,  Fraction.__truediv__.__name__.__eq__,  ["__truediv__"],  true]
    - [neg,      Fraction.__neg__.__name__.__eq__,      ["__neg__"],      true]
    - [abs,      Fraction.__abs__.__name__.__eq__,      ["__abs__"],      true]

# ---------------------------------------------------------------------------
# Fraction(2, 5) — coprime inputs, no reduction
#
# fractions_extra4 covers Fraction(1,3)/Fraction(-1,3)/Fraction(0,5) numerator/denominator.
# fractions_extra8 covers Fraction(1,2)/Fraction(3,6)/Fraction(-1,2) numerator/denominator.
# No prior spec covers Fraction(2, 5) where 2 and 5 are coprime so no reduction occurs.
# ---------------------------------------------------------------------------

invariant fractions_extra10.Fraction.two_fifths_numerator:
  description: "Fraction(2, 5).numerator == 2 — coprime inputs require no reduction"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [2, 5]
  method: numerator
  expected: 2

invariant fractions_extra10.Fraction.two_fifths_denominator:
  description: "Fraction(2, 5).denominator == 5 — coprime inputs require no reduction"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [2, 5]
  method: denominator
  expected: 5

# ---------------------------------------------------------------------------
# Fraction('7/8') — string constructor with slash notation
#
# fractions_extra3 covers Fraction('3/5') str constructor.
# fractions_extra7 covers Fraction('3/7') str constructor.
# No prior spec covers Fraction('7/8') with both numerator and denominator.
# ---------------------------------------------------------------------------

invariant fractions_extra10.Fraction.string_seven_eighths_numerator:
  description: "Fraction('7/8').numerator == 7 — string constructor with slash notation"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: ["7/8"]
  method: numerator
  expected: 7

invariant fractions_extra10.Fraction.string_seven_eighths_denominator:
  description: "Fraction('7/8').denominator == 8 — string constructor with slash notation"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: ["7/8"]
  method: denominator
  expected: 8

# ---------------------------------------------------------------------------
# Fraction(3, 4).as_integer_ratio() — tuple component access
#
# fractions_extra7 covers Fraction(1, 3).as_integer_ratio() == (1, 3) as a
# whole-tuple comparison. No prior spec accesses individual tuple components
# via __getitem__ for a different input value.
# Fraction(3, 4).as_integer_ratio() returns (3, 4); [0] == 3, [1] == 4.
# ---------------------------------------------------------------------------

invariant fractions_extra10.Fraction.as_integer_ratio_three_quarters_num:
  description: "Fraction(3, 4).as_integer_ratio()[0] == 3 — numerator component of ratio tuple"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: as_integer_ratio
  method_chain: __getitem__
  method_chain_args: [0]
  expected: 3

invariant fractions_extra10.Fraction.as_integer_ratio_three_quarters_den:
  description: "Fraction(3, 4).as_integer_ratio()[1] == 4 — denominator component of ratio tuple"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: as_integer_ratio
  method_chain: __getitem__
  method_chain_args: [1]
  expected: 4
