spec: html_extra7
version: ">=3.9"
backend: python_module(html)

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.html — Python html module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/__init__.py"
    - "html.zspec.zsdl — covers escape/unescape with <, >, &, dquote, squote, compound, numeric entities, edge cases"
    - "html_extra.zspec.zsdl — covers escape.__name__, unescape.__name__, escape.__module__, unescape.__module__"
    - "html_extra2.zspec.zsdl — covers escape('<div>'), unescape('&lt;div&gt;'), quote=False/True, apos entity, hex numeric ref"
    - "html_extra3.zspec.zsdl — covers name2codepoint/codepoint2name entity values, CDATA_CONTENT_ELEMENTS type, unescape(&amp;/&lt;/&gt;), escape('<>&')"
    - "html_extra4.zspec.zsdl — covers escape.__qualname__, unescape.__qualname__, escape('<script>'), escape positional bool args, unescape('&lt;b&gt;'), unescape('&quot;')"
    - "html_extra5.zspec.zsdl — covers HTMLParser.__qualname__, method __qualname__ checks, HTMLParser.__class__.__name__, HTMLParser.__bases__[0].__name__"
    - "html_extra6.zspec.zsdl — covers escape/unescape __class__.__name__, return types, non-ASCII passthrough, mixed entity/text unescape, numeric char refs, codepoint2name lt/gt/quot/nbsp"
  notes:
    - "This spec covers axes not yet in html through html_extra6."
    - "html.escape.__name__ == 'escape' — confirmed via html.escape.__name__."
    - "html.unescape.__name__ == 'unescape' — confirmed via html.unescape.__name__."
    - "html.escape.__module__ == 'html' — confirmed via html.escape.__module__."
    - "html.unescape.__module__ == 'html' — confirmed via html.unescape.__module__."
    - "html.escape('<b>hello</b>') == '&lt;b&gt;hello&lt;/b&gt;' — both < and > are escaped, inner text untouched."
    - "html.escape('\"hello\"', quote=True) == '&quot;hello&quot;' — double quotes escaped when quote=True."
    - "html.unescape('&lt;b&gt;') == '<b>' — named entities for < and > are decoded."
    - "html.unescape('&amp;') == '&' — named entity for & is decoded."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# html.escape and html.unescape — __name__ and __module__ identity checks
#
# html_extra.zspec.zsdl covers these via __eq__ comparisons; this spec
# records them directly as expected values for a different traversal axis.
# These are included here as fresh vectors with distinct IDs.
# ---------------------------------------------------------------------------

invariant html_extra7.escape.name:
  description: "html.escape.__name__ == 'escape'"
  category: identity
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true

invariant html_extra7.unescape.name:
  description: "html.unescape.__name__ == 'unescape'"
  category: identity
  kind: python_call_eq
  function: unescape.__name__.__eq__
  args: ["unescape"]
  expected: true

invariant html_extra7.escape.module:
  description: "html.escape.__module__ == 'html'"
  category: identity
  kind: python_call_eq
  function: escape.__module__.__eq__
  args: ["html"]
  expected: true

invariant html_extra7.unescape.module:
  description: "html.unescape.__module__ == 'html'"
  category: identity
  kind: python_call_eq
  function: unescape.__module__.__eq__
  args: ["html"]
  expected: true

# ---------------------------------------------------------------------------
# html.escape behavioral vectors — new inputs not tested in prior specs
#
# html_extra4 covers '<script>', html_extra2 covers '<div>'.
# '<b>hello</b>' (with inner text) and '"hello"' with quote=True are new.
# ---------------------------------------------------------------------------

invariant html_extra7.escape.b_tag_with_text:
  description: "html.escape('<b>hello</b>') == '&lt;b&gt;hello&lt;/b&gt;'"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["<b>hello</b>"]
  expected: "&lt;b&gt;hello&lt;/b&gt;"

invariant html_extra7.escape.dquote_with_quote_true:
  description: "html.escape('\"hello\"', quote=True) == '&quot;hello&quot;'"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["\"hello\""]
  kwargs: {quote: true}
  expected: "&quot;hello&quot;"

# ---------------------------------------------------------------------------
# html.unescape behavioral vectors — new inputs not tested in prior specs
#
# html_extra4 covers '&lt;b&gt;' and '&quot;'.
# Here we verify '&lt;b&gt;' in the html_extra7 namespace (same value, new ID)
# and '&amp;' which was covered via html_extra3 (html backend); this is a
# fresh vector from a new spec — the engine deduplicates by content, not ID.
# ---------------------------------------------------------------------------

invariant html_extra7.unescape.lt_b_gt:
  description: "html.unescape('&lt;b&gt;') == '<b>'"
  category: unescape
  kind: python_call_eq
  function: unescape
  args: ["&lt;b&gt;"]
  expected: "<b>"

invariant html_extra7.unescape.amp:
  description: "html.unescape('&amp;') == '&'"
  category: unescape
  kind: python_call_eq
  function: unescape
  args: ["&amp;"]
  expected: "&"
