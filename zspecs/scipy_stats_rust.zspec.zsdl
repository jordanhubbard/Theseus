spec: scipy_stats_rust
version: ">=3.9"
backend: rust_module(scipy_stats_rust)

docs: https://docs.scipy.org/doc/scipy/reference/stats.html

provenance:
  derived_from:
    - "https://docs.scipy.org/doc/scipy/reference/stats.html — SciPy stats documentation"
  not_derived_from:
    - "scipy source: scipy/stats/_stats_py.py"
  notes:
    - "SciPy provides statistical functions for Python."
    - "scipy.stats.norm.pdf(0) == 1/sqrt(2*pi) ≈ 0.3989422804014327."
    - "scipy.stats.norm.cdf(0) == 0.5 — median of standard normal."
    - "scipy.stats.norm.ppf(0.5) == 0.0 — inverse CDF at median."
    - "scipy.stats.describe([1,2,3,4,5]).mean == 3.0."
    - "scipy.stats.describe([1,2,3,4,5]).nobs == 5."
    - "Expose norm_cdf_zero() -> float: stats.norm.cdf(0) == 0.5."
    - "Expose norm_ppf_half() -> float: stats.norm.ppf(0.5) == 0.0."
    - "Expose describe_nobs(lst) -> int: stats.describe(lst).nobs."
    - "Expose describe_mean(lst) -> float: stats.describe(lst).mean."
    - "All test vectors verified against scipy 1.15.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# norm.cdf — cumulative distribution function
invariant scipy_stats_rust.norm.cdf_zero:
  description: "norm.cdf(0) == 0.5"
  category: norm_cdf
  kind: python_call_eq
  function: norm_cdf_zero
  args: []
  expected: 0.5

# norm.ppf — percent point function (inverse CDF)
invariant scipy_stats_rust.norm.ppf_half:
  description: "norm.ppf(0.5) == 0.0"
  category: norm_ppf
  kind: python_call_eq
  function: norm_ppf_half
  args: []
  expected: 0.0

# describe — descriptive statistics
table scipy_stats_rust.describe.nobs:
  kind: python_call_eq
  category: nobs
  id_prefix: sc_nobs
  function: describe_nobs

  columns: [id, args, expected]
  rows:
    - [five,   [[1, 2, 3, 4, 5]], 5]
    - [three,  [[1, 2, 3]],       3]
    - [one,    [[42]],            1]

table scipy_stats_rust.describe.mean:
  kind: python_call_eq
  category: mean
  id_prefix: sc_mean
  function: describe_mean

  columns: [id, args, expected]
  rows:
    - [three,   [[1, 2, 3]], 2.0]
    - [sym,     [[0, 0]],    0.0]
    - [one,     [[42]],      42.0]

