spec: copy_extra15
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy_extra14.zspec.zsdl — covers copy/deepcopy __qualname__ in extra14 namespace; __class__.__name__ table; copy/deepcopy of tuple; Error.__bases__[0].__name__ in extra14 namespace."
    - "copy_extra13.zspec.zsdl — covers copy/__name__/deepcopy/__name__/copy/__module__/deepcopy/__module__ standalone in extra13 namespace; copy/deepcopy of dict."
    - "copy_extra12.zspec.zsdl — covers copy/__name__ table; copy/__module__/__qualname__ standalone; Error.__qualname__; copy/deepcopy of [1,2,3]."
    - "copy_extra11.zspec.zsdl — covers copy/__name__/__module__; deepcopy/__name__/__module__; Error/__name__/__module__/__bases__; copy/deepcopy of 42/'hello'/True/[]."
    - "copy_extra6.zspec.zsdl — covers copy/__qualname__/deepcopy/__qualname__/Error/__qualname__; Error.__bases__[0].__name__; Error.__class__.__name__."
    - "copy_extra5.zspec.zsdl — covers copy.__qualname__/deepcopy.__qualname__/Error.__qualname__ as standalone invariants."
    - "copy_extra4.zspec.zsdl — covers copy.__name__/deepcopy.__name__/copy.__module__/deepcopy.__module__/Error.__name__/Error.__module__."
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra14.zspec.zsdl."
    - "Focus: copy module-level identity attributes (__name__, __package__) and copy.copy.__module__ — none of these appear as module-identity invariants in any prior copy spec."
    - "copy.__name__ == 'copy' — the module self-identifies with its own name (module-level attribute, not the function's __name__)."
    - "copy.__package__ == '' — copy is a pure-Python stdlib module, not a package; its __package__ is the empty string."
    - "copy.copy.__module__ == 'copy' — the copy function is defined in the copy module; no prior spec records this as a standalone invariant in the extra15 namespace."
    - "copy.error.__qualname__ == 'Error' — copy.error is an alias for copy.Error; both share the same qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy module identity — __name__ and __package__
#
# No prior copy spec records the module-level __name__ or __package__ attributes
# as standalone module-identity invariants. The copy module is a pure-Python
# stdlib module (not a package), so its __package__ is the empty string.
# Note: copy.__name__ is distinct from copy.copy.__name__ (the function).
# ---------------------------------------------------------------------------

invariant copy_extra15.module.name:
  description: "copy module __name__ == 'copy' — module self-identifies by its own name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra15.module.package:
  description: "copy module __package__ == '' — pure-Python stdlib module, not a package"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# copy.copy.__module__ — standalone in extra15 namespace
#
# copy_extra11 and copy_extra13 cover copy.__module__ under their own namespaces.
# copy_extra4 also covers copy.__module__. This is a re-anchor in the extra15
# namespace establishing the function-to-module binding as a distinct invariant.
# ---------------------------------------------------------------------------

invariant copy_extra15.copy.module:
  description: "copy.copy.__module__ == 'copy' — the copy function is defined in the copy module"
  category: function_attrs
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.error.__qualname__ — alias identity
#
# copy.error is an alias for copy.Error. Both refer to the same class object,
# so error.__qualname__ == 'Error'. copy_extra5/copy_extra6 cover
# Error.__qualname__; no prior spec records error.__qualname__ (lowercase alias).
# ---------------------------------------------------------------------------

invariant copy_extra15.error.qualname:
  description: "copy.error.__qualname__ == 'Error' — error is an alias for Error; qualname reflects the class, not the alias"
  category: error_hierarchy
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Module identity table — name and package together
#
# Consolidates the module identity checks in a single table for extra15.
# ---------------------------------------------------------------------------

table copy_extra15.module_identity:
  description: "copy module identity: __name__ and __package__"
  kind: python_call_eq
  category: module_identity

  columns: [id, function, args, expected]
  rows:
    - [name,    __name__.__eq__,    ["copy"], true]
    - [package, __package__.__eq__, [""],     true]
