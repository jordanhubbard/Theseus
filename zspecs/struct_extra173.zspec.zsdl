spec: struct_extra173
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "RFC 1700 — Assigned Numbers (network byte order = big-endian)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "RFC 1700 — Assigned Numbers (network byte order = big-endian)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec covers: struct endianness format specifiers — calcsize and Struct.format for '>', '<', '!', '=' prefixes."
    - "Format prefix '>' = big-endian (most significant byte first)."
    - "Format prefix '<' = little-endian (least significant byte first)."
    - "Format prefix '!' = network byte order, which is big-endian per RFC 1700."
    - "Format prefix '=' = native byte order without alignment padding."
    - "calcsize('>i') == calcsize('<i') == calcsize('!i') == calcsize('=i') == 4 — byte order prefix does not change type size."
    - "calcsize('>q') == calcsize('<q') == 8 — signed 64-bit integer is always 8 bytes regardless of byte order prefix."
    - "struct.Struct('>i').format == '>i' — Struct preserves the format string exactly as given."
    - "struct.Struct('<i').format == '<i' — Struct preserves the format string exactly as given."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# calcsize — endianness prefixes for signed int 'i' (4 bytes)
# ---------------------------------------------------------------------------

table struct_extra173.calcsize.int_endian:
  description: "calcsize for 'i' (signed 32-bit int) is always 4 regardless of byte-order prefix"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: structendian173

  columns: [id, function, args, expected, description]
  rows:
    - [big_endian_i,     calcsize.__call__.__eq__, [">i"],  4, "calcsize('>i') == 4 — big-endian signed int"]
    - [little_endian_i,  calcsize.__call__.__eq__, ["<i"],  4, "calcsize('<i') == 4 — little-endian signed int"]
    - [network_i,        calcsize.__call__.__eq__, ["!i"],  4, "calcsize('!i') == 4 — network byte order (big-endian) signed int"]
    - [native_i,         calcsize.__call__.__eq__, ["=i"],  4, "calcsize('=i') == 4 — native byte order signed int"]

# ---------------------------------------------------------------------------
# calcsize — endianness prefixes for signed long long 'q' (8 bytes)
# ---------------------------------------------------------------------------

table struct_extra173.calcsize.longlong_endian:
  description: "calcsize for 'q' (signed 64-bit long long) is always 8 regardless of byte-order prefix"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: structendian173

  columns: [id, function, args, expected, description]
  rows:
    - [big_endian_q,    calcsize.__call__.__eq__, [">q"],  8, "calcsize('>q') == 8 — big-endian signed long long"]
    - [little_endian_q, calcsize.__call__.__eq__, ["<q"],  8, "calcsize('<q') == 8 — little-endian signed long long"]
    - [network_q,       calcsize.__call__.__eq__, ["!q"],  8, "calcsize('!q') == 8 — network byte order signed long long"]

# ---------------------------------------------------------------------------
# struct.Struct.format — preserves the format string exactly
# ---------------------------------------------------------------------------

table struct_extra173.Struct.format:
  description: "struct.Struct preserves the format string in its .format attribute"
  kind: python_call_eq
  category: struct_object
  id_prefix: structendian173

  columns: [id, function, args, expected, description]
  rows:
    - [big_endian_fmt,     Struct.__call__().format.__eq__, [">i"],  true, "Struct('>i').format == '>i'"]
    - [little_endian_fmt,  Struct.__call__().format.__eq__, ["<i"],  true, "Struct('<i').format == '<i'"]
    - [network_fmt,        Struct.__call__().format.__eq__, ["!i"],  true, "Struct('!i').format == '!i'"]
    - [native_fmt,         Struct.__call__().format.__eq__, ["=i"],  true, "Struct('=i').format == '=i'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra173.calcsize.big_endian_i:
  description: "struct.calcsize('>i') == 4 — big-endian signed 32-bit int is always 4 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: [">i"]
  expected: 4

invariant struct_extra173.calcsize.little_endian_i:
  description: "struct.calcsize('<i') == 4 — little-endian signed 32-bit int is always 4 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["<i"]
  expected: 4

invariant struct_extra173.calcsize.network_i:
  description: "struct.calcsize('!i') == 4 — network byte order ('!' = big-endian per RFC 1700) signed 32-bit int is 4 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!i"]
  expected: 4

invariant struct_extra173.calcsize.big_endian_q:
  description: "struct.calcsize('>q') == 8 — big-endian signed 64-bit long long is always 8 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: [">q"]
  expected: 8

invariant struct_extra173.calcsize.little_endian_q:
  description: "struct.calcsize('<q') == 8 — little-endian signed 64-bit long long is always 8 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["<q"]
  expected: 8

invariant struct_extra173.Struct.big_endian_format:
  description: "struct.Struct('>i').format == '>i' — Struct preserves format string exactly"
  category: struct_object
  kind: python_call_eq
  function: Struct
  args: [">i"]
  method: format.__eq__
  method_args: [">i"]
  expected: true

invariant struct_extra173.Struct.little_endian_format:
  description: "struct.Struct('<i').format == '<i' — Struct preserves format string exactly"
  category: struct_object
  kind: python_call_eq
  function: Struct
  args: ["<i"]
  method: format.__eq__
  method_args: ["<i"]
  expected: true

