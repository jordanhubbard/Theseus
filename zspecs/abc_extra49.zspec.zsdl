spec: abc_extra49
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra48.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables (extra25/extra29/extra32: lengths only), ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8). abstractmethod/__annotations__/__class__.__name__.__len__()==4 (extra32), ABCMeta/__bases__[0].__module__.__len__()==8 and __qualname__.__len__()==4 (extra33), ABCMeta MRO __module__/__qualname__.__len__() tables (extra33), abstractmethod/__name__=='abstractmethod', get_cache_token/__module__=='_abc', ABC/__name__=='ABC' (extra34), ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type'/__mro__.__len__()==3 (extra35), abstractproperty/__qualname__=='abstractproperty', abstractclassmethod/__qualname__=='abstractclassmethod', abstractstaticmethod/__qualname__=='abstractstaticmethod', ABCMeta.register/__qualname__=='ABCMeta.register', ABC/__abstractmethods__/__class__/__name__=='frozenset' (extra38), abstractmethod/__qualname__=='abstractmethod', ABCMeta/__qualname__=='ABCMeta', ABC/__qualname__=='ABC', get_cache_token/__qualname__=='get_cache_token' (extra39), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ equality for all abc exports (extra41-extra43), abstractmethod/__doc__/__class__/__name__=='str', ABCMeta/__doc__/__class__/__name__=='str' (extra44), abstractmethod/__code__/__class__ attrs (extra46-extra47), abstractmethod/__annotations__/__class__/__name__/__qualname__/__module__ string equality, abstractmethod/__globals__/__class__/__name__/__qualname__ string equality (extra48), ABCMeta/__bases__[0]/__qualname__.__eq__('type') and __module__.__eq__('builtins') (extra48). abstractmethod/__name__.__len__()==14 (extra22/extra29), abstractmethod/__qualname__.__len__()==14 (extra17/extra22/extra27/extra29/extra36/extra39), update_abstractmethods/__qualname__.__len__()==22 (extra25/extra29), update_abstractmethods/__name__.__len__()==22 (extra29)."
    - "This spec covers: abc class __dict__.__class__.__name__ string equality ('mappingproxy') for abstractproperty/abstractclassmethod/abstractstaticmethod — prior specs captured only __dict__.__class__.__name__.__len__()==12 in length tables (extra25/extra29/extra32); ABCMeta and ABC __dict__.__class__.__name__.__eq__ were covered in extra9/extra8 respectively; extra49 extends to the three deprecated abstract decorator classes. Also: ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ string equality ('mappingproxy') — no prior abc spec captured __dict__.__class__.__qualname__. Also: abc module __dict__.__class__.__name__ and __dict__.__class__.__qualname__ — module __dict__ is also a mappingproxy; novel module-level check. abstractmethod/__name__.__len__()==14, abstractmethod/__qualname__.__len__()==14, update_abstractmethods/__name__.__len__()==22 are all already covered in many prior specs; extra49 does NOT re-cover them."
    - "abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy'. abstractproperty is a deprecated subclass of property defined in Lib/abc.py. Every Python class __dict__ is a mappingproxy; abstractproperty follows the same pattern. Prior specs captured __dict__.__class__.__name__.__len__()==12 in length tables (extra25/extra29/extra32) but not the string equality for abstractproperty. Extra49 supplies the string equality check in the abcdict49 namespace. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy'. abstractclassmethod is a deprecated subclass of classmethod defined in Lib/abc.py. Its __dict__ is a mappingproxy; prior specs captured __len__()==12 but not the string equality. Extra49 supplies the string equality check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy'. abstractstaticmethod is a deprecated subclass of staticmethod defined in Lib/abc.py. Its __dict__ is a mappingproxy; prior specs captured __len__()==12 but not the string equality. Extra49 supplies the string equality check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type is a built-in type with no enclosing class or function scope, so __qualname__ == __name__ == 'mappingproxy'. Prior extra9 captured ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') (the __name__ string equality) but not the __qualname__. Extra49 supplies the complementary __qualname__ string equality check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__class__.__qualname__ == 'mappingproxy'. Prior extra8 captured ABC.__dict__.__class__.__name__.__eq__('mappingproxy') (the __name__ string equality) but not the __qualname__. Extra49 supplies the complementary __qualname__ string equality check for ABC. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__dict__.__class__.__name__ == 'mappingproxy'. Module __dict__ objects are also mappingproxy instances in CPython — the module's global namespace is exposed as a mappingproxy via the module's __dict__ attribute. No prior abc spec has examined the module-level __dict__.__class__. Extra49 introduces this novel check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__dict__.__class__.__qualname__ == 'mappingproxy'. The module __dict__ is a mappingproxy instance; mappingproxy is a built-in type with __qualname__ == __name__ == 'mappingproxy'. This is the __qualname__ complement to the __name__ check above. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc deprecated abstract decorator class __dict__.__class__.__name__ — extra49
#
# The three deprecated abstract decorator classes (abstractproperty,
# abstractclassmethod, abstractstaticmethod) each have a __dict__ that is
# a mappingproxy, consistent with all Python classes. Prior specs captured
# __dict__.__class__.__name__.__len__()==12 in length tables but never the
# string equality 'mappingproxy' for these three classes. Note:
#   ABCMeta.__dict__.__class__.__name__.__eq__ covered in abc_extra9
#   ABC.__dict__.__class__.__name__.__eq__    covered in abc_extra8
# Extra49 fills the gap for the three deprecated decorator classes.
# ---------------------------------------------------------------------------

table abc_extra49.deprecated_abstract_dict_class_name_eq:
  description: "abc deprecated abstract decorator class __dict__.__class__.__name__ string equality in extra49 namespace — abstractproperty/abstractclassmethod/abstractstaticmethod; prior specs captured __len__()==12 only"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdict49depabsname

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty,    abstractproperty.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true, "abstractproperty.__dict__.__class__.__name__ == 'mappingproxy' — deprecated subclass of property; class __dict__ is a mappingproxy; prior specs captured __len__()==12 but not the string equality"]
    - [abstractclassmethod, abstractclassmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy' — deprecated subclass of classmethod; class __dict__ is a mappingproxy; prior specs captured __len__()==12 but not the string equality"]
    - [abstractstaticmethod, abstractstaticmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy' — deprecated subclass of staticmethod; class __dict__ is a mappingproxy; prior specs captured __len__()==12 but not the string equality"]

# ---------------------------------------------------------------------------
# abc class __dict__.__class__.__qualname__ string equality — extra49
#
# The mappingproxy type is a built-in type with no enclosing class or function
# scope, so __qualname__ == __name__ == 'mappingproxy'. No prior abc spec has
# captured __dict__.__class__.__qualname__ for any abc class. Extra49 introduces
# this dimension for ABCMeta and ABC:
#   ABCMeta.__dict__.__class__.__qualname__ == 'mappingproxy'
#   ABC.__dict__.__class__.__qualname__     == 'mappingproxy'
# These complement the __name__ checks from abc_extra9 and abc_extra8 respectively.
# ---------------------------------------------------------------------------

table abc_extra49.class_dict_class_qualname_eq:
  description: "abc class __dict__.__class__.__qualname__ string equality in extra49 namespace — ABCMeta and ABC; prior specs covered __dict__.__class__.__name__ only; extra49 opens the __qualname__ dimension"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdict49clsqualname

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta, ABCMeta.__dict__.__class__.__qualname__.__eq__, ["mappingproxy"], true, "ABCMeta.__dict__.__class__.__qualname__ == 'mappingproxy' — mappingproxy is a built-in type with no enclosing scope; __qualname__ == __name__ == 'mappingproxy' (12 chars); prior extra9 captured __name__.__eq__ but not __qualname__.__eq__"]
    - [ABC,     ABC.__dict__.__class__.__qualname__.__eq__,     ["mappingproxy"], true, "ABC.__dict__.__class__.__qualname__ == 'mappingproxy' — ABC is a class; its __dict__ is a mappingproxy; prior extra8 captured __name__.__eq__ but not __qualname__.__eq__"]

# ---------------------------------------------------------------------------
# abc module __dict__.__class__ string equality — extra49
#
# Module __dict__ objects are mappingproxy instances in CPython. The abc
# module's global namespace is exposed as a mappingproxy via abc.__dict__.
# No prior abc spec has examined the module-level __dict__.__class__ at all.
# Extra49 introduces both the __name__ and __qualname__ checks for the
# module-level __dict__:
#   abc.__dict__.__class__.__name__     == 'mappingproxy'  (12 chars)
#   abc.__dict__.__class__.__qualname__ == 'mappingproxy'  (12 chars)
# ---------------------------------------------------------------------------

table abc_extra49.module_dict_class_attrs_eq:
  description: "abc module __dict__.__class__.__name__ and __qualname__ string equality in extra49 namespace — module __dict__ is a mappingproxy; novel module-level check not in any prior abc spec"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcdict49moddict

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_name,    __dict__.__class__.__name__.__eq__,    ["mappingproxy"], true, "abc.__dict__.__class__.__name__ == 'mappingproxy' — module __dict__ is a mappingproxy in CPython; the module namespace is exposed as a read-only mappingproxy via __dict__; novel module-level check not in prior abc specs"]
    - [module_dict_qualname, __dict__.__class__.__qualname__.__eq__, ["mappingproxy"], true, "abc.__dict__.__class__.__qualname__ == 'mappingproxy' — mappingproxy is a built-in type with __qualname__ == __name__ == 'mappingproxy' (no enclosing scope); complement to the __name__ check above"]

# ---------------------------------------------------------------------------
# abc class __dict__.__class__.__name__.__len__() cross-check — extra49
#
# 'mappingproxy' has 12 characters: m-a-p-p-i-n-g-p-r-o-x-y = 12.
# These cross-check the string equality values above for the deprecated
# abstract decorator classes and complement the __len__() checks from
# prior specs (extra25/extra29/extra32).
# ---------------------------------------------------------------------------

table abc_extra49.deprecated_abstract_dict_class_name_len:
  description: "abc deprecated abstract decorator class __dict__.__class__.__name__.__len__() cross-check in extra49 namespace — 'mappingproxy' has 12 characters"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdict49depabsnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty,    abstractproperty.__dict__.__class__.__name__.__len__,    [], 12, "abstractproperty.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters; cross-check for string equality above"]
    - [abstractclassmethod, abstractclassmethod.__dict__.__class__.__name__.__len__, [], 12, "abstractclassmethod.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"]
    - [abstractstaticmethod, abstractstaticmethod.__dict__.__class__.__name__.__len__, [], 12, "abstractstaticmethod.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra49
# ---------------------------------------------------------------------------

invariant abc_extra49.abstractproperty_dict_class_name_eq:
  description: "abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy' — deprecated subclass of property defined in Lib/abc.py; class __dict__ is a mappingproxy (12 chars); prior specs captured __len__()==12, extra49 adds the string equality"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra49.abstractclassmethod_dict_class_name_eq:
  description: "abc.abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy' — deprecated subclass of classmethod; class __dict__ is a mappingproxy; prior specs captured __len__()==12, extra49 adds the string equality"
  category: class_names
  kind: python_call_eq
  function: abstractclassmethod.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra49.abstractstaticmethod_dict_class_name_eq:
  description: "abc.abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy' — deprecated subclass of staticmethod; class __dict__ is a mappingproxy; prior specs captured __len__()==12, extra49 adds the string equality"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra49.ABCMeta_dict_class_qualname_eq:
  description: "abc.ABCMeta.__dict__.__class__.__qualname__ == 'mappingproxy' — mappingproxy is a built-in type with no enclosing scope; __qualname__ == __name__ == 'mappingproxy' (12 chars); prior extra9 captured __dict__.__class__.__name__.__eq__ but not __qualname__.__eq__"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra49.ABC_dict_class_qualname_eq:
  description: "abc.ABC.__dict__.__class__.__qualname__ == 'mappingproxy' — ABC is a class; its __dict__ is a mappingproxy; mappingproxy.__qualname__ == 'mappingproxy'; prior extra8 captured __dict__.__class__.__name__.__eq__ but not __qualname__.__eq__"
  category: class_names
  kind: python_call_eq
  function: ABC.__dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra49.module_dict_class_name_eq:
  description: "abc.__dict__.__class__.__name__ == 'mappingproxy' — module __dict__ is a mappingproxy in CPython; the module's global namespace is exposed as a read-only mappingproxy; novel module-level check not in prior abc specs"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra49.module_dict_class_qualname_eq:
  description: "abc.__dict__.__class__.__qualname__ == 'mappingproxy' — module __dict__ is a mappingproxy; mappingproxy is a built-in type with __qualname__ == __name__ == 'mappingproxy' (no enclosing scope)"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true
