spec: itertools_extra2836
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "any proprietary source"
    - "zspecs/itertools_extra2821.zspec.zsdl — wave 635 predecessor (__radd__, __rsub__, __rmul__)"
  notes:
    - "Wave 636 (_extra2836): __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo)."
    - "All itertools types are lazy iterator wrappers — none define reflected division or modulo operators."
    - "itertools.chain, count, repeat, cycle, islice, compress, dropwhile, takewhile: C-level types; no __rtruediv__/__rfloordiv__/__rmod__."
    - "itertools.starmap, groupby, filterfalse, accumulate, zip_longest: C-level types; no __rtruediv__/__rfloordiv__/__rmod__."
    - "itertools.pairwise, product, permutations, combinations, combinations_with_replacement: C-level types; no __rtruediv__/__rfloordiv__/__rmod__."
    - "Reflected operators (__rtruediv__, __rfloordiv__, __rmod__) are invoked when the left operand does not support the operation; iterator types produce sequences, not numeric values."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __rtruediv__ dict-presence (reflected true division)
#
# Core itertools types: chain, count, repeat, cycle, islice, compress,
# dropwhile, takewhile, starmap, groupby — none define __rtruediv__.
# ---------------------------------------------------------------------------

table itertools_extra2836.rtruediv_protocol_core:
  description: "itertools core types __rtruediv__ dict-presence checks — all False (no reflected true division protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2836
  columns: [id, function, args, expected]
  rows:
    - ["it2836001", "itertools.chain.__dict__.__contains__",     ["__rtruediv__"], false]
    - ["it2836002", "itertools.count.__dict__.__contains__",     ["__rtruediv__"], false]
    - ["it2836003", "itertools.repeat.__dict__.__contains__",    ["__rtruediv__"], false]
    - ["it2836004", "itertools.cycle.__dict__.__contains__",     ["__rtruediv__"], false]
    - ["it2836005", "itertools.islice.__dict__.__contains__",    ["__rtruediv__"], false]
    - ["it2836006", "itertools.compress.__dict__.__contains__",  ["__rtruediv__"], false]
    - ["it2836007", "itertools.dropwhile.__dict__.__contains__", ["__rtruediv__"], false]
    - ["it2836008", "itertools.takewhile.__dict__.__contains__", ["__rtruediv__"], false]
    - ["it2836009", "itertools.starmap.__dict__.__contains__",   ["__rtruediv__"], false]
    - ["it2836010", "itertools.groupby.__dict__.__contains__",   ["__rtruediv__"], false]

