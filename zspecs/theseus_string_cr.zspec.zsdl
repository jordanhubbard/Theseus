spec: theseus_string_cr
version: ">=3.9"
backend: python_cleanroom(theseus_string_cr)
blocks: string

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html"
  notes:
    - "Clean-room string module constants and Template. Do NOT import string."
    - "digits: '0123456789'."
    - "ascii_lowercase: 'abcdefghijklmnopqrstuvwxyz'."
    - "ascii_uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'."
    - "ascii_letters: ascii_lowercase + ascii_uppercase."
    - "punctuation: '!\"#$%&\\'()*+,-./:;<=>?@[\\\\]^_`{|}~'."
    - "whitespace: ' \\t\\n\\r\\x0b\\x0c'."
    - "Template(template): $-based string substitution."
    - "Template.substitute(**kws): replace $key with value (raises KeyError if missing)."
    - "Template.safe_substitute(**kws): replace $key with value (leaves missing keys unchanged)."
    - "string_template_sub(): Template('Hello $name').substitute(name='World') == 'Hello World'."
    - "string_digits(): digits == '0123456789'."
    - "string_ascii_lower(): ascii_lowercase == 'abcdefghijklmnopqrstuvwxyz'."
    - "Export: digits, ascii_lowercase, ascii_uppercase, ascii_letters, punctuation, whitespace, Template."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_string_cr.template_sub:
  description: "Template('Hello $name').substitute(name='World') == 'Hello World'"
  category: template
  kind: python_call_eq
  function: string_template_sub
  args: []
  expected: "Hello World"

invariant theseus_string_cr.digits:
  description: "digits == '0123456789'"
  category: constants
  kind: python_call_eq
  function: string_digits
  args: []
  expected: "0123456789"

invariant theseus_string_cr.ascii_lower:
  description: "ascii_lowercase == 'abcdefghijklmnopqrstuvwxyz'"
  category: constants
  kind: python_call_eq
  function: string_ascii_lower
  args: []
  expected: "abcdefghijklmnopqrstuvwxyz"
