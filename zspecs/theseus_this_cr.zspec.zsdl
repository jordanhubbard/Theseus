spec: theseus_this_cr
version: ">=3.0"
backend: python_cleanroom(theseus_this_cr)
blocks: this

docs: https://docs.python.org/3/library/this.html

provenance:
  derived_from:
    - "CPython docs"
  not_derived_from:
    - "CPython source: Lib/this.py"
  notes:
    - "Clean-room this module. Do NOT import this."

error_model: python_exceptions

invariant theseus_this_cr.this2_zen:
  description: "s attribute contains the encoded Zen of Python"
  category: behavior
  kind: python_call_eq
  function: this2_zen
  args: []
  expected: true

invariant theseus_this_cr.this2_decode:
  description: "The decoded text contains 'Beautiful is better than ugly'"
  category: behavior
  kind: python_call_eq
  function: this2_decode
  args: []
  expected: true

invariant theseus_this_cr.this2_d:
  description: "d dict maps encoded to decoded characters"
  category: behavior
  kind: python_call_eq
  function: this2_d
  args: []
  expected: true
