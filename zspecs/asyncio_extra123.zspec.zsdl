spec: asyncio_extra123
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers: wave 261 theme — asyncio Event and Condition method __qualname__ and code attributes not previously covered. Prior specs covered: asyncio.Event.set/__qualname__.__len__==9 and asyncio.Event.is_set/__qualname__ in extra120-122 waves; asyncio.Semaphore.acquire/__qualname__=='Semaphore.acquire' and len==17 covered in earlier specs. NOT previously covered: Event.set co_varnames[1]='fut' (len=3); Event.clear co_varnames len=1; Event.is_set co_varnames len=1; Condition.notify co_varnames[1]='n' (len=1); Condition.notify_all co_varnames len=1; Condition.wait.__qualname__=='Condition.wait' (len=14); Condition.wait_for.__qualname__=='Condition.wait_for' (len=18); Semaphore.locked.__qualname__=='Semaphore.locked' (len=16); Semaphore.__module__=='asyncio.locks' length; Condition.__mro__.__len__()==4."
    - "asyncio.Event.set.__code__.co_varnames == ('self', 'fut'): len=2. co_varnames[1]='fut' (len=3: a local asyncio.Future created when set() notifies waiting coroutines; shorter than Queue 'putter'=6 or 'getter'=6 — Event.set uses the shorter generic name 'fut'). Event.set.__qualname__=='Event.set' (len=9). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Condition.notify.__code__.co_varnames == ('self', 'n'): len=2. co_varnames[1]='n' (len=1: the count of waiters to notify; single-character name — the shortest possible parameter name, conventional for count parameters). Condition.notify.__qualname__=='Condition.notify' (len=16). Condition.notify_all.__qualname__=='Condition.notify_all' (len=20). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__mro__.__len__() == 4 — Semaphore MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin (may vary by version), object] or a similar 4-element chain. Event.__mro__.__len__()==3 (simpler chain). Condition.__mro__.__len__()==4 (same depth as Semaphore). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.locked.__qualname__ == 'Semaphore.locked' (len=16). asyncio.Condition.wait.__qualname__ == 'Condition.wait' (len=14). asyncio.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18). Qualname length ordering among Condition methods: wait=14 < notify=16 (tied with locked=16) < wait_for=18 < notify_all=20 (longest). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Event method co_varnames element checks — extra123
#
# Wave 261 theme: asyncio Event and Condition method code attributes.
#
# Event.set.__code__.co_varnames  == ('self', 'fut')  len=2; co_varnames[1]='fut' (len=3)
# Event.clear.__code__.co_varnames == ('self',)        len=1
# Event.is_set.__code__.co_varnames == ('self',)       len=1
# Event.set.__qualname__ == 'Event.set'   (len=9)
# Event.clear.__qualname__ == 'Event.clear'  (len=11)
# Event.is_set.__qualname__ == 'Event.is_set' (len=12)
# ---------------------------------------------------------------------------

table asyncio_extra123.event_method_co_varnames:
  description: "asyncio.Event method co_varnames element checks in eventcv123 namespace — wave 261 theme: Event method code attributes; Event.set.__code__.co_varnames==('self','fut') len=2: co_argcount==1 (self only; 'fut' is a local asyncio.Future not a parameter); co_varnames[1].__eq__('fut')==True (len=3: 'fut' is a local Future that is resolved when set() notifies waiting coroutines; same generic name 'fut'=3 used in asyncio.Lock.acquire; shorter than Queue 'putter'=6 and 'getter'=6 — Event uses the concise 'fut'); co_varnames.__len__()==2 (2: 1 self param + 1 local fut; same count as Lock.acquire=2 which also has 'self'+'fut'); Event.clear.__code__.co_varnames==('self',) len=1 (only 'self': Event.clear simply sets self._value=False and has no local variables beyond self); Event.is_set.__code__.co_varnames==('self',) len=1 (tied with Event.clear=1: is_set simply returns bool(self._value) with no local variables); Event.set.__code__.co_qualname=='Event.set' (len=9: 'Event.'=6+'set'=3=9; same length as Queue.put and Queue.get co_qualname=9); Event.clear.__qualname__=='Event.clear' (len=11: 'Event.'=6+'clear'=5=11; 2 more than Event.set=9); Event.is_set.__qualname__=='Event.is_set' (len=12: 'Event.'=6+'is_set'=6=12; longest Event method qualname in this table); qualname length ordering: Event.set=9 < Event.clear=11 < Event.is_set=12; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: eventcv123

  columns: [id, function, args, expected, description]
  rows:
    - [set_vlen,    Event.set.__code__.co_varnames.__len__,       [],        2,    "Event.set co_varnames.__len__() == 2 (('self','fut'); 1 self + 1 local fut); verified with Python 3.14.3"]
    - [set_v1_eq,   "Event.set.__code__.co_varnames[1].__eq__",   ["fut"],   true, "Event.set co_varnames[1] == 'fut' (len=3; local Future; same name as Lock.acquire 'fut'); verified with Python 3.14.3"]
    - [set_v1_len,  "Event.set.__code__.co_varnames[1].__len__",  [],        3,    "Event.set co_varnames[1].__len__() == 3 ('fut'=3; shorter than Queue 'putter'=6 and 'getter'=6); verified with Python 3.14.3"]
    - [set_qn_eq,   Event.set.__code__.co_qualname.__eq__,        ["Event.set"], true, "Event.set co_qualname == 'Event.set' (len=9: tied with Queue.put/get co_qualname=9); verified with Python 3.14.3"]
    - [set_qn_len,  Event.set.__code__.co_qualname.__len__,       [],        9,    "Event.set co_qualname.__len__() == 9 ('Event.'=6+'set'=3=9); verified with Python 3.14.3"]
    - [clr_vlen,    Event.clear.__code__.co_varnames.__len__,     [],        1,    "Event.clear co_varnames.__len__() == 1 (('self',); no locals beyond self); verified with Python 3.14.3"]
    - [clr_qn_len,  Event.clear.__code__.co_qualname.__len__,     [],        11,   "Event.clear co_qualname.__len__() == 11 ('Event.clear'=11: 'Event.'=6+'clear'=5=11); verified with Python 3.14.3"]
    - [isset_vlen,  Event.is_set.__code__.co_varnames.__len__,    [],        1,    "Event.is_set co_varnames.__len__() == 1 (tied with Event.clear=1; no local variables); verified with Python 3.14.3"]
    - [isset_qn_len, Event.is_set.__code__.co_qualname.__len__,   [],        12,   "Event.is_set co_qualname.__len__() == 12 ('Event.is_set'=12: 'Event.'=6+'is_set'=6=12; longest Event method qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Condition method __qualname__ and co_varnames — extra123
#
# Wave 261 theme: Condition.notify co_varnames[1]='n' (len=1, shortest possible).
#
# Condition.notify.__code__.co_varnames  == ('self', 'n')  len=2; co_varnames[1]='n' (len=1)
# Condition.notify_all.__code__.co_varnames == ('self',)    len=1
# Condition.wait.__qualname__    == 'Condition.wait'    (len=14)
# Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18)
# Condition.notify.__qualname__   == 'Condition.notify'   (len=16)
# Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20, longest)
# ---------------------------------------------------------------------------

table asyncio_extra123.condition_method_qualnames_and_varnames:
  description: "asyncio.Condition method __qualname__ and co_varnames checks in condcv123 namespace — wave 261 theme: Condition method code attributes and qualnames; Condition.notify.__code__.co_varnames==('self','n') len=2: co_varnames[1].__eq__('n')==True (len=1: 'n' is the count of waiters to notify; single-character name — the shortest possible parameter name: 1 char; compare: Queue.put co_varnames[1]='item'=4, Lock.acquire co_varnames[1]='fut'=3; 'n' at len=1 is shorter than all other co_varnames[1] values seen in asyncio specs); co_varnames[1].__len__()==1 (1 is the shortest co_varnames element length seen in asyncio method specs; 'n' is a conventional single-char name for 'number' or 'count'); Condition.notify_all.__code__.co_varnames==('self',) len=1 (no locals: notify_all notifies all waiters unconditionally, so it needs no count parameter); Condition.wait.__qualname__.__eq__('Condition.wait')==True (len=14: 'Condition.'=10+'wait'=4=14; Condition.wait is an async coroutine that releases the lock, waits for notification, re-acquires the lock); Condition.wait.__qualname__.__len__()==14; Condition.wait_for.__qualname__.__eq__('Condition.wait_for')==True (len=18: 'Condition.'=10+'wait_for'=8=18; wait_for calls wait() until a predicate becomes True); Condition.wait_for.__qualname__.__len__()==18; Condition.notify.__qualname__.__eq__('Condition.notify')==True (len=16: 'Condition.'=10+'notify'=6=16); Condition.notify_all.__qualname__.__eq__('Condition.notify_all')==True (len=20: 'Condition.'=10+'notify_all'=10=20; longest Condition method qualname: 10+10=20, symmetric lengths); qualname length ordering: Condition.wait=14 < Condition.notify=16 (tied with Semaphore.locked=16) < Condition.wait_for=18 < Condition.notify_all=20; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: condcv123

  columns: [id, function, args, expected, description]
  rows:
    - [ntf_vlen,     Condition.notify.__code__.co_varnames.__len__,       [],          2,    "Condition.notify co_varnames.__len__() == 2 (('self','n'); 1 param + 0 locals beyond self); verified with Python 3.14.3"]
    - [ntf_v1_eq,    "Condition.notify.__code__.co_varnames[1].__eq__",   ["n"],       true, "Condition.notify co_varnames[1] == 'n' (len=1; count of waiters to notify; shortest possible param name); verified with Python 3.14.3"]
    - [ntf_v1_len,   "Condition.notify.__code__.co_varnames[1].__len__",  [],          1,    "Condition.notify co_varnames[1].__len__() == 1 ('n'=1; shortest co_varnames element length in asyncio spec); verified with Python 3.14.3"]
    - [ntfall_vlen,  Condition.notify_all.__code__.co_varnames.__len__,   [],          1,    "Condition.notify_all co_varnames.__len__() == 1 (('self',); notify_all needs no count param); verified with Python 3.14.3"]
    - [wait_qn_eq,   Condition.wait.__qualname__.__eq__,                  ["Condition.wait"], true, "Condition.wait.__qualname__ == 'Condition.wait' (len=14: 'Condition.'=10+'wait'=4=14); verified with Python 3.14.3"]
    - [wait_qn_len,  Condition.wait.__qualname__.__len__,                 [],          14,   "Condition.wait.__qualname__.__len__() == 14 (shortest Condition method qualname in spec); verified with Python 3.14.3"]
    - [wfor_qn_eq,   Condition.wait_for.__qualname__.__eq__,              ["Condition.wait_for"], true, "Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18: 'Condition.'=10+'wait_for'=8=18); verified with Python 3.14.3"]
    - [wfor_qn_len,  Condition.wait_for.__qualname__.__len__,             [],          18,   "Condition.wait_for.__qualname__.__len__() == 18 ('Condition.'=10+'wait_for'=8=18); verified with Python 3.14.3"]
    - [ntf_qn_eq,    Condition.notify.__qualname__.__eq__,                ["Condition.notify"], true, "Condition.notify.__qualname__ == 'Condition.notify' (len=16: 'Condition.'=10+'notify'=6=16); verified with Python 3.14.3"]
    - [ntf_qn_len,   Condition.notify.__qualname__.__len__,               [],          16,   "Condition.notify.__qualname__.__len__() == 16 ('Condition.'=10+'notify'=6=16); verified with Python 3.14.3"]
    - [ntfall_qn_eq, Condition.notify_all.__qualname__.__eq__,            ["Condition.notify_all"], true, "Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20; longest Condition method qualname); verified with Python 3.14.3"]
    - [ntfall_qn_len, Condition.notify_all.__qualname__.__len__,          [],          20,   "Condition.notify_all.__qualname__.__len__() == 20 ('Condition.'=10+'notify_all'=10=20; symmetric 10+10); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore.locked and class identity — extra123
#
# Wave 261 theme: Semaphore.locked qualname, Semaphore/Condition MRO lengths.
#
# Semaphore.locked.__qualname__ == 'Semaphore.locked'  (len=16)
# Semaphore.release.__qualname__ == 'Semaphore.release' (len=17)
# Semaphore.__mro__.__len__() == 4
# Condition.__mro__.__len__() == 4
# Event.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table asyncio_extra123.semaphore_locked_and_mro:
  description: "asyncio.Semaphore.locked qualname and class MRO length checks in semlocked123 namespace — wave 261 theme: Semaphore.locked qualname and MRO depths of asyncio sync primitives; Semaphore.locked.__qualname__.__eq__('Semaphore.locked')==True (len=16: 'Semaphore.'=9+'locked'=6=16? wait: 'Semaphore.'=10, not 9: 'S'+'e'+'m'+'a'+'p'+'h'+'o'+'r'+'e'+'.'=10; so 'Semaphore.locked'=10+6=16); Semaphore.locked.__qualname__.__len__()==16 (tied with Condition.notify=16: both are 16-char qualnames from different classes); Semaphore.release.__qualname__.__eq__('Semaphore.release')==True (len=17: 'Semaphore.'=10+'release'=7=17; 1 more than locked=16; tied with Semaphore.acquire=17); Semaphore.release.__qualname__.__len__()==17; Semaphore.__mro__.__len__()==4 (MRO depth 4: Semaphore inherits from multiple base classes including _ContextManagerMixin; deeper than Event.__mro__=3); Condition.__mro__.__len__()==4 (tied with Semaphore=4: both have 4-element MRO chains); Event.__mro__.__len__()==3 (shallower: Event inherits from a different hierarchy with only 3 elements); Event.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Event's sole direct base is _LoopBoundMixin); Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Condition's sole direct base is _ContextManagerMixin; Semaphore.__bases__[0].__name__='_ContextManagerMixin' tied with Condition); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: semlocked123

  columns: [id, function, args, expected, description]
  rows:
    - [locked_qn_eq,   Semaphore.locked.__qualname__.__eq__,             ["Semaphore.locked"],  true, "Semaphore.locked.__qualname__ == 'Semaphore.locked' (len=16: tied with Condition.notify=16); verified with Python 3.14.3"]
    - [locked_qn_len,  Semaphore.locked.__qualname__.__len__,            [],                    16,   "Semaphore.locked.__qualname__.__len__() == 16 ('Semaphore.'=10+'locked'=6=16); verified with Python 3.14.3"]
    - [release_qn_eq,  Semaphore.release.__qualname__.__eq__,            ["Semaphore.release"], true, "Semaphore.release.__qualname__ == 'Semaphore.release' (len=17: tied with Semaphore.acquire=17); verified with Python 3.14.3"]
    - [release_qn_len, Semaphore.release.__qualname__.__len__,           [],                    17,   "Semaphore.release.__qualname__.__len__() == 17 ('Semaphore.'=10+'release'=7=17; 1 more than locked=16); verified with Python 3.14.3"]
    - [sem_mro_len,    asyncio.Semaphore.__mro__.__len__,                [],                    4,    "asyncio.Semaphore.__mro__.__len__() == 4 (deeper than Event=3; tied with Condition=4); verified with Python 3.14.3"]
    - [cond_mro_len,   asyncio.Condition.__mro__.__len__,                [],                    4,    "asyncio.Condition.__mro__.__len__() == 4 (tied with Semaphore=4; deeper than Event=3); verified with Python 3.14.3"]
    - [event_mro_len,  asyncio.Event.__mro__.__len__,                   [],                    3,    "asyncio.Event.__mro__.__len__() == 3 (shallower than Semaphore=4 and Condition=4); verified with Python 3.14.3"]
    - [cond_base0,     "asyncio.Condition.__bases__[0].__name__.__eq__", ["_ContextManagerMixin"], true, "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant asyncio_extra123.Event_set_co_varnames_v1_fut:
  description: "asyncio.Event.set.__code__.co_varnames[1].__eq__('fut') returns True — Event.set co_varnames[1]='fut' (len=3); co_varnames==('self','fut') len=2; 'fut' is a local asyncio.Future variable created inside Event.set when it needs to notify waiting coroutines; co_argcount==1 (self only; 'fut' is a local not a parameter); 'fut'=3 is the same generic Future variable name used in asyncio.Lock.acquire co_varnames[1]='fut'=3 (same name, same len=3; both are parking Futures: Lock.acquire parks self while waiting for the lock; Event.set creates a fut to notify waiters); contrast with Queue.put co_varnames[2]='putter'=6 and Queue.get co_varnames[1]='getter'=6 (Queue uses descriptive 6-char names while Lock/Event use the concise 3-char 'fut'); Event.set.__code__.co_qualname=='Event.set' (len=9: tied with Queue.put/Queue.get=9); NEW in extra123: first standalone Event.set co_varnames[1] equality invariant in eventcv123 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "Event.set.__code__.co_varnames[1].__eq__"
  args: ["fut"]
  expected: true

invariant asyncio_extra123.Condition_notify_co_varnames_v1_n:
  description: "asyncio.Condition.notify.__code__.co_varnames[1].__eq__('n') returns True — Condition.notify co_varnames[1]='n' (len=1); co_varnames==('self','n') len=2; 'n' is the count of waiters to notify (default n=1 in the Condition.notify signature: notify(n=1) notifies n waiters); 'n'=1 char is the shortest possible parameter name and the shortest co_varnames element length observed in asyncio specs in this series; contrast: Lock.acquire co_varnames[1]='fut'=3, Queue.get co_varnames[1]='getter'=6, Queue.__init__ co_varnames[1]='maxsize'=7; 'n' at len=1 is shorter than all of these; using 'n' as a single-letter name for a count/number parameter is a Python convention (analogous to range(n), math operations, etc.); Condition.notify.__qualname__=='Condition.notify' (len=16: 'Condition.'=10+'notify'=6=16); Condition.notify_all.__qualname__=='Condition.notify_all' (len=20: longest Condition method qualname; 'notify_all' is 10 chars vs 'notify'=6: 4 more because '_all' suffix adds 4); NEW in extra123: first standalone Condition.notify co_varnames[1] equality invariant in condcv123 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "Condition.notify.__code__.co_varnames[1].__eq__"
  args: ["n"]
  expected: true

invariant asyncio_extra123.Condition_notify_all_qualname_len_20:
  description: "asyncio.Condition.notify_all.__qualname__.__len__() == 20 — Condition.notify_all.__qualname__=='Condition.notify_all' (20 chars: 'Condition.'=10+'notify_all'=10=20); this is the longest Condition method qualname in this spec; the symmetric 10+10 structure (class prefix 10 chars + method name 10 chars) makes 20 the expected result; qualname length ordering for Condition methods: wait=14 < notify=16 < wait_for=18 < notify_all=20; Condition.notify_all.__class__.__name__=='function' (Python-defined in asyncio.locks); Condition.notify_all.__code__.co_varnames==('self',) len=1 (no parameters beyond self: notify_all does not take a count argument — it always notifies all waiters); compare: asyncio.Queue.put.__code__.co_qualname.__len__()==9 and Condition.notify_all is 11 more chars; NEW in extra123: first standalone Condition.notify_all qualname length invariant in condcv123 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra123.Semaphore_locked_qualname_len_16:
  description: "asyncio.Semaphore.locked.__qualname__.__len__() == 16 — Semaphore.locked.__qualname__=='Semaphore.locked' (16 chars: 'Semaphore.'=10+'locked'=6=16); tied with Condition.notify.__qualname__.__len__()==16 ('Condition.'=10+'notify'=6=16: both are 10-char class prefixes plus a 6-char method name); Semaphore.locked() returns True if the semaphore value is zero (semaphore is locked/acquired), False otherwise (equivalent to checking if further acquire() calls would block); Semaphore.locked.__qualname__ len=16 is 1 less than Semaphore.acquire=17 and Semaphore.release=17 (both acquire and release are 7-char method names while locked is 6 chars); compare: Semaphore.acquire.__qualname__.__len__()==17 (covered in prior specs); locked=6 < acquire=7 == release=7 in method name length; NEW in extra123: first standalone Semaphore.locked qualname length invariant in semlocked123 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Semaphore.locked.__qualname__.__len__
  args: []
  expected: 16

invariant asyncio_extra123.Semaphore_mro_len_4:
  description: "asyncio.Semaphore.__mro__.__len__() == 4 — Semaphore's MRO has 4 elements; it inherits from _ContextManagerMixin which provides __aenter__/__aexit__, and further from _LoopBoundMixin and object; asyncio.Condition.__mro__.__len__()==4 (tied: Condition also inherits from _ContextManagerMixin with a 4-element MRO); asyncio.Event.__mro__.__len__()==3 (shallower: Event inherits from _LoopBoundMixin and object for a 3-element MRO); the MRO depth difference (4 vs 3) reflects that Semaphore and Condition need the context manager mixin (_ContextManagerMixin for async with support) while Event can use a simpler base; Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (same base as Condition); Event.__bases__[0].__name__=='_LoopBoundMixin' (different base); Semaphore.__module__=='asyncio.locks' (Python-defined in Lib/asyncio/locks.py); NEW in extra123: first standalone Semaphore MRO length invariant in semlocked123 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__mro__.__len__
  args: []
  expected: 4
