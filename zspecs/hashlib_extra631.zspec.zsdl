spec: hashlib_extra631
version: ">=3.9"
backend: python_module(hashlib)
docs: "Behavioral spec for hashlib sha3 and shake function identity checks."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib SHA-3 and SHAKE constructors"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that sha3 and shake constructors are builtin_function_or_method and have str __doc__"
  created_at: "2026-04-12T00:00:00Z"

table hashlib_extra631.sha3_class_name:
  description: "sha3 and shake constructor __class__.__name__ identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: hl631sh
  columns: [id, function, args, expected]
  rows:
    - [hl631sh001, hashlib.sha3_224.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl631sh002, hashlib.sha3_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl631sh003, hashlib.sha3_384.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl631sh004, hashlib.sha3_512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl631sh005, hashlib.shake_128.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl631sh006, hashlib.shake_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table hashlib_extra631.sha3_doc_class_name:
  description: "sha3 and shake constructor __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_identity
  id_prefix: hl631dc
  columns: [id, function, args, expected]
  rows:
    - [hl631dc001, hashlib.sha3_224.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl631dc002, hashlib.sha3_256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl631dc003, hashlib.sha3_384.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl631dc004, hashlib.sha3_512.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl631dc005, hashlib.shake_128.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl631dc006, hashlib.shake_256.__doc__.__class__.__name__.__eq__, ["str"], true]
