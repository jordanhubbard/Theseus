spec: threading_extra60
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra59.zspec.zsdl."
    - "Wave 225 theme: __loader__ identity checks + __spec__ attribute chains + module __file__ checks (None for C extensions, path strings for Python files) + __cached__ attribute presence."
    - "threading is a pure-Python module (Lib/threading.py). Its __loader__ is an instance of SourceFileLoader (from _frozen_importlib_external), so threading.__loader__.__class__.__name__ == 'SourceFileLoader'. No prior threading spec has a table row checking __loader__.__class__.__name__.__eq__('SourceFileLoader')."
    - "threading.__spec__ is a ModuleSpec instance (from _frozen_importlib). threading.__spec__.__class__.__name__ == 'ModuleSpec'. No prior threading spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec')."
    - "threading.__file__ is a str (the absolute filesystem path to threading.py). For pure-Python stdlib modules, __file__ is always a str pointing to the .py source file. No prior threading spec has a table row checking __file__.__class__.__name__.__eq__('str')."
    - "threading.__cached__ is a str (the absolute filesystem path to the compiled .pyc bytecode file under __pycache__/). For pure-Python stdlib modules, __cached__ is always a str. No prior threading spec has a table row checking __cached__.__class__.__name__.__eq__('str')."
    - "This spec covers: threading.__loader__.__class__.__name__.__eq__('SourceFileLoader')==true; threading.__spec__.__class__.__name__.__eq__('ModuleSpec')==true; threading.__file__.__class__.__name__.__eq__('str')==true; threading.__cached__.__class__.__name__.__eq__('str')==true."
    - "Key findings: threading.__loader__ is a SourceFileLoader instance — standard loader for pure-Python source files. threading.__spec__ is a ModuleSpec instance with origin pointing to threading.py. threading.__file__ is a str path to threading.py. threading.__cached__ is a str path to threading.cpython-<ver>.pyc in __pycache__/. All four attributes are consistent with pure-Python module identity. Note: threading imports from _thread (a C extension), but threading itself is a pure-Python module in Lib/threading.py, so its own __loader__, __file__, and __cached__ reflect the Python source file, not the C extension. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.__loader__ identity — extra60
#
# Wave 225 theme: __loader__ identity checks.
#
# threading.__loader__ is an instance of SourceFileLoader from
# _frozen_importlib_external. SourceFileLoader is the standard loader that
# CPython's importlib uses for pure-Python source (.py) files. Since threading
# is implemented as Lib/threading.py (a .py source file), its __loader__ is a
# SourceFileLoader instance.
#
# Note: threading internally imports _thread (Modules/_threadmodule.c, a C
# extension). But threading itself (as a module) is Lib/threading.py — a
# pure-Python source file. The __loader__ attribute reflects the loader for
# the threading module itself, not for _thread.
#
# The check: threading.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# — __loader__ is an object whose __class__ is SourceFileLoader, and
# SourceFileLoader.__name__ == 'SourceFileLoader' (17 chars).
#
# No prior threading spec has a table row checking __loader__.__class__.__name__.__eq__('SourceFileLoader').
# New to extra60.
# ---------------------------------------------------------------------------

table threading_extra60.loader_identity:
  description: "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader')==true — threading is pure Python (Lib/threading.py), loaded by SourceFileLoader despite internally using C extension _thread; wave 225 __loader__ identity check; no prior threading spec has table rows for __loader__; new to extra60"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdload60

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq_SourceFileLoader,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading.__loader__ is an instance of _frozen_importlib_external.SourceFileLoader; SourceFileLoader is the standard CPython importlib loader for pure-Python source (.py) files; threading is implemented in Lib/threading.py (a pure-Python source file) even though it internally imports _thread (a C extension in Modules/_threadmodule.c); the __loader__ attribute reflects the loader for the threading module itself (its .py source), not for _thread; __loader__.__class__.__name__ is 'SourceFileLoader' (17 chars); contrast with C built-in modules (itertools) where __loader__ is the BuiltinImporter class itself; no prior threading spec has a table row checking __loader__.__class__.__name__.__eq__('SourceFileLoader'); new to extra60"]

# ---------------------------------------------------------------------------
# threading.__spec__ class identity — extra60
#
# Wave 225 theme: __spec__ attribute chains.
#
# threading.__spec__ is a ModuleSpec instance from _frozen_importlib.
# Every importable Python module has a __spec__ attribute set to a ModuleSpec
# object by the import machinery (PEP 451). For threading, __spec__.origin
# points to the threading.py source file path on disk.
#
# The check: threading.__spec__.__class__.__name__.__eq__('ModuleSpec')
# — __spec__ is a ModuleSpec object, and ModuleSpec.__name__ == 'ModuleSpec' (10 chars).
#
# No prior threading spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec').
# New to extra60.
# ---------------------------------------------------------------------------

table threading_extra60.spec_class_identity:
  description: "threading.__spec__.__class__.__name__.__eq__('ModuleSpec')==true — module spec class is ModuleSpec from _frozen_importlib (PEP 451); origin points to threading.py; wave 225 __spec__ attribute chain; no prior threading spec has table rows for __spec__.__class__.__name__; new to extra60"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdload60

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — threading.__spec__ is an instance of _frozen_importlib.ModuleSpec; the ModuleSpec class was introduced in PEP 451 (Python 3.4) to provide a standardized specification object that the import machinery attaches to every imported module as its __spec__ attribute; ModuleSpec carries name, loader, origin (threading.py filepath), submodule_search_locations, and other import metadata; for threading, __spec__.origin is an absolute path to threading.py; ModuleSpec.__name__ == 'ModuleSpec' (10 chars); this is consistent with functools, inspect (pure-Python) and also with itertools (C builtin) — all have ModuleSpec as their __spec__ class; no prior threading spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec'); new to extra60"]

# ---------------------------------------------------------------------------
# threading.__file__ type check — extra60
#
# Wave 225 theme: module __file__ checks (path strings for Python files).
#
# threading.__file__ is a str — the absolute filesystem path to threading.py.
# For pure-Python stdlib modules, __file__ is always a str because the module
# is loaded from a .py source file on disk. The path is set by SourceFileLoader
# during the import process.
#
# Example: '/opt/homebrew/.../python3.14/lib/python3.14/threading.py'
#
# Contrast with C builtin modules (like itertools): they have no __file__
# attribute at all (hasattr(itertools, '__file__') is False).
#
# The check: threading.__file__.__class__.__name__.__eq__('str')
# — __file__ is a str object, and str.__name__ == 'str' (3 chars).
#
# No prior threading spec has a table row checking __file__.__class__.__name__.__eq__('str').
# New to extra60.
# ---------------------------------------------------------------------------

table threading_extra60.file_type_check:
  description: "threading.__file__.__class__.__name__.__eq__('str')==true — threading is pure Python so __file__ is a str path to threading.py (not None and not missing); wave 225 __file__ check; no prior threading spec has table rows for __file__.__class__.__name__; new to extra60"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdload60

  columns: [id, function, args, expected, description]
  rows:
    - [file_class_name_eq_str,
       __file__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__file__.__class__.__name__.__eq__('str') == True — threading.__file__ is a Python str object containing the absolute filesystem path to the threading.py source file (e.g., '/opt/homebrew/.../lib/python3.14/threading.py'); for pure-Python stdlib modules, __file__ is always a str set by SourceFileLoader during import; threading is a pure-Python module that provides thread synchronization primitives (Thread, Lock, Event, Semaphore, Condition, Barrier, Timer) as wrappers around the lower-level _thread C extension; the str type has __class__.__name__ == 'str' (3 chars); contrast with C builtin modules (itertools) which have no __file__ attribute at all; functools, inspect, and threading all have __file__ as a str; no prior threading spec has a table row checking __file__.__class__.__name__.__eq__('str'); new to extra60"]

# ---------------------------------------------------------------------------
# threading.__cached__ type check — extra60
#
# Wave 225 theme: __cached__ attribute presence.
#
# threading.__cached__ is a str — the absolute filesystem path to the compiled
# bytecode cache file (.pyc) under __pycache__/. For pure-Python stdlib modules,
# __cached__ is always a str pointing to the .pyc file generated by compileall.
#
# Example: '/opt/homebrew/.../python3.14/lib/python3.14/__pycache__/threading.cpython-314.pyc'
#
# Contrast with C builtin modules (like itertools): they have no __cached__
# attribute at all (hasattr(itertools, '__cached__') is False).
#
# The check: threading.__cached__.__class__.__name__.__eq__('str')
# — __cached__ is a str object, and str.__name__ == 'str' (3 chars).
#
# No prior threading spec has a table row checking __cached__.__class__.__name__.__eq__('str').
# New to extra60.
# ---------------------------------------------------------------------------

table threading_extra60.cached_type_check:
  description: "threading.__cached__.__class__.__name__.__eq__('str')==true — threading is pure Python so __cached__ is a str path to the .pyc bytecode cache (not None and not missing); wave 225 __cached__ attribute check; no prior threading spec has table rows for __cached__.__class__.__name__; new to extra60"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdload60

  columns: [id, function, args, expected, description]
  rows:
    - [cached_class_name_eq_str,
       __cached__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__cached__.__class__.__name__.__eq__('str') == True — threading.__cached__ is a Python str object containing the absolute filesystem path to the compiled bytecode cache file for threading (e.g., '/opt/homebrew/.../lib/python3.14/__pycache__/threading.cpython-314.pyc'); for pure-Python stdlib modules, __cached__ is always a str set by the import machinery to the PEP 3147 bytecode cache path under __pycache__/; threading.py compiles to a .pyc bytecode file containing the thread synchronization classes and primitives; the str type has __class__.__name__ == 'str' (3 chars); contrast with C builtin modules (itertools) which have no __cached__ attribute at all because they have no source file and hence no bytecode cache; functools, inspect, and threading all have __cached__ as a str; no prior threading spec has a table row checking __cached__.__class__.__name__.__eq__('str'); new to extra60"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra60
# ---------------------------------------------------------------------------

invariant threading_extra60.loader_is_SourceFileLoader:
  description: "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading is pure Python (Lib/threading.py), loaded by a SourceFileLoader instance; wave 225 __loader__ identity check; new to extra60"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra60.spec_is_ModuleSpec:
  description: "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — threading.__spec__ is a ModuleSpec instance (PEP 451); holds for all importable stdlib modules; wave 225 __spec__ chain; new to extra60"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant threading_extra60.file_is_str:
  description: "threading.__file__.__class__.__name__.__eq__('str') == True — __file__ is a str path for pure-Python modules; absent for C builtins; wave 225 __file__ check; new to extra60"
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra60.cached_is_str:
  description: "threading.__cached__.__class__.__name__.__eq__('str') == True — __cached__ is a str path to .pyc bytecode for pure-Python modules; absent for C builtins; wave 225 __cached__ check; new to extra60"
  kind: python_call_eq
  function: __cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
