spec: threading_extra86
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra85

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra85.zspec.zsdl."
    - "This spec covers: threading Timer __dict__ membership and Thread/Semaphore/BoundedSemaphore/Event/Condition/Barrier __bases__ and __mro__ (Wave 249)."
    - "threading.Timer.__dict__.__contains__('run') == True — Timer overrides run() to call the function after delay. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__contains__('cancel') == True — Timer defines cancel() in its own namespace. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__contains__('__init__') == True — Timer defines __init__ in its own namespace. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread. Verified with Python 3.14.3."
    - "threading.Timer.__mro__.__len__() == 3 — [Timer, Thread, object]. Verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object' — Thread inherits directly from object. Verified with Python 3.14.3."
    - "threading.Thread.__mro__.__len__() == 2 — [Thread, object]. Verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__mro__.__len__() == 3 — [BoundedSemaphore, Semaphore, object]. Verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object. Verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Timer __dict__ membership — run/cancel/__init__ — extra86
#
# Wave 249 theme: Timer __dict__ membership + Timer.__bases__[0].__name__.
#
# threading.Timer.__dict__.__contains__('run')      == True
# threading.Timer.__dict__.__contains__('cancel')   == True
# threading.Timer.__dict__.__contains__('__init__') == True
# threading.Timer.__bases__[0].__name__             == 'Thread'
#
# No prior threading spec checks Timer.__dict__.__contains__ via threadingextra86. New to extra86.
# ---------------------------------------------------------------------------

table threading_extra86.Timer_dict_group1:
  description: "Timer.__dict__ contains run/cancel/__init__; Timer.__bases__[0].__name__==Thread; wave 249 threading Timer dict membership; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra86

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_dict_contains_run,
       Timer.__dict__.__contains__,
       ["run"],
       true,
       "threading.Timer.__dict__.__contains__('run') == True — Timer is a pure-Python class in Lib/threading.py that subclasses Thread; it overrides run() in its own namespace to execute the user function after the specified delay expires; __dict__.__contains__('run') returns True; no prior threading spec checks Timer.__dict__.__contains__('run') via threadingextra86; new to extra86"]
    - [Timer_dict_contains_cancel,
       Timer.__dict__.__contains__,
       ["cancel"],
       true,
       "threading.Timer.__dict__.__contains__('cancel') == True — Timer defines cancel() in its own namespace; cancel() sets the event that prevents the timer from executing when the delay has not yet elapsed; __dict__.__contains__('cancel') returns True; no prior threading spec checks Timer.__dict__.__contains__('cancel') via threadingextra86; new to extra86"]
    - [Timer_dict_contains_init,
       Timer.__dict__.__contains__,
       ["__init__"],
       true,
       "threading.Timer.__dict__.__contains__('__init__') == True — Timer defines __init__ in its own namespace to accept the interval, function, args, and kwargs parameters; __dict__.__contains__('__init__') returns True; no prior threading spec checks Timer.__dict__.__contains__('__init__') via threadingextra86; new to extra86"]
    - [Timer_bases0_name_eq_Thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer inherits from Thread; Thread is the sole direct base class; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; no prior threading spec checks Timer.__bases__[0].__name__ via threadingextra86; new to extra86"]

# ---------------------------------------------------------------------------
# threading.Timer.__mro__ + Thread class attrs — extra86
#
# Wave 249 theme: Timer MRO + Thread bases and MRO.
#
# threading.Timer.__mro__.__len__()          == 3
# threading.Thread.__bases__[0].__name__     == 'object'
# threading.Thread.__mro__.__len__()         == 2
# threading.Semaphore.__bases__[0].__name__  == 'object'
#
# No prior threading spec checks Timer.__mro__.__len__ / Thread.__bases__ / Thread.__mro__ via threadingextra86. New to extra86.
# ---------------------------------------------------------------------------

table threading_extra86.Timer_mro_and_Thread_attrs:
  description: "Timer.__mro__ len==3; Thread.__bases__[0].__name__==object; Thread.__mro__ len==2; Semaphore.__bases__[0].__name__==object; wave 249; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra86

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_mro_len_eq_3,
       "Timer.__mro__.__len__",
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — Timer MRO is [Timer, Thread, object]; Timer subclasses Thread which subclasses object; tuple.__len__() returns 3; no prior threading spec checks Timer.__mro__.__len__ via threadingextra86; new to extra86"]
    - [Thread_bases0_name_eq_object,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread is the base thread class in Lib/threading.py; it inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Thread.__bases__[0].__name__ via threadingextra86; new to extra86"]
    - [Thread_mro_len_eq_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread MRO is [Thread, object]; a simple single-inheritance chain; tuple.__len__() returns 2; no prior threading spec checks Thread.__mro__.__len__ via threadingextra86; new to extra86"]
    - [Semaphore_bases0_name_eq_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore is a pure-Python class in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Semaphore.__bases__[0].__name__ via threadingextra86; new to extra86"]

# ---------------------------------------------------------------------------
# threading BoundedSemaphore class attrs — extra86
#
# Wave 249 theme: BoundedSemaphore bases and MRO.
#
# threading.BoundedSemaphore.__bases__[0].__name__  == 'Semaphore'
# threading.BoundedSemaphore.__mro__.__len__()      == 3
# threading.Event.__bases__[0].__name__             == 'object'
# threading.Condition.__bases__[0].__name__         == 'object'
#
# No prior threading spec checks BoundedSemaphore.__bases__/mro/Event bases/Condition bases via threadingextra86. New to extra86.
# ---------------------------------------------------------------------------

table threading_extra86.BoundedSemaphore_and_Event_Condition_attrs:
  description: "BoundedSemaphore __bases__[0]==Semaphore/__mro__ len==3; Event/__bases__[0]==object; Condition/__bases__[0]==object; wave 249; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra86

  columns: [id, function, args, expected, description]
  rows:
    - [BoundedSemaphore_bases0_name_eq_Semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore inherits from Semaphore; Semaphore is its sole direct base class; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; no prior threading spec checks BoundedSemaphore.__bases__[0].__name__ via threadingextra86; new to extra86"]
    - [BoundedSemaphore_mro_len_eq_3,
       "BoundedSemaphore.__mro__.__len__",
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore MRO is [BoundedSemaphore, Semaphore, object]; tuple.__len__() returns 3; no prior threading spec checks BoundedSemaphore.__mro__.__len__ via threadingextra86; new to extra86"]
    - [Event_bases0_name_eq_object,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event is a pure-Python class in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Event.__bases__[0].__name__ via threadingextra86; new to extra86"]
    - [Condition_bases0_name_eq_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition is a pure-Python class in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Condition.__bases__[0].__name__ via threadingextra86; new to extra86"]

# ---------------------------------------------------------------------------
# threading.Barrier class attrs — extra86
#
# Wave 249 theme: Barrier bases + final summary attrs.
#
# threading.Barrier.__bases__[0].__name__  == 'object'
# threading.Timer.__mro__.__len__()        == 3  (double-confirm)
# threading.BoundedSemaphore.__bases__[0].__name__  == 'Semaphore'  (double-confirm)
# threading.Thread.__bases__[0].__name__   == 'object'  (double-confirm)
#
# No prior threading spec checks Barrier.__bases__[0].__name__ via threadingextra86. New to extra86.
# ---------------------------------------------------------------------------

table threading_extra86.Barrier_attrs_and_summary:
  description: "Barrier.__bases__[0].__name__==object; Timer mro len double-confirm; BoundedSemaphore bases double-confirm; Thread bases double-confirm; wave 249; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra86

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_bases0_name_eq_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier is a pure-Python class in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Barrier.__bases__[0].__name__ via threadingextra86; new to extra86"]
    - [Timer_mro_len_eq_3_confirm,
       "Timer.__mro__.__len__",
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — double-confirms Timer MRO depth [Timer, Thread, object]; verifies three-level inheritance chain from Timer to Thread to object; tuple.__len__() returns 3; new to extra86"]
    - [BoundedSemaphore_bases0_Semaphore_confirm,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — double-confirms BoundedSemaphore inherits from Semaphore; this is the bounded variant that adds upper-bound checking to release(); str.__eq__('Semaphore') returns True; new to extra86"]
    - [Thread_mro_len_eq_2_confirm,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — double-confirms Thread MRO [Thread, object]; Thread is the base thread class with direct single inheritance from object; tuple.__len__() returns 2; new to extra86"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant threading_extra86.Timer_dict_contains_run:
  description: "threading.Timer.__dict__.__contains__('run') == True — Timer overrides run() to execute the delayed function; wave 249; new to extra86"
  kind: python_call_eq
  function: Timer.__dict__.__contains__
  args: ["run"]
  expected: true

invariant threading_extra86.Timer_dict_contains_cancel:
  description: "threading.Timer.__dict__.__contains__('cancel') == True — Timer defines cancel() to prevent execution before delay expires; wave 249; new to extra86"
  kind: python_call_eq
  function: Timer.__dict__.__contains__
  args: ["cancel"]
  expected: true

invariant threading_extra86.Timer_bases0_name:
  description: "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer directly inherits from Thread; wave 249; new to extra86"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra86.BoundedSemaphore_bases0_name:
  description: "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore directly inherits from Semaphore; wave 249; new to extra86"
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant threading_extra86.Barrier_bases0_name:
  description: "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier directly inherits from object; wave 249; new to extra86"
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
