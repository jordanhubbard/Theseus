  function: getcomments.__name__.__eq__
  args: ["getcomments"]
  expected: true

invariant inspect_extra386.getcomments_module:
  description: "inspect.getcomments.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra386"
  kind: python_call_eq
  function: getcomments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra386.cleandoc_name:
  description: "inspect.cleandoc.__name__ == 'cleandoc' — pure-Python function in Lib/inspect.py; new to extra386"
  kind: python_call_eq
  function: cleandoc.__name__.__eq__
  args: ["cleandoc"]
  expected: true

invariant inspect_extra386.cleandoc_module:
  description: "inspect.cleandoc.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra386"
  kind: python_call_eq
