spec: inspect_extra386
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.getfile.__name__ == 'getfile', __module__ == 'inspect' — pure-Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.getsourcefile.__name__ == 'getsourcefile', __module__ == 'inspect' — pure-Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.getdoc.__name__ == 'getdoc', __module__ == 'inspect' — pure-Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.getcomments.__name__ == 'getcomments', __module__ == 'inspect' — pure-Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.cleandoc.__name__ == 'cleandoc', __module__ == 'inspect' — pure-Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs', __module__ == 'inspect' — pure-Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect source-retrieval functions __name__ and __module__
#
# inspect.getfile.__name__ == 'getfile'
# inspect.getfile.__module__ == 'inspect'
# inspect.getsourcefile.__name__ == 'getsourcefile'
# inspect.getsourcefile.__module__ == 'inspect'
# inspect.getdoc.__name__ == 'getdoc'
# inspect.getdoc.__module__ == 'inspect'
#
# These are pure-Python helper functions defined in Lib/inspect.py that
# retrieve the file, source file, and documentation string for live objects.
# ---------------------------------------------------------------------------

table inspect_extra386.source_retrieval_identity:
  description: "inspect.getfile, inspect.getsourcefile, and inspect.getdoc __name__ and __module__ identity; new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsr386

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_name_eq,
       "getfile.__name__.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — getfile is a pure-Python function in Lib/inspect.py that returns the name of the file in which an object was defined; __name__ is 'getfile'; str.__eq__('getfile') returns True; new to extra386"]
    - [getfile_module_eq,
       "getfile.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra386"]
    - [getsourcefile_name_eq,
       "getsourcefile.__name__.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__name__.__eq__('getsourcefile') == True — getsourcefile is a pure-Python function in Lib/inspect.py that returns the name of the Python source file in which an object was defined; __name__ is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra386"]
    - [getsourcefile_module_eq,
       "getsourcefile.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getsourcefile.__module__.__eq__('inspect') == True — getsourcefile is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra386"]
    - [getdoc_name_eq,
       "getdoc.__name__.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__name__.__eq__('getdoc') == True — getdoc is a pure-Python function in Lib/inspect.py that retrieves the documentation string for an object, cleaning it with cleandoc; __name__ is 'getdoc'; str.__eq__('getdoc') returns True; new to extra386"]
    - [getdoc_module_eq,
       "getdoc.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — getdoc is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Table 2: inspect comment/doc utility and class-attr functions identity
#
# inspect.getcomments.__name__ == 'getcomments'
# inspect.getcomments.__module__ == 'inspect'
# inspect.cleandoc.__name__ == 'cleandoc'
# inspect.cleandoc.__module__ == 'inspect'
# inspect.classify_class_attrs.__name__ == 'classify_class_attrs'
# inspect.classify_class_attrs.__module__ == 'inspect'
#
# All are pure-Python functions in Lib/inspect.py. getcomments returns lines of
# comments immediately preceding an object's source. cleandoc trims leading
# whitespace from a docstring. classify_class_attrs classifies the attributes
# of a class by how they are inherited or defined.
# ---------------------------------------------------------------------------

table inspect_extra386.comment_and_classify_identity:
  description: "inspect.getcomments, inspect.cleandoc, and inspect.classify_class_attrs __name__ and __module__ identity; new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcc386

  columns: [id, function, args, expected, description]
  rows:
    - [getcomments_name_eq,
       "getcomments.__name__.__eq__",
       ["getcomments"],
       true,
       "inspect.getcomments.__name__.__eq__('getcomments') == True — getcomments is a pure-Python function in Lib/inspect.py that returns lines of comments immediately preceding an object's source code; __name__ is 'getcomments'; str.__eq__('getcomments') returns True; new to extra386"]
    - [getcomments_module_eq,
       "getcomments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getcomments.__module__.__eq__('inspect') == True — getcomments is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra386"]
    - [cleandoc_name_eq,
       "cleandoc.__name__.__eq__",
       ["cleandoc"],
       true,
       "inspect.cleandoc.__name__.__eq__('cleandoc') == True — cleandoc is a pure-Python function in Lib/inspect.py that trims leading whitespace from docstrings; __name__ is 'cleandoc'; str.__eq__('cleandoc') returns True; new to extra386"]
    - [cleandoc_module_eq,
       "cleandoc.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.cleandoc.__module__.__eq__('inspect') == True — cleandoc is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra386"]
    - [classify_class_attrs_name_eq,
       "classify_class_attrs.__name__.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__eq__('classify_class_attrs') == True — classify_class_attrs is a pure-Python function in Lib/inspect.py that classifies the attributes of a class as method, class method, static method, property, or data; __name__ is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra386"]
    - [classify_class_attrs_module_eq,
       "classify_class_attrs.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — classify_class_attrs is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra386
# ---------------------------------------------------------------------------

invariant inspect_extra386.getfile_name:
  description: "inspect.getfile.__name__ == 'getfile' — pure-Python function in Lib/inspect.py; new to extra386"
  kind: python_call_eq
  function: getfile.__name__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra386.getfile_module:
  description: "inspect.getfile.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra386"
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra386.getsourcefile_name:
  description: "inspect.getsourcefile.__name__ == 'getsourcefile' — pure-Python function in Lib/inspect.py; new to extra386"
  kind: python_call_eq
