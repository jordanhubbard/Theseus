spec: io_extra135
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/iobase.c"
  notes:
    - "This spec covers: io.IOBase class method qualnames and inheritance chain."
    - "io.IOBase.__name__ == 'IOBase' (length 6)."
    - "io.IOBase.__module__ == 'io' (length 2) — the public wrapper module, not '_io'."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase directly extends the private C base _IOBase."
    - "io.IOBase.__mro__.__len__() == 3 — MRO is [IOBase, _IOBase, object]."
    - "All io.IOBase methods are actually defined on _IOBase (C extension), so their __qualname__ starts with '_IOBase.'."
    - "io.IOBase.close.__qualname__ == '_IOBase.close' (length 13)."
    - "io.IOBase.readline.__qualname__ == '_IOBase.readline' (length 16)."
    - "io.IOBase.readlines.__qualname__ == '_IOBase.readlines' (length 17)."
    - "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' (length 18)."
    - "io.IOBase.seek.__qualname__ == '_IOBase.seek' (length 12)."
    - "io.IOBase.tell.__qualname__ == '_IOBase.tell' (length 12)."
    - "io.IOBase.flush.__qualname__ == '_IOBase.flush' (length 13)."
    - "io.IOBase.truncate.__qualname__ == '_IOBase.truncate' (length 16)."
    - "io.IOBase.fileno.__qualname__ == '_IOBase.fileno' (length 14)."
    - "io.IOBase.isatty.__qualname__ == '_IOBase.isatty' (length 14)."
    - "io.IOBase.readable.__qualname__ == '_IOBase.readable' (length 16)."
    - "io.IOBase.writable.__qualname__ == '_IOBase.writable' (length 16)."
    - "io.IOBase.seekable.__qualname__ == '_IOBase.seekable' (length 16)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase class identity: __name__, __module__, __bases__, __mro__
# io.IOBase is the public Python-level wrapper; the actual C type is _IOBase.
# __bases__[0].__name__ == '_IOBase' (not 'object').
# __mro__ length == 3: [IOBase, _IOBase, object].
# ---------------------------------------------------------------------------

table io_extra135.IOBase_class_identity:
  description: "io.IOBase class identity: __name__ ('IOBase', len 6), __module__ ('io', len 2), __bases__[0].__name__ ('_IOBase'), __mro__.__len__() (3)"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioiobase135

  columns: [id, function, args, expected]
  rows:
    - [iobase_name_eq,      IOBase.__name__.__eq__,                   ["IOBase"],  true]
    - [iobase_name_len,     IOBase.__name__.__len__,                  [],          6]
    - [iobase_module_eq,    IOBase.__module__.__eq__,                 ["io"],      true]
    - [iobase_module_len,   IOBase.__module__.__len__,                [],          2]
    - [iobase_module_not,   IOBase.__module__.__eq__,                 ["_io"],     false]
    - [iobase_base_eq,      "IOBase.__bases__[0].__name__.__eq__",    ["_IOBase"], true]
    - [iobase_base_not_obj, "IOBase.__bases__[0].__name__.__eq__",    ["object"],  false]
    - [iobase_mro_len,      IOBase.__mro__.__len__,                   [],          3]

# ---------------------------------------------------------------------------
# io.IOBase read/write method __qualname__ equality and lengths
# All methods are defined on _IOBase (C extension), so qualnames start with '_IOBase.'.
# close (len 13), readline (len 16), readlines (len 17), writelines (len 18).
# ---------------------------------------------------------------------------

table io_extra135.IOBase_read_write_qualnames:
  description: "io.IOBase read/write method __qualname__ values: close='_IOBase.close'(13), readline='_IOBase.readline'(16), readlines='_IOBase.readlines'(17), writelines='_IOBase.writelines'(18)"
  kind: python_call_eq
  category: qualname
  id_prefix: ioiobase135

  columns: [id, function, args, expected]
  rows:
    - [close_qname_eq,      IOBase.close.__qualname__.__eq__,      ["_IOBase.close"],      true]
    - [close_qname_len,     IOBase.close.__qualname__.__len__,     [],                     13]
    - [readline_qname_eq,   IOBase.readline.__qualname__.__eq__,   ["_IOBase.readline"],   true]
    - [readline_qname_len,  IOBase.readline.__qualname__.__len__,  [],                     16]
    - [readlines_qname_eq,  IOBase.readlines.__qualname__.__eq__,  ["_IOBase.readlines"],  true]
    - [readlines_qname_len, IOBase.readlines.__qualname__.__len__, [],                     17]
    - [writelines_qname_eq, IOBase.writelines.__qualname__.__eq__, ["_IOBase.writelines"], true]
    - [writelines_qname_len,IOBase.writelines.__qualname__.__len__,[],                     18]

# ---------------------------------------------------------------------------
# io.IOBase seek/stream method __qualname__ equality and lengths
# seek/tell (len 12), flush/close (len 13), fileno/isatty (len 14),
# truncate/readable/writable/seekable (len 16).
# ---------------------------------------------------------------------------

table io_extra135.IOBase_seek_stream_qualnames:
  description: "io.IOBase seek/stream method __qualname__ lengths: seek/tell=12, flush=13, fileno/isatty=14, truncate/readable/writable/seekable=16"
  kind: python_call_eq
  category: qualname
  id_prefix: ioiobase135

  columns: [id, function, args, expected]
  rows:
    - [seek_qname_len,     IOBase.seek.__qualname__.__len__,     [], 12]
    - [tell_qname_len,     IOBase.tell.__qualname__.__len__,     [], 12]
    - [flush_qname_len,    IOBase.flush.__qualname__.__len__,    [], 13]
    - [fileno_qname_len,   IOBase.fileno.__qualname__.__len__,   [], 14]
    - [isatty_qname_len,   IOBase.isatty.__qualname__.__len__,   [], 14]
    - [truncate_qname_len, IOBase.truncate.__qualname__.__len__, [], 16]
    - [readable_qname_len, IOBase.readable.__qualname__.__len__, [], 16]
    - [writable_qname_len, IOBase.writable.__qualname__.__len__, [], 16]
    - [seekable_qname_len, IOBase.seekable.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra135.IOBase.name_is_IOBase:
  description: "io.IOBase.__name__ == 'IOBase' (length 6; the public Python-level ABC name)"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra135.IOBase.module_is_io:
  description: "io.IOBase.__module__ == 'io' (length 2; IOBase is exposed via the public 'io' module, not the internal '_io' C extension)"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra135.IOBase.mro_len_3:
  description: "io.IOBase.__mro__.__len__() == 3 (MRO is [IOBase, _IOBase, object]; _IOBase is the private C base)"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__mro__.__len__
  args: []
  expected: 3

invariant io_extra135.IOBase.writelines_qualname_eq:
  description: "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' (length 18; longest of the four read/write method qualnames)"
  category: qualname
  kind: python_call_eq
  function: IOBase.writelines.__qualname__.__eq__
  args: ["_IOBase.writelines"]
  expected: true

invariant io_extra135.IOBase.readline_qualname_len:
  description: "io.IOBase.readline.__qualname__.__len__() == 16 ('_IOBase.readline' has 16 characters)"
  category: qualname
  kind: python_call_eq
  function: IOBase.readline.__qualname__.__len__
  args: []
  expected: 16
