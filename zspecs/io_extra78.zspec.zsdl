spec: io_extra78
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra77."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase.__dict__ membership."
    - "io_extra77 covers RawIOBase/BufferedIOBase/TextIOBase method descriptor identity and IOBase.__dict__ membership for __module__, __doc__, __abstractmethods__, _abc_impl."
    - "This spec covers: RawIOBase/BufferedIOBase/TextIOBase __dict__.__class__.__name__ == 'mappingproxy'; __dict__ membership for __module__ and __abstractmethods__; FileIO/__module__ == '_io'; BufferedReader/__name__; BytesIO/__name__; StringIO/__name__."
    - "io.RawIOBase.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy."
    - "io.RawIOBase.__dict__.__contains__('__module__') == True — pure Python ABC sets __module__."
    - "io.RawIOBase.__dict__.__contains__('__abstractmethods__') == True."
    - "io.BufferedIOBase.__dict__.__class__.__name__ == 'mappingproxy'."
    - "io.BufferedIOBase.__dict__.__contains__('__module__') == True."
    - "io.TextIOBase.__dict__.__class__.__name__ == 'mappingproxy'."
    - "io.TextIOBase.__dict__.__contains__('__module__') == True."
    - "io.FileIO.__name__ == 'FileIO'."
    - "io.FileIO.__module__ == '_io' — FileIO is a C extension class."
    - "io.BufferedReader.__name__ == 'BufferedReader'."
    - "io.BytesIO.__name__ == 'BytesIO'."
    - "io.StringIO.__name__ == 'StringIO'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# RawIOBase, BufferedIOBase, TextIOBase __dict__ class checks
# All three are pure Python ABCs in Python 3.14; their __dict__ is a
# mappingproxy. Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra78.ABC_dict_class:
  description: "RawIOBase, BufferedIOBase, TextIOBase __dict__ is a mappingproxy"
  kind: python_call_eq
  category: class_dict
  id_prefix: ioann78

  columns: [id, function, args, expected]
  rows:
    - [raw_dict_class,      RawIOBase.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [buffered_dict_class, BufferedIOBase.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [text_dict_class,     TextIOBase.__dict__.__class__.__name__.__eq__,     ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# RawIOBase, BufferedIOBase, TextIOBase __dict__ membership for __module__
# Each ABC sets __module__ in its class dict. Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra78.ABC_dict_module_member:
  description: "RawIOBase, BufferedIOBase, TextIOBase __dict__ contains '__module__'"
  kind: python_call_eq
  category: class_dict
  id_prefix: ioann78

  columns: [id, function, args, expected]
  rows:
    - [raw_has_module,      "RawIOBase.__dict__.__contains__",      ["__module__"], true]
    - [buffered_has_module, "BufferedIOBase.__dict__.__contains__", ["__module__"], true]
    - [text_has_module,     "TextIOBase.__dict__.__contains__",     ["__module__"], true]

# ---------------------------------------------------------------------------
# RawIOBase and BufferedIOBase __dict__ membership for __abstractmethods__
# Both ABCs store __abstractmethods__ in their class dict.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra78.ABC_dict_abstractmethods:
  description: "RawIOBase and BufferedIOBase __dict__ contains '__abstractmethods__'"
  kind: python_call_eq
  category: class_dict
  id_prefix: ioann78

  columns: [id, function, args, expected]
  rows:
    - [raw_has_abstractmethods,      "RawIOBase.__dict__.__contains__",      ["__abstractmethods__"], true]
    - [buffered_has_abstractmethods, "BufferedIOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - [text_has_abstractmethods,     "TextIOBase.__dict__.__contains__",     ["__abstractmethods__"], true]

# ---------------------------------------------------------------------------
# FileIO, BufferedReader, BytesIO, StringIO identity checks
# __name__ and __module__ for concrete C-implemented io classes.
# FileIO.__module__ == '_io' confirms C extension origin.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra78.concrete_class_identity:
  description: "FileIO, BufferedReader, BytesIO, StringIO __name__ and __module__ identity"
  kind: python_call_eq
  category: class_names
  id_prefix: ioann78

  columns: [id, function, args, expected]
  rows:
    - [fileio_name,         FileIO.__name__.__eq__,          ["FileIO"],          true]
    - [fileio_module,       FileIO.__module__.__eq__,        ["_io"],             true]
    - [buffered_reader,     BufferedReader.__name__.__eq__,  ["BufferedReader"],  true]
    - [bytesio_name,        BytesIO.__name__.__eq__,         ["BytesIO"],         true]
    - [stringio_name,       StringIO.__name__.__eq__,        ["StringIO"],        true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra78.RawIOBase_dict.mappingproxy:
  description: "io.RawIOBase.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: RawIOBase.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra78.BufferedIOBase_dict.mappingproxy:
  description: "io.BufferedIOBase.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: BufferedIOBase.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra78.TextIOBase_dict.mappingproxy:
  description: "io.TextIOBase.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: TextIOBase.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra78.FileIO.name_eq:
  description: "io.FileIO.__name__ == 'FileIO'"
  category: class_names
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra78.FileIO.module_c_ext:
  description: "io.FileIO.__module__ == '_io' — C extension class"
  category: class_names
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true
