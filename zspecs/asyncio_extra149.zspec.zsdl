spec: asyncio_extra149
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers asyncio.Task method __qualname__ attributes and asyncio.Task.__dict__ size. asyncio.Task is implemented in C (_asyncio module, not asyncio.tasks), so asyncio.Task.__module__=='_asyncio' (len=8). asyncio.Task.__dict__.__len__()==31 (mappingproxy). asyncio.Task.__dict__.__class__.__name__=='mappingproxy'. asyncio.Task.cancel.__qualname__=='Task.cancel' (len=11). asyncio.Task.result.__qualname__=='Task.result' (len=11). asyncio.Task.exception.__qualname__=='Task.exception' (len=14). asyncio.Task.done.__qualname__=='Task.done' (len=9). asyncio.Task.cancelled.__qualname__=='Task.cancelled' (len=14). asyncio.Task.add_done_callback.__qualname__=='Task.add_done_callback' (len=22: the longest in this spec). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task methods are method_descriptor objects (C-level), not Python functions, so they have no __module__ attribute (returns None) and no __code__ attribute. Only __qualname__ and __name__ are reliably accessible. asyncio.Task.__module__=='_asyncio' (the underlying C extension module). asyncio.Task.__name__=='Task' (len=4). asyncio.Task.__dict__.__len__()==31. asyncio.Future.__dict__.__len__()==30 (also from _asyncio). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task method qualnames — extra149
#
# asyncio.Task.cancel.__qualname__           == 'Task.cancel'           (len=11)
# asyncio.Task.result.__qualname__           == 'Task.result'           (len=11)
# asyncio.Task.exception.__qualname__        == 'Task.exception'        (len=14)
# asyncio.Task.done.__qualname__             == 'Task.done'             (len=9)
# asyncio.Task.cancelled.__qualname__        == 'Task.cancelled'        (len=14)
# asyncio.Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (len=22)
# ---------------------------------------------------------------------------

table asyncio_extra149.task_method_qualnames:
  description: "asyncio.Task method __qualname__ checks in task_qn149 namespace — asyncio.Task.cancel.__qualname__.__eq__('Task.cancel')==True (len=11: 'Task'=4+'.'=1+'cancel'=6=11; tied with result for shortest in this spec); asyncio.Task.result.__qualname__.__eq__('Task.result')==True (len=11: 'Task'=4+'.'=1+'result'=6=11; tied with cancel); asyncio.Task.exception.__qualname__.__eq__('Task.exception')==True (len=14: 'Task'=4+'.'=1+'exception'=9=14; tied with cancelled); asyncio.Task.done.__qualname__.__eq__('Task.done')==True (len=9: 'Task'=4+'.'=1+'done'=4=9; shortest in this spec); asyncio.Task.cancelled.__qualname__.__eq__('Task.cancelled')==True (len=14: 'Task'=4+'.'=1+'cancelled'=9=14; tied with exception); asyncio.Task.add_done_callback.__qualname__.__eq__('Task.add_done_callback')==True (len=22: 'Task'=4+'.'=1+'add_done_callback'=17=22; longest in this spec); asyncio.Task is a C-level class from _asyncio so methods are method_descriptor objects; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: task_qn149

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_qn_eq,     asyncio.Task.cancel.__qualname__.__eq__,            ["Task.cancel"],            true,  "asyncio.Task.cancel.__qualname__ == 'Task.cancel' (len=11); verified with Python 3.14.3"]
    - [cancel_qn_len,    asyncio.Task.cancel.__qualname__.__len__,            [],                         11,    "asyncio.Task.cancel.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [result_qn_eq,     asyncio.Task.result.__qualname__.__eq__,            ["Task.result"],            true,  "asyncio.Task.result.__qualname__ == 'Task.result' (len=11); verified with Python 3.14.3"]
    - [result_qn_len,    asyncio.Task.result.__qualname__.__len__,            [],                         11,    "asyncio.Task.result.__qualname__.__len__() == 11 (tied with cancel); verified with Python 3.14.3"]
    - [exception_qn_eq,  asyncio.Task.exception.__qualname__.__eq__,         ["Task.exception"],         true,  "asyncio.Task.exception.__qualname__ == 'Task.exception' (len=14); verified with Python 3.14.3"]
    - [exception_qn_len, asyncio.Task.exception.__qualname__.__len__,         [],                         14,    "asyncio.Task.exception.__qualname__.__len__() == 14 (tied with cancelled); verified with Python 3.14.3"]
    - [done_qn_eq,       asyncio.Task.done.__qualname__.__eq__,              ["Task.done"],              true,  "asyncio.Task.done.__qualname__ == 'Task.done' (len=9; shortest in this spec); verified with Python 3.14.3"]
    - [done_qn_len,      asyncio.Task.done.__qualname__.__len__,              [],                         9,     "asyncio.Task.done.__qualname__.__len__() == 9 (shortest in this spec); verified with Python 3.14.3"]
    - [cancelled_qn_eq,  asyncio.Task.cancelled.__qualname__.__eq__,         ["Task.cancelled"],         true,  "asyncio.Task.cancelled.__qualname__ == 'Task.cancelled' (len=14); verified with Python 3.14.3"]
    - [cancelled_qn_len, asyncio.Task.cancelled.__qualname__.__len__,         [],                         14,    "asyncio.Task.cancelled.__qualname__.__len__() == 14 (tied with exception); verified with Python 3.14.3"]
    - [adc_qn_eq,        asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true,  "asyncio.Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (len=22; longest in this spec); verified with Python 3.14.3"]
    - [adc_qn_len,       asyncio.Task.add_done_callback.__qualname__.__len__, [],                         22,    "asyncio.Task.add_done_callback.__qualname__.__len__() == 22 (longest in this spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task and asyncio.Future __dict__ attributes — extra149
#
# asyncio.Task.__dict__.__len__()             == 31
# asyncio.Task.__dict__.__class__.__name__    == 'mappingproxy'
# asyncio.Task.__name__.__len__()             == 4
# asyncio.Task.__module__.__eq__('_asyncio')  == True   (len=8)
# asyncio.Future.__dict__.__len__()           == 30
# asyncio.Future.__dict__.__class__.__name__  == 'mappingproxy'
# ---------------------------------------------------------------------------

table asyncio_extra149.task_and_future_dict:
  description: "asyncio.Task and asyncio.Future __dict__ attribute checks in task_qn149 namespace — asyncio.Task.__dict__.__len__()==31 (31 entries in the Task class namespace mappingproxy; asyncio.Task is implemented in C so these include C-level method wrappers and class attributes); asyncio.Task.__dict__.__class__.__name__.__eq__('mappingproxy')==True (the type's __dict__ is always a mappingproxy for C-extension classes); asyncio.Task.__name__.__eq__('Task')==True (len=4: 'T'+'a'+'s'+'k'=4); asyncio.Task.__name__.__len__()==4; asyncio.Task.__module__.__eq__('_asyncio')==True (len=8: Task is from the C extension module _asyncio, NOT from asyncio.tasks; '_asyncio'=8 chars); asyncio.Task.__module__.__len__()==8; asyncio.Future.__dict__.__len__()==30 (1 fewer than Task at 31; Future is also from _asyncio); asyncio.Future.__dict__.__class__.__name__.__eq__('mappingproxy')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: task_dict149

  columns: [id, function, args, expected, description]
  rows:
    - [task_dict_len,     asyncio.Task.__dict__.__len__,                      [],              31,    "asyncio.Task.__dict__.__len__() == 31; verified with Python 3.14.3"]
    - [task_dict_cls,     asyncio.Task.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true,  "asyncio.Task.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [task_name_eq,      asyncio.Task.__name__.__eq__,                       ["Task"],        true,  "asyncio.Task.__name__ == 'Task' (len=4); verified with Python 3.14.3"]
    - [task_name_len,     asyncio.Task.__name__.__len__,                       [],              4,     "asyncio.Task.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [task_mod_eq,       asyncio.Task.__module__.__eq__,                     ["_asyncio"],    true,  "asyncio.Task.__module__ == '_asyncio' (C extension, len=8); verified with Python 3.14.3"]
    - [task_mod_len,      asyncio.Task.__module__.__len__,                     [],              8,     "asyncio.Task.__module__.__len__() == 8 ('_asyncio'); verified with Python 3.14.3"]
    - [future_dict_len,   asyncio.Future.__dict__.__len__,                     [],              30,    "asyncio.Future.__dict__.__len__() == 30 (1 fewer than Task); verified with Python 3.14.3"]
    - [future_dict_cls,   asyncio.Future.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true,  "asyncio.Future.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra149
# ---------------------------------------------------------------------------

invariant asyncio_extra149.task_cancel_qualname_len_11:
  description: "asyncio.Task.cancel.__qualname__.__len__() == 11 — asyncio.Task.cancel.__qualname__ is 'Task.cancel' (11 chars: 'Task'=4+'.'=1+'cancel'=6=11); tied with asyncio.Task.result.__qualname__.__len__()==11 for the joint-shortest qualnames in this spec (along with 'Task.result'); the shortest single-name qualname is asyncio.Task.done at 9; asyncio.Task.cancel cancels the Task by scheduling a CancelledError exception; since Task is C-implemented (_asyncio), cancel is a method_descriptor not a Python function; asyncio.Task.__module__=='_asyncio' (len=8); NEW in extra149: first standalone asyncio.Task.cancel qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.cancel.__qualname__.__len__
  args: []
  expected: 11

invariant asyncio_extra149.task_done_qualname_len_9:
  description: "asyncio.Task.done.__qualname__.__len__() == 9 — asyncio.Task.done.__qualname__ is 'Task.done' (9 chars: 'Task'=4+'.'=1+'done'=4=9); the shortest qualname in this spec (compare: cancel/result=11, exception/cancelled=14, add_done_callback=22); asyncio.Task.done() returns True if the Task is finished (either completed normally, raised an exception, or was cancelled); since Task is C-implemented (_asyncio), done is a method_descriptor; asyncio.Task.__dict__.__len__()==31; NEW in extra149: first standalone asyncio.Task.done qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.done.__qualname__.__len__
  args: []
  expected: 9

invariant asyncio_extra149.task_add_done_callback_qualname_len_22:
  description: "asyncio.Task.add_done_callback.__qualname__.__len__() == 22 — asyncio.Task.add_done_callback.__qualname__ is 'Task.add_done_callback' (22 chars: 'Task'=4+'.'=1+'add_done_callback'=17=22); the longest method qualname in this spec; add_done_callback adds a callback to be run when the Task completes; the callback takes a single argument (the completed future) and is called in the event loop's thread; asyncio.Task.__dict__.__len__()==31; asyncio.Task.__module__=='_asyncio' (len=8); NEW in extra149: first standalone asyncio.Task.add_done_callback qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.add_done_callback.__qualname__.__len__
  args: []
  expected: 22

invariant asyncio_extra149.task_dict_len_31:
  description: "asyncio.Task.__dict__.__len__() == 31 — asyncio.Task.__dict__ has 31 entries (a mappingproxy of the Task class namespace); asyncio.Task is implemented in C (the _asyncio extension module), so its __dict__ contains C-level method wrappers, slots, and class attributes; asyncio.Future.__dict__.__len__()==30 (1 fewer than Task); asyncio.Task.__dict__.__class__.__name__=='mappingproxy'; asyncio.Task.__module__=='_asyncio' (len=8: the C extension, not the pure-Python asyncio.tasks module); NEW in extra149: first standalone asyncio.Task.__dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__dict__.__len__
  args: []
  expected: 31

invariant asyncio_extra149.task_module_is_asyncio_c:
  description: "asyncio.Task.__module__.__eq__('_asyncio') returns True — asyncio.Task.__module__ is '_asyncio' (8 chars: the underlying C extension module); asyncio.Task is NOT defined in the pure-Python asyncio.tasks module; the C implementation lives in Modules/_asynciomodule.c and is compiled into the _asyncio extension; asyncio.Task.__module__.__len__()==8; asyncio.Task.__name__=='Task' (len=4); asyncio.Task.__dict__.__len__()==31; in contrast asyncio.Future.__module__ is also '_asyncio'; NEW in extra149: first standalone asyncio.Task module name invariant verifying the C-extension origin; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra149.future_dict_len_30:
  description: "asyncio.Future.__dict__.__len__() == 30 — asyncio.Future.__dict__ has 30 entries (a mappingproxy of the Future class namespace); asyncio.Future is also implemented in C (_asyncio extension), so its __dict__ contains C-level method wrappers and class attributes; asyncio.Task.__dict__.__len__()==31 (1 more than Future); asyncio.Future.__dict__.__class__.__name__=='mappingproxy'; asyncio.Future is the lower-level building block on which asyncio.Task is built; asyncio.Task adds additional task-specific methods (cancel with cancelling_count, get_name, set_name, etc.) explaining the extra entry; NEW in extra149: first standalone asyncio.Future.__dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__dict__.__len__
  args: []
  expected: 30
