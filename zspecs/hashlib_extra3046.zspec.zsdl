spec: hl3046
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib: Secure hashes and message digests"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (hl3046): __enter__, __exit__, __aenter__ dict-presence checks for hashlib types."
    - "On CPython, type(hashlib.md5()), type(hashlib.sha256()), type(hashlib.sha512()), type(hashlib.sha224()), type(hashlib.sha384()) all resolve to the same C-level HASH type from _hashlib."
    - "hashlib.blake2b and hashlib.blake2s are distinct C extension types from _blake2."
    - "None of the hashlib hash types implement the context manager protocol — __enter__, __exit__, and __aenter__ are absent from their __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3046.enter:
  description: "hashlib types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3046
  columns: [id, function, args, expected]
  rows:
    - ["hl3046001", operator.contains, [type(hashlib.md5()).__dict__,    "__enter__"], false]
    - ["hl3046002", operator.contains, [type(hashlib.sha256()).__dict__, "__enter__"], false]
    - ["hl3046003", operator.contains, [type(hashlib.sha512()).__dict__, "__enter__"], false]
    - ["hl3046004", operator.contains, [hashlib.blake2b.__dict__,        "__enter__"], false]
    - ["hl3046005", operator.contains, [hashlib.blake2s.__dict__,        "__enter__"], false]

