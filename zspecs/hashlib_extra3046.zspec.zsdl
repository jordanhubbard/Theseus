    - ["hl3046008", operator.contains, [type(hashlib.sha512()).__dict__, "__exit__"], false]
    - ["hl3046009", operator.contains, [hashlib.blake2b.__dict__,        "__exit__"], false]
    - ["hl3046010", operator.contains, [hashlib.blake2s.__dict__,        "__exit__"], false]

