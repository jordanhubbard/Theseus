spec: uuid_extra1831
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "uuid stdlib documentation"
    - "CPython source: Lib/uuid.py"
  not_derived_from:
    - "third-party UUID libraries"
  notes:
    - "uuid.UUID is a pure-Python class; instances are not callable (no __call__ in UUID.__dict__)"
    - "uuid.UUID defines __init__ and __new__ in its __dict__"
    - "uuid.SafeUUID is an IntEnum subclass; it does not define __init__ or __new__ directly"
    - "UUID does not implement the descriptor protocol (__get__/__set__/__delete__ absent from UUID.__dict__)"
    - "UUID properties (bytes_le, fields, time_low, etc.) are property objects stored in UUID.__dict__"
    - "UUID does not define __iter__ or __contains__"
  created_at: "2026-04-12"

table uuid_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu1831-dp-001", "uuid.UUID.__dict__.__contains__", ["__get__"], false]
    - ["uu1831-dp-002", "uuid.UUID.__dict__.__contains__", ["__set__"], false]
    - ["uu1831-dp-003", "uuid.UUID.__dict__.__contains__", ["__delete__"], false]
    - ["uu1831-dp-004", "uuid.UUID.__dict__.__contains__", ["__set_name__"], false]
    - ["uu1831-dp-005", "uuid.SafeUUID.__dict__.__contains__", ["__get__"], false]
    - ["uu1831-dp-006", "uuid.SafeUUID.__dict__.__contains__", ["__set__"], false]
    - ["uu1831-dp-007", "uuid.SafeUUID.__dict__.__contains__", ["__delete__"], false]
    - ["uu1831-dp-008", "uuid.SafeUUID.__dict__.__contains__", ["__set_name__"], false]

table uuid_extra1831.callable_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu1831-cp-001", "uuid.UUID.__dict__.__contains__", ["__call__"], false]
    - ["uu1831-cp-002", "uuid.SafeUUID.__dict__.__contains__", ["__call__"], false]
    - ["uu1831-cp-003", "uuid.UUID.__dict__.__contains__", ["__init__"], true]
    - ["uu1831-cp-004", "uuid.UUID.__dict__.__contains__", ["__new__"], true]
    - ["uu1831-cp-005", "uuid.SafeUUID.__dict__.__contains__", ["__init__"], false]
    - ["uu1831-cp-006", "uuid.SafeUUID.__dict__.__contains__", ["__new__"], false]
    - ["uu1831-cp-007", "uuid.UUID.__dict__.__contains__", ["__iter__"], false]
    - ["uu1831-cp-008", "uuid.UUID.__dict__.__contains__", ["__contains__"], false]

