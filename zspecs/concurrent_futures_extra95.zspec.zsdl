spec: concurrent_futures_extra95
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra94

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra94.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures Future and Executor class hierarchy identity. NEW in extra95: Future.__module__=='concurrent.futures._base'; Future.__qualname__=='Future' (len=6); Future.__mro__.__len__()==2; Future.__bases__[0].__name__=='object'; Executor.__module__=='concurrent.futures._base'; Executor.__qualname__=='Executor' (len=8); Executor.__mro__.__len__()==2; Executor.__bases__[0].__name__=='object'; ThreadPoolExecutor.__mro__.__len__()==3; ThreadPoolExecutor.__bases__[0].__name__=='Executor'; ProcessPoolExecutor.__mro__.__len__()==3; ProcessPoolExecutor.__bases__[0].__name__=='Executor'; Future.cancel.__qualname__=='Future.cancel'; Future.result.__qualname__=='Future.result'; Executor.map.__qualname__=='Executor.map'; Executor.map.__module__=='concurrent.futures._base'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Future.__module__ == 'concurrent.futures._base'. Future is defined in the private _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Future.__mro__.__len__() == 2. Future's MRO is [Future, object] — minimal single-inheritance chain. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Executor.__mro__.__len__() == 2. Executor's MRO is [Executor, object] — minimal single-inheritance chain. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ThreadPoolExecutor.__mro__.__len__() == 3. ThreadPoolExecutor's MRO is [ThreadPoolExecutor, Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future class hierarchy identity — extra95
#
# Wave 254 theme: concurrent.futures Future and Executor class hierarchy identity.
#
# Future.__module__ == 'concurrent.futures._base'
# Future.__qualname__ == 'Future' (len=6)
# Future.__mro__.__len__() == 2
# Future.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table concurrent_futures_extra95.future_class_hierarchy:
  description: "concurrent.futures.Future class hierarchy identity checks in cffutureident95 namespace — wave 254 theme: Future and Executor class hierarchy; concurrent.futures.Future is defined in Lib/concurrent/futures/_base.py (the private submodule); Future.__module__.__eq__('concurrent.futures._base')==True (len=24); Future.__qualname__.__eq__('Future')==True (len=6; module-level class, qualname equals name); Future.__mro__.__len__()==2 (MRO is [Future, object] — a minimal direct-subclass-of-object chain); Future.__bases__[0].__name__.__eq__('object')==True (Future inherits directly from object with no intermediate base); Future.__class__.__name__.__eq__('type')==True (Future is a class, so its metaclass is type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutureident95

  columns: [id, function, args, expected, description]
  rows:
    - [future_module,    "Future.__module__.__eq__",                   ["concurrent.futures._base"], true, "Future.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [future_qualname,  "Future.__qualname__.__eq__",                 ["Future"],                   true, "Future.__qualname__ == 'Future' (len=6); verified with Python 3.14.3"]
    - [future_mro_len,   "Future.__mro__.__len__",                     [],                           2,    "Future.__mro__.__len__() == 2 — MRO is [Future, object]; verified with Python 3.14.3"]
    - [future_base0,     "Future.__bases__[0].__name__.__eq__",        ["object"],                   true, "Future.__bases__[0].__name__ == 'object' — direct subclass of object; verified with Python 3.14.3"]
    - [future_class_nm,  "Future.__class__.__name__.__eq__",           ["type"],                     true, "Future.__class__.__name__ == 'type' — Future is a class whose metaclass is type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Executor class hierarchy identity — extra95
#
# Executor.__module__ == 'concurrent.futures._base'
# Executor.__qualname__ == 'Executor' (len=8)
# Executor.__mro__.__len__() == 2
# Executor.__bases__[0].__name__ == 'object'
# Executor.map.__qualname__ == 'Executor.map'
# Executor.submit.__qualname__ == 'Executor.submit'
# ---------------------------------------------------------------------------

table concurrent_futures_extra95.executor_class_hierarchy:
  description: "concurrent.futures.Executor class hierarchy identity checks in cffutureident95 namespace — wave 254 theme: Executor base class identity; concurrent.futures.Executor is the abstract base class for ThreadPoolExecutor and ProcessPoolExecutor; it is defined in Lib/concurrent/futures/_base.py; Executor.__module__.__eq__('concurrent.futures._base')==True; Executor.__qualname__.__eq__('Executor')==True (len=8, two chars longer than Future's 'Future' len=6); Executor.__mro__.__len__()==2 (MRO is [Executor, object], same minimal depth as Future); Executor.__bases__[0].__name__.__eq__('object')==True; Executor.map.__qualname__.__eq__('Executor.map')==True (Executor defines map in _base.py); Executor.submit.__qualname__.__eq__('Executor.submit')==True; Executor.map.__module__.__eq__('concurrent.futures._base')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutureident95a

  columns: [id, function, args, expected, description]
  rows:
    - [exec_module,     "Executor.__module__.__eq__",                    ["concurrent.futures._base"], true, "Executor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [exec_qualname,   "Executor.__qualname__.__eq__",                  ["Executor"],                 true, "Executor.__qualname__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [exec_mro_len,    "Executor.__mro__.__len__",                      [],                           2,    "Executor.__mro__.__len__() == 2 — MRO is [Executor, object]; verified with Python 3.14.3"]
    - [exec_base0,      "Executor.__bases__[0].__name__.__eq__",         ["object"],                   true, "Executor.__bases__[0].__name__ == 'object' — direct subclass of object; verified with Python 3.14.3"]
    - [exec_map_qeq,    "Executor.map.__qualname__.__eq__",              ["Executor.map"],             true, "Executor.map.__qualname__ == 'Executor.map'; defined in _base.py; verified with Python 3.14.3"]
    - [exec_map_module, "Executor.map.__module__.__eq__",                ["concurrent.futures._base"], true, "Executor.map.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor MRO depths — extra95
#
# ThreadPoolExecutor.__mro__.__len__() == 3
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ProcessPoolExecutor.__mro__.__len__() == 3
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
# ThreadPoolExecutor.__name__.__len__() == 18
# ProcessPoolExecutor.__name__.__len__() == 19
# ---------------------------------------------------------------------------

table concurrent_futures_extra95.executor_subclass_mro_depths:
  description: "ThreadPoolExecutor and ProcessPoolExecutor MRO depth checks in cffutureident95 namespace — wave 254 theme: Executor subclass MRO depths; ThreadPoolExecutor and ProcessPoolExecutor both inherit directly from Executor giving them a 3-element MRO; ThreadPoolExecutor.__mro__.__len__()==3 (MRO is [ThreadPoolExecutor, Executor, object]); ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True; ProcessPoolExecutor.__mro__.__len__()==3 (MRO is [ProcessPoolExecutor, Executor, object]); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True; ThreadPoolExecutor.__name__.__len__()==18 ('ThreadPoolExecutor' is 18 chars); ProcessPoolExecutor.__name__.__len__()==19 ('ProcessPoolExecutor' is 19 chars, one char longer); both are 3-deep (same as asyncio.Semaphore and SyncManager); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutureident95b

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_mro_len,    "ThreadPoolExecutor.__mro__.__len__",                    [],            3,    "ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is [ThreadPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [tpe_base0,      "ThreadPoolExecutor.__bases__[0].__name__.__eq__",       ["Executor"],  true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
    - [tpe_name_len,   "ThreadPoolExecutor.__name__.__len__",                   [],            18,   "ThreadPoolExecutor.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [ppe_mro_len,    "ProcessPoolExecutor.__mro__.__len__",                   [],            3,    "ProcessPoolExecutor.__mro__.__len__() == 3 — MRO is [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [ppe_base0,      "ProcessPoolExecutor.__bases__[0].__name__.__eq__",      ["Executor"],  true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
    - [ppe_name_len,   "ProcessPoolExecutor.__name__.__len__",                  [],            19,   "ProcessPoolExecutor.__name__.__len__() == 19 (one char longer than ThreadPoolExecutor); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Future method __qualname__ equality — extra95
#
# Future.cancel.__qualname__ == 'Future.cancel'
# Future.running.__qualname__ == 'Future.running'
# Future.done.__qualname__ == 'Future.done'
# Future.result.__qualname__ == 'Future.result'
# ---------------------------------------------------------------------------

table concurrent_futures_extra95.future_method_qualnames:
  description: "concurrent.futures.Future method __qualname__ equality checks in cffutureident95 namespace — wave 254 theme: Future method qualnames; concurrent.futures.Future is a pure Python class in _base.py; Future.cancel.__qualname__.__eq__('Future.cancel')==True; Future.running.__qualname__.__eq__('Future.running')==True; Future.done.__qualname__.__eq__('Future.done')==True; Future.result.__qualname__.__eq__('Future.result')==True; Future.cancel.__class__.__name__.__eq__('function')==True (these are Python functions, not wrapper_descriptors); all Future methods are defined directly on the Future class in _base.py so their qualnames use the 'Future.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutureident95c

  columns: [id, function, args, expected, description]
  rows:
    - [future_cancel_qeq,   "Future.cancel.__qualname__.__eq__",    ["Future.cancel"],  true, "Future.cancel.__qualname__ == 'Future.cancel'; verified with Python 3.14.3"]
    - [future_running_qeq,  "Future.running.__qualname__.__eq__",   ["Future.running"], true, "Future.running.__qualname__ == 'Future.running'; verified with Python 3.14.3"]
    - [future_done_qeq,     "Future.done.__qualname__.__eq__",      ["Future.done"],    true, "Future.done.__qualname__ == 'Future.done'; verified with Python 3.14.3"]
    - [future_result_qeq,   "Future.result.__qualname__.__eq__",    ["Future.result"],  true, "Future.result.__qualname__ == 'Future.result'; verified with Python 3.14.3"]
    - [future_cancel_cls,   "Future.cancel.__class__.__name__.__eq__", ["function"],    true, "Future.cancel.__class__.__name__ == 'function' — Python function, not C wrapper; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra95
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra95.Future_module_is_base:
  description: "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') returns True — Future is defined in the private submodule concurrent.futures._base (Lib/concurrent/futures/_base.py); the public name concurrent.futures.Future is re-exported through concurrent/futures/__init__.py; the _base module (len=24) is also where Executor is defined; both Future and Executor share the same __module__ value; Future.__mro__ has only 2 elements ([Future, object]) indicating it has no intermediate base class; NEW in extra95: first standalone Future module invariant in cffutureident95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra95.Future_mro_len_is_2:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — Future's MRO is [Future, object]; this minimal 2-element MRO means Future inherits directly from object with no intermediate classes; the same MRO depth applies to Executor (both are 2); ThreadPoolExecutor and ProcessPoolExecutor both have MRO length 3 because they insert Executor between themselves and object; Future.__qualname__ is 'Future' (len=6) and Future.__bases__[0].__name__ is 'object'; NEW in extra95: first standalone Future MRO length invariant in cffutureident95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.__mro__.__len__"
  args: []
  expected: 2

invariant concurrent_futures_extra95.Executor_mro_len_is_2:
  description: "concurrent.futures.Executor.__mro__.__len__() == 2 — Executor's MRO is [Executor, object]; Executor is the abstract base class that defines the executor interface (submit, map, shutdown, __enter__, __exit__) but inherits no behavior from any intermediate class; both Future and Executor have the same minimal MRO depth of 2 while their subclasses (ThreadPoolExecutor, ProcessPoolExecutor) extend it to depth 3; Executor.__qualname__ is 'Executor' (len=8); Executor.map.__module__ is 'concurrent.futures._base'; NEW in extra95: first standalone Executor MRO length invariant in cffutureident95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Executor.__mro__.__len__"
  args: []
  expected: 2

invariant concurrent_futures_extra95.ThreadPoolExecutor_mro_len_is_3:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — ThreadPoolExecutor's MRO is [ThreadPoolExecutor, Executor, object]; this 3-element chain adds the Executor abstract base between ThreadPoolExecutor and object; ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py (module='concurrent.futures.thread', len=25); ProcessPoolExecutor shares the same MRO depth of 3 (its MRO is [ProcessPoolExecutor, Executor, object]); ThreadPoolExecutor.__bases__[0].__name__ is 'Executor'; ThreadPoolExecutor.__name__ has length 18; NEW in extra95: first standalone ThreadPoolExecutor MRO length invariant in cffutureident95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ThreadPoolExecutor.__mro__.__len__"
  args: []
  expected: 3

invariant concurrent_futures_extra95.Executor_map_module_is_base:
  description: "concurrent.futures.Executor.map.__module__.__eq__('concurrent.futures._base') returns True — Executor.map is defined directly in _base.py (alongside Executor itself) and not overridden in the base Executor class; Executor.map.__qualname__ is 'Executor.map'; map is a concrete method on the abstract Executor class that implements the map-reduce pattern using submit(); ProcessPoolExecutor and ThreadPoolExecutor override map to add chunksize support; Executor.map.__module__ is 'concurrent.futures._base' (len=24); NEW in extra95: first standalone Executor.map module invariant in cffutureident95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Executor.map.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true
