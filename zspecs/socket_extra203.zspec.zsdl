spec: socket_extra203
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra99.zspec.zsdl — covers socket module attributes up through extra99."
  notes:
    - "socket.__dict__.__contains__('socket') == True — socket class is a top-level name in the socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('AF_INET') == True — AF_INET address family constant is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('AF_INET6') == True — AF_INET6 address family constant is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('SOCK_STREAM') == True — SOCK_STREAM socket type constant is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('SOCK_DGRAM') == True — SOCK_DGRAM socket type constant is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('gethostname') == True — gethostname function is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('gethostbyname') == True — gethostbyname function is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('getaddrinfo') == True — getaddrinfo function is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('create_connection') == True — create_connection function is in socket module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__mro__.__len__() == 3 — socket.socket MRO is (socket, socket, object); the inner C socket class and the Python-level socket class both appear. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__mro__[0].__name__ == 'socket' — the first MRO entry is socket itself. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module __dict__.__contains__ for socket class and address family constants
# ---------------------------------------------------------------------------

table socket_extra203.module_dict_socket_and_af_constants:
  description: "socket.__dict__.__contains__ checks for socket, AF_INET, AF_INET6, SOCK_STREAM — the socket class, IPv4/IPv6 address families, and stream socket type"
  kind: python_call_eq
  category: module_dict
  id_prefix: socketdict203

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_socket,       __dict__.__contains__, ["socket"],      true, "socket.__dict__.__contains__('socket') — socket class is in socket module namespace"]
    - [dict_has_AF_INET,      __dict__.__contains__, ["AF_INET"],     true, "socket.__dict__.__contains__('AF_INET') — IPv4 address family constant is in socket module namespace"]
    - [dict_has_AF_INET6,     __dict__.__contains__, ["AF_INET6"],    true, "socket.__dict__.__contains__('AF_INET6') — IPv6 address family constant is in socket module namespace"]
    - [dict_has_SOCK_STREAM,  __dict__.__contains__, ["SOCK_STREAM"], true, "socket.__dict__.__contains__('SOCK_STREAM') — stream socket type constant is in socket module namespace"]

# ---------------------------------------------------------------------------
# socket module __dict__.__contains__ for SOCK_DGRAM and network utility functions
# ---------------------------------------------------------------------------

table socket_extra203.module_dict_dgram_and_utilities:
  description: "socket.__dict__.__contains__ checks for SOCK_DGRAM, gethostname, gethostbyname, getaddrinfo — datagram socket type and name resolution utility functions"
  kind: python_call_eq
  category: module_dict
  id_prefix: socketdict203

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_SOCK_DGRAM,      __dict__.__contains__, ["SOCK_DGRAM"],      true, "socket.__dict__.__contains__('SOCK_DGRAM') — datagram socket type constant is in socket module namespace"]
    - [dict_has_gethostname,     __dict__.__contains__, ["gethostname"],     true, "socket.__dict__.__contains__('gethostname') — gethostname() function is in socket module namespace"]
    - [dict_has_gethostbyname,   __dict__.__contains__, ["gethostbyname"],   true, "socket.__dict__.__contains__('gethostbyname') — gethostbyname() function is in socket module namespace"]
    - [dict_has_getaddrinfo,     __dict__.__contains__, ["getaddrinfo"],     true, "socket.__dict__.__contains__('getaddrinfo') — getaddrinfo() function is in socket module namespace"]

# ---------------------------------------------------------------------------
# socket module __dict__.__contains__ for create_connection and socket.__mro__ checks
# ---------------------------------------------------------------------------

table socket_extra203.module_dict_create_connection_and_mro:
  description: "socket.__dict__.__contains__('create_connection')==True; socket.socket.__mro__.__len__()==3; socket.socket.__mro__[0].__name__=='socket'"
  kind: python_call_eq
  category: module_dict
  id_prefix: socketdict203

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_create_connection, __dict__.__contains__,              ["create_connection"], true, "socket.__dict__.__contains__('create_connection') — create_connection() convenience function is in socket module namespace"]
    - [mro_len,                    socket.__mro__.__len__,             [],                    3,    "socket.socket.__mro__.__len__() == 3 — MRO is (socket, socket, object) including C and Python layers"]
    - ["mro0_name",                "socket.__mro__[0].__name__.__eq__", ["socket"],           true, "socket.socket.__mro__[0].__name__ == 'socket' — first MRO entry is socket class itself"]
    - [dict_has_AF_INET6_2,        __dict__.__contains__,              ["AF_INET6"],          true, "socket.__dict__.__contains__('AF_INET6') re-anchored in mro table"]

