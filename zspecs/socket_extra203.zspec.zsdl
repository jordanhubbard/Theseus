  expected: true

invariant socket_extra203.socket_mro_len:
  description: "socket.socket.__mro__.__len__() == 3 — socket.socket MRO is (socket, socket, object); length 3 reflects both the Python wrapper layer and the C socket type"
  category: class_mro
