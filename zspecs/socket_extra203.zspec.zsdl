invariant socket_extra203.dict_has_socket:
  description: "socket.__dict__.__contains__('socket') == True — the socket class is a top-level name in the socket module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["socket"]
  expected: true

invariant socket_extra203.dict_has_AF_INET:
  description: "socket.__dict__.__contains__('AF_INET') == True — AF_INET IPv4 address family constant is in the socket module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["AF_INET"]
  expected: true

invariant socket_extra203.dict_has_SOCK_STREAM:
  description: "socket.__dict__.__contains__('SOCK_STREAM') == True — SOCK_STREAM stream socket type constant is in the socket module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["SOCK_STREAM"]
  expected: true

invariant socket_extra203.dict_has_gethostname:
  description: "socket.__dict__.__contains__('gethostname') == True — gethostname() function is a top-level name in the socket module namespace"
  category: module_dict
