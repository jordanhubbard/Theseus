  function: socket.__mro__.__len__
  args: []
  expected: 3

invariant socket_extra203.socket_mro0_name:
  description: "socket.socket.__mro__[0].__name__ == 'socket' — first entry in socket.socket MRO is socket itself"
  category: class_mro
