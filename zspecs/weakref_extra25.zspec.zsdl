spec: weakref_extra25
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra24.zspec.zsdl."
    - "Prior specs covered: ref/__name__/__module__/__qualname__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __name__/__module__/__qualname__, ref.__bases__[0].__name__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __bases__[0].__name__, getweakrefcount/getweakrefs __name__/__module__, ref.__init__.__name__, WeakSet.__module__=='_weakrefset', finalize.__module__=='weakref', ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __module__.__len__() and __name__.__len__(), getweakrefcount/getweakrefs __qualname__."
    - "This spec covers: __module__.__len__() for proxy/getweakrefcount/getweakrefs/ReferenceType/ProxyType/CallableProxyType/WeakMethod; __name__.__len__() for proxy/getweakrefcount/getweakrefs/ReferenceType/ProxyType/CallableProxyType/WeakMethod; __qualname__.__len__() for finalize methods (__init__/__call__/peek/detach)."
    - "proxy/getweakrefcount/getweakrefs have __module__ == '_weakref' (length 8) — they are C-level objects from the _weakref extension module."
    - "ReferenceType/ProxyType/CallableProxyType/WeakMethod have __module__ == 'weakref' (length 7) — Python-level aliases or subclasses."
    - "weakref.CallableProxyType.__name__ == 'CallableProxyType' (length 17) — longest __name__ among weakref proxy types."
    - "weakref.WeakMethod.__name__ == 'WeakMethod' (length 10)."
    - "finalize.__init__.__qualname__ == 'finalize.__init__' (length 17); finalize.peek.__qualname__ == 'finalize.peek' (length 13)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for proxy/getweakrefcount/getweakrefs (C-level, _weakref)
# and ReferenceType/ProxyType/CallableProxyType/WeakMethod (weakref module)
#
# extra24 recorded __module__.__len__() for ref/WeakValueDictionary/WeakKeyDictionary/
# WeakSet/finalize. This table extends coverage to seven more weakref objects.
# proxy/getweakrefcount/getweakrefs come from _weakref (length 8);
# ReferenceType/ProxyType/CallableProxyType/WeakMethod come from weakref (length 7).
# ---------------------------------------------------------------------------

table weakref_extra25.module_lens_extended:
  description: "__module__.__len__() for additional weakref objects — _weakref (8) vs weakref (7)"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [proxy,               proxy.__module__.__len__,               [], 8]
    - [getweakrefcount,     getweakrefcount.__module__.__len__,     [], 8]
    - [getweakrefs,         getweakrefs.__module__.__len__,         [], 8]
    - [ReferenceType,       ReferenceType.__module__.__len__,       [], 7]
    - [ProxyType,           ProxyType.__module__.__len__,           [], 7]
    - [CallableProxyType,   CallableProxyType.__module__.__len__,   [], 7]
    - [WeakMethod,          WeakMethod.__module__.__len__,          [], 7]

# ---------------------------------------------------------------------------
# __name__.__len__() for proxy/getweakrefcount/getweakrefs/ReferenceType/
# ProxyType/CallableProxyType/WeakMethod
#
# Name lengths vary: proxy (5), getweakrefcount (15), getweakrefs (11),
# ReferenceType (13), ProxyType (9), CallableProxyType (17), WeakMethod (10).
# CallableProxyType (17) has the longest __name__ in this table.
# No prior weakref spec records __name__.__len__() for any of these objects.
# ---------------------------------------------------------------------------

table weakref_extra25.name_lens_extended:
  description: "__name__.__len__() for additional weakref objects — lengths range from 5 (proxy) to 17 (CallableProxyType)"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [proxy,             proxy.__name__.__len__,             [], 5]
    - [getweakrefcount,   getweakrefcount.__name__.__len__,   [], 15]
    - [getweakrefs,       getweakrefs.__name__.__len__,       [], 11]
    - [ReferenceType,     ReferenceType.__name__.__len__,     [], 13]
    - [ProxyType,         ProxyType.__name__.__len__,         [], 9]
    - [CallableProxyType, CallableProxyType.__name__.__len__, [], 17]
    - [WeakMethod,        WeakMethod.__name__.__len__,        [], 10]

# ---------------------------------------------------------------------------
# finalize method __qualname__.__len__() — combined table
#
# finalize is a Python class; its methods have __qualname__ in the form
# 'finalize.<method_name>'. No prior weakref spec records __qualname__.__len__()
# for any finalize method. The prefix 'finalize.' contributes 9 characters.
# ---------------------------------------------------------------------------

table weakref_extra25.finalize_method_qualname_lens:
  description: "__qualname__.__len__() for finalize methods — 'finalize.' prefix adds 9 chars"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [__init__, finalize.__init__.__qualname__.__len__, [], 17]
    - [__call__, finalize.__call__.__qualname__.__len__, [], 17]
    - [peek,     finalize.peek.__qualname__.__len__,     [], 13]
    - [detach,   finalize.detach.__qualname__.__len__,   [], 15]

# ---------------------------------------------------------------------------
# weakref.CallableProxyType.__name__.__len__() == 17 — standalone
#
# CallableProxyType.__name__ is 'CallableProxyType', length 17 — the longest
# __name__ among all weakref proxy types and all C-level weakref objects measured
# across the extra series. It exceeds WeakValueDictionary (19) is NOT exceeded;
# WeakValueDictionary (19 chars) remains the longest overall. CallableProxyType
# (17) is the longest among proxy-related types.
# ---------------------------------------------------------------------------

invariant weakref_extra25.CallableProxyType.name_len:
  description: "weakref.CallableProxyType.__name__.__len__() == 17 — 'CallableProxyType' has length 17; longest __name__ among weakref proxy types"
  category: name_attr_lengths
  kind: python_call_eq
  function: CallableProxyType.__name__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# weakref.getweakrefcount.__module__.__len__() == 8 — standalone
#
# getweakrefcount has __module__ == '_weakref' (length 8), not 'weakref' (7).
# extra24 recorded its __qualname__ but not its __module__.__len__(). This
# invariant closes that gap and highlights the _weakref vs weakref distinction.
# ---------------------------------------------------------------------------

invariant weakref_extra25.getweakrefcount.module_len:
  description: "weakref.getweakrefcount.__module__.__len__() == 8 — '_weakref' has length 8; C-level function from extension module, not pure-Python 'weakref' (7)"
  category: module_attr_lengths
  kind: python_call_eq
  function: getweakrefcount.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# weakref.finalize.__init__.__qualname__.__len__() == 17 — standalone
#
# finalize.__init__.__qualname__ is 'finalize.__init__', length 17.
# finalize.__call__.__qualname__ is also 'finalize.__call__', length 17 — both
# dunder methods have the same qualname length due to symmetric 8-char names.
# Re-anchored as a standalone to highlight the dunder-method qualname pattern.
# ---------------------------------------------------------------------------

invariant weakref_extra25.finalize.init.qualname_len:
  description: "weakref.finalize.__init__.__qualname__.__len__() == 17 — 'finalize.__init__' has length 17; tied with finalize.__call__ (same pattern)"
  category: method_qualname_lengths
  kind: python_call_eq
  function: finalize.__init__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# weakref.proxy.__module__.__len__() == 8 — standalone
#
# weakref.proxy has __module__ == '_weakref' (length 8), distinct from the
# 'weakref' (7) module used by ReferenceType, ProxyType, CallableProxyType,
# and WeakMethod. This invariant anchors the _weakref / weakref boundary for
# the proxy function specifically.
# ---------------------------------------------------------------------------

invariant weakref_extra25.proxy.module_len:
  description: "weakref.proxy.__module__.__len__() == 8 — '_weakref' has length 8; proxy is a C-level function, distinct from Python-level ProxyType whose __module__ is 'weakref' (7)"
  category: module_attr_lengths
  kind: python_call_eq
  function: proxy.__module__.__len__
  args: []
  expected: 8
