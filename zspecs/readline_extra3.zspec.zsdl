spec: readline_extra3
version: ">=3.9"
backend: python_module(readline)

docs: https://docs.python.org/3/library/readline.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/readline.html — Python readline module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/readline.c"
  notes:
    - "This spec extends readline.zspec.zsdl and readline_extra through readline_extra2.zspec.zsdl."
    - "readline covers: function __name__ table (all 11 main functions); get_history_length default -1; get_current_history_length non-negative."
    - "readline_extra covers: read_history_file/write_history_file/get_history_length/set_completer/get_completer/parse_and_bind/add_history __name__+__module__; module __name__."
    - "readline_extra2 covers: set_history_length/clear_history/get_current_history_length/get_history_item/remove_history_item/replace_history_item __module__; remove_history_item/replace_history_item individual __name__."
    - "This spec adds: get_begidx/get_endidx/get_line_buffer/insert_text/read_init_file/redisplay/set_auto_history/set_completer_delims/get_completer_delims/set_pre_input_hook/set_startup_hook __name__ and __module__."
    - "readline is a POSIX-only C extension module; all functions are C builtins with __module__ == 'readline'."
    - "get_begidx and get_endidx return the begin/end index of the completion scope in the current line buffer."
    - "get_line_buffer returns the current line buffer contents as a string."
    - "insert_text inserts text at the current cursor position in the line buffer."
    - "read_init_file reads a readline initialisation file (analogous to ~/.inputrc)."
    - "redisplay updates the terminal display to reflect the current line buffer."
    - "set_auto_history enables or disables automatic addition of input to history."
    - "set_completer_delims / get_completer_delims get/set the word-delimiters string."
    - "set_pre_input_hook / set_startup_hook register callback hooks called before the first prompt."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __name__ checks for readline functions not yet covered individually
# readline covers these in a table but readline_extra/extra2 do not repeat them.
# Individual invariants follow for __module__, which is genuinely new.
# ---------------------------------------------------------------------------

table readline_extra3.completion_scope_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [get_begidx,              get_begidx.__name__.__eq__,              ["get_begidx"],              true]
    - [get_endidx,              get_endidx.__name__.__eq__,              ["get_endidx"],              true]
    - [get_line_buffer,         get_line_buffer.__name__.__eq__,         ["get_line_buffer"],         true]
    - [insert_text,             insert_text.__name__.__eq__,             ["insert_text"],             true]
    - [read_init_file,          read_init_file.__name__.__eq__,          ["read_init_file"],          true]
    - [redisplay,               redisplay.__name__.__eq__,               ["redisplay"],               true]
    - [set_auto_history,        set_auto_history.__name__.__eq__,        ["set_auto_history"],        true]
    - [set_completer_delims,    set_completer_delims.__name__.__eq__,    ["set_completer_delims"],    true]
    - [get_completer_delims,    get_completer_delims.__name__.__eq__,    ["get_completer_delims"],    true]
    - [set_pre_input_hook,      set_pre_input_hook.__name__.__eq__,      ["set_pre_input_hook"],      true]
    - [set_startup_hook,        set_startup_hook.__name__.__eq__,        ["set_startup_hook"],        true]

# ---------------------------------------------------------------------------
# __module__ checks for the same set of functions — all belong to 'readline'
# None of these appear in readline_extra or readline_extra2.
# ---------------------------------------------------------------------------

table readline_extra3.completion_scope_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [get_begidx,              get_begidx.__module__.__eq__,              ["readline"], true]
    - [get_endidx,              get_endidx.__module__.__eq__,              ["readline"], true]
    - [get_line_buffer,         get_line_buffer.__module__.__eq__,         ["readline"], true]
    - [insert_text,             insert_text.__module__.__eq__,             ["readline"], true]
    - [read_init_file,          read_init_file.__module__.__eq__,          ["readline"], true]
    - [redisplay,               redisplay.__module__.__eq__,               ["readline"], true]
    - [set_auto_history,        set_auto_history.__module__.__eq__,        ["readline"], true]
    - [set_completer_delims,    set_completer_delims.__module__.__eq__,    ["readline"], true]
    - [get_completer_delims,    get_completer_delims.__module__.__eq__,    ["readline"], true]
    - [set_pre_input_hook,      set_pre_input_hook.__module__.__eq__,      ["readline"], true]
    - [set_startup_hook,        set_startup_hook.__module__.__eq__,        ["readline"], true]
