spec: abc_extra1276
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 532 _extra1276: TYPE checks for __subclasses__, __mro__, and __bases__ on abc.ABC and abc.ABCMeta — note abc.ABCMeta.__subclasses__ is an unbound method so its type check uses abc.ABC.__subclasses__; distinct from prior waves that checked lengths"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1276.subclasses_type:
  description: "abc.ABC __subclasses__() return type is list"
  kind: python_call_eq
  category: subclasses_type
  id_prefix: ab1276sc
  columns: [id, function, args, expected]
  rows:
    - [ab1276sc001, abc.ABC.__subclasses__().__class__.__name__.__eq__,                    ["list"],  true]
    - [ab1276sc002, abc.ABC.__subclasses__().__class__.__name__.__eq__,                    ["tuple"], false]
    - [ab1276sc003, abc.ABC.__subclasses__().__class__.__name__.__eq__,                    ["set"],   false]
    - [ab1276sc004, abc.abstractmethod.__subclasses__().__class__.__name__.__eq__,         ["list"],  true]
    - [ab1276sc005, abc.abstractproperty.__subclasses__().__class__.__name__.__eq__,       ["list"],  true]
    - [ab1276sc006, abc.ABC.__subclasses__().__class__.__name__.__eq__,                    ["list"],  true]

