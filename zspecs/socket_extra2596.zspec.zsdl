spec: socket_extra2596
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence — checking whether socket.socket implements the descriptor protocol in its own class __dict__."
    - "socket.socket is a Python class (defined in Lib/socket.py) wrapping a C-level socket file descriptor."
    - "socket.socket.__dict__.__contains__('__get__') == False — socket objects are not descriptors; they do not implement __get__. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__set__') == False — socket objects do not define __set__; they are not data descriptors. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__delete__') == False — socket objects do not define __delete__, confirming non-descriptor status. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__set_name__') == False — __set_name__ is also absent."
    - "Note: socket.socket.__dict__ contains member_descriptor typed values (_closed, _io_refs) and getset_descriptor typed values (__weakref__), but the socket class itself does not implement __get__/__set__/__delete__."
    - "socket.socket.__dict__ contains: accept, close, sendfile, detach, dup, makefile, get_inheritable, set_inheritable, family (property), type (property), __enter__, __exit__, __repr__, __init__."
    - "socket.socket 'family' and 'type' attributes are Python property objects defined in __dict__; they are descriptors defined ON the socket class, but that does not make socket.socket itself a descriptor."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ absence — socket.socket does not implement the non-data descriptor protocol
#
# For a class to act as a non-data descriptor, it must define __get__ in its
# own __dict__. socket.socket does not. Socket objects are I/O endpoints
# wrapping file descriptors, not attribute lookup interceptors.
# ---------------------------------------------------------------------------

table socket_extra2596.get_absent:
  description: "__get__ is absent from socket.socket.__dict__ — socket objects do not implement the non-data descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2596

  columns: [id, function, args, expected]
  rows:
    - ["sk2596001", "socket.socket.__dict__.__contains__", ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ and __delete__ absence — socket.socket is not a data descriptor
#
# A data descriptor must define __set__ and/or __delete__. socket.socket
# defines neither. The class manages socket state internally but does not
# act as an attribute descriptor for other objects.
# ---------------------------------------------------------------------------

table socket_extra2596.set_delete_absent:
  description: "__set__ and __delete__ are absent from socket.socket.__dict__ — socket.socket is not a data descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2596

  columns: [id, function, args, expected]
  rows:
    - ["sk2596002", "socket.socket.__dict__.__contains__", ["__set__"],      false]
    - ["sk2596003", "socket.socket.__dict__.__contains__", ["__delete__"],   false]
    - ["sk2596004", "socket.socket.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# I/O and lifecycle API present in socket.socket.__dict__
#
# These True entries confirm socket.socket has a real API in its __dict__
# and that the dict lookup mechanism works correctly.
# ---------------------------------------------------------------------------

table socket_extra2596.io_api_present:
  description: "I/O and lifecycle methods are present in socket.socket.__dict__, contrasting with absent descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2596

  columns: [id, function, args, expected]
  rows:
    - ["sk2596005", "socket.socket.__dict__.__contains__", ["accept"],          true]
    - ["sk2596006", "socket.socket.__dict__.__contains__", ["close"],           true]
    - ["sk2596007", "socket.socket.__dict__.__contains__", ["sendfile"],        true]
    - ["sk2596008", "socket.socket.__dict__.__contains__", ["detach"],          true]
    - ["sk2596009", "socket.socket.__dict__.__contains__", ["dup"],             true]
    - ["sk2596010", "socket.socket.__dict__.__contains__", ["makefile"],        true]
    - ["sk2596011", "socket.socket.__dict__.__contains__", ["get_inheritable"], true]
    - ["sk2596012", "socket.socket.__dict__.__contains__", ["set_inheritable"], true]

# ---------------------------------------------------------------------------
# Context manager, repr, and property dunders present in socket.socket.__dict__
#
# socket.socket defines __enter__/__exit__ for use as a context manager,
# __repr__ and __init__, and property descriptors 'family' and 'type'.
# The presence of property descriptors IN the class does not make the
# class itself a descriptor.
# ---------------------------------------------------------------------------

table socket_extra2596.dunders_and_properties_present:
  description: "Context manager, repr dunders, and property descriptors are present in socket.socket.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2596

  columns: [id, function, args, expected]
  rows:
    - ["sk2596013", "socket.socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk2596014", "socket.socket.__dict__.__contains__", ["__exit__"],  true]
    - ["sk2596015", "socket.socket.__dict__.__contains__", ["__repr__"],  true]
    - ["sk2596016", "socket.socket.__dict__.__contains__", ["__init__"],  true]
    - ["sk2596017", "socket.socket.__dict__.__contains__", ["family"],    true]
    - ["sk2596018", "socket.socket.__dict__.__contains__", ["type"],      true]
    - ["sk2596019", "socket.socket.__dict__.__contains__", ["__get__"],   false]
    - ["sk2596020", "socket.socket.__dict__.__contains__", ["__set__"],   false]
