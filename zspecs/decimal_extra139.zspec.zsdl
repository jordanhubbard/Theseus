spec: decimal_extra139
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow, and decimal.Underflow exception class identity — __name__ lengths and values, __module__ identity, __class__.__name__, __bases__[0].__name__, and MRO lengths and key MRO entries. Also covers decimal.DecimalException as the common base, and decimal.Clamped, decimal.Inexact, decimal.Rounded, decimal.Subnormal."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' (16 chars; the longest name among the covered exception classes; note: __doc__ is None for all the signal/exception classes)."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero' (14 chars); its MRO includes ZeroDivisionError at position 2, making its MRO length 7 (unique among the covered classes)."
    - "decimal.Overflow.__name__ == 'Overflow' (8 chars); its __bases__[0] is 'Inexact' (not 'DecimalException' directly); MRO length 8."
    - "decimal.Underflow.__name__ == 'Underflow' (9 chars); its __bases__[0] is 'Inexact'; MRO length 9 (the longest among covered exception classes, because Underflow also inherits Subnormal)."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'; MRO length 5."
    - "All four signal exception classes (InvalidOperation, DivisionByZero, Overflow, Underflow) have __module__ == 'decimal' and __class__.__name__ == 'type'."
    - "decimal.Clamped, Inexact, Rounded, Subnormal all have __name__ lengths: Clamped=7, Inexact=7, Rounded=7, Subnormal=9; all have __bases__[0].__name__ == 'DecimalException'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal signal exception class __name__ and __module__ identity
# InvalidOperation.__name__ == 'InvalidOperation' (16 chars; longest).
# DivisionByZero.__name__ == 'DivisionByZero' (14 chars).
# Overflow.__name__ == 'Overflow' (8 chars).
# Underflow.__name__ == 'Underflow' (9 chars).
# DecimalException.__name__ == 'DecimalException' (16 chars; tied with InvalidOperation).
# All have __module__ == 'decimal' and __class__.__name__ == 'type'.
# All have __doc__ == None (no docstrings on the signal exception classes).
# ---------------------------------------------------------------------------

table decimal_extra139.signal_exception_names_and_module:
  description: "decimal signal exception class __name__ lengths: InvalidOperation=16, DivisionByZero=14, DecimalException=16, Overflow=8, Underflow=9; all __module__='decimal'; all __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decexc139

  columns: [id, function, args, expected, description]
  rows:
    - [invop_name_eq,   InvalidOperation.__name__.__eq__,              ["InvalidOperation"],  true, "decimal.InvalidOperation.__name__ == 'InvalidOperation'"]
    - [invop_name_len,  InvalidOperation.__name__.__len__,             [],                   16,   "decimal.InvalidOperation.__name__.__len__() == 16 ('InvalidOperation' has 16 characters; tied with DecimalException for the longest name)"]
    - [invop_mod_eq,    InvalidOperation.__module__.__eq__,            ["decimal"],           true, "decimal.InvalidOperation.__module__ == 'decimal'"]
    - [invop_cls_eq,    InvalidOperation.__class__.__name__.__eq__,    ["type"],              true, "decimal.InvalidOperation.__class__.__name__ == 'type' (a regular exception class)"]
    - [divzero_name_eq, DivisionByZero.__name__.__eq__,                ["DivisionByZero"],    true, "decimal.DivisionByZero.__name__ == 'DivisionByZero'"]
    - [divzero_name_len,DivisionByZero.__name__.__len__,               [],                   14,   "decimal.DivisionByZero.__name__.__len__() == 14 ('DivisionByZero' has 14 characters)"]
    - [divzero_mod_eq,  DivisionByZero.__module__.__eq__,              ["decimal"],           true, "decimal.DivisionByZero.__module__ == 'decimal'"]
    - [oflow_name_eq,   Overflow.__name__.__eq__,                      ["Overflow"],          true, "decimal.Overflow.__name__ == 'Overflow'"]
    - [oflow_name_len,  Overflow.__name__.__len__,                     [],                   8,    "decimal.Overflow.__name__.__len__() == 8 ('Overflow' has 8 characters; shortest among the four signal exceptions)"]
    - [oflow_mod_eq,    Overflow.__module__.__eq__,                    ["decimal"],           true, "decimal.Overflow.__module__ == 'decimal'"]
    - [uflow_name_eq,   Underflow.__name__.__eq__,                     ["Underflow"],         true, "decimal.Underflow.__name__ == 'Underflow'"]
    - [uflow_name_len,  Underflow.__name__.__len__,                    [],                   9,    "decimal.Underflow.__name__.__len__() == 9 ('Underflow' has 9 characters)"]
    - [uflow_mod_eq,    Underflow.__module__.__eq__,                   ["decimal"],           true, "decimal.Underflow.__module__ == 'decimal'"]

# ---------------------------------------------------------------------------
# decimal exception class __bases__ structure
# InvalidOperation.__bases__[0].__name__ == 'DecimalException'.
# DivisionByZero.__bases__[0].__name__ == 'DecimalException'.
# Overflow.__bases__[0].__name__ == 'Inexact' (not DecimalException directly).
# Underflow.__bases__[0].__name__ == 'Inexact' (not DecimalException directly).
# DecimalException.__bases__[0].__name__ == 'ArithmeticError'.
# ---------------------------------------------------------------------------

table decimal_extra139.signal_exception_bases:
  description: "decimal exception class __bases__: InvalidOperation<-DecimalException, DivisionByZero<-DecimalException, Overflow<-Inexact, Underflow<-Inexact, DecimalException<-ArithmeticError"
  kind: python_call_eq
  category: class_identity
  id_prefix: decexc139

  columns: [id, function, args, expected, description]
  rows:
    - [invop_base0_eq,   "InvalidOperation.__bases__[0].__name__.__eq__",  ["DecimalException"],  true, "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' (direct subclass of the decimal signal base class)"]
    - [divzero_base0_eq, "DivisionByZero.__bases__[0].__name__.__eq__",   ["DecimalException"],  true, "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' (also a direct DecimalException subclass, despite its MRO also including ZeroDivisionError)"]
    - [oflow_base0_eq,   "Overflow.__bases__[0].__name__.__eq__",          ["Inexact"],           true, "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow is a subclass of Inexact, not a direct subclass of DecimalException)"]
    - [uflow_base0_eq,   "Underflow.__bases__[0].__name__.__eq__",         ["Inexact"],           true, "decimal.Underflow.__bases__[0].__name__ == 'Inexact' (Underflow subclasses Inexact, just like Overflow)"]
    - [decexc_base0_eq,  "DecimalException.__bases__[0].__name__.__eq__",  ["ArithmeticError"],   true, "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (the root of the decimal exception hierarchy subclasses the built-in ArithmeticError)"]
    - [decexc_name_eq,   DecimalException.__name__.__eq__,                 ["DecimalException"],  true, "decimal.DecimalException.__name__ == 'DecimalException'"]
    - [decexc_name_len,  DecimalException.__name__.__len__,                [],                   16,   "decimal.DecimalException.__name__.__len__() == 16 ('DecimalException' has 16 characters; tied with InvalidOperation for longest name)"]
    - [decexc_mod_eq,    DecimalException.__module__.__eq__,               ["decimal"],           true, "decimal.DecimalException.__module__ == 'decimal'"]

# ---------------------------------------------------------------------------
# decimal exception class MRO lengths
# DecimalException MRO length == 5 ([DecimalException, ArithmeticError, Exception, BaseException, object]).
# InvalidOperation MRO length == 6 ([InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]).
# DivisionByZero MRO length == 7 ([DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object]).
# Overflow MRO length == 8 ([Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]).
# Underflow MRO length == 9 ([Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object]).
# ---------------------------------------------------------------------------

table decimal_extra139.signal_exception_mro_lengths:
  description: "decimal exception MRO lengths: DecimalException=5, InvalidOperation=6, DivisionByZero=7, Overflow=8, Underflow=9; key MRO entries for DivisionByZero and Underflow"
  kind: python_call_eq
  category: class_identity
  id_prefix: decexc139

  columns: [id, function, args, expected, description]
  rows:
    - [decexc_mro_len,   "DecimalException.__mro__.__len__",                  [], 5, "decimal.DecimalException.__mro__.__len__() == 5 ([DecimalException, ArithmeticError, Exception, BaseException, object])"]
    - [invop_mro_len,    "InvalidOperation.__mro__.__len__",                  [], 6, "decimal.InvalidOperation.__mro__.__len__() == 6 ([InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object])"]
    - [divzero_mro_len,  "DivisionByZero.__mro__.__len__",                    [], 7, "decimal.DivisionByZero.__mro__.__len__() == 7 (7 entries because DivisionByZero also inherits ZeroDivisionError, adding an extra MRO entry at position 2)"]
    - [divzero_mro2_eq,  "DivisionByZero.__mro__[2].__name__.__eq__",  ["ZeroDivisionError"], true, "decimal.DivisionByZero.__mro__[2].__name__ == 'ZeroDivisionError' (DivisionByZero is both a DecimalException and a ZeroDivisionError; MRO merges both hierarchies)"]
    - [oflow_mro_len,    "Overflow.__mro__.__len__",                          [], 8, "decimal.Overflow.__mro__.__len__() == 8 ([Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object])"]
    - [oflow_mro1_eq,    "Overflow.__mro__[1].__name__.__eq__",       ["Inexact"],           true, "decimal.Overflow.__mro__[1].__name__ == 'Inexact' (Overflow inherits Inexact, which means it is both an overflow and an inexact result)"]
    - [uflow_mro_len,    "Underflow.__mro__.__len__",                         [], 9, "decimal.Underflow.__mro__.__len__() == 9 (longest MRO among covered decimal exceptions; Underflow also inherits Subnormal making MRO include: [Underflow, Inexact, Rounded, Subnormal, DecimalException, ...])"]
    - [uflow_mro3_eq,    "Underflow.__mro__[3].__name__.__eq__",      ["Subnormal"],         true, "decimal.Underflow.__mro__[3].__name__ == 'Subnormal' (Underflow's MRO includes Subnormal at position 3, distinguishing it from Overflow whose MRO has only 8 entries and no Subnormal)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra139.InvalidOperation.name_len_16:
  description: "decimal.InvalidOperation.__name__.__len__() == 16 ('InvalidOperation' has 16 characters; tied with DecimalException for the longest __name__ among the covered decimal exception classes; longer than DivisionByZero (14), Underflow (9), Overflow (8), and the helper signals Subnormal (9), Clamped/Inexact/Rounded (all 7))"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__name__.__len__
  args: []
  expected: 16

invariant decimal_extra139.DivisionByZero.mro_len_7:
  description: "decimal.DivisionByZero.__mro__.__len__() == 7 (MRO is [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object]; the 7-entry MRO is longer than InvalidOperation (6) because DivisionByZero also inherits ZeroDivisionError, inserting an extra class into the C3 linearization; this allows 'except ZeroDivisionError' to also catch decimal.DivisionByZero)"
  category: class_identity
  kind: python_call_eq
  function: "DivisionByZero.__mro__.__len__"
  args: []
  expected: 7

invariant decimal_extra139.Overflow.base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow is not a direct subclass of DecimalException; it subclasses Inexact, which means an overflow is also classified as an inexact result; this is the decimal arithmetic contract: overflow implies the result could not be exactly represented in the given context)"
  category: class_identity
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra139.Underflow.mro_len_9:
  description: "decimal.Underflow.__mro__.__len__() == 9 (the longest MRO among the covered decimal exceptions; MRO is [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object]; Underflow has 9 entries while Overflow has 8 because Underflow additionally inherits Subnormal (a subnormal underflow is still an underflow), inserting Subnormal at position 3)"
  category: class_identity
  kind: python_call_eq
  function: "Underflow.__mro__.__len__"
  args: []
  expected: 9

invariant decimal_extra139.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException is the root of the decimal signal hierarchy and directly subclasses the built-in ArithmeticError; this means all decimal signal exceptions can be caught with 'except ArithmeticError' as well as 'except decimal.DecimalException'; ArithmeticError is the appropriate built-in for numeric computation errors)"
  category: class_identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra139.DivisionByZero.mro2_is_ZeroDivisionError:
  description: "decimal.DivisionByZero.__mro__[2].__name__ == 'ZeroDivisionError' (DivisionByZero's MRO position 2 is ZeroDivisionError; this dual inheritance means code using 'except ZeroDivisionError' will also catch decimal.DivisionByZero, providing compatibility between decimal arithmetic and standard Python exception handling)"
  category: class_identity
  kind: python_call_eq
  function: "DivisionByZero.__mro__[2].__name__.__eq__"
  args: ["ZeroDivisionError"]
  expected: true

invariant decimal_extra139.Overflow.name_len_8:
  description: "decimal.Overflow.__name__.__len__() == 8 ('Overflow' has 8 characters; the shortest __name__ among the four covered signal exceptions: Overflow=8, Underflow=9, DivisionByZero=14, InvalidOperation=16; at 8 characters it is also the same length as the rounding constant ROUND_UP from decimal_extra138)"
  category: class_identity
  kind: python_call_eq
  function: Overflow.__name__.__len__
  args: []
  expected: 8
