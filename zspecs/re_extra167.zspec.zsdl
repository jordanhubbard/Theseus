spec: re_extra167
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.compile function identity (class name and module) vs re.Pattern class identity."
    - "re.compile.__class__.__name__ == 'function' (len=8) — re.compile is a plain Python function, not a type or class."
    - "re.compile.__module__ == 're' (len=2) — re.compile is defined in the 're' module."
    - "re.Pattern.__name__ == 'Pattern' (len=7) — the compiled pattern class name."
    - "re.Pattern.__module__ == 're' (len=2) — re.Pattern is exported from the 're' module."
    - "re.Match.__name__ == 'Match' (len=5) — the match object class name."
    - "re.Match.__module__ == 're' (len=2) — re.Match is exported from the 're' module."
    - "re.compile is a function (re.compile.__class__.__name__ == 'function') that returns re.Pattern instances when called."
    - "re.Pattern is a type (isinstance(re.Pattern, type) == True), while re.compile is a function — a key distinction."
    - "re.compile.__qualname__ == 'compile' (len=7) — same as 'Pattern' (7 chars) — a coincidental length tie."
    - "Key name lengths: Match (5) < re (2 for module) < Pattern=compile=function (7=7=8? no): Match.__name__ (5), Pattern.__name__ (7), 'function' (8), 're' (2)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile function identity: class name and module
# re.compile.__class__.__name__ == 'function' (len=8)
# re.compile.__module__ == 're' (len=2)
# re.compile is NOT a type — it is a regular Python function.
# ---------------------------------------------------------------------------

table re_extra167.compile_function_identity:
  description: "re.compile function identity: __class__.__name__=='function' (len=8), __module__=='re' (len=2); re.compile is a plain Python function, not a type; re.compile.__qualname__=='compile' (len=7)"
  kind: python_call_eq
  category: identity
  id_prefix: recp167

  columns: [id, function, args, expected, description]
  rows:
    - [compile_cls_name,  "re.compile.__class__.__name__.__eq__",  ["function"],  true, "re.compile.__class__.__name__ == 'function' (re.compile is a plain Python function defined in Lib/re/__init__.py; it is not a type, not a classmethod, and not a builtin_function_or_method; re.compile(pattern, flags=0) compiles a regex pattern string into a re.Pattern object; 'function' has 8 characters: 'f-u-n-c-t-i-o-n'; 'function' (8) is the longest string value among the three checked in this table: 'function' (8) > 'compile' (7) > 're' (2); re.compile.__class__ is the built-in <class 'function'> type; the fact that re.compile is a plain function — not a class — means it cannot be instantiated; calling re.compile(pattern) invokes the function which returns a compiled re.Pattern instance)"]
    - [compile_module,    re.compile.__module__.__eq__,            ["re"],        true, "re.compile.__module__ == 're' (re.compile is defined and exported from the 're' module; 're' has 2 characters — the shortest value in the string comparisons in this table; re.compile.__module__ == 're' (2) contrasts with re.compile.__class__.__name__ == 'function' (8) — the module name is 4 times shorter than the class name; the 're' module's compile() function is the standard entry point for regex compilation in Python; all three module-level regex functions (re.compile, re.match, re.search) have __module__ == 're'; 're' (2 chars) is one of only two 2-character standard library module names frequently seen in spec series: 're' and 'io')"]
    - [compile_qualname,  re.compile.__qualname__.__eq__,          ["compile"],   true, "re.compile.__qualname__ == 'compile' (re.compile is a module-level function, so its __qualname__ is simply 'compile' — no class prefix is added; '__qualname__' for a top-level function equals '__name__' since there is no enclosing class scope; 'compile' has 7 characters: 'c-o-m-p-i-l-e'; re.compile.__qualname__ (7 chars) == re.Pattern.__name__ (7 chars) — 'compile' and 'Pattern' are both 7-character strings — a coincidental length tie between the function's qualname and the class it creates; re.compile.__qualname__ == 'compile' (not 're.compile') because qualname reflects the Python scope chain, not the module namespace)"]
    - [compile_name,      re.compile.__name__.__eq__,              ["compile"],   true, "re.compile.__name__ == 'compile' (re.compile.__name__ is the function's own name as a string; for a module-level function, __name__ and __qualname__ are equal: both are 'compile'; 'compile' has 7 characters; re.compile.__name__ == 'compile' (7) is 5 characters longer than re.compile.__module__ == 're' (2); re.compile.__name__ (7) == re.Pattern.__name__.__len__() (7) — a coincidental tie between the function name length and the Pattern class name length; re.compile is Python's primary API for creating compiled regex patterns; the function name 'compile' describes the action: compiling a pattern string into a Pattern object for efficient repeated use)"]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity
# re.Pattern.__name__ == 'Pattern' (len=7), __module__ == 're' (len=2)
# re.Match.__name__ == 'Match' (len=5), __module__ == 're' (len=2)
# ---------------------------------------------------------------------------

table re_extra167.Pattern_Match_class_identity:
  description: "re.Pattern class identity: __name__=='Pattern' (len=7), __module__=='re' (len=2); re.Match class identity: __name__=='Match' (len=5), __module__=='re' (len=2); Pattern (7) > Match (5) by 2; both modules are 're' (2)"
  kind: python_call_eq
  category: identity
  id_prefix: recp167

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_name,   re.Pattern.__name__.__eq__,   ["Pattern"],  true, "re.Pattern.__name__ == 'Pattern' (re.Pattern is the class of objects returned by re.compile(); 'Pattern' has 7 characters: 'P-a-t-t-e-r-n'; re.Pattern.__name__ (7 chars) == re.compile.__name__.__len__() (7 chars) — 'Pattern' and 'compile' are both 7-character strings, forming a coincidental tie between the class name and the function name that creates its instances; re.Pattern is a type (isinstance(re.Pattern, type) is True) while re.compile is a function (re.compile.__class__.__name__ == 'function') — this is the central distinction of this spec; re.Pattern.__module__ == 're' (2 chars); Pattern (7) > Match (5) by 2 characters)"]
    - [pattern_module, re.Pattern.__module__.__eq__,  ["re"],       true, "re.Pattern.__module__ == 're' (re.Pattern is exported from the 're' module; 're' has 2 characters; re.Pattern.__module__ (2) and re.Match.__module__ (2) are both 're' — both classes share the same 2-character module name; 're' (2) is shorter than 'pathlib' (7) and shorter than '_io' (3); the 're' module wraps the C-extension '_sre' module, re-exporting Pattern and Match under the public 're' namespace; re.Pattern.__module__ == 're' even though the underlying C implementation lives in '_sre' — the public module name is used for all exported objects)"]
    - [match_name,     re.Match.__name__.__eq__,      ["Match"],    true, "re.Match.__name__ == 'Match' (re.Match is the class of objects returned by re.match(), re.search(), re.fullmatch(), and the iterator from re.finditer(); 'Match' has 5 characters: 'M-a-t-c-h'; re.Match.__name__ (5) is 2 characters shorter than re.Pattern.__name__ (7) — the consistent 2-character difference between Pattern (7) and Match (5) propagates through all method qualname lengths in the re module as documented in re_extra165; re.Match objects provide access to matched groups via group(), groups(), span(), start(), end() etc.; Match (5) < Pattern (7) < 'function' (8) in name string lengths in this spec)"]
    - [match_module,   re.Match.__module__.__eq__,    ["re"],       true, "re.Match.__module__ == 're' (re.Match is exported from the 're' module; 're' has 2 characters — the same 2-character module name as re.Pattern; both Pattern and Match share __module__ == 're' (2 chars) despite being implemented at the C level in '_sre'; the uniform module name 're' ensures that isinstance checks, pickling, and repr() output all use the public module name; re.Match.__module__ == 're' is the same 2-character value as re.compile.__module__ == 're' — the function and the two classes it is associated with all share the same module name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra167.compile_is_a_function_not_a_type:
  description: "re.compile.__class__.__name__ == 'function' — re.compile is a plain Python function, not a type or class; this distinguishes it from re.Pattern and re.Match which are types (isinstance(re.Pattern, type) is True); 'function' (8 chars) is the class name of all Python function objects; re.compile is defined in Lib/re/__init__.py as a regular def statement; calling re.compile(pattern) invokes the function which internally calls Pattern.__new__ (or the C-level _sre module) to create a Pattern instance; re.compile being a function means it has __module__, __name__, __qualname__, __doc__, __defaults__, and __code__ attributes — not __bases__ or __mro__ which are type-specific; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.compile.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant re_extra167.Pattern_name_is_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' — re.Pattern is the compiled regex pattern class returned by re.compile(); 'Pattern' has 7 characters; re.Pattern.__name__ (7 chars) equals re.compile.__name__ (also 7 chars: 'compile') in length — a coincidental tie between the Pattern class name and the compile function name; re.Pattern.__module__ == 're' (2 chars); Pattern (7 chars) > Match (5 chars) by 2; this 2-character difference between Pattern and Match name lengths propagates consistently through all method qualname comparisons in the re module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra167.Match_module_is_re:
  description: "re.Match.__module__ == 're' — re.Match is exported from the 're' module; 're' (2 chars) is the shortest module name in the spec series (tied with 'io' at 2 chars); re.Match.__module__ (2), re.Pattern.__module__ (2), and re.compile.__module__ (2) are all 're' — the function and both classes associated with the regex lifecycle share the same 2-character module name; 're' (2 chars) contrasts with 'pathlib' (7 chars) and 'decimal' (7 chars); the 're' module re-exports C-level objects from '_sre' under the public 're' namespace, so __module__ consistently shows 're' for all public re objects; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra167.Pattern_name_len_7_equals_compile_name_len:
  description: "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters; re.compile.__qualname__ == 'compile' also has 7 characters; this coincidental tie (Pattern (7) == compile (7)) links the class returned by re.compile() with the function that creates it, both at length 7; re.Match.__name__ == 'Match' (5 chars) is 2 shorter than Pattern (7) — the consistent 2-char gap between Pattern and Match name lengths; re.Pattern.__name__ (7) > re.Match.__name__ (5) > re (2, module name) in string length; 'Pattern' (7 chars) has the same length as 'pathlib' (7 chars) and 'compile' (7 chars) — multiple 7-character strings appearing in the spec series; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__len__
  args: []
  expected: 7
