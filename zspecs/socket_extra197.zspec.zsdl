spec: socket_extra197
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.SocketType.__name__ == 'socket' (len=6) — SocketType is an alias for socket.socket; both share the same type."
    - "socket.SocketType.__module__ == '_socket' (len=7) — the underlying type is implemented in the _socket C extension."
    - "socket.SocketType.__class__.__name__ == 'type' (len=4) — SocketType is a class (type), not a function or instance."
    - "socket.socket.__init__.__qualname__ == 'socket.__init__' (len=15) — __init__ is defined on the socket type."
    - "socket.socket.__repr__.__qualname__ == 'socket.__repr__' (len=15) — same length as __init__ qualname."
    - "socket.socket.__enter__.__qualname__ == 'socket.__enter__' (len=16) — one character longer than __init__ and __repr__."
    - "socket.socket.__exit__.__qualname__ == 'socket.__exit__' (len=15) — same length as __init__ and __repr__."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno' (len=13) — shortest qualname among covered socket methods."
    - "Qualname length ordering: fileno(13) < __init__==__repr__==__exit__(15) < __enter__(16)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.SocketType class identity — name, module, metaclass
# SocketType is an alias for socket.socket; both are the same C-level type
# ---------------------------------------------------------------------------

table socketsockettype197.sockettype_identity:
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsockettype197

  columns: [id, function, args, expected, description]
  rows:
    - [sockettype_name,         SocketType.__name__.__eq__,               ["socket"], true, "socket.SocketType.__name__ == 'socket' (SocketType is an alias; the underlying type is named 'socket')"]
    - [sockettype_module,       SocketType.__module__.__eq__,             ["_socket"], true, "socket.SocketType.__module__ == '_socket' (C extension backing the socket type)"]
    - [sockettype_class_name,   SocketType.__class__.__name__.__eq__,     ["type"],   true, "socket.SocketType.__class__.__name__ == 'type' (SocketType is a class — its metaclass is 'type')"]

# ---------------------------------------------------------------------------
# socket.socket method qualnames — __init__, __repr__, __exit__
# All three share qualname length 15
# ---------------------------------------------------------------------------

table socketsockettype197.socket_dunder_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: socketsockettype197

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname,  socket.__init__.__qualname__.__eq__,  ["socket.__init__"],  true, "socket.socket.__init__.__qualname__ == 'socket.__init__' (len=15)"]
    - [repr_qualname,  socket.__repr__.__qualname__.__eq__,  ["socket.__repr__"],  true, "socket.socket.__repr__.__qualname__ == 'socket.__repr__' (len=15 — same as __init__)"]
    - [exit_qualname,  socket.__exit__.__qualname__.__eq__,  ["socket.__exit__"],  true, "socket.socket.__exit__.__qualname__ == 'socket.__exit__' (len=15 — same as __init__ and __repr__)"]

# ---------------------------------------------------------------------------
# socket.socket method qualnames — __enter__, fileno
# __enter__(16) is longest; fileno(13) is shortest
# ---------------------------------------------------------------------------

table socketsockettype197.socket_method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: socketsockettype197

  columns: [id, function, args, expected, description]
  rows:
    - [enter_qualname,  socket.__enter__.__qualname__.__eq__,  ["socket.__enter__"], true, "socket.socket.__enter__.__qualname__ == 'socket.__enter__' (len=16 — longest among covered methods)"]
    - [fileno_qualname, socket.fileno.__qualname__.__eq__,     ["socket.fileno"],    true, "socket.socket.fileno.__qualname__ == 'socket.fileno' (len=13 — shortest among covered methods)"]
    - [fileno_qualname_len, socket.fileno.__qualname__.__len__, [], 13,              "len(socket.socket.fileno.__qualname__) == 13 ('socket.fileno' has 13 characters — shortest)"]

