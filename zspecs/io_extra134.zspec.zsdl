    - "io.BufferedRandom.read.__qualname__ = 'BufferedRandom.read' (length 19)."
    - "io.BufferedRandom.write.__qualname__ = 'BufferedRandom.write' (length 20)."
    - "io.BufferedRandom.seek.__qualname__ = 'BufferedRandom.seek' (length 19)."
    - "io.BufferedRandom.flush.__qualname__ = 'BufferedRandom.flush' (length 20)."
    - "io.BufferedRWPair.__name__ = 'BufferedRWPair' (length 14)."
    - "io.BufferedRWPair.__module__ = '_io' — BufferedRWPair is a C extension type from _io."
    - "io.BufferedRWPair.__bases__[0].__name__ = '_BufferedIOBase' — BufferedRWPair directly extends _BufferedIOBase."
    - "io.BufferedRWPair.__mro__.__len__() = 4 — MRO is [BufferedRWPair, _BufferedIOBase, _IOBase, object]."
    - "io.BufferedRWPair.read.__qualname__ = 'BufferedRWPair.read' (length 19)."
    - "io.BufferedRWPair.write.__qualname__ = 'BufferedRWPair.write' (length 20)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

