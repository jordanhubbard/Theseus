# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra134.BufferedRandom.name_is_BufferedRandom:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom' (the class __name__ attribute equals the bare class name, without module prefix)"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra134.BufferedRandom.module_is_underscore_io:
  description: "io.BufferedRandom.__module__ == '_io' (BufferedRandom is a C extension type from the private _io extension module, even though it is re-exported via the io module)"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra134.BufferedRandom.mro_len_4:
  description: "io.BufferedRandom.__mro__.__len__() == 4 (MRO is [BufferedRandom, _BufferedIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__mro__.__len__
  args: []
  expected: 4

invariant io_extra134.BufferedRandom.read_qualname_len_19:
  description: "io.BufferedRandom.read.__qualname__.__len__() == 19 ('BufferedRandom.read' has 19 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedRandom.read.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra134.BufferedRWPair.base_is_BufferedIOBase:
  description: "io.BufferedRWPair.__bases__[0].__name__ == '_BufferedIOBase' (BufferedRWPair directly extends the C-level _BufferedIOBase, like BufferedRandom, BufferedReader, and BufferedWriter)"
  category: class_identity
  kind: python_call_eq
  function: BufferedRWPair.__bases__[0].__name__.__eq__
  args: ["_BufferedIOBase"]
  expected: true

