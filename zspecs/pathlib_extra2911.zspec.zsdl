spec: pp2911
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/pathlib_extra2896.zspec.zsdl — wave 640 predecessor (covered __itruediv__, __ifloordiv__, __imod__)"
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Wave 641 theme: __ilshift__, __irshift__, __ipow__ dict-presence checks (in-place left-shift, right-shift, power operators)."
    - "pathlib path objects define __truediv__ for the / path-joining operator, but have no bitwise or power semantics of any kind."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath, and Path all lack __ilshift__, __irshift__, and __ipow__."
    - "The non-inplace counterparts (__lshift__, __rshift__, __pow__) are also absent from all pathlib classes — no shift/power support at all."
    - "This continues the pattern established across prior waves: pathlib's only arithmetic-adjacent operator is __truediv__ (path joining)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __ilshift__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pp2911.ilshift:
  description: "__ilshift__ is absent from all pathlib class __dict__s — path objects have no bitwise left-shift semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2911

  columns: [id, function, args, expected]
  rows:
    - ["pp2911001", "pathlib.PurePath.__dict__.__contains__",        ["__ilshift__"], false]
    - ["pp2911002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ilshift__"], false]
    - ["pp2911003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ilshift__"], false]
    - ["pp2911004", "pathlib.Path.__dict__.__contains__",            ["__ilshift__"], false]
    - ["pp2911005", "pathlib.PurePath.__dict__.__contains__",        ["__lshift__"],  false]
    - ["pp2911006", "pathlib.Path.__dict__.__contains__",            ["__lshift__"],  false]

