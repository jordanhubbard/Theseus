# ---------------------------------------------------------------------------
# Table: combined — all three in-place shift/power ops absent; __truediv__ present on PurePath
# Highlights that pathlib's only operator is path-joining via __truediv__
# ---------------------------------------------------------------------------

table pp2911.combined:
  description: "pathlib defines __truediv__ on PurePath for / path joining but NO shift or power operators — __ilshift__, __irshift__, __ipow__ absent from all classes"
