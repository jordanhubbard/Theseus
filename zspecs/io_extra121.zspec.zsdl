spec: io_extra121
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec extends io_extra120.zspec.zsdl."
    - "This spec covers: io.BufferedWriter and io.BufferedRandom MRO slot names via double-quoted bracket-path notation."
    - "BufferedWriter.__mro__ has 4 entries: (BufferedWriter, _BufferedIOBase, _IOBase, object)."
    - "BufferedRandom.__mro__ has 4 entries: (BufferedRandom, _BufferedIOBase, _IOBase, object)."
    - "Both concrete types bypass the Python-level BufferedIOBase ABC (only _BufferedIOBase appears at MRO slot 1)."
    - "BufferedWriter and BufferedRandom share the same MRO slot 1 object (_BufferedIOBase) and slot 2 (_IOBase)."
    - "io_extra113 covered BufferedWriter.__mro__.__len__()==4 and __bases__[0].__name__=='_BufferedIOBase'; this spec covers individual slot names."
    - "io_extra114 covered BufferedWriter.__qualname__ == 'BufferedWriter' (len 14); same length as BufferedRandom (14)."
    - "BufferedWriter.__name__.__len__() == 14 == BufferedRandom.__name__.__len__() (both 14 chars); names differ by 'Writer' vs 'Random'."
    - "Both BufferedWriter and BufferedRandom have metaclass 'type' (plain C extension type, no custom metaclass)."
    - "Both have __module__ == '_io' (C extension, not the pure-Python wrapper in Lib/io.py)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedWriter MRO slot names
# BufferedWriter.__mro__ == (BufferedWriter, _BufferedIOBase, _IOBase, object) — 4 entries.
# BufferedWriter is a concrete C extension type for writing to buffered sequential streams.
# It inherits directly from _BufferedIOBase (the C implementation), not the Python-level
# BufferedIOBase ABC. _IOBase is the shared C root type at MRO slot 2.
# io_extra113 covered __mro__.__len__()==4 and __bases__[0].__name__; no spec has indexed
# into BufferedWriter.__mro__ to check individual slot names.
# ---------------------------------------------------------------------------

table io_extra121.BufferedWriter_mro_slot_names:
  description: "io.BufferedWriter.__mro__ slot names: [0]='BufferedWriter',[1]='_BufferedIOBase',[2]='_IOBase',[3]='object'; 4-entry MRO bypassing the Python-level BufferedIOBase ABC; _BufferedIOBase is the C implementation base at slot 1"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iobwmro121a

  columns: [id, function, args, expected, description]
  rows:
    - [bw_mro0_name,  "BufferedWriter.__mro__[0].__name__.__eq__",  ["BufferedWriter"],   true,  "io.BufferedWriter.__mro__[0].__name__ == 'BufferedWriter' (concrete class is first in its own MRO)"]
    - [bw_mro1_name,  "BufferedWriter.__mro__[1].__name__.__eq__",  ["_BufferedIOBase"],  true,  "io.BufferedWriter.__mro__[1].__name__ == '_BufferedIOBase' (direct C base; underscore marks private C implementation type)"]
    - [bw_mro2_name,  "BufferedWriter.__mro__[2].__name__.__eq__",  ["_IOBase"],          true,  "io.BufferedWriter.__mro__[2].__name__ == '_IOBase' (shared root C type for all concrete io types at MRO slot 2)"]
    - [bw_mro3_name,  "BufferedWriter.__mro__[3].__name__.__eq__",  ["object"],           true,  "io.BufferedWriter.__mro__[3].__name__ == 'object' (universal Python base class terminates every MRO)"]
    - [bw_mro1_ne_0,  "BufferedWriter.__mro__[1].__name__.__eq__",  ["BufferedWriter"],   false, "io.BufferedWriter.__mro__[1].__name__ != 'BufferedWriter' (slot 1 is the C base '_BufferedIOBase', not the class itself)"]
    - [bw_mro2_ne_1,  "BufferedWriter.__mro__[2].__name__.__eq__",  ["_BufferedIOBase"],  false, "io.BufferedWriter.__mro__[2].__name__ != '_BufferedIOBase' (slot 2 is '_IOBase', the deeper C root, not '_BufferedIOBase')"]
    - [bw_type_name,  "BufferedWriter.__class__.__name__.__eq__",   ["type"],             true,  "type(io.BufferedWriter).__name__ == 'type' (BufferedWriter is a plain type instance; no custom metaclass)"]

# ---------------------------------------------------------------------------
# io.BufferedRandom MRO slot names
# BufferedRandom.__mro__ == (BufferedRandom, _BufferedIOBase, _IOBase, object) — 4 entries.
# BufferedRandom is a concrete C extension type for random-access buffered I/O.
# Like BufferedWriter, it inherits from _BufferedIOBase at slot 1, sharing the
# same _BufferedIOBase C object as BufferedWriter.__mro__[1].
# No prior spec has indexed into BufferedRandom.__mro__ to check individual slot names.
# ---------------------------------------------------------------------------

table io_extra121.BufferedRandom_mro_slot_names:
  description: "io.BufferedRandom.__mro__ slot names: [0]='BufferedRandom',[1]='_BufferedIOBase',[2]='_IOBase',[3]='object'; same 4-entry MRO pattern as BufferedWriter; both share the identical _BufferedIOBase object at slot 1"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iobrmro121b

  columns: [id, function, args, expected, description]
  rows:
    - [br_mro0_name,  "BufferedRandom.__mro__[0].__name__.__eq__",  ["BufferedRandom"],   true,  "io.BufferedRandom.__mro__[0].__name__ == 'BufferedRandom' (concrete class is first in its own MRO)"]
    - [br_mro1_name,  "BufferedRandom.__mro__[1].__name__.__eq__",  ["_BufferedIOBase"],  true,  "io.BufferedRandom.__mro__[1].__name__ == '_BufferedIOBase' (direct C base; same _BufferedIOBase object as BufferedWriter.__mro__[1])"]
    - [br_mro2_name,  "BufferedRandom.__mro__[2].__name__.__eq__",  ["_IOBase"],          true,  "io.BufferedRandom.__mro__[2].__name__ == '_IOBase' (shared root C type; same as BufferedWriter.__mro__[2].__name__)"]
    - [br_mro3_name,  "BufferedRandom.__mro__[3].__name__.__eq__",  ["object"],           true,  "io.BufferedRandom.__mro__[3].__name__ == 'object' (universal Python base class terminates every MRO)"]
    - [br_mro1_ne_0,  "BufferedRandom.__mro__[1].__name__.__eq__",  ["BufferedRandom"],   false, "io.BufferedRandom.__mro__[1].__name__ != 'BufferedRandom' (slot 1 is the C base '_BufferedIOBase', not the class itself)"]
    - [br_type_name,  "BufferedRandom.__class__.__name__.__eq__",   ["type"],             true,  "type(io.BufferedRandom).__name__ == 'type' (BufferedRandom is a plain type instance; no custom metaclass)"]
    - [br_mro2_eq_bw, "BufferedRandom.__mro__[2].__name__.__eq__",  ["_IOBase"],          true,  "io.BufferedRandom.__mro__[2].__name__ == '_IOBase' == io.BufferedWriter.__mro__[2].__name__ (both share _IOBase at MRO slot 2)"]

# ---------------------------------------------------------------------------
# BufferedWriter and BufferedRandom name lengths, module, and cross-comparisons
# Both have __name__ length 14: 'BufferedWriter' and 'BufferedRandom' differ by suffix only.
# Both have __module__ == '_io' (C extension module, not the Lib/io.py wrapper).
# Both share the same MRO slot 1 (_BufferedIOBase) and slot 2 (_IOBase) objects.
# MRO slot 1 '_BufferedIOBase' has length 15 (one more than the two classes' names).
# ---------------------------------------------------------------------------

table io_extra121.BufferedWriter_BufferedRandom_name_lengths_and_module:
  description: "io.BufferedWriter and BufferedRandom both have __name__ len=14; __module__=='_io'; share _BufferedIOBase at MRO slot 1 (len 15) and _IOBase at slot 2; names differ only in suffix ('Writer' vs 'Random')"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iobwbrmeta121c

  columns: [id, function, args, expected, description]
  rows:
    - [bw_name_len,    "BufferedWriter.__name__.__len__",                         [],      14,    "io.BufferedWriter.__name__.__len__() == 14 ('BufferedWriter' has 14 characters)"]
    - [br_name_len,    "BufferedRandom.__name__.__len__",                         [],      14,    "io.BufferedRandom.__name__.__len__() == 14 ('BufferedRandom' has 14 characters; same as BufferedWriter)"]
    - [bw_mod_eq,      "BufferedWriter.__module__.__eq__",                        ["_io"], true,  "io.BufferedWriter.__module__ == '_io' (C extension; underscore prefix marks implementation module)"]
    - [br_mod_eq,      "BufferedRandom.__module__.__eq__",                        ["_io"], true,  "io.BufferedRandom.__module__ == '_io' (C extension; same module as BufferedWriter)"]
    - [bw_name_ne_br,  "BufferedWriter.__name__.__eq__",                          ["BufferedRandom"], false, "io.BufferedWriter.__name__ != 'BufferedRandom' (distinct names despite equal length 14; Writer for sequential output, Random for seekable I/O)"]
    - [bw_mro1_len,    "BufferedWriter.__mro__[1].__name__.__len__",              [],      15,    "io.BufferedWriter.__mro__[1].__name__.__len__() == 15 ('_BufferedIOBase' has 15 chars; one more than the 14-char class names)"]
    - [br_mro1_len,    "BufferedRandom.__mro__[1].__name__.__len__",              [],      15,    "io.BufferedRandom.__mro__[1].__name__.__len__() == 15 ('_BufferedIOBase' has 15 chars; same object as BufferedWriter.__mro__[1])"]
    - [bw_class_type,  "BufferedWriter.__class__.__name__.__eq__",                ["type"], true, "type(io.BufferedWriter).__name__ == 'type' (plain C extension type; no ABCMeta unlike the abstract bases)"]
    - [br_class_type,  "BufferedRandom.__class__.__name__.__eq__",                ["type"], true, "type(io.BufferedRandom).__name__ == 'type' (plain C extension type; concrete types never use ABCMeta)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra121.BufferedWriter.mro_slot1_is_BufferedIOBase:
  description: "io.BufferedWriter.__mro__[1].__name__ == '_BufferedIOBase' (length 15; BufferedWriter is a concrete C extension type defined in Modules/_io/bufferedio.c; its MRO is (BufferedWriter, _BufferedIOBase, _IOBase, object) — 4 entries; it bypasses the Python-level BufferedIOBase ABC because it directly inherits from the C type _BufferedIOBase; io_extra113 covered __mro__.__len__()==4 and __bases__[0].__name__=='_BufferedIOBase'; this spec is the first to index into individual MRO slots via double-quoted bracket-path notation)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BufferedWriter.__mro__[1].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra121.BufferedWriter.mro_slot2_is_IOBase:
  description: "io.BufferedWriter.__mro__[2].__name__ == '_IOBase' (the shared root C type appears at MRO slot 2 for all 4-entry concrete io types; BufferedWriter has the same '_IOBase' at slot 2 as FileIO, BufferedReader, BufferedRandom, TextIOWrapper, BytesIO, and StringIO; '_IOBase' at slot 2 is characteristic of concrete C extension types in io, whereas abstract bases have '_IOBase' at slot 3 in their 5-entry MROs)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BufferedWriter.__mro__[2].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra121.BufferedRandom.mro_slot1_is_BufferedIOBase:
  description: "io.BufferedRandom.__mro__[1].__name__ == '_BufferedIOBase' (length 15; BufferedRandom is a concrete C extension type also defined in Modules/_io/bufferedio.c; its MRO is (BufferedRandom, _BufferedIOBase, _IOBase, object) — 4 entries; BufferedRandom is a random-access buffered stream that wraps a seekable RawIOBase; no prior spec has indexed into BufferedRandom.__mro__ slots; BufferedWriter and BufferedRandom share the identical _BufferedIOBase C type object at MRO slot 1)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BufferedRandom.__mro__[1].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra121.BufferedRandom.mro_slot2_is_IOBase:
  description: "io.BufferedRandom.__mro__[2].__name__ == '_IOBase' (same shared root C type as BufferedWriter.__mro__[2] and as FileIO.__mro__[2] and BufferedReader.__mro__[2] — all four are 4-entry concrete MROs ending with (_IOBase, object); '_IOBase' is the single C root type that all io concrete and abstract types ultimately descend from, defined in Modules/_io/_iomodule.c)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BufferedRandom.__mro__[2].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra121.BufferedWriter.module_is_underscore_io:
  description: "io.BufferedWriter.__module__ == '_io' (the C extension implementation module; BufferedWriter, BufferedRandom, BufferedReader, FileIO, and TextIOWrapper all have __module__ == '_io' because they are defined in the C extension Modules/_io/; the Python-level io module in Lib/io.py re-exports these types but they originate in '_io'; io_extra113 noted all four concrete types share __module__ == '_io'; the underscore prefix distinguishes the C implementation from the public 'io' module name)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BufferedWriter.__module__.__eq__"
  args: ["_io"]
  expected: true
