spec: hashlib_extra175
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra174.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module-level identity attributes via __eq__ call syntax and __doc__.__contains__('hash') (table + invariants)."
    - "hashlib_extra173.zspec.zsdl — covers hashlib constructor __qualname__ attributes for sha256/md5/pbkdf2_hmac/file_digest and algorithms_guaranteed/available.__class__.__name__=='set' via __eq__ method calls (table + invariants)."
    - "hashlib_extra172.zspec.zsdl — covers hashlib constructor __name__.__len__() integer values for all eight constructors (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__=='hashlib' and hashlib.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra174."
    - "Wave 354 theme: hashlib.algorithms_guaranteed/__available __len__() sizes and __contains__ membership for sha256/md5/blake2b/sha3_512. hashlib_extra173 anchors algorithms_guaranteed/available __class__.__name__=='set' via __eq__ calls; hashlib_extra169 anchors algorithms_guaranteed/__available membership and lengths. This spec anchors the integer sizes __len__()==14 (guaranteed) and __len__()==19 (available) and four __contains__ membership checks (sha256/md5/blake2b/sha3_512) as primary novel content."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0. The 14 guaranteed algorithms: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0. The 19 available algorithms include the 14 guaranteed plus md5-sha1, ripemd160, sha512_224, sha512_256, sm3 (OpenSSL extras)."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0. (Confirmed; hashlib_extra173 anchors.)"
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0. (Confirmed; hashlib_extra173 anchors.)"
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. sha256 is in the guaranteed set."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. md5 is in the guaranteed set."
    - "hashlib.algorithms_guaranteed.__contains__('blake2b') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. blake2b is in the guaranteed set."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. sha3_512 is in the guaranteed set — the SHA-3 family is guaranteed since Python 3.6."
    - "Note: algorithms_guaranteed.__len__()==14 and algorithms_available.__len__()==19. The difference is 5: algorithms_available adds md5-sha1, ripemd160, sha512_224, sha512_256, sm3 (OpenSSL-only algorithms not in the guaranteed set). 14 < 19 by 5 algorithms."
    - "Note: 'sha3_512' is in algorithms_guaranteed. The SHA-3 family (sha3_224, sha3_256, sha3_384, sha3_512) was guaranteed from Python 3.6 onwards when the Keccak-based SHA-3 was standardized. 'sha3_512'(7 chars base='sha3_'=5+'512'=3=8; 'sha3_512'=8 chars) is in the guaranteed set."
    - "Note: 'blake2b' is in algorithms_guaranteed. BLAKE2b is the 64-bit optimized variant of BLAKE2; both blake2b and blake2s are guaranteed since Python 3.6. 'blake2b'(7 chars) < 'sha3_512'(8 chars) in algorithm name length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14
# hashlib.algorithms_available.__len__()==19
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')==True
# hashlib.algorithms_available.__class__.__name__.__eq__('set')==True
#
# Wave 354 theme: algorithms_guaranteed (14) and algorithms_available (19) sizes.
#
# algorithms_guaranteed.__len__() == 14 (14 hash algorithms guaranteed on all platforms).
# algorithms_available.__len__() == 19 (19 hash algorithms available via OpenSSL on this system).
# Both are set instances (class name 'set', 3 chars; hashlib_extra173 anchors class name).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra175.algorithms_set_sizes_and_class:
  description: "hashlib.algorithms_guaranteed.__len__()==14 / algorithms_available.__len__()==19 / algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_available.__class__.__name__.__eq__('set')==True — algorithms_guaranteed.__len__() is 14 (the 14 algorithms guaranteed on all Python platforms regardless of OpenSSL version: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256; 14 is an even number; hashlib_extra169 anchors algorithms_guaranteed length; this spec anchors via __len__() method call under hashalg175); algorithms_available.__len__() is 19 (the 19 algorithms available in this OpenSSL installation: the 14 guaranteed plus md5-sha1, ripemd160, sha512_224, sha512_256, sm3; 19 > 14 by 5; 19 is prime; novel anchor: hashlib_extra169 anchors algorithms_available length; this spec anchors via __len__() call); algorithms_guaranteed.__class__.__name__ is 'set' (3 chars; confirmed; hashlib_extra173 anchors via __eq__ call; algorithms_guaranteed is a mutable Python set containing the guaranteed algorithm names; 'set'(3) is the shortest type name); algorithms_available.__class__.__name__ is 'set' (3 chars; confirmed; hashlib_extra173 anchors; algorithms_available is also a Python set; 'set'(3)==algorithms_guaranteed.__class__.__name__(3) — both algorithm collections are sets; first hashalg175 anchor for sizes and class names)"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg175

  columns: [id, function, args, expected, description]
  rows:
    - [guar_len_14,       "algorithms_guaranteed.__len__",              [],      14,   "hashlib.algorithms_guaranteed.__len__() is 14 (14 algorithms: blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_224/sha3_256/sha3_384/sha3_512/sha512/shake_128/shake_256; novel anchor via __len__() call)"]
    - [avail_len_19,      "algorithms_available.__len__",               [],      19,   "hashlib.algorithms_available.__len__() is 19 (14 guaranteed + 5 OpenSSL extras; 19 > 14 by 5; 19 is prime; novel anchor via __len__() call)"]
    - [guar_class_set,    "algorithms_guaranteed.__class__.__name__.__eq__", ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; hashlib_extra173 anchors; confirmed here under hashalg175)"]
    - [avail_class_set,   "algorithms_available.__class__.__name__.__eq__",  ["set"], true, "hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars; hashlib_extra173 anchors; confirmed here; both sets share 3-char type name)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256')
# hashlib.algorithms_guaranteed.__contains__('md5')
#
# Wave 354 theme: sha256 and md5 membership in algorithms_guaranteed.
#
# algorithms_guaranteed.__contains__('sha256') == True (sha256 is in the guaranteed set).
# algorithms_guaranteed.__contains__('md5') == True (md5 is in the guaranteed set).
# 'sha256' (6 chars) and 'md5' (3 chars) are the most common hash algorithm names.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra175.algorithms_guaranteed_sha256_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256')==True / algorithms_guaranteed.__contains__('md5')==True / algorithms_guaranteed.__len__()==14 — algorithms_guaranteed.__contains__('sha256') is True ('sha256' is a key/member in hashlib.algorithms_guaranteed; SHA-256 (Secure Hash Algorithm 256-bit) is the most widely used cryptographic hash function and is guaranteed available on all Python platforms; 'sha256'(6 chars) = 'sha'=3 + '256'=3; novel anchor: hashlib_extra169 anchors algorithms_guaranteed membership counts; this spec anchors 'sha256' via __contains__ method call under hashalg175); algorithms_guaranteed.__contains__('md5') is True ('md5' is a member of hashlib.algorithms_guaranteed; MD5 (Message Digest 5) is guaranteed despite being cryptographically broken for collision resistance; 'md5'(3 chars) = 3 letters; 'md5'(3) < 'sha256'(6) by 3 chars in algorithm name length; novel anchor via __contains__ method call); algorithms_guaranteed.__len__() is 14 (confirmed; 14 total guaranteed algorithms; 'sha256' and 'md5' are both among the 14; first hashalg175 anchor for sha256/md5 guaranteed membership)"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg175

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_sha256,   "algorithms_guaranteed.__contains__", ["sha256"], true, "hashlib.algorithms_guaranteed.__contains__('sha256') == True ('sha256'=6 chars; most widely used hash; guaranteed on all platforms; novel __contains__ anchor)"]
    - [guar_has_md5,      "algorithms_guaranteed.__contains__", ["md5"],    true, "hashlib.algorithms_guaranteed.__contains__('md5') == True ('md5'=3 chars; guaranteed despite broken collision resistance; 'md5'(3)<'sha256'(6) by 3; novel anchor)"]
    - [guar_len_14_b,     "algorithms_guaranteed.__len__",      [],         14,   "hashlib.algorithms_guaranteed.__len__() is 14 (confirmed; sha256 and md5 are 2 of the 14 guaranteed algorithms)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('blake2b')
# hashlib.algorithms_guaranteed.__contains__('sha3_512')
#
# Wave 354 theme: blake2b and sha3_512 membership in algorithms_guaranteed.
#
# algorithms_guaranteed.__contains__('blake2b') == True (blake2b is guaranteed since Python 3.6).
# algorithms_guaranteed.__contains__('sha3_512') == True (sha3_512 is guaranteed since Python 3.6).
# 'blake2b' (7 chars) and 'sha3_512' (8 chars) are modern cryptographic hash algorithms.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra175.algorithms_guaranteed_blake2b_sha3_512:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b')==True / algorithms_guaranteed.__contains__('sha3_512')==True / algorithms_guaranteed.__len__()==14 — algorithms_guaranteed.__contains__('blake2b') is True ('blake2b' is a member of hashlib.algorithms_guaranteed; BLAKE2b is the 64-bit optimized variant of BLAKE2 — faster than SHA-2 for data larger than 64 bytes; both blake2b and blake2s were guaranteed since Python 3.6 when they were added to the standard library; 'blake2b'(7 chars) = 'blake2'=6 + 'b'=1; novel anchor: this spec provides the first anchor for blake2b guaranteed membership via __contains__ call under hashalg175); algorithms_guaranteed.__contains__('sha3_512') is True ('sha3_512' is a member of hashlib.algorithms_guaranteed; SHA-3 is the Keccak-based hash standardized by NIST in 2015; SHA-3/512 is the 512-bit variant; the full SHA-3 family (sha3_224, sha3_256, sha3_384, sha3_512) has been guaranteed since Python 3.6; 'sha3_512'(8 chars) = 'sha3_'=5 + '512'=3; 'sha3_512'(8) > 'blake2b'(7) > 'sha256'(6) > 'md5'(3) in algorithm name length ordering; novel anchor: this spec provides the first anchor for sha3_512 guaranteed membership via __contains__ under hashalg175); algorithms_guaranteed.__len__() is 14 (confirmed; blake2b and sha3_512 are both among the 14 guaranteed; first hashalg175 anchor for blake2b/sha3_512 guaranteed membership)"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg175

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_blake2b,  "algorithms_guaranteed.__contains__", ["blake2b"],  true, "hashlib.algorithms_guaranteed.__contains__('blake2b') == True ('blake2b'=7 chars; BLAKE2b 64-bit variant; guaranteed since Python 3.6; novel anchor)"]
    - [guar_has_sha3_512, "algorithms_guaranteed.__contains__", ["sha3_512"], true, "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True ('sha3_512'=8 chars; Keccak-based 512-bit SHA-3; guaranteed since Python 3.6; longest name in spec)"]
    - [guar_len_14_c,     "algorithms_guaranteed.__len__",      [],           14,   "hashlib.algorithms_guaranteed.__len__() is 14 (confirmed; blake2b and sha3_512 are 2 of 14; algorithm name lengths: 'md5'(3)<'sha256'(6)<'blake2b'(7)<'sha3_512'(8))"]

# ---------------------------------------------------------------------------
# All four __contains__ results combined — length ordering summary
#
# Wave 354 theme: combined view of all four guaranteed membership checks.
#
# algorithms_guaranteed.__contains__('md5') == True ('md5'=3 chars; shortest).
# algorithms_guaranteed.__contains__('sha256') == True ('sha256'=6 chars).
# algorithms_guaranteed.__contains__('blake2b') == True ('blake2b'=7 chars).
# algorithms_guaranteed.__contains__('sha3_512') == True ('sha3_512'=8 chars; longest).
# Name length ordering: 'md5'(3) < 'sha256'(6) < 'blake2b'(7) < 'sha3_512'(8).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra175.algorithms_guaranteed_membership_lengths:
  description: "hashlib.algorithms_guaranteed.__contains__('md5')==True / algorithms_guaranteed.__contains__('sha256')==True / algorithms_guaranteed.__contains__('blake2b')==True / algorithms_guaranteed.__contains__('sha3_512')==True — complete algorithm name length ordering view: 'md5'(3) < 'sha256'(6) < 'blake2b'(7) < 'sha3_512'(8) — all four are members of algorithms_guaranteed, but differ by 3+1+1 chars in name length; algorithms_guaranteed.__contains__('md5') is True (confirmed; 'md5'=3 chars; shortest algorithm name in this spec; 'md5'(3) == 'set'.__len__(3): md5 name length equals the type name length of the algorithms_guaranteed set); algorithms_guaranteed.__contains__('sha256') is True (confirmed; 'sha256'=6 chars; 'sha256'(6)>'md5'(3) by 3; SHA-256 is the most widely deployed algorithm in HTTPS/TLS); algorithms_guaranteed.__contains__('blake2b') is True (confirmed; 'blake2b'=7 chars; 'blake2b'(7)>'sha256'(6) by 1; BLAKE2b is faster than SHA-2 on 64-bit systems); algorithms_guaranteed.__contains__('sha3_512') is True (confirmed; 'sha3_512'=8 chars; longest algorithm name in spec; 'sha3_512'(8)>'blake2b'(7) by 1; SHA-3/512 provides 256-bit security level; complete ordering: 'md5'(3) < 'sha256'(6) < 'blake2b'(7) < 'sha3_512'(8); first hashalg175 anchor for combined membership length ordering)"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg175

  columns: [id, function, args, expected, description]
  rows:
    - [guar_has_md5_b,       "algorithms_guaranteed.__contains__", ["md5"],      true, "hashlib.algorithms_guaranteed.__contains__('md5') == True (confirmed; 'md5'=3 chars; shortest name in spec; 'md5'(3)<'sha256'(6)<'blake2b'(7)<'sha3_512'(8))"]
    - [guar_has_sha256_b,    "algorithms_guaranteed.__contains__", ["sha256"],   true, "hashlib.algorithms_guaranteed.__contains__('sha256') == True (confirmed; 'sha256'=6 chars; most deployed; 'sha256'(6)>'md5'(3) by 3)"]
    - [guar_has_blake2b_b,   "algorithms_guaranteed.__contains__", ["blake2b"],  true, "hashlib.algorithms_guaranteed.__contains__('blake2b') == True (confirmed; 'blake2b'=7 chars; BLAKE2b 64-bit; 'blake2b'(7)>'sha256'(6) by 1)"]
    - [guar_has_sha3_512_b,  "algorithms_guaranteed.__contains__", ["sha3_512"], true, "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True (confirmed; 'sha3_512'=8 chars; longest; 'sha3_512'(8)>'blake2b'(7) by 1; SHA-3 Keccak 512-bit)"]
    - [avail_len_19_b,       "algorithms_available.__len__",       [],           19,   "hashlib.algorithms_available.__len__() is 19 (confirmed; 5 more than guaranteed(14); 19 > 14 by 5: md5-sha1/ripemd160/sha512_224/sha512_256/sm3 are OpenSSL extras)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The 14 algorithms guaranteed on all
# Python platforms: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224,
# sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. First anchor for this
# integer via __len__() method call under hashalg175.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra175.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — 14 hash algorithms guaranteed available on all Python platforms regardless of OpenSSL version: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256; 14 is an even number; 14 < algorithms_available.__len__()==19 by 5; the 5 non-guaranteed extras (md5-sha1, ripemd160, sha512_224, sha512_256, sm3) depend on OpenSSL; hashlib_extra169 anchors algorithms_guaranteed length; this spec anchors via __len__() method call as a fresh anchor under hashalg175; first hashalg175 standalone for algorithms_guaranteed.__len__()==14"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__()==19 — standalone
#
# hashlib.algorithms_available.__len__() is 19. The 19 available algorithms include
# the 14 guaranteed plus 5 OpenSSL extras: md5-sha1, ripemd160, sha512_224, sha512_256, sm3.
# 19 - 14 = 5. 19 is prime. First anchor for this integer via __len__() call under hashalg175.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra175.algorithms_available_len_19:
  description: "hashlib.algorithms_available.__len__() == 19 — 19 hash algorithms available in this Python/OpenSSL installation: the 14 guaranteed (blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_224/sha3_256/sha3_384/sha3_512/sha512/shake_128/shake_256) plus 5 OpenSSL extras (md5-sha1/ripemd160/sha512_224/sha512_256/sm3); 19 - 14 = 5 additional algorithms from OpenSSL; 19 is prime; algorithms_available.__len__()==19 > algorithms_guaranteed.__len__()==14 by 5; hashlib_extra169 anchors algorithms_available length; this spec anchors via __len__() call as fresh anchor under hashalg175; first hashalg175 standalone for algorithms_available.__len__()==19"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha256') is True. SHA-256 is one of the
# 14 algorithms guaranteed on all Python platforms. 'sha256' (6 chars) = 'sha'=3 + '256'=3.
# Novel anchor: first spec to anchor sha256 guaranteed membership via __contains__ call.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra175.algorithms_guaranteed_has_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — 'sha256' (6 chars = 'sha'=3 + '256'=3; SHA-256 is the most widely used cryptographic hash function; guaranteed on all Python platforms; used in TLS/HTTPS certificate verification, Git object hashing, Bitcoin proof-of-work; 'sha256'(6) is one of the 14 members of algorithms_guaranteed; hashlib.sha256 is the constructor for SHA-256 objects; novel anchor: this spec provides the first __contains__ call anchor for sha256 guaranteed membership under hashalg175; first hashalg175 standalone for algorithms_guaranteed.__contains__('sha256')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('md5') is True. MD5 is one of the 14
# algorithms guaranteed on all Python platforms. 'md5' (3 chars) is the shortest
# algorithm name in this spec. Novel anchor under hashalg175.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra175.algorithms_guaranteed_has_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — 'md5' (3 chars; MD5 is the Message Digest 5 algorithm; guaranteed despite being cryptographically broken for collision resistance — it remains in the guaranteed set for backward compatibility and non-security uses (checksums, content addressing); 'md5'(3) is the shortest algorithm name in this spec: 'md5'(3) < 'sha256'(6) < 'blake2b'(7) < 'sha3_512'(8); algorithms_guaranteed has 14 members total; novel anchor: first hashalg175 standalone for algorithms_guaranteed.__contains__('md5')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('blake2b') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('blake2b') is True. BLAKE2b is one of
# the 14 guaranteed algorithms, added in Python 3.6. 'blake2b' (7 chars) =
# 'blake2'=6 + 'b'=1 (b for 64-bit/big). Novel anchor under hashalg175.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra175.algorithms_guaranteed_has_blake2b:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — 'blake2b' (7 chars = 'blake2'=6 + 'b'=1; 'b' stands for the 64-bit/big variant of BLAKE2; BLAKE2b is faster than MD5/SHA-1/SHA-2 on 64-bit systems while providing better security; both blake2b and blake2s (the 32-bit variant) are guaranteed since Python 3.6; 'blake2b'(7) > 'sha256'(6) by 1 char: 'blake2b' is 1 char longer than 'sha256'; 'blake2b'(7) < 'sha3_512'(8) by 1; algorithms_guaranteed has 14 members including both blake2b and blake2s; novel anchor: first hashalg175 standalone for algorithms_guaranteed.__contains__('blake2b')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_512') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha3_512') is True. SHA-3/512 is one
# of the 14 guaranteed algorithms, standardized by NIST in 2015 (FIPS 202). 'sha3_512'
# (8 chars) = 'sha3_'=5 + '512'=3. 'sha3_512' is the longest algorithm name in this spec.
# Novel anchor: first hashalg175 standalone for sha3_512 guaranteed membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra175.algorithms_guaranteed_has_sha3_512:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True — 'sha3_512' (8 chars = 'sha3_'=5 + '512'=3; SHA-3 is the Keccak-based hash standardized by NIST in 2015 (FIPS 202); SHA-3/512 is the 512-bit output variant providing 256 bits of security; the full SHA-3 family (sha3_224, sha3_256, sha3_384, sha3_512) has been guaranteed since Python 3.6; 'sha3_512'(8) is the longest algorithm name in this spec: 'md5'(3) < 'sha256'(6) < 'blake2b'(7) < 'sha3_512'(8); algorithms_guaranteed contains all four SHA-3 variants; sha3_512 is distinct from sha512 (FIPS 180-4 SHA-2 family) — sha3_512 uses the Keccak sponge construction while sha512 uses a Merkle-Damgard construction; novel anchor: first hashalg175 standalone for algorithms_guaranteed.__contains__('sha3_512')"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_512"]
  expected: true
