spec: lodash_multiply
version: ">=4.0.0"
backend: node(lodash.multiply)

docs: https://lodash.com/docs/#multiply

provenance:
  derived_from:
    - "lodash.multiply README — https://www.npmjs.com/package/lodash.multiply"
    - "Test vectors verified with lodash.multiply@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.multiply exports the _.multiply function directly as module.exports."
    - "multiply(multiplier, multiplicand) multiplies two numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns product of two numbers."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_multiply.multiply:
  kind: node_module_call_eq
  function: ~
  category: multiply
  id_prefix: lmul

  columns: [id, args, expected]
  rows:
    - [basic,  [6, 4],   24]
    - [zero,   [0, 5],   0]
    - [neg,    [-3, 4],  -12]
    - [float,  [2.5, 4], 10]
