spec: itertools_extra203
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers deeper __spec__ attributes of itertools: name, origin, origin.__class__.__name__, has_location, parent, __class__.__name__, submodule_search_locations.__class__.__name__."
    - "itertools.__spec__.name == 'itertools' — ModuleSpec.name equals the module name. Verified with Python 3.14.3."
    - "itertools.__spec__.origin == 'built-in' — itertools is a built-in C extension; origin is the string 'built-in'. Verified with Python 3.14.3."
    - "itertools.__spec__.has_location == False — built-in C module; no source file location. Verified with Python 3.14.3."
    - "itertools.__spec__.parent == '' — top-level module; spec.parent is an empty string. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an instance of ModuleSpec. Verified with Python 3.14.3."
    - "itertools.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType' — itertools has no submodules; submodule_search_locations is None. Verified with Python 3.14.3."
    - "itertools.__spec__.loader.__class__.__name__ == 'type' — built-in modules use the built-in loader (type). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__spec__ name, class, and parent identity
#
# itertools.__spec__.name == 'itertools'
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.parent == ''
# itertools.__spec__.__class__.__module__ == '_frozen_importlib'
# ---------------------------------------------------------------------------

table itertools_extra203.spec_name_class_parent:
  description: "itertools.__spec__ name, __class__.__name__, parent, and __class__.__module__ identity; new to extra203"
  kind: python_call_eq
  category: module_spec
  id_prefix: iterspec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — ModuleSpec.name attribute equals 'itertools'; new to extra203"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec instance; new to extra203"]
    - [spec_parent_eq,
       __spec__.parent.__eq__,
       [""],
       true,
       "itertools.__spec__.parent.__eq__('') == True — top-level module; spec.parent is empty string; new to extra203"]
    - [spec_class_module_eq,
       "__spec__.__class__.__module__.__eq__",
       ["_frozen_importlib"],
       true,
       "itertools.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is defined in _frozen_importlib; new to extra203"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__spec__ has_location and origin (built-in C module)
#
# itertools.__spec__.has_location == False
# itertools.__spec__.origin == 'built-in'
# itertools.__spec__.origin.__class__.__name__ == 'str'
# itertools.__spec__.name.__len__() == 9
# ---------------------------------------------------------------------------

table itertools_extra203.spec_location_origin:
  description: "itertools.__spec__ has_location, origin value, origin type, and name length; new to extra203"
  kind: python_call_eq
  category: module_spec
  id_prefix: iterspec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_has_location_false,
       __spec__.has_location.__eq__,
       [false],
       true,
       "itertools.__spec__.has_location.__eq__(False) == True — itertools is a built-in C module; has_location is False; new to extra203"]
    - [spec_origin_builtin,
       __spec__.origin.__eq__,
       ["built-in"],
       true,
       "itertools.__spec__.origin.__eq__('built-in') == True — built-in C module; origin is the string 'built-in'; new to extra203"]
    - [spec_origin_class_str,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__spec__.origin.__class__.__name__.__eq__('str') == True — spec.origin is a str even for built-in modules; new to extra203"]
    - [spec_name_len,
       __spec__.name.__len__,
       [],
       9,
       "itertools.__spec__.name.__len__() == 9 — len('itertools') is 9; new to extra203"]

# ---------------------------------------------------------------------------
# Table 3: itertools.__spec__ submodule_search_locations, cached, and loader
#
# itertools.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType'
# itertools.__spec__.cached.__class__.__name__ == 'NoneType'
# itertools.__spec__.loader.__class__.__name__ == 'type'
# itertools.__spec__.loader.__class__.__module__ == 'builtins'
# ---------------------------------------------------------------------------

table itertools_extra203.spec_submodule_cached_loader:
  description: "itertools.__spec__ submodule_search_locations, cached, loader class name and module; new to extra203"
  kind: python_call_eq
  category: module_spec
  id_prefix: iterspec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_submodule_locs_class,
       "__spec__.submodule_search_locations.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "itertools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — no submodules; submodule_search_locations is None; new to extra203"]
    - [spec_cached_class,
       "__spec__.cached.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "itertools.__spec__.cached.__class__.__name__.__eq__('NoneType') == True — built-in module has no cached .pyc; cached is None; new to extra203"]
    - [spec_loader_class_name,
       __spec__.loader.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.__spec__.loader.__class__.__name__.__eq__('type') == True — built-in modules use the built-in loader (type); new to extra203"]
    - [spec_loader_class_module,
       __spec__.loader.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.__spec__.loader.__class__.__module__.__eq__('builtins') == True — the built-in loader type is from the builtins module; new to extra203"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra203
# ---------------------------------------------------------------------------

invariant itertools_extra203.spec_name_eq:
  description: "itertools.__spec__.name == 'itertools' — ModuleSpec.name attribute equals module name; new to extra203"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra203.spec_class_name_eq:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is a ModuleSpec instance; new to extra203"
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra203.spec_parent_eq:
  description: "itertools.__spec__.parent == '' — top-level module; spec.parent is empty string; new to extra203"
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant itertools_extra203.spec_has_location_false:
  description: "itertools.__spec__.has_location == False — itertools is a built-in C module; has_location is False; new to extra203"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true

invariant itertools_extra203.spec_origin_builtin:
  description: "itertools.__spec__.origin == 'built-in' — built-in C module; origin is the literal string 'built-in'; new to extra203"
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["built-in"]
  expected: true

invariant itertools_extra203.spec_origin_class_str:
  description: "itertools.__spec__.origin.__class__.__name__ == 'str' — spec.origin is a str even for built-in modules; new to extra203"
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra203.spec_submodule_locs_class:
  description: "itertools.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType' — no submodules; submodule_search_locations is None; new to extra203"
  kind: python_call_eq
  function: "__spec__.submodule_search_locations.__class__.__name__.__eq__"
  args: ["NoneType"]
  expected: true

invariant itertools_extra203.spec_class_module_eq:
  description: "itertools.__spec__.__class__.__module__ == '_frozen_importlib' — ModuleSpec is defined in _frozen_importlib; new to extra203"
  kind: python_call_eq
  function: "__spec__.__class__.__module__.__eq__"
  args: ["_frozen_importlib"]
  expected: true
