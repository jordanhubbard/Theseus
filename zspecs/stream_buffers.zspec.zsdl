spec: stream_buffers
version: ">=3.0.0"
backend: node(stream-buffers)

docs: https://github.com/samcday/node-stream-buffer#readme

provenance:
  derived_from:
    - "stream-buffers README — https://github.com/samcday/node-stream-buffer#readme"
    - "Test vectors verified with stream-buffers via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "stream-buffers source"
  notes:
    - "ReadableStreamBuffer / WritableStreamBuffer — in-memory streams for tests."
    - "Install: npm install stream-buffers"
    - "v3 CJS; named exports include the two stream classes plus 4 default-tuning constants."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Streams emit normal stream errors; constructors don't throw on valid options."
  stderr: "null"
  stickiness: "N/A — each stream independent."
  codes: {}

# Default-tuning constants
invariant stream_buffers.DEFAULT_INITIAL_SIZE:
  description: "DEFAULT_INITIAL_SIZE is 8192 (8 KiB initial buffer)"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: DEFAULT_INITIAL_SIZE}
  expected: 8192

invariant stream_buffers.DEFAULT_INCREMENT_AMOUNT:
  description: "DEFAULT_INCREMENT_AMOUNT is 8192 (grow by 8 KiB)"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: DEFAULT_INCREMENT_AMOUNT}
  expected: 8192

invariant stream_buffers.DEFAULT_CHUNK_SIZE:
  description: "DEFAULT_CHUNK_SIZE is 1024 (1 KiB chunks for the readable side)"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: DEFAULT_CHUNK_SIZE}
  expected: 1024

invariant stream_buffers.DEFAULT_FREQUENCY:
  description: "DEFAULT_FREQUENCY is 1 (millisecond chunk emit cadence)"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: DEFAULT_FREQUENCY}
  expected: 1

# Empty WritableStreamBuffer state
invariant stream_buffers.empty_writable_size_zero:
  description: "Fresh WritableStreamBuffer has size 0"
  category: writable
  kind: node_chain_eq
  entry: constructor
  class: WritableStreamBuffer
  entry_args: []
  chain:
    - {method: size, args: []}
  expected: 0

# write then size + getContentsAsString
invariant stream_buffers.write_then_size:
  description: "After writing 11 bytes, size() returns 11"
  category: writable
  kind: node_chain_eq
  entry: constructor
  class: WritableStreamBuffer
  entry_args: []
  chain:
    - {method: write, args: ["hello world"], tap: true}
    - {method: size, args: []}
  expected: 11

invariant stream_buffers.write_then_get_contents_string:
  description: "getContentsAsString('utf8') returns the written text"
  category: writable
  kind: node_chain_eq
  entry: constructor
  class: WritableStreamBuffer
  entry_args: []
  chain:
    - {method: write, args: ["hello world"], tap: true}
    - {method: getContentsAsString, args: ["utf8"]}
  expected: "hello world"

invariant stream_buffers.size_zero_after_get_contents:
  description: "getContentsAsString consumes the buffer; size() returns 0 after"
  category: writable
  kind: node_chain_eq
  entry: constructor
  class: WritableStreamBuffer
  entry_args: []
  chain:
    - {method: write, args: ["hello world"], tap: true}
    - {method: getContentsAsString, args: ["utf8"], tap: true}
    - {method: size, args: []}
  expected: 0
