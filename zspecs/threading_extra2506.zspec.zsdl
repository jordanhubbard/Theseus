spec: threading_extra2506
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: __add__, __sub__, and __mul__ dict-presence checks for threading module classes."
    - "Theme: arithmetic operator dict-presence — checking whether classes define arithmetic operators in their class __dict__."
    - "threading.Thread, Lock, Condition, Semaphore, BoundedSemaphore, Event, Timer, Barrier, local — none define __add__, __sub__, or __mul__."
    - "threading.Thread is a pure-Python class representing an OS-level thread of execution; its state is managed via attributes (name, daemon, ident) and methods (start, join, run), not arithmetic operators. Verified with Python 3.14."
    - "threading.Lock and threading.RLock are wrappers over C-level lock primitives; they expose acquire/release and context-manager protocol only — no numeric semantics. Verified with Python 3.14."
    - "threading.Semaphore and threading.BoundedSemaphore maintain an internal counter, but the counter is accessed only via acquire() and release(); neither class exposes __add__, __sub__, or __mul__ in its __dict__. Verified with Python 3.14."
    - "threading.Event, threading.Condition, threading.Barrier are higher-level synchronization constructs built around internal locks and conditions; none have numeric roles. Verified with Python 3.14."
    - "threading.local provides per-thread attribute namespaces via attribute access (getattr/setattr), not via arithmetic. Verified with Python 3.14."
    - "threading.Timer is a Thread subclass that fires a function after a delay; it adds no arithmetic protocol beyond what Thread provides. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and threading.Timer — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from Thread and Timer.__dict__.
# Thread manages OS threads via start/join/run; Timer subclasses Thread to run
# a function after a delay. Neither is a numeric type; neither defines
# arithmetic operators.
# ---------------------------------------------------------------------------

table threading_extra2506.thread_timer_arithmetic:
  description: "__add__, __sub__, __mul__ absent from threading.Thread and threading.Timer __dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2506

  columns: [id, function, args, expected]
  rows:
    - ["th2506-001", "Thread.__dict__.__contains__", ["__add__"], false]
    - ["th2506-002", "Thread.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-003", "Thread.__dict__.__contains__", ["__mul__"], false]
    - ["th2506-004", "Timer.__dict__.__contains__", ["__add__"], false]
    - ["th2506-005", "Timer.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-006", "Timer.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 2: threading lock and condition primitives — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from Lock, Condition,
# Semaphore, and BoundedSemaphore.__dict__.
# These synchronization primitives manage access to shared resources;
# Semaphore maintains an internal count but exposes only acquire/release —
# not arithmetic operators. Lock and Condition have no numeric role at all.
# ---------------------------------------------------------------------------

table threading_extra2506.lock_condition_arithmetic:
  description: "__add__, __sub__, __mul__ absent from threading.Lock, Condition, Semaphore, BoundedSemaphore __dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2506

  columns: [id, function, args, expected]
  rows:
    - ["th2506-007", "Lock.__dict__.__contains__", ["__add__"], false]
    - ["th2506-008", "Lock.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-009", "Lock.__dict__.__contains__", ["__mul__"], false]
    - ["th2506-010", "Condition.__dict__.__contains__", ["__add__"], false]
    - ["th2506-011", "Condition.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-012", "Condition.__dict__.__contains__", ["__mul__"], false]
    - ["th2506-013", "Semaphore.__dict__.__contains__", ["__add__"], false]
    - ["th2506-014", "Semaphore.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-015", "Semaphore.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 3: threading.Event, threading.Barrier, threading.local — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from Event, Barrier, and local.__dict__.
# Event is a simple flag-based synchronization primitive; Barrier synchronizes
# a fixed number of threads at a rendezvous point; local provides per-thread
# attribute namespaces. None carry numeric semantics or arithmetic operators.
# ---------------------------------------------------------------------------

table threading_extra2506.event_barrier_local_arithmetic:
  description: "__add__, __sub__, __mul__ absent from threading.Event, Barrier, local __dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2506

  columns: [id, function, args, expected]
  rows:
    - ["th2506-016", "Event.__dict__.__contains__", ["__add__"], false]
    - ["th2506-017", "Event.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-018", "Event.__dict__.__contains__", ["__mul__"], false]
    - ["th2506-019", "Barrier.__dict__.__contains__", ["__add__"], false]
    - ["th2506-020", "Barrier.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-021", "Barrier.__dict__.__contains__", ["__mul__"], false]
    - ["th2506-022", "local.__dict__.__contains__", ["__add__"], false]
    - ["th2506-023", "local.__dict__.__contains__", ["__sub__"], false]
    - ["th2506-024", "local.__dict__.__contains__", ["__mul__"], false]
