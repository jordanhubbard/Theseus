spec: urllib_parse_extra10
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl through urllib_parse_extra9.zspec.zsdl."
    - "urllib_parse_extra.zspec.zsdl covers: ParseResult/SplitResult/DefragResult __name__; urlparse/urlsplit/urljoin/urlencode __name__; _fields content (scheme/netloc/path/params)."
    - "urllib_parse_extra2.zspec.zsdl covers: quote/unquote/quote_plus/unquote_plus/parse_qs/parse_qsl __name__."
    - "urllib_parse_extra3.zspec.zsdl covers: urlparse scheme/netloc/path; quote/unquote value vectors."
    - "urllib_parse_extra4.zspec.zsdl covers: ParseResult/SplitResult/DefragResult __qualname__; function qualnames."
    - "urllib_parse_extra5.zspec.zsdl covers: quote_plus/unquote_plus/parse_qs/parse_qsl qualnames; urlparse.__module__."
    - "urllib_parse_extra6.zspec.zsdl covers: result type __module__; function __module__ for urlsplit/urljoin/urlencode/quote/unquote."
    - "urllib_parse_extra7.zspec.zsdl covers: function __module__ for quote_plus/unquote_plus/parse_qs/parse_qsl/urldefrag; urlsplit behavioral; urldefrag behavioral."
    - "urllib_parse_extra8.zspec.zsdl covers: urlsplit port/fragment/username/password; urlunparse/urlunsplit behavioral; quote_plus numeric; unquote_plus plus_to_space."
    - "urllib_parse_extra9.zspec.zsdl covers: function __class__.__name__ type checks; DefragResult._fields content/length; SplitResult._fields length; ParseResult._fields length; parse_qs empty string."
    - "Focus: quote_from_bytes and unquote_to_bytes — __name__, __qualname__, __module__, __class__.__name__, and behavioral vectors."
    - "SplitResult._fields[2..4] names (path/query/fragment) — extra checks only field[0] and [1] via urlparse_extra."
    - "ParseResult._fields[4] and [5] (query/fragment) — extra checks fields [0..3] only."
    - "urlsplit behavioral: scheme, netloc, path on 'http://example.com/path' — extra3 checks urlparse not urlsplit for these."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# quote_from_bytes — identity, type, and behavioral checks
#
# No prior urllib_parse spec checks quote_from_bytes in any dimension.
# quote_from_bytes operates on bytes objects and produces percent-encoded str.
# ---------------------------------------------------------------------------

table urllib_parse_extra10.quote_from_bytes_identity:
  kind: python_call_eq
  category: quote_from_bytes
  id_prefix: qfb

  columns: [id, function, args, expected]
  rows:
    - [name,     quote_from_bytes.__name__.__eq__,          ["quote_from_bytes"], true]
    - [qualname, quote_from_bytes.__qualname__.__eq__,      ["quote_from_bytes"], true]
    - [module,   quote_from_bytes.__module__.__eq__,        ["urllib.parse"],     true]
    - [type,     quote_from_bytes.__class__.__name__.__eq__, ["function"],        true]

invariant urllib_parse_extra10.quote_from_bytes.space:
  description: "urllib.parse.quote_from_bytes(b' ') == '%20' — space byte encodes to %20"
  category: quote_from_bytes
  kind: python_call_eq
  function: quote_from_bytes
  args: [!hex 20]
  expected: "%20"

invariant urllib_parse_extra10.quote_from_bytes.hello:
  description: "urllib.parse.quote_from_bytes(b'hello') == 'hello' — ASCII letters pass through"
  category: quote_from_bytes
  kind: python_call_eq
  function: quote_from_bytes
  args: [!ascii "hello"]
  expected: "hello"

# ---------------------------------------------------------------------------
# unquote_to_bytes — identity, type, and behavioral checks
#
# No prior urllib_parse spec checks unquote_to_bytes in any dimension.
# unquote_to_bytes decodes percent-encoded strings to bytes objects.
# ---------------------------------------------------------------------------

table urllib_parse_extra10.unquote_to_bytes_identity:
  kind: python_call_eq
  category: unquote_to_bytes
  id_prefix: utb

  columns: [id, function, args, expected]
  rows:
    - [name,     unquote_to_bytes.__name__.__eq__,          ["unquote_to_bytes"], true]
    - [qualname, unquote_to_bytes.__qualname__.__eq__,      ["unquote_to_bytes"], true]
    - [module,   unquote_to_bytes.__module__.__eq__,        ["urllib.parse"],     true]
    - [type,     unquote_to_bytes.__class__.__name__.__eq__, ["function"],        true]

# ---------------------------------------------------------------------------
# SplitResult._fields — field names at indices 2, 3, 4
#
# urllib_parse_extra.zspec.zsdl checks _fields[0]=='scheme' and _fields[1]=='netloc'
# for SplitResult. The remaining three fields (path, query, fragment) are new.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra10.SplitResult.field_2:
  description: "urllib.parse.SplitResult._fields[2] == 'path'"
  category: SplitResult
  kind: python_call_eq
  function: SplitResult._fields.__getitem__
  args: [2]
  expected: "path"

invariant urllib_parse_extra10.SplitResult.field_3:
  description: "urllib.parse.SplitResult._fields[3] == 'query'"
  category: SplitResult
  kind: python_call_eq
  function: SplitResult._fields.__getitem__
  args: [3]
  expected: "query"

invariant urllib_parse_extra10.SplitResult.field_4:
  description: "urllib.parse.SplitResult._fields[4] == 'fragment'"
  category: SplitResult
  kind: python_call_eq
  function: SplitResult._fields.__getitem__
  args: [4]
  expected: "fragment"

# ---------------------------------------------------------------------------
# ParseResult._fields — field names at indices 4 and 5
#
# urllib_parse_extra.zspec.zsdl checks _fields[0..3] for ParseResult.
# Fields [4] (query) and [5] (fragment) have not been individually verified.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra10.ParseResult.field_4:
  description: "urllib.parse.ParseResult._fields[4] == 'query'"
  category: ParseResult
  kind: python_call_eq
  function: ParseResult._fields.__getitem__
  args: [4]
  expected: "query"

invariant urllib_parse_extra10.ParseResult.field_5:
  description: "urllib.parse.ParseResult._fields[5] == 'fragment'"
  category: ParseResult
  kind: python_call_eq
  function: ParseResult._fields.__getitem__
  args: [5]
  expected: "fragment"

# ---------------------------------------------------------------------------
# urlsplit behavioral — scheme, netloc, path on a simple URL
#
# urllib_parse_extra3.zspec.zsdl checks urlparse (not urlsplit) for scheme/netloc/path.
# urllib_parse_extra8.zspec.zsdl checks urlsplit for port/fragment/username/password.
# The scheme, netloc, and path attributes of urlsplit on a simple URL are new.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra10.urlsplit.scheme:
  description: "urllib.parse.urlsplit('http://example.com/path').scheme == 'http'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com/path"]
  method: scheme
  expected: "http"

invariant urllib_parse_extra10.urlsplit.netloc:
  description: "urllib.parse.urlsplit('http://example.com/path').netloc == 'example.com'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com/path"]
  method: netloc
  expected: "example.com"

invariant urllib_parse_extra10.urlsplit.path:
  description: "urllib.parse.urlsplit('http://example.com/path').path == '/path'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com/path"]
  method: path
  expected: "/path"
