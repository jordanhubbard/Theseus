spec: hashlib_extra257
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
  notes:
    - "Wave 257 theme: hashlib.algorithms_available and hashlib.algorithms_guaranteed set membership identity."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. algorithms_available is a Python set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. algorithms_guaranteed is a Python set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.algorithms_available == True. md5 is available via OpenSSL on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.algorithms_available == True. sha256 is available on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha512' in hashlib.algorithms_available == True. sha512 is always available. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha1' in hashlib.algorithms_available == True. sha1 is available on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.algorithms_guaranteed == True. md5 is in the guaranteed set per stdlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.algorithms_guaranteed == True. sha256 is in the guaranteed set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.algorithms_guaranteed == True. blake2b is in the guaranteed set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_256' in hashlib.algorithms_guaranteed == True. sha3_256 is in the guaranteed set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: algorithms_available is a set of names supported by the OpenSSL library on the current platform; it is a superset of algorithms_guaranteed. algorithms_guaranteed is the fixed set of names always available regardless of platform or OpenSSL version."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
#
# Wave 257 theme: hashlib set attributes type identity.
#
# hashlib.algorithms_available and hashlib.algorithms_guaranteed are both Python
# set objects. algorithms_available contains algorithm names supported by the
# current OpenSSL installation; it varies by platform. algorithms_guaranteed
# contains names always available in any CPython installation regardless of
# OpenSSL version or platform. Both are frozenset-like but are actually plain
# mutable sets. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra257.algorithms_set_type_identity:
  description: "hashlib algorithms_available and algorithms_guaranteed are set objects — algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__class__.__name__.__eq__('set')==True — both are Python set objects; algorithms_available contains platform/OpenSSL-dependent names; algorithms_guaranteed contains names always available; wave 257 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsets257

  columns: [id, function, args, expected, description]
  rows:
    - [avail_type,   algorithms_available.__class__.__name__.__eq__,   ["set"], true, "algorithms_available.__class__.__name__ == 'set'; hashlib algorithm set is a plain Python set"]
    - [guar_type,    algorithms_guaranteed.__class__.__name__.__eq__,  ["set"], true, "algorithms_guaranteed.__class__.__name__ == 'set'; hashlib guaranteed algorithm set is a plain Python set"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__('md5') == True
# hashlib.algorithms_available.__contains__('sha256') == True
# hashlib.algorithms_available.__contains__('sha512') == True
# hashlib.algorithms_available.__contains__('sha1') == True
#
# Wave 257 theme: algorithms_available set membership.
#
# algorithms_available contains algorithm names supported by the current OpenSSL
# installation. On macOS with OpenSSL, 'md5', 'sha1', 'sha256', and 'sha512'
# are all present. These are the most widely used cryptographic hash algorithms
# and are expected on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra257.algorithms_available_membership:
  description: "hashlib.algorithms_available set membership — 'md5'/'sha256'/'sha512'/'sha1' are all present — algorithms_available is the OpenSSL-backed set of supported hash algorithm names; includes md5/sha1/sha256/sha512 on all tested platforms; wave 257 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibavail257

  columns: [id, function, args, expected, description]
  rows:
    - [avail_md5,    algorithms_available.__contains__,  ["md5"],    true, "'md5' in hashlib.algorithms_available; md5 is available on macOS via OpenSSL"]
    - [avail_sha256, algorithms_available.__contains__,  ["sha256"], true, "'sha256' in hashlib.algorithms_available; sha256 is universally available"]
    - [avail_sha512, algorithms_available.__contains__,  ["sha512"], true, "'sha512' in hashlib.algorithms_available; sha512 is universally available"]
    - [avail_sha1,   algorithms_available.__contains__,  ["sha1"],   true, "'sha1' in hashlib.algorithms_available; sha1 is available on macOS via OpenSSL"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') == True
# hashlib.algorithms_guaranteed.__contains__('sha256') == True
# hashlib.algorithms_guaranteed.__contains__('blake2b') == True
# hashlib.algorithms_guaranteed.__contains__('sha3_256') == True
#
# Wave 257 theme: algorithms_guaranteed set membership.
#
# algorithms_guaranteed is the fixed set of names guaranteed to be available
# in any CPython installation (regardless of OpenSSL version). It includes
# 'md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512', 'blake2b', 'blake2s',
# 'sha3_224', 'sha3_256', 'sha3_384', 'sha3_512', 'shake_128', 'shake_256'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra257.algorithms_guaranteed_membership:
  description: "hashlib.algorithms_guaranteed set membership — 'md5'/'sha256'/'blake2b'/'sha3_256' are all guaranteed — algorithms_guaranteed is the fixed stdlib-defined set of always-available hash names; includes md5/sha256/blake2b/sha3_256 among 14 names; wave 257 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibguar257

  columns: [id, function, args, expected, description]
  rows:
    - [guar_md5,     algorithms_guaranteed.__contains__,  ["md5"],     true, "'md5' in hashlib.algorithms_guaranteed; md5 is in the stdlib-guaranteed set"]
    - [guar_sha256,  algorithms_guaranteed.__contains__,  ["sha256"],  true, "'sha256' in hashlib.algorithms_guaranteed; sha256 is in the stdlib-guaranteed set"]
    - [guar_blake2b, algorithms_guaranteed.__contains__,  ["blake2b"], true, "'blake2b' in hashlib.algorithms_guaranteed; blake2b is guaranteed via _blake2 C extension"]
    - [guar_sha3256, algorithms_guaranteed.__contains__,  ["sha3_256"], true, "'sha3_256' in hashlib.algorithms_guaranteed; sha3_256 is guaranteed in CPython 3.6+"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available is a set. algorithms_available is populated at
# import time by querying the OpenSSL library for all supported digest names.
# It contains names such as 'md5', 'sha1', 'sha256', 'sha512', and many OpenSSL
# aliases (e.g., 'sha256WithRSAEncryption'). Being a set, duplicate names are
# deduplicated. On Python 3.9+ it is always a plain set (not frozenset). The
# __class__.__name__ is 'set' confirming this. This is the first standalone
# anchor for algorithms_available.__class__.__name__ under hashlibsets257.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra257.algorithms_available_is_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain Python set populated at import from OpenSSL digest names; includes OpenSSL aliases beyond the canonical names; deduplicated by set semantics; __class__.__name__=='set' (not frozenset); first standalone for algorithms_available.__class__.__name__ under hashlibsets257; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') — standalone
#
# 'md5' is in hashlib.algorithms_guaranteed. algorithms_guaranteed is the
# authoritative set of hash algorithm names that CPython guarantees will always
# be available, regardless of platform or OpenSSL installation. MD5 is included
# because CPython ships its own MD5 implementation in Modules/md5module.c as a
# fallback. While MD5 is cryptographically broken for security-sensitive use,
# it remains useful for checksums, legacy compatibility, and non-security
# applications. Its presence in algorithms_guaranteed reflects CPython's
# commitment to backward compatibility. This is the first standalone anchor
# for algorithms_guaranteed.__contains__('md5') under hashlibguar257.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra257.algorithms_guaranteed_contains_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is always available in CPython regardless of OpenSSL; CPython ships its own md5 in Modules/md5module.c as fallback; md5 remains useful for checksums and legacy compatibility despite being broken for security; first standalone for algorithms_guaranteed.__contains__('md5') under hashlibguar257; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_256') — standalone
#
# 'sha3_256' is in hashlib.algorithms_guaranteed. SHA3-256 is the Keccak-based
# 256-bit hash from the SHA-3 family (NIST FIPS 202). It was added to Python's
# guaranteed set in Python 3.6 when the sha3 module (Modules/_sha3/sha3.c) was
# integrated into CPython's core. SHA3-256 produces a 32-byte (256-bit) digest
# and offers resistance to length-extension attacks, unlike SHA-2. On modern
# Python the SHA-3 functions may be provided by OpenSSL or by CPython's own
# Keccak reference implementation. Its presence in algorithms_guaranteed means
# code relying on hashlib.sha3_256 is portable across all CPython 3.6+ installs.
# This is the first standalone anchor for algorithms_guaranteed.__contains__('sha3_256')
# under hashlibguar257. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra257.algorithms_guaranteed_contains_sha3_256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is always available in CPython 3.6+; Keccak-based NIST FIPS 202 256-bit hash; resistant to length-extension attacks unlike SHA-2; provided by OpenSSL or CPython's own Keccak reference in Modules/_sha3/sha3.c; first standalone for algorithms_guaranteed.__contains__('sha3_256') under hashlibguar257; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_256"]
  expected: true
