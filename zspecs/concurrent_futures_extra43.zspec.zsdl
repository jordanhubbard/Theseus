invariant concurrent_futures_extra43.Future_result_module_len:
  description: "concurrent.futures.Future.result.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters"
  category: module_identity
  kind: python_call_eq
  function: Future.result.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra43.Executor_map_module_len:
  description: "concurrent.futures.Executor.map.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters"
  category: module_identity
