spec: concurrent_futures_extra43
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra42.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens for all methods (result/cancel/cancelled/done/running/exception/add_done_callback/set_result/set_exception/set_running_or_notify_cancel), class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, ThreadPoolExecutor/__name__=='ThreadPoolExecutor', ProcessPoolExecutor/__name__=='ProcessPoolExecutor', executor __module__ string equality, wait/__name__=='wait', function __module__ string equality, Executor/__name__=='Executor'/__module__==concurrent.futures._base, Executor map/submit qualname lengths, InvalidStateError/BrokenExecutor __name__/__module__ string equality, ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths, ProcessPoolExecutor/ThreadPoolExecutor/__mro__.__len__()==3, Future/__mro__.__len__()==2, Executor/__mro__.__len__()==2, ThreadPoolExecutor/__qualname__=='ThreadPoolExecutor', ProcessPoolExecutor/__qualname__=='ProcessPoolExecutor', Future/__qualname__=='Future', Executor/__qualname__=='Executor', CancelledError/__qualname__=='CancelledError', BrokenExecutor/__qualname__=='BrokenExecutor', all class __qualname__.__len__() tables (extra41), InvalidStateError/__qualname__=='InvalidStateError', TimeoutError/__qualname__=='TimeoutError', ThreadPoolExecutor/ProcessPoolExecutor/InvalidStateError/TimeoutError __module__.__len__(), module string equality for thread/process/builtins modules (extra42)."
    - "This spec covers: Future.result/__module__.__eq__('concurrent.futures._base'); Future.cancel/__module__.__eq__('concurrent.futures._base'); Future.cancelled/__module__.__eq__('concurrent.futures._base'); Future.done/__module__.__eq__('concurrent.futures._base'); Future.running/__module__.__eq__('concurrent.futures._base'); Future.exception/__module__.__eq__('concurrent.futures._base'); Future.add_done_callback/__module__.__eq__('concurrent.futures._base'); Executor.map/__module__.__eq__('concurrent.futures._base'); all Future method __module__.__len__()==24; Executor.map/__module__.__len__()==24."
    - "concurrent.futures.Future.result.__module__ == 'concurrent.futures._base'. All Future methods are defined in _base.py; each method's __module__ reflects the defining module. Prior specs captured the class __module__ for Future, Executor etc., and method __qualname__/__name__ string equality and lengths; extra43 captures the method-level __module__ string equality for the first time. Verified with Python 3.14.3."
    - "All nine Future public methods (result, cancel, cancelled, done, running, exception, add_done_callback, set_result, set_exception) and Executor.map share __module__ == 'concurrent.futures._base'. This is because they are all defined in the same source file (Lib/concurrent/futures/_base.py). Verified with Python 3.14.3."
    - "Future method __module__.__len__() == 24. 'concurrent.futures._base' has 24 characters. This matches the class-level __module__ lengths already captured in prior specs for Future/Executor/CancelledError/BrokenExecutor/InvalidStateError. Verified with Python 3.14.3."
    - "Executor.map.__module__ == 'concurrent.futures._base'. Executor is the abstract base class for executors; its map method is defined in _base.py, so __module__ == 'concurrent.futures._base' (24 chars). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Future method __module__ string equality — extra43
#
# All Future public methods are defined in Lib/concurrent/futures/_base.py.
# Therefore every method's __module__ attribute equals 'concurrent.futures._base'.
# Prior specs captured the class-level __module__ string equality for Future,
# Executor, CancelledError, BrokenExecutor, and InvalidStateError (extra16,
# extra23, extra36), and method __qualname__/__name__ values extensively.
# Extra43 captures the method-level __module__ string equality for the first time.
#
# Methods covered:
#   Future.result.__module__           == 'concurrent.futures._base'
#   Future.cancel.__module__           == 'concurrent.futures._base'
#   Future.cancelled.__module__        == 'concurrent.futures._base'
#   Future.done.__module__             == 'concurrent.futures._base'
#   Future.running.__module__          == 'concurrent.futures._base'
#   Future.exception.__module__        == 'concurrent.futures._base'
#   Future.add_done_callback.__module__== 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra43.future_method_module_eq:
  description: "concurrent.futures Future method __module__ string equality in extra43 namespace — all public status/query methods"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfFutMethMod43

  columns: [id, function, args, expected, description]
  rows:
    - [result,            Future.result.__module__.__eq__,            ["concurrent.futures._base"], true, "Future.result.__module__ == 'concurrent.futures._base' — defined in _base.py"]
    - [cancel,            Future.cancel.__module__.__eq__,            ["concurrent.futures._base"], true, "Future.cancel.__module__ == 'concurrent.futures._base' — defined in _base.py"]
    - [cancelled,         Future.cancelled.__module__.__eq__,         ["concurrent.futures._base"], true, "Future.cancelled.__module__ == 'concurrent.futures._base' — defined in _base.py"]
    - [done,              Future.done.__module__.__eq__,              ["concurrent.futures._base"], true, "Future.done.__module__ == 'concurrent.futures._base' — defined in _base.py"]
    - [running,           Future.running.__module__.__eq__,           ["concurrent.futures._base"], true, "Future.running.__module__ == 'concurrent.futures._base' — defined in _base.py"]
    - [exception,         Future.exception.__module__.__eq__,         ["concurrent.futures._base"], true, "Future.exception.__module__ == 'concurrent.futures._base' — defined in _base.py"]
    - [add_done_callback, Future.add_done_callback.__module__.__eq__, ["concurrent.futures._base"], true, "Future.add_done_callback.__module__ == 'concurrent.futures._base' — defined in _base.py"]

# ---------------------------------------------------------------------------
# concurrent.futures Future mutation method and Executor.map __module__ eq — extra43
#
# The two Future mutation methods and Executor.map also share the same module:
#   Future.set_result.__module__    == 'concurrent.futures._base'
#   Future.set_exception.__module__ == 'concurrent.futures._base'
#   Executor.map.__module__         == 'concurrent.futures._base'
# This completes the picture for all Future and Executor.map method __module__
# string equality in extra43.
# ---------------------------------------------------------------------------

table concurrent_futures_extra43.future_mutation_executor_module_eq:
  description: "concurrent.futures Future mutation methods and Executor.map __module__ string equality in extra43 namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfFutMutExecMod43

  columns: [id, function, args, expected, description]
  rows:
    - [set_result,   Future.set_result.__module__.__eq__,   ["concurrent.futures._base"], true, "Future.set_result.__module__ == 'concurrent.futures._base' — internal mutation method defined in _base.py"]
    - [set_exception, Future.set_exception.__module__.__eq__, ["concurrent.futures._base"], true, "Future.set_exception.__module__ == 'concurrent.futures._base' — internal mutation method defined in _base.py"]
    - [Executor_map,  Executor.map.__module__.__eq__,        ["concurrent.futures._base"], true, "Executor.map.__module__ == 'concurrent.futures._base' — abstract base executor method defined in _base.py"]

# ---------------------------------------------------------------------------
# concurrent.futures Future method and Executor.map __module__.__len__() — extra43
#
# All Future method and Executor.map __module__ strings have length 24:
#   'concurrent.futures._base' has 24 characters.
# This matches the class-level __module__ lengths captured in prior specs.
# Extra43 presents the method-level lengths as a comprehensive table.
# ---------------------------------------------------------------------------

table concurrent_futures_extra43.method_module_lengths:
  description: "concurrent.futures Future method and Executor.map __module__.__len__() in extra43 namespace — all 24 characters"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfMethModLen43

  columns: [id, function, args, expected, description]
  rows:
    - [result,            Future.result.__module__.__len__,            [], 24, "Future.result.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [cancel,            Future.cancel.__module__.__len__,            [], 24, "Future.cancel.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [done,              Future.done.__module__.__len__,              [], 24, "Future.done.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [running,           Future.running.__module__.__len__,           [], 24, "Future.running.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [exception,         Future.exception.__module__.__len__,         [], 24, "Future.exception.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [add_done_callback, Future.add_done_callback.__module__.__len__, [], 24, "Future.add_done_callback.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [set_result,        Future.set_result.__module__.__len__,        [], 24, "Future.set_result.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [set_exception,     Future.set_exception.__module__.__len__,     [], 24, "Future.set_exception.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]
    - [Executor_map,      Executor.map.__module__.__len__,             [], 24, "Executor.map.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra43
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra43.Future_result_module_eq:
  description: "concurrent.futures.Future.result.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py"
  category: module_identity
  kind: python_call_eq
  function: Future.result.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra43.Future_cancel_module_eq:
  description: "concurrent.futures.Future.cancel.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py"
  category: module_identity
  kind: python_call_eq
  function: Future.cancel.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra43.Future_done_module_eq:
  description: "concurrent.futures.Future.done.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py"
  category: module_identity
  kind: python_call_eq
  function: Future.done.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra43.Future_add_done_callback_module_eq:
  description: "concurrent.futures.Future.add_done_callback.__module__ == 'concurrent.futures._base' — defined in Lib/concurrent/futures/_base.py"
  category: module_identity
  kind: python_call_eq
  function: Future.add_done_callback.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra43.Future_set_result_module_eq:
  description: "concurrent.futures.Future.set_result.__module__ == 'concurrent.futures._base' — internal mutation method defined in _base.py"
  category: module_identity
  kind: python_call_eq
  function: Future.set_result.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra43.Future_set_exception_module_eq:
  description: "concurrent.futures.Future.set_exception.__module__ == 'concurrent.futures._base' — internal mutation method defined in _base.py"
  category: module_identity
  kind: python_call_eq
  function: Future.set_exception.__module__.__eq__
  args: ["concurrent.futures._base"]
