spec: filecmp
version: ">=3.2"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/filecmp.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/filecmp.py (internal implementation)"
  notes:
    - "filecmp.cmp(f1, f2) compares two files; returns True if equal (by default using shallow comparison)."
    - "filecmp.cmpfiles(a, b, common) compares files in two directories; returns (match, mismatch, errors) triple."
    - "filecmp.clear_cache() clears the filecmp cache of file comparison results; returns None."
    - "filecmp.dircmp is a class for directory tree comparison; it computes left_only, right_only, common, etc."
    - "filecmp.DEFAULT_IGNORES is a list of filenames to ignore by default; includes '.git', 'RCS', 'CVS', 'tags'."
    - "dircmp.report() prints a comparison report to stdout; report_full_closure() recurses into subdirectories."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "filecmp functions raise OSError if a file cannot be accessed; cmpfiles silently appends inaccessible names to the errors list."
  stderr: "null"
  stickiness: "N/A — each call is stateless (clear_cache resets shared cache state)."
  codes: {}

# ---------------------------------------------------------------------------
# Function name metadata
# ---------------------------------------------------------------------------

table filecmp.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__name__.__eq__,         ["cmp"],         true]
    - [cmpfiles,    cmpfiles.__name__.__eq__,     ["cmpfiles"],    true]
    - [clear_cache, clear_cache.__name__.__eq__,  ["clear_cache"], true]

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

invariant filecmp.dircmp_name:
  description: "filecmp.dircmp.__name__ == 'dircmp'"
  category: classes
  kind: python_call_eq
  function: dircmp.__name__.__eq__
  args: ["dircmp"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation
# ---------------------------------------------------------------------------

invariant filecmp.cmp_module:
  description: "filecmp.cmp.__module__ == 'filecmp'"
  category: module
  kind: python_call_eq
  function: cmp.__module__.__eq__
  args: ["filecmp"]
  expected: true

# ---------------------------------------------------------------------------
# Method names on dircmp
# ---------------------------------------------------------------------------

table filecmp.dircmp_method_names:
  kind: python_call_eq
  category: dircmp_methods
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [report,                dircmp.report.__name__.__eq__,                ["report"],                true]
    - [report_full_closure,   dircmp.report_full_closure.__name__.__eq__,   ["report_full_closure"],   true]
    - [report_partial_closure, dircmp.report_partial_closure.__name__.__eq__, ["report_partial_closure"], true]

# ---------------------------------------------------------------------------
# DEFAULT_IGNORES — list of filenames ignored by dircmp by default
# ---------------------------------------------------------------------------

invariant filecmp.DEFAULT_IGNORES_is_list:
  description: "filecmp.DEFAULT_IGNORES is a list"
  category: constants
  kind: python_call_eq
  function: DEFAULT_IGNORES.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant filecmp.DEFAULT_IGNORES_contains_git:
  description: "filecmp.DEFAULT_IGNORES contains '.git'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_IGNORES.__contains__
  args: [".git"]
  expected: true

# ---------------------------------------------------------------------------
# clear_cache — returns None
# ---------------------------------------------------------------------------

invariant filecmp.clear_cache_returns_none:
  description: "filecmp.clear_cache() returns None"
  category: clear_cache
  kind: python_call_eq
  function: clear_cache
  args: []
  expected: ~
