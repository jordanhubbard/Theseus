spec: ab3136
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (ab3136): __call__, __len__, __getitem__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__call__): type(abc.abstractmethod(lambda: None)) — i.e. <class 'function'> — defines __call__ in its own __dict__ (true). abc.ABC and abc.ABCMeta return false for __call__. The function type's __call__ is its own dispatch entry, enabling f() syntax for all Python function objects. This is the Python-level hook that parallels the C-level tp_call slot."
    - "Key finding (__len__): all 3 abc subjects return false for __len__. Functions are not sized objects; ABC and ABCMeta have no collection semantics."
    - "Key finding (__getitem__): all 3 abc subjects return false for __getitem__. No abc type supports subscript access in its own __dict__. Note: abc.ABCMeta supports type[T] subscript syntax via __class_getitem__ (not __getitem__), which is inherited from type — that is a different slot entirely."
    - "type(abc.abstractmethod(lambda: None)) is <class 'function'>. The function type defines __call__ directly in its __dict__ — this is what makes Python functions callable via the data model. Wave 655 (ab3121) found __repr__ true for function type; this wave confirms __call__ is also true. Combined: function type defines both __call__ and __repr__ in its own __dict__."
    - "abc.ABC does not define __call__ — ABC is a plain abstract base class whose instances are not callable unless the concrete subclass defines __call__."
    - "abc.ABCMeta is a metaclass. Metaclasses are callable (they create instances via ABCMeta(...)), but __call__ for class creation is defined on type (the meta-metaclass), not on ABCMeta itself. operator.contains(ABCMeta.__dict__, '__call__') is therefore false."
    - "The distinction: calling ABCMeta as a constructor invokes type.__call__ (inherited), while calling an instance of a class defined with ABCMeta would use the class's own __call__ if defined. Neither path puts __call__ into ABCMeta.__dict__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# type(abc.abstractmethod(lambda: None)) is <class 'function'>: TRUE — the
#   function type defines __call__ in its own __dict__. This is the Python
#   data-model entry point for calling any function object: f.__call__(...) is
#   equivalent to f(...). It parallels the C-level tp_call slot.
# abc.ABC: false — not callable by default; instances need to define __call__
#   in a concrete subclass.
# abc.ABCMeta: false — ABCMeta inherits type.__call__ for class construction
#   but does not define its own __call__ in ABCMeta.__dict__.
# ---------------------------------------------------------------------------

table ab3136.call:
  description: "abc types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3136

  columns: [id, function, args, expected]
  rows:
    - ["ab3136001", operator.contains, [abc.ABC.__dict__,                                 "__call__"], false]
    - ["ab3136002", operator.contains, [abc.ABCMeta.__dict__,                             "__call__"], false]
    - ["ab3136003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__call__"], true]

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# All 3 abc subjects return false for __len__.
# Functions are not sized objects — len(f) raises TypeError.
# abc.ABC and abc.ABCMeta have no collection semantics.
# ---------------------------------------------------------------------------

table ab3136.len:
  description: "abc types __len__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3136

  columns: [id, function, args, expected]
  rows:
    - ["ab3136004", operator.contains, [abc.ABC.__dict__,                                 "__len__"], false]
    - ["ab3136005", operator.contains, [abc.ABCMeta.__dict__,                             "__len__"], false]
    - ["ab3136006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__len__"], false]

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# All 3 abc subjects return false for __getitem__.
# Functions do not support [] subscript access.
# abc.ABC does not define __getitem__ — abstract base classes are not containers.
# abc.ABCMeta: note that type.__class_getitem__ (inherited) enables ABC[T] in
#   Python 3.9+ for generic type hints, but __class_getitem__ is a different slot
#   from __getitem__. operator.contains(ABCMeta.__dict__, '__getitem__') is false.
# ---------------------------------------------------------------------------

table ab3136.getitem:
  description: "abc types __getitem__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3136

  columns: [id, function, args, expected]
  rows:
    - ["ab3136007", operator.contains, [abc.ABC.__dict__,                                 "__getitem__"], false]
    - ["ab3136008", operator.contains, [abc.ABCMeta.__dict__,                             "__getitem__"], false]
    - ["ab3136009", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__getitem__"], false]

# ---------------------------------------------------------------------------
# combined — __call__, __len__, __getitem__ across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __call__:    true only for type(abstractmethod(lambda: None)) (<class 'function'>).
#              abc.ABC and abc.ABCMeta: false.
# __len__:     false for all 3.
# __getitem__: false for all 3.
# The only non-false value is function type's __call__ (true).
# This is symmetric with wave 655 (ab3121) where the only non-false value
# was function type's __repr__ (true). Together, function type defines both
# __call__ and __repr__ in its own __dict__ — the two most fundamental
# display/invocation entries in the Python data model.
# abc.ABCMeta asymmetry: ABCMeta instances (i.e. classes) are callable via
# type.__call__, and ABCMeta classes support ABC[T] via __class_getitem__ —
# yet neither __call__ nor __getitem__ appears in ABCMeta.__dict__ itself,
# because both are inherited from type without override.
# Cross-wave summary for abc subjects:
#   Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false for all.
#   Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3.
#   Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3.
#   Wave 655 (ab3121): __ge__ false; __repr__ true for function type only; __str__ false.
#   Wave 656 (ab3136): __call__ true for function type only; __len__/__getitem__ false for all.
# ---------------------------------------------------------------------------

table ab3136.combined:
  description: "abc types combined __call__/__len__/__getitem__; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3136

  columns: [id, function, args, expected]
  rows:
    - ["ab3136010", operator.contains, [abc.ABC.__dict__,                                 "__call__"],    false]
    - ["ab3136011", operator.contains, [abc.ABC.__dict__,                                 "__len__"],     false]
    - ["ab3136012", operator.contains, [abc.ABC.__dict__,                                 "__getitem__"], false]
    - ["ab3136013", operator.contains, [abc.ABCMeta.__dict__,                             "__call__"],    false]
    - ["ab3136014", operator.contains, [abc.ABCMeta.__dict__,                             "__len__"],     false]
    - ["ab3136015", operator.contains, [abc.ABCMeta.__dict__,                             "__getitem__"], false]
    - ["ab3136016", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__call__"],    true]
    - ["ab3136017", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__len__"],     false]
    - ["ab3136018", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__getitem__"], false]
