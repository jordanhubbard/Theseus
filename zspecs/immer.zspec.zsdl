spec: immer
version: ">=10.0.0"
backend: node(immer)

docs: https://immerjs.github.io/immer/

provenance:
  derived_from:
    - "Immer docs — https://immerjs.github.io/immer/"
    - "Test vectors verified with immer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "immer source"
  notes:
    - "Immutable state with mutable syntax — used by Redux Toolkit, Zustand, etc."
    - "Install: npm install immer"
    - "v11 CJS; named exports produce / freeze / isDraft / isDraftable / current / original / immerable / nothing."
    - "produce() takes a recipe function we cannot pass through JSON, so this spec covers the static predicates and helpers."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "produce() throws if the recipe both returns a value AND mutates the draft."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# isDraft on plain objects → false (they're not currently being drafted)
invariant immer.isDraft_plain_object_false:
  description: "isDraft({}) is false outside a produce() recipe"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: isDraft
  entry_args: [{}]
  chain: []
  expected: false

invariant immer.isDraft_plain_array_false:
  description: "isDraft([]) is false"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: isDraft
  entry_args: [[]]
  chain: []
  expected: false

# isDraftable: which inputs immer can draft
invariant immer.isDraftable_object_true:
  description: "isDraftable({}) is true"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: isDraftable
  entry_args: [{}]
  chain: []
  expected: true

invariant immer.isDraftable_array_true:
  description: "isDraftable([]) is true"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: isDraftable
  entry_args: [[]]
  chain: []
  expected: true

invariant immer.isDraftable_null_false:
  description: "isDraftable(null) is false"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: isDraftable
  entry_args: [~]
  chain: []
  expected: false

invariant immer.isDraftable_string_false:
  description: "isDraftable('x') is false"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: isDraftable
  entry_args: ["x"]
  chain: []
  expected: false

invariant immer.isDraftable_number_false:
  description: "isDraftable(5) is false"
  category: predicates
  kind: node_chain_eq
  entry: named
  function: isDraftable
  entry_args: [5]
  chain: []
  expected: false

# produce arity
invariant immer.produce_arity:
  description: "produce takes (base, recipe, listener?) — function.length 3"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "produce.length"}
  expected: 3

# immerable export shape
invariant immer.immerable_is_symbol:
  description: "immerable is a Symbol (used to mark classes drafable)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: immerable}
    - {get: "constructor.name"}
  expected: "Symbol"

# freeze
invariant immer.freeze_returns_frozen_object:
  description: "freeze(obj) returns the same object, frozen"
  category: freeze
  kind: node_chain_eq
  entry: named
  function: freeze
  entry_args: [{a: 1}]
  chain:
    - {get: a}
  expected: 1
