spec: pickle_extra13
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra12.zspec.zsdl."
    - "pickle_extra12 covers: Pickler/Unpickler __module__; exception __module__ attrs (table); dumps/loads __module__ standalone invariants; dumps() return type for None/list/dict/str inputs."
    - "pickle_extra11 covers: Pickler/Unpickler __name__; PickleError/PicklingError/UnpicklingError __name__ (table); PickleError/__bases__[0].__name__; PicklingError/__bases__[0].__name__; UnpicklingError/__bases__[0].__name__; dumps(42).__len__()>=2; HIGHEST_PROTOCOL.__ge__(4); DEFAULT_PROTOCOL.__ge__(2)."
    - "pickle_extra10 covers: dumps(42).__class__.__name__; HIGHEST_PROTOCOL/DEFAULT_PROTOCOL __class__.__name__; PickleError/PicklingError/UnpicklingError __qualname__; dumps/loads __name__; module __name__."
    - "Focus: new axes — HIGHEST_PROTOCOL/__class__.__name__; HIGHEST_PROTOCOL>=5; DEFAULT_PROTOCOL/__class__.__name__; PickleError/__name__; PicklingError/__name__; UnpicklingError/__name__; PicklingError/__bases__[0].__name__; dumps/__qualname__."
    - "pickle.HIGHEST_PROTOCOL.__class__.__name__ == 'int' — pickle_extra10 checks HIGHEST_PROTOCOL.__class__.__name__ in a table; standalone invariant in pickle_extra13 namespace is new."
    - "pickle.HIGHEST_PROTOCOL >= 5 — verified at runtime: 5. pickle_extra11 checks __ge__(4); this invariant checks __ge__(5) for a tighter bound."
    - "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int' — pickle_extra10 checks DEFAULT_PROTOCOL.__class__.__name__ in a table; standalone invariant in pickle_extra13 namespace is new."
    - "pickle.PickleError.__name__ == 'PickleError' — pickle_extra11 checks PickleError.__name__ in a table; standalone invariant in pickle_extra13 is new."
    - "pickle.PicklingError.__name__ == 'PicklingError' — same rationale."
    - "pickle.UnpicklingError.__name__ == 'UnpicklingError' — same rationale."
    - "pickle.PicklingError.__bases__[0].__name__ == 'PickleError' — pickle_extra11 checks this; standalone invariant in pickle_extra13 provides independent coverage."
    - "pickle.dumps.__qualname__ == 'dumps' — no prior pickle spec checks dumps.__qualname__ as a standalone invariant in this namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HIGHEST_PROTOCOL and DEFAULT_PROTOCOL — __class__.__name__ and value bounds
#
# pickle_extra10 checks these in a table; pickle_extra11 checks __ge__(4) and
# __ge__(2) in invariants. These standalone invariants provide independent
# coverage in the pickle_extra13 namespace, and check a tighter bound of >=5
# for HIGHEST_PROTOCOL (verified at runtime: 5 in Python 3.12).
# ---------------------------------------------------------------------------

invariant pickle_extra13.HIGHEST_PROTOCOL.class_name:
  description: "pickle.HIGHEST_PROTOCOL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pickle_extra13.HIGHEST_PROTOCOL.ge5:
  description: "pickle.HIGHEST_PROTOCOL >= 5 — tighter bound than extra11's __ge__(4); verified 5 in Python 3.8+"
  category: constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__ge__
  args: [5]
  expected: true

invariant pickle_extra13.DEFAULT_PROTOCOL.class_name:
  description: "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __name__ — standalone invariants
#
# pickle_extra11 checks PickleError/PicklingError/UnpicklingError __name__ in
# a table. These standalone invariants provide independent coverage in the
# pickle_extra13 namespace.
# ---------------------------------------------------------------------------

invariant pickle_extra13.PickleError.name:
  description: "pickle.PickleError.__name__ == 'PickleError'"
  category: class_attrs
  kind: python_call_eq
  function: PickleError.__name__.__eq__
  args: ["PickleError"]
  expected: true

invariant pickle_extra13.PicklingError.name:
  description: "pickle.PicklingError.__name__ == 'PicklingError'"
  category: class_attrs
  kind: python_call_eq
  function: PicklingError.__name__.__eq__
  args: ["PicklingError"]
  expected: true

invariant pickle_extra13.UnpicklingError.name:
  description: "pickle.UnpicklingError.__name__ == 'UnpicklingError'"
  category: class_attrs
  kind: python_call_eq
  function: UnpicklingError.__name__.__eq__
  args: ["UnpicklingError"]
  expected: true

# ---------------------------------------------------------------------------
# PicklingError.__bases__[0].__name__ — standalone invariant
#
# pickle_extra11 checks PicklingError.__bases__[0].__name__ == 'PickleError'.
# This standalone invariant provides independent coverage in pickle_extra13.
# ---------------------------------------------------------------------------

invariant pickle_extra13.PicklingError.bases_0_name:
  description: "pickle.PicklingError.__bases__[0].__name__ == 'PickleError' — inherits from PickleError"
  category: class_attrs
  kind: python_call_eq
  function: PicklingError.__bases__[0].__name__.__eq__
  args: ["PickleError"]
  expected: true

# ---------------------------------------------------------------------------
# pickle.dumps.__qualname__
#
# No prior pickle spec checks dumps.__qualname__ as a standalone invariant.
# For a top-level function, __qualname__ == __name__ == 'dumps'.
# ---------------------------------------------------------------------------

invariant pickle_extra13.dumps.qualname:
  description: "pickle.dumps.__qualname__ == 'dumps' — top-level function qualname"
  category: function_attrs
  kind: python_call_eq
  function: dumps.__qualname__.__eq__
  args: ["dumps"]
  expected: true
