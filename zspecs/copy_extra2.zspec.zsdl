spec: copy_extra2
version: ">=3.0"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "Python copy documentation — https://docs.python.org/3/library/copy.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "copy.copy.__name__ == 'copy' — the shallow copy function has that dunder name."
    - "copy.deepcopy.__name__ == 'deepcopy' — the deep copy function has that dunder name."
    - "copy.Error.__name__ == 'Error' and copy.error.__name__ == 'Error' — both spellings are the same class."
    - "copy.Error.__bases__[0].__name__ == 'Exception' — Error subclasses Exception directly."
    - "copy.copy([1,2,3]) returns a list equal to [1,2,3]."
    - "copy.deepcopy({'a':1}) returns a dict equal to {'a':1}."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name identity
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.dunder_name:
  description: "copy.copy.__name__ == 'copy'"
  category: function_identity
  kind: python_call_eq
  function: copy.__name__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra2.deepcopy.dunder_name:
  description: "copy.deepcopy.__name__ == 'deepcopy'"
  category: function_identity
  kind: python_call_eq
  function: deepcopy.__name__.__eq__
  args: ["deepcopy"]
  expected: true

# ---------------------------------------------------------------------------
# Error class name — canonical and alias
# ---------------------------------------------------------------------------

invariant copy_extra2.Error.dunder_name:
  description: "copy.Error.__name__ == 'Error'"
  category: error_class
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant copy_extra2.error.dunder_name:
  description: "copy.error.__name__ == 'Error' — lowercase alias has same __name__"
  category: error_class
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Error base class
# ---------------------------------------------------------------------------

invariant copy_extra2.Error.base_is_Exception:
  description: "copy.Error.__bases__[0].__name__ == 'Exception'"
  category: error_class
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Shallow and deep copy value equality
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.list_equal:
  description: "copy.copy([1,2,3]) == [1,2,3]"
  category: copy_value
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  expected: [1, 2, 3]

invariant copy_extra2.deepcopy.dict_equal:
  description: "copy.deepcopy({'a': 1}) == {'a': 1}"
  category: deepcopy_value
  kind: python_call_eq
  function: deepcopy
  args: [{"a": 1}]
  expected: {"a": 1}
