spec: copy_extra2
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "Python copy documentation — https://docs.python.org/3/library/copy.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy.zspec.zsdl — covers function names (copy, deepcopy), error class name (Error), copy.__module__ == 'copy', Error.__module__ == 'copy'"
    - "copy_extra.zspec.zsdl — covers copy(42), copy([1,2,3]), deepcopy({'a':1}), deepcopy([1,[2,3]]), Error bases, copy.__name__, deepcopy.__name__"
  notes:
    - "copy.copy.__module__ == 'copy' — the shallow copy function belongs to the copy module."
    - "copy.deepcopy.__module__ == 'copy' — the deep copy function belongs to the copy module."
    - "copy.Error.__name__ == 'Error' — the exception class name is 'Error'."
    - "copy.copy(None) is None — shallow copy of None returns None (immutable singleton)."
    - "copy.copy(True) == True — shallow copy of True returns True (immutable bool)."
    - "copy.deepcopy(None) is None — deep copy of None returns None."
    - "copy.deepcopy(True) == True — deep copy of True returns True."
    - "copy.copy((1,2,3)) == (1,2,3) — shallow copy of a tuple returns an equal tuple."
    - "copy.deepcopy((1,2,3)) == (1,2,3) — deep copy of a tuple returns an equal tuple."
    - "copy.copy({}) == {} — shallow copy of an empty dict returns an equal empty dict."
    - "copy.deepcopy({}) == {} — deep copy of an empty dict returns an equal empty dict."
    - "copy.copy(42).__class__.__name__ == 'int' — copy of an int returns an int."
    - "copy.deepcopy([1,2]).__class__.__name__ == 'list' — deepcopy of a list returns a list."
    - "copy.copy.__class__.__name__ == 'function' — copy is a plain Python function."
    - "copy.deepcopy.__class__.__name__ == 'function' — deepcopy is a plain Python function."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module affiliation — copy and deepcopy
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.module:
  description: "copy.copy.__module__ == 'copy'"
  category: module
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra2.deepcopy.module:
  description: "copy.deepcopy.__module__ == 'copy'"
  category: module
  kind: python_call_eq
  function: deepcopy.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# Error class name
# ---------------------------------------------------------------------------

invariant copy_extra2.Error.name:
  description: "copy.Error.__name__ == 'Error'"
  category: error_class
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# copy and deepcopy of None (immutable singleton)
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.none_is_none:
  description: "copy.copy(None) == None — copy of None returns None"
  category: copy_immutable
  kind: python_call_eq
  function: copy
  args: [null]
  expected: null

invariant copy_extra2.deepcopy.none_is_none:
  description: "copy.deepcopy(None) == None — deepcopy of None returns None"
  category: deepcopy_immutable
  kind: python_call_eq
  function: deepcopy
  args: [null]
  expected: null

# ---------------------------------------------------------------------------
# copy and deepcopy of True (immutable bool)
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.true_eq_true:
  description: "copy.copy(True) == True — copy of True returns True"
  category: copy_immutable
  kind: python_call_eq
  function: copy
  args: [true]
  expected: true

invariant copy_extra2.deepcopy.true_eq_true:
  description: "copy.deepcopy(True) == True — deepcopy of True returns True"
  category: deepcopy_immutable
  kind: python_call_eq
  function: deepcopy
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# copy and deepcopy of tuples (immutable sequence)
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.tuple_equal:
  description: "copy.copy((1,2,3)) == (1,2,3) — copy of a tuple returns an equal tuple"
  category: copy_immutable
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: false

invariant copy_extra2.copy.tuple_class:
  description: "copy.copy.__class__.__name__ == 'function'"
  category: copy_class
  kind: python_call_eq
  function: copy.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant copy_extra2.deepcopy.function_class:
  description: "copy.deepcopy.__class__.__name__ == 'function'"
  category: copy_class
  kind: python_call_eq
  function: deepcopy.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# copy and deepcopy of empty containers
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.empty_dict:
  description: "copy.copy({}) == {} — copy of an empty dict returns an equal empty dict"
  category: copy_containers
  kind: python_call_eq
  function: copy
  args: [{}]
  expected: {}

invariant copy_extra2.deepcopy.empty_dict:
  description: "copy.deepcopy({}) == {} — deepcopy of an empty dict returns an equal empty dict"
  category: deepcopy_containers
  kind: python_call_eq
  function: deepcopy
  args: [{}]
  expected: {}

# ---------------------------------------------------------------------------
# Return type checks
# ---------------------------------------------------------------------------

invariant copy_extra2.copy.int_class_name:
  description: "copy.copy(42).__class__.__name__ == 'int'"
  category: copy_type
  kind: python_call_eq
  function: copy
  args: [42]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant copy_extra2.deepcopy.list_class_name:
  description: "copy.deepcopy([1,2]).__class__.__name__ == 'list'"
  category: deepcopy_type
  kind: python_call_eq
  function: deepcopy
  args: [[1, 2]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true
