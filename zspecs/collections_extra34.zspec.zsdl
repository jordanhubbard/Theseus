spec: collections_extra34
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra33.zspec.zsdl."
    - "Prior specs covered: all class __name__/__module__/__qualname__/__bases__, __mro__.__len__ for all core classes, __bases__[0].__name__ for all eight classes, __qualname__.__len__ for all nine top-level symbols, deque/Counter/OrderedDict method qualname lengths, __dict__.__class__.__name__ for all major classes (== 'mappingproxy', len=12)."
    - "This spec covers: collections.__all__.__len__() and .__class__.__name__.__len__(); __dict__.__class__.__name__.__len__() for OrderedDict/defaultdict/Counter/deque/ChainMap (all 12); OrderedDict.__reversed__.__qualname__.__len__()==24; ChainMap.new_child/__qualname__.__len__()==18; UserDict/UserList/UserString.__bases__[0].__name__.__len__(); defaultdict.__bases__[0].__name__.__len__()==4."
    - "collections.__all__.__len__() == 9 — nine public symbols: ChainMap, Counter, OrderedDict, UserDict, UserList, UserString, defaultdict, deque, namedtuple."
    - "collections.__all__.__class__.__name__ == 'list' (len=4) — __all__ is a plain Python list."
    - "All five core collection classes have __dict__.__class__.__name__ == 'mappingproxy' (len=12) — the class namespace is always wrapped in a read-only mappingproxy."
    - "OrderedDict.__reversed__.__qualname__ == 'OrderedDict.__reversed__' (len=24) — longest method qualname in the OrderedDict family."
    - "ChainMap.new_child.__qualname__ == 'ChainMap.new_child' (len=18)."
    - "defaultdict.__bases__[0].__name__ == 'dict' (len=4) — defaultdict directly subclasses dict."
    - "UserDict.__bases__[0].__name__ == 'MutableMapping' (len=14) — UserDict is an ABC-backed pure-Python dict wrapper."
    - "UserList.__bases__[0].__name__ == 'MutableSequence' (len=15) — longest base-class name among the User* wrappers."
    - "UserString.__bases__[0].__name__ == 'Sequence' (len=8)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table for core collection classes
# (extra34 namespace)
#
# Every Python class stores its namespace in a read-only 'mappingproxy' object.
# All five core collection classes (OrderedDict, defaultdict, Counter, deque,
# ChainMap) share the same __dict__.__class__.__name__ == 'mappingproxy',
# which has exactly 12 characters. No prior collections spec records all five
# together in the extra34 namespace.
# ---------------------------------------------------------------------------

table collections_extra34.core_class_dict_class_name_lens:
  description: "__dict__.__class__.__name__.__len__() for core collection classes — all equal 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_attrs
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [OrderedDict, OrderedDict.__dict__.__class__.__name__.__len__, [], 12]
    - [defaultdict, defaultdict.__dict__.__class__.__name__.__len__, [], 12]
    - [Counter,     Counter.__dict__.__class__.__name__.__len__,     [], 12]
    - [deque,       deque.__dict__.__class__.__name__.__len__,       [], 12]
    - [ChainMap,    ChainMap.__dict__.__class__.__name__.__len__,    [], 12]

# ---------------------------------------------------------------------------
# User* wrapper class __bases__[0].__name__.__len__() table
# (extra34 namespace)
#
# UserDict, UserList, and UserString are pure-Python wrapper classes that
# delegate to an underlying data attribute. Each inherits from an ABC:
#   UserDict   -> MutableMapping  (14 chars)
#   UserList   -> MutableSequence (15 chars) — longest
#   UserString -> Sequence        (8 chars)  — shortest
# No prior collections spec records these base-class name lengths in the
# extra34 namespace.
# ---------------------------------------------------------------------------

table collections_extra34.user_wrapper_base_name_lens:
  description: "__bases__[0].__name__.__len__() for UserDict, UserList, UserString"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: user_base_name_len

  columns: [id, function, args, expected]
  rows:
    - [UserDict,   "UserDict.__bases__[0].__name__.__len__",   [], 14]
    - [UserList,   "UserList.__bases__[0].__name__.__len__",   [], 15]
    - [UserString, "UserString.__bases__[0].__name__.__len__", [], 8]

# ---------------------------------------------------------------------------
# collections.__all__.__len__() == 9 — standalone (extra34 namespace)
#
# The collections module exports exactly nine public names via __all__:
# ChainMap, Counter, OrderedDict, UserDict, UserList, UserString, defaultdict,
# deque, and namedtuple. This count has been stable since Python 3.3.
# No prior collections spec records this standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra34.all_len:
  description: "len(collections.__all__) == 9 — nine public names exported by the collections module"
  category: module_attrs
  kind: python_call_eq
  function: collections.__all__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# collections.__all__.__class__.__name__.__len__() == 4 — standalone
# (extra34 namespace)
#
# collections.__all__ is a plain Python list, so __class__.__name__ == 'list'
# (4 characters). No prior collections spec records this standalone in the
# extra34 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra34.all_class_name_len:
  description: "len(collections.__all__.__class__.__name__) == 4 — __all__ is a list"
  category: module_attrs
  kind: python_call_eq
  function: collections.__all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# OrderedDict.__reversed__.__qualname__.__len__() == 24 — standalone
# (extra34 namespace)
#
# 'OrderedDict.__reversed__' has 24 characters, making it the longest method
# qualname in the OrderedDict family and the longest dunder method qualname
# among core collection classes covered in this spec series. __reversed__
# enables reversed() iteration over an OrderedDict in O(1) per step.
# No prior collections spec records this standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra34.OrderedDict.reversed.qualname_len:
  description: "len(collections.OrderedDict.__reversed__.__qualname__) == 24 — longest OrderedDict dunder method qualname"
  category: method_qualname_lengths
  kind: python_call_eq
  function: OrderedDict.__reversed__.__qualname__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# defaultdict.__bases__[0].__name__.__len__() == 4 — standalone
# (extra34 namespace)
#
# defaultdict directly subclasses dict. 'dict' has 4 characters — the same
# as 'list', 'type', etc. defaultdict differs from UserDict in that it is a
# true C-level subclass of dict rather than an ABC-backed wrapper.
# No prior collections spec records this standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra34.defaultdict.base_name_len:
  description: "len(collections.defaultdict.__bases__[0].__name__) == 4 — defaultdict's direct base is 'dict'"
  category: class_hierarchy
  kind: python_call_eq
  function: "defaultdict.__bases__[0].__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# ChainMap.new_child.__qualname__.__len__() == 18 — standalone
# (extra34 namespace)
#
# 'ChainMap.new_child' has 18 characters. new_child(m=None) creates a new
# ChainMap with a fresh map followed by all maps in the current chain,
# enabling scoped updates without modifying the parent maps.
# No prior collections spec records this standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra34.ChainMap.new_child.qualname_len:
  description: "len(collections.ChainMap.new_child.__qualname__) == 18 — 'ChainMap.new_child' is 18 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: ChainMap.new_child.__qualname__.__len__
  args: []
  expected: 18
