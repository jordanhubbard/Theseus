spec: kebab_case
version: ">=2.0.0"
backend: node(kebab-case)

docs: https://github.com/sindresorhus/kebab-case#readme

provenance:
  derived_from:
    - "kebab-case README — https://github.com/sindresorhus/kebab-case#readme"
    - "Test vectors verified with kebab-case via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "kebab-case source"
  notes:
    - "Convert camelCase / PascalCase to kebab-case — preserves embedded hyphens, splits on case boundaries."
    - "Install: npm install kebab-case"
    - "v2 CJS with default export."
    - "Note: this implementation prepends a leading dash for PascalCase input ('HelloWorld' → '-hello-world'); spaces and underscores pass through unchanged."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant kebab_case.camelCase_to_kebab:
  description: "kebabCase('helloWorld') is 'hello-world'"
  category: convert
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["helloWorld"]
  chain: []
  expected: "hello-world"

invariant kebab_case.PascalCase_with_leading_dash:
  description: "kebabCase('HelloWorld') is '-hello-world' (leading capital prepends dash)"
  category: convert
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["HelloWorld"]
  chain: []
  expected: "-hello-world"

invariant kebab_case.already_kebab_passthrough:
  description: "kebabCase('already-kebab') is unchanged"
  category: convert
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["already-kebab"]
  chain: []
  expected: "already-kebab"

invariant kebab_case.spaces_unchanged:
  description: "Spaces are NOT converted (only case boundaries)"
  category: convert
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello world"]
  chain: []
  expected: "hello world"

invariant kebab_case.underscores_unchanged:
  description: "Underscores are NOT converted"
  category: convert
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello_world"]
  chain: []
  expected: "hello_world"

invariant kebab_case.acronym_each_letter_separated:
  description: "Acronym 'HTTPRequest' splits each capital → '-h-t-t-p-request'"
  category: convert
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["HTTPRequest"]
  chain: []
  expected: "-h-t-t-p-request"

invariant kebab_case.empty_string:
  description: "kebabCase('') is ''"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [""]
  chain: []
  expected: ""

invariant kebab_case.single_lowercase_letter:
  description: "kebabCase('a') is 'a'"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["a"]
  chain: []
  expected: "a"
