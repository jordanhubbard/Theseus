spec: methods
version: ">=1.0.0"
backend: node(methods)

docs: https://github.com/jshttp/methods#readme

provenance:
  derived_from:
    - "methods README — https://github.com/jshttp/methods#readme"
    - "Test vectors verified with methods@1.1.2 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "methods source: index.js (MIT; source inspection permitted)"
  not_derived_from: []
  notes:
    - "methods exports an array of HTTP method name strings, all in lowercase."
    - "The array contains 35 entries including standard (GET, POST, PUT, DELETE, PATCH, HEAD, OPTIONS) and extended methods (PROPFIND, LOCK, MOVE, etc.)."
    - "All entries are lowercase: 'get', 'post', etc. Uppercase variants are NOT in the array."
    - "The array includes WebDAV methods: lock, unlock, propfind, proppatch, mkcol, copy, move, report."
    - "The array includes exotic methods: acl, bind, rebind, unbind, link, unlink, purge, query, source, search, subscribe, unsubscribe, notify."
    - "Alphabetically, 'acl' is the first entry; 'unsubscribe' is the last."
    - "Since methods is an array (not a function), invariants call array prototype methods: includes, indexOf."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Array method calls do not throw. node exits 0 for all invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# methods.includes(name) — membership test (all lowercase)
# ---------------------------------------------------------------------------

table methods.includes:
  kind: node_module_call_eq
  function: includes
  id_prefix: inc

  columns: [id, category, args, expected]
  rows:
    - [get,         standard,  ["get"],         true]
    - [post,        standard,  ["post"],        true]
    - [put,         standard,  ["put"],         true]
    - [delete,      standard,  ["delete"],      true]
    - [patch,       standard,  ["patch"],       true]
    - [head,        standard,  ["head"],        true]
    - [options,     standard,  ["options"],     true]
    - [trace,       standard,  ["trace"],       true]
    - [connect,     standard,  ["connect"],     true]
    - [upper_GET,   case,      ["GET"],         false]
    - [upper_POST,  case,      ["POST"],        false]
    - [invalid,     invalid,   ["invalid"],     false]

# ---------------------------------------------------------------------------
# methods.indexOf(name) — position in array
# ---------------------------------------------------------------------------

table methods.indexOf:
  kind: node_module_call_eq
  function: indexOf
  id_prefix: idx

  columns: [id, category, args, expected]
  rows:
    - [get,       present, ["get"],     6]
    - [post,      present, ["post"],    19]
    - [acl,       present, ["acl"],     0]
    - [missing,   absent,  ["INVALID"], -1]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-15T19:44:16Z
  iterations: 1
  pass_count: 16
  fail_count: 0
  total_invariants: 16
  notes: Synthesis succeeded in 1 iteration(s). 16 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
