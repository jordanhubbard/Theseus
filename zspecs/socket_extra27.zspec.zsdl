spec: socket_extra27
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra26.zspec.zsdl — covers socket.timeout/__bases__[0].__name__, socket.herror/__bases__[0].__name__, socket.gaierror/__bases__[0].__name__, socket.socket.__init__.__name__, socket.inet_aton/__name__/__module__, socket.inet_ntoa/__name__."
    - "socket_extra25.zspec.zsdl — covers socket.error/__module__, socket.timeout/__module__, socket.gaierror/__module__, socket.herror/__module__, socket.gethostname/__qualname__/__module__, socket.getfqdn/__qualname__/__module__, socket.getaddrinfo/__qualname__/__module__, socket.create_connection/__qualname__/__module__."
  notes:
    - "This spec extends socket_extra26.zspec.zsdl."
    - "Prior specs covered: socket.__name__/__package__, socket.socket/__name__/__module__/__qualname__/__bases__[0].__name__/__init__.__name__, error/timeout/herror/gaierror __name__/__module__/__bases__[0].__name__, AF_INET/AF_INET6/AF_UNIX values, SOCK_STREAM/SOCK_DGRAM values, IPPROTO_TCP/IPPROTO_UDP, gethostname/getfqdn/__name__/__module__, inet_aton/inet_ntoa/__name__/__module__."
    - "This spec covers: __module__.__len__() for socket.socket/error/timeout/herror/gaierror; __name__.__len__() for socket.socket/error; __qualname__ for gethostname/getfqdn/inet_aton/inet_ntoa; __module__.__len__() for gethostname."
    - "socket.socket.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins' — len 8. socket.error is OSError which is defined in builtins. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins' — len 8. socket.timeout is TimeoutError which is defined in builtins. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__name__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError' — len 7. socket.error is an alias for OSError. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__ == 'gethostname' — C-extension function; __qualname__ equals __name__ for C builtins. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__qualname__ == 'getfqdn' — pure-Python function in socket module. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.inet_aton.__qualname__ == 'inet_aton' — C-extension function from _socket. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.inet_ntoa.__qualname__ == 'inet_ntoa' — C-extension function from _socket. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket' — len 7. C-extension function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for socket.socket, error, timeout, herror, gaierror
#
# socket_extra25 covers __module__.__eq__ for error/timeout (== 'builtins')
# and herror/gaierror (== 'socket'). No prior spec checks __module__.__len__()
# for any of these. socket.socket.__module__ == 'socket' (len 6).
# socket.error/timeout.__module__ == 'builtins' (len 8).
# socket.herror/gaierror.__module__ == 'socket' (len 6).
# ---------------------------------------------------------------------------

invariant socket_extra27.socket_class.module_len:
  description: "len(socket.socket.__module__) == 6 — len('socket') == 6; socket.socket is defined in the socket module"
  category: class_module
  kind: python_call_eq
  function: socket.__module__.__len__
  args: []
  expected: 6

table socket_extra27.exception_module_lengths:
  description: "len(__module__) for socket.error/timeout (8, 'builtins') and herror/gaierror (6, 'socket')"
  kind: python_call_eq
  category: class_module
  id_prefix: eml27

  columns: [id, function, args, expected]
  rows:
    - [error,    error.__module__.__len__,    [], 8]
    - [timeout,  timeout.__module__.__len__,  [], 8]
    - [herror,   herror.__module__.__len__,   [], 6]
    - [gaierror, gaierror.__module__.__len__, [], 6]

# ---------------------------------------------------------------------------
# __name__.__len__() for socket.socket and socket.error
#
# socket.socket.__name__ == 'socket' (len 6).
# socket.error.__name__ == 'OSError' (len 7) — socket.error is an alias for OSError.
# No prior spec checks __name__.__len__() for either.
# ---------------------------------------------------------------------------

invariant socket_extra27.socket_class.name_len:
  description: "len(socket.socket.__name__) == 6 — len('socket') == 6"
  category: class_names
  kind: python_call_eq
  function: socket.__name__.__len__
  args: []
  expected: 6

invariant socket_extra27.error.name_len:
  description: "len(socket.error.__name__) == 7 — len('OSError') == 7; socket.error is an alias for OSError"
  category: class_names
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __qualname__ for gethostname, getfqdn, inet_aton, inet_ntoa
#
# socket_extra25 covers __qualname__.__eq__ for gethostname and getfqdn.
# socket_extra26 covers inet_aton.__name__ and inet_ntoa.__name__.
# No prior spec checks __qualname__ as a standalone attribute lookup for these
# four functions (rather than calling __qualname__.__eq__).
# For module-level functions __qualname__ == __name__ == the function name.
# gethostname.__qualname__ == 'gethostname'; getfqdn.__qualname__ == 'getfqdn';
# inet_aton.__qualname__ == 'inet_aton'; inet_ntoa.__qualname__ == 'inet_ntoa'.
# ---------------------------------------------------------------------------

table socket_extra27.function_qualnames:
  description: "__qualname__.__eq__ for gethostname/getfqdn/inet_aton/inet_ntoa — standalone cross-namespace anchor from extra27"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fq27

  columns: [id, function, args, expected]
  rows:
    - [gethostname, gethostname.__qualname__.__eq__, ["gethostname"], true]
    - [getfqdn,     getfqdn.__qualname__.__eq__,     ["getfqdn"],     true]
    - [inet_aton,   inet_aton.__qualname__.__eq__,   ["inet_aton"],   true]
    - [inet_ntoa,   inet_ntoa.__qualname__.__eq__,   ["inet_ntoa"],   true]

# ---------------------------------------------------------------------------
# socket.gethostname.__module__.__len__()
#
# socket_extra25 covers gethostname.__module__.__eq__ == '_socket'.
# No prior spec checks gethostname.__module__.__len__().
# gethostname.__module__ == '_socket' (len 7, note the leading underscore).
# ---------------------------------------------------------------------------

invariant socket_extra27.gethostname.module_len:
  description: "len(socket.gethostname.__module__) == 7 — len('_socket') == 7 (leading underscore for C-extension module)"
  category: function_module
  kind: python_call_eq
  function: gethostname.__module__.__len__
  args: []
  expected: 7
