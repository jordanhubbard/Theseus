spec: string_natural_compare
version: ">=3.0.1"
backend: node(string-natural-compare)

docs: https://www.npmjs.com/package/string-natural-compare

provenance:
  derived_from:
    - "string-natural-compare README — https://www.npmjs.com/package/string-natural-compare"
    - "Test vectors verified with string-natural-compare via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "string-natural-compare source"
  notes:
    - "string-natural-compare is an npm package. Install: npm install string-natural-compare"
    - "Natural order string comparison: numeric substrings are sorted numerically."
    - "Returns negative if a < b, positive if a > b, 0 if equal."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_natural_compare.compare:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: snc

  columns: [id, args, expected]
  rows:
    - [a1_lt_a2,   ["a1", "a2"],   -1]
    - [a10_gt_a9,  ["a10", "a9"],  1]
    - [b_gt_a,     ["b", "a"],     1]
    - [equal,      ["a", "a"],     0]
