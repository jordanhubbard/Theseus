spec: asyncio_extra88
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra87

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra87.zspec.zsdl."
    - "This spec covers: wave 248 theme — asyncio Task, Future, and Queue __dict__ membership. NEW in extra88: Task.__dict__.__contains__('cancel')==True; Task.__dict__.__contains__('done')==True; Task.__dict__.__contains__('result')==True; Task.__dict__.__contains__('exception')==True; Task.__dict__.__contains__('add_done_callback')==True; Queue.__dict__.__contains__('put')==True; Queue.__dict__.__contains__('get')==True; Queue.__dict__.__contains__('put_nowait')==True; Queue.__dict__.__contains__('get_nowait')==True; Queue.__dict__.__contains__('join')==True; Queue.__dict__.__contains__('task_done')==True; Future.__dict__.__contains__('set_result')==True; Future.__dict__.__contains__('set_exception')==True; Future.__dict__.__contains__('cancel')==True. Note: Task is implemented in C in Python 3.12+; its methods live in Task.__dict__ even for C implementations. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('cancel') == True. Task is implemented in C (_asyncio module) in Python 3.12+; cancel is present in Task.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('done') == True. done is present in Task.__dict__ even for C implementation. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('result') == True. result is present in Task.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('exception') == True. exception is present in Task.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('add_done_callback') == True. add_done_callback is present in Task.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('put') == True. put is defined directly on Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('get') == True. get is defined directly on Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('put_nowait') == True. put_nowait is defined directly on Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('get_nowait') == True. get_nowait is defined directly on Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('join') == True. join is defined directly on Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__dict__.__contains__('task_done') == True. task_done is defined directly on Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__dict__.__contains__('set_result') == True. set_result is present in Future.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__dict__.__contains__('set_exception') == True. set_exception is present in Future.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__dict__.__contains__('cancel') == True. cancel is present in Future.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

