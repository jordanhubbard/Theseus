# ---------------------------------------------------------------------------
# Standalone invariants — extra88
# ---------------------------------------------------------------------------

invariant asyncio_extra88.Task_has_cancel:
  description: "asyncio.Task.__dict__.__contains__('cancel') returns True — cancel is present in Task.__dict__ even though Task is implemented in C (_asyncio module) in Python 3.12+; NEW in extra88: first standalone __dict__.__contains__ invariant for Task.cancel in asynciotaskdict88 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__dict__.__contains__
  args: ["cancel"]
  expected: true

invariant asyncio_extra88.Task_has_result:
  description: "asyncio.Task.__dict__.__contains__('result') returns True — result is present in Task.__dict__; Task inherits from Future but overrides result to check for cancellation; NEW in extra88: first standalone __dict__.__contains__ invariant for Task.result in asynciotaskdict88 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__dict__.__contains__
  args: ["result"]
  expected: true

invariant asyncio_extra88.Queue_has_join:
  description: "asyncio.Queue.__dict__.__contains__('join') returns True — join is a coroutine method defined directly on Queue that blocks until all items are processed; NEW in extra88: first standalone __dict__.__contains__ invariant for Queue.join in asynciotaskdict88 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__dict__.__contains__
  args: ["join"]
  expected: true

invariant asyncio_extra88.Future_has_set_result:
  description: "asyncio.Future.__dict__.__contains__('set_result') returns True — set_result is present in Future.__dict__; it sets the result of the future, making it resolved; NEW in extra88: first standalone __dict__.__contains__ invariant for Future.set_result in asynciotaskdict88 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["set_result"]
  expected: true

invariant asyncio_extra88.Future_has_set_exception:
  description: "asyncio.Future.__dict__.__contains__('set_exception') returns True — set_exception is present in Future.__dict__; it sets an exception on the future, making it resolved in an error state; NEW in extra88: first standalone __dict__.__contains__ invariant for Future.set_exception in asynciotaskdict88 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["set_exception"]
  expected: true
