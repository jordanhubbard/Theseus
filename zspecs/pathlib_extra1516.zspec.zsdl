spec: pathlib_extra1516
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "os.path source code"
  notes:
    - "Wave 548 (_extra1516): arithmetic/numeric operator __dict__ presence checks for pathlib module classes."
    - "pathlib.PurePath defines __truediv__ and __rtruediv__ in its own __dict__ for path joining via the / operator (e.g., PurePath('/usr') / 'local' == PurePath('/usr/local'))."
    - "pathlib.PurePath does NOT define __add__, __mul__, __sub__, __floordiv__, __mod__, or __pow__ — only the division-style path-joining operators are defined."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath inherit __truediv__ and __rtruediv__ from PurePath; neither defines these operators in its own __dict__."
    - "pathlib.Path inherits __truediv__ and __rtruediv__ from PurePath; Path.__dict__ does not contain these operators."
    - "The / operator on PurePath performs path joining, not numeric division: PurePath('/usr') / 'local' / 'bin' navigates the directory hierarchy."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1516.purepath_truediv_ops:
  description: "pathlib.PurePath __truediv__ and __rtruediv__ presence — PurePath defines both path-joining division operators in its own __dict__; all other arithmetic operators (__add__, __mul__, __sub__, __floordiv__, __mod__, __pow__) are absent; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: pl1516pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1516pp001,
       pathlib.PurePath.__dict__.__contains__,
       ["__truediv__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__truediv__') == True — pathlib.PurePath defines __truediv__ in its own __dict__ to implement the path-joining / operator; PurePath('/usr') / 'local' returns PurePath('/usr/local'); __truediv__ is unique among arithmetic operators on PurePath — it is the only forward arithmetic operator defined; contrast with __add__, __mul__, __sub__, __floordiv__, __mod__, __pow__ which are all absent; verified with Python 3.14.3"]
    - [pl1516pp002,
       pathlib.PurePath.__dict__.__contains__,
       ["__rtruediv__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__rtruediv__') == True — pathlib.PurePath defines __rtruediv__ in its own __dict__ to support reversed path joining; 'base' / PurePath('sub') uses __rtruediv__; both __truediv__ and __rtruediv__ are defined on PurePath making it the only pathlib class to define arithmetic-style operators directly; verified with Python 3.14.3"]
    - [pl1516pp003,
       pathlib.PurePath.__dict__.__contains__,
       ["__add__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__add__') == False — pathlib.PurePath does not implement __add__; path concatenation via + is not supported; only the / operator (__truediv__) and its reflected form (__rtruediv__) are defined for path arithmetic; __add__ and __radd__ are both absent; verified with Python 3.14.3"]
    - [pl1516pp004,
       pathlib.PurePath.__dict__.__contains__,
       ["__mul__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__mul__') == False — pathlib.PurePath does not implement __mul__; path multiplication has no defined semantics; of the seven arithmetic operators (__add__, __sub__, __mul__, __truediv__, __floordiv__, __mod__, __pow__), only __truediv__ and __rtruediv__ are defined on PurePath; verified with Python 3.14.3"]
    - [pl1516pp005,
       pathlib.PurePath.__dict__.__contains__,
       ["__sub__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__sub__') == False — pathlib.PurePath does not implement __sub__; path subtraction is not defined; use PurePath.relative_to() for computing relative paths, which is a method call rather than a subtraction operator; verified with Python 3.14.3"]
    - [pl1516pp006,
       pathlib.PurePath.__dict__.__contains__,
       ["__floordiv__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__floordiv__') == False — pathlib.PurePath does not implement __floordiv__; floor division is absent from PurePath.__dict__; only true division (__truediv__) has a defined meaning for paths (path joining), not floor division; verified with Python 3.14.3"]
    - [pl1516pp007,
       pathlib.PurePath.__dict__.__contains__,
       ["__mod__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__mod__') == False — pathlib.PurePath does not implement __mod__; modulo is absent from PurePath.__dict__; the only arithmetic operator defined on PurePath is __truediv__ (and __rtruediv__) for path joining; verified with Python 3.14.3"]
    - [pl1516pp008,
       pathlib.PurePath.__dict__.__contains__,
       ["__pow__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__pow__') == False — pathlib.PurePath does not implement __pow__; exponentiation is absent from PurePath.__dict__; the complete set of absent arithmetic operators from PurePath: __add__, __radd__, __mul__, __rmul__, __sub__, __rsub__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__; only __truediv__ and __rtruediv__ are defined; verified with Python 3.14.3"]
    - [pl1516pp009,
       pathlib.PurePath.__dict__.__contains__,
       ["name"],
       true,
       "pathlib.PurePath.__dict__.__contains__('name') == True — positive anchor: PurePath defines 'name' as a property in its own __dict__; path component properties (name, parent, suffix, stem, parts) are defined alongside the __truediv__ path-joining operator; verified with Python 3.14.3"]

table pathlib_extra1516.subclass_truediv_inheritance:
  description: "pathlib.PurePosixPath and PureWindowsPath do NOT define __truediv__ in their own __dict__ — they inherit it from PurePath; pathlib.Path also inherits __truediv__ from PurePath without defining it in its own __dict__; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: pl1516sc
  columns: [id, function, args, expected, description]
  rows:
    - [pl1516sc001,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__truediv__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__truediv__') == False — pathlib.PurePosixPath does NOT define __truediv__ in its own __dict__; PurePosixPath inherits path joining from PurePath.__truediv__; PurePosixPath's own __dict__ is minimal (module, doc, slots metadata) and contains no arithmetic operators; verified with Python 3.14.3"]
    - [pl1516sc002,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__rtruediv__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__rtruediv__') == False — pathlib.PurePosixPath does NOT define __rtruediv__ in its own __dict__; PurePosixPath inherits the reflected path joining from PurePath.__rtruediv__; neither __truediv__ nor __rtruediv__ is re-defined by PurePosixPath; verified with Python 3.14.3"]
    - [pl1516sc003,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__truediv__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__truediv__') == False — pathlib.PureWindowsPath does NOT define __truediv__ in its own __dict__; PureWindowsPath inherits path joining from PurePath.__truediv__; PureWindowsPath's own __dict__ is minimal with no arithmetic operators; verified with Python 3.14.3"]
    - [pl1516sc004,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__rtruediv__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__rtruediv__') == False — pathlib.PureWindowsPath does NOT define __rtruediv__ in its own __dict__; PureWindowsPath inherits reflected path joining from PurePath; neither platform-specific pure path subclass re-defines the path joining operators; verified with Python 3.14.3"]
    - [pl1516sc005,
       pathlib.Path.__dict__.__contains__,
       ["__truediv__"],
       false,
       "pathlib.Path.__dict__.__contains__('__truediv__') == False — pathlib.Path does NOT define __truediv__ in its own __dict__; Path inherits path joining from PurePath.__truediv__; Path adds file system methods (open, exists, stat, mkdir, etc.) but does not re-define the division operator; verified with Python 3.14.3"]
    - [pl1516sc006,
       pathlib.Path.__dict__.__contains__,
       ["__rtruediv__"],
       false,
       "pathlib.Path.__dict__.__contains__('__rtruediv__') == False — pathlib.Path does NOT define __rtruediv__ in its own __dict__; Path inherits reflected path joining from PurePath; both __truediv__ and __rtruediv__ are defined solely in PurePath.__dict__ — the single point of definition for path-joining arithmetic in the entire pathlib hierarchy; verified with Python 3.14.3"]
    - [pl1516sc007,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__add__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__add__') == False — PurePosixPath does not define __add__ in its own __dict__ and does not inherit it from PurePath either; __add__ is absent from the entire pathlib class hierarchy; path concatenation via + is not supported anywhere in pathlib; verified with Python 3.14.3"]
    - [pl1516sc008,
       pathlib.Path.__dict__.__contains__,
       ["open"],
       true,
       "pathlib.Path.__dict__.__contains__('open') == True — positive anchor: pathlib.Path defines 'open' in its own __dict__; Path.open() returns a sync file object; file system I/O methods (open, exists, stat, mkdir) are defined in Path's own __dict__ while arithmetic operators are inherited (only __truediv__/__rtruediv__ from PurePath) or entirely absent; verified with Python 3.14.3"]
    - [pl1516sc009,
       pathlib.Path.__dict__.__contains__,
       ["__mul__"],
       false,
       "pathlib.Path.__dict__.__contains__('__mul__') == False — pathlib.Path does not implement __mul__ in its own __dict__; multiplication is not defined anywhere in the pathlib hierarchy; PurePath defines __truediv__ and __rtruediv__ for path joining only — no other arithmetic operators appear anywhere in pathlib (PurePath, PurePosixPath, PureWindowsPath, or Path); verified with Python 3.14.3"]

table pathlib_extra1516.purepath_arithmetic_summary:
  description: "Comprehensive arithmetic operator presence/absence summary for pathlib.PurePath — __truediv__ and __rtruediv__ are the only arithmetic operators defined; all others absent; also verifies path properties present; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: pl1516sm
  columns: [id, function, args, expected, description]
  rows:
    - [pl1516sm001,
       pathlib.PurePath.__dict__.__contains__,
       ["__truediv__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__truediv__') == True — summary confirmation: __truediv__ IS defined in PurePath.__dict__; this is the / operator for path joining; PurePath('/a') / 'b' == PurePath('/a/b'); __truediv__ is one of exactly two arithmetic-style operators defined in PurePath.__dict__; verified with Python 3.14.3"]
    - [pl1516sm002,
       pathlib.PurePath.__dict__.__contains__,
       ["__rtruediv__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__rtruediv__') == True — summary confirmation: __rtruediv__ IS defined in PurePath.__dict__; this is the reflected / operator; 'str_base' / PurePath('sub') dispatches to __rtruediv__; exactly two arithmetic-style operators (__truediv__ and __rtruediv__) are defined in PurePath; verified with Python 3.14.3"]
    - [pl1516sm003,
       pathlib.PurePath.__dict__.__contains__,
       ["__radd__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__radd__') == False — pathlib.PurePath does not implement __radd__; reflected addition is absent; the full set of absent arithmetic operators: __add__, __radd__, __mul__, __rmul__, __sub__, __rsub__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__; only __truediv__ and __rtruediv__ are defined; verified with Python 3.14.3"]
    - [pl1516sm004,
       pathlib.PurePath.__dict__.__contains__,
       ["__rmul__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__rmul__') == False — pathlib.PurePath does not implement __rmul__; reflected multiplication is absent; PurePath is not a numeric type and supports only path-joining via __truediv__/__rtruediv__; verified with Python 3.14.3"]
    - [pl1516sm005,
       pathlib.PurePath.__dict__.__contains__,
       ["__rsub__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__rsub__') == False — pathlib.PurePath does not implement __rsub__; reflected subtraction is absent from PurePath.__dict__; path relative computation uses PurePath.relative_to(), not the subtraction operator; verified with Python 3.14.3"]
    - [pl1516sm006,
       pathlib.PurePath.__dict__.__contains__,
       ["suffix"],
       true,
       "pathlib.PurePath.__dict__.__contains__('suffix') == True — positive anchor: PurePath defines 'suffix' as a property in its own __dict__; PurePath('file.tar.gz').suffix == '.gz'; path component properties (name, parent, suffix, stem, parts, drive, root, anchor) coexist with the __truediv__ path-joining operator in PurePath.__dict__; verified with Python 3.14.3"]
    - [pl1516sm007,
       pathlib.PurePath.__dict__.__contains__,
       ["__rfloordiv__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__rfloordiv__') == False — pathlib.PurePath does not implement __rfloordiv__; reflected floor division is absent; only true division operators (__truediv__ and __rtruediv__) are defined — floor division has no path-joining semantics and is absent; verified with Python 3.14.3"]
    - [pl1516sm008,
       pathlib.PurePath.__dict__.__contains__,
       ["__rmod__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__rmod__') == False — pathlib.PurePath does not implement __rmod__; reflected modulo is absent from PurePath.__dict__; the twelve arithmetic operators absent from PurePath: __add__, __radd__, __sub__, __rsub__, __mul__, __rmul__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__; the two arithmetic operators present: __truediv__, __rtruediv__; verified with Python 3.14.3"]
    - [pl1516sm009,
       pathlib.PurePath.__dict__.__contains__,
       ["joinpath"],
       true,
       "pathlib.PurePath.__dict__.__contains__('joinpath') == True — positive anchor: PurePath defines 'joinpath' in its own __dict__; joinpath is the method equivalent of the / operator: PurePath('/a').joinpath('b', 'c') == PurePath('/a/b/c'); both __truediv__ (operator form) and joinpath (method form) are defined for path joining; verified with Python 3.14.3"]
