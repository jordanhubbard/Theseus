spec: it2986
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (it2986): __len__, __length_hint__, __contains__ dict-presence checks for itertools types."
    - "itertools types are lazy iterator classes — none define __len__ or __contains__ in their own __dict__."
    - "itertools.repeat defines __length_hint__ (returns the remaining count when maxlen is set); all others return false."
    - "Verified types: itertools.chain, itertools.cycle, itertools.count, itertools.islice, itertools.product, itertools.permutations, itertools.combinations, itertools.groupby, itertools.starmap, itertools.zip_longest, itertools.takewhile, itertools.dropwhile, itertools.filterfalse, itertools.compress, itertools.accumulate, itertools.repeat, itertools.combinations_with_replacement, itertools.pairwise."
    - "itertools.pairwise requires Python >= 3.10."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table it2986.len:
  description: "itertools types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2986
  columns: [id, function, args, expected]
  rows:
    - ["it2986001", operator.contains, [itertools.chain.__dict__,                        "__len__"], false]
    - ["it2986002", operator.contains, [itertools.cycle.__dict__,                        "__len__"], false]
    - ["it2986003", operator.contains, [itertools.count.__dict__,                        "__len__"], false]
