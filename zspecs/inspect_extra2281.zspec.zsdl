  category: mro_depth
  id_prefix: in2281

  columns: [id, function, args, expected]
  rows:
    - ["in2281009", "inspect.BoundArguments.__mro__.__len__", [], 2]
    - ["in2281010", "inspect.BoundArguments.__bases__.__len__", [], 1]
    - ["in2281011", "inspect.BoundArguments.__dict__.__len__", [], 18]
    - ["in2281012", "inspect.BoundArguments.__dict__.__contains__", ["__flags__"], false]

