spec: inspect_extra2281
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size, __flags__ dict-presence."
    - "Subjects: inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FullArgSpec, inspect.ArgInfo, inspect.FrameInfo, inspect.BlockFinder, inspect.EndOfBlock."
    - "inspect.ArgSpec was removed in Python 3.11; not included."
    - "inspect.Parameter: __mro__.__len__ == 2, __bases__.__len__ == 1, __dict__.__len__ == 29."
    - "inspect.Signature: __mro__.__len__ == 2, __bases__.__len__ == 1, __dict__.__len__ == 27."
    - "inspect.BoundArguments: __mro__.__len__ == 2, __bases__.__len__ == 1, __dict__.__len__ == 18."
    - "inspect.FullArgSpec: namedtuple subclass; __mro__.__len__ == 3 (FullArgSpec -> tuple -> object), __bases__.__len__ == 1, __dict__.__len__ == 20."
    - "inspect.ArgInfo: namedtuple subclass; __mro__.__len__ == 3 (ArgInfo -> tuple -> object), __bases__.__len__ == 1, __dict__.__len__ == 17."
    - "inspect.FrameInfo: __mro__.__len__ == 4 (FrameInfo -> _FrameInfo -> tuple -> object), __bases__.__len__ == 1, __dict__.__len__ == 7."
    - "inspect.BlockFinder: __mro__.__len__ == 2, __bases__.__len__ == 1, __dict__.__len__ == 8."
    - "inspect.EndOfBlock: exception subclass; __mro__.__len__ == 4 (EndOfBlock -> Exception -> BaseException -> object), __bases__.__len__ == 1, __dict__.__len__ == 5."
    - "__flags__ is not present in any of these types' __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2281.parameter_signature_mro:
  description: "inspect.Parameter and inspect.Signature MRO depth, base count, dict size, and __flags__ dict-presence"
  kind: python_call_eq
  category: mro_depth
  id_prefix: in2281

  columns: [id, function, args, expected]
  rows:
    - ["in2281001", "inspect.Parameter.__mro__.__len__", [], 2]
    - ["in2281002", "inspect.Parameter.__bases__.__len__", [], 1]
    - ["in2281003", "inspect.Parameter.__dict__.__len__", [], 29]
    - ["in2281004", "inspect.Parameter.__dict__.__contains__", ["__flags__"], false]
    - ["in2281005", "inspect.Signature.__mro__.__len__", [], 2]
    - ["in2281006", "inspect.Signature.__bases__.__len__", [], 1]
    - ["in2281007", "inspect.Signature.__dict__.__len__", [], 27]
    - ["in2281008", "inspect.Signature.__dict__.__contains__", ["__flags__"], false]

table inspect_extra2281.bound_arguments_mro:
  description: "inspect.BoundArguments MRO depth, base count, dict size, and __flags__ dict-presence"
