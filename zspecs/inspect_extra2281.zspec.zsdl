    - ["in2281015", "inspect.FullArgSpec.__dict__.__len__", [], 20]
    - ["in2281016", "inspect.FullArgSpec.__dict__.__contains__", ["__flags__"], false]
    - ["in2281017", "inspect.ArgInfo.__mro__.__len__", [], 3]
