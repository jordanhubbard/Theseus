spec: decimal_extra69
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra68."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context.__name__/__module__/__dict__.__class__.__name__."
    - "decimal_extra68 covers Decimal C slot wrappers (__add__/__mul__/__str__/__repr__); Decimal/__dict__ membership; Context class identity."
    - "This spec covers: Context method identity — Context.__dict__ contains quantize and clear_flags; decimal exception MRO depths for DecimalException/InvalidOperation/Overflow; exception class __name__ identity for Clamped/Inexact/Rounded/Subnormal."
    - "decimal.Context.__dict__.__contains__('quantize') == True — Context has quantize as a C method."
    - "decimal.Context.__dict__.__contains__('clear_flags') == True — Context has clear_flags as a C method."
    - "decimal.DecimalException.__mro__.__len__() == 5 — MRO: [DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.InvalidOperation.__mro__.__len__() == 6 — MRO: [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Overflow.__mro__.__len__() == 8 — MRO: [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Clamped.__name__ == 'Clamped'."
    - "decimal.Clamped.__module__ == 'decimal'."
    - "decimal.Inexact.__name__ == 'Inexact'."
    - "decimal.Rounded.__name__ == 'Rounded'."
    - "decimal.Subnormal.__name__ == 'Subnormal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context.__dict__ method membership — quantize and clear_flags
# Context is the C accelerator arithmetic context type. Both quantize and
# clear_flags are defined as C methods in Context.__dict__.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra69.Context_dict_methods:
  description: "Context.__dict__ contains quantize and clear_flags C methods"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore69

  columns: [id, function, args, expected]
  rows:
    - [has_quantize,    "Context.__dict__.__contains__", ["quantize"],    true]
    - [has_clear_flags, "Context.__dict__.__contains__", ["clear_flags"], true]

# ---------------------------------------------------------------------------
# Decimal exception MRO depth checks
# DecimalException is a direct subclass of ArithmeticError: depth 5.
# InvalidOperation is a direct subclass of DecimalException: depth 6.
# Overflow inherits from Inexact and Rounded (both from DecimalException): depth 8.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra69.exception_mro_depths:
  description: "Decimal exception MRO depths for DecimalException/InvalidOperation/Overflow"
  kind: python_call_eq
  category: class_bases
  id_prefix: decimalmore69

  columns: [id, function, args, expected]
  rows:
    - [decimal_exc_mro,   DecimalException.__mro__.__len__,   [], 5]
    - [invalid_op_mro,    InvalidOperation.__mro__.__len__,   [], 6]
    - [overflow_mro,      Overflow.__mro__.__len__,           [], 8]

# ---------------------------------------------------------------------------
# Exception class __name__ identity — Clamped, Inexact, Rounded, Subnormal
# These are all decimal exception classes with simple __name__ values.
# Clamped.__module__ == 'decimal' confirms C accelerator re-exports them.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra69.exception_names:
  description: "Decimal exception class __name__ and __module__ identity"
  kind: python_call_eq
  category: class_names
  id_prefix: decimalmore69

  columns: [id, function, args, expected]
  rows:
    - [clamped_name,   Clamped.__name__.__eq__,   ["Clamped"],   true]
    - [clamped_module, Clamped.__module__.__eq__,  ["decimal"],   true]
    - [inexact_name,   Inexact.__name__.__eq__,   ["Inexact"],   true]
    - [rounded_name,   Rounded.__name__.__eq__,   ["Rounded"],   true]
    - [subnormal_name, Subnormal.__name__.__eq__, ["Subnormal"], true]

# ---------------------------------------------------------------------------
# Overflow MRO detail and Subnormal MRO length
# Overflow.__mro__.__len__() == 8 reflects multi-inheritance from Inexact and
# Rounded. Subnormal is a simpler case with MRO depth 6.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra69.exception_mro_extra:
  description: "Additional exception MRO depths: Clamped and Subnormal"
  kind: python_call_eq
  category: class_bases
  id_prefix: decimalmore69

  columns: [id, function, args, expected]
  rows:
    - [clamped_mro,   Clamped.__mro__.__len__,   [], 6]
    - [subnormal_mro, Subnormal.__mro__.__len__, [], 6]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra69.Context_dict.has_quantize:
  description: "decimal.Context.__dict__.__contains__('quantize') == True"
  category: class_dict
  kind: python_call_eq
  function: "Context.__dict__.__contains__"
  args: ["quantize"]
  expected: true

invariant decimal_extra69.Context_dict.has_clear_flags:
  description: "decimal.Context.__dict__.__contains__('clear_flags') == True"
  category: class_dict
  kind: python_call_eq
  function: "Context.__dict__.__contains__"
  args: ["clear_flags"]
  expected: true

invariant decimal_extra69.DecimalException.mro_len_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5"
  category: class_bases
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra69.InvalidOperation.mro_len_6:
  description: "decimal.InvalidOperation.__mro__.__len__() == 6"
  category: class_bases
  kind: python_call_eq
  function: InvalidOperation.__mro__.__len__
  args: []
  expected: 6

invariant decimal_extra69.Clamped.name_eq:
  description: "decimal.Clamped.__name__ == 'Clamped'"
  category: class_names
  kind: python_call_eq
  function: Clamped.__name__.__eq__
  args: ["Clamped"]
  expected: true
