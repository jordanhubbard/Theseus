spec: trim_right
version: ">=2.0.0"
backend: node(trim-right)

docs: https://www.npmjs.com/package/trim-right

provenance:
  derived_from:
    - "trim-right README — https://www.npmjs.com/package/trim-right"
    - "Test vectors verified with trim-right via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "trim-right source"
  notes:
    - "trim-right is an npm package. Install: npm install trim-right"
    - "Removes trailing whitespace from a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table trim_right.trim:
  kind: node_module_call_eq
  function: "default"
  category: strings
  id_prefix: trimr

  columns: [id, args, expected]
  rows:
    - [both_sides, ["  hello  "], "  hello"]
    - [left_only,  ["  hello"],   "  hello"]
    - [no_spaces,  ["hello"],     "hello"]
