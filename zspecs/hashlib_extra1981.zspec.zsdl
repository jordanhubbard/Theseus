spec: hashlib_extra1981
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#object.__sizeof__"
    - "https://docs.python.org/3/reference/datamodel.html#object.__length_hint__"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "_hashlib.HASH is the C-extension type returned by hashlib.md5(), hashlib.sha1(), hashlib.sha256(), etc."
    - "_hashlib.HASHXOF is the C-extension type returned by hashlib.shake_128(), hashlib.shake_256()."
    - "hashlib.blake2b and hashlib.blake2s are exposed directly on the hashlib namespace via _blake2."
    - "None of the hashlib hash types define __sizeof__ in their own dict — they use the inherited object.__sizeof__."
    - "None of the hashlib hash types define __length_hint__ — they are not iterators."
    - "None of the hashlib hash types define __floor__, __ceil__, or __trunc__ — they are not numeric types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra1981.sizeof_protocol:
  description: "hashlib hash types __sizeof__ dict-presence checks — none define __sizeof__ in own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1981
  columns: [id, function, args, expected]
  rows:
    - ["hl1981001", "_hashlib.HASH.__dict__.__contains__",    ["__sizeof__"], false]
    - ["hl1981002", "_hashlib.HASHXOF.__dict__.__contains__", ["__sizeof__"], false]
    - ["hl1981003", "hashlib.blake2b.__dict__.__contains__",  ["__sizeof__"], false]
    - ["hl1981004", "hashlib.blake2s.__dict__.__contains__",  ["__sizeof__"], false]

