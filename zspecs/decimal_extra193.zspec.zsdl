    - [lt_qn,  "Decimal.__lt__.__qualname__.__eq__",  ["Decimal.__lt__"],  true, "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (len=14); verified with Python 3.14.3"]
    - [le_qn,  "Decimal.__le__.__qualname__.__eq__",  ["Decimal.__le__"],  true, "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (len=14); verified with Python 3.14.3"]
