# ---------------------------------------------------------------------------
# Standalone invariants — decimalcompare193
# ---------------------------------------------------------------------------

invariant decimal_extra193.Decimal.eq_qualname_eq:
  description: "decimal.Decimal.__eq__.__qualname__.__eq__('Decimal.__eq__') returns True — __eq__ implements the == operator for Decimal; qualname 'Decimal.__eq__' has len=14 ('Decimal.'=8+'__eq__'=6=14); Decimal comparison is exact and follows IEEE 754/IBM GDA semantics; compare: __bool__ qualname='Decimal.__bool__' len=16 (longest); __int__ qualname='Decimal.__int__' len=15; all richcmp qualnames have len=14; NEW in decimal_extra193: first standalone Decimal.__eq__ qualname invariant in decimalcompare193 namespace; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__eq__.__qualname__.__eq__"
  args: ["Decimal.__eq__"]
  expected: true

invariant decimal_extra193.Decimal.lt_qualname_eq:
  description: "decimal.Decimal.__lt__.__qualname__.__eq__('Decimal.__lt__') returns True — __lt__ implements the < operator for Decimal; qualname 'Decimal.__lt__' has len=14; Decimal('1') < Decimal('2') is True; compare NaN: Decimal('NaN') < Decimal('1') raises InvalidOperation; compare: __gt__ qualname='Decimal.__gt__' also len=14; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__lt__.__qualname__.__eq__"
  args: ["Decimal.__lt__"]
  expected: true

invariant decimal_extra193.Decimal.le_qualname_len:
  description: "decimal.Decimal.__le__.__qualname__.__len__() == 14 — 'Decimal.__le__' has 14 chars ('Decimal.'=8+'__le__'=6=14); __le__ implements the <= operator; all six richcmp methods (__eq__, __lt__, __le__, __gt__, __ge__, __ne__) share qualname length 14 since the dunder names all have 6 chars; compare: __int__ len=15, __bool__ len=16; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__le__.__qualname__.__len__"
  args: []
  expected: 14

invariant decimal_extra193.Decimal.gt_qualname_len:
  description: "decimal.Decimal.__gt__.__qualname__.__len__() == 14 — 'Decimal.__gt__' has 14 chars ('Decimal.'=8+'__gt__'=6=14); __gt__ implements the > operator; all six richcmp dunder names have 6 chars so all qualnames have len=14; compare: __ge__ qualname='Decimal.__ge__' also len=14; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__gt__.__qualname__.__len__"
  args: []
  expected: 14

invariant decimal_extra193.Decimal.ge_qualname_eq:
  description: "decimal.Decimal.__ge__.__qualname__.__eq__('Decimal.__ge__') returns True — __ge__ implements the >= operator for Decimal; qualname 'Decimal.__ge__' has len=14; compare: __ne__ qualname='Decimal.__ne__' also len=14; all richcmp methods defined on Decimal class itself (not inherited from object) on Python 3.14.3; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__ge__.__qualname__.__eq__"
  args: ["Decimal.__ge__"]
  expected: true

invariant decimal_extra193.Decimal.ne_qualname_eq:
  description: "decimal.Decimal.__ne__.__qualname__.__eq__('Decimal.__ne__') returns True — __ne__ implements the != operator; qualname 'Decimal.__ne__' has len=14 ('Decimal.'=8+'__ne__'=6=14); on Python 3.14.3 decimal.Decimal defines __ne__ explicitly (not inherited from object's default); compare: all richcmp qualnames have len=14; __bool__ len=16, __int__ len=15; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__ne__.__qualname__.__eq__"
  args: ["Decimal.__ne__"]
  expected: true

invariant decimal_extra193.Decimal.bool_qualname_len:
  description: "decimal.Decimal.__bool__.__qualname__.__len__() == 16 — 'Decimal.__bool__' has 16 chars ('Decimal.'=8+'__bool__'=8=16) — longest method qualname in this spec; __bool__ converts Decimal to bool: Decimal('0') is False, all other finite values and Infinity are True; NaN raises InvalidOperation in boolean context; compare: __int__ qualname='Decimal.__int__' len=15; all richcmp qualnames len=14 (shortest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__bool__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra193.Decimal.int_qualname_len:
  description: "decimal.Decimal.__int__.__qualname__.__len__() == 15 — 'Decimal.__int__' has 15 chars ('Decimal.'=8+'__int__'=7=15); __int__ truncates the decimal towards zero and returns an integer; Decimal('3.7') truncates to 3; compare qualname lengths in spec: richcmp=14, __int__=15, __bool__=16 (longest); compare: __int__ dunder name has 7 chars vs richcmp dunder names which have 6 chars each; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__int__.__qualname__.__len__"
  args: []
  expected: 15

