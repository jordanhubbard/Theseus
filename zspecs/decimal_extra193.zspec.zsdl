spec: decimal_extra193
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal.__str__, is_finite/is_nan/is_infinite/is_zero/is_signed/is_normal, as_tuple, class_name, getcontext"
    - "decimal_extra.zspec.zsdl — covers Decimal predicates, to_eng_string, Context/BasicContext/ExtendedContext/DefaultContext class names, rounding constants"
  notes:
    - "This spec covers decimal.Decimal comparison method qualnames not already in decimal.zspec.zsdl or decimal_extra.zspec.zsdl."
    - "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' — comparison method defined on the Decimal class."
    - "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' — less-than method defined on the Decimal class."
    - "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' — less-than-or-equal method defined on the Decimal class."
    - "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__' — greater-than method defined on the Decimal class."
    - "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__' — greater-than-or-equal method defined on the Decimal class."
    - "decimal.Decimal.__ne__.__qualname__ == 'Decimal.__ne__' — not-equal method defined on the Decimal class."
    - "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__' — bool conversion method defined on the Decimal class."
    - "decimal.Decimal.__int__.__qualname__ == 'Decimal.__int__' — int conversion method defined on the Decimal class."
    - "All qualnames verified: __eq__, __lt__, __le__, __gt__, __ge__, __ne__ have len=14; __bool__ has len=16; __int__ has len=15."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

