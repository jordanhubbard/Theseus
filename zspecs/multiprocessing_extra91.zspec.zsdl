table multiprocessing_extra91.Semaphore_and_Condition_identity:
  description: "multiprocessing Semaphore and Condition factory method identity checks in mpprimitives91 namespace — wave 253 theme: multiprocessing Queue, Pipe, Value, Array function/class identity; Semaphore.__class__.__name__.__eq__('method')==True; Semaphore.__qualname__.__eq__('BaseContext.Semaphore')==True; Semaphore.__code__.co_argcount==2 (takes self and value); Condition.__class__.__name__.__eq__('method')==True; Condition.__qualname__.__eq__('BaseContext.Condition')==True; Condition.__code__.co_argcount==2 (takes self and lock); Queue.__code__.co_argcount==2 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprimitives91c

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_class_name,   "Semaphore.__class__.__name__.__eq__",   ["method"],                  true, "Semaphore.__class__.__name__ == 'method' — Semaphore is a bound method of BaseContext; verified with Python 3.14.3"]
    - [semaphore_qualname,     Semaphore.__qualname__.__eq__,           ["BaseContext.Semaphore"],   true, "Semaphore.__qualname__ == 'BaseContext.Semaphore' — method defined on BaseContext; verified with Python 3.14.3"]
    - [semaphore_co_argcount,  Semaphore.__code__.co_argcount,          [],                          2,    "Semaphore.__code__.co_argcount == 2 — takes self and value; verified with Python 3.14.3"]
    - [condition_class_name,   "Condition.__class__.__name__.__eq__",   ["method"],                  true, "Condition.__class__.__name__ == 'method' — Condition is a bound method of BaseContext; verified with Python 3.14.3"]
    - [condition_qualname,     Condition.__qualname__.__eq__,           ["BaseContext.Condition"],   true, "Condition.__qualname__ == 'BaseContext.Condition' — method defined on BaseContext; verified with Python 3.14.3"]
    - [condition_co_argcount,  Condition.__code__.co_argcount,          [],                          2,    "Condition.__code__.co_argcount == 2 — takes self and lock; verified with Python 3.14.3"]
    - [queue_co_argcount_cross, Queue.__code__.co_argcount,             [],                          2,    "Queue.__code__.co_argcount == 2 — cross-check; takes self and maxsize; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant multiprocessing_extra91.Queue_is_method_not_class:
  description: "multiprocessing.Queue.__class__.__name__.__eq__('method') returns True — multiprocessing.Queue is not a class; it is a bound method of the default multiprocessing context (a BaseContext instance); calling multiprocessing.Queue() invokes BaseContext.Queue() which creates and returns a queue object; this contrasts with threading.Queue which is a class; NEW in extra91: first standalone __class__.__name__ invariant for Queue in mpprimitives91 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Queue.__class__.__name__.__eq__"
  args: ["method"]
  expected: true

invariant multiprocessing_extra91.Queue_qualname_is_BaseContext:
  description: "multiprocessing.Queue.__qualname__.__eq__('BaseContext.Queue') returns True — Queue's __qualname__ reveals that it is defined as a method on BaseContext, not as a standalone function or class; the multiprocessing module exposes it as a top-level name by binding the default context's Queue method; NEW in extra91: first standalone __qualname__ invariant for Queue in mpprimitives91 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__qualname__.__eq__
  args: ["BaseContext.Queue"]
  expected: true

invariant multiprocessing_extra91.Array_co_argcount_three:
  description: "multiprocessing.Array.__code__.co_argcount == 3 — Array.__code__.co_argcount is 3 because Array takes self (the context), typecode_or_type, and size_or_initializer as its three positional parameters; this differs from Queue, Pipe, Value, Lock, RLock, Event which have co_argcount of 1 or 2; NEW in extra91: first standalone co_argcount invariant for Array in mpprimitives91 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Array.__code__.co_argcount
  args: []
  expected: 3

invariant multiprocessing_extra91.Pipe_module_is_context:
  description: "multiprocessing.Pipe.__module__.__eq__('multiprocessing.context') returns True — like Queue, Pipe is a bound method of BaseContext defined in Lib/multiprocessing/context.py; its __module__ is 'multiprocessing.context'; Pipe.__code__.co_argcount==2 (takes self and duplex); NEW in extra91: first standalone __module__ invariant for Pipe in mpprimitives91 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pipe.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra91.Semaphore_co_argcount_two:
  description: "multiprocessing.Semaphore.__code__.co_argcount == 2 — Semaphore takes self (the context) and value (the initial semaphore count) as its two positional parameters; in contrast Lock, RLock, and Event have co_argcount==1 (self only); NEW in extra91: first standalone co_argcount invariant for Semaphore in mpprimitives91 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Semaphore.__code__.co_argcount
  args: []
  expected: 2
