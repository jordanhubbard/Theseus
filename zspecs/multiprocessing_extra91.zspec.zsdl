  description: "multiprocessing Value and Array factory method identity checks in mpprimitives91 namespace — wave 253 theme: multiprocessing Queue, Pipe, Value, Array function/class identity; Value.__class__.__name__.__eq__('method')==True (Value is a bound method of BaseContext); Value.__module__.__eq__('multiprocessing.context')==True; Value.__qualname__.__eq__('BaseContext.Value')==True; Value.__code__.co_argcount==2 (takes self and typecode_or_type); Array.__class__.__name__.__eq__('method')==True; Array.__qualname__.__eq__('BaseContext.Array')==True; Array.__code__.co_argcount==3 (takes self, typecode_or_type, size_or_initializer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprimitives91a

  columns: [id, function, args, expected, description]
  rows:
    - [value_class_name,   "Value.__class__.__name__.__eq__",   ["method"],                  true, "Value.__class__.__name__ == 'method' — Value is a bound method of BaseContext; verified with Python 3.14.3"]
    - [value_module,       Value.__module__.__eq__,             ["multiprocessing.context"], true, "Value.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; verified with Python 3.14.3"]
    - [value_qualname,     Value.__qualname__.__eq__,           ["BaseContext.Value"],       true, "Value.__qualname__ == 'BaseContext.Value' — method defined on BaseContext; verified with Python 3.14.3"]
    - [value_co_argcount,  Value.__code__.co_argcount,          [],                          2,    "Value.__code__.co_argcount == 2 — takes self and typecode_or_type; verified with Python 3.14.3"]
    - [array_class_name,   "Array.__class__.__name__.__eq__",   ["method"],                  true, "Array.__class__.__name__ == 'method' — Array is a bound method of BaseContext; verified with Python 3.14.3"]
    - [array_qualname,     Array.__qualname__.__eq__,           ["BaseContext.Array"],       true, "Array.__qualname__ == 'BaseContext.Array' — method defined on BaseContext; verified with Python 3.14.3"]
    - [array_co_argcount,  Array.__code__.co_argcount,          [],                          3,    "Array.__code__.co_argcount == 3 — takes self, typecode_or_type, size_or_initializer; verified with Python 3.14.3"]

