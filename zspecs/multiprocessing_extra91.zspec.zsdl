table multiprocessing_extra91.Lock_RLock_Event_identity:
  description: "multiprocessing Lock, RLock, Event factory method identity checks in mpprimitives91 namespace — wave 253 theme: multiprocessing Queue, Pipe, Value, Array function/class identity; Lock.__class__.__name__.__eq__('method')==True; Lock.__qualname__.__eq__('BaseContext.Lock')==True; Lock.__code__.co_argcount==1 (takes self only); RLock.__class__.__name__.__eq__('method')==True; RLock.__qualname__.__eq__('BaseContext.RLock')==True; RLock.__code__.co_argcount==1; Event.__class__.__name__.__eq__('method')==True; Event.__qualname__.__eq__('BaseContext.Event')==True; Event.__code__.co_argcount==1; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprimitives91b

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_name,   "Lock.__class__.__name__.__eq__",   ["method"],              true, "Lock.__class__.__name__ == 'method' — Lock is a bound method of BaseContext; verified with Python 3.14.3"]
    - [lock_qualname,     Lock.__qualname__.__eq__,           ["BaseContext.Lock"],    true, "Lock.__qualname__ == 'BaseContext.Lock' — method defined on BaseContext; verified with Python 3.14.3"]
    - [lock_co_argcount,  Lock.__code__.co_argcount,          [],                      1,    "Lock.__code__.co_argcount == 1 — takes self only; verified with Python 3.14.3"]
    - [rlock_class_name,  "RLock.__class__.__name__.__eq__",  ["method"],              true, "RLock.__class__.__name__ == 'method' — RLock is a bound method of BaseContext; verified with Python 3.14.3"]
    - [rlock_qualname,    RLock.__qualname__.__eq__,          ["BaseContext.RLock"],   true, "RLock.__qualname__ == 'BaseContext.RLock' — method defined on BaseContext; verified with Python 3.14.3"]
    - [rlock_co_argcount, RLock.__code__.co_argcount,         [],                      1,    "RLock.__code__.co_argcount == 1 — takes self only; verified with Python 3.14.3"]
    - [event_class_name,  "Event.__class__.__name__.__eq__",  ["method"],              true, "Event.__class__.__name__ == 'method' — Event is a bound method of BaseContext; verified with Python 3.14.3"]
    - [event_qualname,    Event.__qualname__.__eq__,          ["BaseContext.Event"],   true, "Event.__qualname__ == 'BaseContext.Event' — method defined on BaseContext; verified with Python 3.14.3"]
    - [event_co_argcount, Event.__code__.co_argcount,         [],                      1,    "Event.__code__.co_argcount == 1 — takes self only; verified with Python 3.14.3"]

