spec: multiprocessing_extra91
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra90

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Lib/multiprocessing/sharedctypes.py"
  notes:
    - "This spec extends multiprocessing_extra90.zspec.zsdl."
    - "This spec covers: wave 253 theme — multiprocessing Queue, Pipe, Value, Array function/class identity. NEW in extra91: multiprocessing.Queue.__class__.__name__=='method' (Queue is a bound method of BaseContext, not a class); Queue.__module__=='multiprocessing.context'; Queue.__qualname__=='BaseContext.Queue'; Queue.__code__.co_argcount==2; Pipe.__class__.__name__=='method'; Pipe.__qualname__=='BaseContext.Pipe'; Pipe.__code__.co_argcount==2; Value.__class__.__name__=='method'; Value.__qualname__=='BaseContext.Value'; Value.__code__.co_argcount==2; Array.__class__.__name__=='method'; Array.__qualname__=='BaseContext.Array'; Array.__code__.co_argcount==3; Lock.__code__.co_argcount==1; Event.__code__.co_argcount==1; Semaphore.__code__.co_argcount==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue is a bound method of the default BaseContext instance, not a class. Its __class__.__name__ is 'method'. Calling multiprocessing.Queue() creates and returns a queue object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue'. Queue is defined as a method on BaseContext. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue.__code__.co_argcount == 2. Takes self (the context) and maxsize. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe'. Pipe.__code__.co_argcount == 2 (takes self and duplex). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Value.__qualname__ == 'BaseContext.Value'. Value.__code__.co_argcount == 2 (takes self and typecode_or_type). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Array.__qualname__ == 'BaseContext.Array'. Array.__code__.co_argcount == 3 (takes self, typecode_or_type, size_or_initializer). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Lock.__code__.co_argcount == 1 (takes self only). multiprocessing.Event.__code__.co_argcount == 1. multiprocessing.Semaphore.__code__.co_argcount == 2 (takes self and value). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Queue and Pipe factory method identity — extra91
#
# Wave 253 theme: multiprocessing Queue, Pipe, Value, Array function/class identity.
#
# Queue.__class__.__name__ == 'method'  (bound method of BaseContext)
# Queue.__module__ == 'multiprocessing.context'
# Queue.__qualname__ == 'BaseContext.Queue'
# Queue.__code__.co_argcount == 2
# Pipe.__class__.__name__ == 'method'
# Pipe.__qualname__ == 'BaseContext.Pipe'
# Pipe.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra91.Queue_and_Pipe_identity:
  description: "multiprocessing Queue and Pipe factory method identity checks in mpprimitives91 namespace — wave 253 theme: multiprocessing Queue, Pipe, Value, Array function/class identity; Queue.__class__.__name__.__eq__('method')==True (Queue is a bound method of BaseContext, not a class); Queue.__module__.__eq__('multiprocessing.context')==True; Queue.__qualname__.__eq__('BaseContext.Queue')==True; Queue.__code__.co_argcount==2 (takes self and maxsize); Pipe.__class__.__name__.__eq__('method')==True; Pipe.__qualname__.__eq__('BaseContext.Pipe')==True; Pipe.__code__.co_argcount==2 (takes self and duplex); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprimitives91

  columns: [id, function, args, expected, description]
  rows:
    - [queue_class_name,    "Queue.__class__.__name__.__eq__",    ["method"],                  true, "Queue.__class__.__name__ == 'method' — Queue is a bound method of BaseContext, not a class; verified with Python 3.14.3"]
    - [queue_module,        Queue.__module__.__eq__,              ["multiprocessing.context"], true, "Queue.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; verified with Python 3.14.3"]
    - [queue_qualname,      Queue.__qualname__.__eq__,            ["BaseContext.Queue"],       true, "Queue.__qualname__ == 'BaseContext.Queue' — method defined on BaseContext; verified with Python 3.14.3"]
    - [queue_co_argcount,   Queue.__code__.co_argcount,           [],                          2,    "Queue.__code__.co_argcount == 2 — takes self and maxsize; verified with Python 3.14.3"]
    - [pipe_class_name,     "Pipe.__class__.__name__.__eq__",     ["method"],                  true, "Pipe.__class__.__name__ == 'method' — Pipe is a bound method of BaseContext; verified with Python 3.14.3"]
    - [pipe_qualname,       Pipe.__qualname__.__eq__,             ["BaseContext.Pipe"],        true, "Pipe.__qualname__ == 'BaseContext.Pipe' — method defined on BaseContext; verified with Python 3.14.3"]
    - [pipe_co_argcount,    Pipe.__code__.co_argcount,            [],                          2,    "Pipe.__code__.co_argcount == 2 — takes self and duplex; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
