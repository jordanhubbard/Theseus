spec: multiprocessing_extra2236
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py — BaseProcess and context-derived Process"
    - "CPython source: Lib/multiprocessing/synchronize.py — Lock, RLock, Semaphore, Event"
    - "CPython source: Lib/multiprocessing/queues.py — Queue"
  notes:
    - "Wave 2236 (_extra2236): __slots__ and slot descriptor protocol — __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__ presence in multiprocessing class dicts."
    - "Classes checked: multiprocessing.Process (context-derived), multiprocessing.synchronize.Lock, multiprocessing.synchronize.RLock, multiprocessing.synchronize.Semaphore, multiprocessing.synchronize.Event, multiprocessing.queues.Queue."
    - "__slots__ is NOT in the __dict__ of any of the 6 classes — none define __slots__ in their class body."
    - "multiprocessing.Process does NOT have __weakref__ or __dict__ in its class dict — it inherits them from multiprocessing.process.BaseProcess."
    - "multiprocessing.synchronize.Lock, RLock, and Semaphore do NOT have __weakref__ or __dict__ in their class dicts — they inherit from SemLock or parent synchronize primitives."
    - "multiprocessing.synchronize.Event DOES have __weakref__ and __dict__ in its class dict — Event is a top-level class in the synchronize module hierarchy at this level."
    - "multiprocessing.queues.Queue DOES have __weakref__ and __dict__ in its class dict — Queue is a top-level class in queues.py that introduces its own instance storage."
    - "__abstractmethods__ is NOT in the __dict__ of any of the 6 classes — none use ABCMeta."
    - "multiprocessing.synchronize.Lock, RLock, Semaphore, Event, and queues.Queue define __init__ in their class dict. multiprocessing.Process does NOT define __init__ — it uses BaseProcess.__init__."
    - "__new__ is NOT in the __dict__ of any of the 6 classes — all use object.__new__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __slots__ dict-presence — all 6 multiprocessing classes
#
# __slots__ is NOT in the __dict__ of any of the 6 multiprocessing classes.
# Process, synchronize.Lock, synchronize.RLock, synchronize.Semaphore,
# synchronize.Event, and queues.Queue all use per-instance __dict__ storage
# without declaring __slots__. All 6 return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2236.slots_dict_presence:
  description: "__slots__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2236

  columns: [id, function, args, expected]
  rows:
    - ["mp2236001", "multiprocessing.Process.__dict__.__contains__", ["__slots__"], false]
    - ["mp2236002", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__slots__"], false]
    - ["mp2236003", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__slots__"], false]
    - ["mp2236004", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__slots__"], false]
    - ["mp2236005", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__slots__"], false]
    - ["mp2236006", "multiprocessing.queues.Queue.__dict__.__contains__", ["__slots__"], false]

# ---------------------------------------------------------------------------
# Table 2: __weakref__ dict-presence — all 6 multiprocessing classes
#
# __weakref__ is present in the class dicts of multiprocessing.synchronize.Event
# and multiprocessing.queues.Queue — both are effectively root classes in their
# local inheritance chain, so CPython inserts a __weakref__ slot descriptor
# in their class dict. Process, Lock, RLock, and Semaphore do NOT have
# __weakref__ in their own class dicts; they inherit it from higher-level
# base classes. Process=False, Lock=False, RLock=False, Semaphore=False,
# Event=True, Queue=True.
# ---------------------------------------------------------------------------

table multiprocessing_extra2236.weakref_dict_presence:
  description: "__weakref__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — Event and Queue True, rest False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2236

  columns: [id, function, args, expected]
  rows:
    - ["mp2236007", "multiprocessing.Process.__dict__.__contains__", ["__weakref__"], false]
    - ["mp2236008", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__weakref__"], false]
    - ["mp2236009", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__weakref__"], false]
    - ["mp2236010", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__weakref__"], false]
    - ["mp2236011", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__weakref__"], true]
    - ["mp2236012", "multiprocessing.queues.Queue.__dict__.__contains__", ["__weakref__"], true]

# ---------------------------------------------------------------------------
# Table 3: __dict__ dict-presence — all 6 multiprocessing classes
#
# A __dict__ descriptor in a class's own __dict__ indicates that class
# introduces per-instance attribute storage at that point in the hierarchy.
# multiprocessing.synchronize.Event and multiprocessing.queues.Queue both
# carry __dict__ descriptors in their class dicts (mirroring __weakref__).
# Process, Lock, RLock, and Semaphore do not — they inherit the instance
# dict from their respective base classes. Process=False, Lock=False,
# RLock=False, Semaphore=False, Event=True, Queue=True.
# ---------------------------------------------------------------------------

table multiprocessing_extra2236.dict_dict_presence:
  description: "__dict__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — Event and Queue True, rest False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2236

  columns: [id, function, args, expected]
  rows:
    - ["mp2236013", "multiprocessing.Process.__dict__.__contains__", ["__dict__"], false]
    - ["mp2236014", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__dict__"], false]
    - ["mp2236015", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__dict__"], false]
    - ["mp2236016", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__dict__"], false]
    - ["mp2236017", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__dict__"], true]
    - ["mp2236018", "multiprocessing.queues.Queue.__dict__.__contains__", ["__dict__"], true]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__ dict-presence — all 6 multiprocessing classes
#
# __abstractmethods__ is NOT in the __dict__ of any multiprocessing class.
# None of the six classes use ABCMeta or carry unimplemented abstract methods
# in their own class namespace. All 6 return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2236.abstractmethods_dict_presence:
  description: "__abstractmethods__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2236

  columns: [id, function, args, expected]
  rows:
    - ["mp2236019", "multiprocessing.Process.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["mp2236020", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["mp2236021", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["mp2236022", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["mp2236023", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["mp2236024", "multiprocessing.queues.Queue.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 5: __init__ dict-presence — all 6 multiprocessing classes
#
# __init__ IS in the __dict__ of the four synchronize primitives (Lock, RLock,
# Semaphore, Event) and queues.Queue — each defines custom __init__ accepting
# context-specific arguments. multiprocessing.Process does NOT define __init__
# in its own class dict; the context-derived Process class inherits __init__
# from multiprocessing.process.BaseProcess. Process=False; Lock/RLock/
# Semaphore/Event/Queue=True.
# ---------------------------------------------------------------------------

table multiprocessing_extra2236.init_dict_presence:
  description: "__init__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — Process False, sync primitives and Queue True"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2236

  columns: [id, function, args, expected]
  rows:
    - ["mp2236025", "multiprocessing.Process.__dict__.__contains__", ["__init__"], false]
    - ["mp2236026", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__init__"], true]
    - ["mp2236027", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__init__"], true]
    - ["mp2236028", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__init__"], true]
    - ["mp2236029", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__init__"], true]
    - ["mp2236030", "multiprocessing.queues.Queue.__dict__.__contains__", ["__init__"], true]

# ---------------------------------------------------------------------------
# Table 6: __new__ dict-presence — all 6 multiprocessing classes
#
# __new__ is NOT in the __dict__ of any multiprocessing class checked here.
# None of Process, Lock, RLock, Semaphore, Event, or queues.Queue define a
# custom __new__ method — all rely on object.__new__ for instance allocation.
# All 6 return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2236.new_dict_presence:
  description: "__new__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2236

  columns: [id, function, args, expected]
  rows:
    - ["mp2236031", "multiprocessing.Process.__dict__.__contains__", ["__new__"], false]
    - ["mp2236032", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__new__"], false]
    - ["mp2236033", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__new__"], false]
    - ["mp2236034", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__new__"], false]
    - ["mp2236035", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__new__"], false]
    - ["mp2236036", "multiprocessing.queues.Queue.__dict__.__contains__", ["__new__"], false]
