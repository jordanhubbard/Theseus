spec: decimal_extra2296
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "decimal.Decimal and decimal.Context are C types from the _decimal extension but their __module__ reports 'decimal' (not '_decimal') in Python 3.14."
    - "All decimal exception classes (DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, Clamped) have __module__ == 'decimal'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2296.core_classes_module:
  description: "decimal.Decimal and decimal.Context report __module__ == 'decimal' even as C types"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc2296

  columns: [id, function, args, expected]
  rows:
    - ["dc2296001", "decimal.Decimal.__module__", [], "decimal"]
    - ["dc2296002", "decimal.Context.__module__", [], "decimal"]

table decimal_extra2296.core_classes_qualname:
  description: "decimal.Decimal and decimal.Context have simple __qualname__ matching class name"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc2296

  columns: [id, function, args, expected]
  rows:
    - ["dc2296003", "decimal.Decimal.__qualname__", [], "Decimal"]
    - ["dc2296004", "decimal.Context.__qualname__", [], "Context"]

table decimal_extra2296.exception_classes_module:
  description: "decimal exception hierarchy classes all report __module__ == 'decimal'"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc2296

  columns: [id, function, args, expected]
  rows:
    - ["dc2296005", "decimal.DecimalException.__module__", [], "decimal"]
    - ["dc2296006", "decimal.InvalidOperation.__module__", [], "decimal"]
    - ["dc2296007", "decimal.DivisionByZero.__module__", [], "decimal"]
    - ["dc2296008", "decimal.Overflow.__module__", [], "decimal"]
    - ["dc2296009", "decimal.Underflow.__module__", [], "decimal"]
    - ["dc2296010", "decimal.Inexact.__module__", [], "decimal"]
    - ["dc2296011", "decimal.Rounded.__module__", [], "decimal"]
    - ["dc2296012", "decimal.Subnormal.__module__", [], "decimal"]
    - ["dc2296013", "decimal.FloatOperation.__module__", [], "decimal"]
    - ["dc2296014", "decimal.Clamped.__module__", [], "decimal"]

table decimal_extra2296.exception_classes_qualname:
  description: "decimal exception classes have simple __qualname__ values matching class name"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc2296

  columns: [id, function, args, expected]
  rows:
    - ["dc2296015", "decimal.DecimalException.__qualname__", [], "DecimalException"]
    - ["dc2296016", "decimal.InvalidOperation.__qualname__", [], "InvalidOperation"]
    - ["dc2296017", "decimal.DivisionByZero.__qualname__", [], "DivisionByZero"]
    - ["dc2296018", "decimal.Overflow.__qualname__", [], "Overflow"]
    - ["dc2296019", "decimal.Underflow.__qualname__", [], "Underflow"]
    - ["dc2296020", "decimal.Inexact.__qualname__", [], "Inexact"]
    - ["dc2296021", "decimal.Rounded.__qualname__", [], "Rounded"]
    - ["dc2296022", "decimal.Subnormal.__qualname__", [], "Subnormal"]
    - ["dc2296023", "decimal.FloatOperation.__qualname__", [], "FloatOperation"]
    - ["dc2296024", "decimal.Clamped.__qualname__", [], "Clamped"]
