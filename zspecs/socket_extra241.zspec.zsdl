spec: socket_extra241
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol"
  - "RFC 768 — User Datagram Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 793 — Transmission Control Protocol, September 1981"
    - "RFC 768 — User Datagram Protocol, August 1980"
    - "Test vectors verified by running Python 3.14.3 socket on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra240.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/ICMP class names and values; SOL_SOCKET/SO_REUSEADDR/SO_KEEPALIVE/SO_BROADCAST class names and values."
    - "socket_extra24.zspec.zsdl — covers socket.socket __qualname__/__module__/__bases__[0].__name__; AddressFamily/SocketKind __qualname__/__module__; AF_INET/SOCK_STREAM __class__.__qualname__; socket.error/timeout __qualname__."
    - "socket_extra22.zspec.zsdl — covers socket.socket instance methods connect/bind/listen/accept/close/recv/send __qualname__.__eq__."
    - "socket_extra23.zspec.zsdl — covers setsockopt/getsockopt/getsockname/getpeername/setblocking/settimeout/gettimeout/fileno __qualname__."
    - "socket_extra8.zspec.zsdl — covers socket class __qualname__.__eq__; error/timeout/gaierror/herror exception class table."
  notes:
    - "This spec covers socket.socket class identity contracts and instance method __name__ contracts."
    - "socket_extra22 and socket_extra23 cover __qualname__.__eq__ for instance methods; this spec covers __name__ (the orthogonal short-name dimension) for the same methods."
    - "socket_extra24 covers socket.socket.__qualname__/__module__/__bases__[0].__name__ individually; this spec groups them in the extra241 namespace."
    - "socket.socket.__name__ == 'socket' — top-level class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket' — the Python-level socket wrapper module (not _socket C extension). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket' — top-level class, no nesting. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket' — the C extension base class is also named 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3 — MRO is [socket, socket (C base), object]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket().connect.__name__ == 'connect' — instance method bare name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket().bind.__name__ == 'bind'. socket.socket().listen.__name__ == 'listen'. socket.socket().accept.__name__ == 'accept'."
    - "socket.socket().connect.__qualname__ == 'socket.connect' — len 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket().bind.__qualname__ == 'socket.bind' — len 11."
    - "socket.socket().listen.__qualname__ == 'socket.listen' — len 13."
    - "socket.socket().accept.__qualname__ == 'socket.accept' — len 13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError for I/O failures. Class identity and method name attribute checks are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class identity or method name checks."
  codes: {}

# ---------------------------------------------------------------------------
# socket.socket class identity: __name__, __module__, __qualname__
# socket_extra24 covers these individually; this table groups them in the
# extra241 namespace.
# socket.socket.__module__ == 'socket' on Python 3.14.3 (the Python wrapper,
# not the C extension _socket).
# ---------------------------------------------------------------------------

table socksock241.class_identity:
  description: "socket.socket class __name__/__module__/__qualname__ equality — grouped in extra241 namespace; extra24 covers individually"
  kind: python_call_eq
  category: class_identity
  id_prefix: socksock241

  columns: [id, function, args, expected]
  rows:
    - [name_eq,      socket.__name__.__eq__,     ["socket"], true]
    - [module_eq,    socket.__module__.__eq__,   ["socket"], true]
    - [qualname_eq,  socket.__qualname__.__eq__,  ["socket"], true]

# ---------------------------------------------------------------------------
# socket.socket class identity lengths
# All three — __name__, __module__, __qualname__ — have len 6 ('socket').
# ---------------------------------------------------------------------------

table socksock241.class_identity_lengths:
  description: "socket.socket __name__/__module__/__qualname__ string lengths — all 6 for 'socket'"
  kind: python_call_eq
  category: class_identity
  id_prefix: socksock241

  columns: [id, function, args, expected]
  rows:
    - [name_len,     socket.__name__.__len__,     [], 6]
    - [module_len,   socket.__module__.__len__,   [], 6]
    - [qualname_len, socket.__qualname__.__len__,  [], 6]

# ---------------------------------------------------------------------------
# socket.socket.__bases__[0].__name__ == 'socket'
# The Python-level socket class inherits from the C-extension _socket.socket,
# which is also named 'socket'. __bases__[0].__module__ == '_socket'.
# ---------------------------------------------------------------------------

invariant socksock241.bases_name:
  description: "socket.socket.__bases__[0].__name__ == 'socket' — C-extension base class is also named 'socket'"
  category: class_hierarchy
  kind: python_call_eq
  "function": "socket.__bases__[0].__name__.__eq__"
  args: ["socket"]
  expected: true

invariant socksock241.bases_module:
  description: "socket.socket.__bases__[0].__module__ == '_socket' — C-extension base class lives in _socket"
  category: class_hierarchy
  kind: python_call_eq
  "function": "socket.__bases__[0].__module__.__eq__"
  args: ["_socket"]
  expected: true

invariant socksock241.mro_len:
  description: "socket.socket.__mro__.__len__() == 3 — MRO is [socket, _socket.socket, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: socket.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# socket.socket instance method __name__ contracts
# socket_extra22 covers __qualname__.__eq__ for connect/bind/listen/accept/close/recv/send.
# This table covers __name__ (the short bare name) for the same set of methods.
# Instance creation via socket() is not tested here; we use the dotted function
# chain form to access instance method __name__.
# ---------------------------------------------------------------------------

table socksockm241.method_names:
  description: "socket.socket() instance method __name__ values — connect/bind/listen/accept/close/recv/send; extra22 covers __qualname__"
  kind: python_call_eq
  category: method_identity
  id_prefix: socksockm241
  function: socket

  columns: [id, args, method, method_args, expected]
  rows:
    - [connect_name, [], connect.__name__.__eq__, ["connect"], true]
    - [bind_name,    [], bind.__name__.__eq__,    ["bind"],    true]
    - [listen_name,  [], listen.__name__.__eq__,  ["listen"],  true]
    - [accept_name,  [], accept.__name__.__eq__,  ["accept"],  true]
    - [close_name,   [], close.__name__.__eq__,   ["close"],   true]
    - [recv_name,    [], recv.__name__.__eq__,    ["recv"],    true]
    - [send_name,    [], send.__name__.__eq__,    ["send"],    true]

# ---------------------------------------------------------------------------
# socket.socket instance method __qualname__ contracts
# socket_extra22 covers connect/bind/listen/accept/close/recv/send __qualname__.__eq__.
# This table groups the same set in the extra241 namespace.
# Qualnames: 'socket.connect'=14, 'socket.bind'=11, 'socket.listen'=13,
#   'socket.accept'=13, 'socket.close'=12, 'socket.recv'=11, 'socket.send'=11.
# ---------------------------------------------------------------------------

table socksockm241.method_qualnames:
  description: "socket.socket() instance method __qualname__ values — grouped in extra241 namespace; extra22 covers individually"
  kind: python_call_eq
  category: method_identity
  id_prefix: socksockm241
  function: socket

  columns: [id, args, method, method_args, expected]
  rows:
    - [connect_qualname, [], connect.__qualname__.__eq__, ["socket.connect"], true]
    - [bind_qualname,    [], bind.__qualname__.__eq__,    ["socket.bind"],    true]
    - [listen_qualname,  [], listen.__qualname__.__eq__,  ["socket.listen"],  true]
    - [accept_qualname,  [], accept.__qualname__.__eq__,  ["socket.accept"],  true]

# ---------------------------------------------------------------------------
# socket.socket instance method __qualname__ lengths
# 'socket.connect'=14, 'socket.bind'=11, 'socket.listen'=13, 'socket.accept'=13
# ---------------------------------------------------------------------------

table socksockm241.method_qualname_lengths:
  description: "socket.socket() method __qualname__.__len__() — connect=14, bind=11, listen=13, accept=13"
  kind: python_call_eq
  category: method_identity
  id_prefix: socksockm241
  function: socket

  columns: [id, args, method, method_args, expected]
  rows:
    - [connect_qualname_len, [], connect.__qualname__.__len__, [], 14]
    - [bind_qualname_len,    [], bind.__qualname__.__len__,    [], 11]
    - [listen_qualname_len,  [], listen.__qualname__.__len__,  [], 13]
    - [accept_qualname_len,  [], accept.__qualname__.__len__,  [], 13]
