spec: dbm_extra4
version: ">=3.9"
backend: python_module(dbm)

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dbm.html — Python dbm module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dbm/__init__.py"
  notes:
    - "This spec extends dbm.zspec.zsdl through dbm_extra3.zspec.zsdl with new, non-duplicate invariants."
    - "dbm.zspec.zsdl covers: open/__name__, whichdb/__name__, whichdb nonexistent returns None, error is tuple."
    - "dbm_extra covers: open/__name__; whichdb/__name__/__module__/is_function; error/__name__/__module__/is_type/base_is_OSError/bases_len; dumb/__name__/open_name/error_name."
    - "dbm_extra2 covers: dbm.__name__; dbm.__package__; open class is not None; dumb.open/__module__; dumb._Database/__name__/__module__; ndbm/__name__; attr_names table."
    - "dbm_extra3 covers: __qualname__ for open, whichdb, error; _names.__class__.__name__ == 'list'."
    - "New here: dbm.open.__module__ (the module the open callable is defined in); dbm.open.__doc__ type; dbm.dumb.error.__module__; dbm._names first element is a str; dbm.error.__mro__ length."
    - "dbm.open.__module__ — on CPython the dbm.open object exposes __module__; for a builtin it is 'dbm'."
    - "dbm.open.__doc__ is a str — the callable carries a docstring describing its flags argument."
    - "dbm.dumb.error is an alias for OSError in the dumb submodule; its __module__ is 'builtins'."
    - "dbm._names[0] is a str — each entry is a dotted module name string (e.g. 'dbm.sqlite3')."
    - "dbm.error.__mro__ has length 5 on CPython: [error, OSError, Exception, BaseException, object]."
    - "dbm.error.__mro__.__len__() == 5 — the MRO chain for dbm.error is [error, OSError, Exception, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dbm.open.__module__ — not covered in any prior dbm spec
# dbm_extra checks open.__name__ and open.__class__.__name__.
# New here: the __module__ attribute of the open callable.
# On CPython dbm, open is implemented in Python inside dbm/__init__.py;
# __module__ == 'dbm'.
# ---------------------------------------------------------------------------

invariant dbm_extra4.open.module:
  description: "dbm.open.__module__ == 'dbm' — open is defined in the dbm package"
  category: functions
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["dbm"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.open.__doc__ type — not covered in any prior dbm spec
# The open callable carries a docstring describing its flags argument.
# __doc__ is a str (or potentially None for C builtins, but on CPython dbm
# it is a str). We verify the type is not NoneType by checking it is 'str'.
# ---------------------------------------------------------------------------

invariant dbm_extra4.open.doc_is_str:
  description: "dbm.open.__doc__.__class__.__name__ == 'str' — open carries a docstring"
  category: functions
  kind: python_call_eq
  function: open.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.dumb.error.__module__ — not covered in any prior dbm spec
# dbm_extra checks dumb.error.__name__ == 'error'.
# New here: the __module__ attribute of dumb.error.
# dbm.dumb.error is an alias for OSError; OSError is defined in 'builtins'.
# ---------------------------------------------------------------------------

invariant dbm_extra4.dumb.error_module:
  description: "dbm.dumb.error.__module__ == 'builtins' — dumb.error is an alias for OSError"
  category: submodules
  kind: python_call_eq
  function: dumb.error.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# dbm._names[0] is a str — not covered in any prior dbm spec
# dbm_extra3 checks _names.__class__.__name__ == 'list'.
# New here: the first element of _names is a str (a dotted module name).
# ---------------------------------------------------------------------------

invariant dbm_extra4._names.item_is_str:
  description: "dbm._names[0].__class__.__name__ == 'str' — each backend name is a string"
  category: module_attrs
  kind: python_call_eq
  function: _names.__getitem__
  args: [0]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.error.__mro__ length — not covered in any prior dbm spec
# dbm_extra checks __bases__[0] and bases_len==1.
# New here: the full MRO chain length for dbm.error.
# MRO: [error, OSError, Exception, BaseException, object] — length 5.
# ---------------------------------------------------------------------------

invariant dbm_extra4.error.mro_len:
  description: "len(dbm.error.__mro__) == 5 — MRO is [error, OSError, Exception, BaseException, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 5
