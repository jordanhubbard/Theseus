spec: multiprocessing_extra32
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/exceptions.py"
  notes:
    - "This spec extends multiprocessing_extra31.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__len__() tables, AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/AuthenticationError/ProcessError __mro__.__len__(), __all__ metadata, class __dict__.__class__.__name__.__len__() for Process/AuthenticationError/ProcessError, Pool class metadata, DefaultContext method qualname lengths, BufferTooShort/TimeoutError qualname lengths, synchronize.Lock/Event/Semaphore identity and hierarchy, queues.Queue identity and hierarchy."
    - "This spec covers: Process.__bases__[0].__name__.__len__()==11 ('BaseProcess'); Process.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'); AuthenticationError.__name__.__len__()==19; ProcessError.__name__.__len__()==12; BufferTooShort.__name__.__len__()==14; TimeoutError.__name__.__len__()==12 (mp.TimeoutError); ProcessError.__mro__.__len__()==4; AuthenticationError.__mro__.__len__()==5; cpu_count.__name__.__len__()==9; current_process.__name__.__len__()==15."
    - "Process.__bases__[0].__name__ == 'BaseProcess' (11 chars) — the public Process class is a platform-specific subclass of BaseProcess."
    - "Process.__dict__.__class__.__name__ == 'mappingproxy' (12 chars) — class __dict__ is always a mappingproxy, consistent with other modules."
    - "ProcessError.__mro__.__len__() == 4 — (ProcessError, Exception, BaseException, object) — no intermediate error class."
    - "AuthenticationError.__mro__.__len__() == 5 — (AuthenticationError, ProcessError, Exception, BaseException, object) — one deeper than ProcessError."
    - "mp.TimeoutError.__name__ == 'TimeoutError' (12 chars) — same string length as ProcessError.__name__ despite being a different class."
    - "cpu_count.__name__ == 'cpu_count' (9 chars); current_process.__name__ == 'current_process' (15 chars) — the longest top-level function name measured in this spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process base class and dict class name lengths — extra32
#
# The public multiprocessing.Process class is a platform-specific subclass
# of BaseProcess:
#   Process.__bases__[0].__name__ == 'BaseProcess' (11 chars)
#   Process.__bases__[0].__name__.__len__() == 11
# The class __dict__ is a mappingproxy (consistent across all Python classes):
#   Process.__dict__.__class__.__name__ == 'mappingproxy' (12 chars)
#   Process.__dict__.__class__.__name__.__len__() == 12
# Prior specs noted Process.__bases__[0].__name__ == 'BaseProcess' in text
# but did not capture the __len__() as an explicit table or invariant.
# ---------------------------------------------------------------------------

table multiprocessing_extra32.process_class_metadata:
  description: "multiprocessing.Process class metadata lengths in extra32 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: procmeta32

  columns: [id, function, args, expected]
  rows:
    - [base_name_len,    "Process.__bases__[0].__name__.__len__",           [], 11]
    - [dict_class_len,   Process.__dict__.__class__.__name__.__len__,       [], 12]

# ---------------------------------------------------------------------------
# multiprocessing exception class __name__ lengths — extra32 namespace
#
# The four public exception classes have these __name__ lengths:
#   AuthenticationError.__name__.__len__() == 19 ('AuthenticationError')
#   ProcessError.__name__.__len__()        == 12 ('ProcessError')
#   BufferTooShort.__name__.__len__()      == 14 ('BufferTooShort')
#   TimeoutError.__name__.__len__()        == 12 ('TimeoutError')
# ProcessError and TimeoutError share the same __name__ length (12) despite
# being distinct exception classes. AuthenticationError is the longest at 19.
# These __name__.__len__() values as function-call form were not recorded
# in prior specs (only the string values were noted in text).
# ---------------------------------------------------------------------------

table multiprocessing_extra32.exception_name_lengths:
  description: "multiprocessing exception class __name__.__len__() in extra32 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: excnamelen32

  columns: [id, function, args, expected]
  rows:
    - [AuthenticationError, AuthenticationError.__name__.__len__, [], 19]
    - [ProcessError,        ProcessError.__name__.__len__,        [], 12]
    - [BufferTooShort,      BufferTooShort.__name__.__len__,      [], 14]
    - [TimeoutError,        TimeoutError.__name__.__len__,        [], 12]

# ---------------------------------------------------------------------------
# multiprocessing exception class MRO depths — extra32 namespace
#
# ProcessError and AuthenticationError have different MRO depths:
#   ProcessError.__mro__       == (ProcessError, Exception, BaseException, object) — depth 4
#   AuthenticationError.__mro__ == (AuthenticationError, ProcessError, Exception, BaseException, object) — depth 5
# AuthenticationError is one level deeper because it subclasses ProcessError.
# No prior multiprocessing spec has explicitly tabled these MRO depths as
# __len__() function calls for both classes in the same table.
# ---------------------------------------------------------------------------

table multiprocessing_extra32.exception_mro_depths:
  description: "multiprocessing exception class __mro__.__len__() in extra32 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excmrolen32

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [ProcessError,
       ProcessError.__mro__,
       [],
       !ascii "",
       __len__,
       [],
       "ProcessError MRO depth == 4 — (ProcessError, Exception, BaseException, object)"]
    - [AuthenticationError,
       AuthenticationError.__mro__,
       [],
       !ascii "",
       __len__,
       [],
       "AuthenticationError MRO depth == 5 — (AuthenticationError, ProcessError, Exception, BaseException, object)"]

# ---------------------------------------------------------------------------
# multiprocessing top-level function __name__ lengths — extra32 namespace
#
# Two widely-used top-level functions:
#   cpu_count.__name__ == 'cpu_count' (9 chars)
#   current_process.__name__ == 'current_process' (15 chars)
# current_process is 6 characters longer than cpu_count.
# These __name__.__len__() values as function-call form were not captured
# in prior multiprocessing specs (only __qualname__ variants were noted).
# ---------------------------------------------------------------------------

table multiprocessing_extra32.toplevel_function_name_lengths:
  description: "multiprocessing top-level function __name__.__len__() for cpu_count and current_process in extra32 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: toplfunclen32

  columns: [id, function, args, expected]
  rows:
    - [cpu_count,       cpu_count.__name__.__len__,       [], 9]
    - [current_process, current_process.__name__.__len__,  [], 15]

# ---------------------------------------------------------------------------
# Standalone invariants — extra32
# ---------------------------------------------------------------------------

invariant multiprocessing_extra32.AuthenticationError_name_len:
  description: "multiprocessing.AuthenticationError.__name__.__len__() == 19 — 'AuthenticationError' is the longest exception name in the multiprocessing module"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__name__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra32.AuthenticationError_mro_len:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — one level deeper than ProcessError (4) due to ProcessError intermediate"
  category: class_hierarchy
  kind: python_call_eq
  function: AuthenticationError.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra32.current_process_name_len:
  description: "multiprocessing.current_process.__name__.__len__() == 15 — 'current_process' is 15 characters, the longest top-level function name in this spec"
  category: function_names
  kind: python_call_eq
  function: current_process.__name__.__len__
  args: []
  expected: 15
