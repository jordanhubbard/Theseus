spec: abc_extra184
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters"
    - "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters"
    - "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters"
    - "abc.abstractproperty.__name__.__len__() == 16 — 'abstractproperty' has 16 characters"
    - "abc.abstractclassmethod.__name__.__len__() == 19 — 'abstractclassmethod' has 19 characters"
    - "abc.abstractstaticmethod.__name__.__len__() == 20 — 'abstractstaticmethod' has 20 characters"
    - "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 characters"
    - "Length ordering: ABC(3) < ABCMeta(7) < abstractmethod(14) < get_cache_token(15) < abstractproperty(16) < abstractclassmethod(19) < abstractstaticmethod(20)"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc module short exported name lengths (ABC, ABCMeta)
#
# abc.ABC.__name__.__len__().__eq__(3) == True
# abc.ABCMeta.__name__.__len__().__eq__(7) == True
# ---------------------------------------------------------------------------

table abc_extra184.abc_short_name_lens:
  description: "abc module short exported name lengths: ABC(3), ABCMeta(7); verified with Python 3.14.3; new to abc_extra184"
  kind: python_call_eq
  category: identity
  id_prefix: abcnamelens184

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_len_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters: A-B-C; shortest abc public name; str.__len__() returns 3; new to abc_extra184"]
    - [abcmeta_name_len_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters: A-B-C-M-e-t-a; str.__len__() returns 7; new to abc_extra184"]
    - [abc_name_eq,
       ABC.__name__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__name__.__eq__('ABC') == True — class name identity; len=3; str.__eq__ returns True; new to abc_extra184"]
    - [abcmeta_name_eq,
       ABCMeta.__name__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__name__.__eq__('ABCMeta') == True — class name identity; len=7; str.__eq__ returns True; new to abc_extra184"]
    - [abc_len_eq_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — ordering anchor: ABC(3) < ABCMeta(7) < abstractmethod(14); str.__len__() returns 3; new to abc_extra184"]

