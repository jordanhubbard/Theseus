spec: socket_extra99
version: ">=3.9"
backend: python_module(socket)
extends: socket_extra98

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (connect/bind/listen/send/recv and __init__/accept/close/makefile) (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra98; it does NOT duplicate invariants present in those files."
    - "Wave 262 theme: socket module function __qualname__.__len__() values and socket.SocketIO class identity — gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__ lengths / SocketIO __class__.__name__/'ABCMeta' / SocketIO __module__=='socket' / SocketIO __bases__[0].__name__=='RawIOBase'."
    - "socket.gethostname.__qualname__.__len__() == 11 ('gethostname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__qualname__.__len__() == 13 ('gethostbyname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__qualname__.__len__() == 11 ('getaddrinfo'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__qualname__.__len__() == 17 ('setdefaulttimeout'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__qualname__.__len__() == 17 ('getdefaulttimeout'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__class__.__name__ == 'ABCMeta'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__bases__[0].__name__ == 'RawIOBase'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: gethostname and getaddrinfo both have qualname length 11 because both names are 11 chars."
    - "Note: setdefaulttimeout and getdefaulttimeout both have qualname length 17 because both names are 17 chars."
    - "Note: gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout are C builtins (builtin_function_or_method); getaddrinfo is a Python-level function wrapper."
    - "Note: SocketIO.__class__.__name__ is 'ABCMeta' because SocketIO is defined with ABCMeta as its metaclass (it inherits from io.RawIOBase via ABC machinery)."
    - "Note: SocketIO.__bases__[0].__module__ is 'io' — RawIOBase lives in the io module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostname.__qualname__.__len__()==11
# socket.gethostbyname.__qualname__.__len__()==13
# socket.getaddrinfo.__qualname__.__len__()==11
#
# Wave 262 theme: socket name resolution function __qualname__.__len__().
#
# gethostname ('gethostname', 11) and getaddrinfo ('getaddrinfo', 11) share
# length 11. gethostbyname ('gethostbyname', 13) is longer. gethostname and
# gethostbyname/setdefaulttimeout/getdefaulttimeout are C builtins; getaddrinfo
# is a Python-level wrapper function. socket_extra96 anchors their class names;
# socket_extra94 anchors their __qualname__.__eq__; this table first anchors
# __qualname__.__len__() for these three under sockmodqlen99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra99.socket_name_fn_qualname_lengths:
  description: "socket.gethostname/__qualname__/__len__()==11 / gethostbyname/__qualname__/__len__()==13 / getaddrinfo/__qualname__/__len__()==11 — gethostname and getaddrinfo share length 11 (both 11-char names); gethostbyname is 13; extra96 anchors class names; extra94 anchors qualname equality; first sockmodqlen99 anchor for these qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockmodqlen99

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_qlen,   gethostname.__qualname__.__len__,   [], 11, "'gethostname' is 11 chars, C builtin from socketmodule.c"]
    - [gethostbyname_qlen, gethostbyname.__qualname__.__len__, [], 13, "'gethostbyname' is 13 chars, C builtin from socketmodule.c"]
    - [getaddrinfo_qlen,   getaddrinfo.__qualname__.__len__,   [], 11, "'getaddrinfo' is 11 chars, Python-level wrapper in Lib/socket.py"]

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__qualname__.__len__()==17
# socket.getdefaulttimeout.__qualname__.__len__()==17
#
# Wave 262 theme: socket timeout control function __qualname__.__len__().
#
# setdefaulttimeout and getdefaulttimeout both have 17-char qualnames equal
# to their function names. They are C builtins from socketmodule.c.
# socket_extra96 anchors their __class__.__name__=='builtin_function_or_method';
# socket_extra94 anchors their __qualname__.__eq__; this table first anchors
# __qualname__.__len__()==17 for both under sockmodqlen99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra99.socket_timeout_fn_qualname_lengths:
  description: "socket.setdefaulttimeout/__qualname__/__len__()==17 / getdefaulttimeout/__qualname__/__len__()==17 — both are 17-char C builtin function names equal to their __qualname__; extra96 anchors class names; extra94 anchors qualname equality; first sockmodqlen99 anchor for timeout function qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockmodqlen99

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_qlen, setdefaulttimeout.__qualname__.__len__, [], 17, "'setdefaulttimeout' is 17 chars, C builtin for setting default socket timeout"]
    - [getdefaulttimeout_qlen, getdefaulttimeout.__qualname__.__len__, [], 17, "'getdefaulttimeout' is 17 chars, C builtin for getting default socket timeout"]

# ---------------------------------------------------------------------------
# socket.SocketIO.__class__.__name__.__eq__('ABCMeta')
# socket.SocketIO.__module__.__eq__('socket')
# socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase')
# socket.SocketIO.__qualname__.__len__()==8
#
# Wave 262 theme: socket.SocketIO class identity.
#
# SocketIO is a Python class in Lib/socket.py that wraps a socket object as a
# raw I/O stream. Its metaclass is ABCMeta (not 'type') because it is defined
# using ABCMeta machinery through inheriting from io.RawIOBase. Its __module__
# is 'socket'. Its single base class is RawIOBase from the io module.
# No prior socket spec anchors SocketIO class identity under sockmodqlen99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra99.SocketIO_class_identity:
  description: "socket.SocketIO/__class__.__name__.__eq__('ABCMeta')==True / SocketIO/__module__.__eq__('socket')==True / SocketIO/__bases__[0]/__name__.__eq__('RawIOBase')==True / SocketIO/__qualname__/__len__()==8 — SocketIO metaclass is ABCMeta (not 'type') because it inherits from io.RawIOBase via ABC machinery; defined in Lib/socket.py; base class is RawIOBase from io module; __qualname__ is 'SocketIO' (8 chars); no prior socket spec anchors SocketIO identity; first sockmodqlen99 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmodqlen99

  columns: [id, function, args, expected, description]
  rows:
    - [socketio_metaclass,  "SocketIO.__class__.__name__.__eq__",        ["ABCMeta"],   true, "SocketIO metaclass is ABCMeta (not 'type'), due to ABC inheritance from RawIOBase"]
    - [socketio_module,     "SocketIO.__module__.__eq__",                 ["socket"],    true, "SocketIO is defined in Lib/socket.py, __module__ is 'socket'"]
    - [socketio_base_name,  "SocketIO.__bases__[0].__name__.__eq__",     ["RawIOBase"], true, "SocketIO's single base class is io.RawIOBase"]
    - [socketio_qlen,       SocketIO.__qualname__.__len__,                [],            8,    "'SocketIO' is 8 chars, the simple class name with no enclosing scope prefix"]

# ---------------------------------------------------------------------------
# socket.gethostname.__qualname__.__len__()==11 — standalone
#
# socket.gethostname.__qualname__.__len__() is 11. gethostname.__qualname__ is
# 'gethostname' (11 chars), the same as the function name — it is a top-level
# C builtin from socketmodule.c so no class prefix is present. gethostname
# returns the hostname of the machine running the Python interpreter. socket_extra96
# anchors its __class__.__name__=='builtin_function_or_method'; socket_extra94
# anchors its __qualname__.__eq__; no prior spec anchors gethostname.__qualname__.__len__()
# as a standalone under sockmodqlen99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra99.gethostname_qualname_len_11:
  description: "socket.gethostname.__qualname__.__len__() == 11 — gethostname.__qualname__ is 'gethostname' (11 chars); top-level C builtin from socketmodule.c with no class prefix; extra96 anchors class name; extra94 anchors qualname equality; first standalone for gethostname.__qualname__.__len__() under sockmodqlen99"
  category: qualname_lengths
  kind: python_call_eq
  function: gethostname.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# socket.SocketIO.__class__.__name__.__eq__('ABCMeta') — standalone
#
# socket.SocketIO.__class__.__name__ is 'ABCMeta'. SocketIO is defined in
# Lib/socket.py as a class that inherits from io.RawIOBase. Since RawIOBase
# is part of Python's ABC hierarchy (from abc.ABCMeta), SocketIO's metaclass
# becomes ABCMeta rather than the plain 'type'. This distinguishes SocketIO
# from ordinary Python classes and from C-extension type objects. No prior
# socket spec anchors SocketIO.__class__.__name__.__eq__('ABCMeta') as a
# standalone under sockmodqlen99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra99.SocketIO_metaclass_ABCMeta:
  description: "socket.SocketIO.__class__.__name__.__eq__('ABCMeta') == True — SocketIO's metaclass is ABCMeta because it inherits from io.RawIOBase which is part of Python's ABC hierarchy; this distinguishes SocketIO from ordinary 'type' classes and from C-extension types; no prior socket spec anchors SocketIO.__class__.__name__ as a standalone; first standalone for SocketIO metaclass under sockmodqlen99"
  category: type_identity
  kind: python_call_eq
  function: "SocketIO.__class__.__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketIO.__module__.__eq__('socket') — standalone
#
# socket.SocketIO.__module__ is 'socket'. SocketIO is defined in Lib/socket.py
# (the Python-level socket module), not in socketmodule.c (the C extension).
# This means SocketIO is a pure Python class that wraps an underlying C socket
# object, providing a file-like I/O interface. The __module__ attribute confirms
# its origin in the Python-level socket module. No prior socket spec anchors
# SocketIO.__module__.__eq__('socket') as a standalone under sockmodqlen99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra99.SocketIO_module_socket:
  description: "socket.SocketIO.__module__.__eq__('socket') == True — SocketIO is defined in Lib/socket.py (not socketmodule.c), confirming it is a pure Python class providing a file-like I/O wrapper over C socket objects; no prior socket spec anchors SocketIO.__module__ as a standalone; first standalone for SocketIO.__module__ under sockmodqlen99"
  category: type_identity
  kind: python_call_eq
  function: "SocketIO.__module__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase') — standalone
#
# socket.SocketIO.__bases__[0].__name__ is 'RawIOBase'. SocketIO's single base
# class is io.RawIOBase, which provides the raw I/O interface for byte streams.
# By inheriting from RawIOBase, SocketIO can be used wherever a raw I/O stream
# is expected (e.g., with io.BufferedReader). RawIOBase itself is defined in
# the io module (C implementation in _io module). No prior socket spec anchors
# SocketIO.__bases__[0].__name__.__eq__('RawIOBase') as a standalone under
# sockmodqlen99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra99.SocketIO_base_RawIOBase:
  description: "socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase') == True — SocketIO's single base class is io.RawIOBase, enabling use wherever a raw I/O stream is expected (e.g., with io.BufferedReader); RawIOBase is defined in the io module (_io C extension); no prior socket spec anchors SocketIO.__bases__[0].__name__ as a standalone; first standalone for SocketIO base class under sockmodqlen99"
  category: type_identity
  kind: python_call_eq
  function: "SocketIO.__bases__[0].__name__.__eq__"
  args: ["RawIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__qualname__.__len__()==17 — standalone
#
# socket.setdefaulttimeout.__qualname__.__len__() is 17. setdefaulttimeout.__qualname__
# is 'setdefaulttimeout' (17 chars), the same as the function name. It is a top-level
# C builtin from socketmodule.c. setdefaulttimeout sets the default timeout for
# new socket objects; without it, new sockets operate in blocking mode. socket_extra96
# anchors its __class__.__name__=='builtin_function_or_method'; socket_extra94 anchors
# its __qualname__.__eq__; no prior spec anchors setdefaulttimeout.__qualname__.__len__()
# as a standalone under sockmodqlen99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra99.setdefaulttimeout_qualname_len_17:
  description: "socket.setdefaulttimeout.__qualname__.__len__() == 17 — setdefaulttimeout.__qualname__ is 'setdefaulttimeout' (17 chars); C builtin from socketmodule.c; sets the default timeout for new socket objects; extra96 anchors class name; extra94 anchors qualname equality; first standalone for setdefaulttimeout.__qualname__.__len__() under sockmodqlen99"
  category: qualname_lengths
  kind: python_call_eq
  function: setdefaulttimeout.__qualname__.__len__
  args: []
  expected: 17
