spec: configparser_extra12
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
    - "configparser_extra11.zspec.zsdl — covers Error/NoSectionError/NoOptionError __qualname__; ConfigParser.__name__.__class__.__name__=='str'; ConfigParser().optionxform() lowercasing behavior; RawConfigParser().sections()==[]"
    - "configparser_extra10.zspec.zsdl — covers ConfigParser/__qualname__; RawConfigParser/__qualname__; exception __module__ table; DEFAULTSECT.__len__()==7; MutableMapping method names pop/clear/update; BasicInterpolation/__bases__[0].__name__=='Interpolation'; ExtendedInterpolation/__bases__[0].__name__=='Interpolation'"
    - "configparser_extra9.zspec.zsdl — covers metaclasses; __bases__.__len__()==1 for Interpolation/Basic/Extended/NoOptionError/DuplicateSectionError/MissingSectionHeaderError; ConfigParser method names read_file/keys/values/defaults"
    - "configparser_extra8.zspec.zsdl — covers __bases__.__len__()==1 for ConfigParser/RawConfigParser/Error/NoSectionError; method names read_dict/has_option/getint/getfloat/getboolean"
    - "configparser_extra5.zspec.zsdl — covers configparser.__name__=='configparser'; ConfigParser.__bases__[0].__name__=='RawConfigParser'"
  notes:
    - "This spec extends the configparser chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: configparser.__all__.__len__()==23 and __all__.__class__.__name__=='tuple' (len 5); __dict__.__class__.__name__.__len__()==12 for ConfigParser/RawConfigParser/Error; ConfigParser.__mro__.__len__()==9; ConfigParser.__bases__[0].__name__.__len__()==15 ('RawConfigParser'); RawConfigParser.__mro__.__len__()==8; RawConfigParser.__bases__[0].__name__.__len__()==14 ('MutableMapping'); Error.__bases__[0].__name__.__len__()==9 ('Exception'); DEFAULTSECT.__class__.__name__.__len__()==3 ('str'); ConfigParser method __qualname__.__len__() for set/add_section; RawConfigParser.read/__qualname__.__len__()==20."
    - "configparser.__all__.__len__() == 23 on Python 3.12. __all__ is a tuple (not a list). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "configparser.__all__.__class__.__name__ == 'tuple' — len('tuple') == 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "configparser.ConfigParser.__mro__.__len__() == 9 — (ConfigParser, RawConfigParser, MutableMapping, Mapping, Collection, Sized, Iterable, Container, object). NOT 3 as suggested in task brief. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "configparser.RawConfigParser.__mro__.__len__() == 8 — (RawConfigParser, MutableMapping, Mapping, Collection, Sized, Iterable, Container, object). NOT 2 as suggested. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "configparser.RawConfigParser.__bases__[0].__name__ == 'MutableMapping' — len 14. NOT 13/'RawConfigParser' as suggested for the bases. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "configparser.ConfigParser.set.__qualname__ == 'ConfigParser.set' (len 16). configparser.ConfigParser.add_section.__qualname__ == 'ConfigParser.add_section' (len 24 via ConfigParser direct; RawConfigParser.add_section is len 27). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "configparser.RawConfigParser.read.__qualname__ == 'RawConfigParser.read' (len 20). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "SafeConfigParser does not exist in Python 3.12 — omitted from this spec."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# configparser.__all__.__len__() and __all__.__class__.__name__
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__.
# configparser.__all__ is a tuple of 23 public names on Python 3.12.
# NOTE: __all__ is a tuple (not a list) — __class__.__name__ == 'tuple' (len 5).
# ---------------------------------------------------------------------------

invariant configparser_extra12.all_len:
  description: "configparser.__all__.__len__() == 23 — 23 public names exported"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 23

invariant configparser_extra12.all_class_name_len:
  description: "configparser.__all__.__class__.__name__.__len__() == 5 — len('tuple') == 5"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() == 12 for core classes
#
# No prior spec checks __dict__.__class__.__name__.__len__() for configparser classes.
# Class __dict__ is a mappingproxy; len('mappingproxy') == 12.
# ---------------------------------------------------------------------------

table configparser_extra12.class_dict_proxy_name_lens:
  description: "ConfigParser/RawConfigParser/Error __dict__.__class__.__name__.__len__() == 12"
  kind: python_call_eq
  category: class_structure
  id_prefix: cpdpnl12

  columns: [id, function, args, expected, description]
  rows:
    - [ConfigParser_dict_class_len,
       "ConfigParser.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(configparser.ConfigParser.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [RawConfigParser_dict_class_len,
       "RawConfigParser.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(configparser.RawConfigParser.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [Error_dict_class_len,
       "Error.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(configparser.Error.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# MRO lengths for ConfigParser and RawConfigParser
#
# ConfigParser.__mro__.__len__() == 9 — includes full ABC chain.
# RawConfigParser.__mro__.__len__() == 8.
# No prior spec checks __mro__.__len__() for these classes.
# NOTE: Task brief suggested 3 and 2 respectively — actual Python 3.12 values
# are 9 and 8 due to MutableMapping ABC inheritance chain.
# ---------------------------------------------------------------------------

invariant configparser_extra12.ConfigParser.mro_len:
  description: "configparser.ConfigParser.__mro__.__len__() == 9 — includes full MutableMapping ABC chain"
  category: class_hierarchy
  kind: python_call_eq
  function: ConfigParser.__mro__.__len__
  args: []
  expected: 9

invariant configparser_extra12.RawConfigParser.mro_len:
  description: "configparser.RawConfigParser.__mro__.__len__() == 8 — includes full MutableMapping ABC chain"
  category: class_hierarchy
  kind: python_call_eq
  function: RawConfigParser.__mro__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Base class __name__ lengths
#
# ConfigParser.__bases__[0].__name__ == 'RawConfigParser' (len 15).
# RawConfigParser.__bases__[0].__name__ == 'MutableMapping' (len 14).
# Error.__bases__[0].__name__ == 'Exception' (len 9).
# No prior spec checks the string length of these base class names.
# ---------------------------------------------------------------------------

table configparser_extra12.base_name_lens:
  description: "ConfigParser/RawConfigParser/Error __bases__[0].__name__.__len__()"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cpbnl12

  columns: [id, function, args, expected, description]
  rows:
    - [ConfigParser_base_name_len,
       "ConfigParser.__bases__.__getitem__",
       [0],
       "RawConfigParser",
       "configparser.ConfigParser.__bases__[0].__name__ == 'RawConfigParser' — inherited from RawConfigParser"]

# (The above row calls __getitem__ and expects the class; length checks use standalone invariants below)

invariant configparser_extra12.ConfigParser.base_name_len:
  description: "configparser.ConfigParser.__bases__[0].__name__.__len__() == 15 — len('RawConfigParser') == 15"
  category: class_hierarchy
  kind: python_call_eq
  function: ConfigParser.__bases__.__getitem__
  args: [0]
  method_chain: __name__.__len__
  method_chain_args: []
  expected: 15

invariant configparser_extra12.RawConfigParser.base_name_len:
  description: "configparser.RawConfigParser.__bases__[0].__name__.__len__() == 14 — len('MutableMapping') == 14"
  category: class_hierarchy
  kind: python_call_eq
  function: RawConfigParser.__bases__.__getitem__
  args: [0]
  method_chain: __name__.__len__
  method_chain_args: []
  expected: 14

invariant configparser_extra12.Error.base_name_len:
  description: "configparser.Error.__bases__[0].__name__.__len__() == 9 — len('Exception') == 9"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method_chain: __name__.__len__
  method_chain_args: []
  expected: 9

# ---------------------------------------------------------------------------
# DEFAULTSECT.__class__.__name__.__len__() == 3
#
# configparser_extra7 checks DEFAULTSECT.__class__.__name__ == 'str'.
# No prior spec checks the length of that class name.
# len('str') == 3.
# ---------------------------------------------------------------------------

invariant configparser_extra12.DEFAULTSECT.class_name_len:
  description: "configparser.DEFAULTSECT.__class__.__name__.__len__() == 3 — len('str') == 3"
  category: module_constants
  kind: python_call_eq
  function: DEFAULTSECT.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# ConfigParser method __qualname__.__len__() values
#
# ConfigParser.set.__qualname__ == 'ConfigParser.set' (len 16) — defined on ConfigParser itself.
# ConfigParser.add_section.__qualname__ == 'ConfigParser.add_section' (len 24) — defined on ConfigParser.
# RawConfigParser.read.__qualname__ == 'RawConfigParser.read' (len 20).
# No prior spec checks __qualname__.__len__() for these methods.
# ---------------------------------------------------------------------------

table configparser_extra12.method_qualname_lens:
  description: "ConfigParser.set/add_section and RawConfigParser.read __qualname__.__len__()"
  kind: python_call_eq
  category: function_attrs
  id_prefix: cpmql12

  columns: [id, function, args, expected, description]
  rows:
    - [ConfigParser_set_qualname_len,
       ConfigParser.set.__qualname__.__len__,
       [],
       16,
       "len('ConfigParser.set') == 16"]
    - [ConfigParser_add_section_qualname_len,
       ConfigParser.add_section.__qualname__.__len__,
       [],
       24,
       "len('ConfigParser.add_section') == 24"]
    - [RawConfigParser_read_qualname_len,
       RawConfigParser.read.__qualname__.__len__,
       [],
       20,
       "len('RawConfigParser.read') == 20"]
