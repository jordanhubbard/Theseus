spec: hashlib_extra2131
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib.zspec.zsdl — covers sha256/sha1/md5/sha512/sha3 vectors, algorithms_guaranteed"
    - "hashlib_extra.zspec.zsdl — covers blake2b/blake2s attrs, algorithms_available, pbkdf2_hmac"
    - "hashlib_extra2.zspec.zsdl — covers hexdigest known vectors, algorithms_guaranteed type, new()"
  notes:
    - "Wave extra2131, theme: exception protocol dict-presence."
    - "Checks whether exception-related protocol attributes (__cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback) appear in the __dict__ of hashlib types."
    - "hashlib.blake2b and hashlib.blake2s are non-exception C extension types; none of the exception protocol attributes appear in their __dict__."
    - "hashlib has no UnsupportedDigestmodError on Python < 3.9; as of Python 3.9 through 3.12 it does not exist either — confirmed at runtime."
    - "__cause__, __context__, __traceback__, __suppress_context__ are instance attributes set by CPython exception machinery — NOT in any class __dict__."
    - "args and with_traceback live in BaseException.__dict__, not in derived-class __dict__ unless overridden."
    - "blake2b.__dict__ contains: __new__, copy, digest, hexdigest, update, name, block_size, digest_size, SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE."
    - "blake2s.__dict__ contains the same keys as blake2b."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# blake2b — exception protocol attributes absent from class __dict__
# blake2b is a non-exception C extension type; none of the protocol attrs live here.
# ---------------------------------------------------------------------------

table hashlib_extra2131.blake2b_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: hl2131

  columns: [id, function, args, expected]
  rows:
    - ["hl2131001", blake2b.__dict__.__contains__, ["__cause__"],             false]
    - ["hl2131002", blake2b.__dict__.__contains__, ["__context__"],           false]
    - ["hl2131003", blake2b.__dict__.__contains__, ["__traceback__"],         false]
    - ["hl2131004", blake2b.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["hl2131005", blake2b.__dict__.__contains__, ["__notes__"],             false]
    - ["hl2131006", blake2b.__dict__.__contains__, ["args"],                  false]
    - ["hl2131007", blake2b.__dict__.__contains__, ["with_traceback"],        false]

# ---------------------------------------------------------------------------
# blake2s — exception protocol attributes absent from class __dict__
# ---------------------------------------------------------------------------

table hashlib_extra2131.blake2s_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: hl2131

  columns: [id, function, args, expected]
  rows:
    - ["hl2131008", blake2s.__dict__.__contains__, ["__cause__"],             false]
    - ["hl2131009", blake2s.__dict__.__contains__, ["__context__"],           false]
    - ["hl2131010", blake2s.__dict__.__contains__, ["__traceback__"],         false]
    - ["hl2131011", blake2s.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["hl2131012", blake2s.__dict__.__contains__, ["__notes__"],             false]
    - ["hl2131013", blake2s.__dict__.__contains__, ["args"],                  false]
    - ["hl2131014", blake2s.__dict__.__contains__, ["with_traceback"],        false]

# ---------------------------------------------------------------------------
# blake2b — positive presence: known real attributes ARE in __dict__
# These confirm the __dict__.__contains__ mechanism works correctly for this type.
# ---------------------------------------------------------------------------

table hashlib_extra2131.blake2b_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2131

  columns: [id, function, args, expected]
  rows:
    - ["hl2131015", blake2b.__dict__.__contains__, ["copy"],          true]
    - ["hl2131016", blake2b.__dict__.__contains__, ["digest"],        true]
    - ["hl2131017", blake2b.__dict__.__contains__, ["hexdigest"],     true]
    - ["hl2131018", blake2b.__dict__.__contains__, ["update"],        true]
    - ["hl2131019", blake2b.__dict__.__contains__, ["SALT_SIZE"],     true]
    - ["hl2131020", blake2b.__dict__.__contains__, ["MAX_KEY_SIZE"],  true]
    - ["hl2131021", blake2b.__dict__.__contains__, ["digest_size"],   true]
    - ["hl2131022", blake2b.__dict__.__contains__, ["block_size"],    true]

# ---------------------------------------------------------------------------
# blake2s — positive presence: known real attributes ARE in __dict__
# ---------------------------------------------------------------------------

table hashlib_extra2131.blake2s_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2131

  columns: [id, function, args, expected]
  rows:
    - ["hl2131023", blake2s.__dict__.__contains__, ["copy"],          true]
    - ["hl2131024", blake2s.__dict__.__contains__, ["digest"],        true]
    - ["hl2131025", blake2s.__dict__.__contains__, ["hexdigest"],     true]
    - ["hl2131026", blake2s.__dict__.__contains__, ["update"],        true]
    - ["hl2131027", blake2s.__dict__.__contains__, ["SALT_SIZE"],     true]
    - ["hl2131028", blake2s.__dict__.__contains__, ["MAX_KEY_SIZE"],  true]
