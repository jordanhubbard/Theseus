spec: strip_ansi
version: ">=6.0.0"
backend: node(strip-ansi)

docs: https://github.com/chalk/strip-ansi#readme

provenance:
  derived_from:
    - "strip-ansi README --- https://github.com/chalk/strip-ansi#readme"
    - "Test vectors verified with strip-ansi@6.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "strip-ansi source: index.js"
  notes:
    - "strip-ansi exports the stripAnsi function as the module default (CJS)."
    - "require('strip-ansi') returns the function directly; fn_name is null (call module itself)."
    - "Removes all ANSI escape sequences from a string, returning only the visible characters."
    - "Strings without ANSI codes are returned unchanged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "No errors thrown for string inputs. Returns the stripped string directly."
  stderr: "null"
  stickiness: "N/A --- stateless."
  codes: {}

table strip_ansi.passthrough:
  kind: node_module_call_eq
  function: ~
  category: passthrough
  id_prefix: pass

  columns: [id, args, expected]
  rows:
    - [plain,  ["hello"],  "hello"]
    - [empty,  [""],       ""]

table strip_ansi.strip:
  kind: node_module_call_eq
  function: ~
  category: strip
  id_prefix: strip

  columns: [id, args, expected]
  rows:
    - [red_color,  ["\u001B[31mhello\u001B[0m"],       "hello"]
    - [bold,       ["\u001B[1mbold\u001B[22m"],         "bold"]
    - [mixed,      ["\u001B[32mgreen\u001B[0m normal"], "green normal"]
