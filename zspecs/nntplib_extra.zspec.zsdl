spec: nntplib_extra
version: ">=3.9,<3.13"
backend: python_module(nntplib)

docs: https://docs.python.org/3.11/library/nntplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3.11/library/nntplib.html — Python nntplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/nntplib.py"
  notes:
    - "This spec extends nntplib.zspec.zsdl with additional identity and hierarchy invariants not covered there."
    - "nntplib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "nntplib.NNTP.__name__ == 'NNTP' and nntplib.NNTP.__module__ == 'nntplib'."
    - "nntplib.NNTP_SSL.__name__ == 'NNTP_SSL'; its base class is _NNTPBase (an internal mixin)."
    - "nntplib.NNTPError is the root exception, directly subclassing Exception."
    - "nntplib.NNTPTemporaryError and nntplib.NNTPPermanentError both subclass NNTPError."
    - "nntplib.NNTPReplyError and nntplib.NNTPDataError also subclass NNTPError."
    - "nntplib.NNTPProtocolError subclasses NNTPError."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NNTP class name and module affiliation
# ---------------------------------------------------------------------------

invariant nntplib_extra.names.NNTP:
  description: "nntplib.NNTP.__name__ == 'NNTP'"
  category: names
  kind: python_call_eq
  function: NNTP.__name__.__eq__
  args: ["NNTP"]
  expected: true

invariant nntplib_extra.modules.NNTP:
  description: "nntplib.NNTP.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTP.__module__.__eq__
  args: ["nntplib"]
  expected: true

# ---------------------------------------------------------------------------
# NNTP_SSL class name and base class
# ---------------------------------------------------------------------------

invariant nntplib_extra.names.NNTP_SSL:
  description: "nntplib.NNTP_SSL.__name__ == 'NNTP_SSL'"
  category: names
  kind: python_call_eq
  function: NNTP_SSL.__name__.__eq__
  args: ["NNTP_SSL"]
  expected: true

invariant nntplib_extra.hierarchy.NNTP_SSL_base:
  description: "nntplib.NNTP_SSL.__bases__[0].__name__ == '_NNTPBase'"
  category: hierarchy
  kind: python_call_eq
  function: NNTP_SSL.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_NNTPBase"

# ---------------------------------------------------------------------------
# NNTPError — root exception name and hierarchy
# ---------------------------------------------------------------------------

invariant nntplib_extra.names.NNTPError:
  description: "nntplib.NNTPError.__name__ == 'NNTPError'"
  category: names
  kind: python_call_eq
  function: NNTPError.__name__.__eq__
  args: ["NNTPError"]
  expected: true

invariant nntplib_extra.hierarchy.NNTPError_base:
  description: "nntplib.NNTPError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: NNTPError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# NNTPTemporaryError — class name and hierarchy
# ---------------------------------------------------------------------------

invariant nntplib_extra.names.NNTPTemporaryError:
  description: "nntplib.NNTPTemporaryError.__name__ == 'NNTPTemporaryError'"
  category: names
  kind: python_call_eq
  function: NNTPTemporaryError.__name__.__eq__
  args: ["NNTPTemporaryError"]
  expected: true

invariant nntplib_extra.hierarchy.NNTPTemporaryError_base:
  description: "nntplib.NNTPTemporaryError.__bases__[0].__name__ == 'NNTPError'"
  category: hierarchy
  kind: python_call_eq
  function: NNTPTemporaryError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

# ---------------------------------------------------------------------------
# NNTPPermanentError — class name and hierarchy
# ---------------------------------------------------------------------------

invariant nntplib_extra.names.NNTPPermanentError:
  description: "nntplib.NNTPPermanentError.__name__ == 'NNTPPermanentError'"
  category: names
  kind: python_call_eq
  function: NNTPPermanentError.__name__.__eq__
  args: ["NNTPPermanentError"]
  expected: true

invariant nntplib_extra.hierarchy.NNTPPermanentError_base:
  description: "nntplib.NNTPPermanentError.__bases__[0].__name__ == 'NNTPError'"
  category: hierarchy
  kind: python_call_eq
  function: NNTPPermanentError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

# ---------------------------------------------------------------------------
# NNTPReplyError and NNTPDataError — class names
# ---------------------------------------------------------------------------

invariant nntplib_extra.names.NNTPReplyError:
  description: "nntplib.NNTPReplyError.__name__ == 'NNTPReplyError'"
  category: names
  kind: python_call_eq
  function: NNTPReplyError.__name__.__eq__
  args: ["NNTPReplyError"]
  expected: true

invariant nntplib_extra.names.NNTPDataError:
  description: "nntplib.NNTPDataError.__name__ == 'NNTPDataError'"
  category: names
  kind: python_call_eq
  function: NNTPDataError.__name__.__eq__
  args: ["NNTPDataError"]
  expected: true

# ---------------------------------------------------------------------------
# NNTPReplyError and NNTPDataError — hierarchy
# ---------------------------------------------------------------------------

invariant nntplib_extra.hierarchy.NNTPReplyError_base:
  description: "nntplib.NNTPReplyError.__bases__[0].__name__ == 'NNTPError'"
  category: hierarchy
  kind: python_call_eq
  function: NNTPReplyError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

invariant nntplib_extra.hierarchy.NNTPDataError_base:
  description: "nntplib.NNTPDataError.__bases__[0].__name__ == 'NNTPError'"
  category: hierarchy
  kind: python_call_eq
  function: NNTPDataError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"
