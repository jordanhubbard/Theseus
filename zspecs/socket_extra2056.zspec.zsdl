spec: socket_extra2056
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "socket.socket is a C type representing a network socket; it defines none of the sequence/mapping or attribute access protocol methods in its own __dict__."
    - "socket.error and socket.timeout are aliases for OSError and TimeoutError respectively; none of the target dunders appear in their own __dict__."
    - "socket.gaierror is a socket-specific exception subclass; none of the target dunders appear in its own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; none of the target dunders appear in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2056.getitem_protocol:
  description: "socket types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2056

  columns: [id, function, args, expected]
  rows:
    - ["sk2056001", "socket.socket.__dict__.__contains__",        ["__getitem__"], false]
