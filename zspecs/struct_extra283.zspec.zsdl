spec: struct_extra283
version: ">=3.9"
backend: python_module(struct)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/struct.py, Modules/_struct.c"
  notes:
    - "struct is a Python wrapper (Lib/struct.py) over the _struct C extension"
    - "__loader__ is SourceFileLoader because the top-level module is a .py file"
    - "__all__ is a list with 8 entries: calcsize, pack, pack_into, unpack, unpack_from, iter_unpack, Struct, error"
    - "All public functions (pack, unpack, etc.) are builtin_function_or_method from _struct"
    - "struct.Struct is a type; struct.error is a type (exception class)"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra283.module_identity:
  description: "struct module identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: stex283

  columns: [id, function, args, expected, description]
  rows:
    - [stex283_001, struct.__name__, [], struct, "struct module __name__"]
    - [stex283_002, struct.__package__, [], "", "struct module __package__ is empty string"]
    - [stex283_003, struct.__spec__.__class__.__name__, [], ModuleSpec, "struct __spec__ class"]
    - [stex283_004, struct.__loader__.__class__.__name__, [], SourceFileLoader, "struct __loader__ class (Python wrapper)"]
    - [stex283_005, struct.__all__.__class__.__name__, [], list, "struct __all__ is a list"]

table struct_extra283.all_membership_and_func_classes:
  description: "struct __all__ membership checks and function class names"
  kind: python_call_eq
  category: identity
  id_prefix: stex283b

  columns: [id, function, args, expected, description]
  rows:
    - [stex283b_001, struct.pack.__class__.__name__, [], builtin_function_or_method, "struct.pack class name"]
    - [stex283b_002, struct.unpack.__class__.__name__, [], builtin_function_or_method, "struct.unpack class name"]
    - [stex283b_003, struct.calcsize.__class__.__name__, [], builtin_function_or_method, "struct.calcsize class name"]
    - [stex283b_004, struct.pack_into.__class__.__name__, [], builtin_function_or_method, "struct.pack_into class name"]
    - [stex283b_005, struct.unpack_from.__class__.__name__, [], builtin_function_or_method, "struct.unpack_from class name"]
    - [stex283b_006, struct.iter_unpack.__class__.__name__, [], builtin_function_or_method, "struct.iter_unpack class name"]
    - [stex283b_007, struct.Struct.__class__.__name__, [], type, "struct.Struct class name"]
    - [stex283b_008, struct.error.__class__.__name__, [], type, "struct.error class name"]

invariant struct_extra283.all_len:
  description: "struct.__all__ has exactly 8 entries"
  category: identity
  kind: python_call_eq
  function: struct.__all__.__len__
  args: []
  expected: 8

invariant struct_extra283.calcsize_in_all:
  description: "calcsize is in struct.__all__"
  category: identity
  kind: python_call_eq
  function: struct.__all__.__contains__
  args: ["calcsize"]
  expected: true

invariant struct_extra283.Struct_in_all:
  description: "Struct is in struct.__all__"
  category: identity
  kind: python_call_eq
  function: struct.__all__.__contains__
  args: ["Struct"]
  expected: true
