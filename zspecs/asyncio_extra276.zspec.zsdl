    - [sw_module,          StreamWriter.__module__.__eq__,                ["asyncio.streams"],         true, "asyncio.StreamWriter.__module__ == 'asyncio.streams'"]
    - [sw_write_name,      StreamWriter.write.__name__.__eq__,            ["write"],                   true, "asyncio.StreamWriter.write.__name__ == 'write'"]
    - [sw_write_qn,        StreamWriter.write.__qualname__.__eq__,        ["StreamWriter.write"],      true, "asyncio.StreamWriter.write.__qualname__ == 'StreamWriter.write'"]
    - [sw_drain_name,      StreamWriter.drain.__name__.__eq__,            ["drain"],                   true, "asyncio.StreamWriter.drain.__name__ == 'drain'"]
    - [sw_drain_qn,        StreamWriter.drain.__qualname__.__eq__,        ["StreamWriter.drain"],      true, "asyncio.StreamWriter.drain.__qualname__ == 'StreamWriter.drain'"]
    - [sw_close_qn,        StreamWriter.close.__qualname__.__eq__,        ["StreamWriter.close"],      true, "asyncio.StreamWriter.close.__qualname__ == 'StreamWriter.close'"]
    - [sw_wait_closed_qn,  StreamWriter.wait_closed.__qualname__.__eq__,  ["StreamWriter.wait_closed"], true, "asyncio.StreamWriter.wait_closed.__qualname__ == 'StreamWriter.wait_closed'"]

