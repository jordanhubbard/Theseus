spec: asyncio_extra276
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "asyncio.StreamReader.__module__ == 'asyncio.streams' — pure-Python class in streams.py."
    - "asyncio.StreamReader.__bases__[0].__name__ == 'object' — direct subclass of object; no ABC base."
    - "asyncio.StreamReader.__mro__.__len__() == 2 — [StreamReader, object]."
    - "asyncio.StreamWriter.__module__ == 'asyncio.streams' — also in streams.py."
    - "asyncio.StreamWriter.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "asyncio.StreamWriter.__mro__.__len__() == 2 — [StreamWriter, object]."
    - "asyncio.open_connection is a coroutine function defined in asyncio.streams; its __module__ == 'asyncio.streams'."
    - "StreamReader method qualnames: read, readline, readexactly, readuntil, feed_data, set_exception, at_eof all use 'StreamReader.' prefix."
    - "StreamWriter method qualnames: write, drain, close, wait_closed, is_closing all use 'StreamWriter.' prefix."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.StreamReader class identity — table
#
# StreamReader is a pure-Python class in asyncio.streams.
# It inherits directly from object (no ABC base).
# ---------------------------------------------------------------------------

table asyncio_extra276.streamreader_identity:
  description: "asyncio.StreamReader class identity and method __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: srid

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name,            StreamReader.__name__.__eq__,                  ["StreamReader"],        true, "asyncio.StreamReader.__name__ == 'StreamReader'"]
    - [sr_module,          StreamReader.__module__.__eq__,                ["asyncio.streams"],     true, "asyncio.StreamReader.__module__ == 'asyncio.streams'"]
    - [sr_read_name,       StreamReader.read.__name__.__eq__,             ["read"],                true, "asyncio.StreamReader.read.__name__ == 'read'"]
    - [sr_read_qn,         StreamReader.read.__qualname__.__eq__,         ["StreamReader.read"],   true, "asyncio.StreamReader.read.__qualname__ == 'StreamReader.read'"]
    - [sr_readline_name,   StreamReader.readline.__name__.__eq__,         ["readline"],            true, "asyncio.StreamReader.readline.__name__ == 'readline'"]
    - [sr_readline_qn,     StreamReader.readline.__qualname__.__eq__,     ["StreamReader.readline"], true, "asyncio.StreamReader.readline.__qualname__ == 'StreamReader.readline'"]
    - [sr_at_eof_name,     StreamReader.at_eof.__name__.__eq__,           ["at_eof"],              true, "asyncio.StreamReader.at_eof.__name__ == 'at_eof'"]
    - [sr_feed_data_qn,    StreamReader.feed_data.__qualname__.__eq__,    ["StreamReader.feed_data"], true, "asyncio.StreamReader.feed_data.__qualname__ == 'StreamReader.feed_data'"]

