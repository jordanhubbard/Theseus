spec: hl3271
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 665 (hl3271): __rand__, __ror__, __rxor__ dict-presence checks for hashlib types."
    - "Theme: __rand__/__ror__/__rxor__ dict-presence (reflected bitwise logical)."
    - "All values False — hash objects, UUID, Struct, and socket types have no reflected bitwise logical protocol."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __rand__, __ror__, or __rxor__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3271.rand:
  description: "hashlib types __rand__ dict-presence checks; wave 665"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3271
  columns: [id, function, args, expected]
  rows:
    - ["hl3271001", operator.contains, [type(hashlib.md5()).__dict__,        "__rand__"], false]
    - ["hl3271002", operator.contains, [type(hashlib.sha1()).__dict__,       "__rand__"], false]
    - ["hl3271003", operator.contains, [type(hashlib.sha256()).__dict__,     "__rand__"], false]
    - ["hl3271004", operator.contains, [type(hashlib.sha512()).__dict__,     "__rand__"], false]
    - ["hl3271005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__rand__"], false]

