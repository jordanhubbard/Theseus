spec: decimal_extra2251
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal.zspec.zsdl"
    - "decimal_extra1876.zspec.zsdl"
  notes:
    - "Wave 2251, theme: callable protocol and function-attribute dict-presence."
    - "Checks __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in decimal class __dict__s."
    - "decimal.Decimal and decimal.Context are C extension types; neither defines callable-protocol or function-attribute dunders."
    - "Positive anchor rows verify real method membership (exp, ln, sqrt, quantize, normalize, etc.)."
  created_at: "2026-04-12"

table decimal_extra2251.callable_protocol_decimal:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["dc2251001", decimal.Decimal.__dict__.__contains__,  ["__call__"],       false]
    - ["dc2251002", decimal.Decimal.__dict__.__contains__,  ["__code__"],       false]
    - ["dc2251003", decimal.Decimal.__dict__.__contains__,  ["__globals__"],    false]
    - ["dc2251004", decimal.Decimal.__dict__.__contains__,  ["__defaults__"],   false]
    - ["dc2251005", decimal.Decimal.__dict__.__contains__,  ["__kwdefaults__"], false]
    - ["dc2251006", decimal.Decimal.__dict__.__contains__,  ["__annotations__"],false]
    - ["dc2251007", decimal.Decimal.__dict__.__contains__,  ["__builtins__"],   false]

table decimal_extra2251.callable_protocol_context:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["dc2251008", decimal.Context.__dict__.__contains__,  ["__call__"],       false]
    - ["dc2251009", decimal.Context.__dict__.__contains__,  ["__code__"],       false]
    - ["dc2251010", decimal.Context.__dict__.__contains__,  ["__globals__"],    false]
    - ["dc2251011", decimal.Context.__dict__.__contains__,  ["__defaults__"],   false]
    - ["dc2251012", decimal.Context.__dict__.__contains__,  ["__kwdefaults__"], false]
    - ["dc2251013", decimal.Context.__dict__.__contains__,  ["__annotations__"],false]
    - ["dc2251014", decimal.Context.__dict__.__contains__,  ["__builtins__"],   false]

table decimal_extra2251.positive_anchors_decimal:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["dc2251015", decimal.Decimal.__dict__.__contains__,  ["exp"],            true]
    - ["dc2251016", decimal.Decimal.__dict__.__contains__,  ["ln"],             true]
    - ["dc2251017", decimal.Decimal.__dict__.__contains__,  ["log10"],          true]
    - ["dc2251018", decimal.Decimal.__dict__.__contains__,  ["sqrt"],           true]
    - ["dc2251019", decimal.Decimal.__dict__.__contains__,  ["fma"],            true]
    - ["dc2251020", decimal.Decimal.__dict__.__contains__,  ["quantize"],       true]
    - ["dc2251021", decimal.Decimal.__dict__.__contains__,  ["normalize"],      true]
    - ["dc2251022", decimal.Decimal.__dict__.__contains__,  ["to_eng_string"],  true]
    - ["dc2251023", decimal.Decimal.__dict__.__contains__,  ["is_nan"],         true]
    - ["dc2251024", decimal.Decimal.__dict__.__contains__,  ["is_finite"],      true]
    - ["dc2251025", decimal.Decimal.__dict__.__contains__,  ["compare"],        true]

table decimal_extra2251.positive_anchors_context:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["dc2251026", decimal.Context.__dict__.__contains__,  ["abs"],            true]
    - ["dc2251027", decimal.Context.__dict__.__contains__,  ["exp"],            true]
    - ["dc2251028", decimal.Context.__dict__.__contains__,  ["ln"],             true]
    - ["dc2251029", decimal.Context.__dict__.__contains__,  ["sqrt"],           true]
    - ["dc2251030", decimal.Context.__dict__.__contains__,  ["quantize"],       true]
    - ["dc2251031", decimal.Context.__dict__.__contains__,  ["normalize"],      true]
    - ["dc2251032", decimal.Context.__dict__.__contains__,  ["prec"],           true]
    - ["dc2251033", decimal.Context.__dict__.__contains__,  ["plus"],           true]
    - ["dc2251034", decimal.Context.__dict__.__contains__,  ["minus"],          true]
    - ["dc2251035", decimal.Context.__dict__.__contains__,  ["add"],            true]
