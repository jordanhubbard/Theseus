spec: pathlib_extra131
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __code__ attributes (co_varnames and co_argcount)."
    - "Path methods are ordinary Python functions; their __code__ objects expose co_varnames and co_argcount."
    - "pathlib.Path.open.__code__.co_varnames[0] = 'self', co_argcount = 6 (self, mode, buffering, encoding, errors, newline)."
    - "pathlib.Path.open.__code__.co_varnames[1] = 'mode' — second param is 'mode'."
    - "pathlib.Path.read_text.__code__.co_varnames[0] = 'self', co_argcount = 4 (self, encoding, errors, newline)."
    - "pathlib.Path.read_text.__code__.co_varnames[1] = 'encoding' — second param is 'encoding'."
    - "pathlib.Path.write_text.__code__.co_varnames[0] = 'self', co_argcount = 5 (self, data, encoding, errors, newline)."
    - "pathlib.Path.write_text.__code__.co_varnames[1] = 'data' — second param is 'data'."
    - "pathlib.Path.mkdir.__code__.co_varnames[0] = 'self', co_argcount = 4 (self, mode, parents, exist_ok)."
    - "pathlib.Path.mkdir.__code__.co_varnames[1] = 'mode' — second param is 'mode'."
    - "pathlib.Path.read_bytes.__code__.co_argcount = 1 (only 'self')."
    - "pathlib.Path.write_bytes.__code__.co_argcount = 2 (self, data)."
    - "pathlib.Path.rename.__code__.co_argcount = 2 (self, target)."
    - "pathlib.Path.unlink.__code__.co_argcount = 2 (self, missing_ok)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path I/O method __code__.co_varnames[0] and co_argcount
# All methods have co_varnames[0] == 'self' (first parameter is always self).
# open=6, read_text=4, write_text=5 positional args.
# ---------------------------------------------------------------------------

table pathlib_extra131.Path_io_code_co_varnames:
  description: "pathlib.Path I/O method __code__.co_varnames[0] and co_argcount: open, read_text, write_text"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibcode131

  columns: [id, function, args, expected, description]
  rows:
    - [open_vars0_eq,     Path.open.__code__.co_varnames.__getitem__,     [0], "self",     "Path.open.__code__.co_varnames[0] == 'self'"]
    - [open_argc_eq,      Path.open.__code__.co_argcount.__eq__,          [6], true,       "Path.open.__code__.co_argcount == 6 (self, mode, buffering, encoding, errors, newline)"]
    - [open_vars1_eq,     Path.open.__code__.co_varnames.__getitem__,     [1], "mode",     "Path.open.__code__.co_varnames[1] == 'mode'"]
    - [rt_vars0_eq,       Path.read_text.__code__.co_varnames.__getitem__, [0], "self",    "Path.read_text.__code__.co_varnames[0] == 'self'"]
    - [rt_argc_eq,        Path.read_text.__code__.co_argcount.__eq__,     [4], true,       "Path.read_text.__code__.co_argcount == 4 (self, encoding, errors, newline)"]
    - [rt_vars1_eq,       Path.read_text.__code__.co_varnames.__getitem__, [1], "encoding","Path.read_text.__code__.co_varnames[1] == 'encoding'"]
    - [wt_vars0_eq,       Path.write_text.__code__.co_varnames.__getitem__,[0], "self",    "Path.write_text.__code__.co_varnames[0] == 'self'"]
    - [wt_argc_eq,        Path.write_text.__code__.co_argcount.__eq__,    [5], true,       "Path.write_text.__code__.co_argcount == 5 (self, data, encoding, errors, newline)"]
    - [wt_vars1_eq,       Path.write_text.__code__.co_varnames.__getitem__,[1], "data",    "Path.write_text.__code__.co_varnames[1] == 'data'"]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem method __code__.co_varnames[0] and co_argcount
# mkdir=4 (self, mode, parents, exist_ok).
# read_bytes=1 (self only). write_bytes=2 (self, data).
# rename=2 (self, target). unlink=2 (self, missing_ok).
# ---------------------------------------------------------------------------

table pathlib_extra131.Path_fs_code_co_varnames:
  description: "pathlib.Path filesystem method __code__.co_varnames[0] and co_argcount: mkdir, read_bytes, write_bytes, rename, unlink"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibcode131

  columns: [id, function, args, expected, description]
  rows:
    - [mkdir_vars0_eq,  Path.mkdir.__code__.co_varnames.__getitem__,      [0], "self",  "Path.mkdir.__code__.co_varnames[0] == 'self'"]
    - [mkdir_argc_eq,   Path.mkdir.__code__.co_argcount.__eq__,           [4], true,    "Path.mkdir.__code__.co_argcount == 4 (self, mode, parents, exist_ok)"]
    - [mkdir_vars1_eq,  Path.mkdir.__code__.co_varnames.__getitem__,      [1], "mode",  "Path.mkdir.__code__.co_varnames[1] == 'mode'"]
    - [rb_vars0_eq,     Path.read_bytes.__code__.co_varnames.__getitem__, [0], "self",  "Path.read_bytes.__code__.co_varnames[0] == 'self'"]
    - [rb_argc_eq,      Path.read_bytes.__code__.co_argcount.__eq__,      [1], true,    "Path.read_bytes.__code__.co_argcount == 1 (only self; no extra params)"]
    - [wb_vars0_eq,     Path.write_bytes.__code__.co_varnames.__getitem__,[0], "self",  "Path.write_bytes.__code__.co_varnames[0] == 'self'"]
    - [wb_argc_eq,      Path.write_bytes.__code__.co_argcount.__eq__,     [2], true,    "Path.write_bytes.__code__.co_argcount == 2 (self, data)"]
    - [wb_vars1_eq,     Path.write_bytes.__code__.co_varnames.__getitem__,[1], "data",  "Path.write_bytes.__code__.co_varnames[1] == 'data'"]
    - [rename_argc_eq,  Path.rename.__code__.co_argcount.__eq__,          [2], true,    "Path.rename.__code__.co_argcount == 2 (self, target)"]
    - [unlink_argc_eq,  Path.unlink.__code__.co_argcount.__eq__,          [2], true,    "Path.unlink.__code__.co_argcount == 2 (self, missing_ok)"]

# ---------------------------------------------------------------------------
# pathlib.Path co_argcount comparisons — verifying relative orderings
# open has the most positional args (6); read_bytes has fewest (1).
# write_text (5) > mkdir (4) > read_text (4) = mkdir.
# ---------------------------------------------------------------------------

table pathlib_extra131.Path_argcount_comparisons:
  description: "pathlib.Path method co_argcount values confirmed: open=6, write_text=5, mkdir=4, read_text=4, write_bytes=2, rename=2, unlink=2, read_bytes=1"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibcode131

  columns: [id, function, args, expected, description]
  rows:
    - [open_argc_6,      Path.open.__code__.co_argcount.__eq__,       [6], true,  "Path.open co_argcount == 6"]
    - [wt_argc_5,        Path.write_text.__code__.co_argcount.__eq__, [5], true,  "Path.write_text co_argcount == 5"]
    - [mkdir_argc_4,     Path.mkdir.__code__.co_argcount.__eq__,      [4], true,  "Path.mkdir co_argcount == 4"]
    - [rt_argc_4,        Path.read_text.__code__.co_argcount.__eq__,  [4], true,  "Path.read_text co_argcount == 4"]
    - [rb_argc_1,        Path.read_bytes.__code__.co_argcount.__eq__,[1],  true,  "Path.read_bytes co_argcount == 1"]
    - [open_argc_not_5,  Path.open.__code__.co_argcount.__eq__,       [5], false, "Path.open co_argcount != 5"]
    - [rb_argc_not_0,    Path.read_bytes.__code__.co_argcount.__eq__, [0], false, "Path.read_bytes co_argcount != 0 (has 'self')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra131.Path.open_co_varnames_0:
  description: "pathlib.Path.open.__code__.co_varnames[0] == 'self' (the first parameter of every Path instance method is 'self')"
  category: code_attrs
  kind: python_call_eq
  function: Path.open.__code__.co_varnames.__getitem__
  args: [0]
  expected: "self"

invariant pathlib_extra131.Path.open_co_argcount:
  description: "pathlib.Path.open.__code__.co_argcount == 6 (self, mode, buffering, encoding, errors, newline — six named positional parameters)"
  category: code_attrs
  kind: python_call_eq
  function: Path.open.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant pathlib_extra131.Path.read_text_co_varnames_1:
  description: "pathlib.Path.read_text.__code__.co_varnames[1] == 'encoding' (the second parameter of read_text is the encoding argument)"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_text.__code__.co_varnames.__getitem__
  args: [1]
  expected: "encoding"

invariant pathlib_extra131.Path.read_bytes_co_argcount:
  description: "pathlib.Path.read_bytes.__code__.co_argcount == 1 (read_bytes takes only 'self'; no encoding or mode parameters needed for raw bytes)"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_bytes.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra131.Path.write_text_co_varnames_1:
  description: "pathlib.Path.write_text.__code__.co_varnames[1] == 'data' (the second parameter of write_text is the data to be written)"
  category: code_attrs
  kind: python_call_eq
  function: Path.write_text.__code__.co_varnames.__getitem__
  args: [1]
  expected: "data"
