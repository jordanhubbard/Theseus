spec: argparse_extra2
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers class __name__ checks, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, ArgumentError/ArgumentTypeError MRO"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/__module__, Namespace/__module__, HelpFormatter/__module__, ArgumentError/__module__, Action/__module__, Action/__bases__[0].__name__, ArgumentDefaultsHelpFormatter/__name__, FileType/__name__+__module__, ArgumentParser parse_args/__name__, add_argument/__name__"
  notes:
    - "This spec extends argparse.zspec.zsdl and argparse_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "ArgumentParser.__module__ == 'argparse' is covered in argparse_extra; this spec adds remaining class __module__ checks not covered there."
    - "ArgumentTypeError.__module__ == 'argparse' — exception defined in the argparse module."
    - "RawTextHelpFormatter.__module__ == 'argparse' — formatter class defined in the argparse module."
    - "RawDescriptionHelpFormatter.__module__ == 'argparse' — formatter class defined in the argparse module."
    - "ArgumentDefaultsHelpFormatter.__module__ == 'argparse' — formatter class defined in the argparse module."
    - "MetavarTypeHelpFormatter.__module__ == 'argparse' — formatter class defined in the argparse module."
    - "ArgumentParser.__bases__[0].__name__ == '_ActionsContainer' — ArgumentParser inherits from the internal _ActionsContainer."
    - "Namespace.__bases__[0].__name__ == 'object' — Namespace inherits directly from object."
    - "ArgumentError.__bases__[0].__name__ == 'Exception' — ArgumentError inherits directly from Exception."
    - "ArgumentTypeError.__bases__[0].__name__ == 'Exception' — ArgumentTypeError inherits directly from Exception."
    - "HelpFormatter.__bases__[0].__name__ == 'object' — HelpFormatter inherits directly from object."
    - "RawTextHelpFormatter.__bases__[0].__name__ == 'HelpFormatter' — inherits from HelpFormatter."
    - "RawDescriptionHelpFormatter.__bases__[0].__name__ == 'HelpFormatter' — inherits from HelpFormatter."
    - "All expected values verified by running Python 3.12 argparse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ checks not already covered by argparse_extra.zspec.zsdl
#
# argparse_extra covers: ArgumentParser, Namespace, HelpFormatter, ArgumentError, Action.
# This spec adds: ArgumentTypeError, RawTextHelpFormatter, RawDescriptionHelpFormatter,
#                 ArgumentDefaultsHelpFormatter, MetavarTypeHelpFormatter.
# ---------------------------------------------------------------------------

table argparse_extra2.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [argumenttypeerror,             ArgumentTypeError.__module__.__eq__,             ["argparse"], true]
    - [rawtexthelpformatter,          RawTextHelpFormatter.__module__.__eq__,          ["argparse"], true]
    - [rawdescriptionhelpformatter,   RawDescriptionHelpFormatter.__module__.__eq__,   ["argparse"], true]
    - [argumentdefaultshelpformatter, ArgumentDefaultsHelpFormatter.__module__.__eq__, ["argparse"], true]
    - [metavartypehelpformatter,      MetavarTypeHelpFormatter.__module__.__eq__,      ["argparse"], true]

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__ checks
#
# ArgumentParser inherits from _ActionsContainer (internal class).
# Namespace, HelpFormatter inherit from object.
# ArgumentError, ArgumentTypeError inherit from Exception.
# RawTextHelpFormatter, RawDescriptionHelpFormatter inherit from HelpFormatter.
# ---------------------------------------------------------------------------

invariant argparse_extra2.ArgumentParser.base_is_ActionsContainer:
  description: "argparse.ArgumentParser.__bases__[0].__name__ == '_ActionsContainer'"
  category: class_hierarchy
  kind: python_call_eq
  function: ArgumentParser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_ActionsContainer"

invariant argparse_extra2.Namespace.base_is_object:
  description: "argparse.Namespace.__bases__[0].__name__ == 'object' — Namespace inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Namespace.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant argparse_extra2.ArgumentError.base_is_Exception:
  description: "argparse.ArgumentError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: ArgumentError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant argparse_extra2.ArgumentTypeError.base_is_Exception:
  description: "argparse.ArgumentTypeError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: ArgumentTypeError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant argparse_extra2.HelpFormatter.base_is_object:
  description: "argparse.HelpFormatter.__bases__[0].__name__ == 'object' — HelpFormatter inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: HelpFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant argparse_extra2.RawTextHelpFormatter.base_is_HelpFormatter:
  description: "argparse.RawTextHelpFormatter.__bases__[0].__name__ == 'HelpFormatter'"
  category: class_hierarchy
  kind: python_call_eq
  function: RawTextHelpFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HelpFormatter"

invariant argparse_extra2.RawDescriptionHelpFormatter.base_is_HelpFormatter:
  description: "argparse.RawDescriptionHelpFormatter.__bases__[0].__name__ == 'HelpFormatter'"
  category: class_hierarchy
  kind: python_call_eq
  function: RawDescriptionHelpFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HelpFormatter"

invariant argparse_extra2.ArgumentDefaultsHelpFormatter.base_is_HelpFormatter:
  description: "argparse.ArgumentDefaultsHelpFormatter.__bases__[0].__name__ == 'HelpFormatter'"
  category: class_hierarchy
  kind: python_call_eq
  function: ArgumentDefaultsHelpFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HelpFormatter"

# ---------------------------------------------------------------------------
# Additional class __name__ checks for formatter subclasses
# (argparse.zspec.zsdl has RawDescriptionHelpFormatter, RawTextHelpFormatter,
#  ArgumentDefaultsHelpFormatter, MetavarTypeHelpFormatter __name__ in the table;
#  argparse_extra.zspec.zsdl adds ArgumentDefaultsHelpFormatter.__name__ as standalone.
#  This spec adds MetavarTypeHelpFormatter.__name__ as a standalone invariant for
#  completeness and cross-spec anchoring.)
# ---------------------------------------------------------------------------

invariant argparse_extra2.MetavarTypeHelpFormatter.name:
  description: "argparse.MetavarTypeHelpFormatter.__name__ == 'MetavarTypeHelpFormatter'"
  category: class_names
  kind: python_call_eq
  function: MetavarTypeHelpFormatter.__name__.__eq__
  args: ["MetavarTypeHelpFormatter"]
  expected: true

invariant argparse_extra2.RawTextHelpFormatter.name:
  description: "argparse.RawTextHelpFormatter.__name__ == 'RawTextHelpFormatter'"
  category: class_names
  kind: python_call_eq
  function: RawTextHelpFormatter.__name__.__eq__
  args: ["RawTextHelpFormatter"]
  expected: true

invariant argparse_extra2.ArgumentTypeError.name:
  description: "argparse.ArgumentTypeError.__name__ == 'ArgumentTypeError'"
  category: class_names
  kind: python_call_eq
  function: ArgumentTypeError.__name__.__eq__
  args: ["ArgumentTypeError"]
  expected: true
