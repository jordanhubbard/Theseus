spec: datetime_extra5
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl, datetime_extra.zspec.zsdl, datetime_extra2.zspec.zsdl, datetime_extra3.zspec.zsdl, datetime_extra4.zspec.zsdl, and datetime_timedelta.zspec.zsdl."
    - "Focus: datetime.timezone, datetime.tzinfo class attributes, and datetime.MAXYEAR/MINYEAR module constants."
    - "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — timezone inherits directly from tzinfo."
    - "datetime.MAXYEAR == 9999 and datetime.MINYEAR == 1 are module-level integer constants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# datetime.timezone — class identity attributes
# ---------------------------------------------------------------------------

invariant datetime_extra5.timezone.class_name:
  description: "datetime.timezone.__name__ == 'timezone'"
  category: timezone
  kind: python_call_eq
  function: timezone.__name__.__eq__
  args: ["timezone"]
  expected: true

invariant datetime_extra5.timezone.module:
  description: "datetime.timezone.__module__ == 'datetime'"
  category: timezone
  kind: python_call_eq
  function: timezone.__module__.__eq__
  args: ["datetime"]
  expected: true

invariant datetime_extra5.timezone.base_is_tzinfo:
  description: "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — timezone inherits from tzinfo"
  category: timezone
  kind: python_call_eq
  function: timezone.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tzinfo"

# ---------------------------------------------------------------------------
# datetime.tzinfo — class identity attributes
# ---------------------------------------------------------------------------

invariant datetime_extra5.tzinfo.class_name:
  description: "datetime.tzinfo.__name__ == 'tzinfo'"
  category: tzinfo
  kind: python_call_eq
  function: tzinfo.__name__.__eq__
  args: ["tzinfo"]
  expected: true

invariant datetime_extra5.tzinfo.module:
  description: "datetime.tzinfo.__module__ == 'datetime'"
  category: tzinfo
  kind: python_call_eq
  function: tzinfo.__module__.__eq__
  args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.timezone.utc — the canonical UTC sentinel
# ---------------------------------------------------------------------------

invariant datetime_extra5.timezone_utc.class_name:
  description: "datetime.timezone.utc.__class__.__name__ == 'timezone'"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.__class__.__name__.__eq__
  args: ["timezone"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.MAXYEAR and datetime.MINYEAR — module-level integer constants
# ---------------------------------------------------------------------------

invariant datetime_extra5.MAXYEAR.value:
  description: "datetime.MAXYEAR == 9999"
  category: constants
  kind: python_call_eq
  function: MAXYEAR.__eq__
  args: [9999]
  expected: true

invariant datetime_extra5.MINYEAR.value:
  description: "datetime.MINYEAR == 1"
  category: constants
  kind: python_call_eq
  function: MINYEAR.__eq__
  args: [1]
  expected: true

invariant datetime_extra5.MAXYEAR.class_name:
  description: "datetime.MAXYEAR.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAXYEAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant datetime_extra5.MINYEAR.class_name:
  description: "datetime.MINYEAR.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MINYEAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# class_names table — timezone and tzinfo
# ---------------------------------------------------------------------------

table datetime_extra5.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [timezone, timezone.__name__.__eq__, ["timezone"], true]
    - [tzinfo,   tzinfo.__name__.__eq__,   ["tzinfo"],   true]
