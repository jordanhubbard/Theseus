spec: pp2851
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/pathlib_extra2836.zspec.zsdl — wave 636 predecessor (covered __rtruediv__, __rfloordiv__, __rmod__)"
    - "CPython source: Lib/pathlib/"
  notes:
    - "Wave 637 theme: __rlshift__, __rrshift__, and __rpow__ dict-presence checks (reflected left-shift, right-shift, and power operators)."
    - "pathlib path types define __truediv__ and __rtruediv__ for the / path-joining operator — no other reflected arithmetic operators are defined."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, and WindowsPath do NOT define __rlshift__, __rrshift__, or __rpow__."
    - "Bitwise shift and exponentiation have no path semantics whatsoever — absence is total across all six pathlib classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rlshift__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pp2851.rlshift_protocol:
  description: "__rlshift__ is absent from all pathlib path class __dict__s — path objects have no left-shift semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2851

  columns: [id, function, args, expected]
  rows:
    - ["pp2851001", "pathlib.PurePath.__dict__.__contains__",        ["__rlshift__"], false]
    - ["pp2851002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rlshift__"], false]
    - ["pp2851003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rlshift__"], false]
    - ["pp2851004", "pathlib.Path.__dict__.__contains__",            ["__rlshift__"], false]
    - ["pp2851005", "pathlib.PosixPath.__dict__.__contains__",       ["__rlshift__"], false]
    - ["pp2851006", "pathlib.WindowsPath.__dict__.__contains__",     ["__rlshift__"], false]

