# ---------------------------------------------------------------------------
# Table: combined — shift/power ops vs path-joining operator on PurePath
# Contrasts the defined __truediv__/__rtruediv__ with the absent shift/pow ops,
# confirming that only the / operator has path-joining semantics
# ---------------------------------------------------------------------------

table pp2851.path_operator_contrast:
  description: "pathlib.PurePath defines only path-joining operators; reflected shift and power are entirely absent across all six classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2851

  columns: [id, function, args, expected]
  rows:
    - ["pp2851019", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2851020", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pp2851021", "pathlib.PurePath.__dict__.__contains__", ["__rlshift__"],  false]
    - ["pp2851022", "pathlib.PurePath.__dict__.__contains__", ["__rrshift__"],  false]
    - ["pp2851023", "pathlib.PurePath.__dict__.__contains__", ["__rpow__"],     false]
    - ["pp2851024", "pathlib.Path.__dict__.__contains__",     ["__rlshift__"],  false]
    - ["pp2851025", "pathlib.Path.__dict__.__contains__",     ["__rrshift__"],  false]
    - ["pp2851026", "pathlib.Path.__dict__.__contains__",     ["__rpow__"],     false]
