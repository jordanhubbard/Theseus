spec: lib2to3_extra2
version: ">=3.9,<3.13"
backend: python_module(lib2to3.pytree)

docs: https://docs.python.org/3/library/2to3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/2to3.html — Python lib2to3 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lib2to3/pytree.py"
  notes:
    - "This spec extends lib2to3.zspec.zsdl (which uses backend python_module(lib2to3.refactor))."
    - "lib2to3.zspec.zsdl covers: RefactoringTool.__name__/__module__, MultiprocessRefactoringTool.__name__/__module__/__bases__, RefactoringTool method names table."
    - "This spec targets lib2to3.pytree, a separate submodule providing the parse-tree node types used internally by lib2to3."
    - "lib2to3.pytree.Base is the abstract base class for all parse-tree nodes."
    - "lib2to3.pytree.Node represents an interior (non-leaf) parse-tree node."
    - "lib2to3.pytree.Leaf represents a leaf (terminal) parse-tree node."
    - "lib2to3.pytree.NodePattern matches Node objects in patterns."
    - "lib2to3.pytree.LeafPattern matches Leaf objects in patterns."
    - "lib2to3 is deprecated since Python 3.11 and removed in Python 3.13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "lib2to3.pytree raises TypeError on invalid node construction."
  stderr: "null"
  stickiness: "N/A — class metadata checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class __name__ checks — Base, Node, Leaf
# ---------------------------------------------------------------------------

table lib2to3_extra2.class_names:
  description: "lib2to3.pytree core node classes have correct __name__ values"
  kind: python_call_eq
  category: classnames
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Base, Base.__name__.__eq__, ["Base"], true]
    - [Node, Node.__name__.__eq__, ["Node"], true]
    - [Leaf, Leaf.__name__.__eq__, ["Leaf"], true]

# ---------------------------------------------------------------------------
# Pattern class __name__ checks — NodePattern, LeafPattern
# ---------------------------------------------------------------------------

table lib2to3_extra2.pattern_class_names:
  description: "lib2to3.pytree pattern classes have correct __name__ values"
  kind: python_call_eq
  category: classnames
  id_prefix: pname

  columns: [id, function, args, expected]
  rows:
    - [NodePattern, NodePattern.__name__.__eq__, ["NodePattern"], true]
    - [LeafPattern, LeafPattern.__name__.__eq__, ["LeafPattern"], true]

# ---------------------------------------------------------------------------
# Class __module__ checks — Base, Node, Leaf
# All are defined in lib2to3.pytree.
# ---------------------------------------------------------------------------

table lib2to3_extra2.class_modules:
  description: "lib2to3.pytree core node classes have __module__ == 'lib2to3.pytree'"
  kind: python_call_eq
  category: class_attrs
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [Base, Base.__module__.__eq__, ["lib2to3.pytree"], true]
    - [Node, Node.__module__.__eq__, ["lib2to3.pytree"], true]
    - [Leaf, Leaf.__module__.__eq__, ["lib2to3.pytree"], true]

# ---------------------------------------------------------------------------
# Class __qualname__ checks — Base, Node, Leaf
# Top-level classes have __qualname__ == __name__.
# ---------------------------------------------------------------------------

table lib2to3_extra2.class_qualnames:
  description: "lib2to3.pytree core node classes have __qualname__ equal to __name__"
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [Base, Base.__qualname__.__eq__, ["Base"], true]
    - [Node, Node.__qualname__.__eq__, ["Node"], true]
    - [Leaf, Leaf.__qualname__.__eq__, ["Leaf"], true]

# ---------------------------------------------------------------------------
# Class hierarchy — Node and Leaf inherit from Base
# ---------------------------------------------------------------------------

invariant lib2to3_extra2.Node.base_is_Base:
  description: "lib2to3.pytree.Node.__bases__[0].__name__ == 'Base' — Node inherits from Base"
  category: class_hierarchy
  kind: python_call_eq
  function: Node.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Base"

invariant lib2to3_extra2.Leaf.base_is_Base:
  description: "lib2to3.pytree.Leaf.__bases__[0].__name__ == 'Base' — Leaf inherits from Base"
  category: class_hierarchy
  kind: python_call_eq
  function: Leaf.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Base"
