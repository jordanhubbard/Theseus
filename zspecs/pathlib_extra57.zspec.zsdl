spec: pathlib_extra57
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname/module for Path/PurePath/PurePosixPath/PureWindowsPath/pathlib-module and Path.open/read_text/exists __qualname__.__eq__()."
    - "pathlib_extra55.zspec.zsdl — covers 12 Path method qualname lengths (open=9, read_text=14, write_text=15, read_bytes=15, write_bytes=16, mkdir=10, unlink=11, exists=11, is_file=12, is_dir=11, stat=9, rename=11)."
    - "pathlib_extra54.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type'); Path.cwd/__class__.__qualname__.__eq__('method'); Path.home/__class__.__qualname__.__eq__('method'); Path/__class__.__module__.__eq__('builtins'); PurePath/__class__.__module__.__eq__('builtins')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __class__.__name__.__eq__('type') and __class__.__name__.__len__()==4; Path.cwd/__class__.__name__.__eq__('method'); Path.home/__class__.__name__.__eq__('method')."
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__(); Path.cwd/__qualname__.__len__()==8; Path.home/__qualname__.__len__()==9."
    - "pathlib_extra49.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__eq__(); Path.cwd/__qualname__.__eq__('Path.cwd'); Path.home/__qualname__.__eq__('Path.home')."
  notes:
    - "This spec extends pathlib_extra56.zspec.zsdl."
    - "Prior specs collectively covered: all pathlib class __qualname__ equality and lengths (pathlib_extra49/pathlib_extra50); class __class__.__name__/__qualname__ equality (pathlib_extra53/pathlib_extra54); Path.cwd and Path.home __qualname__ equality and length; Path file-operation method __qualname__ lengths (pathlib_extra55); pathlib class __doc__.__class__.__name__/__qualname__/__module__ (pathlib_extra56); Path.open/read_text/exists __qualname__.__eq__() (pathlib_extra56). NO prior pathlib spec checks __qualname__.__eq__() for write_text/read_bytes/write_bytes/mkdir/unlink/is_file/is_dir/stat/rename."
    - "This spec covers: pathlib.Path.write_text.__qualname__.__eq__('Path.write_text') (NOVEL — pathlib_extra55 covers __qualname__.__len__()==15; pathlib_extra56 covers read_text/open/exists; no prior pathlib spec checks __qualname__.__eq__() for write_text; novel); pathlib.Path.read_bytes.__qualname__.__eq__('Path.read_bytes') (NOVEL); pathlib.Path.write_bytes.__qualname__.__eq__('Path.write_bytes') (NOVEL); pathlib.Path.mkdir.__qualname__.__eq__('Path.mkdir') (NOVEL); pathlib.Path.unlink.__qualname__.__eq__('Path.unlink') (NOVEL); pathlib.Path.is_file.__qualname__.__eq__('Path.is_file') (NOVEL); pathlib.Path.is_dir.__qualname__.__eq__('Path.is_dir') (NOVEL); pathlib.Path.stat.__qualname__.__eq__('Path.stat') (NOVEL); pathlib.Path.rename.__qualname__.__eq__('Path.rename') (NOVEL)."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text'. pathlib_extra55 records length 15; pathlib_extra56 does not cover write_text (covers open/read_text/exists). Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes'. pathlib_extra55 records length 15. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes'. pathlib_extra55 records length 16. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir'. pathlib_extra55 records length 10. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink'. pathlib_extra55 records length 11. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_file.__qualname__ == 'Path.is_file'. pathlib_extra55 records length 12. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir'. pathlib_extra55 records length 11. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat'. pathlib_extra55 records length 9. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename'. pathlib_extra55 records length 11. Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ string equality (complementing extra55 lengths)
#
# Path is a Python class in pathlib. Its concrete file-operation methods carry
# __qualname__ strings of the form 'Path.<methodname>'. pathlib_extra55 records
# the lengths; pathlib_extra56 covers open/read_text/exists equality. This spec
# records the exact __qualname__ strings for the remaining nine methods:
#
#   Path.write_text.__qualname__  == 'Path.write_text'
#   Path.read_bytes.__qualname__  == 'Path.read_bytes'
#   Path.write_bytes.__qualname__ == 'Path.write_bytes'
#   Path.mkdir.__qualname__       == 'Path.mkdir'
#   Path.unlink.__qualname__      == 'Path.unlink'
#   Path.is_file.__qualname__     == 'Path.is_file'
#   Path.is_dir.__qualname__      == 'Path.is_dir'
#   Path.stat.__qualname__        == 'Path.stat'
#   Path.rename.__qualname__      == 'Path.rename'
#
# pathlib_extra49 covers class-level __qualname__.__eq__() (e.g. Path.__qualname__).
# pathlib_extra55 covers __qualname__.__len__() for all twelve file-operation methods.
# pathlib_extra56 covers __qualname__.__eq__() for Path.open/read_text/exists.
# No prior pathlib spec checks __qualname__.__eq__() for any of these nine methods.
# All nine equality anchors are novel in the pathlib_extra57 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra57.path_method_qualname_eq:
  description: "pathlib.Path method __qualname__.__eq__() for write_text/read_bytes/write_bytes/mkdir/unlink/is_file/is_dir/stat/rename — qualname strings are 'Path.<method>'; pathlib_extra49 covers class-level __qualname__.__eq__; pathlib_extra55 covers __qualname__.__len__(); pathlib_extra56 covers open/read_text/exists; no prior pathlib spec checks __qualname__.__eq__() for any of these nine methods; all nine novel equality anchors in pathlib_extra57 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibmeth57

  columns: [id, function, args, expected]
  rows:
    - [Path_write_text_qualname_eq,  "Path.write_text.__qualname__.__eq__",  ["Path.write_text"],  true]
    - [Path_read_bytes_qualname_eq,  "Path.read_bytes.__qualname__.__eq__",  ["Path.read_bytes"],  true]
    - [Path_write_bytes_qualname_eq, "Path.write_bytes.__qualname__.__eq__", ["Path.write_bytes"], true]
    - [Path_mkdir_qualname_eq,       "Path.mkdir.__qualname__.__eq__",       ["Path.mkdir"],       true]
    - [Path_unlink_qualname_eq,      "Path.unlink.__qualname__.__eq__",      ["Path.unlink"],      true]
    - [Path_is_file_qualname_eq,     "Path.is_file.__qualname__.__eq__",     ["Path.is_file"],     true]
    - [Path_is_dir_qualname_eq,      "Path.is_dir.__qualname__.__eq__",      ["Path.is_dir"],      true]
    - [Path_stat_qualname_eq,        "Path.stat.__qualname__.__eq__",        ["Path.stat"],        true]
    - [Path_rename_qualname_eq,      "Path.rename.__qualname__.__eq__",      ["Path.rename"],      true]
