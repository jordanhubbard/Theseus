  notes:
    - "abc.abstractmethod.__name__ == 'abstractmethod' (len=14: abstractmethod=14)."
    - "abc.abstractmethod.__module__ == 'abc' (len=3: a(1)b(2)c(3)); defined in the abc module itself."
    - "abc.abstractmethod.__class__.__name__ == 'function' (len=8); abstractmethod is a plain Python function used as a decorator."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14); same as __name__ — top-level function, not a method."
    - "abc.get_cache_token.__name__ == 'get_cache_token' (len=15: get_cache_token=15)."
    - "abc.get_cache_token.__module__ == '_abc' (len=4: _=1+a=1+b=1+c=1=4); get_cache_token is C-accelerated in the _abc extension."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (len=26); C extension functions have this class name."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15); same as __name__ — top-level builtin."
    - "Length ordering: abc (3) < _abc (4) < function (8) < abstractmethod==get_cache_token name (14==15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

