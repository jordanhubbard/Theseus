invariant abc_extra187.abstractmethod_name_eq:
  description: "abc.abstractmethod.__name__.__eq__('abstractmethod') returns True — abc.abstractmethod.__name__=='abstractmethod' (len=14: a(1)b(2)s(3)t(4)r(5)a(6)c(7)t(8)m(9)e(10)t(11)h(12)o(13)d(14)); abstractmethod is the decorator that marks methods as abstract in an ABCMeta class; applying @abstractmethod to a method sets method.__isabstractmethod__=True, and ABCMeta aggregates these to prevent instantiation of classes with unimplemented abstract methods; abstractmethod.__name__ (14) < get_cache_token.__name__ (15) by 1; NEW in abcabstractmethod187: first standalone abstractmethod.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra187.abstractmethod_module_eq:
  description: "abc.abstractmethod.__module__.__eq__('abc') returns True — abc.abstractmethod.__module__=='abc' (len=3: a(1)b(2)c(3)); abstractmethod is a pure Python function defined in Lib/abc.py (the 'abc' module); this contrasts with abc.get_cache_token whose __module__=='_abc' (the C extension); 'abc' (3) is one of the shortest module names in the Python stdlib; abstractmethod.__module__ (3) < get_cache_token.__module__ (4) by 1 — pure Python 'abc' vs C extension '_abc'; the abc module re-exports get_cache_token from _abc while implementing abstractmethod itself in Python; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra187.abstractmethod_class_is_function:
  description: "abc.abstractmethod.__class__.__name__.__eq__('function') returns True — abc.abstractmethod.__class__.__name__=='function' (len=8); abstractmethod is implemented as a plain Python function (not a class or descriptor) in Lib/abc.py; when applied as @abstractmethod, it simply sets __isabstractmethod__=True on the wrapped callable and returns it; the function class name 'function' (8) is much shorter than 'builtin_function_or_method' (26) which identifies get_cache_token; abstractmethod.__class__.__name__ (8) == Lock.__module__ length (13)? No — 'function'=8; compare: type(abc.ABC).__name__=='ABCMeta'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra187.abstractmethod_qualname_eq:
  description: "abc.abstractmethod.__qualname__.__eq__('abstractmethod') returns True — abc.abstractmethod.__qualname__=='abstractmethod' (len=14; same as __name__=='abstractmethod'); for top-level module-level functions, __qualname__ equals __name__ because there is no enclosing class or function scope to add as a prefix; contrast with class methods: Pool.__init__.__qualname__=='Pool.__init__' (13) differs from Pool.__init__.__name__=='__init__' (8); abstractmethod.__qualname__==abstractmethod.__name__ is an identity-confirming structural property; NEW in abcabstractmethod187: standalone qualname invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra187.get_cache_token_name_eq:
  description: "abc.get_cache_token.__name__.__eq__('get_cache_token') returns True — abc.get_cache_token.__name__=='get_cache_token' (len=15: get=3+_=1+cache=5+_=1+token=5=15); get_cache_token is a C-accelerated function (implemented in Modules/_abc.c) that returns the current ABCMeta cache invalidation token — an integer that increments each time a new virtual subclass is registered with register(); this token is used by issubclass() and isinstance() to detect stale caches; get_cache_token.__name__ (15) > abstractmethod.__name__ (14) by 1; NEW in abcabstractmethod187: standalone get_cache_token.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra187.get_cache_token_module_eq:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token.__module__=='_abc' (len=4: _=1+a=1+b=1+c=1=4); get_cache_token is defined in the C extension module Modules/_abc.c and exposed as _abc.get_cache_token; the abc.py Python module imports it: 'from _abc import get_cache_token'; '_abc' (4) has the underscore prefix indicating a private C extension; get_cache_token.__module__ (4) > abstractmethod.__module__ (3) by 1 — '_abc' vs 'abc'; both share the 'abc' substring; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra187.get_cache_token_class_is_builtin:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26: builtin=7+_=1+function=8+_=1+or=2+_=1+method=6=26); this is the standard Python class name for C extension functions and built-in methods; 'builtin_function_or_method' (26) is the longest value in this spec by far; compare abstractmethod.__class__.__name__=='function' (8) — a Python function is much shorter; the 26-char class name reflects that C builtins can be either module-level functions or bound methods of C objects; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra187.get_cache_token_qualname_eq:
  description: "abc.get_cache_token.__qualname__.__eq__('get_cache_token') returns True — abc.get_cache_token.__qualname__=='get_cache_token' (len=15; same as __name__=='get_cache_token'); like abstractmethod, get_cache_token is a top-level function so __qualname__==__name__; get_cache_token.__qualname__ (15) > abstractmethod.__qualname__ (14) by 1 — 'get_cache_token' (15) vs 'abstractmethod' (14); both are top-level names with qualname==name; NEW in abcabstractmethod187: standalone get_cache_token.__qualname__ invariant completing 8-invariant coverage for abc.abstractmethod and abc.get_cache_token; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

