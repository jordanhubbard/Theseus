spec: smaz
version: ">=1.0.0"
backend: node(smaz)

docs: https://github.com/personalcomputer/smaz.js#readme

provenance:
  derived_from:
    - "smaz.js README — https://github.com/personalcomputer/smaz.js#readme"
    - "Salvatore Sanfilippo's SMAZ — a small-string compressor"
    - "Test vectors verified with smaz via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "smaz source"
  notes:
    - "SMAZ is a static-codebook compressor designed for very short English strings (<= ~1KB)."
    - "Install: npm install smaz"
    - "compress(s) returns a Uint8Array; decompress(buf) returns a string."
    - "Codebook is fixed: there's no per-call training — outputs are deterministic for a given input."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# compress.length contracts — small English strings shrink
invariant smaz.hello_world_compresses:
  description: "compress('hello world') produces a 7-byte buffer (codebook hits)"
  category: compress_size
  kind: node_chain_eq
  entry: named
  function: compress
  entry_args: ["hello world"]
  chain:
    - {get: length}
  expected: 7

invariant smaz.this_is_a_test_compresses:
  description: "compress('this is a test') produces a 6-byte buffer"
  category: compress_size
  kind: node_chain_eq
  entry: named
  function: compress
  entry_args: ["this is a test"]
  chain:
    - {get: length}
  expected: 6

# Round-trip via decompress with known compressed bytes
invariant smaz.roundtrip_hello_world:
  description: "decompress recovers 'hello world' from known SMAZ bytes"
  category: roundtrip
  kind: node_chain_eq
  entry: named
  function: decompress
  entry_args: [[16, 152, 96, 65, 42, 22, 24]]
  chain: []
  expected: "hello world"
