spec: hashlib_extra10
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "FIPS 202 — SHA-3 Standard, NIST, August 2015"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC, November 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3/sha3module.c"
    - "CPython source: Modules/_blake2/blake2module.c"
  notes:
    - "This spec extends hashlib through hashlib_extra9; it does NOT duplicate invariants present in those files."
    - "hashlib_extra.zspec.zsdl covers sha3_224/sha3_384 digest_size/block_size and name; sha3_224 name == 'sha3_224'."
    - "hashlib_extra7 covers new('sha3_256').digest_size, new('sha3_512') name, new('sha1').block_size, new('sha224').digest_size/block_size."
    - "hashlib_extra7 covers sha384/sha224 digest_size via direct constructors."
    - "hashlib_extra6 covers sha3_256.__name__ == 'sha3_256' and sha3_256.__module__ == '_sha3'."
    - "No prior spec covers: sha3_224.__name__, sha3_224.__module__, sha3_384.__name__, sha3_384.__module__."
    - "No prior spec covers: new('sha3_224').digest_size or new('sha3_384').digest_size via new()."
    - "No prior spec covers: sha512(b'hello').hexdigest() — the sha512 hexdigest of a non-empty string."
    - "No prior spec covers: sha224(b'abc').hexdigest() — the sha224 hexdigest of b'abc'."
    - "No prior spec covers: pbkdf2_hmac('sha1', b'', b'', 1) return length == 20."
    - "No prior spec covers: sha3_224.__qualname__ or sha3_384.__qualname__."
    - "No prior spec covers: new('sha3_224').name == 'sha3_224' or new('sha3_384').name == 'sha3_384'."
    - "hashlib.sha3_224.__name__ == 'sha3_224' — SHA-3 constructors keep canonical names (not openssl_xxx)."
    - "hashlib.sha3_224.__module__ == '_sha3' — SHA-3 family lives in the '_sha3' C extension on CPython."
    - "hashlib.sha3_384.__name__ == 'sha3_384' — likewise."
    - "hashlib.sha3_384.__module__ == '_sha3' — likewise."
    - "hashlib.sha512(b'hello').hexdigest() == '9b71d224bd62f3785d96d46ad3ea3d73319bfbc2890caadae2dff72519673ca72323c3d99ba5c11d7c7acc6e14b8c5da0c4663475c2e5c3adef46f73bcdec043' — verified on Python 3.12."
    - "hashlib.sha224(b'abc').hexdigest() == '23097d223405d8228642a477bda255b32aadbce4bda0b3f7e36c9da7' — verified on Python 3.12."
    - "pbkdf2_hmac('sha1', b'', b'', 1) returns 20 bytes — SHA-1 output is 20 bytes (160 bits)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SHA-3 constructor identity — __name__ and __module__
#
# hashlib_extra6 covers sha3_256.__name__ and sha3_256.__module__; it does not
# cover sha3_224, sha3_384, sha3_512 identity. This table fills those gaps.
# ---------------------------------------------------------------------------

table hashlib_extra10.sha3_constructors_identity:
  kind: python_call_eq
  category: identity
  id_prefix: sha3_id

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_name,    sha3_224.__name__.__eq__,    ["sha3_224"],    true]
    - [sha3_224_module,  sha3_224.__module__.__eq__,  ["_sha3"],       true]
    - [sha3_384_name,    sha3_384.__name__.__eq__,    ["sha3_384"],    true]
    - [sha3_384_module,  sha3_384.__module__.__eq__,  ["_sha3"],       true]
    - [sha3_512_name,    sha3_512.__name__.__eq__,    ["sha3_512"],    true]
    - [sha3_512_module,  sha3_512.__module__.__eq__,  ["_sha3"],       true]

# ---------------------------------------------------------------------------
# SHA-3 constructor __qualname__ — new coverage
#
# hashlib_extra8 covers openssl-backed constructor __qualname__ for sha256/sha512/
# sha1/md5/sha224/sha384.  hashlib_extra6 shows sha3_256.__name__ == 'sha3_256'.
# No prior spec asserts __qualname__ for any SHA-3 constructor.
# For C-extension types __qualname__ equals __name__ (flat, no nesting).
# ---------------------------------------------------------------------------

invariant hashlib_extra10.sha3_224.qualname:
  description: "hashlib.sha3_224.__qualname__ == 'sha3_224' — C-extension type has flat qualname"
  category: qualnames
  kind: python_call_eq
  function: sha3_224.__qualname__.__eq__
  args: ["sha3_224"]
  expected: true

invariant hashlib_extra10.sha3_256.qualname:
  description: "hashlib.sha3_256.__qualname__ == 'sha3_256' — C-extension type has flat qualname"
  category: qualnames
  kind: python_call_eq
  function: sha3_256.__qualname__.__eq__
  args: ["sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() with sha3_224 and sha3_384 — via factory, not direct constructor
#
# hashlib_extra7 covers new('sha3_256').digest_size.
# No prior spec covers sha3_224 or sha3_384 via the new() factory.
# ---------------------------------------------------------------------------

invariant hashlib_extra10.new.sha3_224.digest_size:
  description: "hashlib.new('sha3_224').digest_size == 28 — SHA3-224 via new() produces 28 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_224"]
  method: digest_size.__eq__
  method_args: [28]
  expected: true

invariant hashlib_extra10.new.sha3_224.name_attr:
  description: "hashlib.new('sha3_224').name == 'sha3_224'"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_224"]
  method: name.__eq__
  method_args: ["sha3_224"]
  expected: true

invariant hashlib_extra10.new.sha3_384.digest_size:
  description: "hashlib.new('sha3_384').digest_size == 48 — SHA3-384 via new() produces 48 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_384"]
  method: digest_size.__eq__
  method_args: [48]
  expected: true

invariant hashlib_extra10.new.sha3_384.name_attr:
  description: "hashlib.new('sha3_384').name == 'sha3_384'"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_384"]
  method: name.__eq__
  method_args: ["sha3_384"]
  expected: true

# ---------------------------------------------------------------------------
# sha512 hexdigest for non-empty input (b'hello')
#
# hashlib.zspec.zsdl covers sha512 known vectors for b'' and b'abc' via
# hash_known_vector kind. hashlib_extra2 covers sha512.digest_size via
# python_call_eq but with b'hello' only for size.
# No prior spec records sha512(b'hello').hexdigest() as a python_call_eq invariant.
# ---------------------------------------------------------------------------

invariant hashlib_extra10.sha512.hello_hexdigest:
  description: "hashlib.sha512(b'hello').hexdigest() — known vector verified on Python 3.12"
  category: known_vector
  kind: python_call_eq
  function: sha512
  args: [!hex 68656c6c6f]
  method: hexdigest
  method_args: []
  expected: "9b71d224bd62f3785d96d46ad3ea3d73319bfbc2890caadae2dff72519673ca72323c3d99ba5c11d7c7acc6e14b8c5da0c4663475c2e5c3adef46f73bcdec043"

# ---------------------------------------------------------------------------
# sha224 hexdigest for b'abc'
#
# No prior spec records sha224(b'abc').hexdigest() as a python_call_eq invariant.
# FIPS 180-4 specifies SHA-224 but does not list b'abc' as a primary test vector;
# the value here is independently verified on Python 3.12.
# ---------------------------------------------------------------------------

invariant hashlib_extra10.sha224.abc_hexdigest:
  description: "hashlib.sha224(b'abc').hexdigest() — verified on Python 3.12"
  category: known_vector
  kind: python_call_eq
  function: sha224
  args: [!hex 616263]
  method: hexdigest
  method_args: []
  expected: "23097d223405d8228642a477bda255b32aadbce4bda0b3f7e36c9da7"

# ---------------------------------------------------------------------------
# pbkdf2_hmac with SHA-1 — return length
#
# hashlib_extra.zspec.zsdl covers pbkdf2_hmac('sha256', ...) return length (32)
# and pbkdf2_hmac('sha512', ...) return length (64).
# No prior spec covers SHA-1 (output 20 bytes) for pbkdf2_hmac.
# ---------------------------------------------------------------------------

invariant hashlib_extra10.pbkdf2_hmac.sha1_return_length:
  description: "len(hashlib.pbkdf2_hmac('sha1', b'', b'', 1)) == 20 — SHA-1 output is 20 bytes"
  category: functions
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["sha1", "", "", 1]
  method: __len__
  method_args: []
  expected: 20
