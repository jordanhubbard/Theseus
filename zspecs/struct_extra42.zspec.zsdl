spec: struct_extra42
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra40.zspec.zsdl — covers Struct.__init__/__repr__ __name__.__eq__ and __name__.__len__()==8."
    - "struct_extra38.zspec.zsdl — covers Struct/error __bases__[0].__qualname__.__eq__; error mro entry __name__.__eq__."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all six module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra9.zspec.zsdl — covers Struct method pack/unpack/pack_into/unpack_from/iter_unpack __name__.__eq__ and __qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra41; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior struct spec checks __class__.__name__.__eq__ for Struct (the class), for the six module-level functions (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack), or for error. The __class__.__name__ axis identifies each object's Python type, providing structural regression vectors independent of __name__/__qualname__/__module__. struct_extra41 covers Struct.size.__class__.__name__.__eq__('getset_descriptor') and Struct.format.__class__.__name__.__eq__('getset_descriptor') (descriptor axis only, not the callables themselves). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__class__.__name__ == 'type'. Struct is a C extension type; its metaclass is type. No prior spec checks Struct.__class__.__name__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. pack is a C builtin in the _struct extension. No prior spec checks pack.__class__.__name__.__eq__('builtin_function_or_method'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method'. Same as pack. No prior spec checks unpack.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method'. Same as pack and unpack. No prior spec checks calcsize.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack_into.__class__.__name__ == 'builtin_function_or_method'. Same C builtin calling convention. No prior spec checks pack_into.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__name__ == 'builtin_function_or_method'. Same C builtin calling convention. No prior spec checks unpack_from.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method'. Same C builtin calling convention. No prior spec checks iter_unpack.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__name__ == 'type'. error is a C extension exception type; its metaclass is type. No prior spec checks error.__class__.__name__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level callable __class__.__name__.__eq__ string values
#
# No prior struct spec checks __class__.__name__.__eq__ for Struct, pack, unpack,
# calcsize, pack_into, unpack_from, iter_unpack, or error.
# struct.Struct.__class__.__name__ == 'type'
# struct.pack/unpack/calcsize/pack_into/unpack_from/iter_unpack.__class__.__name__
#   == 'builtin_function_or_method'
# struct.error.__class__.__name__ == 'type'
# struct_extra41 covers Struct.size/format __class__.__name__.__eq__('getset_descriptor')
#   for descriptor objects — those are excluded from this table.
# ---------------------------------------------------------------------------

table struct_extra42.callable_class_names:
  description: "struct Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __class__.__name__.__eq__ — novel: extra41 covers Struct.size/format descriptor __class__.__name__.__eq__('getset_descriptor') only; no prior spec checks __class__.__name__.__eq__ for the Struct type or any module-level function or the error exception type"
  kind: python_call_eq
  category: type_structure
  id_prefix: sccn42

  columns: [id, function, args, expected]
  rows:
    - [Struct_class_name_eq,      Struct.__class__.__name__.__eq__,      ["type"],                       true]
    - [pack_class_name_eq,        pack.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [unpack_class_name_eq,      unpack.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [calcsize_class_name_eq,    calcsize.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [pack_into_class_name_eq,   pack_into.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [unpack_from_class_name_eq, unpack_from.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [iter_unpack_class_name_eq, iter_unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [error_class_name_eq,       error.__class__.__name__.__eq__,       ["type"],                       true]
