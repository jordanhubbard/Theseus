spec: safety_rust
version: ">=3.9"
backend: rust_module(safety_rust)

docs: https://github.com/pyupio/safety

provenance:
  derived_from:
    - "https://github.com/pyupio/safety — Safety documentation"
  not_derived_from:
    - "safety source: safety/__init__.py"
  notes:
    - "Safety checks Python dependencies for known security vulnerabilities."
    - "safety.__version__ is a non-empty string."
    - "safety.safety is available."
    - "Expose safety_version_nonempty() -> bool: len(safety.__version__) > 0."
    - "Expose safety_has_safety() -> bool: hasattr(safety, 'safety')."
    - "All test vectors verified against safety 3.3.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# safety_version_nonempty — version non-empty
invariant safety_rust.version.nonempty:
  description: "safety.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: safety_version_nonempty
  args: []
  expected: true

# safety_has_safety — safety module present
invariant safety_rust.module.has_safety:
  description: "safety.safety is available"
  category: module
  kind: python_call_eq
  function: safety_has_safety
  args: []
  expected: true

