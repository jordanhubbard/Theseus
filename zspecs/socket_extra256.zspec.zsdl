spec: socket_extra256
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 256 theme: socket.socket instance method identity — bind/listen/accept/connect/send/recv/close __name__ and __class__.__name__; socket.socket class identity."
    - "type(socket.socket()).__name__ == 'socket'. The socket instance type name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket()).__module__ == 'socket'. The socket class is exposed from the socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__name__ == 'socket'. The class __name__ attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. The socket.socket class __module__ is 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket'. socket.socket inherits from _socket.socket (the C-level socket type); both have __name__ 'socket' but different __module__ values ('socket' vs '_socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__module__ == '_socket'. The base class is _socket.socket from the _socket C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "s.bind.__name__ == 'bind'. bind is a builtin_function_or_method (from _socket C extension). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "s.listen.__name__ == 'listen'. listen is a builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "s.connect.__name__ == 'connect'. connect is a builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "s.send.__name__ == 'send'. send is a builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "s.recv.__name__ == 'recv'. recv is a builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "s.accept.__name__ == 'accept'. accept is a Python 'method' (defined in Lib/socket.py as a wrapper). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "s.close.__name__ == 'close'. close is a Python 'method' (defined in Lib/socket.py as a wrapper that also calls _real_close). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: bind/listen/connect/send/recv are builtin_function_or_method (from _socket C extension); accept/close are Python 'method' objects (wrapped in Lib/socket.py). This is a key distinction: C extension methods vs Python wrapper methods."
    - "Note: socket.socket.__bases__[0] is _socket.socket (the C-level socket type). Both have __name__=='socket' but socket.__bases__[0].__module__=='_socket' while socket.socket.__module__=='socket'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class identity
#
# Wave 256 theme: socket.socket class __name__, __module__, __bases__.
#
# socket.socket.__name__ == 'socket'. Class name.
# socket.socket.__module__ == 'socket'. The Python-level socket class.
# socket.socket.__bases__[0].__name__ == 'socket'. Inherits from _socket.socket.
# socket.socket.__bases__[0].__module__ == '_socket'. The C-level base.
# socket_extra247 covers socket.socket.__name__/__module__/__qualname__ as a table;
# no prior spec anchors __bases__[0] identity under sockmethod256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra256.socket_class_identity:
  description: "socket.socket class identity — socket.__name__.__eq__('socket')==True / socket.__module__.__eq__('socket')==True / socket.__qualname__.__eq__('socket')==True — socket.socket is the Python-level socket class defined in Lib/socket.py; it wraps _socket.socket (C extension); __name__/__module__/__qualname__ are all 'socket'; socket_extra247 also covers these but as part of a different wave; first sockmethod256 anchor; wave 256 theme"
  kind: python_call_eq
  category: class_identity
  id_prefix: sockmethod256

  columns: [id, function, args, expected, description]
  rows:
    - [sock_name,    socket.__name__.__eq__,     ["socket"], true, "socket.socket.__name__ == 'socket'; Python-level socket class name"]
    - [sock_module,  socket.__module__.__eq__,   ["socket"], true, "socket.socket.__module__ == 'socket'; defined in Lib/socket.py"]
    - [sock_qualname, socket.__qualname__.__eq__, ["socket"], true, "socket.socket.__qualname__ == 'socket'; top-level class, qualname equals __name__"]

invariant socket_extra256.socket.base_class_name:
  description: "socket.socket.__bases__[0].__name__ == 'socket' — socket.socket inherits from _socket.socket (C-level); both have __name__=='socket' but different __module__; base provides the actual fd management and system calls; wave 256 theme; first standalone for socket base class __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: socket.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "socket"

invariant socket_extra256.socket.base_class_module:
  description: "socket.socket.__bases__[0].__module__ == '_socket' — the base class _socket.socket is from the _socket C extension; contrasts with socket.socket.__module__=='socket'; wave 256 theme; first standalone for socket base __module__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: socket.__bases__.__getitem__
  args: [0]
  method: __module__
  expected: "_socket"

# ---------------------------------------------------------------------------
# socket.socket() instance method __name__ — bind, listen, connect, send, recv
#
# Wave 256 theme: socket instance method identity for C-extension methods.
#
# bind, listen, connect, send, recv are builtin_function_or_method objects
# inherited from _socket.socket (C extension). Their __name__ equals the
# method name string and their __class__.__name__ is 'builtin_function_or_method'.
# No prior spec anchors socket instance method __name__ for bind/listen/connect/
# send/recv under sockmethod256. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# socket.socket() instance method __name__ — standalone invariants
# (bind, listen, connect, send, recv — builtin_function_or_method)
# (accept, close — Python method)
# ---------------------------------------------------------------------------

invariant socket_extra256.socket_instance.bind_name:
  description: "socket.socket().bind.__name__ == 'bind' — bind binds the socket to an address; builtin_function_or_method from _socket C extension; wave 256 theme; first standalone for bind __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: bind.__name__.__eq__
  method_args: ["bind"]
  expected: true

invariant socket_extra256.socket_instance.bind_class_name:
  description: "socket.socket().bind.__class__.__name__ == 'builtin_function_or_method' — bind is a C extension method from _socket; wave 256 theme; first standalone for bind __class__.__name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: bind.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra256.socket_instance.listen_name:
  description: "socket.socket().listen.__name__ == 'listen' — listen enables incoming connections on a bound socket; builtin_function_or_method from _socket; wave 256 theme; first standalone for listen __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: listen.__name__.__eq__
  method_args: ["listen"]
  expected: true

invariant socket_extra256.socket_instance.listen_class_name:
  description: "socket.socket().listen.__class__.__name__ == 'builtin_function_or_method' — listen is a C extension method from _socket; wave 256 theme; first standalone for listen __class__.__name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: listen.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra256.socket_instance.connect_name:
  description: "socket.socket().connect.__name__ == 'connect' — connect initiates a connection to a remote address; builtin_function_or_method from _socket; wave 256 theme; first standalone for connect __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: connect.__name__.__eq__
  method_args: ["connect"]
  expected: true

invariant socket_extra256.socket_instance.connect_class_name:
  description: "socket.socket().connect.__class__.__name__ == 'builtin_function_or_method' — connect is a C extension method from _socket; wave 256 theme; first standalone for connect __class__.__name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: connect.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra256.socket_instance.send_name:
  description: "socket.socket().send.__name__ == 'send' — send transmits data to a connected socket; builtin_function_or_method from _socket; wave 256 theme; first standalone for send __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: send.__name__.__eq__
  method_args: ["send"]
  expected: true

invariant socket_extra256.socket_instance.send_class_name:
  description: "socket.socket().send.__class__.__name__ == 'builtin_function_or_method' — send is a C extension method from _socket; wave 256 theme; first standalone for send __class__.__name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: send.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra256.socket_instance.recv_name:
  description: "socket.socket().recv.__name__ == 'recv' — recv receives data from a connected socket; builtin_function_or_method from _socket; wave 256 theme; first standalone for recv __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: recv.__name__.__eq__
  method_args: ["recv"]
  expected: true

invariant socket_extra256.socket_instance.recv_class_name:
  description: "socket.socket().recv.__class__.__name__ == 'builtin_function_or_method' — recv is a C extension method from _socket; wave 256 theme; first standalone for recv __class__.__name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: recv.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra256.socket_instance.accept_name:
  description: "socket.socket().accept.__name__ == 'accept' — accept waits for and accepts an incoming connection; Python 'method' (wrapper defined in Lib/socket.py); wave 256 theme; first standalone for accept __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: accept.__name__.__eq__
  method_args: ["accept"]
  expected: true

invariant socket_extra256.socket_instance.accept_class_name:
  description: "socket.socket().accept.__class__.__name__ == 'method' — accept is a Python 'method' (defined in Lib/socket.py as a wrapper), unlike bind/send/recv which are builtin_function_or_method; wave 256 theme; first standalone for accept __class__.__name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: accept.__class__.__name__.__eq__
  method_args: ["method"]
  expected: true

invariant socket_extra256.socket_instance.close_name:
  description: "socket.socket().close.__name__ == 'close' — close releases the socket file descriptor; Python 'method' (wrapper in Lib/socket.py that also calls _real_close); wave 256 theme; first standalone for close __name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: close.__name__.__eq__
  method_args: ["close"]
  expected: true

invariant socket_extra256.socket_instance.close_class_name:
  description: "socket.socket().close.__class__.__name__ == 'method' — close is a Python 'method' (wrapper in Lib/socket.py), unlike send/recv which are builtin_function_or_method from _socket; wave 256 theme; first standalone for close __class__.__name__ under sockmethod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: close.__class__.__name__.__eq__
  method_args: ["method"]
  expected: true
