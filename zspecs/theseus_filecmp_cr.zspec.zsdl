spec: theseus_filecmp_cr
version: ">=3.8"
backend: python_cleanroom(theseus_filecmp_cr)
blocks: filecmp

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/filecmp.html"
  not_derived_from:
    - "CPython source: Lib/filecmp.py (internal implementation)"
  notes:
    - "Clean-room filecmp module. Do NOT import filecmp."
    - "cmp(f1, f2, shallow=True): compare two files; return True if equal."
    - "cmpfiles(dir1, dir2, common): compare lists of files in two directories."
    - "shallow=True: compare only os.stat() signatures (size, mtime); not content."
    - "shallow=False: compare file contents byte-by-byte."

error_model: python_exceptions

invariant theseus_filecmp_cr.filecmp2_equal:
  description: "cmp of two identical temp files returns True"
  category: cmp
  kind: python_call_eq
  function: filecmp2_equal
  args: []
  expected: true

invariant theseus_filecmp_cr.filecmp2_different:
  description: "cmp of two different temp files returns False"
  category: cmp
  kind: python_call_eq
  function: filecmp2_different
  args: []
  expected: false

invariant theseus_filecmp_cr.filecmp2_self:
  description: "cmp(f, f) is always True"
  category: cmp
  kind: python_call_eq
  function: filecmp2_self
  args: []
  expected: true
