spec: uuid_extra48
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra47.zspec.zsdl — covers UUID.__repr__/__hash__.__class__.__name__.__eq__('function'); UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor'); NAMESPACE_DNS/URL/OID/X500.__repr__.__class__.__name__.__eq__('method')."
    - "uuid_extra46.zspec.zsdl — covers uuid1/uuid3/uuid5 __class__.__module__.__eq__('builtins'); UUID.__init__.__class__.__name__/__module__.__eq__('function'/'builtins')."
    - "uuid_extra45.zspec.zsdl — covers UUID/__dict__/__class__/__name__/__qualname__.__eq__('mappingproxy'); uuid module __dict__/__class__/__name__/__qualname__.__eq__('mappingproxy')."
    - "uuid_extra43.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__ string values."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS/getnode __class__.__qualname__.__eq__ and __class__.__module__.__eq__."
    - "uuid_extra36.zspec.zsdl — covers UUID dunder method __module__.__eq__('uuid') for __repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra35.zspec.zsdl — covers UUID dunder method __name__.__eq__ string values."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid_extra16.zspec.zsdl — covers UUID.__repr__/__hash__/__eq__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra47; it does NOT duplicate invariants present in those files."
    - "Wave 223 theme: module __all__ content + __eq__.__class__.__name__ checks."
    - "Coverage gap 1: uuid does not define __all__. Verified with Python 3.14.3 macOS/Darwin 25.4.0: hasattr(uuid, '__all__') == False. uuid is a pure Python module that does not declare a public __all__ list. This is notable contrast to hashlib (tuple, 19 entries), struct (list, 8 entries), and socket (list, 238 entries). The absence of __all__ means 'from uuid import *' imports all names that do not start with an underscore. No prior uuid spec documents the absence of __all__."
    - "uuid has no __all__ attribute. hasattr(uuid, '__all__') == False. This is the definitive Python 3.14.3 macOS/Darwin 25.4.0 verified state. The uuid module (Lib/uuid.py) does not define __all__, meaning its public API boundary is not explicitly declared via __all__. This is distinct from modules like hashlib (has __all__ as tuple), struct (has __all__ as list), and socket (has __all__ as list)."
    - "Coverage gap 2: No prior uuid spec checks UUID.__eq__.__class__.__name__. uuid_extra16 covers UUID.__eq__.__qualname__.__eq__ and __qualname__.__len__()==11. uuid_extra35 covers UUID.__eq__.__name__.__eq__('__eq__'). uuid_extra36 covers UUID.__eq__.__module__.__eq__('uuid'). uuid_extra47 covers UUID.__repr__.__class__.__name__ and UUID.__hash__.__class__.__name__ (both 'function'). But no prior spec checks UUID.__eq__.__class__.__name__. UUID is a pure Python class; its __eq__ is a Python function, so UUID.__eq__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__class__.__name__ == 'function'. UUID defines __eq__ as a Python function in Lib/uuid.py; its __class__.__name__ is 'function'. uuid_extra47 covers UUID.__repr__.__class__.__name__.__eq__('function') and UUID.__hash__.__class__.__name__.__eq__('function'), but NOT UUID.__eq__.__class__.__name__. No prior uuid spec checks UUID.__eq__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior uuid spec checks UUID.__lt__/__le__/__gt__/__ge__.__class__.__name__. uuid_extra17 covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11. uuid_extra36 covers __module__.__eq__('uuid') for these methods. uuid_extra35 covers __name__.__eq__ for these methods. But no prior spec checks __class__.__name__ for any of UUID's comparison operators. UUID defines __lt__, __le__, __gt__, __ge__ as Python functions in Lib/uuid.py; all have __class__.__name__ == 'function'. UUID is an ordered type (total ordering defined in Python). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__class__.__name__ == 'function'. UUID defines __lt__ as a Python function; no prior uuid spec checks UUID.__lt__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__class__.__name__ == 'function'. UUID defines __le__ as a Python function; no prior uuid spec checks UUID.__le__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__class__.__name__ == 'function'. UUID defines __gt__ as a Python function; no prior uuid spec checks UUID.__gt__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__class__.__name__ == 'function'. UUID defines __ge__ as a Python function; no prior uuid spec checks UUID.__ge__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID __eq__.__class__.__name__.__eq__('function')
#
# uuid_extra47 covers UUID.__repr__.__class__.__name__.__eq__('function') and
# UUID.__hash__.__class__.__name__.__eq__('function'). No prior uuid spec checks
# UUID.__eq__.__class__.__name__. UUID is a pure Python class; its __eq__ is a
# Python function defined in Lib/uuid.py. The __class__.__name__ of a Python
# function is 'function'. This is independent from __qualname__ (extra16),
# __name__ (extra35), and __module__ (extra36).
# uuid has no __all__ (verified: hasattr(uuid, '__all__') == False), so there
# are no __all__.__contains__ checks to perform for this module.
# ---------------------------------------------------------------------------

table uuid_extra48.UUID_eq_class_name:
  description: "uuid.UUID/__eq__/__class__/__name__.__eq__('function') — UUID is a pure Python class; __eq__ is a Python function; uuid_extra47 covers UUID.__repr__/__hash__.__class__.__name__.__eq__('function') but NOT __eq__; uuid_extra16/35/36 cover __qualname__/__name__/__module__ axes for __eq__ but NOT __class__.__name__; no prior uuid spec checks UUID.__eq__.__class__.__name__.__eq__('function')"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidall48

  columns: [id, function, args, expected]
  rows:
    - [UUID_eq_class_name_eq, UUID.__eq__.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# uuid.UUID __lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function')
#
# UUID defines a total ordering: __lt__, __le__, __gt__, __ge__ are all
# Python functions defined in Lib/uuid.py. uuid_extra17 covers these four
# methods' __qualname__.__eq__ and __qualname__.__len__()==11. uuid_extra36
# covers their __module__.__eq__('uuid'). uuid_extra35 covers their
# __name__.__eq__ string values. But no prior spec checks __class__.__name__
# for any of UUID's ordering operators. All four are Python functions, so
# __class__.__name__ == 'function' for all.
# ---------------------------------------------------------------------------

table uuid_extra48.UUID_ordering_class_name:
  description: "uuid.UUID/__lt__/__le__/__gt__/__ge__/__class__/__name__.__eq__('function') — UUID defines all four ordering operators as pure Python functions; uuid_extra17 covers __qualname__.__eq__ and uuid_extra36 covers __module__.__eq__ for these methods but neither checks __class__.__name__; no prior uuid spec checks __class__.__name__ for UUID.__lt__, UUID.__le__, UUID.__gt__, or UUID.__ge__"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidall48

  columns: [id, function, args, expected]
  rows:
    - [UUID_lt_class_name_eq, UUID.__lt__.__class__.__name__.__eq__, ["function"], true]
    - [UUID_le_class_name_eq, UUID.__le__.__class__.__name__.__eq__, ["function"], true]
    - [UUID_gt_class_name_eq, UUID.__gt__.__class__.__name__.__eq__, ["function"], true]
    - [UUID_ge_class_name_eq, UUID.__ge__.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# uuid has no __all__ — structural invariant
#
# The uuid module does not define __all__. hasattr(uuid, '__all__') == False.
# This is significant: it means 'from uuid import *' uses the default rule
# (import all names without a leading underscore). This structural fact is
# distinct from modules that define __all__ (hashlib: tuple of 19; struct:
# list of 8; socket: list of 238). No prior uuid spec documents this.
# We express this as a python_call_eq on hasattr via __dict__.__contains__.
# ---------------------------------------------------------------------------

invariant uuid_extra48.no_all_attribute:
  description: "uuid.__dict__.__contains__('__all__') == False — uuid module does not define __all__; 'from uuid import *' uses the default rule (no leading underscore); distinct from hashlib/struct/socket which all define __all__; no prior uuid spec checks for the absence of __all__ in the uuid namespace"
  category: module_structure
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__all__"]
  expected: false
