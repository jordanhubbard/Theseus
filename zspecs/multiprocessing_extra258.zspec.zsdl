spec: multiprocessing_extra258
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#managers

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — multiprocessing managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "multiprocessing.managers.BaseManager is the root of the manager class hierarchy; __bases__[0].__name__ == 'object'."
    - "multiprocessing.managers.SyncManager inherits from BaseManager; __bases__[0].__name__ == 'BaseManager'."
    - "BaseManager has no 'shutdown' method; public methods are: address, connect, get_server, join, register, start."
    - "BaseManager.__enter__ and __exit__ implement context manager protocol."
    - "All BaseManager method __qualname__ values carry the 'BaseManager.' prefix."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseManager and SyncManager class identity — table
#
# BaseManager and SyncManager __name__ and __module__ identity checks.
# BaseManager inherits from object; SyncManager inherits from BaseManager.
# ---------------------------------------------------------------------------

table multiprocessing_extra258.manager_class_identity:
  description: "multiprocessing.managers BaseManager and SyncManager report expected __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: mgrid

  columns: [id, function, args, expected, description]
  rows:
    - [base_name,   managers.BaseManager.__name__.__eq__,   ["BaseManager"],               true, "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'"]
    - [base_mod,    managers.BaseManager.__module__.__eq__, ["multiprocessing.managers"],   true, "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'"]
    - [sync_name,   managers.SyncManager.__name__.__eq__,   ["SyncManager"],               true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'"]
    - [sync_mod,    managers.SyncManager.__module__.__eq__, ["multiprocessing.managers"],   true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'"]
    - [sync_base,   "managers.SyncManager.__bases__[0].__name__.__eq__", ["BaseManager"],  true, "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'"]

# ---------------------------------------------------------------------------
# BaseManager method __name__ — table
#
# Six public methods of BaseManager: start, connect, join, get_server,
# register, __enter__. Note: BaseManager has no 'shutdown' method.
# ---------------------------------------------------------------------------

table multiprocessing_extra258.basemanager_method_names:
  description: "multiprocessing.managers.BaseManager methods report expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mgrmethod

  columns: [id, function, args, expected, description]
  rows:
    - [start,     managers.BaseManager.start.__name__.__eq__,     ["start"],     true, "BaseManager.start.__name__ == 'start'"]
    - [connect,   managers.BaseManager.connect.__name__.__eq__,   ["connect"],   true, "BaseManager.connect.__name__ == 'connect'"]
    - [join,      managers.BaseManager.join.__name__.__eq__,      ["join"],      true, "BaseManager.join.__name__ == 'join'"]
    - [get_server, managers.BaseManager.get_server.__name__.__eq__, ["get_server"], true, "BaseManager.get_server.__name__ == 'get_server'"]
    - [__enter__, managers.BaseManager.__enter__.__name__.__eq__, ["__enter__"], true, "BaseManager.__enter__.__name__ == '__enter__'"]

# ---------------------------------------------------------------------------
# BaseManager.__bases__[0] is object — standalone invariant
# ---------------------------------------------------------------------------

invariant multiprocessing_extra258.BaseManager.bases0_name:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "managers.BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# BaseManager method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra258.BaseManager.start_qualname:
  description: "multiprocessing.managers.BaseManager.start.__qualname__ == 'BaseManager.start'"
  category: identity
  kind: python_call_eq
  function: managers.BaseManager.start.__qualname__.__eq__
  args: ["BaseManager.start"]
  expected: true

invariant multiprocessing_extra258.BaseManager.connect_qualname:
  description: "multiprocessing.managers.BaseManager.connect.__qualname__ == 'BaseManager.connect'"
  category: identity
  kind: python_call_eq
  function: managers.BaseManager.connect.__qualname__.__eq__
  args: ["BaseManager.connect"]
  expected: true

invariant multiprocessing_extra258.BaseManager.exit_name:
  description: "multiprocessing.managers.BaseManager.__exit__.__name__ == '__exit__'"
  category: identity
  kind: python_call_eq
  function: managers.BaseManager.__exit__.__name__.__eq__
  args: ["__exit__"]
  expected: true
