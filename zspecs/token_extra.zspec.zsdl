spec: token_extra
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/token.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token.zspec.zsdl — that spec covers exact integer values for core and extended constants, NT_OFFSET, tok_name lookups, and ISEOF/ISTERMINAL/ISNONTERMINAL predicates"
  notes:
    - "This spec covers token aspects not in token.zspec.zsdl."
    - "All token constants are plain Python ints; __class__.__name__ == 'int' for every constant."
    - "tok_name is a dict; EXACT_TOKEN_TYPES is also a dict."
    - "EXACT_TOKEN_TYPES maps operator strings to token type integers (added in Python 3.8)."
    - "NAME == 1, NUMBER == 2, STRING == 3, NEWLINE == 4, ENDMARKER == 0 — stable across all Python 3.x."
    - "INDENT == 5, DEDENT == 6 — stable across all Python 3.x."
    - "ERRORTOKEN is a terminal token type for scanner errors; its value is version-dependent."
    - "COMMENT, NEWLINE, OP, ENDMARKER constants are all ints regardless of exact value."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Token constant type checks — all are plain Python ints
#
# token.zspec.zsdl checked exact integer values; here we verify __class__.__name__
# for completeness and for constants whose exact values may vary across versions.
# ---------------------------------------------------------------------------

table token_extra.constant_types:
  kind: python_call_eq
  category: constant_types
  id_prefix: toktype

  columns: [id, function, args, expected]
  rows:
    - [name,       NAME.__class__.__name__.__eq__,       ["int"], true]
    - [number,     NUMBER.__class__.__name__.__eq__,     ["int"], true]
    - [string,     STRING.__class__.__name__.__eq__,     ["int"], true]
    - [op,         OP.__class__.__name__.__eq__,         ["int"], true]
    - [comment,    COMMENT.__class__.__name__.__eq__,    ["int"], true]
    - [newline,    NEWLINE.__class__.__name__.__eq__,    ["int"], true]
    - [endmarker,  ENDMARKER.__class__.__name__.__eq__,  ["int"], true]
    - [indent,     INDENT.__class__.__name__.__eq__,     ["int"], true]
    - [dedent,     DEDENT.__class__.__name__.__eq__,     ["int"], true]
    - [errortoken, ERRORTOKEN.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# Dict-typed module attributes — tok_name and EXACT_TOKEN_TYPES
# ---------------------------------------------------------------------------

invariant token_extra.tok_name.is_dict:
  description: "token.tok_name.__class__.__name__ == 'dict'"
  category: dict_attrs
  kind: python_call_eq
  function: tok_name.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant token_extra.EXACT_TOKEN_TYPES.is_dict:
  description: "token.EXACT_TOKEN_TYPES.__class__.__name__ == 'dict'"
  category: dict_attrs
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# Stable core constant values — NAME, NUMBER, STRING, NEWLINE, ENDMARKER
#
# These five values have been stable across all Python 3.x releases.
# token.zspec.zsdl covers INDENT, DEDENT, OP and others via __eq__; here
# we provide the canonical values for the five most commonly referenced.
# ---------------------------------------------------------------------------

invariant token_extra.NAME.value:
  description: "token.NAME == 1"
  category: constant_values
  kind: python_call_eq
  function: NAME.__eq__
  args: [1]
  expected: true

invariant token_extra.NUMBER.value:
  description: "token.NUMBER == 2"
  category: constant_values
  kind: python_call_eq
  function: NUMBER.__eq__
  args: [2]
  expected: true

invariant token_extra.STRING.value:
  description: "token.STRING == 3"
  category: constant_values
  kind: python_call_eq
  function: STRING.__eq__
  args: [3]
  expected: true

invariant token_extra.NEWLINE.value:
  description: "token.NEWLINE == 4"
  category: constant_values
  kind: python_call_eq
  function: NEWLINE.__eq__
  args: [4]
  expected: true

invariant token_extra.ENDMARKER.value:
  description: "token.ENDMARKER == 0"
  category: constant_values
  kind: python_call_eq
  function: ENDMARKER.__eq__
  args: [0]
  expected: true
