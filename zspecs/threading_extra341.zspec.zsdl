spec: threading_extra341
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.__name__ == 'threading' — the module name attribute."
    - "threading.__package__ == '' — threading is not a package; __package__ is the empty string."
    - "threading.__spec__.name == 'threading' — the ModuleSpec name matches the module name."
    - "threading.__all__.__class__.__name__ == 'list' — __all__ is a plain list."
    - "threading.__all__.__len__() == 28 — 28 public names exported by threading on Python 3.14."
    - "threading.__all__.__contains__('Thread') == True — Thread is in __all__."
    - "threading.__all__.__contains__('Lock') == True — Lock is in __all__."
    - "threading.__all__.__contains__('RLock') == True — RLock is in __all__."
    - "threading.__doc__.__class__.__name__ == 'str' — threading has a plain string module docstring (not NoneType)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity attributes: __name__, __package__, __spec__.name
# ---------------------------------------------------------------------------

invariant threading_extra341.module.name:
  description: "threading.__name__ == 'threading'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra341.module.package:
  description: "threading.__package__ == '' — threading is not a package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant threading_extra341.module.spec_name:
  description: "threading.__spec__.name == 'threading'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# __all__ — class name, length, and membership
# ---------------------------------------------------------------------------

invariant threading_extra341.all.class_name:
  description: "threading.__all__.__class__.__name__ == 'list'"
  category: all_attr
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant threading_extra341.all.length:
  description: "threading.__all__.__len__() == 28 — 28 public names on Python 3.14"
  category: all_attr
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 28

invariant threading_extra341.all.contains_Thread:
  description: "threading.__all__.__contains__('Thread') == True"
  category: all_attr
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra341.all.contains_Lock:
  description: "threading.__all__.__contains__('Lock') == True"
  category: all_attr
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra341.all.contains_RLock:
  description: "threading.__all__.__contains__('RLock') == True"
  category: all_attr
  kind: python_call_eq
  function: __all__.__contains__
  args: ["RLock"]
  expected: true

# ---------------------------------------------------------------------------
# __doc__ — class name
#
# threading has a plain string module docstring (not NoneType).
# ---------------------------------------------------------------------------

invariant threading_extra341.doc.class_name:
  description: "threading.__doc__.__class__.__name__ == 'str'"
  category: doc
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
