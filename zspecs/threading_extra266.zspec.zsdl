spec: threading_extra266
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading module __name__, __package__, __spec__ identity; threading.__all__ type and key members; threading.TIMEOUT_MAX type check."
    - "threading.__name__ == 'threading' — the module's own name attribute. Verified with Python 3.14.3."
    - "threading.__package__ == '' — threading is a top-level Python module (Lib/threading.py); its __package__ is the empty string. Verified with Python 3.14.3."
    - "threading.__spec__.__class__.__name__ == 'ModuleSpec' — threading.__spec__ is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "threading.__spec__.name == 'threading' — the spec's name matches the module name. Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is loaded from Lib/threading.py. Verified with Python 3.14.3."
    - "type(threading.__all__).__name__ == 'list' — threading.__all__ is a plain Python list. Verified with Python 3.14.3."
    - "'Thread', 'Lock', 'Event', 'Semaphore', 'Timer', 'Barrier' are all in threading.__all__. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a Python float constant. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module __name__, __package__, __spec__ identity
#
# threading.__name__ == 'threading'
# threading.__package__ == ''
# threading.__spec__.__class__.__name__ == 'ModuleSpec'
# threading.__spec__.name == 'threading'
# threading.__loader__.__class__.__name__ == 'SourceFileLoader'
#
# threading is a top-level Python module in Lib/threading.py. Its __package__
# is '' (empty string). New to extra266.
# ---------------------------------------------------------------------------

table threading_extra266.module_identity:
  description: "threading module __name__, __package__, __spec__, __loader__ identity; new to extra266"
  kind: python_call_eq
  category: identity
  id_prefix: thrmod266

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       "__name__.__eq__",
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — the threading module's __name__ attribute is the string 'threading'; str.__eq__('threading') returns True; new to extra266"]
    - [mod_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "threading.__package__.__eq__('') == True — threading is a top-level Python module in Lib/threading.py; its __package__ is the empty string ''; str.__eq__('') returns True; new to extra266"]
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — threading.__spec__ is an importlib.machinery.ModuleSpec instance; str.__eq__('ModuleSpec') returns True; new to extra266"]
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["threading"],
       true,
       "threading.__spec__.name.__eq__('threading') == True — the ModuleSpec's name field matches the module __name__; str.__eq__('threading') returns True; new to extra266"]
    - [loader_class_source_file_loader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading is a pure Python module loaded from Lib/threading.py by importlib._bootstrap_external.SourceFileLoader; str.__eq__('SourceFileLoader') returns True; new to extra266"]

# ---------------------------------------------------------------------------
# Table 2: threading.__all__ type and key members
#
# type(threading.__all__).__name__ == 'list'
# 'Thread' in threading.__all__ == True
# 'Lock' in threading.__all__ == True
# 'Event' in threading.__all__ == True
# 'Semaphore' in threading.__all__ == True
#
# threading.__all__ is a plain Python list. New to extra266.
# ---------------------------------------------------------------------------

table threading_extra266.all_type_and_members:
  description: "threading.__all__ type list; Thread, Lock, Event, Semaphore present; new to extra266"
  kind: python_call_eq
  category: identity
  id_prefix: thrall266

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "threading.__all__.__class__.__name__.__eq__('list') == True — threading.__all__ is a plain Python list (not a tuple or set); its __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra266"]
    - [has_thread,
       "__all__.__contains__",
       ["Thread"],
       true,
       "threading.__all__.__contains__('Thread') == True — 'Thread' is listed in threading.__all__; list.__contains__('Thread') returns True; new to extra266"]
    - [has_lock,
       "__all__.__contains__",
       ["Lock"],
       true,
       "threading.__all__.__contains__('Lock') == True — 'Lock' is listed in threading.__all__; list.__contains__('Lock') returns True; new to extra266"]
    - [has_event,
       "__all__.__contains__",
       ["Event"],
       true,
       "threading.__all__.__contains__('Event') == True — 'Event' is listed in threading.__all__; list.__contains__('Event') returns True; new to extra266"]
    - [has_semaphore,
       "__all__.__contains__",
       ["Semaphore"],
       true,
       "threading.__all__.__contains__('Semaphore') == True — 'Semaphore' is listed in threading.__all__; list.__contains__('Semaphore') returns True; new to extra266"]

# ---------------------------------------------------------------------------
# Table 3: threading.__all__ additional members and TIMEOUT_MAX type
#
# 'Timer' in threading.__all__ == True
# 'Barrier' in threading.__all__ == True
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.__name__.__len__() == 9
# threading.__package__.__len__() == 0
#
# TIMEOUT_MAX is a float constant representing the maximum supported timeout
# for threading primitives. New to extra266.
# ---------------------------------------------------------------------------

table threading_extra266.all_extra_members_and_timeout:
  description: "threading.__all__ has Timer, Barrier; TIMEOUT_MAX is float; name len 9; package len 0; new to extra266"
  kind: python_call_eq
  category: identity
  id_prefix: thrtmo266

  columns: [id, function, args, expected, description]
  rows:
    - [has_timer,
       "__all__.__contains__",
       ["Timer"],
       true,
       "threading.__all__.__contains__('Timer') == True — 'Timer' is listed in threading.__all__; list.__contains__('Timer') returns True; new to extra266"]
    - [has_barrier,
       "__all__.__contains__",
       ["Barrier"],
       true,
       "threading.__all__.__contains__('Barrier') == True — 'Barrier' is listed in threading.__all__; list.__contains__('Barrier') returns True; new to extra266"]
    - [timeout_max_class_float,
       TIMEOUT_MAX.__class__.__name__.__eq__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a Python float constant representing the maximum supported timeout value for blocking threading primitives; its __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra266"]
    - [mod_name_len_9,
       "__name__.__len__",
       [],
       9,
       "threading.__name__.__len__() == 9 — the string 'threading' has exactly 9 characters: t-h-r-e-a-d-i-n-g; str.__len__() returns 9; new to extra266"]
    - [mod_package_len_0,
       "__package__.__len__",
       [],
       0,
       "threading.__package__.__len__() == 0 — threading.__package__ is the empty string ''; its length is 0; str.__len__() returns 0; new to extra266"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra266
# ---------------------------------------------------------------------------

invariant threading_extra266.module_name.eq:
  description: "threading.__name__.__eq__('threading') == True; new to extra266"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra266.module_package.empty:
  description: "threading.__package__.__eq__('') == True — top-level module, not a package; new to extra266"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant threading_extra266.spec_class.modulespec:
  description: "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True; new to extra266"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant threading_extra266.spec_name.eq:
  description: "threading.__spec__.name.__eq__('threading') == True; new to extra266"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra266.loader_class.source_file_loader:
  description: "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True; new to extra266"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra266.all_class.list:
  description: "threading.__all__.__class__.__name__.__eq__('list') == True — __all__ is a plain list; new to extra266"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant threading_extra266.all.has_thread:
  description: "threading.__all__.__contains__('Thread') == True; new to extra266"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra266.all.has_lock:
  description: "threading.__all__.__contains__('Lock') == True; new to extra266"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra266.TIMEOUT_MAX.class_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — constant is a float; new to extra266"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true
