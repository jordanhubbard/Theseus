spec: enum_extra24
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra23.zspec.zsdl."
    - "enum_extra23 covers: combined __bases__[0].__name__ table for EnumType/Flag/StrEnum/auto; combined __mro__.__len__ table for IntEnum/StrEnum/IntFlag; EnumType.__bases__[0].__name__ standalone; auto.__mro__.__len__ == 2 standalone; StrEnum.__mro__[1].__name__ standalone; IntFlag.__mro__[1].__name__ standalone."
    - "enum_extra21 covers: combined __qualname__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique; EnumMeta/__qualname__ standalone; combined __module__ table for all seven."
    - "Focus of this spec: (1) combined __qualname__ table for enum.unique/global_enum/member/nonmember/property/show_flag_values — Python 3.11+ decorator helpers not yet tested together; (2) combined __module__ table for those same six names; (3) enum.member.__mro__.__len__ == 2 standalone; (4) enum.nonmember.__mro__.__len__ == 2 standalone; (5) enum.property.__mro__.__len__ == 3 standalone; (6) __qualname__.__len__ for member/nonmember standalone."
    - "NOT yet covered (entering this spec): combined __qualname__ table for unique/global_enum/member/nonmember/property/show_flag_values in the extra24 namespace; combined __module__ table for those six; enum.member.__mro__.__len__() == 2 standalone; enum.nonmember.__mro__.__len__() == 2 standalone; enum.property.__mro__.__len__() == 3 standalone; member/__qualname__.__len__ == 6 standalone; nonmember/__qualname__.__len__ == 9 standalone."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for six enum decorator helpers (Python 3.11+)
#
# enum.unique, enum.global_enum, enum.member, enum.nonmember, enum.property,
# and enum.show_flag_values are all decorator/utility names introduced or
# formalised in Python 3.11. enum_extra21 covers unique, but the others are
# not yet tested together in a combined table under the extra24 namespace.
# ---------------------------------------------------------------------------

table enum_extra24.decorator_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [unique,           unique.__qualname__.__eq__,           ["unique"],           true]
    - [global_enum,      global_enum.__qualname__.__eq__,      ["global_enum"],      true]
    - [member,           member.__qualname__.__eq__,           ["member"],           true]
    - [nonmember,        nonmember.__qualname__.__eq__,        ["nonmember"],        true]
    - [property,         property.__qualname__.__eq__,         ["property"],         true]
    - [show_flag_values, show_flag_values.__qualname__.__eq__, ["show_flag_values"], true]

# ---------------------------------------------------------------------------
# __module__ for six enum decorator helpers
#
# All six names are defined in the enum module itself.  No prior spec has
# unique/global_enum/member/nonmember/property/show_flag_values together in a
# single combined __module__ table under the extra24 namespace.
# ---------------------------------------------------------------------------

table enum_extra24.decorator_modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [unique,           unique.__module__.__eq__,           ["enum"], true]
    - [global_enum,      global_enum.__module__.__eq__,      ["enum"], true]
    - [member,           member.__module__.__eq__,           ["enum"], true]
    - [nonmember,        nonmember.__module__.__eq__,        ["enum"], true]
    - [property,         property.__module__.__eq__,         ["enum"], true]
    - [show_flag_values, show_flag_values.__module__.__eq__, ["enum"], true]

# ---------------------------------------------------------------------------
# enum.member.__mro__.__len__() == 2
#
# enum.member directly subclasses object, giving an MRO of [member, object].
# No prior spec covers member.__mro__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant enum_extra24.member.mro.len:
  description: "enum.member.__mro__.__len__() == 2 — member MRO is [member, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: member.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# enum.nonmember.__mro__.__len__() == 2
#
# enum.nonmember directly subclasses object, giving an MRO of [nonmember, object].
# No prior spec covers nonmember.__mro__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant enum_extra24.nonmember.mro.len:
  description: "enum.nonmember.__mro__.__len__() == 2 — nonmember MRO is [nonmember, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: nonmember.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# enum.property.__mro__.__len__() == 3
#
# enum.property inherits from types.DynamicClassAttribute, giving an MRO of
# [property, DynamicClassAttribute, object] (length 3).
# No prior spec covers enum.property.__mro__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant enum_extra24.property.mro.len:
  description: "enum.property.__mro__.__len__() == 3 — enum.property inherits from DynamicClassAttribute"
  category: class_hierarchy
  kind: python_call_eq
  function: property.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# enum.member.__qualname__.__len__() == 6
#
# The qualname string 'member' has length 6.  No prior spec verifies the
# length of member.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant enum_extra24.member.qualname.len:
  description: "enum.member.__qualname__.__len__() == 6 — len('member') == 6"
  category: qualnames
  kind: python_call_eq
  function: member.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# enum.nonmember.__qualname__.__len__() == 9
#
# The qualname string 'nonmember' has length 9.  No prior spec verifies the
# length of nonmember.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant enum_extra24.nonmember.qualname.len:
  description: "enum.nonmember.__qualname__.__len__() == 9 — len('nonmember') == 9"
  category: qualnames
  kind: python_call_eq
  function: nonmember.__qualname__.__len__
  args: []
  expected: 9
