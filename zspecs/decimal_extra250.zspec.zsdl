spec: decimal_extra250
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal module public name presence and signal class identity."
    - "decimal does not define __all__ on Python 3.14.4; membership is verified via hasattr() / direct attribute access."
    - "decimal.Decimal.__name__ == 'Decimal' — the main arbitrary-precision decimal class."
    - "decimal.Context.__name__ == 'Context' — the decimal arithmetic context class."
    - "decimal.ROUND_UP is the string 'ROUND_UP' — rounding mode constants are plain str objects."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' — signal for invalid operations."
    - "decimal.Subnormal.__name__ == 'Subnormal', __module__ == 'decimal', base is DecimalException."
    - "decimal.Rounded.__name__ == 'Rounded', base is DecimalException."
    - "decimal.Clamped.__name__ == 'Clamped', base is DecimalException."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal module public class name identity
#
# decimal.Decimal, decimal.Context, and decimal.InvalidOperation are the
# three core public objects. Their __name__ attributes are verified here.
# decimal.ROUND_UP is a rounding mode string constant.
# ---------------------------------------------------------------------------

table decimal_extra250.public_class_names:
  description: "decimal module public class __name__ identity — Decimal, Context, InvalidOperation, and ROUND_UP; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: decxpcn250

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_class_name,
       "Decimal.__name__.__eq__",
       ["Decimal"],
       true,
       "decimal.Decimal.__name__.__eq__('Decimal') == True — Decimal is the main arbitrary-precision decimal floating-point class; its __name__ is 'Decimal'; str.__eq__('Decimal') returns True; new to extra250"]
    - [context_class_name,
       "Context.__name__.__eq__",
       ["Context"],
       true,
       "decimal.Context.__name__.__eq__('Context') == True — Context encapsulates the arithmetic settings (precision, rounding, etc.) for decimal operations; its __name__ is 'Context'; str.__eq__('Context') returns True; new to extra250"]
    - [invalid_operation_name,
       "InvalidOperation.__name__.__eq__",
       ["InvalidOperation"],
       true,
       "decimal.InvalidOperation.__name__.__eq__('InvalidOperation') == True — InvalidOperation is the signal raised for mathematically invalid operations; its __name__ is 'InvalidOperation'; str.__eq__('InvalidOperation') returns True; new to extra250"]
    - [round_up_value,
       "ROUND_UP.__eq__",
       ["ROUND_UP"],
       true,
       "decimal.ROUND_UP.__eq__('ROUND_UP') == True — ROUND_UP is a plain str constant naming the round-away-from-zero rounding mode; str.__eq__('ROUND_UP') returns True; new to extra250"]

# ---------------------------------------------------------------------------
# Table 2: decimal signal class identity — Subnormal, Rounded, Clamped
#
# These three signal classes all inherit directly from DecimalException.
# Their __name__, __module__, and base class name are verified.
# ---------------------------------------------------------------------------

table decimal_extra250.signal_class_identity:
  description: "decimal signal class identity — Subnormal, Rounded, Clamped __name__, __module__, and base; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: decxsci250

  columns: [id, function, args, expected, description]
  rows:
    - [subnormal_name,
       "Subnormal.__name__.__eq__",
       ["Subnormal"],
       true,
       "decimal.Subnormal.__name__.__eq__('Subnormal') == True — Subnormal is the signal raised when a result is subnormal (exponent too small before rounding); its __name__ is 'Subnormal'; str.__eq__('Subnormal') returns True; new to extra250"]
    - [subnormal_module,
       "Subnormal.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Subnormal.__module__.__eq__('decimal') == True — Subnormal is defined in the decimal module (C extension); its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra250"]
    - [subnormal_base,
       "Subnormal.__bases__.__getitem__",
       [0],
       "DecimalException",
       "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal inherits directly from DecimalException, the base class for all decimal signals; __getitem__(0).__name__ is 'DecimalException'; new to extra250"]
    - [rounded_name,
       "Rounded.__name__.__eq__",
       ["Rounded"],
       true,
       "decimal.Rounded.__name__.__eq__('Rounded') == True — Rounded is the signal raised when a result has been rounded (i.e., some digits were discarded); its __name__ is 'Rounded'; str.__eq__('Rounded') returns True; new to extra250"]
    - [rounded_base,
       "Rounded.__bases__.__getitem__",
       [0],
       "DecimalException",
       "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded inherits directly from DecimalException; __getitem__(0).__name__ is 'DecimalException'; new to extra250"]
    - [clamped_name,
       "Clamped.__name__.__eq__",
       ["Clamped"],
       true,
       "decimal.Clamped.__name__.__eq__('Clamped') == True — Clamped is the signal raised when an exponent is altered to fit the current context's Emin/Emax range; its __name__ is 'Clamped'; str.__eq__('Clamped') returns True; new to extra250"]
    - [clamped_base,
       "Clamped.__bases__.__getitem__",
       [0],
       "DecimalException",
       "decimal.Clamped.__bases__[0].__name__ == 'DecimalException' — Clamped inherits directly from DecimalException; __getitem__(0).__name__ is 'DecimalException'; new to extra250"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra250
# ---------------------------------------------------------------------------

invariant decimal_extra250.decimal_name:
  description: "decimal.Decimal.__name__ == 'Decimal' — the main arbitrary-precision decimal class; new to extra250"
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra250.context_name:
  description: "decimal.Context.__name__ == 'Context' — the decimal arithmetic context class; new to extra250"
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra250.round_up_is_string:
  description: "decimal.ROUND_UP.__eq__('ROUND_UP') == True — ROUND_UP is a plain str constant for the round-away-from-zero mode; new to extra250"
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra250.subnormal_name:
  description: "decimal.Subnormal.__name__ == 'Subnormal' — the signal for subnormal results; new to extra250"
  kind: python_call_eq
  function: Subnormal.__name__.__eq__
  args: ["Subnormal"]
  expected: true

invariant decimal_extra250.subnormal_module:
  description: "decimal.Subnormal.__module__ == 'decimal' — Subnormal is defined in the decimal C extension; new to extra250"
  kind: python_call_eq
  function: Subnormal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra250.subnormal_base_is_decimalexception:
  description: "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal inherits from DecimalException; new to extra250"
  kind: python_call_eq
  function: "Subnormal.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra250.rounded_name:
  description: "decimal.Rounded.__name__ == 'Rounded' — the signal for rounded results; new to extra250"
  kind: python_call_eq
  function: Rounded.__name__.__eq__
  args: ["Rounded"]
  expected: true

invariant decimal_extra250.rounded_base_is_decimalexception:
  description: "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded inherits from DecimalException; new to extra250"
  kind: python_call_eq
  function: "Rounded.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra250.clamped_name:
  description: "decimal.Clamped.__name__ == 'Clamped' — the signal for clamped exponents; new to extra250"
  kind: python_call_eq
  function: Clamped.__name__.__eq__
  args: ["Clamped"]
  expected: true

invariant decimal_extra250.clamped_base_is_decimalexception:
  description: "decimal.Clamped.__bases__[0].__name__ == 'DecimalException' — Clamped inherits from DecimalException; new to extra250"
  kind: python_call_eq
  function: "Clamped.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true
