spec: socket_extra270
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra269.zspec.zsdl — covers socket.inet_aton/inet_ntoa/inet_pton/inet_ntop function identity."
    - "socket_extra268.zspec.zsdl — covers socket.create_connection/create_server/socketpair function identity."
  notes:
    - "socket.socket.__init__.__name__ == '__init__' — pure-Python method defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__init__.__class__.__name__ == 'function' — __init__ is a pure-Python function defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__repr__.__name__ == '__repr__' — pure-Python method defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__repr__.__class__.__name__ == 'function' — __repr__ is a pure-Python function defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__str__.__class__.__name__ == 'wrapper_descriptor' — __str__ is inherited from object; socket.socket does not override __str__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for the builtin TimeoutError. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.timeout.__module__ == 'builtins' — TimeoutError is a builtin exception; its __module__ is 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits from OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.family.__class__.__name__ == 'property' — family is a property descriptor on socket.socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.type.__class__.__name__ == 'property' — type is a property descriptor on socket.socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.family.fget.__name__ == 'family' — property getter function is named 'family'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.type.fget.__name__ == 'type' — property getter function is named 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket __init__ and __repr__ method identity
# socket.socket is defined in Lib/socket.py as a pure-Python class wrapping
# the _socket.socket C type. Both __init__ and __repr__ are pure-Python
# functions (class 'function'). __str__ is inherited from object
# (class 'wrapper_descriptor').
# ---------------------------------------------------------------------------

table socket_extra270.socket_class_method_identity:
  description: "socket.socket __init__/__repr__/__str__ method identity — __init__ and __repr__ are 'function' (pure-Python in Lib/socket.py); __str__ is 'wrapper_descriptor' (inherited from object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockmeth270

  columns: [id, function, args, expected, description]
  rows:
    - [init_name,     socket.__init__.__name__.__eq__,          ["__init__"],          true, "socket.socket.__init__.__name__ == '__init__' — pure-Python method in Lib/socket.py"]
    - [init_class,    socket.__init__.__class__.__name__.__eq__, ["function"],          true, "socket.socket.__init__.__class__.__name__ == 'function' — pure-Python function defined in Lib/socket.py"]
    - [repr_name,     socket.__repr__.__name__.__eq__,           ["__repr__"],          true, "socket.socket.__repr__.__name__ == '__repr__' — pure-Python method in Lib/socket.py"]
    - [repr_class,    socket.__repr__.__class__.__name__.__eq__, ["function"],          true, "socket.socket.__repr__.__class__.__name__ == 'function' — pure-Python function defined in Lib/socket.py"]
    - [str_class,     socket.__str__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "socket.socket.__str__.__class__.__name__ == 'wrapper_descriptor' — inherited from object, not overridden"]

# ---------------------------------------------------------------------------
# socket.timeout exception identity and socket.error alias identity
# socket.timeout is an alias for the builtin TimeoutError.
# TimeoutError.__name__ == 'TimeoutError' and __module__ == 'builtins'.
# socket.error is an alias for OSError.
# socket.socket.family and .type are property descriptors with fget functions.
# ---------------------------------------------------------------------------

table socket_extra270.socket_exception_property_identity:
  description: "socket.timeout exception identity and socket property descriptors — timeout.__name__/'TimeoutError', timeout.__module__/'builtins', timeout.__bases__[0]/'OSError', error.__name__/'OSError', family/type are property descriptors; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockexc270

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_name,     timeout.__name__.__eq__,                      ["TimeoutError"],  true, "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for the builtin TimeoutError"]
    - [timeout_module,   timeout.__module__.__eq__,                    ["builtins"],      true, "socket.timeout.__module__ == 'builtins' — TimeoutError is a builtin exception"]
    - [error_name,       error.__name__.__eq__,                        ["OSError"],       true, "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError"]
    - [family_class,     socket.family.__class__.__name__.__eq__,      ["property"],      true, "socket.socket.family.__class__.__name__ == 'property' — family is a property descriptor"]
    - [type_class,       socket.type.__class__.__name__.__eq__,        ["property"],      true, "socket.socket.type.__class__.__name__ == 'property' — type is a property descriptor"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket.socket method and exception identity
# ---------------------------------------------------------------------------

invariant socket_extra270.socket_init_name_eq:
  description: "socket.socket.__init__.__name__ == '__init__' — pure-Python constructor defined in Lib/socket.py wrapping the _socket.socket C type; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant socket_extra270.socket_init_class_eq:
  description: "socket.socket.__init__.__class__.__name__ == 'function' — __init__ is a pure-Python function defined in Lib/socket.py; contrasts with C-extension wrapper_descriptors; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant socket_extra270.socket_repr_name_eq:
  description: "socket.socket.__repr__.__name__ == '__repr__' — pure-Python __repr__ defined in Lib/socket.py that formats the socket fd, family, type, proto; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true

invariant socket_extra270.socket_repr_class_eq:
  description: "socket.socket.__repr__.__class__.__name__ == 'function' — __repr__ is a pure-Python function defined in Lib/socket.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.__repr__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant socket_extra270.socket_str_class_eq:
  description: "socket.socket.__str__.__class__.__name__ == 'wrapper_descriptor' — socket.socket does not override __str__ so it inherits object.__str__; wrapper_descriptor is the C-level descriptor type for inherited slot methods; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.__str__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant socket_extra270.socket_timeout_name_eq:
  description: "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for the builtin TimeoutError exception; its __name__ is 'TimeoutError' not 'timeout'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant socket_extra270.socket_timeout_module_eq:
  description: "socket.timeout.__module__ == 'builtins' — TimeoutError is a builtin exception; __module__ is 'builtins'; socket.timeout is merely an alias for it; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: timeout.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant socket_extra270.socket_timeout_bases0_name_eq:
  description: "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits directly from OSError in the exception hierarchy; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "timeout.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant socket_extra270.socket_error_name_eq:
  description: "socket.error.__name__ == 'OSError' — socket.error is an alias for the builtin OSError; its __name__ is 'OSError' not 'error'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra270.socket_family_fget_name_eq:
  description: "socket.socket.family.fget.__name__ == 'family' — family is a property on socket.socket; its getter function is named 'family'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.family.fget.__name__.__eq__
  args: ["family"]
  expected: true

invariant socket_extra270.socket_type_fget_name_eq:
  description: "socket.socket.type.fget.__name__ == 'type' — type is a property on socket.socket; its getter function is named 'type'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socket.type.fget.__name__.__eq__
  args: ["type"]
  expected: true
