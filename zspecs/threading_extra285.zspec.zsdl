spec: threading_extra285
version: ">=3.4"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers threading module-level metadata: __name__, __package__, __spec__.name, __loader__.__class__.__name__, and __file__ path."
    - "threading.__name__ == 'threading' — module's own name attribute. Verified with Python 3.14.3."
    - "threading.__package__ == '' — empty string; threading is a top-level module. Verified with Python 3.14.3."
    - "threading.__spec__.name == 'threading' — ModuleSpec.name matches the module name. Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is a pure-Python module loaded from threading.py. Verified with Python 3.14.3."
    - "threading.__file__.endswith('threading.py') == True — the module source file ends with threading.py. Verified with Python 3.14.3."
    - "threading.__spec__.__class__.__name__ == 'ModuleSpec' — the spec is a ModuleSpec instance. Verified with Python 3.14.3."
    - "len(threading.__name__) == 9 — 'threading' has 9 characters. Verified with Python 3.14.3."
    - "len(threading.__package__) == 0 — the package string is empty for a top-level module. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module-level identity metadata
#
# threading.__name__ == 'threading'
# threading.__package__ == ''          (empty string, top-level module)
# threading.__spec__.name == 'threading'
# threading.__loader__.__class__.__name__ == 'SourceFileLoader'
# threading.__spec__.__class__.__name__ == 'ModuleSpec'
# ---------------------------------------------------------------------------

table threading_extra285.module_metadata:
  description: "threading module-level metadata: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __spec__.__class__.__name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex285mm

  columns: [id, function, args, expected, description]
  rows:
    - [mm_name_eq,
       __name__.__eq__,
       ["threading"],
       true,
       "threading.__name__ == 'threading' — module's own name attribute; verified with Python 3.14.3"]
    - [mm_pkg_eq,
       __package__.__eq__,
       [""],
       true,
       "threading.__package__ == '' — empty string; threading is a top-level module; verified with Python 3.14.3"]
    - [mm_spec_name_eq,
       __spec__.name.__eq__,
       ["threading"],
       true,
       "threading.__spec__.name == 'threading' — ModuleSpec.name matches the module name; verified with Python 3.14.3"]
    - [mm_loader_cls_eq,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is a pure-Python module; verified with Python 3.14.3"]
    - [mm_spec_cls_eq,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__ == 'ModuleSpec' — spec is a ModuleSpec instance; verified with Python 3.14.3"]
    - [mm_name_len,
       __name__.__len__,
       [],
       9,
       "threading.__name__.__len__() == 9 — 'threading' has 9 characters; verified with Python 3.14.3"]
    - [mm_pkg_len,
       __package__.__len__,
       [],
       0,
       "threading.__package__.__len__() == 0 — empty package string has length 0; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: threading __file__ path checks
#
# threading.__file__.endswith('threading.py') == True
# threading.__file__.__contains__('threading') == True
# ---------------------------------------------------------------------------

table threading_extra285.module_file:
  description: "threading.__file__ path ends with 'threading.py' and contains 'threading'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex285mf

  columns: [id, function, args, expected, description]
  rows:
    - [mf_endswith,
       __file__.endswith,
       ["threading.py"],
       true,
       "threading.__file__.endswith('threading.py') == True — source file path ends with threading.py; verified with Python 3.14.3"]
    - [mf_contains,
       __file__.__contains__,
       ["threading"],
       true,
       "threading.__file__.__contains__('threading') == True — source file path contains the module name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra285
# ---------------------------------------------------------------------------

invariant threading_extra285.module_name_is_threading:
  description: "threading.__name__ == 'threading' — module name attribute; new to extra285"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra285.module_package_is_empty_string:
  description: "threading.__package__ == '' — empty string; threading is a top-level module; new to extra285"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant threading_extra285.spec_name_is_threading:
  description: "threading.__spec__.name == 'threading' — ModuleSpec.name matches __name__; new to extra285"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra285.loader_is_source_file_loader:
  description: "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is loaded from a .py source file; new to extra285"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra285.file_endswith_threading_py:
  description: "threading.__file__.endswith('threading.py') == True — the module source ends with threading.py; new to extra285"
  category: identity
  kind: python_call_eq
  function: __file__.endswith
  args: ["threading.py"]
  expected: true

invariant threading_extra285.spec_class_is_module_spec:
  description: "threading.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec instance; new to extra285"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant threading_extra285.name_len_is_9:
  description: "threading.__name__.__len__() == 9 — 'threading' has 9 characters; new to extra285"
  category: identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant threading_extra285.package_len_is_0:
  description: "threading.__package__.__len__() == 0 — the package string is empty (length 0) for a top-level module; new to extra285"
  category: identity
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0
