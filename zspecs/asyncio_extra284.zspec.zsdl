spec: asyncio_extra284
version: ">=3.4"
backend: python_module(asyncio.tasks)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio Tasks documentation"
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "asyncio_extra283.zspec.zsdl — covers asyncio.queues module identity; Queue/LifoQueue/PriorityQueue/QueueShutDown class identity; Queue method __qualname__ lengths"
    - "asyncio_extra282.zspec.zsdl — covers asyncio.coroutines module identity; iscoroutine and iscoroutinefunction function identity"
    - "asyncio_extra281.zspec.zsdl — covers asyncio.runners module identity; asyncio.run and asyncio.Runner class identity"
    - "asyncio_extra280.zspec.zsdl — covers asyncio.exceptions module identity; CancelledError, InvalidStateError, SendfileNotAvailableError class identity"
    - "asyncio_extra28.zspec.zsdl — covers Queue/Lock/Event __module__.__len__(); class __name__.__len__() and function __qualname__ checks"
    - "asyncio_extra.zspec.zsdl — covers Queue/Lock/Event/Semaphore/Task/Future __name__ and __module__ equality checks"
  notes:
    - "This spec covers: asyncio.tasks submodule identity (__name__, __spec__.name, __package__, __loader__.__class__.__name__, __all__ class and len); asyncio.Task class identity (__name__, __module__=='_asyncio', __bases__[0].__name__=='Future', __mro__.__len__()==3); asyncio.Task method __qualname__ lengths (cancel, result, done, set_result, get_name, get_coro, set_name, uncancel, cancelling, add_done_callback); top-level asyncio.tasks function __qualname__ lengths (sleep, gather, create_task, wait_for, shield, current_task, all_tasks)."
    - "asyncio.tasks.__name__ == 'asyncio.tasks' (len=13); __package__ == 'asyncio' (len=7); __spec__.name == 'asyncio.tasks'; __loader__.__class__.__name__ == 'SourceFileLoader' (pure Python source module). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.tasks.__all__ is a tuple with 21 members. Includes Task, create_task, FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED, wait, wait_for, as_completed, sleep, gather, shield, ensure_future, run_coroutine_threadsafe, current_task, all_tasks, create_eager_task_factory, eager_task_factory, and several private _register/_enter/_leave_task helpers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Task is implemented in the C extension module _asyncio. Task.__module__ == '_asyncio' (NOT 'asyncio.tasks'). Task.__bases__[0].__name__ == 'Future' (also from _asyncio). Task.__mro__.__len__() == 3 ([Task, Future, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Task method __qualname__ lengths: cancel=11, result=11, done=9, set_result=15, cancelling=15, get_name=13, get_coro=13, set_name=13, uncancel=13, add_done_callback=22. add_done_callback is the longest (22 chars). done is the shortest (9 chars). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Top-level asyncio.tasks function __qualname__ lengths: sleep=5, gather=6, shield=6, wait_for=8, all_tasks=9, create_task=11, current_task=12. current_task is the longest (12 chars). sleep is the shortest (5 chars). All are module-level functions so __qualname__ == __name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.tasks module identity — extra284
#
# asyncio.tasks.__name__             == 'asyncio.tasks'    (len=13)
# asyncio.tasks.__spec__.name        == 'asyncio.tasks'
# asyncio.tasks.__package__          == 'asyncio'           (len=7)
# asyncio.tasks.__loader__.__class__.__name__ == 'SourceFileLoader'
# asyncio.tasks.__all__.__class__.__name__    == 'tuple'
# asyncio.tasks.__all__.__len__()             == 21
# ---------------------------------------------------------------------------

table asyncio_extra284.asyncio_tasks_module_identity:
  description: "asyncio.tasks module identity checks in extra284 namespace — asyncio.tasks.__name__=='asyncio.tasks' (len=13); __spec__.name=='asyncio.tasks'; __package__=='asyncio' (len=7); __loader__.__class__.__name__=='SourceFileLoader'; __all__ is a tuple with 21 members; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotasks284

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   asyncio.tasks.__name__.__eq__,                      ["asyncio.tasks"],    true,  "asyncio.tasks.__name__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [mod_spec_eq,   asyncio.tasks.__spec__.name.__eq__,                 ["asyncio.tasks"],    true,  "asyncio.tasks.__spec__.name == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [mod_name_len,  asyncio.tasks.__name__.__len__,                     [],                   13,    "asyncio.tasks.__name__.__len__() == 13 ('asyncio.tasks'=13); verified with Python 3.14.3"]
    - [mod_pkg_eq,    asyncio.tasks.__package__.__eq__,                   ["asyncio"],          true,  "asyncio.tasks.__package__ == 'asyncio' (parent package); verified with Python 3.14.3"]
    - [mod_pkg_len,   asyncio.tasks.__package__.__len__,                  [],                   7,     "asyncio.tasks.__package__.__len__() == 7 ('asyncio'=7); verified with Python 3.14.3"]
    - [mod_loader_eq, asyncio.tasks.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true,  "asyncio.tasks.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]
    - [all_class_eq,  asyncio.tasks.__all__.__class__.__name__.__eq__,    ["tuple"],            true,  "asyncio.tasks.__all__.__class__.__name__ == 'tuple' (not a list); verified with Python 3.14.3"]
    - [all_len,       asyncio.tasks.__all__.__len__,                      [],                   21,    "asyncio.tasks.__all__.__len__() == 21 — Task, create_task, sleep, gather, wait, wait_for, shield, etc.; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task class identity — extra284
#
# asyncio.Task is implemented in the _asyncio C extension module.
# Key facts:
#   Task.__name__               == 'Task'
#   Task.__module__             == '_asyncio'  (NOT 'asyncio.tasks')
#   Task.__bases__[0].__name__  == 'Future'
#   Task.__mro__.__len__()      == 3  ([Task, Future, object])
# ---------------------------------------------------------------------------

table asyncio_extra284.task_class_identity:
  description: "asyncio.Task class identity checks in extra284 namespace — Task is from _asyncio C extension; __module__=='_asyncio' (NOT asyncio.tasks); __bases__[0].__name__=='Future'; __mro__.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: taskident284

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,     Task.__name__.__eq__,              ["Task"],     true,  "Task.__name__ == 'Task'; verified with Python 3.14.3"]
    - [module_eq,   Task.__module__.__eq__,             ["_asyncio"], true,  "Task.__module__ == '_asyncio' — implemented in C extension (not asyncio.tasks); verified with Python 3.14.3"]
    - [base_eq,     "Task.__bases__[0].__name__.__eq__", ["Future"],  true,  "Task.__bases__[0].__name__ == 'Future' — Task subclasses Future; verified with Python 3.14.3"]
    - [mro_len,     Task.__mro__.__len__,               [],           3,     "Task.__mro__.__len__() == 3 — [Task, Future, object]; verified with Python 3.14.3"]
    - [name_len,    Task.__name__.__len__,               [],           4,     "Task.__name__.__len__() == 4 — 'Task' is 4 characters; verified with Python 3.14.3"]
    - [module_len,  Task.__module__.__len__,             [],           7,     "Task.__module__.__len__() == 7 — '_asyncio' is 7 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task method __qualname__ lengths — extra284
#
# Task methods carry 'Task.' (5 chars) as their __qualname__ prefix:
#   Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (22)
#   Task.set_result.__qualname__        == 'Task.set_result'        (15)
#   Task.cancelling.__qualname__        == 'Task.cancelling'        (15)
#   Task.get_name.__qualname__          == 'Task.get_name'          (13)
#   Task.get_coro.__qualname__          == 'Task.get_coro'          (13)
#   Task.set_name.__qualname__          == 'Task.set_name'          (13)
#   Task.uncancel.__qualname__          == 'Task.uncancel'          (13)
#   Task.cancel.__qualname__            == 'Task.cancel'            (11)
#   Task.result.__qualname__            == 'Task.result'            (11)
#   Task.done.__qualname__              == 'Task.done'              (9)
# add_done_callback is the longest (22); done is the shortest (9).
# ---------------------------------------------------------------------------

table asyncio_extra284.task_method_qualname_lengths:
  description: "asyncio.Task method __qualname__.__len__() in extra284 namespace — add_done_callback is longest (22); done is shortest (9); set_result and cancelling tie at 15; get_name/get_coro/set_name/uncancel tie at 13; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: taskmqlen284

  columns: [id, function, args, expected]
  rows:
    - [add_done_callback, Task.add_done_callback.__qualname__.__len__, [], 22]
    - [set_result,        Task.set_result.__qualname__.__len__,        [], 15]
    - [cancelling,        Task.cancelling.__qualname__.__len__,        [], 15]
    - [get_name,          Task.get_name.__qualname__.__len__,          [], 13]
    - [get_coro,          Task.get_coro.__qualname__.__len__,          [], 13]
    - [set_name,          Task.set_name.__qualname__.__len__,          [], 13]
    - [uncancel,          Task.uncancel.__qualname__.__len__,          [], 13]
    - [cancel,            Task.cancel.__qualname__.__len__,            [], 11]
    - [result,            Task.result.__qualname__.__len__,            [], 11]
    - [done,              Task.done.__qualname__.__len__,              [], 9]

# ---------------------------------------------------------------------------
# asyncio.tasks top-level function __qualname__ lengths — extra284
#
# All are module-level functions, so __qualname__ == __name__:
#   sleep.__qualname__        == 'sleep'        (5)
#   gather.__qualname__       == 'gather'       (6)
#   shield.__qualname__       == 'shield'       (6)
#   wait_for.__qualname__     == 'wait_for'     (8)
#   all_tasks.__qualname__    == 'all_tasks'    (9)
#   create_task.__qualname__  == 'create_task'  (11)
#   current_task.__qualname__ == 'current_task' (12)
# current_task is the longest (12 chars); sleep is the shortest (5 chars).
# ---------------------------------------------------------------------------

invariant asyncio_extra284.sleep.qualname_len:
  description: "asyncio.tasks.sleep.__qualname__.__len__() == 5 — 'sleep' is 5 characters; shortest of the surveyed asyncio.tasks functions"
  category: functions
  kind: python_call_eq
  function: sleep.__qualname__.__len__
  args: []
  expected: 5

invariant asyncio_extra284.gather.qualname_len:
  description: "asyncio.tasks.gather.__qualname__.__len__() == 6 — 'gather' is 6 characters"
  category: functions
  kind: python_call_eq
  function: gather.__qualname__.__len__
  args: []
  expected: 6

invariant asyncio_extra284.wait_for.qualname_len:
  description: "asyncio.tasks.wait_for.__qualname__.__len__() == 8 — 'wait_for' is 8 characters"
  category: functions
  kind: python_call_eq
  function: wait_for.__qualname__.__len__
  args: []
  expected: 8

invariant asyncio_extra284.create_task.qualname_len:
  description: "asyncio.tasks.create_task.__qualname__.__len__() == 11 — 'create_task' is 11 characters"
  category: functions
  kind: python_call_eq
  function: create_task.__qualname__.__len__
  args: []
  expected: 11

invariant asyncio_extra284.current_task.qualname_len:
  description: "asyncio.tasks.current_task.__qualname__.__len__() == 12 — 'current_task' is 12 characters; longest of the surveyed asyncio.tasks functions"
  category: functions
  kind: python_call_eq
  function: current_task.__qualname__.__len__
  args: []
  expected: 12

invariant asyncio_extra284.Task.add_done_callback_qualname_eq:
  description: "asyncio.Task.add_done_callback.__qualname__ == 'Task.add_done_callback' — the longest Task method qualname (len=22)"
  category: method_names
  kind: python_call_eq
  function: Task.add_done_callback.__qualname__.__eq__
  args: ["Task.add_done_callback"]
  expected: true

invariant asyncio_extra284.Task.cancel_qualname_eq:
  description: "asyncio.Task.cancel.__qualname__ == 'Task.cancel' — cancel method on Task (len=11)"
  category: method_names
  kind: python_call_eq
  function: Task.cancel.__qualname__.__eq__
  args: ["Task.cancel"]
  expected: true
