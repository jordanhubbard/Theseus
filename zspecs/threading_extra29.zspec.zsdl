spec: threading_extra29
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra28.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__module__/__qualname__, Lock/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier class names and modules, current_thread/main_thread/active_count/enumerate/__name__, TIMEOUT_MAX, local().__class__.__name__, threading.excepthook/__name__, threading.stack_size/__name__, Thread.__init__.__name__, Event.__qualname__=='Event', various __module__ checks, class __name__ length table for Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier."
    - "This spec covers: __module__.__len__() for Thread/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier; __qualname__.__len__() for Thread/Event/Condition; __name__.__len__() for Thread/Event."
    - "Thread.__module__ == 'threading' — length 9."
    - "Event.__module__ == 'threading' — length 9."
    - "Condition.__module__ == 'threading' — length 9."
    - "Semaphore.__module__ == 'threading' — length 9."
    - "BoundedSemaphore.__module__ == 'threading' — length 9."
    - "Timer.__module__ == 'threading' — length 9."
    - "Barrier.__module__ == 'threading' — length 9."
    - "Thread.__qualname__ == 'Thread' — length 6."
    - "Event.__qualname__ == 'Event' — length 5."
    - "Condition.__qualname__ == 'Condition' — length 9."
    - "Thread.__name__ == 'Thread' — length 6."
    - "Event.__name__ == 'Event' — length 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ length table — extra29 namespace
#
# All threading sync classes (Thread, Event, Condition, Semaphore,
# BoundedSemaphore, Timer, Barrier) are pure-Python classes defined in
# Lib/threading.py. Their __module__ == 'threading' (length 9). Prior specs
# check __module__ equality; this spec adds the __len__() axis.
# ---------------------------------------------------------------------------

table threading_extra29.class_module_lengths:
  description: "threading class __module__ lengths in extra29 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmodlen29

  columns: [id, function, args, expected]
  rows:
    - [Thread,            Thread.__module__.__len__,            [], 9]
    - [Event,             Event.__module__.__len__,             [], 9]
    - [Condition,         Condition.__module__.__len__,         [], 9]
    - [Semaphore,         Semaphore.__module__.__len__,         [], 9]
    - [BoundedSemaphore,  BoundedSemaphore.__module__.__len__,  [], 9]
    - [Timer,             Timer.__module__.__len__,             [], 9]
    - [Barrier,           Barrier.__module__.__len__,           [], 9]

# ---------------------------------------------------------------------------
# Class __qualname__ length table — extra29 namespace
#
# Thread.__qualname__ == 'Thread' (length 6).
# Event.__qualname__ == 'Event' (length 5).
# Condition.__qualname__ == 'Condition' (length 9).
# Prior specs check __qualname__ equality for these classes; this spec adds
# the __len__() dimension for Thread, Event, and Condition.
# ---------------------------------------------------------------------------

table threading_extra29.class_qualname_lengths:
  description: "threading class __qualname__ lengths in extra29 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsqualnamelen29

  columns: [id, function, args, expected]
  rows:
    - [Thread,    Thread.__qualname__.__len__,    [], 6]
    - [Event,     Event.__qualname__.__len__,     [], 5]
    - [Condition, Condition.__qualname__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Thread.__name__.__len__() — standalone extra29 invariant
#
# threading.Thread.__name__ == 'Thread' (length 6). Prior specs confirm the
# string value; this spec adds the length invariant in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra29.Thread.name_len:
  description: "threading.Thread.__name__.__len__() == 6 — 'Thread' has six characters"
  category: method_names
  kind: python_call_eq
  function: Thread.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Event.__name__.__len__() — standalone extra29 invariant
#
# threading.Event.__name__ == 'Event' (length 5). Prior specs confirm the
# string value; this spec adds the length invariant in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra29.Event.name_len:
  description: "threading.Event.__name__.__len__() == 5 — 'Event' has five characters"
  category: method_names
  kind: python_call_eq
  function: Event.__name__.__len__
  args: []
  expected: 5
