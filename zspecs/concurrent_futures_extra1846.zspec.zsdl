spec: concurrent_futures_extra1846
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "concurrent.futures stdlib documentation"
    - "CPython source: Lib/concurrent/futures/"
  not_derived_from:
    - "any third-party executor extensions"
  notes:
    - "concurrent.futures classes do not define arithmetic or comparison operators"
    - "Future does not define __eq__ and inherits identity-based comparison from object"
  created_at: "2026-04-12"

