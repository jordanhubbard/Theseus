spec: pathlib_extra253
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python 3 pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath component access, parent, parts, predicates, manipulation, joining, str"
    - "pathlib_extra.zspec.zsdl — covers Path.__name__, PurePosixPath.module, component/parent/truediv/parts/suffix/is_absolute"
    - "pathlib_extra252.zspec.zsdl — covers PurePath class identity, method __name__/__qualname__ for joinpath/with_name/with_suffix"
  notes:
    - "This spec covers: pathlib.PurePath behavioral contracts — name, stem, suffix, parts for known paths."
    - "PurePath('/a/b/c.txt').name == 'c.txt' — the final path component including extension; verified Python 3.14.3 macOS."
    - "PurePath('/a/b/c.txt').stem == 'c' — the final component without its last suffix; verified Python 3.14.3 macOS."
    - "PurePath('/a/b/c.txt').suffix == '.txt' — the file extension including the leading dot; verified Python 3.14.3 macOS."
    - "PurePath('/a/b/c').suffix == '' — a path component with no extension has an empty suffix; verified Python 3.14.3 macOS."
    - "PurePath('a/b').name == 'b' — the name of a relative path's final component; verified Python 3.14.3 macOS."
    - "PurePath('/').name == '' — the root path '/' has no final component so name is empty string; verified Python 3.14.3 macOS."
    - "PurePath('/a/b/c').parts == ('/', 'a', 'b', 'c') — tuple of path components; verified Python 3.14.3 macOS."
    - "PurePath('/a/b/c.txt').parts == ('/', 'a', 'b', 'c.txt') — parts includes extension in last component; verified Python 3.14.3 macOS."
    - "PurePath('/a/b/c').stem == 'c' — stem of a path without extension equals name; verified Python 3.14.3 macOS."
    - "PurePath('a/b/c').parts == ('a', 'b', 'c') — relative path parts has no leading '/'; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath.name behavioral contracts
# name is the string name of the final path component (not a method call).
# Accessed as an attribute, so we use method: name.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra253.purepath_name:
  description: "PurePath.name for various paths: c.txt, b, empty for root; verified Python 3.14.3"
  kind: python_call_eq
  category: components
  id_prefix: pathpurebeh253
  function: PurePath
  method: name

  columns: [id, args, expected]
  rows:
    - [name_c_txt,   ["/a/b/c.txt"],  "c.txt"]
    - [name_c,       ["/a/b/c"],      "c"]
    - [name_ab_b,    ["a/b"],         "b"]
    - [name_root,    ["/"],           ""]
    - [name_abc_c,   ["/a/b/c"],      "c"]

# ---------------------------------------------------------------------------
# PurePath.stem behavioral contracts
# stem is the final component without its last suffix.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra253.purepath_stem:
  description: "PurePath.stem for paths with and without extensions; verified Python 3.14.3"
  kind: python_call_eq
  category: components
  id_prefix: pathpurebeh253
  function: PurePath
  method: stem

  columns: [id, args, expected]
  rows:
    - [stem_c_txt,  ["/a/b/c.txt"], "c"]
    - [stem_c,      ["/a/b/c"],     "c"]
    - [stem_ab_b,   ["a/b"],        "b"]

# ---------------------------------------------------------------------------
# PurePath.suffix behavioral contracts
# suffix is the file extension of the final component (includes leading dot),
# or '' if there is no extension.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra253.purepath_suffix:
  description: "PurePath.suffix for paths with .txt extension, no extension, empty root; verified Python 3.14.3"
  kind: python_call_eq
  category: components
  id_prefix: pathpurebeh253
  function: PurePath
  method: suffix

  columns: [id, args, expected]
  rows:
    - [suffix_txt,      ["/a/b/c.txt"], ".txt"]
    - [suffix_no_ext,   ["/a/b/c"],     ""]
    - [suffix_rel_b,    ["a/b"],        ""]
    - [suffix_root,     ["/"],          ""]

# ---------------------------------------------------------------------------
# PurePath.is_absolute behavioral contracts
# is_absolute() returns True if the path starts with '/'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra253.purepath_is_absolute:
  description: "PurePath.is_absolute() returns True for absolute paths, False for relative; verified Python 3.14.3"
  kind: python_call_eq
  category: predicates
  id_prefix: pathpurebeh253
  function: PurePath
  method: is_absolute

  columns: [id, args, expected]
  rows:
    - [abs_ctxt,   ["/a/b/c.txt"],  true ]
    - [abs_abc,    ["/a/b/c"],      true ]
    - [rel_ab,     ["a/b"],         false]
    - [rel_abc,    ["a/b/c"],       false]

# ---------------------------------------------------------------------------
# Standalone invariants — PurePath.name
# ---------------------------------------------------------------------------

invariant pathlib_extra253.PurePath.name.c_txt:
  description: "PurePath('/a/b/c.txt').name == 'c.txt' — the final path component including its extension; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c.txt"]
  method: name
  expected: "c.txt"

invariant pathlib_extra253.PurePath.name.c_no_ext:
  description: "PurePath('/a/b/c').name == 'c' — the final component of a path without extension; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c"]
  method: name
  expected: "c"

invariant pathlib_extra253.PurePath.name.ab_b:
  description: "PurePath('a/b').name == 'b' — the final component of a two-element relative path; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["a/b"]
  method: name
  expected: "b"

invariant pathlib_extra253.PurePath.name.root_empty:
  description: "PurePath('/').name == '' — the root-only path '/' has no final component, so name is the empty string; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/"]
  method: name
  expected: ""

# ---------------------------------------------------------------------------
# Standalone invariants — PurePath.stem
# ---------------------------------------------------------------------------

invariant pathlib_extra253.PurePath.stem.c_txt:
  description: "PurePath('/a/b/c.txt').stem == 'c' — the final component stripped of its last suffix; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c.txt"]
  method: stem
  expected: "c"

invariant pathlib_extra253.PurePath.stem.no_ext:
  description: "PurePath('/a/b/c').stem == 'c' — stem equals name when there is no extension; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c"]
  method: stem
  expected: "c"

# ---------------------------------------------------------------------------
# Standalone invariants — PurePath.suffix
# ---------------------------------------------------------------------------

invariant pathlib_extra253.PurePath.suffix.txt:
  description: "PurePath('/a/b/c.txt').suffix == '.txt' — the file extension includes the leading dot; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c.txt"]
  method: suffix
  expected: ".txt"

invariant pathlib_extra253.PurePath.suffix.no_ext_empty:
  description: "PurePath('/a/b/c').suffix == '' — a path with no extension has an empty suffix; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c"]
  method: suffix
  expected: ""

# ---------------------------------------------------------------------------
# Standalone invariants — PurePath.parts
# ---------------------------------------------------------------------------

invariant pathlib_extra253.PurePath.parts.abc:
  description: "PurePath('/a/b/c').parts == ('/', 'a', 'b', 'c') — tuple of all path components; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c"]
  method: parts
  expected: ["/", "a", "b", "c"]

invariant pathlib_extra253.PurePath.parts.c_txt:
  description: "PurePath('/a/b/c.txt').parts == ('/', 'a', 'b', 'c.txt') — parts includes extension in last component; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["/a/b/c.txt"]
  method: parts
  expected: ["/", "a", "b", "c.txt"]

invariant pathlib_extra253.PurePath.parts.relative:
  description: "PurePath('a/b/c').parts == ('a', 'b', 'c') — relative path parts has no leading '/'; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePath
  args: ["a/b/c"]
  method: parts
  expected: ["a", "b", "c"]
