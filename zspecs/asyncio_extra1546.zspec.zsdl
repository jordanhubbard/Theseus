spec: asyncio_extra1546
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 550 (_extra1546): bitwise operator dict-presence checks for asyncio classes."
    - "asyncio.Queue, asyncio.Task, asyncio.Future, asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.Barrier, asyncio.TaskGroup are not bitwise types."
    - "None of these classes define __and__, __or__, __xor__, __invert__, __lshift__, __rshift__ or their reflected variants in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue — bitwise operator dict-presence (all False)
# ---------------------------------------------------------------------------

table asyncio_extra1546.queue_bitwise_ops:
  description: "asyncio.Queue.__dict__ does not contain any bitwise operator dunder"
  kind: python_call_eq
  category: bitwise_presence
  id_prefix: as1546qu

  columns: [id, function, args, expected]
  rows:
    - [as1546qu001, asyncio.Queue.__dict__.__contains__, ["__and__"],     false]
    - [as1546qu002, asyncio.Queue.__dict__.__contains__, ["__or__"],      false]
    - [as1546qu003, asyncio.Queue.__dict__.__contains__, ["__xor__"],     false]
    - [as1546qu004, asyncio.Queue.__dict__.__contains__, ["__invert__"],  false]
    - [as1546qu005, asyncio.Queue.__dict__.__contains__, ["__lshift__"],  false]
    - [as1546qu006, asyncio.Queue.__dict__.__contains__, ["__rshift__"],  false]
    - [as1546qu007, asyncio.Queue.__dict__.__contains__, ["__rand__"],    false]
    - [as1546qu008, asyncio.Queue.__dict__.__contains__, ["__ror__"],     false]
    - [as1546qu009, asyncio.Queue.__dict__.__contains__, ["__rxor__"],    false]
    - [as1546qu010, asyncio.Queue.__dict__.__contains__, ["__rlshift__"], false]
    - [as1546qu011, asyncio.Queue.__dict__.__contains__, ["__rrshift__"], false]

