spec: hashlib_extra1081
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks sha1/sha224/sha384/sha512 constructor qualnames and module, HASH object __class__.__name__ identity, hashlib.md5.__doc__.__class__.__name__, and hashlib.__spec__.name"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1081.sha_constructor_qualnames:
  description: "sha1/sha224/sha384/sha512 constructor __qualname__ and __module__ identity"
  kind: python_call_eq
  category: sha_constructor_attrs
  id_prefix: hl1081sc
  columns: [id, function, args, expected]
  rows:
    - [hl1081sc001, hashlib.sha1.__qualname__.__eq__,    ["openssl_sha1"],   true]
    - [hl1081sc002, hashlib.sha224.__qualname__.__eq__,  ["openssl_sha224"], true]
    - [hl1081sc003, hashlib.sha384.__qualname__.__eq__,  ["openssl_sha384"], true]
    - [hl1081sc004, hashlib.sha512.__qualname__.__eq__,  ["openssl_sha512"], true]
    - [hl1081sc005, hashlib.sha1.__module__.__eq__,      ["_hashlib"],       true]
    - [hl1081sc006, hashlib.sha224.__module__.__eq__,    ["_hashlib"],       true]
    - [hl1081sc007, hashlib.sha384.__module__.__eq__,    ["_hashlib"],       true]
    - [hl1081sc008, hashlib.sha512.__module__.__eq__,    ["_hashlib"],       true]

table hashlib_extra1081.hash_object_class_name:
  description: "HASH object __class__.__name__ identity for md5, sha1, sha256, sha512 instances"
  kind: python_call_eq
  category: hash_object_classname
  id_prefix: hl1081ho
  columns: [id, function, args, expected]
  rows:
    - [hl1081ho001, hashlib.md5.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [hl1081ho002, hashlib.sha1.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [hl1081ho003, hashlib.sha256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl1081ho004, hashlib.sha512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl1081ho005, hashlib.sha224.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl1081ho006, hashlib.sha384.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl1081ho007, hashlib.md5.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [hl1081ho008, hashlib.sha1.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [hl1081ho009, hashlib.sha256.__qualname__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra1081.module_doc_and_spec:
  description: "hashlib.md5.__doc__.__class__.__name__ and hashlib.__spec__.name identity"
  kind: python_call_eq
  category: module_doc_spec
  id_prefix: hl1081ms
  columns: [id, function, args, expected]
  rows:
    - [hl1081ms001, hashlib.md5.__doc__.__class__.__name__.__eq__,    ["str"],     true]
    - [hl1081ms002, hashlib.sha256.__doc__.__class__.__name__.__eq__, ["str"],     true]
    - [hl1081ms003, hashlib.sha512.__doc__.__class__.__name__.__eq__, ["str"],     true]
    - [hl1081ms004, hashlib.new.__doc__.__class__.__name__.__eq__,    ["str"],     true]
    - [hl1081ms005, hashlib.__spec__.name.__eq__,                     ["hashlib"], true]
    - [hl1081ms006, hashlib.__spec__.name.__class__.__name__.__eq__,  ["str"],     true]
