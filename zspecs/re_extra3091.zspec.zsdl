    - ["re3091013", operator.contains, [re.Match.__dict__,     "__hash__"], false]
    - ["re3091014", operator.contains, [re.Match.__dict__,     "__eq__"],   false]
    - ["re3091015", operator.contains, [re.Match.__dict__,     "__bool__"], false]
    - ["re3091016", operator.contains, [re.RegexFlag.__dict__,  "__hash__"], false]
    - ["re3091017", operator.contains, [re.RegexFlag.__dict__,  "__eq__"],   false]
    - ["re3091018", operator.contains, [re.RegexFlag.__dict__,  "__bool__"], false]
    - ["re3091019", operator.contains, [re.Pattern.__dict__,   "__hash__"], true]
