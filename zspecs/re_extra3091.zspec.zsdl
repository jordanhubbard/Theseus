spec: re3091
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (re3091): __hash__, __eq__, __bool__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "re.Pattern defines both __hash__ and __eq__ in its own __dict__: compiled patterns support value-based equality and hashing (by pattern string and flags)."
    - "re.Match does NOT define __hash__, __eq__, or __bool__ in its own __dict__; identity-based comparison is inherited from object."
    - "re.RegexFlag does NOT define __hash__, __eq__, or __bool__ in its own __dict__; it is an IntFlag enum and inherits these from IntFlag/int."
    - "No re type defines __bool__ in its own __dict__; all false."
    - "re.Pattern.__dict__ is accessed directly (not via type(re.compile(...)).__dict__) per wave 653 convention."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# re.Pattern defines __hash__ (true): compiled patterns are hashable by value.
# re.Match and re.RegexFlag do not define __hash__ in their own __dict__ (false).
# re.Pattern.__dict__ is used directly, not type(re.compile(...)).__dict__.
# ---------------------------------------------------------------------------

table re3091.hash:
  description: "re types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3091

  columns: [id, function, args, expected]
  rows:
    - ["re3091001", operator.contains, [re.Pattern.__dict__,   "__hash__"], true]
    - ["re3091002", operator.contains, [re.Match.__dict__,     "__hash__"], false]
    - ["re3091003", operator.contains, [re.RegexFlag.__dict__,  "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# re.Pattern defines __eq__ (true): compiled patterns compare equal when
# they have the same pattern string and flags.
# re.Match and re.RegexFlag do not define __eq__ in their own __dict__ (false).
# ---------------------------------------------------------------------------

table re3091.eq:
  description: "re types __eq__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3091

  columns: [id, function, args, expected]
  rows:
    - ["re3091004", operator.contains, [re.Pattern.__dict__,   "__eq__"], true]
    - ["re3091005", operator.contains, [re.Match.__dict__,     "__eq__"], false]
    - ["re3091006", operator.contains, [re.RegexFlag.__dict__,  "__eq__"], false]

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# No re type defines __bool__ in its own __dict__; all false.
# re.Pattern, re.Match, and re.RegexFlag do not override boolean coercion.
# ---------------------------------------------------------------------------

table re3091.bool:
  description: "re types __bool__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3091

  columns: [id, function, args, expected]
  rows:
    - ["re3091007", operator.contains, [re.Pattern.__dict__,   "__bool__"], false]
    - ["re3091008", operator.contains, [re.Match.__dict__,     "__bool__"], false]
    - ["re3091009", operator.contains, [re.RegexFlag.__dict__,  "__bool__"], false]

# ---------------------------------------------------------------------------
# combined — __hash__, __eq__, __bool__ across all 3 re subjects
#
# Full matrix: 3 classes x 3 methods = 9 rows, padded with additional
# cross-checks cycling through the 3 subjects to reach ~24 rows.
# __hash__: re.Pattern=true; re.Match=false; re.RegexFlag=false.
# __eq__:   re.Pattern=true; re.Match=false; re.RegexFlag=false.
# __bool__: all false — no re type overrides boolean coercion.
# ---------------------------------------------------------------------------

table re3091.combined:
