spec: multiprocessing_extra183
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "All four exception classes (ProcessError, BufferTooShort, TimeoutError, AuthenticationError) have __module__=='multiprocessing.context'."
    - "multiprocessing.TimeoutError is NOT the builtin TimeoutError; it is a distinct class with __bases__[0].__name__=='ProcessError'."
    - "multiprocessing.TimeoutError.__name__ == 'TimeoutError' (len=12); it lives in multiprocessing.context."
    - "ProcessError.__bases__[0].__name__ == 'Exception'; all others have __bases__[0].__name__ == 'ProcessError'."
    - "Name lengths: ProcessError=12, BufferTooShort=14, TimeoutError=12, AuthenticationError=19."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

