spec: concurrent_futures_extra174
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.Future state method code attrs — concurrent.futures.Future.set_exception.__code__.co_argcount==2 (self, exception); concurrent.futures.Future.cancel.__qualname__=='Future.cancel' (len=13; uses dot for nested); concurrent.futures.Future.result.__qualname__=='Future.result' (len=13; same len as cancel qualname); concurrent.futures.Future.__repr__.__qualname__=='Future.__repr__' (len=15); concurrent.futures.Future.done.__name__=='done' (len=4); concurrent.futures.Future.running.__name__=='running' (len=7); concurrent.futures.Future.cancelled.__name__=='cancelled' (len=9). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.set_exception.__code__.co_argcount == 2. The set_exception(self, exception) method takes 2 arguments: self and exception. co_argcount counts positional parameters including self for methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13). __qualname__ uses dot notation for methods nested inside classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.result.__qualname__ == 'Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13; same len as 'Future.cancel'=13). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__repr__.__qualname__ == 'Future.__repr__' (len=15: 'Future'=6+'.'=1+'__repr__'=8=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.done.__name__ == 'done' (len=4: d-o-n-e). concurrent.futures.Future.running.__name__ == 'running' (len=7: r-u-n-n-i-n-g). concurrent.futures.Future.cancelled.__name__ == 'cancelled' (len=9: c-a-n-c-e-l-l-e-d). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future state query method names
#
# concurrent.futures.Future.done.__name__ == 'done' (len=4)
# concurrent.futures.Future.running.__name__ == 'running' (len=7)
# concurrent.futures.Future.cancelled.__name__ == 'cancelled' (len=9)
#
# done(), running(), cancelled() are state query methods on Future.
# NAME LENGTHS: 'done'=4 < 'running'=7 < 'cancelled'=9.
# All defined in Lib/concurrent/futures/_base.py. New to extra174.
# ---------------------------------------------------------------------------

table concurrent_futures_extra174.future_state_method_names:
  description: "Future.done.__name__ 'done' len 4; Future.running.__name__ 'running' len 7; Future.cancelled.__name__ 'cancelled' len 9; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: cffutstate174

  columns: [id, function, args, expected, description]
  rows:
    - [done_name_eq,
       "concurrent.futures.Future.done.__name__.__eq__",
       ["done"],
       true,
       "concurrent.futures.Future.done.__name__.__eq__('done') == True — Future.done() returns True if the future is cancelled or finished executing; its __name__ is 'done' (4 chars: d-o-n-e); str.__eq__('done') returns True; new to extra174"]
    - [done_name_len_4,
       "concurrent.futures.Future.done.__name__.__len__",
       [],
       4,
       "concurrent.futures.Future.done.__name__.__len__() == 4 — 'done' has exactly 4 characters: d-o-n-e; shortest state method name (done=4 < running=7 < cancelled=9); str.__len__() returns 4; new to extra174"]
    - [running_name_eq,
       "concurrent.futures.Future.running.__name__.__eq__",
       ["running"],
       true,
       "concurrent.futures.Future.running.__name__.__eq__('running') == True — Future.running() returns True if the future is currently executing and cannot be cancelled; its __name__ is 'running' (7 chars: r-u-n-n-i-n-g); str.__eq__('running') returns True; new to extra174"]
    - [running_name_len_7,
       "concurrent.futures.Future.running.__name__.__len__",
       [],
       7,
       "concurrent.futures.Future.running.__name__.__len__() == 7 — 'running' has exactly 7 characters: r-u-n-n-i-n-g; middle length among state methods (done=4 < running=7 < cancelled=9); str.__len__() returns 7; new to extra174"]
    - [cancelled_name_eq,
       "concurrent.futures.Future.cancelled.__name__.__eq__",
       ["cancelled"],
       true,
       "concurrent.futures.Future.cancelled.__name__.__eq__('cancelled') == True — Future.cancelled() returns True if the future was successfully cancelled; its __name__ is 'cancelled' (9 chars: c-a-n-c-e-l-l-e-d); str.__eq__('cancelled') returns True; new to extra174"]
    - [cancelled_name_len_9,
       "concurrent.futures.Future.cancelled.__name__.__len__",
       [],
       9,
       "concurrent.futures.Future.cancelled.__name__.__len__() == 9 — 'cancelled' has exactly 9 characters: c-a-n-c-e-l-l-e-d; longest state method name (done=4 < running=7 < cancelled=9); str.__len__() returns 9; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.Future method __qualname__ attrs
#
# concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel' (len=13)
# concurrent.futures.Future.result.__qualname__ == 'Future.result' (len=13; same)
# concurrent.futures.Future.__repr__.__qualname__ == 'Future.__repr__' (len=15)
#
# __qualname__ for methods nested inside a class uses dot notation: Class.method.
# 'Future.cancel' and 'Future.result' both have len 13. 'Future.__repr__' has
# len 15 because '__repr__' (8 chars) is 2 longer than 'cancel' or 'result' (6).
# New to extra174.
# ---------------------------------------------------------------------------

table concurrent_futures_extra174.future_method_qualnames:
  description: "Future.cancel.__qualname__ 'Future.cancel' len 13; Future.result.__qualname__ 'Future.result' len 13 (same); Future.__repr__.__qualname__ 'Future.__repr__' len 15; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: cffutstate174

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_qualname_eq,
       "concurrent.futures.Future.cancel.__qualname__.__eq__",
       ["Future.cancel"],
       true,
       "concurrent.futures.Future.cancel.__qualname__.__eq__('Future.cancel') == True — Future.cancel() attempts to cancel the future; its __qualname__ uses dot notation 'Future.cancel' (13 chars: 'Future'=6+'.'=1+'cancel'=6=13); str.__eq__('Future.cancel') returns True; new to extra174"]
    - [cancel_qualname_len_13,
       "concurrent.futures.Future.cancel.__qualname__.__len__",
       [],
       13,
       "concurrent.futures.Future.cancel.__qualname__.__len__() == 13 — 'Future.cancel' has 13 characters: 'Future'=6+'.'=1+'cancel'=6=13; same length as 'Future.result'=13; str.__len__() returns 13; new to extra174"]
    - [result_qualname_eq,
       "concurrent.futures.Future.result.__qualname__.__eq__",
       ["Future.result"],
       true,
       "concurrent.futures.Future.result.__qualname__.__eq__('Future.result') == True — Future.result(timeout=None) returns the value returned by the call; its __qualname__ is 'Future.result' (13 chars: 'Future'=6+'.'=1+'result'=6=13); same len as 'Future.cancel'=13; str.__eq__('Future.result') returns True; new to extra174"]
    - [result_qualname_len_13,
       "concurrent.futures.Future.result.__qualname__.__len__",
       [],
       13,
       "concurrent.futures.Future.result.__qualname__.__len__() == 13 — 'Future.result' has 13 characters: 'Future'=6+'.'=1+'result'=6=13; same as cancel qualname length; str.__len__() returns 13; new to extra174"]
    - [repr_qualname_eq,
       "concurrent.futures.Future.__repr__.__qualname__.__eq__",
       ["Future.__repr__"],
       true,
       "concurrent.futures.Future.__repr__.__qualname__.__eq__('Future.__repr__') == True — Future.__repr__ provides string representation of a Future; its __qualname__ is 'Future.__repr__' (15 chars: 'Future'=6+'.'=1+'__repr__'=8=15); dunder names add 4 chars (__) on each side vs plain names; str.__eq__('Future.__repr__') returns True; new to extra174"]
    - [repr_qualname_len_15,
       "concurrent.futures.Future.__repr__.__qualname__.__len__",
       [],
       15,
       "concurrent.futures.Future.__repr__.__qualname__.__len__() == 15 — 'Future.__repr__' has 15 characters: 'Future'=6+'.'=1+'__repr__'=8=15; 2 chars longer than 'Future.cancel'=13 and 'Future.result'=13 because '__repr__'=8 vs 'cancel'/'result'=6; str.__len__() returns 15; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.Future.set_exception code attrs
#
# concurrent.futures.Future.set_exception.__code__.co_argcount == 2
# (self, exception — 2 positional arguments including self)
#
# co_argcount counts all positional parameters including self for unbound
# methods (functions stored on the class). set_exception(self, exception)
# sets the result of the future to the given exception. New to extra174.
# ---------------------------------------------------------------------------

table concurrent_futures_extra174.future_set_exception_code_attrs:
  description: "Future.set_exception.__code__.co_argcount==2 (self, exception); __code__.co_name=='set_exception'; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: cffutstate174

  columns: [id, function, args, expected, description]
  rows:
    - [set_exc_co_argcount_2,
       "concurrent.futures.Future.set_exception.__code__.co_argcount.__eq__",
       [2],
       true,
       "concurrent.futures.Future.set_exception.__code__.co_argcount.__eq__(2) == True — set_exception(self, exception) has 2 positional parameters: self (the Future instance) and exception (the exception to set); co_argcount includes self for class methods; int.__eq__(2) returns True; new to extra174"]
    - [set_exc_co_name_eq,
       "concurrent.futures.Future.set_exception.__code__.co_name.__eq__",
       ["set_exception"],
       true,
       "concurrent.futures.Future.set_exception.__code__.co_name.__eq__('set_exception') == True — co_name is the name of the code object, matching the function's __name__; 'set_exception' has 13 chars: 'set'=3+'_exception'=10=13; str.__eq__('set_exception') returns True; new to extra174"]
    - [set_exc_name_len_13,
       "concurrent.futures.Future.set_exception.__name__.__len__",
       [],
       13,
       "concurrent.futures.Future.set_exception.__name__.__len__() == 13 — 'set_exception' has 13 characters: 'set'=3+'_exception'=10=13; same length as 'Future.cancel' qualname (13) and 'Future.result' qualname (13) coincidentally; str.__len__() returns 13; new to extra174"]
    - [cancel_name_len_6,
       "concurrent.futures.Future.cancel.__name__.__len__",
       [],
       6,
       "concurrent.futures.Future.cancel.__name__.__len__() == 6 — 'cancel' has 6 characters: c-a-n-c-e-l; note __name__=6 while __qualname__='Future.cancel'=13; str.__len__() returns 6; new to extra174"]
    - [result_name_len_6,
       "concurrent.futures.Future.result.__name__.__len__",
       [],
       6,
       "concurrent.futures.Future.result.__name__.__len__() == 6 — 'result' has 6 characters: r-e-s-u-l-t; same length as 'cancel'=6; __name__=6 while __qualname__='Future.result'=13; str.__len__() returns 6; new to extra174"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra174
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra174.future_done_name_eq:
  description: "concurrent.futures.Future.done.__name__ == 'done' — state query method; __name__ is 'done' (4 chars); shortest state method name; new to extra174"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.done.__name__.__eq__"
  args: ["done"]
  expected: true

invariant concurrent_futures_extra174.future_running_name_len_7:
  description: "concurrent.futures.Future.running.__name__.__len__() == 7 — 'running' has 7 chars; middle length among done=4, running=7, cancelled=9; new to extra174"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.running.__name__.__len__"
  args: []
  expected: 7

invariant concurrent_futures_extra174.future_cancelled_name_len_9:
  description: "concurrent.futures.Future.cancelled.__name__.__len__() == 9 — 'cancelled' has 9 chars; longest state method name (done=4 < running=7 < cancelled=9); new to extra174"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.cancelled.__name__.__len__"
  args: []
  expected: 9

invariant concurrent_futures_extra174.future_cancel_qualname_eq:
  description: "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel' — dot notation for class method; len=13 ('Future'=6+'.'=1+'cancel'=6=13); new to extra174"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.cancel.__qualname__.__eq__"
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra174.future_result_qualname_len_13:
  description: "concurrent.futures.Future.result.__qualname__.__len__() == 13 — 'Future.result' has 13 chars; same as 'Future.cancel'=13; new to extra174"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.result.__qualname__.__len__"
  args: []
  expected: 13

invariant concurrent_futures_extra174.future_repr_qualname_len_15:
  description: "concurrent.futures.Future.__repr__.__qualname__.__len__() == 15 — 'Future.__repr__' has 15 chars ('Future'=6+'.'=1+'__repr__'=8=15); 2 longer than cancel/result qualnames (13); new to extra174"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__repr__.__qualname__.__len__"
  args: []
  expected: 15

invariant concurrent_futures_extra174.future_set_exception_co_argcount_2:
  description: "concurrent.futures.Future.set_exception.__code__.co_argcount == 2 — set_exception(self, exception) has 2 positional params; co_argcount includes self; new to extra174"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.set_exception.__code__.co_argcount.__eq__"
  args: [2]
  expected: true
