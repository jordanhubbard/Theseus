spec: multiprocessing_extra1066
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing Lock, RLock, and Event documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Lock/RLock module and qualname identity, multiprocessing.Event method qualnames, multiprocessing.Semaphore module identity — behaviors not covered by extra1036 or extra1051"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1066.lock_rlock_identity:
  description: "multiprocessing.Lock and RLock module, qualname, and class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1066lr
  columns: [id, function, args, expected]
  rows:
    - [mp1066lr001, multiprocessing.Lock.__module__.__eq__,         ["multiprocessing.synchronize"], true]
    - [mp1066lr002, multiprocessing.Lock.__qualname__.__eq__,       ["Lock"],                        true]
    - [mp1066lr003, multiprocessing.Lock.__name__.__eq__,           ["Lock"],                        true]
    - [mp1066lr004, multiprocessing.Lock.__class__.__name__.__eq__, ["type"],                        true]
    - [mp1066lr005, multiprocessing.RLock.__module__.__eq__,        ["multiprocessing.synchronize"], true]
    - [mp1066lr006, multiprocessing.RLock.__qualname__.__eq__,      ["RLock"],                       true]
    - [mp1066lr007, multiprocessing.RLock.__name__.__eq__,          ["RLock"],                       true]

table multiprocessing_extra1066.event_method_qualnames:
  description: "multiprocessing.Event method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mp1066em
  columns: [id, function, args, expected]
  rows:
    - [mp1066em001, multiprocessing.Event.__module__.__eq__,           ["multiprocessing.synchronize"], true]
    - [mp1066em002, multiprocessing.Event.__qualname__.__eq__,         ["Event"],                       true]
    - [mp1066em003, multiprocessing.Event.set.__qualname__.__eq__,     ["Event.set"],                   true]
    - [mp1066em004, multiprocessing.Event.clear.__qualname__.__eq__,   ["Event.clear"],                 true]
    - [mp1066em005, multiprocessing.Event.wait.__qualname__.__eq__,    ["Event.wait"],                  true]
    - [mp1066em006, multiprocessing.Event.is_set.__qualname__.__eq__,  ["Event.is_set"],                true]
    - [mp1066em007, multiprocessing.Event.__class__.__name__.__eq__,   ["type"],                        true]

table multiprocessing_extra1066.semaphore_and_barrier_identity:
  description: "multiprocessing.Semaphore and Barrier module and qualname identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1066sb
  columns: [id, function, args, expected]
  rows:
    - [mp1066sb001, multiprocessing.Semaphore.__module__.__eq__,         ["multiprocessing.synchronize"], true]
    - [mp1066sb002, multiprocessing.Semaphore.__qualname__.__eq__,       ["Semaphore"],                   true]
    - [mp1066sb003, multiprocessing.Semaphore.__class__.__name__.__eq__, ["type"],                        true]
    - [mp1066sb004, multiprocessing.BoundedSemaphore.__module__.__eq__,  ["multiprocessing.synchronize"], true]
    - [mp1066sb005, multiprocessing.BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"],            true]
    - [mp1066sb006, multiprocessing.Barrier.__module__.__eq__,           ["multiprocessing.synchronize"], true]
    - [mp1066sb007, multiprocessing.Barrier.__qualname__.__eq__,         ["Barrier"],                     true]
