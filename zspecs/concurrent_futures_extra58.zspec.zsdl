spec: concurrent_futures_extra58
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#qualname — Python __qualname__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra57.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__/__module__=='builtins' tables (extra47/extra49), ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins') (extra52), as_completed/__class__.__module__.__eq__('builtins') (extra52), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function') (extra52), class __repr__.__class__.__name__ tables (extra53), class __weakref__.__class__.__name__ tables (extra53), exception __repr__.__class__.__name__ tables (extra53), cf.__all__.__class__.__name__.__eq__('list') (extra54), cf.__all__.__len__()==14 (extra54), ThreadPoolExecutor/ProcessPoolExecutor/Future/CancelledError/TimeoutError/BrokenExecutor __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra54), cf.__all__.__contains__ membership checks (extra55), cf.__package__.__eq__('concurrent.futures') (extra55), Future/Executor __doc__.__class__.__name__.__eq__('str') (extra55), __loader__.__class__.__name__.__eq__('SourceFileLoader') (extra56), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra56), __file__.__class__.__name__.__eq__('str') (extra56), __cached__.__class__.__name__.__eq__('str') (extra56), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra57). Future.result/done/cancel/cancelled/exception __qualname__.__eq__ (extra10/extra20). ThreadPoolExecutor.submit/shutdown __qualname__.__eq__ (extra10/extra21/extra26). Future.__init__/__qualname__.__len__()==15 (extra32). ThreadPoolExecutor.__init__.__qualname__.__len__()==27 (extra32)."
    - "This spec covers (cfqual58 namespace): wave 227 theme — class method __qualname__ string equality checks for public methods not yet covered. NEW in extra58: Future.__init__.__qualname__.__eq__('Future.__init__') and ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') — the __init__ qualname string equality checks have NOT appeared in any prior concurrent.futures spec (extra32 captured __init__.__qualname__.__len__() only; no spec captured the __qualname__ string equality for Future.__init__ or ThreadPoolExecutor.__init__). Future.result/done/cancel/exception and ThreadPoolExecutor.submit/shutdown qualname equalities were covered in prior specs — included here alongside the novel __init__ checks to build a complete wave 227 table."
    - "concurrent.futures.Future.__init__.__qualname__ == 'Future.__init__'. Future defines its own __init__ in Lib/concurrent/futures/_base.py. The qualname carries the class prefix 'Future.' followed by '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__'. ThreadPoolExecutor defines its own __init__ in Lib/concurrent/futures/thread.py. The qualname carries the full class prefix 'ThreadPoolExecutor.' followed by '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.result.__qualname__ == 'Future.result'. concurrent.futures.Future.done.__qualname__ == 'Future.done'. concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel'. concurrent.futures.Future.exception.__qualname__ == 'Future.exception'. All defined directly on concurrent.futures.Future in Lib/concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'. concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'. Both defined directly on ThreadPoolExecutor in Lib/concurrent/futures/thread.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Future method __qualname__ string equality — extra58
#
# Wave 227 theme: class method __qualname__ string equality checks for public
# methods not yet covered.
#
# NEW: Future.__init__.__qualname__.__eq__('Future.__init__') — first time in
# any concurrent.futures spec. extra32 captured the length (15 chars) only;
# no prior spec has the string equality check.
#
# Already covered in extra10/extra20 (included here for completeness):
#   Future.result, Future.done, Future.cancel, Future.exception
# ---------------------------------------------------------------------------

table concurrent_futures_extra58.future_method_qualnames:
  description: "concurrent.futures Future method __qualname__ string equality checks in cfqual58 namespace — wave 227 theme: class method __qualname__ string equality; Future.__init__.__qualname__.__eq__('Future.__init__') is NEW (extra32 captured length 15 only; no prior cf spec has the string equality check); Future.result/done/cancel/exception also included; all Future methods defined in Lib/concurrent/futures/_base.py; pure-Python class methods follow 'ClassName.method' qualname pattern; first __init__ qualname string equality check for cf.Future in any concurrent.futures spec"
  kind: python_call_eq
  category: qualname
  id_prefix: cfqual58

  columns: [id, function, args, expected, description]
  rows:
    - [future_init,      "Future.__init__.__qualname__.__eq__",      ["Future.__init__"],      true,  "Future.__init__.__qualname__ == 'Future.__init__' — Future defines its own __init__ in Lib/concurrent/futures/_base.py; qualname carries class prefix 'Future.' + '__init__'; NEW in extra58: first __init__ qualname string equality check for cf.Future in any concurrent.futures spec; extra32 captured len==15 only; verified with Python 3.14.3"]
    - [future_result,    Future.result.__qualname__.__eq__,          ["Future.result"],        true,  "Future.result.__qualname__ == 'Future.result' — method defined directly on concurrent.futures.Future in Lib/concurrent/futures/_base.py; returns the value returned by the call; wave 227 table entry alongside novel __init__ check"]
    - [future_done,      Future.done.__qualname__.__eq__,            ["Future.done"],          true,  "Future.done.__qualname__ == 'Future.done' — method defined directly on concurrent.futures.Future; returns True if the future completed successfully or was cancelled; wave 227 table entry"]
    - [future_cancel,    Future.cancel.__qualname__.__eq__,          ["Future.cancel"],        true,  "Future.cancel.__qualname__ == 'Future.cancel' — method defined directly on concurrent.futures.Future; attempts to cancel the future; wave 227 table entry"]
    - [future_exception, Future.exception.__qualname__.__eq__,       ["Future.exception"],     true,  "Future.exception.__qualname__ == 'Future.exception' — method defined directly on concurrent.futures.Future; returns the exception raised by the call; wave 227 table entry"]

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor method __qualname__ string equality
# — extra58
#
# Wave 227 theme: class method __qualname__ string equality.
#
# NEW: ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')
# — first time in any concurrent.futures spec. extra32 captured the length (27
# chars) only; no prior spec has the string equality check.
#
# Already covered in extra10/extra21/extra26 (included here for completeness):
#   ThreadPoolExecutor.submit, ThreadPoolExecutor.shutdown
# ---------------------------------------------------------------------------

table concurrent_futures_extra58.threadpoolexecutor_method_qualnames:
  description: "concurrent.futures ThreadPoolExecutor method __qualname__ string equality checks in cfqual58 namespace — wave 227 theme: class method __qualname__ string equality; ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') is NEW (extra32 captured length 27 only; no prior cf spec has the string equality check); ThreadPoolExecutor.submit/shutdown also included; methods defined in Lib/concurrent/futures/thread.py; first __init__ qualname string equality check for ThreadPoolExecutor in any concurrent.futures spec"
  kind: python_call_eq
  category: qualname
  id_prefix: cfqual58tpe

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init,     "ThreadPoolExecutor.__init__.__qualname__.__eq__",     ["ThreadPoolExecutor.__init__"],     true,  "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' — ThreadPoolExecutor defines its own __init__ in Lib/concurrent/futures/thread.py; qualname carries full class prefix 'ThreadPoolExecutor.' + '__init__' (27 chars); NEW in extra58: first __init__ qualname string equality check for ThreadPoolExecutor in any concurrent.futures spec; extra32 captured len==27 only; verified with Python 3.14.3"]
    - [tpe_submit,   ThreadPoolExecutor.submit.__qualname__.__eq__,         ["ThreadPoolExecutor.submit"],       true,  "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' — method defined directly on ThreadPoolExecutor in Lib/concurrent/futures/thread.py; schedules callable to be executed; wave 227 table entry alongside novel __init__ check"]
    - [tpe_shutdown, ThreadPoolExecutor.shutdown.__qualname__.__eq__,       ["ThreadPoolExecutor.shutdown"],     true,  "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' — method defined directly on ThreadPoolExecutor; signals the executor to free resources; wave 227 table entry"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra58
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra58.future_init_qualname_eq:
  description: "concurrent.futures.Future.__init__.__qualname__.__eq__('Future.__init__') returns True — Future defines its own __init__ in Lib/concurrent/futures/_base.py; qualname carries class prefix 'Future.' + '__init__' (15 chars); NEW in extra58: no prior concurrent.futures spec has captured the Future.__init__ qualname string equality (extra32 captured len==15 only); wave 227 first __init__ qualname eq invariant for cf.Future"
  category: qualname
  kind: python_call_eq
  function: Future.__init__.__qualname__.__eq__
  args: ["Future.__init__"]
  expected: true

invariant concurrent_futures_extra58.tpe_init_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') returns True — ThreadPoolExecutor defines its own __init__ in Lib/concurrent/futures/thread.py; qualname carries full class prefix 'ThreadPoolExecutor.' + '__init__' (27 chars); NEW in extra58: no prior concurrent.futures spec has captured the ThreadPoolExecutor.__init__ qualname string equality (extra32 captured len==27 only); wave 227 first __init__ qualname eq invariant for ThreadPoolExecutor"
  category: qualname
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__qualname__.__eq__
  args: ["ThreadPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra58.future_result_qualname_eq:
  description: "concurrent.futures.Future.result.__qualname__.__eq__('Future.result') returns True — Future.result is defined directly on concurrent.futures.Future in Lib/concurrent/futures/_base.py; pure-Python method qualname follows 'ClassName.method' pattern; wave 227 invariant alongside novel __init__ checks"
  category: qualname
  kind: python_call_eq
  function: Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true
