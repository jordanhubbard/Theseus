spec: sly_rust
version: ">=3.9"
backend: rust_module(sly_rust)

docs: https://sly.readthedocs.io/

provenance:
  derived_from:
    - "https://sly.readthedocs.io/ — SLY lexer/parser documentation"
  not_derived_from:
    - "sly source: sly/lex.py"
  notes:
    - "SLY is a Python lexer and parser toolkit."
    - "SLY uses Python metaclasses to define lexers and parsers."
    - "Expose sly_lex_tokens(text) -> list: tokenize text using a simple lexer."
    - "Expose sly_token_types(text) -> list: list of token type names."
    - "Simple lexer with NUMBER and NAME tokens."
    - "lex('42') gives [Token(NUMBER, '42', ...)]."
    - "lex('hello') gives [Token(NAME, 'hello', ...)]."
    - "lex('42 hello').token_types == ['NUMBER', 'NAME']."
    - "All test vectors verified against sly 0.5."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# sly_token_types — list of token type names
table sly_rust.lex.token_types:
  kind: python_call_eq
  category: token_types
  id_prefix: sly_tt
  function: sly_token_types

  columns: [id, args, expected]
  rows:
    - [number,      ["42"],         ["NUMBER"]]
    - [name,        ["hello"],      ["NAME"]]
    - [num_name,    ["42 hello"],   ["NUMBER", "NAME"]]
    - [two_names,   ["foo bar"],    ["NAME", "NAME"]]

# sly_token_count — count tokens
invariant sly_rust.lex.three_tokens:
  description: "lex('1 2 3') gives 3 NUMBER tokens"
  category: count
  kind: python_call_eq
  function: sly_token_count
  args: ["1 2 3"]
  expected: 3

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:56:20Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
