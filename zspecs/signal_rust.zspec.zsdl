spec: signal_rust
version: ">=3.9"
backend: rust_module(signal_rust)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal documentation"
    - "POSIX.1-2017 — Signal constants"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python signal module constants, exposed via PyO3."
    - "Targets POSIX systems — all constants are standard POSIX signal numbers."
    - "SIGHUP == 1 — hangup on controlling terminal."
    - "SIGINT == 2 — keyboard interrupt (Ctrl+C)."
    - "SIGQUIT == 3 — keyboard quit (Ctrl+\\)."
    - "SIGABRT == 6 — abnormal termination."
    - "SIGKILL == 9 — kill signal (cannot be caught)."
    - "SIGSEGV == 11 — invalid memory reference."
    - "SIGPIPE == 13 — broken pipe."
    - "SIGALRM == 14 — timer signal."
    - "SIGTERM == 15 — termination signal."
    - "SIG_DFL == 0 — default signal handler."
    - "SIG_IGN == 1 — ignore signal handler."
    - "All test vectors verified against Python 3.14.3 signal module on POSIX."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# POSIX signal number constants
table signal_rust.constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: sig

  columns: [id, function, args, expected]
  rows:
    - [sighup,  SIGHUP.__eq__,  [1],  true]
    - [sigint,  SIGINT.__eq__,  [2],  true]
    - [sigquit, SIGQUIT.__eq__, [3],  true]
    - [sigabrt, SIGABRT.__eq__, [6],  true]
    - [sigkill, SIGKILL.__eq__, [9],  true]
    - [sigsegv, SIGSEGV.__eq__, [11], true]
    - [sigpipe, SIGPIPE.__eq__, [13], true]
    - [sigalrm, SIGALRM.__eq__, [14], true]
    - [sigterm, SIGTERM.__eq__, [15], true]

# SIG_DFL and SIG_IGN — special handler sentinel values
table signal_rust.handlers.sentinels:
  kind: python_call_eq
  category: handlers
  id_prefix: sigh

  columns: [id, function, args, expected]
  rows:
    - [sig_dfl, SIG_DFL.__eq__, [0], true]
    - [sig_ign, SIG_IGN.__eq__, [1], true]

