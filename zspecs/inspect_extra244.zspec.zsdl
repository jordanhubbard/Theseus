spec: inspect_extra244
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra243.zspec.zsdl — covers classify_class_attrs and getmembers identity"
    - "inspect_extra242.zspec.zsdl — covers isclass, isfunction, ismethod identity"
    - "inspect_extra.zspec.zsdl — covers ismodule, isbuiltin, isroutine names and modules"
    - "inspect.zspec.zsdl — covers inspect function names and callable checks"
  notes:
    - "This spec covers inspect.getmembers_static (Python 3.11+) and inspect.get_annotations (Python 3.10+) function identity."
    - "Also covers inspect.ismethoddescriptor, inspect.isgetsetdescriptor, inspect.ismemberdescriptor function names."
    - "inspect.getmembers_static.__name__ == 'getmembers_static' (len=17) — getmembers_static is a Python function in Lib/inspect.py added in Python 3.11. Verified with Python 3.14.3."
    - "inspect.getmembers_static.__module__ == 'inspect' (len=7) — getmembers_static is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.get_annotations.__name__ == 'get_annotations' (len=15) — get_annotations is a Python function; __module__ moved to 'annotationlib' in Python 3.14. Verified with Python 3.14.3."
    - "inspect.get_annotations.__module__ == 'annotationlib' (len=13) — in Python 3.14 get_annotations lives in annotationlib but is re-exported via inspect. Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__name__ == 'ismethoddescriptor' (len=18) — Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isgetsetdescriptor.__name__ == 'isgetsetdescriptor' (len=18) — Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismemberdescriptor.__name__ == 'ismemberdescriptor' (len=18) — Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers_static function identity contracts
#
# inspect.getmembers_static.__name__ == 'getmembers_static' (len=17)
# inspect.getmembers_static.__module__ == 'inspect' (len=7)
# inspect.getmembers_static.__class__.__name__ == 'function'
# inspect.getmembers_static.__qualname__ == 'getmembers_static' (len=17)
# inspect.getmembers_static.__name__.__len__() == 17
#
# getmembers_static added in Python 3.11. New to extra244.
# ---------------------------------------------------------------------------

table inspect_extra244.insp244fns_gms_identity:
  description: "inspect.getmembers_static function identity: name, module, class, qualname; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: insp244fns

  columns: [id, function, args, expected, description]
  rows:
    - [gms_name_eq,
       getmembers_static.__name__.__eq__,
       ["getmembers_static"],
       true,
       "inspect.getmembers_static.__name__.__eq__('getmembers_static') == True — getmembers_static is a Python function in Lib/inspect.py; __name__ is 'getmembers_static' (len=17); new to extra244"]
    - [gms_name_len_17,
       getmembers_static.__name__.__len__,
       [],
       17,
       "inspect.getmembers_static.__name__.__len__() == 17 — 'getmembers_static' has exactly 17 characters; str.__len__() returns 17; new to extra244"]
    - [gms_module_eq,
       getmembers_static.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers_static.__module__.__eq__('inspect') == True — getmembers_static is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra244"]
    - [gms_module_len_7,
       getmembers_static.__module__.__len__,
       [],
       7,
       "inspect.getmembers_static.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra244"]
    - [gms_class_is_function,
       getmembers_static.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getmembers_static.__class__.__name__.__eq__('function') == True — getmembers_static is a plain Python function; __class__.__name__ is 'function'; new to extra244"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers_static qualname and content checks
#
# inspect.getmembers_static.__qualname__ == 'getmembers_static' (len=17)
# inspect.getmembers_static.__name__.__contains__('members') == True
# inspect.getmembers_static.__name__.__contains__('static') == True
# inspect.getmembers_static.__module__.__contains__('inspect') == True
# inspect.getmembers_static.__class__.__module__ == 'builtins'
#
# New to extra244.
# ---------------------------------------------------------------------------

table inspect_extra244.insp244fns_gms_extra:
  description: "inspect.getmembers_static qualname and content checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: insp244fnsb

  columns: [id, function, args, expected, description]
  rows:
    - [gms_qualname_eq,
       getmembers_static.__qualname__.__eq__,
       ["getmembers_static"],
       true,
       "inspect.getmembers_static.__qualname__.__eq__('getmembers_static') == True — __qualname__ is 'getmembers_static' (len=17); same as __name__ for top-level function; new to extra244"]
    - [gms_name_contains_members,
       getmembers_static.__name__.__contains__,
       ["members"],
       true,
       "inspect.getmembers_static.__name__.__contains__('members') == True — 'getmembers_static' contains 'members'; new to extra244"]
    - [gms_name_contains_static,
       getmembers_static.__name__.__contains__,
       ["static"],
       true,
       "inspect.getmembers_static.__name__.__contains__('static') == True — 'getmembers_static' contains 'static'; new to extra244"]
    - [gms_module_contains_inspect,
       getmembers_static.__module__.__contains__,
       ["inspect"],
       true,
       "inspect.getmembers_static.__module__.__contains__('inspect') == True — 'inspect' contains the substring 'inspect'; new to extra244"]
    - [gms_class_module_builtins,
       getmembers_static.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "inspect.getmembers_static.__class__.__module__.__eq__('builtins') == True — function type is defined in the builtins module; new to extra244"]

# ---------------------------------------------------------------------------
# Table 3: inspect.get_annotations function identity contracts
#
# inspect.get_annotations.__name__ == 'get_annotations' (len=15)
# inspect.get_annotations.__module__ == 'annotationlib' (len=13)
# inspect.get_annotations.__class__.__name__ == 'function'
# inspect.get_annotations.__qualname__ == 'get_annotations' (len=15)
# inspect.get_annotations.__name__.__len__() == 15
#
# get_annotations added in Python 3.10; __module__ is 'annotationlib' in Python 3.14. New to extra244.
# ---------------------------------------------------------------------------

table inspect_extra244.insp244fns_ga_identity:
  description: "inspect.get_annotations function identity: name, module, class, qualname; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: insp244fnsc

  columns: [id, function, args, expected, description]
  rows:
    - [ga_name_eq,
       get_annotations.__name__.__eq__,
       ["get_annotations"],
       true,
       "inspect.get_annotations.__name__.__eq__('get_annotations') == True — get_annotations is a Python function; __name__ is 'get_annotations' (len=15); new to extra244"]
    - [ga_name_len_15,
       get_annotations.__name__.__len__,
       [],
       15,
       "inspect.get_annotations.__name__.__len__() == 15 — 'get_annotations' has exactly 15 characters; str.__len__() returns 15; new to extra244"]
    - [ga_module_eq,
       get_annotations.__module__.__eq__,
       ["annotationlib"],
       true,
       "inspect.get_annotations.__module__.__eq__('annotationlib') == True — in Python 3.14 get_annotations lives in annotationlib; __module__ is 'annotationlib' (len=13); new to extra244"]
    - [ga_module_len_13,
       get_annotations.__module__.__len__,
       [],
       13,
       "inspect.get_annotations.__module__.__len__() == 13 — 'annotationlib' has exactly 13 characters; str.__len__() returns 13; new to extra244"]
    - [ga_class_is_function,
       get_annotations.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.get_annotations.__class__.__name__.__eq__('function') == True — get_annotations is a plain Python function; __class__.__name__ is 'function'; new to extra244"]

# ---------------------------------------------------------------------------
# Table 4: inspect descriptor predicate function names
#
# inspect.ismethoddescriptor.__name__ == 'ismethoddescriptor' (len=18)
# inspect.isgetsetdescriptor.__name__ == 'isgetsetdescriptor' (len=18)
# inspect.ismemberdescriptor.__name__ == 'ismemberdescriptor' (len=18)
# inspect.ismethoddescriptor.__module__ == 'inspect' (len=7)
# inspect.isgetsetdescriptor.__module__ == 'inspect' (len=7)
#
# All three are Python functions in Lib/inspect.py. New to extra244.
# ---------------------------------------------------------------------------

table inspect_extra244.insp244fns_desc_names:
  description: "inspect descriptor predicate function names: ismethoddescriptor, isgetsetdescriptor, ismemberdescriptor; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: insp244fnsd

  columns: [id, function, args, expected, description]
  rows:
    - [imd_name_eq,
       ismethoddescriptor.__name__.__eq__,
       ["ismethoddescriptor"],
       true,
       "inspect.ismethoddescriptor.__name__.__eq__('ismethoddescriptor') == True — ismethoddescriptor is a Python function in Lib/inspect.py; __name__ is 'ismethoddescriptor' (len=18); new to extra244"]
    - [igsd_name_eq,
       isgetsetdescriptor.__name__.__eq__,
       ["isgetsetdescriptor"],
       true,
       "inspect.isgetsetdescriptor.__name__.__eq__('isgetsetdescriptor') == True — isgetsetdescriptor is a Python function in Lib/inspect.py; __name__ is 'isgetsetdescriptor' (len=18); new to extra244"]
    - [imemd_name_eq,
       ismemberdescriptor.__name__.__eq__,
       ["ismemberdescriptor"],
       true,
       "inspect.ismemberdescriptor.__name__.__eq__('ismemberdescriptor') == True — ismemberdescriptor is a Python function in Lib/inspect.py; __name__ is 'ismemberdescriptor' (len=18); new to extra244"]
    - [imd_module_eq,
       ismethoddescriptor.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethoddescriptor.__module__.__eq__('inspect') == True — ismethoddescriptor is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra244"]
    - [igsd_module_eq,
       isgetsetdescriptor.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isgetsetdescriptor.__module__.__eq__('inspect') == True — isgetsetdescriptor is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra244"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra244
# ---------------------------------------------------------------------------

invariant inspect_extra244.gms_name_eq:
  description: "inspect.getmembers_static.__name__ == 'getmembers_static' (len=17); new to extra244"
  kind: python_call_eq
  function: getmembers_static.__name__.__eq__
  args: ["getmembers_static"]
  expected: true

invariant inspect_extra244.gms_module_eq:
  description: "inspect.getmembers_static.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra244"
  kind: python_call_eq
  function: getmembers_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra244.gms_class_is_function:
  description: "inspect.getmembers_static.__class__.__name__ == 'function' — plain Python function; new to extra244"
  kind: python_call_eq
  function: getmembers_static.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra244.gms_name_len_17:
  description: "inspect.getmembers_static.__name__.__len__() == 17; new to extra244"
  kind: python_call_eq
  function: getmembers_static.__name__.__len__
  args: []
  expected: 17

invariant inspect_extra244.ga_name_eq:
  description: "inspect.get_annotations.__name__ == 'get_annotations' (len=15); new to extra244"
  kind: python_call_eq
  function: get_annotations.__name__.__eq__
  args: ["get_annotations"]
  expected: true

invariant inspect_extra244.ga_module_eq:
  description: "inspect.get_annotations.__module__ == 'annotationlib' — moved to annotationlib in Python 3.14; new to extra244"
  kind: python_call_eq
  function: get_annotations.__module__.__eq__
  args: ["annotationlib"]
  expected: true

invariant inspect_extra244.ga_name_len_15:
  description: "inspect.get_annotations.__name__.__len__() == 15; new to extra244"
  kind: python_call_eq
  function: get_annotations.__name__.__len__
  args: []
  expected: 15

invariant inspect_extra244.imd_name_eq:
  description: "inspect.ismethoddescriptor.__name__ == 'ismethoddescriptor' (len=18); new to extra244"
  kind: python_call_eq
  function: ismethoddescriptor.__name__.__eq__
  args: ["ismethoddescriptor"]
  expected: true

invariant inspect_extra244.igsd_name_eq:
  description: "inspect.isgetsetdescriptor.__name__ == 'isgetsetdescriptor' (len=18); new to extra244"
  kind: python_call_eq
  function: isgetsetdescriptor.__name__.__eq__
  args: ["isgetsetdescriptor"]
  expected: true

invariant inspect_extra244.imemd_name_eq:
  description: "inspect.ismemberdescriptor.__name__ == 'ismemberdescriptor' (len=18); new to extra244"
  kind: python_call_eq
  function: ismemberdescriptor.__name__.__eq__
  args: ["ismemberdescriptor"]
  expected: true

invariant inspect_extra244.imd_module_eq:
  description: "inspect.ismethoddescriptor.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra244"
  kind: python_call_eq
  function: ismethoddescriptor.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra244.gms_qualname_eq:
  description: "inspect.getmembers_static.__qualname__ == 'getmembers_static'; new to extra244"
  kind: python_call_eq
  function: getmembers_static.__qualname__.__eq__
  args: ["getmembers_static"]
  expected: true
