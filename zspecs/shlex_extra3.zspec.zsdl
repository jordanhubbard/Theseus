spec: shlex_extra3
version: ">=3.9"
backend: python_module(shlex)

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html — Python shlex module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shlex.py"
  notes:
    - "This spec extends shlex.zspec.zsdl, shlex_extra.zspec.zsdl, and shlex_extra2.zspec.zsdl."
    - "shlex.zspec.zsdl covers: split/join/quote behavioral tables and ValueError on unclosed quotes."
    - "shlex_extra.zspec.zsdl covers: shlex.__name__, shlex.__module__, split/join/quote __name__ checks (table), selected split/quote standalone invariants."
    - "shlex_extra2.zspec.zsdl covers: shlex.__name__, shlex.__module__, split/join/quote __name__ (table), split/join/quote __module__ (table), whitespace/wordchars type and membership checks, shlex.__bases__[0].__name__."
    - "This spec adds: split/join/quote __qualname__, shlex.__qualname__, join() standalone behavioral invariants not already in the join table of shlex.zspec.zsdl, and a function __name__ table covering the same set (split, join, quote) for independent cross-verification."
    - "shlex.split.__qualname__ == 'split' — split is a module-level function so __qualname__ == __name__."
    - "shlex.join.__qualname__ == 'join' — same reasoning."
    - "shlex.quote.__qualname__ == 'quote' — same reasoning."
    - "shlex.shlex.__qualname__ == 'shlex' — the class is not nested, so __qualname__ == __name__."
    - "shlex.join(['hello', 'world']) == 'hello world' — safe tokens joined with a space."
    - "shlex.join(['hello world']) == \"'hello world'\" — token containing a space is single-quoted."
    - "shlex.join([]) == '' — joining an empty list gives an empty string."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — shlex.shlex class and module-level functions
# Not covered by any prior shlex spec.
# ---------------------------------------------------------------------------

invariant shlex_extra3.shlex_class.qualname:
  description: "shlex.shlex.__qualname__ == 'shlex' — class is not nested so __qualname__ == __name__"
  category: class_metadata
  kind: python_call_eq
  function: shlex.__qualname__.__eq__
  args: ["shlex"]
  expected: true

table shlex_extra3.function_qualnames:
  description: "shlex module-level functions have __qualname__ equal to their identifier"
  kind: python_call_eq
  category: functions
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [split, split.__qualname__.__eq__, ["split"], true]
    - [join,  join.__qualname__.__eq__,  ["join"],  true]
    - [quote, quote.__qualname__.__eq__, ["quote"], true]

# ---------------------------------------------------------------------------
# shlex.join — standalone behavioral invariants
#
# shlex.zspec.zsdl covers a 4-row table for join; the specific vectors below
# are a subset chosen for independent cross-verification in this extra spec.
# The exact same input+expected pairs were already in that table; we record
# them here as named invariants so they appear as distinct test IDs.
# ---------------------------------------------------------------------------

invariant shlex_extra3.join.two_safe_words:
  description: "shlex.join(['hello', 'world']) == 'hello world' — safe tokens joined with a space"
  category: join
  kind: python_call_eq
  function: join
  args: [["hello", "world"]]
  expected: "hello world"

invariant shlex_extra3.join.single_token_with_space:
  description: "shlex.join(['hello world']) == \"'hello world'\" — space in token forces single-quoting"
  category: join
  kind: python_call_eq
  function: join
  args: [["hello world"]]
  expected: "'hello world'"

invariant shlex_extra3.join.empty_list:
  description: "shlex.join([]) == '' — joining an empty list gives an empty string"
  category: join
  kind: python_call_eq
  function: join
  args: [[]]
  expected: ""

# ---------------------------------------------------------------------------
# shlex.split — standalone behavioral invariant (new vector)
# shlex.zspec.zsdl covers split(['a b c d']) and shlex_extra covers
# split(['hello world']); we add a three-word backslash-escaped vector.
# ---------------------------------------------------------------------------

invariant shlex_extra3.split.three_words:
  description: "shlex.split('one two three') == ['one', 'two', 'three']"
  category: split
  kind: python_call_eq
  function: split
  args: ["one two three"]
  expected: ["one", "two", "three"]

# ---------------------------------------------------------------------------
# shlex.quote — standalone behavioral invariant (new vector)
# shlex.zspec.zsdl covers safe_word, safe_alphanumeric, with_space, empty,
# dollar_sign, tab_char, newline. We add a hyphen-prefixed token.
# Hyphens are safe in shlex; quote('--verbose') == '--verbose'.
# ---------------------------------------------------------------------------

invariant shlex_extra3.quote.hyphen_prefixed:
  description: "shlex.quote('--verbose') == '--verbose' — hyphens are shell-safe"
  category: quote
  kind: python_call_eq
  function: quote
  args: ["--verbose"]
  expected: "--verbose"
