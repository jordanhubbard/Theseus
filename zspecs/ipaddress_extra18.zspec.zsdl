spec: ipaddress_extra18
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__.__eq__ for IPv4Address/IPv6Address/IPv4Network/IPv6Network/IPv4Interface/IPv6Interface and ip_address/ip_network/ip_interface factories, plus AddressValueError/NetmaskValueError."
    - "ipaddress_extra16.zspec.zsdl — covers __qualname__.__len__() for IPv4Address/IPv6Address/IPv4Network/IPv6Network (all == 11); standalone __qualname__.__eq__ for IPv4Address and IPv6Network."
    - "ipaddress_extra17.zspec.zsdl — covers __qualname__.__len__() for AddressValueError/NetmaskValueError/summarize_address_range/collapse_addresses/get_mixed_type_key; __name__.__eq__ for utility functions; module __name__ and __package__."
  notes:
    - "This spec extends the ipaddress chain through ipaddress_extra17; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__eq__ for IPv4Network/IPv6Network method descriptors (subnets, supernet, overlaps) — these methods are defined on the private _BaseNetwork mixin, so their __qualname__ values are '_BaseNetwork.subnets', '_BaseNetwork.supernet', '_BaseNetwork.overlaps'. No prior spec checks any of these qualnames."
    - "Also covers: ip_network.__qualname__.__eq__ and ip_interface.__qualname__.__eq__ as standalone invariants in the extra18 namespace — extra5 covers these in a table; standalone invariants provide cross-namespace regression checkpoints (same pattern as extra16 re-checking IPv4Address/IPv6Network standalone)."
    - "IPv4Network.subnets.__qualname__ == '_BaseNetwork.subnets' — subnets is inherited from _BaseNetwork. len('_BaseNetwork.subnets') == 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Network.supernet.__qualname__ == '_BaseNetwork.supernet' — supernet is inherited from _BaseNetwork. len('_BaseNetwork.supernet') == 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Network.overlaps.__qualname__ == '_BaseNetwork.overlaps' — overlaps is inherited from _BaseNetwork. len('_BaseNetwork.overlaps') == 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "type(IPv4Address('1.2.3.4').packed).__name__ == 'bytes' — .packed returns the address as a bytes object. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4Network method __qualname__.__eq__ checks
#
# subnets, supernet, and overlaps are defined on the internal _BaseNetwork
# mixin class. Their __qualname__ values reflect this: '_BaseNetwork.subnets',
# '_BaseNetwork.supernet', '_BaseNetwork.overlaps'.
# No prior ipaddress spec checks the __qualname__ of any of these methods.
# ipaddress_extra3 checks __bases__[0].__name__ == '_BaseNetwork' for
# IPv4Network/IPv6Network but does not check any method qualnames.
# Lengths: '_BaseNetwork.subnets' == 20; '_BaseNetwork.supernet' == 21;
# '_BaseNetwork.overlaps' == 21.
# ---------------------------------------------------------------------------

invariant ipaddress_extra18.IPv4Network.subnets_qualname:
  description: "ipaddress.IPv4Network.subnets.__qualname__ == '_BaseNetwork.subnets' — method defined on internal _BaseNetwork mixin"
  category: class_qualnames
  kind: python_call_eq
  function: IPv4Network.subnets.__qualname__.__eq__
  args: ["_BaseNetwork.subnets"]
  expected: true

invariant ipaddress_extra18.IPv4Network.supernet_qualname:
  description: "ipaddress.IPv4Network.supernet.__qualname__ == '_BaseNetwork.supernet' — method defined on internal _BaseNetwork mixin"
  category: class_qualnames
  kind: python_call_eq
  function: IPv4Network.supernet.__qualname__.__eq__
  args: ["_BaseNetwork.supernet"]
  expected: true

invariant ipaddress_extra18.IPv4Network.overlaps_qualname:
  description: "ipaddress.IPv4Network.overlaps.__qualname__ == '_BaseNetwork.overlaps' — method defined on internal _BaseNetwork mixin"
  category: class_qualnames
  kind: python_call_eq
  function: IPv4Network.overlaps.__qualname__.__eq__
  args: ["_BaseNetwork.overlaps"]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Network method __qualname__.__len__() checks
#
# No prior spec checks __qualname__.__len__() for subnets/supernet/overlaps.
# len('_BaseNetwork.subnets') == 20; len('_BaseNetwork.supernet') == 21;
# len('_BaseNetwork.overlaps') == 21.
# ---------------------------------------------------------------------------

table ipaddress_extra18.network_method_qualname_lengths:
  description: "Length of __qualname__ strings for IPv4Network inherited methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: nmqlen18

  columns: [id, function, args, expected]
  rows:
    - [subnets,  IPv4Network.subnets.__qualname__.__len__,  [], 20]
    - [supernet, IPv4Network.supernet.__qualname__.__len__, [], 21]
    - [overlaps, IPv4Network.overlaps.__qualname__.__len__, [], 21]

# ---------------------------------------------------------------------------
# ip_network and ip_interface __qualname__.__eq__ — cross-namespace anchors
#
# ipaddress_extra5 covers ip_network.__qualname__.__eq__ and
# ip_interface.__qualname__.__eq__ in its factory table. The standalone
# invariants below anchor these same properties from the extra18 namespace,
# providing a cross-namespace regression checkpoint (analogous to how
# extra16 re-checked IPv4Address and IPv6Network as standalone invariants).
# ---------------------------------------------------------------------------

invariant ipaddress_extra18.ip_network.qualname_eq:
  description: "ipaddress.ip_network.__qualname__ == 'ip_network' — top-level factory function"
  category: function_qualnames
  kind: python_call_eq
  function: ip_network.__qualname__.__eq__
  args: ["ip_network"]
  expected: true

invariant ipaddress_extra18.ip_interface.qualname_eq:
  description: "ipaddress.ip_interface.__qualname__ == 'ip_interface' — top-level factory function"
  category: function_qualnames
  kind: python_call_eq
  function: ip_interface.__qualname__.__eq__
  args: ["ip_interface"]
  expected: true
