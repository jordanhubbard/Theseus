spec: fast_levenshtein
version: ">=2.0.0"
backend: node(fast-levenshtein)

docs: https://www.npmjs.com/package/fast-levenshtein

provenance:
  derived_from:
    - "fast-levenshtein README — https://www.npmjs.com/package/fast-levenshtein"
    - "Test vectors verified with fast-levenshtein via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fast-levenshtein source"
  notes:
    - "fast-levenshtein is an npm package. Install: npm install fast-levenshtein"
    - "lev.get(a, b) computes the Levenshtein edit distance between two strings."
    - "Distance is the minimum number of single-character edits (insert, delete, substitute)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer edit distance."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fast_levenshtein.get:
  kind: node_module_call_eq
  function: get
  category: get
  id_prefix: lev

  columns: [id, args, expected]
  rows:
    - [equal,    ["abc", "abc"],        0]
    - [empty,    ["", ""],              0]
    - [insert,   ["ab", "abc"],         1]
    - [delete,   ["abc", "ab"],         1]
    - [subst,    ["a", "b"],            1]
    - [classic,  ["kitten", "sitting"], 3]
