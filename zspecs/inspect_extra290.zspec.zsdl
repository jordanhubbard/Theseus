spec: inspect_extra290
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect.isXxx predicate qualnames and CO_ compile flags"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py, Include/code.h"
  notes:
    - "inspect.ismethodwrapper was added in Python 3.11"
    - "All inspect.isXxx predicates have __module__ == 'inspect'"
    - "CO_OPTIMIZED, CO_GENERATOR, CO_COROUTINE are plain int constants"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra290.predicate_qualnames:
  description: "__qualname__ for isasyncgen, isasyncgenfunction, isawaitable, isframe, iscode, istraceback, isbuiltin, ismethodwrapper"
  kind: python_call_eq
  category: identity
  id_prefix: inex290a

  columns: [id, function, args, expected, description]
  rows:
    - [inex290a01, inspect.isasyncgen.__qualname__.__eq__, ["isasyncgen"], true, "isasyncgen qualname is isasyncgen"]
    - [inex290a02, inspect.isasyncgenfunction.__qualname__.__eq__, ["isasyncgenfunction"], true, "isasyncgenfunction qualname is isasyncgenfunction"]
    - [inex290a03, inspect.isawaitable.__qualname__.__eq__, ["isawaitable"], true, "isawaitable qualname is isawaitable"]
    - [inex290a04, inspect.isframe.__qualname__.__eq__, ["isframe"], true, "isframe qualname is isframe"]
    - [inex290a05, inspect.iscode.__qualname__.__eq__, ["iscode"], true, "iscode qualname is iscode"]
    - [inex290a06, inspect.istraceback.__qualname__.__eq__, ["istraceback"], true, "istraceback qualname is istraceback"]
    - [inex290a07, inspect.isbuiltin.__qualname__.__eq__, ["isbuiltin"], true, "isbuiltin qualname is isbuiltin"]
    - [inex290a08, inspect.ismethodwrapper.__qualname__.__eq__, ["ismethodwrapper"], true, "ismethodwrapper qualname is ismethodwrapper"]

table inspect_extra290.predicate_modules:
  description: "__module__ for isasyncgen, isasyncgenfunction, isawaitable, isframe, iscode, istraceback, isbuiltin, ismethodwrapper (all 'inspect')"
  kind: python_call_eq
  category: identity
  id_prefix: inex290b

  columns: [id, function, args, expected, description]
  rows:
    - [inex290b01, inspect.isasyncgen.__module__.__eq__, ["inspect"], true, "isasyncgen module is inspect"]
    - [inex290b02, inspect.isasyncgenfunction.__module__.__eq__, ["inspect"], true, "isasyncgenfunction module is inspect"]
    - [inex290b03, inspect.isawaitable.__module__.__eq__, ["inspect"], true, "isawaitable module is inspect"]
    - [inex290b04, inspect.isframe.__module__.__eq__, ["inspect"], true, "isframe module is inspect"]
    - [inex290b05, inspect.iscode.__module__.__eq__, ["inspect"], true, "iscode module is inspect"]
    - [inex290b06, inspect.istraceback.__module__.__eq__, ["inspect"], true, "istraceback module is inspect"]
    - [inex290b07, inspect.isbuiltin.__module__.__eq__, ["inspect"], true, "isbuiltin module is inspect"]
    - [inex290b08, inspect.ismethodwrapper.__module__.__eq__, ["inspect"], true, "ismethodwrapper module is inspect"]

invariant inspect_extra290.inv_co_optimized_int:
  description: "CO_OPTIMIZED compile flag is an int"
  category: identity
  kind: python_call_eq
  function: inspect.CO_OPTIMIZED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra290.inv_co_generator_int:
  description: "CO_GENERATOR compile flag is an int"
  category: identity
  kind: python_call_eq
  function: inspect.CO_GENERATOR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra290.inv_co_coroutine_int:
  description: "CO_COROUTINE compile flag is an int"
  category: identity
  kind: python_call_eq
  function: inspect.CO_COROUTINE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
