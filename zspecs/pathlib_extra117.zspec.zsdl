spec: pathlib_extra117
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra116.zspec.zsdl."
    - "This spec covers: pathlib.PurePath property fget qualnames for parts, drive, root, anchor, parents, name, suffix, suffixes, stem."
    - "All these properties are defined on PurePath so fget qualnames use the 'PurePath.' prefix."
    - "pathlib.PurePath.parts.fget.__qualname__ == 'PurePath.parts' (len 14)."
    - "pathlib.PurePath.drive.fget.__qualname__ == 'PurePath.drive' (len 14)."
    - "pathlib.PurePath.root.fget.__qualname__ == 'PurePath.root' (len 13)."
    - "pathlib.PurePath.anchor.fget.__qualname__ == 'PurePath.anchor' (len 15)."
    - "pathlib.PurePath.parents.fget.__qualname__ == 'PurePath.parents' (len 16)."
    - "pathlib.PurePath.name.fget.__qualname__ == 'PurePath.name' (len 13)."
    - "pathlib.PurePath.suffix.fget.__qualname__ == 'PurePath.suffix' (len 15)."
    - "pathlib.PurePath.suffixes.fget.__qualname__ == 'PurePath.suffixes' (len 17)."
    - "pathlib.PurePath.stem.fget.__qualname__ == 'PurePath.stem' (len 13)."
    - "root, name, and stem all share qualname length 13; parts and drive share length 14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.parts, drive, root fget qualnames
# All defined on PurePath; fget qualnames use 'PurePath.' prefix.
# parts: 'PurePath.parts' (14 chars).
# drive: 'PurePath.drive' (14 chars; same length as parts).
# root: 'PurePath.root' (13 chars).
# ---------------------------------------------------------------------------

table pathlib_extra117.PurePath_parts_drive_root_fget_qualnames:
  description: "pathlib.PurePath parts/drive/root fget.__qualname__: parts='PurePath.parts'(14), drive='PurePath.drive'(14), root='PurePath.root'(13); all defined on PurePath with 'PurePath.' prefix"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn117a

  columns: [id, function, args, expected, description]
  rows:
    - [parts_fget_qn_eq,    "PurePath.parts.fget.__qualname__.__eq__",   ["PurePath.parts"],  true,  "pathlib.PurePath.parts.fget.__qualname__ == 'PurePath.parts' (returns tuple of path components)"]
    - [parts_fget_qn_len,   "PurePath.parts.fget.__qualname__.__len__",  [],                  14,    "pathlib.PurePath.parts.fget.__qualname__.__len__() == 14 ('PurePath.parts' has 14 chars)"]
    - [drive_fget_qn_eq,    "PurePath.drive.fget.__qualname__.__eq__",   ["PurePath.drive"],  true,  "pathlib.PurePath.drive.fget.__qualname__ == 'PurePath.drive' (returns drive letter or empty string)"]
    - [drive_fget_qn_len,   "PurePath.drive.fget.__qualname__.__len__",  [],                  14,    "pathlib.PurePath.drive.fget.__qualname__.__len__() == 14 ('PurePath.drive' has 14 chars; same length as parts)"]
    - [root_fget_qn_eq,     "PurePath.root.fget.__qualname__.__eq__",    ["PurePath.root"],   true,  "pathlib.PurePath.root.fget.__qualname__ == 'PurePath.root' (returns root string such as '/' on POSIX)"]
    - [root_fget_qn_len,    "PurePath.root.fget.__qualname__.__len__",   [],                  13,    "pathlib.PurePath.root.fget.__qualname__.__len__() == 13 ('PurePath.root' has 13 chars)"]
    - [parts_eq_drive_len,  "PurePath.parts.fget.__qualname__.__len__.__eq__", [14],          true,  "len('PurePath.parts') == len('PurePath.drive') == 14 (parts and drive share identical fget qualname length)"]
    - [root_lt_parts,       "PurePath.root.fget.__qualname__.__len__.__lt__",  [14],          true,  "len('PurePath.root') < len('PurePath.parts') (13 < 14; root is one char shorter than parts and drive)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.anchor, parents, name fget qualnames
# All defined on PurePath; fget qualnames use 'PurePath.' prefix.
# anchor: 'PurePath.anchor' (15 chars).
# parents: 'PurePath.parents' (16 chars).
# name: 'PurePath.name' (13 chars; same length as root and stem).
# ---------------------------------------------------------------------------

table pathlib_extra117.PurePath_anchor_parents_name_fget_qualnames:
  description: "pathlib.PurePath anchor/parents/name fget.__qualname__: anchor='PurePath.anchor'(15), parents='PurePath.parents'(16), name='PurePath.name'(13); all use 'PurePath.' prefix"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn117b

  columns: [id, function, args, expected, description]
  rows:
    - [anchor_fget_qn_eq,   "PurePath.anchor.fget.__qualname__.__eq__",    ["PurePath.anchor"],   true,  "pathlib.PurePath.anchor.fget.__qualname__ == 'PurePath.anchor' (concatenation of drive and root)"]
    - [anchor_fget_qn_len,  "PurePath.anchor.fget.__qualname__.__len__",   [],                    15,    "pathlib.PurePath.anchor.fget.__qualname__.__len__() == 15 ('PurePath.anchor' has 15 chars)"]
    - [parents_fget_qn_eq,  "PurePath.parents.fget.__qualname__.__eq__",   ["PurePath.parents"],  true,  "pathlib.PurePath.parents.fget.__qualname__ == 'PurePath.parents' (immutable sequence of logical ancestors)"]
    - [parents_fget_qn_len, "PurePath.parents.fget.__qualname__.__len__",  [],                    16,    "pathlib.PurePath.parents.fget.__qualname__.__len__() == 16 ('PurePath.parents' has 16 chars; longest in this group)"]
    - [name_fget_qn_eq,     "PurePath.name.fget.__qualname__.__eq__",      ["PurePath.name"],     true,  "pathlib.PurePath.name.fget.__qualname__ == 'PurePath.name' (final path component without drive or root)"]
    - [name_fget_qn_len,    "PurePath.name.fget.__qualname__.__len__",     [],                    13,    "pathlib.PurePath.name.fget.__qualname__.__len__() == 13 ('PurePath.name' has 13 chars; same length as root and stem)"]
    - [parents_gt_anchor,   "PurePath.parents.fget.__qualname__.__len__.__gt__", [15],            true,  "len('PurePath.parents') > len('PurePath.anchor') (16 > 15; parents is longest in this group)"]
    - [name_lt_anchor,      "PurePath.name.fget.__qualname__.__len__.__lt__",    [15],            true,  "len('PurePath.name') < len('PurePath.anchor') (13 < 15; name is shorter than anchor)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.suffix, suffixes, stem fget qualnames
# All defined on PurePath; fget qualnames use 'PurePath.' prefix.
# suffix: 'PurePath.suffix' (15 chars).
# suffixes: 'PurePath.suffixes' (17 chars; longest among all nine properties).
# stem: 'PurePath.stem' (13 chars; same length as root and name).
# ---------------------------------------------------------------------------

table pathlib_extra117.PurePath_suffix_suffixes_stem_fget_qualnames:
  description: "pathlib.PurePath suffix/suffixes/stem fget.__qualname__: suffix='PurePath.suffix'(15), suffixes='PurePath.suffixes'(17), stem='PurePath.stem'(13); suffixes is the longest"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn117c

  columns: [id, function, args, expected, description]
  rows:
    - [suffix_fget_qn_eq,    "PurePath.suffix.fget.__qualname__.__eq__",     ["PurePath.suffix"],    true,  "pathlib.PurePath.suffix.fget.__qualname__ == 'PurePath.suffix' (final file extension including dot)"]
    - [suffix_fget_qn_len,   "PurePath.suffix.fget.__qualname__.__len__",    [],                     15,    "pathlib.PurePath.suffix.fget.__qualname__.__len__() == 15 ('PurePath.suffix' has 15 chars)"]
    - [suffixes_fget_qn_eq,  "PurePath.suffixes.fget.__qualname__.__eq__",   ["PurePath.suffixes"],  true,  "pathlib.PurePath.suffixes.fget.__qualname__ == 'PurePath.suffixes' (list of all file suffixes including dots)"]
    - [suffixes_fget_qn_len, "PurePath.suffixes.fget.__qualname__.__len__",  [],                     17,    "pathlib.PurePath.suffixes.fget.__qualname__.__len__() == 17 ('PurePath.suffixes' has 17 chars; longest among all nine PurePath properties examined)"]
    - [stem_fget_qn_eq,      "PurePath.stem.fget.__qualname__.__eq__",       ["PurePath.stem"],      true,  "pathlib.PurePath.stem.fget.__qualname__ == 'PurePath.stem' (final path component without its suffix)"]
    - [stem_fget_qn_len,     "PurePath.stem.fget.__qualname__.__len__",      [],                     13,    "pathlib.PurePath.stem.fget.__qualname__.__len__() == 13 ('PurePath.stem' has 13 chars; same length as root and name)"]
    - [suffixes_gt_suffix,   "PurePath.suffixes.fget.__qualname__.__len__.__gt__", [15],             true,  "len('PurePath.suffixes') > len('PurePath.suffix') (17 > 15; suffixes is two chars longer than suffix)"]
    - [stem_lt_suffix,       "PurePath.stem.fget.__qualname__.__len__.__lt__",     [15],             true,  "len('PurePath.stem') < len('PurePath.suffix') (13 < 15; stem is shorter than suffix)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra117.PurePath.parts_fget_qualname:
  description: "pathlib.PurePath.parts.fget.__qualname__ == 'PurePath.parts' (length 14; parts is a property defined on PurePath; its fget carries the 'PurePath.' prefix; it returns an immutable tuple of path components such as ('/', 'usr', 'local', 'bin') on POSIX)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.parts.fget.__qualname__.__eq__"
  args: ["PurePath.parts"]
  expected: true

invariant pathlib_extra117.PurePath.drive_fget_qualname_len:
  description: "pathlib.PurePath.drive.fget.__qualname__.__len__() == 14 ('PurePath.drive' has 14 characters; drive and parts share this same fget qualname length of 14; 'PurePath.' (9) + 'drive' (5) == 14; on POSIX drive is always an empty string)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.drive.fget.__qualname__.__len__"
  args: []
  expected: 14

invariant pathlib_extra117.PurePath.suffixes_fget_qualname_len:
  description: "pathlib.PurePath.suffixes.fget.__qualname__.__len__() == 17 ('PurePath.suffixes' has 17 characters; it is the longest fget qualname among the nine PurePath properties examined; 'PurePath.' (9) + 'suffixes' (8) == 17; suffixes returns a list like ['.tar', '.gz'] for 'archive.tar.gz')"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.suffixes.fget.__qualname__.__len__"
  args: []
  expected: 17

invariant pathlib_extra117.PurePath.stem_fget_qualname_len:
  description: "pathlib.PurePath.stem.fget.__qualname__.__len__() == 13 ('PurePath.stem' has 13 characters; root, name, and stem all share this fget qualname length of 13; 'PurePath.' (9) + 'stem' (4) == 13; stem is the final path component without its last suffix)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.stem.fget.__qualname__.__len__"
  args: []
  expected: 13

invariant pathlib_extra117.PurePath.parents_fget_qualname_len:
  description: "pathlib.PurePath.parents.fget.__qualname__.__len__() == 16 ('PurePath.parents' has 16 characters; parents is the longest fget qualname after suffixes at 17; 'PurePath.' (9) + 'parents' (7) == 16; parents returns an immutable sequence of PurePath objects representing the logical ancestors)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.parents.fget.__qualname__.__len__"
  args: []
  expected: 16
