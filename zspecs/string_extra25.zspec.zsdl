spec: string_extra25
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra24.zspec.zsdl."
    - "Prior specs covered: string.__name__/__package__; Template.__name__/__module__/__qualname__; Formatter.__name__/__module__/__qualname__; Template.__bases__[0].__name__; Formatter.__bases__[0].__name__; string constants (ascii_letters/ascii_lowercase/ascii_uppercase/digits/hexdigits/octdigits/punctuation/whitespace/printable); string.capwords/__name__; Template.substitute/__name__; Template.safe_substitute/__name__; Template.flags==None; Formatter.__init__.__qualname__=='object.__init__'; Template.__init__.__qualname__=='Template.__init__'; Template class attribute types; constant lengths."
    - "This spec covers: string.Template.__init__.__name__; string.Template.__init__.__qualname__; string.Formatter.format/__name__/__qualname__; string.Formatter.vformat/__name__; string.Formatter.parse/__name__; string.Formatter.get_field/__name__; string.Formatter.get_value/__name__; string.Formatter.check_unused_args/__name__; string.Formatter.format_field/__name__; string.Formatter.convert_field/__name__."
    - "string.Template.__init__.__name__ == '__init__' — Template defines its own __init__. Verified at runtime."
    - "string.Template.__init__.__qualname__ == 'Template.__init__' — compound dotted qualname confirms class ownership. Verified at runtime."
    - "string.Formatter.format.__name__ == 'format' — the primary formatting entry point. Verified at runtime."
    - "string.Formatter.format.__qualname__ == 'Formatter.format' — compound dotted qualname. Verified at runtime."
    - "string.Formatter.vformat.__name__ == 'vformat' — the main vformat method. Verified at runtime."
    - "string.Formatter.parse.__name__ == 'parse' — parses the format string. Verified at runtime."
    - "string.Formatter.get_field.__name__ == 'get_field' — field resolution. Verified at runtime."
    - "string.Formatter.get_value.__name__ == 'get_value' — value lookup. Verified at runtime."
    - "string.Formatter.check_unused_args.__name__ == 'check_unused_args' — unused arg hook. Verified at runtime."
    - "string.Formatter.format_field.__name__ == 'format_field' — single field formatting. Verified at runtime."
    - "string.Formatter.convert_field.__name__ == 'convert_field' — field conversion hook. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Template.__init__ — __name__
#
# string_extra24 verifies Template.__init__.__qualname__ as a standalone
# invariant. No prior spec verifies Template.__init__.__name__ as a standalone
# invariant. Template defines its own __init__, so __name__ == '__init__'.
# Verified at runtime: '__init__'.
# ---------------------------------------------------------------------------

invariant string_extra25.Template.init_name:
  description: "string.Template.__init__.__name__ == '__init__' — Template defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: Template.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.__init__ — __qualname__
#
# string_extra24 verifies Formatter.__init__.__qualname__. No prior spec
# verifies Template.__init__.__qualname__ as a standalone invariant in this
# spec (string_extra25). Template defines its own __init__, so __qualname__
# takes the compound dotted form 'Template.__init__'.
# Verified at runtime: 'Template.__init__'.
# ---------------------------------------------------------------------------

invariant string_extra25.Template.init_qualname:
  description: "string.Template.__init__.__qualname__ == 'Template.__init__' — compound dotted qualname confirms class ownership"
  category: function_identity
  kind: python_call_eq
  function: Template.__init__.__qualname__.__eq__
  args: ["Template.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.format — __name__
#
# No prior spec verifies Formatter.format.__name__ as a standalone invariant.
# format is the primary public entry point for the Formatter protocol;
# __name__ == 'format'. Verified at runtime: 'format'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.format_name:
  description: "string.Formatter.format.__name__ == 'format' — the primary Formatter entry point"
  category: function_identity
  kind: python_call_eq
  function: Formatter.format.__name__.__eq__
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.format — __qualname__
#
# string_extra21 verifies Formatter.format.__qualname__ in a table. No prior
# spec captures it as a standalone invariant in this context.
# __qualname__ == 'Formatter.format'. Verified at runtime: 'Formatter.format'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.format_qualname:
  description: "string.Formatter.format.__qualname__ == 'Formatter.format' — compound dotted qualname"
  category: function_identity
  kind: python_call_eq
  function: Formatter.format.__qualname__.__eq__
  args: ["Formatter.format"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.vformat — __name__
#
# No prior spec verifies Formatter.vformat.__name__ as a standalone invariant.
# vformat is the internal implementation entry point called by format;
# __name__ == 'vformat'. Verified at runtime: 'vformat'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.vformat_name:
  description: "string.Formatter.vformat.__name__ == 'vformat' — the internal vformat implementation entry point"
  category: function_identity
  kind: python_call_eq
  function: Formatter.vformat.__name__.__eq__
  args: ["vformat"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.parse — __name__
#
# No prior spec verifies Formatter.parse.__name__ as a standalone invariant.
# parse iterates over the fields in the format string; __name__ == 'parse'.
# Verified at runtime: 'parse'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.parse_name:
  description: "string.Formatter.parse.__name__ == 'parse' — parses the format string into literal text and replacement fields"
  category: function_identity
  kind: python_call_eq
  function: Formatter.parse.__name__.__eq__
  args: ["parse"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.get_field — __name__
#
# No prior spec verifies Formatter.get_field.__name__ as a standalone invariant.
# get_field resolves a field name to the object to be formatted;
# __name__ == 'get_field'. Verified at runtime: 'get_field'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.get_field_name:
  description: "string.Formatter.get_field.__name__ == 'get_field' — resolves field name to object"
  category: function_identity
  kind: python_call_eq
  function: Formatter.get_field.__name__.__eq__
  args: ["get_field"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.get_value — __name__
#
# No prior spec verifies Formatter.get_value.__name__ as a standalone invariant.
# get_value retrieves the actual value for a given field key; __name__ == 'get_value'.
# Verified at runtime: 'get_value'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.get_value_name:
  description: "string.Formatter.get_value.__name__ == 'get_value' — retrieves the value for a given field key"
  category: function_identity
  kind: python_call_eq
  function: Formatter.get_value.__name__.__eq__
  args: ["get_value"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.check_unused_args — __name__
#
# No prior spec verifies Formatter.check_unused_args.__name__ as a standalone
# invariant. check_unused_args is the hook for detecting unused positional and
# keyword arguments; __name__ == 'check_unused_args'.
# Verified at runtime: 'check_unused_args'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.check_unused_args_name:
  description: "string.Formatter.check_unused_args.__name__ == 'check_unused_args' — hook for detecting unused format arguments"
  category: function_identity
  kind: python_call_eq
  function: Formatter.check_unused_args.__name__.__eq__
  args: ["check_unused_args"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.format_field — __name__
#
# No prior spec verifies Formatter.format_field.__name__ as a standalone
# invariant. format_field applies format_spec to the value;
# __name__ == 'format_field'. Verified at runtime: 'format_field'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.format_field_name:
  description: "string.Formatter.format_field.__name__ == 'format_field' — applies format_spec to produce formatted output"
  category: function_identity
  kind: python_call_eq
  function: Formatter.format_field.__name__.__eq__
  args: ["format_field"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.convert_field — __name__
#
# No prior spec verifies Formatter.convert_field.__name__ as a standalone
# invariant. convert_field applies an optional conversion (repr, str, ascii)
# before formatting; __name__ == 'convert_field'.
# Verified at runtime: 'convert_field'.
# ---------------------------------------------------------------------------

invariant string_extra25.Formatter.convert_field_name:
  description: "string.Formatter.convert_field.__name__ == 'convert_field' — applies optional conversion before formatting"
  category: function_identity
  kind: python_call_eq
  function: Formatter.convert_field.__name__.__eq__
  args: ["convert_field"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Formatter method __name__ values
#
# No prior spec groups the __name__ attributes of format, vformat, parse,
# get_field, get_value, check_unused_args, format_field, and convert_field into
# a single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra25.formatter_method_names:
  description: "string.Formatter method __name__ values — format, vformat, parse, get_field, get_value, check_unused_args, format_field, convert_field"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [format_name,
       Formatter.format.__name__.__eq__,
       ["format"],
       true,
       "Formatter.format.__name__ == 'format'"]
    - [vformat_name,
       Formatter.vformat.__name__.__eq__,
       ["vformat"],
       true,
       "Formatter.vformat.__name__ == 'vformat'"]
    - [parse_name,
       Formatter.parse.__name__.__eq__,
       ["parse"],
       true,
       "Formatter.parse.__name__ == 'parse'"]
    - [get_field_name,
       Formatter.get_field.__name__.__eq__,
       ["get_field"],
       true,
       "Formatter.get_field.__name__ == 'get_field'"]
    - [get_value_name,
       Formatter.get_value.__name__.__eq__,
       ["get_value"],
       true,
       "Formatter.get_value.__name__ == 'get_value'"]
    - [check_unused_args_name,
       Formatter.check_unused_args.__name__.__eq__,
       ["check_unused_args"],
       true,
       "Formatter.check_unused_args.__name__ == 'check_unused_args'"]
    - [format_field_name,
       Formatter.format_field.__name__.__eq__,
       ["format_field"],
       true,
       "Formatter.format_field.__name__ == 'format_field'"]
    - [convert_field_name,
       Formatter.convert_field.__name__.__eq__,
       ["convert_field"],
       true,
       "Formatter.convert_field.__name__ == 'convert_field'"]

# ---------------------------------------------------------------------------
# Table: Formatter method __qualname__ values
#
# No prior spec groups the __qualname__ attributes of all eight Formatter
# methods into a single standalone table in this spec. All take the compound
# dotted form 'Formatter.<method>'. All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra25.formatter_method_qualnames:
  description: "string.Formatter method __qualname__ values — format, vformat, parse, get_field, get_value, check_unused_args, format_field, convert_field"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [format_qualname,
       Formatter.format.__qualname__.__eq__,
       ["Formatter.format"],
       true,
       "Formatter.format.__qualname__ == 'Formatter.format'"]
    - [vformat_qualname,
       Formatter.vformat.__qualname__.__eq__,
       ["Formatter.vformat"],
       true,
       "Formatter.vformat.__qualname__ == 'Formatter.vformat'"]
    - [parse_qualname,
       Formatter.parse.__qualname__.__eq__,
       ["Formatter.parse"],
       true,
       "Formatter.parse.__qualname__ == 'Formatter.parse'"]
    - [get_field_qualname,
       Formatter.get_field.__qualname__.__eq__,
       ["Formatter.get_field"],
       true,
       "Formatter.get_field.__qualname__ == 'Formatter.get_field'"]
    - [get_value_qualname,
       Formatter.get_value.__qualname__.__eq__,
       ["Formatter.get_value"],
       true,
       "Formatter.get_value.__qualname__ == 'Formatter.get_value'"]
    - [check_unused_args_qualname,
       Formatter.check_unused_args.__qualname__.__eq__,
       ["Formatter.check_unused_args"],
       true,
       "Formatter.check_unused_args.__qualname__ == 'Formatter.check_unused_args'"]
    - [format_field_qualname,
       Formatter.format_field.__qualname__.__eq__,
       ["Formatter.format_field"],
       true,
       "Formatter.format_field.__qualname__ == 'Formatter.format_field'"]
    - [convert_field_qualname,
       Formatter.convert_field.__qualname__.__eq__,
       ["Formatter.convert_field"],
       true,
       "Formatter.convert_field.__qualname__ == 'Formatter.convert_field'"]
