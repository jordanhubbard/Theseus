spec: socket_extra2536
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec focuses on __format__, __bytes__, and __fspath__ dict-presence for socket.socket."
    - "socket_extra.zspec.zsdl covers: create_connection/create_server/setdefaulttimeout/htons/ntohs names; inet_aton/inet_ntoa vectors; htons/ntohs/ntohl/htonl byte-order checks."
    - "socket_extra2.zspec.zsdl covers: AddressFamily/SocketKind enum class names; constant integer values; gethostname/getfqdn return types; socket.error alias; socket.timeout alias."
    - "socket.socket does NOT define __format__ in its __dict__ — no custom formatting protocol."
    - "socket.socket does NOT define __bytes__ in its __dict__ — sockets are not byte-convertible via the bytes() protocol."
    - "socket.socket does NOT define __fspath__ in its __dict__ — sockets are not filesystem paths."
    - "socket.socket.__dict__ DOES contain: __init__, __repr__, __enter__, __exit__, __slots__, plus Python-level methods: dup, accept, makefile, sendfile, close, detach, family, type, etc."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class __dict__ presence: __format__ absent
# ---------------------------------------------------------------------------

table socket_extra2536.socket.format_absent:
  description: "socket.socket.__dict__ does NOT contain __format__ — no custom formatting protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2536

  columns: [id, function, args, expected]
  rows:
    - ["sk2536-fmt-absent", socket.__dict__.__contains__, ["__format__"], false]

# ---------------------------------------------------------------------------
# socket.socket class __dict__ presence: __bytes__ absent
# ---------------------------------------------------------------------------

table socket_extra2536.socket.bytes_absent:
  description: "socket.socket.__dict__ does NOT contain __bytes__ — no bytes-conversion protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2536

  columns: [id, function, args, expected]
  rows:
    - ["sk2536-bytes-absent", socket.__dict__.__contains__, ["__bytes__"], false]

# ---------------------------------------------------------------------------
# socket.socket class __dict__ presence: __fspath__ absent
# ---------------------------------------------------------------------------

table socket_extra2536.socket.fspath_absent:
  description: "socket.socket.__dict__ does NOT contain __fspath__ — sockets are not filesystem paths"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2536

  columns: [id, function, args, expected]
  rows:
    - ["sk2536-fspath-absent", socket.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# socket.socket class __dict__ presence: members that ARE present (positive control)
# These confirm __dict__.__contains__ works correctly for socket.socket.
# ---------------------------------------------------------------------------

table socket_extra2536.socket.dict_present:
  description: "socket.socket.__dict__ DOES contain these members (positive-control checks)"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2536

  columns: [id, function, args, expected]
  rows:
    - ["sk2536-init-present",   socket.__dict__.__contains__, ["__init__"],   true]
    - ["sk2536-repr-present",   socket.__dict__.__contains__, ["__repr__"],   true]
    - ["sk2536-enter-present",  socket.__dict__.__contains__, ["__enter__"],  true]
    - ["sk2536-exit-present",   socket.__dict__.__contains__, ["__exit__"],   true]
    - ["sk2536-close-present",  socket.__dict__.__contains__, ["close"],      true]
    - ["sk2536-detach-present", socket.__dict__.__contains__, ["detach"],     true]

# ---------------------------------------------------------------------------
# socket.socket class __dict__ presence: all three protocols absent in one table
# Consolidates the three absent checks for compact cross-reference.
# ---------------------------------------------------------------------------

table socket_extra2536.socket.protocol_dunders_absent:
  description: "socket.socket.__dict__ contains none of __format__, __bytes__, __fspath__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2536

  columns: [id, function, args, expected]
  rows:
    - ["sk2536-p1-fmt",    socket.__dict__.__contains__, ["__format__"], false]
    - ["sk2536-p1-bytes",  socket.__dict__.__contains__, ["__bytes__"],  false]
    - ["sk2536-p1-fspath", socket.__dict__.__contains__, ["__fspath__"], false]
