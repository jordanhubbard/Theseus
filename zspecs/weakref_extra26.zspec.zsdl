spec: weakref_extra26
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra25.zspec.zsdl."
    - "Prior specs covered: ref/__name__/__module__/__qualname__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __name__/__module__/__qualname__, ref.__bases__[0].__name__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __bases__[0].__name__, ref.__init__.__name__, __module__.__len__() and __name__.__len__() for proxy/getweakrefcount/getweakrefs/ReferenceType/ProxyType/CallableProxyType/WeakMethod, finalize method __qualname__.__len__() for __init__/__call__/peek/detach."
    - "This spec covers: __qualname__.__len__() for WeakValueDictionary methods (get/__setitem__/__getitem__/setdefault/pop); __qualname__.__len__() for WeakKeyDictionary methods (get/__setitem__/__getitem__/setdefault/pop); __mro__.__len__() for WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; __slots__ existence and type for WeakValueDictionary/WeakKeyDictionary/finalize."
    - "WeakValueDictionary.get.__qualname__ == 'WeakValueDictionary.get' (23); WeakValueDictionary.__setitem__.__qualname__ (31); WeakValueDictionary.setdefault.__qualname__ (30)."
    - "WeakKeyDictionary.get.__qualname__ == 'WeakKeyDictionary.get' (21); WeakKeyDictionary.__setitem__.__qualname__ (29)."
    - "WeakValueDictionary and WeakKeyDictionary both have __mro__ length 8 (inherit through the full MutableMapping chain)."
    - "weakref.WeakSet.__mro__ length 2 — WeakSet directly subclasses object (defined in _weakrefset)."
    - "weakref.finalize.__mro__ length 2 — finalize directly subclasses object."
    - "WeakValueDictionary.__slots__ == () and WeakKeyDictionary.__slots__ == () — both define empty __slots__."
    - "finalize.__slots__ == () — finalize defines empty __slots__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for WeakValueDictionary methods
#
# WeakValueDictionary is a Python class; its methods have __qualname__ of the
# form 'WeakValueDictionary.<method>'. The class name prefix contributes 19
# characters plus a dot. Dunder methods (__setitem__/__getitem__, 11 chars each)
# reach 31; setdefault (10 chars) reaches 30; get/pop (3 chars) reach 23.
# No prior weakref spec records __qualname__.__len__() for WeakValueDictionary
# methods.
# ---------------------------------------------------------------------------

table weakref_extra26.weakvaluedict_method_qualname_lens:
  description: "__qualname__.__len__() for WeakValueDictionary methods — range 23 (get/pop) to 31 (__setitem__/__getitem__)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [get,         WeakValueDictionary.get.__qualname__.__len__,         [], 23]
    - [__setitem__, WeakValueDictionary.__setitem__.__qualname__.__len__,  [], 31]
    - [__getitem__, WeakValueDictionary.__getitem__.__qualname__.__len__,  [], 31]
    - [setdefault,  WeakValueDictionary.setdefault.__qualname__.__len__,   [], 30]
    - [pop,         WeakValueDictionary.pop.__qualname__.__len__,          [], 23]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for WeakKeyDictionary methods
#
# WeakKeyDictionary methods use the prefix 'WeakKeyDictionary.' (17 chars +
# dot). The pattern mirrors WeakValueDictionary but is 2 chars shorter at each
# position: get/pop at 21, __setitem__/__getitem__ at 29, setdefault at 28.
# No prior weakref spec records __qualname__.__len__() for WeakKeyDictionary
# methods.
# ---------------------------------------------------------------------------

table weakref_extra26.weakkeydict_method_qualname_lens:
  description: "__qualname__.__len__() for WeakKeyDictionary methods — range 21 (get/pop) to 29 (__setitem__/__getitem__)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [get,         WeakKeyDictionary.get.__qualname__.__len__,         [], 21]
    - [__setitem__, WeakKeyDictionary.__setitem__.__qualname__.__len__,  [], 29]
    - [__getitem__, WeakKeyDictionary.__getitem__.__qualname__.__len__,  [], 29]
    - [setdefault,  WeakKeyDictionary.setdefault.__qualname__.__len__,   [], 28]
    - [pop,         WeakKeyDictionary.pop.__qualname__.__len__,          [], 21]

# ---------------------------------------------------------------------------
# __mro__.__len__() for WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize
#
# WeakValueDictionary and WeakKeyDictionary both inherit through the full
# MutableMapping ABC chain: WeakXDictionary -> MutableMapping -> Mapping ->
# Collection -> Sized/Iterable/Container -> object (8 entries). WeakSet and
# finalize each subclass object directly (MRO length 2). No prior weakref spec
# records __mro__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table weakref_extra26.class_mro_lens:
  description: "__mro__.__len__() for weakref classes — WeakValueDict/WeakKeyDict depth 8, WeakSet/finalize depth 2"
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [WeakValueDictionary, WeakValueDictionary.__mro__.__len__, [], 8]
    - [WeakKeyDictionary,   WeakKeyDictionary.__mro__.__len__,   [], 8]
    - [WeakSet,             WeakSet.__mro__.__len__,             [], 2]
    - [finalize,            finalize.__mro__.__len__,            [], 2]

# ---------------------------------------------------------------------------
# weakref.WeakValueDictionary.__setitem__.__qualname__.__len__() == 31 —
# standalone
#
# 'WeakValueDictionary.__setitem__' has 31 characters: the 19-character class
# name, a dot, and the 11-character dunder method name. This is the longest
# method qualname among all WeakValueDictionary methods measured here and the
# longest in the weakref module across the extra series.
# ---------------------------------------------------------------------------

invariant weakref_extra26.WeakValueDictionary.setitem.qualname_len:
  description: "weakref.WeakValueDictionary.__setitem__.__qualname__.__len__() == 31 — 'WeakValueDictionary.__setitem__' is 19 + 1 + 11 = 31 characters; longest method qualname in weakref extra series"
  category: method_qualname_lengths
  kind: python_call_eq
  function: WeakValueDictionary.__setitem__.__qualname__.__len__
  args: []
  expected: 31

# ---------------------------------------------------------------------------
# weakref.WeakValueDictionary.__slots__.__class__.__name__.__len__() == 5 —
# standalone
#
# WeakValueDictionary.__slots__ == () — an empty tuple. The class name 'tuple'
# has length 5. This confirms WeakValueDictionary explicitly defines __slots__
# (to suppress __dict__) but reserves no named slots.
# ---------------------------------------------------------------------------

invariant weakref_extra26.WeakValueDictionary.slots_class_name_len:
  description: "weakref.WeakValueDictionary.__slots__.__class__.__name__.__len__() == 5 — __slots__ is a tuple (length 5); empty __slots__ defined to suppress __dict__"
  category: slot_checks
  kind: python_call_eq
  function: WeakValueDictionary.__slots__.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# weakref.WeakValueDictionary.__mro__.__len__() == 8 — standalone
#
# WeakValueDictionary inherits through the full MutableMapping ABC hierarchy:
# WeakValueDictionary -> MutableMapping -> Mapping -> Collection ->
# Sized/Iterable/Container -> object (8 entries total). This is the deepest
# MRO among all weakref classes measured in the extra series.
# ---------------------------------------------------------------------------

invariant weakref_extra26.WeakValueDictionary.mro_len:
  description: "weakref.WeakValueDictionary.__mro__.__len__() == 8 — inherits through the full MutableMapping ABC chain (8 entries); deepest MRO in weakref module"
  category: mro_lengths
  kind: python_call_eq
  function: WeakValueDictionary.__mro__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# weakref.finalize.__slots__.__class__.__name__.__len__() == 5 — standalone
#
# weakref.finalize.__slots__ == () — empty tuple. Its class name is 'tuple'
# (length 5). finalize is a C-level class that defines empty __slots__.
# ---------------------------------------------------------------------------

invariant weakref_extra26.finalize.slots_class_name_len:
  description: "weakref.finalize.__slots__.__class__.__name__.__len__() == 5 — finalize.__slots__ is a tuple (length 5); empty __slots__ defined on the finalize class"
  category: slot_checks
  kind: python_call_eq
  function: finalize.__slots__.__class__.__name__.__len__
  args: []
  expected: 5
