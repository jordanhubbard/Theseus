    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 642 (uu2926): __iand__, __ior__, __ixor__ dict-presence checks for uuid types."
    - "uuid.UUID is an immutable identifier class; uuid.SafeUUID is an IntEnum — neither defines in-place bitwise AND, OR, or XOR operators."
    - "Verified types: uuid.UUID, uuid.SafeUUID."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu2926.iand:
