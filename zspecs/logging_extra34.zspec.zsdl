spec: logging_extra34
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra33.zspec.zsdl — covers Filter/Filterer __mro__/__bases__[0].__name__; Filterer __qualname__/__dict__ type; NOTSET class name len; Logger remaining method qualnames (findCaller/makeRecord/handle/callHandlers/getEffectiveLevel/isEnabledFor); Handler remaining method qualnames (acquire/release/close/addFilter); Formatter/Filter method qualnames (formatTime/formatException/filter); additional module-level fn qualnames (disable/addLevelName/captureWarnings/shutdown)."
    - "logging_extra32.zspec.zsdl — covers Logger method __qualname__.__len__() for critical/exception/addHandler/setLevel/removeHandler/hasHandlers; Handler method __qualname__.__len__() for format/setFormatter/handle/setLevel; module-level fn qualnames for warning/error/info/debug/critical/exception/log; StreamHandler/NullHandler/FileHandler hierarchy; Logger/Handler/Formatter/Filter/LogRecord __qualname__.__len__()."
    - "logging_extra30.zspec.zsdl — covers Logger/Handler/Formatter/LogRecord __mro__.__len__() and __bases__[0].__name__.__len__(); Logger.debug/info/warning/error/emit and Formatter.format __qualname__.__len__()."
  notes:
    - "This spec extends logging_extra33.zspec.zsdl."
    - "Prior specs covered: Logger/Handler/Formatter/Filter/Filterer/LogRecord __mro__/__bases__/__dict__/__qualname__, all major method qualnames, module-level function qualnames, level constant class names."
    - "This spec covers NEW angles: class __name__.__len__() for Logger(6)/Handler(7)/Formatter(9)/Filter(6)/Filterer(8)/LogRecord(9); Logger.__qualname__.__len__()==6 as standalone invariant; __mro__.__len__() for Logger(3)/Handler(3)/Formatter(2) as standalone invariants."
    - "logging.Logger.__name__ == 'Logger' (len 6). logging.Logger.__qualname__ == 'Logger' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Handler.__name__ == 'Handler' (len 7). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Formatter.__name__ == 'Formatter' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Filter.__name__ == 'Filter' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Filterer.__name__ == 'Filterer' (len 8). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.LogRecord.__name__ == 'LogRecord' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.__mro__.__len__() == 3 — MRO: [Logger, Filterer, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Handler.__mro__.__len__() == 3 — MRO: [Handler, Filterer, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Formatter.__mro__.__len__() == 2 — MRO: [Formatter, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# logging class __name__.__len__() for Logger, Handler, Formatter, Filter,
# Filterer, LogRecord
#
# Prior specs (extra32) checked __qualname__.__len__() for these classes.
# This spec records __name__.__len__(). For top-level classes __name__ equals
# __qualname__. Values: Logger(6), Handler(7), Formatter(9), Filter(6),
# Filterer(8), LogRecord(9).
# ---------------------------------------------------------------------------

invariant logging_extra34.Logger.name.len:
  description: "logging.Logger.__name__.__len__() == 6 — 'Logger' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Logger.__name__.__len__
  args: []
  expected: 6

invariant logging_extra34.Handler.name.len:
  description: "logging.Handler.__name__.__len__() == 7 — 'Handler' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Handler.__name__.__len__
  args: []
  expected: 7

invariant logging_extra34.Formatter.name.len:
  description: "logging.Formatter.__name__.__len__() == 9 — 'Formatter' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__name__.__len__
  args: []
  expected: 9

invariant logging_extra34.Filter.name.len:
  description: "logging.Filter.__name__.__len__() == 6 — 'Filter' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Filter.__name__.__len__
  args: []
  expected: 6

invariant logging_extra34.Filterer.name.len:
  description: "logging.Filterer.__name__.__len__() == 8 — 'Filterer' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Filterer.__name__.__len__
  args: []
  expected: 8

invariant logging_extra34.LogRecord.name.len:
  description: "logging.LogRecord.__name__.__len__() == 9 — 'LogRecord' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: LogRecord.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# logging.Logger.__qualname__.__len__() as standalone invariant
#
# extra32 covered Logger.__qualname__.__len__()==6 in a table alongside other
# class qualnames. This standalone invariant records it with its own ID for
# direct reference in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant logging_extra34.Logger.qualname.len:
  description: "logging.Logger.__qualname__.__len__() == 6 — 'Logger' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Logger.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# logging class __mro__.__len__() as standalone invariants
#
# extra30 covered __mro__.__len__() for Logger/Handler/Formatter/LogRecord in
# a table. These standalone invariants record Logger(3)/Handler(3)/Formatter(2)
# with individual invariant IDs for direct reference in the extra34 namespace.
# Logger and Handler both inherit from Filterer then object (depth 3).
# Formatter inherits directly from object (depth 2).
# ---------------------------------------------------------------------------

invariant logging_extra34.Logger.mro.len:
  description: "logging.Logger.__mro__.__len__() == 3 — MRO: [Logger, Filterer, object]"
  category: class_introspection
  kind: python_call_eq
  function: Logger.__mro__.__len__
  args: []
  expected: 3

invariant logging_extra34.Handler.mro.len:
  description: "logging.Handler.__mro__.__len__() == 3 — MRO: [Handler, Filterer, object]"
  category: class_introspection
  kind: python_call_eq
  function: Handler.__mro__.__len__
  args: []
  expected: 3

invariant logging_extra34.Formatter.mro.len:
  description: "logging.Formatter.__mro__.__len__() == 2 — MRO: [Formatter, object]"
  category: class_introspection
  kind: python_call_eq
  function: Formatter.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Table: class __name__.__len__() for all six core logging classes
#
# Groups the __name__ length checks for Logger, Handler, Formatter, Filter,
# Filterer, and LogRecord in a single table for batch validation.
# ---------------------------------------------------------------------------

table logging_extra34.class_name_lens:
  description: "logging class __name__.__len__() — Logger (6), Handler (7), Formatter (9), Filter (6), Filterer (8), LogRecord (9)"
  kind: python_call_eq
  category: class_identity
  id_prefix: l34cn

  columns: [id, function, args, expected]
  rows:
    - [Logger_name_len,    Logger.__name__.__len__,    [], 6]
    - [Handler_name_len,   Handler.__name__.__len__,   [], 7]
    - [Formatter_name_len, Formatter.__name__.__len__, [], 9]
    - [Filter_name_len,    Filter.__name__.__len__,    [], 6]
    - [Filterer_name_len,  Filterer.__name__.__len__,  [], 8]
    - [LogRecord_name_len, LogRecord.__name__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Table: class __mro__.__len__() for Logger, Handler, and Formatter
#
# Records MRO depth as a table for Logger(3), Handler(3), Formatter(2).
# Logger and Handler both descend through Filterer; Formatter is a direct
# subclass of object.
# ---------------------------------------------------------------------------

table logging_extra34.class_mro_lens:
  description: "logging class __mro__.__len__() — Logger (3), Handler (3), Formatter (2)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: l34mro

  columns: [id, function, args, expected]
  rows:
    - [Logger_mro_len,    Logger.__mro__.__len__,    [], 3]
    - [Handler_mro_len,   Handler.__mro__.__len__,   [], 3]
    - [Formatter_mro_len, Formatter.__mro__.__len__, [], 2]
