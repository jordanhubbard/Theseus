spec: unittest
version: ">=3.0"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/unittest.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "unittest source: Lib/unittest/__init__.py (PSF; source inspection permitted)"
  not_derived_from:
    - "unittest source: internal test runner implementation"
  notes:
    - "unittest is the Python standard library test framework, inspired by JUnit."
    - "TestCase is the base class for all test cases; methods starting with 'test' are discovered automatically."
    - "TestLoader.testMethodPrefix defaults to 'test' — any method with this prefix is collected."
    - "TestSuite aggregates TestCase instances; countTestCases() returns the total count."
    - "TestResult tracks errors, failures, and testsRun; wasSuccessful() returns True when both lists are empty."
    - "SkipTest inherits from Exception and is raised by skip/skipIf/skipUnless decorators."
    - "unittest.main is actually the TestProgram class — its __name__ is 'TestProgram'."
    - "IsolatedAsyncioTestCase was added in Python 3.8 for async test support."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata — verify __name__ of core unittest classes
# ---------------------------------------------------------------------------

table unittest.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [testcase,          TestCase.__name__.__eq__,               ["TestCase"],               true]
    - [testsuite,         TestSuite.__name__.__eq__,              ["TestSuite"],              true]
    - [testloader,        TestLoader.__name__.__eq__,             ["TestLoader"],             true]
    - [testresult,        TestResult.__name__.__eq__,             ["TestResult"],             true]
    - [texttestrunner,    TextTestRunner.__name__.__eq__,         ["TextTestRunner"],         true]
    - [texttestresult,    TextTestResult.__name__.__eq__,         ["TextTestResult"],         true]
    - [functiontestcase,  FunctionTestCase.__name__.__eq__,       ["FunctionTestCase"],       true]
    - [testprogram,       TestProgram.__name__.__eq__,            ["TestProgram"],            true]
    - [skiptest,          SkipTest.__name__.__eq__,               ["SkipTest"],               true]
    - [isolatedasyncio,   IsolatedAsyncioTestCase.__name__.__eq__, ["IsolatedAsyncioTestCase"], true]

# ---------------------------------------------------------------------------
# Function name metadata — verify __name__ of top-level unittest functions
# ---------------------------------------------------------------------------

table unittest.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [skip,            skip.__name__.__eq__,            ["skip"],            true]
    - [skipif,          skipIf.__name__.__eq__,          ["skipIf"],          true]
    - [skipunless,      skipUnless.__name__.__eq__,      ["skipUnless"],      true]
    - [expectedfailure, expectedFailure.__name__.__eq__,  ["expectedFailure"], true]
    - [installhandler,  installHandler.__name__.__eq__,   ["installHandler"],  true]
    - [registerresult,  registerResult.__name__.__eq__,   ["registerResult"],  true]
    - [removeresult,    removeResult.__name__.__eq__,     ["removeResult"],    true]
    - [removehandler,   removeHandler.__name__.__eq__,    ["removeHandler"],   true]

# ---------------------------------------------------------------------------
# TestLoader defaults — testMethodPrefix governs test discovery
# ---------------------------------------------------------------------------

invariant unittest.loader_prefix:
  description: "unittest.TestLoader().testMethodPrefix == 'test' — discovers methods starting with 'test'"
  category: loader_attrs
  kind: python_call_eq
  function: TestLoader
  args: []
  method: testMethodPrefix
  expected: "test"

# ---------------------------------------------------------------------------
# TestSuite initial state — empty suite has zero tests
# ---------------------------------------------------------------------------

invariant unittest.suite_empty:
  description: "unittest.TestSuite().countTestCases() == 0 — a new suite contains no tests"
  category: suite_state
  kind: python_call_eq
  function: TestSuite
  args: []
  method: countTestCases
  method_args: []
  expected: 0

# ---------------------------------------------------------------------------
# TestResult initial state — no runs, no errors, no failures
# ---------------------------------------------------------------------------

invariant unittest.result_successful:
  description: "unittest.TestResult().wasSuccessful() == True — a fresh result with no tests is successful"
  category: result_state
  kind: python_call_eq
  function: TestResult
  args: []
  method: wasSuccessful
  method_args: []
  expected: true

invariant unittest.result_tests_run:
  description: "unittest.TestResult().testsRun == 0 — no tests have been executed yet"
  category: result_state
  kind: python_call_eq
  function: TestResult
  args: []
  method: testsRun
  expected: 0

invariant unittest.result_errors_empty:
  description: "unittest.TestResult().errors == [] — no errors in a fresh result"
  category: result_state
  kind: python_call_eq
  function: TestResult
  args: []
  method: errors.__eq__
  method_args: [[]]
  expected: true

invariant unittest.result_failures_empty:
  description: "unittest.TestResult().failures == [] — no failures in a fresh result"
  category: result_state
  kind: python_call_eq
  function: TestResult
  args: []
  method: failures.__eq__
  method_args: [[]]
  expected: true

# ---------------------------------------------------------------------------
# SkipTest exception hierarchy — inherits from Exception
# ---------------------------------------------------------------------------

invariant unittest.skiptest_base_is_exception:
  description: "unittest.SkipTest.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: SkipTest.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true
