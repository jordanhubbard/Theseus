spec: lodash_isobject
version: ">=4.0.0"
backend: node(lodash.isobject)

docs: https://lodash.com/docs/#isObject

provenance:
  derived_from:
    - "lodash.isobject README — https://www.npmjs.com/package/lodash.isobject"
    - "Test vectors verified with lodash.isobject@3.0.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isobject exports the _.isObject function directly as module.exports."
    - "isObject checks if value is the language type of Object (not primitives)."
    - "Returns true for arrays, plain objects. Returns false for null, strings, numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isobject.isobject:
  kind: node_module_call_eq
  function: ~
  category: isobject
  id_prefix: liso

  columns: [id, args, expected]
  rows:
    - [plain_obj,  [{"a": 1}],    true]
    - [array,      [[1, 2, 3]],   true]
    - [null_val,   [null],        false]
    - [string,     ["hello"],     false]
    - [number,     [42],          false]
    - [boolean,    [true],        false]
