spec: inspect_extra1111
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks Parameter.empty class name and module, Parameter.POSITIONAL_ONLY/_KEYWORD_ONLY class names, FullArgSpec/ArgInfo/Attribute class identity (module, qualname, name, class), Signature/BoundArguments identity — not covered in _extra1081/_extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1111.parameter_empty_and_kind_identity:
  description: "inspect.Parameter.empty and ParameterKind sentinel class identity"
  kind: python_call_eq
  category: parameter_empty_kind_identity
  id_prefix: ip1111pe
  columns: [id, function, args, expected]
  rows:
    - [ip1111pe001, inspect.Parameter.empty.__class__.__name__.__eq__,            ["type"],                             true]
    - [ip1111pe002, inspect.Parameter.empty.__name__.__eq__,                      ["_empty"],                           true]
    - [ip1111pe003, inspect.Parameter.empty.__module__.__eq__,                    ["inspect"],                          true]
    - [ip1111pe004, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,  ["_ParameterKind"],                   true]
    - [ip1111pe005, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,     ["_ParameterKind"],                   true]
    - [ip1111pe006, inspect.Parameter.__module__.__eq__,                          ["inspect"],                          true]
    - [ip1111pe007, inspect.Parameter.__qualname__.__eq__,                        ["Parameter"],                        true]
    - [ip1111pe008, inspect.Parameter.__class__.__name__.__eq__,                  ["type"],                             true]

table inspect_extra1111.fullargspec_arginfo_attribute_identity:
  description: "inspect.FullArgSpec, ArgInfo, and Attribute namedtuple class identity"
  kind: python_call_eq
  category: fullargspec_arginfo_attribute_identity
  id_prefix: ip1111fa
  columns: [id, function, args, expected]
  rows:
    - [ip1111fa001, inspect.FullArgSpec.__name__.__eq__,                          ["FullArgSpec"],                      true]
    - [ip1111fa002, inspect.FullArgSpec.__qualname__.__eq__,                      ["FullArgSpec"],                      true]
    - [ip1111fa003, inspect.FullArgSpec.__module__.__eq__,                        ["inspect"],                          true]
    - [ip1111fa004, inspect.FullArgSpec.__class__.__name__.__eq__,                ["type"],                             true]
    - [ip1111fa005, inspect.ArgInfo.__name__.__eq__,                              ["ArgInfo"],                          true]
    - [ip1111fa006, inspect.ArgInfo.__qualname__.__eq__,                          ["ArgInfo"],                          true]
    - [ip1111fa007, inspect.ArgInfo.__module__.__eq__,                            ["inspect"],                          true]
    - [ip1111fa008, inspect.ArgInfo.__class__.__name__.__eq__,                    ["type"],                             true]

table inspect_extra1111.signature_boundarguments_and_attribute_identity:
  description: "inspect.Attribute, Signature, BoundArguments class identity not covered in _extra1081/_extra1096"
  kind: python_call_eq
  category: signature_boundarguments_attribute_identity
  id_prefix: ip1111sb
  columns: [id, function, args, expected]
  rows:
    - [ip1111sb001, inspect.Attribute.__name__.__eq__,                            ["Attribute"],                        true]
    - [ip1111sb002, inspect.Attribute.__qualname__.__eq__,                        ["Attribute"],                        true]
    - [ip1111sb003, inspect.Attribute.__module__.__eq__,                          ["inspect"],                          true]
    - [ip1111sb004, inspect.Attribute.__class__.__name__.__eq__,                  ["type"],                             true]
    - [ip1111sb005, inspect.Signature.__name__.__eq__,                            ["Signature"],                        true]
    - [ip1111sb006, inspect.Signature.__qualname__.__eq__,                        ["Signature"],                        true]
    - [ip1111sb007, inspect.BoundArguments.__name__.__eq__,                       ["BoundArguments"],                   true]
    - [ip1111sb008, inspect.BoundArguments.__module__.__eq__,                     ["inspect"],                          true]
