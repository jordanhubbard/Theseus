spec: asyncio_events
version: ">=3.10"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-eventloop.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "asyncio source: internal event loop scheduling and I/O implementation"
  notes:
    - "AbstractEventLoop is the ABC that all event loop implementations must satisfy."
    - "BaseEventLoop is the concrete base class for the default selector-based loop."
    - "DefaultEventLoopPolicy is the policy used when no policy has been set explicitly."
    - "AbstractEventLoopPolicy is the ABC for event loop policies."
    - "Handle and TimerHandle are used to represent scheduled callbacks."
    - "BaseProtocol is the root ABC for asyncio protocol classes."
    - "Protocol extends BaseProtocol with data_received / eof_received callbacks."
    - "DatagramProtocol extends BaseProtocol for UDP-style transports."
    - "new_event_loop() creates a fresh, independent event loop without setting it as current."
    - "get_event_loop_policy() / set_event_loop_policy() manage the global policy object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata — event loop classes not covered in asyncio.zspec.zsdl
# ---------------------------------------------------------------------------

table asyncio_events.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [abstract_event_loop,        AbstractEventLoop.__name__.__eq__,        ["AbstractEventLoop"],        true]
    - [abstract_event_loop_policy, AbstractEventLoopPolicy.__name__.__eq__,  ["AbstractEventLoopPolicy"],  true]
    - [base_event_loop,            BaseEventLoop.__name__.__eq__,            ["BaseEventLoop"],            true]
    - [default_event_loop_policy,  DefaultEventLoopPolicy.__name__.__eq__,   ["DefaultEventLoopPolicy"],   true]
    - [handle,                     Handle.__name__.__eq__,                   ["Handle"],                   true]
    - [timer_handle,               TimerHandle.__name__.__eq__,              ["TimerHandle"],              true]
    - [base_protocol,              BaseProtocol.__name__.__eq__,             ["BaseProtocol"],             true]
    - [protocol,                   Protocol.__name__.__eq__,                 ["Protocol"],                 true]
    - [datagram_protocol,          DatagramProtocol.__name__.__eq__,         ["DatagramProtocol"],         true]

# ---------------------------------------------------------------------------
# Module checks — classes must live in the asyncio package
# ---------------------------------------------------------------------------

table asyncio_events.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [handle,        Handle.__module__.__eq__,        ["asyncio.events"],  true]
    - [timer_handle,  TimerHandle.__module__.__eq__,   ["asyncio.events"],  true]
    - [base_protocol, BaseProtocol.__module__.__eq__,  ["asyncio.protocols"], true]

# ---------------------------------------------------------------------------
# Base class checks — inheritance hierarchy
# ---------------------------------------------------------------------------

invariant asyncio_events.timer_handle_base:
  description: "TimerHandle.__bases__[0].__name__ == 'Handle'"
  category: bases
  kind: python_call_eq
  function: TimerHandle.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Handle"

invariant asyncio_events.protocol_base:
  description: "Protocol.__bases__[0].__name__ == 'BaseProtocol'"
  category: bases
  kind: python_call_eq
  function: Protocol.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BaseProtocol"

# ---------------------------------------------------------------------------
# Policy functions — name metadata
# ---------------------------------------------------------------------------

table asyncio_events.policy_function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: pfname

  columns: [id, function, args, expected]
  rows:
    - [get_event_loop_policy, get_event_loop_policy.__name__.__eq__, ["get_event_loop_policy"], true]
    - [set_event_loop_policy, set_event_loop_policy.__name__.__eq__, ["set_event_loop_policy"], true]
    - [new_event_loop,        new_event_loop.__name__.__eq__,        ["new_event_loop"],        true]

