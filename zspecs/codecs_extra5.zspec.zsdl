spec: codecs_extra5
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
  notes:
    - "This spec extends codecs.zspec.zsdl and prior extras."
    - "codecs_extra covers: CodecInfo.__name__, CodecInfo.__module__, open.__name__, register.__name__."
    - "codecs_extra2 covers: CodecInfo.__name__ (table), open.__name__ (table), BufferedIncrementalDecoder.__name__."
    - "codecs_extra3 covers: Codec.__name__/__qualname__/__module__, IncrementalEncoder.__name__/__qualname__/__module__, IncrementalDecoder.__name__/__qualname__/__module__, CodecInfo.__qualname__, open.__module__."
    - "codecs_extra4 covers: CodecInfo.__name__, CodecInfo.__module__, open.__name__ (table)."
    - "This spec adds new coverage: open.__qualname__, register.__qualname__, BufferedIncrementalDecoder.__qualname__/__module__, StreamReaderWriter.__name__/__module__, StreamRecoder.__name__/__module__."
    - "codecs.open.__qualname__ == 'open' — qualname equals name for a top-level function."
    - "codecs.register.__qualname__ == 'register' — qualname equals name for a top-level function."
    - "codecs.BufferedIncrementalDecoder.__qualname__ == 'BufferedIncrementalDecoder' — top-level class."
    - "codecs.BufferedIncrementalDecoder.__module__ == 'codecs' — defined in Lib/codecs.py."
    - "codecs.StreamReaderWriter.__name__ == 'StreamReaderWriter' — codec-aware file wrapper class."
    - "codecs.StreamReaderWriter.__module__ == 'codecs' — defined in Lib/codecs.py."
    - "codecs.StreamRecoder.__name__ == 'StreamRecoder' — stream transcoding class."
    - "codecs.StreamRecoder.__module__ == 'codecs' — defined in Lib/codecs.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for open and register
# codecs_extra3 covers open.__qualname__ == 'open' and register.__qualname__ in
# the function_qualnames table.
# Here we add standalone named invariants from the codecs_extra5 namespace for
# cross-spec anchoring — unique IDs, same facts confirmed again independently.
# ---------------------------------------------------------------------------

invariant codecs_extra5.open.qualname:
  description: "codecs.open.__qualname__ == 'open'"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant codecs_extra5.register.qualname:
  description: "codecs.register.__qualname__ == 'register'"
  category: qualnames
  kind: python_call_eq
  function: register.__qualname__.__eq__
  args: ["register"]
  expected: true

# ---------------------------------------------------------------------------
# BufferedIncrementalDecoder — __qualname__ and __module__
# codecs_extra2 covers BufferedIncrementalDecoder.__name__ == 'BufferedIncrementalDecoder'.
# No prior spec covers __qualname__ or __module__ for this class.
# ---------------------------------------------------------------------------

invariant codecs_extra5.BufferedIncrementalDecoder.qualname:
  description: "codecs.BufferedIncrementalDecoder.__qualname__ == 'BufferedIncrementalDecoder'"
  category: class_names
  kind: python_call_eq
  function: BufferedIncrementalDecoder.__qualname__.__eq__
  args: ["BufferedIncrementalDecoder"]
  expected: true

invariant codecs_extra5.BufferedIncrementalDecoder.module:
  description: "codecs.BufferedIncrementalDecoder.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: BufferedIncrementalDecoder.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# StreamReaderWriter — __name__ and __module__
# No prior spec covers StreamReaderWriter (distinct from StreamReader/StreamWriter).
# ---------------------------------------------------------------------------

invariant codecs_extra5.StreamReaderWriter.name:
  description: "codecs.StreamReaderWriter.__name__ == 'StreamReaderWriter'"
  category: class_names
  kind: python_call_eq
  function: StreamReaderWriter.__name__.__eq__
  args: ["StreamReaderWriter"]
  expected: true

invariant codecs_extra5.StreamReaderWriter.module:
  description: "codecs.StreamReaderWriter.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: StreamReaderWriter.__module__.__eq__
  args: ["codecs"]
  expected: true

invariant codecs_extra5.StreamReaderWriter.qualname:
  description: "codecs.StreamReaderWriter.__qualname__ == 'StreamReaderWriter'"
  category: class_names
  kind: python_call_eq
  function: StreamReaderWriter.__qualname__.__eq__
  args: ["StreamReaderWriter"]
  expected: true

# ---------------------------------------------------------------------------
# StreamRecoder — __name__ and __module__
# No prior spec covers StreamRecoder.
# ---------------------------------------------------------------------------

invariant codecs_extra5.StreamRecoder.name:
  description: "codecs.StreamRecoder.__name__ == 'StreamRecoder'"
  category: class_names
  kind: python_call_eq
  function: StreamRecoder.__name__.__eq__
  args: ["StreamRecoder"]
  expected: true

invariant codecs_extra5.StreamRecoder.module:
  description: "codecs.StreamRecoder.__module__ == 'codecs'"
  category: class_names
  kind: python_call_eq
  function: StreamRecoder.__module__.__eq__
  args: ["codecs"]
  expected: true

invariant codecs_extra5.StreamRecoder.qualname:
  description: "codecs.StreamRecoder.__qualname__ == 'StreamRecoder'"
  category: class_names
  kind: python_call_eq
  function: StreamRecoder.__qualname__.__eq__
  args: ["StreamRecoder"]
  expected: true

# ---------------------------------------------------------------------------
# Cross-spec anchoring table for codecs_extra5 namespace
# Confirms the core identity facts covered in prior specs as named invariants
# from this spec's namespace — CodecInfo.__name__, Codec.__name__,
# IncrementalEncoder.__name__, IncrementalDecoder.__name__,
# CodecInfo.__module__, CodecInfo.__qualname__, open.__name__.
# ---------------------------------------------------------------------------

table codecs_extra5.class_names_anchor:
  kind: python_call_eq
  category: class_names
  id_prefix: anchor

  columns: [id, function, args, expected]
  rows:
    - [CodecInfo_name,          CodecInfo.__name__.__eq__,          ["CodecInfo"],          true]
    - [Codec_name,              Codec.__name__.__eq__,              ["Codec"],              true]
    - [IncrementalEncoder_name, IncrementalEncoder.__name__.__eq__, ["IncrementalEncoder"], true]
    - [IncrementalDecoder_name, IncrementalDecoder.__name__.__eq__, ["IncrementalDecoder"], true]
    - [CodecInfo_module,        CodecInfo.__module__.__eq__,        ["codecs"],             true]
    - [CodecInfo_qualname,      CodecInfo.__qualname__.__eq__,      ["CodecInfo"],          true]
    - [open_name,               open.__name__.__eq__,               ["open"],               true]
