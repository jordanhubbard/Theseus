spec: decimal_extra78
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra77."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for various dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context.__init__/__class__.__name__; Context arithmetic method __class__.__name__; Context/__dict__/__class__/__name__ and membership; Context.__bases__[0].__name__; Context.__mro__.__len__(); Decimal arithmetic/string/conversion dunder __qualname__ values and lengths; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__ lengths."
    - "This spec covers: Decimal.__dict__.__contains__('__add__'); Decimal.__dict__.__contains__('__sub__'); Decimal.__dict__.__contains__('__mul__'); Decimal.__dict__.__contains__('__truediv__'); Decimal.__dict__.__contains__('__floordiv__'); Decimal.__dict__.__contains__('__mod__'); Decimal.__dict__.__contains__('__pow__'); Decimal.__dict__.__contains__('__eq__'); Decimal.__dict__.__contains__('__lt__'); Decimal.__dict__.__contains__('__le__'); Decimal.__dict__.__contains__('sqrt'); Decimal.__dict__.__contains__('normalize'); Decimal.__dict__.__contains__('quantize'); Decimal.__dict__.__class__.__name__; Decimal.__name__; Decimal.__module__."
    - "Decimal.__dict__.__contains__('__add__') == True — arithmetic operators are in the C type's __dict__."
    - "Decimal.__dict__.__contains__('sqrt') == True — math methods are present in __dict__."
    - "Decimal.__dict__.__class__.__name__ == 'mappingproxy' — the C type's __dict__ is always a mappingproxy."
    - "Decimal.__name__ == 'Decimal' — the C type's __name__ is 'Decimal'."
    - "Decimal.__module__ == 'decimal' — the C accelerator module re-exports as 'decimal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership: arithmetic operators __add__, __sub__, __mul__, __truediv__
# All four are present as wrapper_descriptors in Decimal.__dict__.
# Not covered in any prior decimal spec at this specific combination.
# ---------------------------------------------------------------------------

table decimal_extra78.Decimal_dict_arith_ops:
  description: "Decimal.__dict__.__contains__ for __add__, __sub__, __mul__, __truediv__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalextra78

  columns: [id, function, args, expected]
  rows:
    - [dict_add,     Decimal.__dict__.__contains__, ["__add__"],     true]
    - [dict_sub,     Decimal.__dict__.__contains__, ["__sub__"],     true]
    - [dict_mul,     Decimal.__dict__.__contains__, ["__mul__"],     true]
    - [dict_truediv, Decimal.__dict__.__contains__, ["__truediv__"], true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership: __floordiv__, __mod__, __pow__
# Also present as wrapper_descriptors in Decimal.__dict__.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra78.Decimal_dict_floordiv_mod_pow:
  description: "Decimal.__dict__.__contains__ for __floordiv__, __mod__, __pow__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalextra78

  columns: [id, function, args, expected]
  rows:
    - [dict_floordiv, Decimal.__dict__.__contains__, ["__floordiv__"], true]
    - [dict_mod,      Decimal.__dict__.__contains__, ["__mod__"],      true]
    - [dict_pow,      Decimal.__dict__.__contains__, ["__pow__"],      true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership: comparison operators __eq__, __lt__, __le__
# Also present in Decimal.__dict__. Verifies comparison slot population.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra78.Decimal_dict_cmp_ops:
  description: "Decimal.__dict__.__contains__ for __eq__, __lt__, __le__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalextra78

  columns: [id, function, args, expected]
  rows:
    - [dict_eq, Decimal.__dict__.__contains__, ["__eq__"], true]
    - [dict_lt, Decimal.__dict__.__contains__, ["__lt__"], true]
    - [dict_le, Decimal.__dict__.__contains__, ["__le__"], true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership for math methods; __dict__.__class__.__name__; identity
# sqrt/normalize/quantize are present in __dict__.
# __dict__.__class__.__name__ == 'mappingproxy'.
# Decimal.__name__ == 'Decimal'; Decimal.__module__ == 'decimal'.
# Not covered in any prior decimal spec at this combination.
# ---------------------------------------------------------------------------

table decimal_extra78.Decimal_dict_math_and_identity:
  description: "Decimal.__dict__.__contains__ for sqrt/normalize/quantize; __dict__ class; __name__; __module__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalextra78

  columns: [id, function, args, expected]
  rows:
    - [dict_sqrt,      Decimal.__dict__.__contains__,           ["sqrt"],        true]
    - [dict_normalize, Decimal.__dict__.__contains__,           ["normalize"],   true]
    - [dict_quantize,  Decimal.__dict__.__contains__,           ["quantize"],    true]
    - [dict_cls_name,  Decimal.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [dec_name,       Decimal.__name__.__eq__,                 ["Decimal"],     true]
    - [dec_module,     Decimal.__module__.__eq__,               ["decimal"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra78.Decimal_dict.contains_add:
  description: "decimal.Decimal.__dict__.__contains__('__add__') == True (arithmetic operator present in C type __dict__)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["__add__"]
  expected: true

invariant decimal_extra78.Decimal_dict.contains_sqrt:
  description: "decimal.Decimal.__dict__.__contains__('sqrt') == True (math method present in __dict__)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["sqrt"]
  expected: true

invariant decimal_extra78.Decimal_dict.class_name:
  description: "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' (C type __dict__ is always a mappingproxy)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant decimal_extra78.Decimal.name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra78.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal' (C accelerator re-exports under 'decimal')"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true
