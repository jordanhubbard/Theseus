spec: decimal_extra1696
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal.zspec.zsdl — covers core decimal type attributes and arithmetic interface"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "decimal.Decimal defines __reduce__, __copy__, and __deepcopy__ in its __dict__ — it is a C extension type with full custom pickling and copying support."
    - "decimal.Decimal does NOT define __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__ in its own __dict__."
    - "decimal.Context defines __reduce__ and __copy__ in its __dict__ — but NOT __deepcopy__, __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__."
    - "decimal.DecimalException and all signal subclasses (InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, Clamped, FloatOperation) define none of the pickling or copy protocol methods in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol
#
# Records whether each decimal type defines the five pickling dunder methods
# directly in its own __dict__.
#
# decimal.Decimal: __reduce__ → True; __getstate__, __setstate__,
#   __getnewargs__, __getnewargs_ex__ → False.
# decimal.Context: __reduce__ → True; rest → False.
# All exception/signal subclasses: all five → False.
# ---------------------------------------------------------------------------

table decimal_extra1696.pickling_protocol:
  description: "decimal types pickling protocol dict-presence checks"
  kind: python_call_eq
  category: pickling_protocol
  id_prefix: dc1696

  columns: [id, function, args, expected]
  rows:
    - ["dc1696001", "decimal.Decimal.__dict__.__contains__",          ["__reduce__"],        true]
    - ["dc1696002", "decimal.Decimal.__dict__.__contains__",          ["__getstate__"],      false]
    - ["dc1696003", "decimal.Decimal.__dict__.__contains__",          ["__setstate__"],      false]
    - ["dc1696004", "decimal.Decimal.__dict__.__contains__",          ["__getnewargs__"],    false]
    - ["dc1696005", "decimal.Decimal.__dict__.__contains__",          ["__getnewargs_ex__"], false]
    - ["dc1696006", "decimal.Context.__dict__.__contains__",          ["__reduce__"],        true]
    - ["dc1696007", "decimal.Context.__dict__.__contains__",          ["__getstate__"],      false]
    - ["dc1696008", "decimal.Context.__dict__.__contains__",          ["__setstate__"],      false]
    - ["dc1696009", "decimal.Context.__dict__.__contains__",          ["__getnewargs__"],    false]
    - ["dc1696010", "decimal.Context.__dict__.__contains__",          ["__getnewargs_ex__"], false]
    - ["dc1696011", "decimal.DecimalException.__dict__.__contains__", ["__reduce__"],        false]
    - ["dc1696012", "decimal.DecimalException.__dict__.__contains__", ["__getstate__"],      false]
    - ["dc1696013", "decimal.DecimalException.__dict__.__contains__", ["__setstate__"],      false]
    - ["dc1696014", "decimal.InvalidOperation.__dict__.__contains__", ["__reduce__"],        false]
    - ["dc1696015", "decimal.DivisionByZero.__dict__.__contains__",   ["__reduce__"],        false]
    - ["dc1696016", "decimal.Overflow.__dict__.__contains__",         ["__reduce__"],        false]
    - ["dc1696017", "decimal.Underflow.__dict__.__contains__",        ["__reduce__"],        false]
    - ["dc1696018", "decimal.Inexact.__dict__.__contains__",          ["__reduce__"],        false]
    - ["dc1696019", "decimal.Rounded.__dict__.__contains__",          ["__reduce__"],        false]
    - ["dc1696020", "decimal.Subnormal.__dict__.__contains__",        ["__reduce__"],        false]
    - ["dc1696021", "decimal.Clamped.__dict__.__contains__",          ["__reduce__"],        false]
    - ["dc1696022", "decimal.FloatOperation.__dict__.__contains__",   ["__reduce__"],        false]

# ---------------------------------------------------------------------------
# Table 2: copy_protocol
#
# Checks __copy__ and __deepcopy__ dict-presence.
#
# decimal.Decimal: both → True.
# decimal.Context: __copy__ → True; __deepcopy__ → False.
# All exception/signal subclasses: both → False.
# ---------------------------------------------------------------------------

table decimal_extra1696.copy_protocol:
  description: "decimal types copy protocol (__copy__, __deepcopy__) dict-presence checks"
  kind: python_call_eq
  category: copy_protocol
  id_prefix: dc1696

  columns: [id, function, args, expected]
  rows:
    - ["dc1696030", "decimal.Decimal.__dict__.__contains__",          ["__copy__"],     true]
    - ["dc1696031", "decimal.Decimal.__dict__.__contains__",          ["__deepcopy__"], true]
    - ["dc1696032", "decimal.Context.__dict__.__contains__",          ["__copy__"],     true]
    - ["dc1696033", "decimal.Context.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["dc1696034", "decimal.DecimalException.__dict__.__contains__", ["__copy__"],     false]
    - ["dc1696035", "decimal.DecimalException.__dict__.__contains__", ["__deepcopy__"], false]
    - ["dc1696036", "decimal.InvalidOperation.__dict__.__contains__", ["__copy__"],     false]
    - ["dc1696037", "decimal.InvalidOperation.__dict__.__contains__", ["__deepcopy__"], false]
    - ["dc1696038", "decimal.DivisionByZero.__dict__.__contains__",   ["__copy__"],     false]
    - ["dc1696039", "decimal.DivisionByZero.__dict__.__contains__",   ["__deepcopy__"], false]
    - ["dc1696040", "decimal.Overflow.__dict__.__contains__",         ["__copy__"],     false]
    - ["dc1696041", "decimal.Overflow.__dict__.__contains__",         ["__deepcopy__"], false]
    - ["dc1696042", "decimal.Underflow.__dict__.__contains__",        ["__copy__"],     false]
    - ["dc1696043", "decimal.Underflow.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["dc1696044", "decimal.FloatOperation.__dict__.__contains__",   ["__copy__"],     false]
    - ["dc1696045", "decimal.FloatOperation.__dict__.__contains__",   ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: decimal_context_asymmetry
#
# Highlights the asymmetry between decimal.Decimal (has both __copy__ and
# __deepcopy__) and decimal.Context (has __copy__ only).  Also contrasts the
# two types on __reduce__ (both True) vs the exception hierarchy (all False).
# ---------------------------------------------------------------------------

table decimal_extra1696.decimal_context_asymmetry:
  description: "Decimal vs Context pickling+copy asymmetry, and exception hierarchy contrast"
  kind: python_call_eq
  category: decimal_context_asymmetry
  id_prefix: dc1696

  columns: [id, function, args, expected]
  rows:
    - ["dc1696050", "decimal.Decimal.__dict__.__contains__", ["__reduce__"],   true]
    - ["dc1696051", "decimal.Decimal.__dict__.__contains__", ["__copy__"],     true]
    - ["dc1696052", "decimal.Decimal.__dict__.__contains__", ["__deepcopy__"], true]
    - ["dc1696053", "decimal.Context.__dict__.__contains__", ["__reduce__"],   true]
    - ["dc1696054", "decimal.Context.__dict__.__contains__", ["__copy__"],     true]
    - ["dc1696055", "decimal.Context.__dict__.__contains__", ["__deepcopy__"], false]
    - ["dc1696056", "decimal.DecimalException.__dict__.__contains__", ["__reduce__"],   false]
    - ["dc1696057", "decimal.DecimalException.__dict__.__contains__", ["__copy__"],     false]
    - ["dc1696058", "decimal.DecimalException.__dict__.__contains__", ["__deepcopy__"], false]
    - ["dc1696059", "decimal.Decimal.__dict__.__contains__", ["__getstate__"],      false]
    - ["dc1696060", "decimal.Decimal.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["dc1696061", "decimal.Decimal.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["dc1696062", "decimal.Context.__dict__.__contains__", ["__getstate__"],      false]
    - ["dc1696063", "decimal.Context.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["dc1696064", "decimal.Context.__dict__.__contains__", ["__getnewargs_ex__"], false]
