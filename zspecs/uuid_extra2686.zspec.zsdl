spec: uuid_extra2686
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 626: checks uuid.UUID and uuid.SafeUUID __dict__ for __and__, __or__, __xor__ presence. uuid.UUID is a plain Python class; uuid.SafeUUID is an IntEnum subclass. All return False — neither defines __and__, __or__, nor __xor__ in its own __dict__. (IntFlag defines these, not IntEnum.)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table uuid_extra2686.UUID_dict_presence:
  description: "uuid.UUID __dict__ does not contain __and__, __or__, or __xor__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2686ud
  columns: [id, function, args, expected]
  rows:
    - ["uu2686ud001", uuid.UUID.__dict__.__contains__, ["__and__"], false]
    - ["uu2686ud002", uuid.UUID.__dict__.__contains__, ["__or__"],  false]
    - ["uu2686ud003", uuid.UUID.__dict__.__contains__, ["__xor__"], false]

