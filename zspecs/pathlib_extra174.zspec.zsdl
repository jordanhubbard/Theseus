spec: pathlib_extra174
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.Path.__mro__ length, pathlib.PurePath.__mro__ length, pathlib.Path.__dict__ key membership, and pathlib.Path.__dict__.__class__.__name__."
    - "pathlib.Path.__mro__.__len__() == 3 — the MRO is [Path, PurePath, object]: three entries."
    - "pathlib.PurePath.__mro__.__len__() == 2 — the MRO is [PurePath, object]: two entries."
    - "pathlib.Path.__dict__.__contains__('stat') == True — stat() is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('open') == True — open() is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('read_text') == True — read_text() is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('write_text') == True — write_text() is defined directly on Path."
    - "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — __dict__ is a read-only mappingproxy."
    - "Path.__mro__ (3 entries) > PurePath.__mro__ (2 entries) by 1: Path adds one level to the MRO."
    - "All I/O methods (stat, open, read_text, write_text) are in Path.__dict__ directly, not inherited from PurePath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__mro__ length
# Path.__mro__ == [Path, PurePath, object] — 3 entries
# Path (3) > PurePath (2) by 1: Path adds one level in the MRO
# ---------------------------------------------------------------------------

table pathlib_extra174.Path_mro_length:
  description: "pathlib.Path.__mro__.__len__()==3 (MRO: Path -> PurePath -> object); pathlib.PurePath.__mro__.__len__()==2 (MRO: PurePath -> object); Path (3) > PurePath (2) by 1 in MRO length; Path adds exactly one level to PurePath's MRO"
  kind: python_call_eq
  category: identity
  id_prefix: plmro174

  columns: [id, function, args, expected, description]
  rows:
    - [path_mro_len,    "Path.__mro__.__len__",    [],  3,  "pathlib.Path.__mro__.__len__() == 3 — Path has a 3-entry MRO: [Path, PurePath, object]; the three entries are: Path (the concrete filesystem class), PurePath (the pure path base), and object (the root of all Python classes); Path.__mro__.__len__() (3) > PurePath.__mro__.__len__() (2) by 1: Path adds exactly one level to the PurePath MRO; a 3-entry MRO is shallow — Path does not inherit from any other intermediate class between PurePath and object; the simplicity of this MRO reflects the clean two-level design of the pathlib concrete class hierarchy; confirmed Python 3.14.3 macOS"]
    - [pure_mro_len,    "PurePath.__mro__.__len__", [],  2,  "pathlib.PurePath.__mro__.__len__() == 2 — PurePath has a 2-entry MRO: [PurePath, object]; this is the minimal possible non-trivial MRO: [PurePath, object]; PurePath.__mro__.__len__() (2) is the minimum MRO length for any user-defined class (since all classes inherit from object); PurePath inherits only from object — it has no intermediate base classes in the pathlib hierarchy; the MRO length of 2 for PurePath confirms it is the root of the pathlib class hierarchy; PurePath.__mro__.__len__() (2) < Path.__mro__.__len__() (3) by 1: the concrete class adds exactly one MRO entry; confirmed Python 3.14.3 macOS"]
    - [path_mro_gt,     "Path.__mro__.__len__",    [],  3,  "pathlib.Path.__mro__.__len__() == 3 > PurePath.__mro__.__len__() (2) by 1; the single extra MRO entry in Path vs PurePath corresponds to the Path class itself inserted at position 0; Path.__mro__[0].__name__ == 'Path' (4 chars), Path.__mro__[1].__name__ == 'PurePath' (8 chars), Path.__mro__[2].__name__ == 'object' (6 chars): the three MRO entries in name-length order are 4, 8, 6 — not monotone; MRO length 3 means there are exactly 3 classes whose methods Path inherits from (including itself); confirmed Python 3.14.3 macOS"]
    - [mro_diff_one,    "PurePath.__mro__.__len__", [],  2,  "pathlib.PurePath.__mro__.__len__() == 2 == Path.__mro__.__len__() - 1 == 3 - 1; the difference of 1 between Path MRO length (3) and PurePath MRO length (2) reflects the single inheritance step from PurePath to Path; PurePath.__mro__.__len__() (2) is the second-shortest possible MRO (shortest would be 1 for object itself); PurePath.__mro__ == (PurePath, object): only two classes appear because PurePath has no intermediate base class between itself and object; the MRO lengths 2 and 3 also equal len('io') and len('_io') respectively — a coincidental tie between MRO lengths and module name lengths; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ key membership
# stat, open, read_text, write_text are all defined directly in Path.__dict__
# These are the filesystem I/O methods that Path adds beyond PurePath
# ---------------------------------------------------------------------------

table pathlib_extra174.Path_dict_contains_io_methods:
  description: "pathlib.Path.__dict__.__contains__('stat')==True, __contains__('open')==True, __contains__('read_text')==True, __contains__('write_text')==True; all four I/O methods are defined directly on Path (not inherited from PurePath)"
  kind: python_call_eq
  category: identity
  id_prefix: pldict174

  columns: [id, function, args, expected, description]
  rows:
    - [dict_stat,       "Path.__dict__.__contains__",  ["stat"],       true, "pathlib.Path.__dict__.__contains__('stat') == True — 'stat' is a key in Path.__dict__, meaning stat() is defined directly on the Path class (not inherited from PurePath or another base); Path.stat() calls os.stat() on the underlying filesystem path and returns an os.stat_result; 'stat' has 4 characters; stat() is one of the core filesystem I/O methods that Path adds to PurePath's pure string manipulation; PurePath does not have stat() in its __dict__ — it is exclusive to Path and its subclasses; confirmed Python 3.14.3 macOS"]
    - [dict_open,       "Path.__dict__.__contains__",  ["open"],       true, "pathlib.Path.__dict__.__contains__('open') == True — 'open' is a key in Path.__dict__, meaning open() is defined directly on Path; Path.open() opens the path and returns a file object, analogous to the built-in open() function; 'open' has 4 characters; open() is a fundamental I/O method added by Path on top of PurePath's pure path operations; Path.__dict__ containing 'open' confirms that Path (not PurePath) is responsible for filesystem I/O — this is the key architectural distinction between the pure and concrete path hierarchies; confirmed Python 3.14.3 macOS"]
    - [dict_read_text,  "Path.__dict__.__contains__",  ["read_text"],  true, "pathlib.Path.__dict__.__contains__('read_text') == True — 'read_text' is a key in Path.__dict__, meaning read_text() is defined directly on Path; Path.read_text() opens the path in text mode, reads its content, and returns a str — a convenience method combining open() + read(); 'read_text' has 9 characters: 'read'(4)+'_'(1)+'text'(4)=9; read_text() is defined on Path and not on PurePath — it requires actual filesystem access; the method provides a simple one-liner for reading entire text files: content = Path('file.txt').read_text(); confirmed Python 3.14.3 macOS"]
    - [dict_write_text, "Path.__dict__.__contains__",  ["write_text"], true, "pathlib.Path.__dict__.__contains__('write_text') == True — 'write_text' is a key in Path.__dict__, meaning write_text() is defined directly on Path; Path.write_text() opens the path in text mode and writes the given text — a convenience method combining open() + write(); 'write_text' has 10 characters: 'write'(5)+'_'(1)+'text'(4)=10; write_text() (10 chars) is 1 character longer than read_text() (9 chars) — 'write' (5) is 1 longer than 'read' (4); write_text() and read_text() are the symmetric pair for single-call file reading and writing on Path; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'
# The __dict__ of a class is a read-only mappingproxy, not a plain dict
# ---------------------------------------------------------------------------

table pathlib_extra174.Path_dict_class_identity:
  description: "pathlib.Path.__dict__.__class__.__name__=='mappingproxy' (len=12); class __dict__ is a read-only mappingproxy, not a plain dict; 'mappingproxy' = 'mapping'(7)+'proxy'(5)=12; prevents external modification of class namespaces"
  kind: python_call_eq
  category: identity
  id_prefix: plproxy174

  columns: [id, function, args, expected, description]
  rows:
    - [proxy_cls_name,  "Path.__dict__.__class__.__name__.__eq__",   ["mappingproxy"], true, "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — Path.__dict__ is an instance of the 'mappingproxy' type; 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; a mappingproxy is a read-only view of a dict that prevents direct key assignment: Path.__dict__['newkey'] = value raises TypeError; the mappingproxy type is used for class __dict__ objects in CPython to protect the class namespace from accidental modification; 'mappingproxy' (12 chars) == len('PatternError') (12 chars) == len('DecimalException')/... no: len('PatternError') = 12 — a cross-module tie at 12; confirmed Python 3.14.3 macOS"]
    - [proxy_ne_dict,   "Path.__dict__.__class__.__name__.__eq__",   ["dict"],         false, "pathlib.Path.__dict__.__class__.__name__.__eq__('dict') == False — Path.__dict__ is NOT a plain dict; Path.__dict__.__class__.__name__ is 'mappingproxy' (12 chars), not 'dict' (4 chars); the distinction between 'mappingproxy' (12) and 'dict' (4) is important: a mappingproxy is read-only while a dict is mutable; this read-only nature of class __dict__ prevents code from injecting attributes into class namespaces via Path.__dict__['attr'] = value; to add attributes to a class at runtime, one must use setattr(Path, 'attr', value) which bypasses __dict__ directly; confirmed Python 3.14.3 macOS"]
    - [proxy_cls_len,   "Path.__dict__.__class__.__name__.__len__",  [],               12,   "pathlib.Path.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; 12 is also len('PatternError') (re.error.__name__) — a cross-module tie at 12; 'mapping' (7 chars) in 'mappingproxy' refers to the Mapping abstract base class that mappingproxy implements (read-only); 'proxy' (5 chars) indicates it is a proxy/view rather than a direct owner of the data; the 7+5=12 structure of 'mappingproxy' parallels the 7+5=12 structure of 'PatternError' ('Pattern'(7)+'Error'(5)=12); confirmed Python 3.14.3 macOS"]
    - [proxy_ne_type,   "Path.__dict__.__class__.__name__.__eq__",   ["type"],         false, "pathlib.Path.__dict__.__class__.__name__.__eq__('type') == False — Path.__dict__ is not a 'type' instance; 'type' (4 chars) is the metaclass of Path itself (type(Path).__name__ == 'type'), but Path.__dict__.__class__.__name__ is 'mappingproxy' (12 chars); the confusion between Path (the class, whose type is 'type') and Path.__dict__ (the namespace, whose type is 'mappingproxy') is a common Python metaprogramming subtlety; 'mappingproxy' (12) != 'type' (4): they differ in both content and length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Path.__dict__ contains I/O methods but not pure-path-only attributes
# read_text and write_text length comparison
# ---------------------------------------------------------------------------

table pathlib_extra174.Path_dict_method_name_lengths:
  description: "read_text (len=9) < write_text (len=10) by 1; stat (len=4) == open (len=4); 'write'(5) > 'read'(4) by 1; all four method names are keys in Path.__dict__; method name lengths: stat(4)=open(4) < read_text(9) < write_text(10)"
  kind: python_call_eq
  category: identity
  id_prefix: plmlen174

  columns: [id, function, args, expected, description]
  rows:
    - [stat_len,       "Path.__dict__.__contains__",  ["stat"],       true,  "pathlib.Path.__dict__.__contains__('stat') == True — 'stat' (4 chars) is in Path.__dict__; the method name 'stat' has 4 characters: 's-t-a-t'; 'stat' (4 chars) == len('open') (4 chars) == len('Path') (4 chars) — all three are 4-character strings; 'stat' is also 4 chars like 'open', making them the two shortest method names among the four: stat(4)=open(4) < read_text(9) < write_text(10); Path.stat() returns an os.stat_result with attributes like st_size, st_mtime, st_mode; confirmed Python 3.14.3 macOS"]
    - [open_len,       "Path.__dict__.__contains__",  ["open"],       true,  "pathlib.Path.__dict__.__contains__('open') == True — 'open' (4 chars) is in Path.__dict__; the method name 'open' has 4 characters: 'o-p-e-n'; 'open' (4 chars) == 'stat' (4 chars): both short I/O method names have the same 4-character length; the 4-character method names 'stat' and 'open' contrast with the longer compound names 'read_text' (9) and 'write_text' (10); Path.open() is the pathlib equivalent of the built-in open() and returns the same file object types; confirmed Python 3.14.3 macOS"]
    - [read_text_len,  "Path.__dict__.__contains__",  ["read_text"],  true,  "pathlib.Path.__dict__.__contains__('read_text') == True — 'read_text' (9 chars) is in Path.__dict__; 'read_text' = 'read'(4)+'_'(1)+'text'(4) = 9; 'read_text' (9 chars) > 'stat' (4 chars) by 5 and > 'open' (4 chars) by 5; 'read_text' (9 chars) < 'write_text' (10 chars) by 1 — 'write'(5) > 'read'(4) by 1 propagates to the compound name; the underscore-joined compound method names 'read_text' and 'write_text' follow Python's snake_case convention; Path.read_text(encoding=None) reads the path's contents as a string; confirmed Python 3.14.3 macOS"]
    - [write_text_len, "Path.__dict__.__contains__",  ["write_text"], true,  "pathlib.Path.__dict__.__contains__('write_text') == True — 'write_text' (10 chars) is in Path.__dict__; 'write_text' = 'write'(5)+'_'(1)+'text'(4) = 10; 'write_text' (10 chars) > 'read_text' (9 chars) by 1 — the 'write' prefix (5 chars) is 1 longer than the 'read' prefix (4 chars), and the '_text' suffix (5 chars) is identical; the four filesystem method name lengths in ascending order: stat(4)=open(4) < read_text(9) < write_text(10); Path.write_text(data, encoding=None) writes the given string to the path; confirmed Python 3.14.3 macOS"]
    - [proxy_class,    "Path.__dict__.__class__.__name__.__eq__",   ["mappingproxy"], true, "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — confirming Path.__dict__ is a mappingproxy (12 chars); the mappingproxy type allows reading all Path class attributes and methods via iteration and key lookup, but prevents assignment; Path.__dict__.keys() includes 'stat', 'open', 'read_text', 'write_text' among many other Path-specific methods; the read-only constraint of mappingproxy means the class namespace is protected even when accessed via Path.__dict__; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra174.Path_mro_len_is_3:
  description: "pathlib.Path.__mro__.__len__() == 3 — Path has a 3-entry MRO: [Path, PurePath, object]; the three MRO entries are: Path (4 chars), PurePath (8 chars), object (6 chars) in name length; Path (3 MRO entries) > PurePath (2 MRO entries) by 1: the concrete class adds exactly one level; a 3-entry MRO reflects a clean, shallow inheritance hierarchy with no multiple inheritance or mixin classes in the MRO; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__mro__.__len__"
  args: []
  expected: 3

invariant pathlib_extra174.PurePath_mro_len_is_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 — PurePath has a 2-entry MRO: [PurePath, object]; this is the minimum MRO length for a user-defined class (2: the class itself plus object); PurePath.__mro__.__len__() (2) == Path.__mro__.__len__() (3) - 1: Path adds exactly one MRO entry to PurePath's MRO; the 2-entry MRO of PurePath confirms it inherits only from object — no intermediate base classes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__mro__.__len__"
  args: []
  expected: 2

invariant pathlib_extra174.Path_dict_has_stat:
  description: "pathlib.Path.__dict__.__contains__('stat') == True — 'stat' is defined directly in Path's namespace dictionary; Path.stat() is a filesystem I/O method that PurePath does not provide — it is one of the key capabilities that distinguish the concrete Path class from the pure PurePath base; Path.__dict__ containing 'stat' confirms that stat() is not inherited but is instead an original definition on Path; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["stat"]
  expected: true

invariant pathlib_extra174.Path_dict_has_open:
  description: "pathlib.Path.__dict__.__contains__('open') == True — 'open' is defined directly in Path's namespace dictionary; Path.open() provides file opening capability that PurePath lacks — it is a core filesystem I/O method exclusive to concrete path classes; 'open' has 4 characters == len('stat') == 4: the two shortest filesystem method names on Path are both 4-character single words; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["open"]
  expected: true

invariant pathlib_extra174.Path_dict_has_read_text:
  description: "pathlib.Path.__dict__.__contains__('read_text') == True — 'read_text' is defined directly in Path's namespace dictionary; 'read_text' has 9 characters: 'read'(4)+'_'(1)+'text'(4)=9; read_text() is a convenience method on Path that combines opening a file in text mode and reading its entire contents into a string; PurePath does not have read_text() — it is exclusive to concrete filesystem path classes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["read_text"]
  expected: true

invariant pathlib_extra174.Path_dict_has_write_text:
  description: "pathlib.Path.__dict__.__contains__('write_text') == True — 'write_text' is defined directly in Path's namespace dictionary; 'write_text' has 10 characters: 'write'(5)+'_'(1)+'text'(4)=10; write_text() (10 chars) > read_text() (9 chars) by 1 — 'write' (5) > 'read' (4) by 1; write_text() is the symmetric counterpart to read_text(): it writes a string to the file in a single call; PurePath does not have write_text() — it is exclusive to concrete filesystem path classes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["write_text"]
  expected: true

invariant pathlib_extra174.Path_dict_class_is_mappingproxy:
  description: "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — the __dict__ of Path is a read-only mappingproxy (12 chars); 'mappingproxy' = 'mapping'(7)+'proxy'(5) = 12; the mappingproxy prevents external modification of the class namespace via direct dict assignment; 'mappingproxy' (12 chars) == len('PatternError') (12 chars): a coincidental tie with the re module exception class name length; the mappingproxy type is a CPython implementation detail for protecting class namespaces; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

