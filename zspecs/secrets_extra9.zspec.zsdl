spec: secrets_extra9
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra8.zspec.zsdl — covers secrets.__name__; randbits.__name__/__module__; choice.__module__; token_bytes n=25/50; token_hex n=25/50; token_bytes/token_hex n=16; choice(['z'])."
    - "secrets_extra7.zspec.zsdl — covers token_bytes n=5/10/20; token_hex n=5/10/20; token_urlsafe n=4/15/20; randbits(0)==0; randbelow(1)==0; choice(['x'])."
    - "secrets_extra6.zspec.zsdl — covers token_bytes n=2/3; token_hex n=2/3; token_urlsafe n=6/8/12; DEFAULT_ENTROPY*8==256; choice([7])/choice([0])."
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table; DEFAULT_ENTROPY==32; token_urlsafe len 24/32; token_bytes len 4/8/64; token_hex len 4/32."
    - "secrets_extra3.zspec.zsdl — covers function __module__ invariants; DEFAULT_ENTROPY class and >=16."
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__; token_bytes len32; token_hex len 2*n."
    - "secrets_extra.zspec.zsdl — covers function __name__/__module__; return type class checks."
  notes:
    - "This spec extends the secrets chain; it does NOT duplicate invariants present in any prior spec."
    - "Focus: __name__ attributes for token_bytes/token_hex/token_urlsafe/choice/randbelow (extra9 namespace); __module__ table; return type class checks for token_bytes/token_hex/token_urlsafe."
    - "secrets.token_bytes.__name__ == 'token_bytes': defined in the secrets module. Verified Python 3.12."
    - "secrets.token_hex.__name__ == 'token_hex': defined in the secrets module. Verified Python 3.12."
    - "secrets.token_urlsafe.__name__ == 'token_urlsafe': defined in the secrets module. Verified Python 3.12."
    - "secrets.choice.__name__ == 'choice': bound method of SystemRandom instance; exposes 'choice' as __name__. Verified Python 3.12."
    - "secrets.randbelow.__name__ == 'randbelow': defined in the secrets module. Verified Python 3.12."
    - "secrets.token_bytes.__module__ == 'secrets': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.token_hex.__module__ == 'secrets': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.token_urlsafe.__module__ == 'secrets': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.choice.__module__ == 'random': bound to SystemRandom instance method from Lib/random.py. Verified Python 3.12."
    - "secrets.randbelow.__module__ == 'secrets': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.token_bytes(16).__class__.__name__ == 'bytes': token_bytes always returns raw bytes. Verified Python 3.12."
    - "secrets.token_hex(8).__class__.__name__ == 'str': token_hex always returns a hex string. Verified Python 3.12."
    - "secrets.token_urlsafe(8).__class__.__name__ == 'str': token_urlsafe always returns a URL-safe string. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes — token_bytes, token_hex, token_urlsafe, choice, randbelow
#
# secrets_extra covers __name__ for these functions from the extra namespace.
# secrets_extra2 covers a __name__ table from the extra2 namespace.
# These invariants anchor from the extra9 namespace with distinct IDs.
# ---------------------------------------------------------------------------

table secrets_extra9.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname9

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__name__.__eq__,   ["token_bytes"],   true]
    - [token_hex,     token_hex.__name__.__eq__,     ["token_hex"],     true]
    - [token_urlsafe, token_urlsafe.__name__.__eq__, ["token_urlsafe"], true]
    - [choice,        choice.__name__.__eq__,        ["choice"],        true]
    - [randbelow,     randbelow.__name__.__eq__,     ["randbelow"],     true]

# ---------------------------------------------------------------------------
# __module__ attributes — token_bytes, token_hex, token_urlsafe, choice, randbelow
#
# secrets_extra3 covers __module__ for these functions from the extra3 namespace.
# Note: secrets.choice.__module__ == 'random' because choice is a bound method
# of a random.SystemRandom instance (defined in Lib/random.py).
# All others are defined directly in Lib/secrets.py (__module__ == 'secrets').
# These invariants anchor from the extra9 namespace with distinct IDs.
# ---------------------------------------------------------------------------

table secrets_extra9.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod9

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__module__.__eq__,   ["secrets"], true]
    - [token_hex,     token_hex.__module__.__eq__,     ["secrets"], true]
    - [token_urlsafe, token_urlsafe.__module__.__eq__, ["secrets"], true]
    - [choice,        choice.__module__.__eq__,        ["random"],  true]
    - [randbelow,     randbelow.__module__.__eq__,     ["secrets"], true]

# ---------------------------------------------------------------------------
# Return type class checks — token_bytes(16), token_hex(8), token_urlsafe(8)
#
# secrets_extra covers return type checks from the extra namespace.
# These invariants anchor the same checks from the extra9 namespace using
# n=16 for token_bytes and n=8 for token_hex/token_urlsafe (distinct fixtures).
# ---------------------------------------------------------------------------

invariant secrets_extra9.token_bytes.class_name:
  description: "secrets.token_bytes(16).__class__.__name__ == 'bytes' — token_bytes returns bytes"
  category: types
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant secrets_extra9.token_hex.class_name:
  description: "secrets.token_hex(8).__class__.__name__ == 'str' — token_hex returns a string"
  category: types
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant secrets_extra9.token_urlsafe.class_name:
  description: "secrets.token_urlsafe(8).__class__.__name__ == 'str' — token_urlsafe returns a string"
  category: types
  kind: python_call_eq
  function: token_urlsafe
  args: [8]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true
