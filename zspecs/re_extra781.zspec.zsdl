spec: re_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library documentation: re module"
    - "CPython source: Lib/re/__init__.py and Lib/re/_constants.py"
  not_derived_from:
    - "Any third-party regex library"
  notes:
    - "Covers class name and integer value identity checks for re module flag aliases"
    - "Flag aliases (re.I, re.M, etc.) are members of the re.RegexFlag IntFlag enum"
    - "Values are fixed by POSIX convention and CPython implementation"
  created_at: "2026-04-12"

table re_extra781.name:
  description: "Verifies __class__.__name__ and .value identity for re module flag aliases"
  kind: python_call_eq
  category: alias_identity
  id_prefix: re781xx
  columns: [id, function, args, expected]
  rows:
    - [re781xx001, re.I.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re781xx002, re.M.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re781xx003, re.S.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re781xx004, re.X.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re781xx005, re.A.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re781xx006, re.L.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re781xx007, re.U.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re781xx008, re.I.value.__eq__, [2], true]
    - [re781xx009, re.M.value.__eq__, [8], true]
    - [re781xx010, re.S.value.__eq__, [16], true]
    - [re781xx011, re.X.value.__eq__, [64], true]
    - [re781xx012, re.A.value.__eq__, [256], true]
