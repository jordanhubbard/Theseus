spec: itertools_extra161
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.takewhile.__name__ 'takewhile'; itertools.takewhile.__module__ 'itertools'; itertools.dropwhile.__name__ 'dropwhile'; itertools.dropwhile.__module__ 'itertools'; itertools.filterfalse.__name__ 'filterfalse'; itertools.filterfalse.__module__ 'itertools'; takewhile.__doc__.__class__.__name__ 'str'; dropwhile.__doc__.__class__.__name__ 'str'; filterfalse.__doc__.__class__.__name__ 'str' (Wave 290)."
    - "itertools.takewhile.__name__ == 'takewhile' — takewhile is a C extension type in itertoolsmodule.c; its simple type __name__ is 'takewhile'. Verified with Python 3.14.3."
    - "itertools.takewhile.__module__ == 'itertools' — takewhile is declared in the itertools C extension module; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' — dropwhile is a C extension type in itertoolsmodule.c; its simple type __name__ is 'dropwhile'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__module__ == 'itertools' — dropwhile is declared in the itertools C extension module; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' — filterfalse is a C extension type in itertoolsmodule.c; its simple type __name__ is 'filterfalse'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools' — filterfalse is declared in the itertools C extension module; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.takewhile.__doc__.__class__.__name__ == 'str' — takewhile has a C-level docstring; its __doc__ is a Python str object; __doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__doc__.__class__.__name__ == 'str' — dropwhile has a C-level docstring; its __doc__ is a Python str object; __doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__doc__.__class__.__name__ == 'str' — filterfalse has a C-level docstring; its __doc__ is a Python str object; __doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.takewhile and itertools.dropwhile class identity
#
# Wave 290 theme: itertools.takewhile and itertools.dropwhile C extension type
# identity — name, module, and docstring class.
#
# itertools.takewhile.__name__ == 'takewhile'
# itertools.takewhile.__module__ == 'itertools'
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.dropwhile.__module__ == 'itertools'
#
# takewhile(predicate, iterable) returns elements from iterable as long as
# predicate is true, stopping at the first element for which it is false.
# dropwhile(predicate, iterable) drops elements from iterable while predicate
# is true, then returns all remaining elements. Both are C extension types
# defined in itertoolsmodule.c. Their __name__ attributes are the simple type
# names and their __module__ is 'itertools'. New to extra161.
# ---------------------------------------------------------------------------

table itertools_extra161.takewhile_and_dropwhile_identity:
  description: "itertools: takewhile.__name__ 'takewhile', takewhile.__module__ 'itertools', dropwhile.__name__ 'dropwhile', dropwhile.__module__ 'itertools'; wave 290; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolstwdwi161

  columns: [id, function, args, expected, description]
  rows:
    - [tw_name_eq_takewhile,
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile is a C extension type in itertoolsmodule.c that returns successive elements from an iterable as long as a predicate is true; its type __name__ is 'takewhile'; str.__eq__('takewhile') returns True; new to extra161"]
    - [tw_module_eq_itertools,
       "takewhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.takewhile.__module__.__eq__('itertools') == True — takewhile is a C extension type declared in the itertools module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra161"]
    - [dw_name_eq_dropwhile,
       "dropwhile.__name__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile is a C extension type in itertoolsmodule.c that drops elements from an iterable while a predicate is true and then returns all remaining elements; its type __name__ is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra161"]
    - [dw_module_eq_itertools,
       "dropwhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.dropwhile.__module__.__eq__('itertools') == True — dropwhile is a C extension type declared in the itertools module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra161"]

# ---------------------------------------------------------------------------
# Table 2: itertools.filterfalse class identity and docstring classes
#
# Wave 290 theme: itertools.filterfalse identity and __doc__.__class__.__name__
# for takewhile, dropwhile, and filterfalse.
#
# itertools.filterfalse.__name__ == 'filterfalse'
# itertools.filterfalse.__module__ == 'itertools'
# itertools.takewhile.__doc__.__class__.__name__ == 'str'
# itertools.dropwhile.__doc__.__class__.__name__ == 'str'
# itertools.filterfalse.__doc__.__class__.__name__ == 'str'
#
# filterfalse(predicate, iterable) returns elements from iterable for which
# predicate is false — the complement of the built-in filter(). All three
# types (takewhile, dropwhile, filterfalse) are C extension types with
# C-level docstrings. Their __doc__ attributes are Python str objects, so
# __doc__.__class__.__name__ is 'str' in all cases. New to extra161.
# ---------------------------------------------------------------------------

table itertools_extra161.filterfalse_and_doc_class_names:
  description: "itertools: filterfalse.__name__ 'filterfalse', filterfalse.__module__ 'itertools'; takewhile/dropwhile/filterfalse __doc__.__class__.__name__ 'str'; wave 290; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsffdc161

  columns: [id, function, args, expected, description]
  rows:
    - [ff_name_eq_filterfalse,
       "filterfalse.__name__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — filterfalse is a C extension type in itertoolsmodule.c that returns elements from an iterable for which predicate is false (complementing the built-in filter()); its type __name__ is 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra161"]
    - [ff_module_eq_itertools,
       "filterfalse.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — filterfalse is a C extension type declared in the itertools module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra161"]
    - [tw_doc_class_eq_str,
       "takewhile.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.takewhile.__doc__.__class__.__name__.__eq__('str') == True — takewhile is a C extension type with a C-level docstring; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra161"]
    - [dw_doc_class_eq_str,
       "dropwhile.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.dropwhile.__doc__.__class__.__name__.__eq__('str') == True — dropwhile is a C extension type with a C-level docstring; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra161"]
    - [ff_doc_class_eq_str,
       "filterfalse.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.filterfalse.__doc__.__class__.__name__.__eq__('str') == True — filterfalse is a C extension type with a C-level docstring; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra161"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra161
# ---------------------------------------------------------------------------

invariant itertools_extra161.takewhile_name_takewhile:
  description: "itertools.takewhile.__name__ == 'takewhile' — C extension type; returns elements while predicate is true; wave 290; new to extra161"
  kind: python_call_eq
  function: takewhile.__name__.__eq__
  args: ["takewhile"]
  expected: true

invariant itertools_extra161.takewhile_module_itertools:
  description: "itertools.takewhile.__module__ == 'itertools' — takewhile C extension type is declared in itertoolsmodule.c; wave 290; new to extra161"
  kind: python_call_eq
  function: takewhile.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra161.dropwhile_name_dropwhile:
  description: "itertools.dropwhile.__name__ == 'dropwhile' — C extension type; drops elements while predicate is true then returns the rest; wave 290; new to extra161"
  kind: python_call_eq
  function: dropwhile.__name__.__eq__
  args: ["dropwhile"]
  expected: true

invariant itertools_extra161.filterfalse_name_filterfalse:
  description: "itertools.filterfalse.__name__ == 'filterfalse' — C extension type; returns elements for which predicate is false; wave 290; new to extra161"
  kind: python_call_eq
  function: filterfalse.__name__.__eq__
  args: ["filterfalse"]
  expected: true

invariant itertools_extra161.filterfalse_module_itertools:
  description: "itertools.filterfalse.__module__ == 'itertools' — filterfalse C extension type is declared in itertoolsmodule.c; wave 290; new to extra161"
  kind: python_call_eq
  function: filterfalse.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra161.takewhile_doc_class_str:
  description: "itertools.takewhile.__doc__.__class__.__name__ == 'str' — C-level docstring is a Python str object; wave 290; new to extra161"
  kind: python_call_eq
  function: takewhile.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
