spec: lodash_includes
version: ">=4.0.0"
backend: node(lodash.includes)

docs: https://lodash.com/docs/#includes

provenance:
  derived_from:
    - "lodash.includes README — https://www.npmjs.com/package/lodash.includes"
    - "Test vectors verified with lodash.includes@4.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.includes exports the _.includes function directly as module.exports."
    - "includes(collection, value) checks if value is in collection."
    - "Works on arrays, objects (values), and strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_includes.includes:
  kind: node_module_call_eq
  function: ~
  category: includes
  id_prefix: linc

  columns: [id, args, expected]
  rows:
    - [array_found,     [[1, 2, 3], 2],        true]
    - [array_not_found, [[1, 2, 3], 4],        false]
    - [string_found,    ["hello", "ell"],       true]
    - [string_not,      ["hello", "xyz"],       false]
    - [from_index,      [[1, 2, 3, 2], 2, 2],  true]

