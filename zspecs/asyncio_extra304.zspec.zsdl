# ---------------------------------------------------------------------------
# asyncio.Transport — class identity
#
# Transport.__bases__ has two entries: ReadTransport and WriteTransport.
# __bases__[0] is ReadTransport.
# ---------------------------------------------------------------------------

invariant asyncio.transport.name:
  description: "asyncio.Transport.__name__ == 'Transport'"
  category: transport
  kind: python_call_eq
  function: Transport.__name__.__eq__
  args: ["Transport"]
  expected: true

invariant asyncio.transport.module:
  description: "asyncio.Transport.__module__ == 'asyncio.transports'"
  category: transport
  kind: python_call_eq
  function: Transport.__module__.__eq__
  args: ["asyncio.transports"]
  expected: true

invariant asyncio.transport.base_name:
  description: "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' — first base is ReadTransport"
  category: transport
  kind: python_call_eq
  function: Transport.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ReadTransport"

