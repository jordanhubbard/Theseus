spec: asyncio_extra304
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.Protocol, DatagramProtocol, and SubprocessProtocol all live in asyncio.protocols."
    - "All three protocol classes inherit directly from BaseProtocol (__bases__[0].__name__ == 'BaseProtocol')."
    - "asyncio.BaseProtocol.__bases__[0].__name__ == 'object' — the root of the protocol hierarchy."
    - "asyncio.BaseTransport.__bases__[0].__name__ == 'object' — root of the transport hierarchy."
    - "asyncio.Transport.__bases__ has TWO entries: ReadTransport and WriteTransport. __bases__[0] is ReadTransport."
    - "asyncio.StreamReader and asyncio.StreamWriter both live in asyncio.streams and inherit directly from object."
    - "All expected values verified by running Python 3.14.3 asyncio module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Protocol — class identity
# ---------------------------------------------------------------------------

invariant asyncio.protocol.name:
  description: "asyncio.Protocol.__name__ == 'Protocol'"
  category: protocol
  kind: python_call_eq
  function: Protocol.__name__.__eq__
  args: ["Protocol"]
  expected: true

invariant asyncio.protocol.module:
  description: "asyncio.Protocol.__module__ == 'asyncio.protocols'"
  category: protocol
  kind: python_call_eq
  function: Protocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio.protocol.base_name:
  description: "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol'"
  category: protocol
  kind: python_call_eq
  function: Protocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseProtocol"

