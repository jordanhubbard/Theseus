spec: stopword
version: ">=2.0.0"
backend: node(stopword)

docs: https://www.npmjs.com/package/stopword

provenance:
  derived_from:
    - "stopword README — https://www.npmjs.com/package/stopword"
    - "Test vectors verified with stopword via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "stopword source"
  notes:
    - "stopword is an npm package. Install: npm install stopword"
    - "removeStopwords(wordArray) removes common English stop words from an array of words."
    - "Words must be pre-tokenized (split into an array before calling)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of words with stop words removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table stopword.removeStopwords:
  kind: node_module_call_eq
  function: removeStopwords
  category: filter
  id_prefix: sw

  columns: [id, args, expected]
  rows:
    - [mixed,   [["is", "the", "hello", "world", "a"]], ["hello", "world"]]
    - [article, [["the", "quick", "brown", "fox"]],     ["quick", "brown", "fox"]]
    - [clean,   [["hello"]],                            ["hello"]]
