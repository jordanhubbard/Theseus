spec: argparse_extra4
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers __name__ (table) for ArgumentParser/Namespace/Action/FileType/HelpFormatter/Raw*/ArgumentDefaults*/MetavarType*/ArgumentError/ArgumentTypeError/BooleanOptionalAction, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, MRO checks"
    - "argparse_formatters.zspec.zsdl — covers formatter __name__/__module__/__bases__ (tables), FileType __name__/__module__, BooleanOptionalAction __name__/__bases__, exception __bases__"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/__name__/__module__, Namespace/__name__/__module__, HelpFormatter/__name__/__module__, ArgumentError/__name__/__module__, Action/__name__/__module__/__bases__[0], ArgumentDefaultsHelpFormatter/__name__, FileType/__name__/__module__, parse_args/__name__, add_argument/__name__"
    - "argparse_extra2.zspec.zsdl — covers ArgumentTypeError/RawTextHelpFormatter/RawDescriptionHelpFormatter/ArgumentDefaultsHelpFormatter/MetavarTypeHelpFormatter __module__ (table), class __bases__[0].__name__ invariants, MetavarTypeHelpFormatter/__name__, RawTextHelpFormatter/__name__, ArgumentTypeError/__name__"
    - "argparse_extra3.zspec.zsdl — covers ArgumentParser/Namespace/Action/ArgumentError/ArgumentTypeError/FileType/HelpFormatter/RawTextHelpFormatter __name__ (table), nargs constants (table), ArgumentParser.__module__, Namespace instance class, ArgumentError/ArgumentTypeError __bases__[0].__name__, ArgumentParser().prog type"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __qualname__ attributes for all public argparse classes and exception classes."
    - "No prior spec covers __qualname__ for any argparse symbol — all prior specs use __name__ or __module__."
    - "argparse.ArgumentParser.__qualname__ == 'ArgumentParser' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.Namespace.__qualname__ == 'Namespace' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.Action.__qualname__ == 'Action' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.FileType.__qualname__ == 'FileType' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.HelpFormatter.__qualname__ == 'HelpFormatter' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.RawDescriptionHelpFormatter.__qualname__ == 'RawDescriptionHelpFormatter' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.RawTextHelpFormatter.__qualname__ == 'RawTextHelpFormatter' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.ArgumentDefaultsHelpFormatter.__qualname__ == 'ArgumentDefaultsHelpFormatter' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.MetavarTypeHelpFormatter.__qualname__ == 'MetavarTypeHelpFormatter' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.ArgumentError.__qualname__ == 'ArgumentError' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "argparse.ArgumentTypeError.__qualname__ == 'ArgumentTypeError' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for all public argparse classes
#
# No prior spec in the argparse chain covers __qualname__ — all prior specs use
# __name__ or __module__. This table is entirely new coverage.
# ---------------------------------------------------------------------------

table argparse_extra4.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [ArgumentParser,                ArgumentParser.__qualname__.__eq__,                ["ArgumentParser"],                true]
    - [Namespace,                     Namespace.__qualname__.__eq__,                     ["Namespace"],                     true]
    - [Action,                        Action.__qualname__.__eq__,                        ["Action"],                        true]
    - [FileType,                      FileType.__qualname__.__eq__,                      ["FileType"],                      true]
    - [HelpFormatter,                 HelpFormatter.__qualname__.__eq__,                 ["HelpFormatter"],                 true]
    - [RawDescriptionHelpFormatter,   RawDescriptionHelpFormatter.__qualname__.__eq__,   ["RawDescriptionHelpFormatter"],   true]
    - [RawTextHelpFormatter,          RawTextHelpFormatter.__qualname__.__eq__,          ["RawTextHelpFormatter"],          true]
    - [ArgumentDefaultsHelpFormatter, ArgumentDefaultsHelpFormatter.__qualname__.__eq__, ["ArgumentDefaultsHelpFormatter"], true]
    - [MetavarTypeHelpFormatter,      MetavarTypeHelpFormatter.__qualname__.__eq__,      ["MetavarTypeHelpFormatter"],      true]
    - [ArgumentError,                 ArgumentError.__qualname__.__eq__,                 ["ArgumentError"],                 true]
    - [ArgumentTypeError,             ArgumentTypeError.__qualname__.__eq__,             ["ArgumentTypeError"],             true]
