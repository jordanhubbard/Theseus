spec: threading_extra195
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.local.__name__ == '_local' (len=6); the internal C-level class name is '_local' (with leading underscore), not 'local'; threading.local is the public alias but the type's __name__ is '_local'; verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' (len=7); local() is implemented in the C-level _thread extension module; verified with Python 3.14.3."
    - "threading.local.__bases__[0].__name__ == 'object' (len=6); local inherits directly from object; verified with Python 3.14.3."
    - "threading.local.__class__.__name__ == 'type' (len=4); local is a class so its metaclass is the builtin type; verified with Python 3.14.3."
    - "threading.local.__init__.__qualname__ == 'object.__init__' (len=15); local does not define its own __init__ so it inherits object.__init__; qualname is 'object.__init__'; verified with Python 3.14.3."
    - "threading.local.__doc__.__class__.__name__ == 'str' (len=3); local has a docstring ('Thread-local data') so __doc__ is a str instance; verified with Python 3.14.3."
    - "threading.get_ident.__name__ == 'get_ident' (len=9); get_ident is a C-level built-in function returning the OS thread identifier; verified with Python 3.14.3."
    - "threading.get_ident.__module__ == '_thread' (len=7); get_ident is implemented in the C-level _thread extension module; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.local name, module, and base class identity
#
# threading.local.__name__              == '_local' (len=6)
# threading.local.__module__            == '_thread' (len=7)
# threading.local.__bases__[0].__name__ == 'object' (len=6)
#
# threading.local is a C-level class from the _thread extension. The class's
# own __name__ is '_local' (with underscore); threading.local is a public
# alias. Its __module__ reflects the C extension that implements it. New to
# extra195.
# ---------------------------------------------------------------------------

table threading_extra195.local_name_module_base:
  description: "threading.local identity: __name__=='_local'(len=6); __module__=='_thread'(len=7); __bases__[0].__name__=='object'(len=6); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglocal195

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq,
       local.__name__.__eq__,
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — the internal C-level class name is '_local' (with leading underscore); threading.local is the public alias but the type's __name__ is '_local' (len=6); str.__eq__('_local') returns True; verified with Python 3.14.3; new to extra195"]
    - [local_name_len,
       local.__name__.__len__,
       [],
       6,
       "threading.local.__name__.__len__() == 6 — '_local' has 6 characters: _-l-o-c-a-l; str.__len__() returns 6; verified with Python 3.14.3; new to extra195"]
    - [local_module_eq,
       local.__module__.__eq__,
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — local() is implemented in the C-level _thread extension module; __module__ is '_thread' (len=7); str.__eq__('_thread') returns True; verified with Python 3.14.3; new to extra195"]
    - [local_module_len,
       local.__module__.__len__,
       [],
       7,
       "threading.local.__module__.__len__() == 7 — '_thread' has 7 characters: _-t-h-r-e-a-d; str.__len__() returns 7; verified with Python 3.14.3; new to extra195"]
    - [local_base_name_eq,
       "local.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — local inherits directly from object; __bases__[0].__name__ is 'object' (len=6); str.__eq__('object') returns True; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Table 2: threading.local metaclass and __init__ qualname
#
# threading.local.__class__.__name__     == 'type' (len=4)
# threading.local.__init__.__qualname__  == 'object.__init__' (len=15)
#
# local's metaclass is the builtin type. local does not define its own
# __init__; it inherits object.__init__, so __init__.__qualname__ is
# 'object.__init__'. New to extra195.
# ---------------------------------------------------------------------------

table threading_extra195.local_class_init:
  description: "threading.local metaclass and init: __class__.__name__=='type'(len=4); __init__.__qualname__=='object.__init__'(len=15); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglocal195

  columns: [id, function, args, expected, description]
  rows:
    - [local_class_name_eq,
       local.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.local.__class__.__name__.__eq__('type') == True — local is a class so its metaclass is the builtin type; __class__.__name__ is 'type' (len=4); str.__eq__('type') returns True; verified with Python 3.14.3; new to extra195"]
    - [local_class_name_len,
       local.__class__.__name__.__len__,
       [],
       4,
       "threading.local.__class__.__name__.__len__() == 4 — 'type' has 4 characters: t-y-p-e; str.__len__() returns 4; verified with Python 3.14.3; new to extra195"]
    - [local_init_qualname_eq,
       local.__init__.__qualname__.__eq__,
       ["object.__init__"],
       true,
       "threading.local.__init__.__qualname__.__eq__('object.__init__') == True — local does not define its own __init__ so it inherits object.__init__; __qualname__ is 'object.__init__' (len=15); str.__eq__('object.__init__') returns True; verified with Python 3.14.3; new to extra195"]
    - [local_init_qualname_len,
       local.__init__.__qualname__.__len__,
       [],
       15,
       "threading.local.__init__.__qualname__.__len__() == 15 — 'object.__init__' has 15 characters; str.__len__() returns 15; verified with Python 3.14.3; new to extra195"]
    - [local_base_name_len,
       "local.__bases__.__getitem__(0).__name__.__len__",
       [],
       6,
       "threading.local.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters: o-b-j-e-c-t; str.__len__() returns 6; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Table 3: threading.local __doc__ class name and get_ident identity
#
# threading.local.__doc__.__class__.__name__ == 'str' (len=3)
# threading.get_ident.__name__               == 'get_ident' (len=9)
# threading.get_ident.__module__             == '_thread' (len=7)
#
# local has a docstring ('Thread-local data') so __doc__ is a str instance.
# get_ident is a C-level function from _thread that returns the OS thread id.
# New to extra195.
# ---------------------------------------------------------------------------

table threading_extra195.local_doc_and_get_ident:
  description: "threading.local __doc__ class and get_ident: __doc__.__class__.__name__=='str'(len=3); get_ident.__name__=='get_ident'(len=9); get_ident.__module__=='_thread'(len=7); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglocal195

  columns: [id, function, args, expected, description]
  rows:
    - [local_doc_class_name_eq,
       local.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.local.__doc__.__class__.__name__.__eq__('str') == True — local has a docstring ('Thread-local data') so __doc__ is a str instance; __doc__.__class__.__name__ is 'str' (len=3); str.__eq__('str') returns True; verified with Python 3.14.3; new to extra195"]
    - [local_doc_class_name_len,
       local.__doc__.__class__.__name__.__len__,
       [],
       3,
       "threading.local.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters: s-t-r; str.__len__() returns 3; verified with Python 3.14.3; new to extra195"]
    - [get_ident_name_eq,
       get_ident.__name__.__eq__,
       ["get_ident"],
       true,
       "threading.get_ident.__name__.__eq__('get_ident') == True — get_ident is a C-level built-in function that returns the OS thread identifier of the calling thread; __name__ is 'get_ident' (len=9); str.__eq__('get_ident') returns True; verified with Python 3.14.3; new to extra195"]
    - [get_ident_name_len,
       get_ident.__name__.__len__,
       [],
       9,
       "threading.get_ident.__name__.__len__() == 9 — 'get_ident' has 9 characters: g-e-t-_-i-d-e-n-t; str.__len__() returns 9; verified with Python 3.14.3; new to extra195"]
    - [get_ident_module_eq,
       get_ident.__module__.__eq__,
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — get_ident is implemented in the C-level _thread extension module; __module__ is '_thread' (len=7); str.__eq__('_thread') returns True; verified with Python 3.14.3; new to extra195"]

