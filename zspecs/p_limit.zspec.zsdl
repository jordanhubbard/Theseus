spec: p_limit
version: ">=7.0.0"
backend: node(p-limit)

docs: https://github.com/sindresorhus/p-limit#readme

provenance:
  derived_from:
    - "p-limit README — https://github.com/sindresorhus/p-limit#readme"
    - "Test vectors verified with p-limit via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "p-limit source"
  notes:
    - "Run multiple promise-returning & async functions with limited concurrency."
    - "Install: npm install p-limit"
    - "v7 ESM only; default export is pLimit(concurrency) returning a limit function."
    - "Limit function exposes activeCount/pendingCount/concurrency/clearQueue properties."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "pLimit() throws TypeError if concurrency is not a positive integer."
  stderr: "null"
  stickiness: "N/A — each pLimit() call returns an independent limit function."
  codes: {}

invariant p_limit.concurrency_set:
  description: "pLimit(3).concurrency is 3"
  category: properties
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [3]
  chain:
    - {get: concurrency}
  expected: 3

invariant p_limit.active_count_zero_initially:
  description: "Newly created limiter has activeCount 0"
  category: properties
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [3]
  chain:
    - {get: activeCount}
  expected: 0

invariant p_limit.pending_count_zero_initially:
  description: "Newly created limiter has pendingCount 0"
  category: properties
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [3]
  chain:
    - {get: pendingCount}
  expected: 0

invariant p_limit.concurrency_one:
  description: "pLimit(1).concurrency is 1 (serial execution)"
  category: properties
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [1]
  chain:
    - {get: concurrency}
  expected: 1

invariant p_limit.large_concurrency:
  description: "pLimit(100).concurrency is 100"
  category: properties
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [100]
  chain:
    - {get: concurrency}
  expected: 100

invariant p_limit.is_function:
  description: "pLimit returns a function (limit fn has typeof function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:19:53Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
