spec: numbers_extra12
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra through numbers_extra11."
    - "numbers_extra through numbers_extra11 cover: Number/Complex/Real/Rational/Integral __name__/__qualname__/__module__/__bases__/__abstractmethods__/__dict__/__instancecheck__."
    - "numbers_extra11 covers Integral.__mro__.__getitem__ at all six indices (0..5)."
    - "No prior spec covers Number.__mro__, Complex.__mro__, Real.__mro__, or Rational.__mro__ items."
    - "numbers.Number.__mro__ == [Number, object] — Number is a direct subclass of object."
    - "numbers.Complex.__mro__ == [Complex, Number, object]."
    - "numbers.Real.__mro__ == [Real, Complex, Number, object]."
    - "numbers.Rational.__mro__ == [Rational, Real, Complex, Number, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Number MRO — two entries: Number itself and object
#
# numbers_extra11 covers only Integral.__mro__.__getitem__.
# No prior spec records Number, Complex, Real, or Rational MRO items.
# ---------------------------------------------------------------------------

invariant numbers_extra12.Number.mro_0:
  description: "numbers.Number.__mro__[0].__name__ == 'Number' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: "Number.__mro__[0].__name__.__eq__"
  args: ["Number"]
  expected: true

invariant numbers_extra12.Number.mro_1:
  description: "numbers.Number.__mro__[1].__name__ == 'object' — Number inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "Number.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Complex MRO — three entries: Complex → Number → object
# ---------------------------------------------------------------------------

table numbers_extra12.complex_mro:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: complex_mro

  columns: [id, function, args, expected, description]
  rows:
    - [0, "Complex.__mro__[0].__name__.__eq__", ["Complex"], true, "MRO[0] is Complex itself"]
    - [1, "Complex.__mro__[1].__name__.__eq__", ["Number"],  true, "MRO[1] is Number — Complex extends Number"]
    - [2, "Complex.__mro__[2].__name__.__eq__", ["object"],  true, "MRO[2] is object — root of all classes"]

# ---------------------------------------------------------------------------
# Real MRO — four entries: Real → Complex → Number → object
# ---------------------------------------------------------------------------

invariant numbers_extra12.Real.mro_0:
  description: "numbers.Real.__mro__[0].__name__ == 'Real' — first MRO entry is Real itself"
  category: class_hierarchy
  kind: python_call_eq
  function: "Real.__mro__[0].__name__.__eq__"
  args: ["Real"]
  expected: true

invariant numbers_extra12.Real.mro_1:
  description: "numbers.Real.__mro__[1].__name__ == 'Complex' — Real extends Complex"
  category: class_hierarchy
  kind: python_call_eq
  function: "Real.__mro__[1].__name__.__eq__"
  args: ["Complex"]
  expected: true

invariant numbers_extra12.Real.mro_2:
  description: "numbers.Real.__mro__[2].__name__ == 'Number' — third MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "Real.__mro__[2].__name__.__eq__"
  args: ["Number"]
  expected: true

invariant numbers_extra12.Real.mro_3:
  description: "numbers.Real.__mro__[3].__name__ == 'object' — fourth and final MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: "Real.__mro__[3].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Rational MRO — five entries: Rational → Real → Complex → Number → object
# ---------------------------------------------------------------------------

invariant numbers_extra12.Rational.mro_0:
  description: "numbers.Rational.__mro__[0].__name__ == 'Rational' — first MRO entry is Rational itself"
  category: class_hierarchy
  kind: python_call_eq
  function: "Rational.__mro__[0].__name__.__eq__"
  args: ["Rational"]
  expected: true

invariant numbers_extra12.Rational.mro_1:
  description: "numbers.Rational.__mro__[1].__name__ == 'Real' — Rational extends Real"
  category: class_hierarchy
  kind: python_call_eq
  function: "Rational.__mro__[1].__name__.__eq__"
  args: ["Real"]
  expected: true
