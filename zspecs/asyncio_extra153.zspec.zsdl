spec: asyncio_extra153
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — Python asyncio exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers: asyncio exception class identity. asyncio.CancelledError.__name__=='CancelledError' (len=14); asyncio.CancelledError.__module__=='asyncio.exceptions' (len=18; defined in Lib/asyncio/exceptions.py, NOT in 'asyncio' top-level); asyncio.CancelledError.__bases__[0].__name__=='BaseException' (CancelledError inherits directly from BaseException, not from Exception — it was changed in Python 3.8 to inherit from BaseException so it can propagate through exception handlers); asyncio.TimeoutError.__name__=='TimeoutError' (len=12); asyncio.TimeoutError.__module__=='builtins' (IS the builtin TimeoutError, not a custom asyncio class); asyncio.InvalidStateError.__name__=='InvalidStateError' (len=17); asyncio.InvalidStateError.__module__=='asyncio.exceptions' (len=18); asyncio.QueueEmpty.__name__=='QueueEmpty' (len=10); asyncio.QueueEmpty.__module__=='asyncio.queues' (len=14); asyncio.QueueFull.__name__=='QueueFull' (len=9); asyncio.QueueFull.__module__=='asyncio.queues' (len=14). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.CancelledError.__module__=='asyncio.exceptions' — CancelledError is defined in Lib/asyncio/exceptions.py and re-exported through asyncio/__init__.py; its __module__ is 'asyncio.exceptions' (len=18), NOT 'asyncio' — this is a key distinction; compare asyncio.TimeoutError.__module__=='builtins' (IS the builtin). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.CancelledError.__bases__[0].__name__=='BaseException' — in Python 3.8+, CancelledError was changed from inheriting from concurrent.futures.CancelledError (which inherits from Exception) to inheriting directly from BaseException; this allows cancellation to propagate through broad 'except Exception' handlers without being caught, matching KeyboardInterrupt behavior; compare asyncio.InvalidStateError.__bases__[0].__name__=='Exception' (InvalidStateError still inherits from Exception). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.TimeoutError.__module__=='builtins' — asyncio.TimeoutError IS the Python builtin TimeoutError (not a custom subclass); asyncio.TimeoutError.__bases__[0].__name__=='OSError' (it is the builtin); compare asyncio.CancelledError.__module__=='asyncio.exceptions' (a custom class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.QueueEmpty and asyncio.QueueFull are defined in Lib/asyncio/queues.py; both have __module__=='asyncio.queues' (len=14); QueueEmpty.__name__ len=10, QueueFull.__name__ len=9; neither inherits from asyncio.CancelledError — they are plain Exception subclasses for use with asyncio.Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.CancelledError and InvalidStateError identity — extra153
#
# asyncio.CancelledError.__name__.__eq__('CancelledError')              == True
# asyncio.CancelledError.__module__.__eq__('asyncio.exceptions')        == True
# asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException')  == True
# asyncio.InvalidStateError.__name__.__eq__('InvalidStateError')        == True
# asyncio.InvalidStateError.__module__.__eq__('asyncio.exceptions')     == True
# asyncio.InvalidStateError.__bases__[0].__name__.__eq__('Exception')   == True
# ---------------------------------------------------------------------------

table asyncio_extra153.asyncio_cancelled_invalidstate_identity:
  description: "asyncio CancelledError and InvalidStateError class identity checks in asyncioexc153 namespace — asyncio.CancelledError.__name__=='CancelledError' (len=14; raised when a Task or Future is cancelled via cancel()); asyncio.CancelledError.__module__=='asyncio.exceptions' (len=18; defined in Lib/asyncio/exceptions.py, re-exported through asyncio/__init__.py — NOT 'asyncio' top-level); asyncio.CancelledError.__bases__[0].__name__=='BaseException' (changed in Python 3.8 to inherit from BaseException rather than Exception, so broad 'except Exception' handlers do not swallow cancellations); asyncio.InvalidStateError.__name__=='InvalidStateError' (len=17; raised when a Future or Task is in an invalid state for the operation, e.g. calling set_result() on an already-done Future); asyncio.InvalidStateError.__module__=='asyncio.exceptions' (len=18; same module as CancelledError — both are in asyncio.exceptions); asyncio.InvalidStateError.__bases__[0].__name__=='Exception' (InvalidStateError inherits from Exception, unlike CancelledError which inherits from BaseException); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexc153

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_name_eq,   asyncio.CancelledError.__name__.__eq__,                             ["CancelledError"],        true,  "asyncio.CancelledError.__name__ == 'CancelledError' (len=14); verified with Python 3.14.3"]
    - [cancel_mod_eq,    asyncio.CancelledError.__module__.__eq__,                            ["asyncio.exceptions"],    true,  "asyncio.CancelledError.__module__ == 'asyncio.exceptions' (len=18; NOT 'asyncio' top-level); verified with Python 3.14.3"]
    - [cancel_base_eq,   "asyncio.CancelledError.__bases__[0].__name__.__eq__",               ["BaseException"],         true,  "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' (changed in Python 3.8 from Exception to BaseException); verified with Python 3.14.3"]
    - [invstate_name_eq, asyncio.InvalidStateError.__name__.__eq__,                           ["InvalidStateError"],     true,  "asyncio.InvalidStateError.__name__ == 'InvalidStateError' (len=17); verified with Python 3.14.3"]
    - [invstate_mod_eq,  asyncio.InvalidStateError.__module__.__eq__,                         ["asyncio.exceptions"],    true,  "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' (len=18; same module as CancelledError); verified with Python 3.14.3"]
    - [invstate_base_eq, "asyncio.InvalidStateError.__bases__[0].__name__.__eq__",            ["Exception"],             true,  "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception' (inherits from Exception, unlike CancelledError); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.TimeoutError identity — extra153
#
# asyncio.TimeoutError.__name__.__eq__('TimeoutError')     == True
# asyncio.TimeoutError.__module__.__eq__('builtins')       == True
# asyncio.TimeoutError.__bases__[0].__name__.__eq__('OSError') == True
# ---------------------------------------------------------------------------

table asyncio_extra153.asyncio_timeout_identity:
  description: "asyncio.TimeoutError class identity checks in asynciotimeout153 namespace — asyncio.TimeoutError.__name__=='TimeoutError' (len=12; asyncio.TimeoutError IS the Python builtin TimeoutError — not a custom asyncio class); asyncio.TimeoutError.__module__=='builtins' (len=8; confirms this is the identical builtin object, not a subclass); asyncio.TimeoutError.__bases__[0].__name__=='OSError' (builtin TimeoutError inherits from OSError, same as concurrent.futures.TimeoutError); the key distinction: asyncio.CancelledError.__module__=='asyncio.exceptions' (custom class) while asyncio.TimeoutError.__module__=='builtins' (the builtin itself); asyncio.TimeoutError.__name__.__len__()==12 (3 chars shorter than 'CancelledError'=14 and 5 chars shorter than 'InvalidStateError'=17); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotimeout153

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_name_eq,  asyncio.TimeoutError.__name__.__eq__,                               ["TimeoutError"],  true,  "asyncio.TimeoutError.__name__ == 'TimeoutError' (len=12; IS the builtin TimeoutError); verified with Python 3.14.3"]
    - [timeout_mod_eq,   asyncio.TimeoutError.__module__.__eq__,                              ["builtins"],      true,  "asyncio.TimeoutError.__module__ == 'builtins' (IS the builtin TimeoutError, not a custom subclass); verified with Python 3.14.3"]
    - [timeout_base_eq,  "asyncio.TimeoutError.__bases__[0].__name__.__eq__",                 ["OSError"],       true,  "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' (builtin TimeoutError inherits from OSError); verified with Python 3.14.3"]
    - [timeout_name_len, asyncio.TimeoutError.__name__.__len__,                               [],                12,    "asyncio.TimeoutError.__name__.__len__() == 12 ('TimeoutError'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.QueueEmpty and asyncio.QueueFull identity — extra153
#
# asyncio.QueueEmpty.__name__.__eq__('QueueEmpty')             == True
# asyncio.QueueEmpty.__module__.__eq__('asyncio.queues')       == True
# asyncio.QueueFull.__name__.__eq__('QueueFull')               == True
# asyncio.QueueFull.__module__.__eq__('asyncio.queues')        == True
# ---------------------------------------------------------------------------

table asyncio_extra153.asyncio_queue_exception_identity:
  description: "asyncio.QueueEmpty and asyncio.QueueFull class identity checks in asyncioqexc153 namespace — asyncio.QueueEmpty.__name__=='QueueEmpty' (len=10; raised by asyncio.Queue.get_nowait() when the queue is empty); asyncio.QueueEmpty.__module__=='asyncio.queues' (len=14; defined in Lib/asyncio/queues.py); asyncio.QueueFull.__name__=='QueueFull' (len=9; raised by asyncio.Queue.put_nowait() when the queue is full — 1 char shorter than 'QueueEmpty'); asyncio.QueueFull.__module__=='asyncio.queues' (len=14; same module as QueueEmpty); QueueEmpty.__module__.__len__()==14 (len('asyncio.queues')=14: 'asyncio'=7+'.'=1+'queues'=6=14); name length comparison: QueueEmpty(10) > QueueFull(9); both exceptions are in 'asyncio.queues' (distinct from 'asyncio.exceptions' where CancelledError and InvalidStateError live); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqexc153

  columns: [id, function, args, expected, description]
  rows:
    - [qempty_name_eq,  asyncio.QueueEmpty.__name__.__eq__,   ["QueueEmpty"],     true,  "asyncio.QueueEmpty.__name__ == 'QueueEmpty' (len=10); verified with Python 3.14.3"]
    - [qempty_mod_eq,   asyncio.QueueEmpty.__module__.__eq__,  ["asyncio.queues"], true,  "asyncio.QueueEmpty.__module__ == 'asyncio.queues' (len=14); verified with Python 3.14.3"]
    - [qfull_name_eq,   asyncio.QueueFull.__name__.__eq__,    ["QueueFull"],      true,  "asyncio.QueueFull.__name__ == 'QueueFull' (len=9; 1 char shorter than 'QueueEmpty'); verified with Python 3.14.3"]
    - [qfull_mod_eq,    asyncio.QueueFull.__module__.__eq__,   ["asyncio.queues"], true,  "asyncio.QueueFull.__module__ == 'asyncio.queues' (len=14; same module as QueueEmpty); verified with Python 3.14.3"]
    - [qempty_mod_len,  asyncio.QueueEmpty.__module__.__len__,  [],                14,    "asyncio.QueueEmpty.__module__.__len__() == 14 ('asyncio.queues'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra153
# ---------------------------------------------------------------------------

invariant asyncio_extra153.asyncio_CancelledError_module_is_exceptions:
  description: "asyncio.CancelledError.__module__.__eq__('asyncio.exceptions') returns True — asyncio.CancelledError is defined in Lib/asyncio/exceptions.py (not in the top-level asyncio package); its __module__ is 'asyncio.exceptions' (len=18); this is a key distinction from asyncio.TimeoutError which has __module__=='builtins' (IS the builtin TimeoutError); asyncio.CancelledError is a custom class that changed inheritance in Python 3.8 from Exception to BaseException so that broad 'except Exception' clauses do not accidentally swallow task cancellations; asyncio.CancelledError.__name__=='CancelledError' (len=14); asyncio.CancelledError.__bases__[0].__name__=='BaseException'; NEW in extra153: first standalone asyncio.CancelledError.__module__ identity invariant in asyncioexc153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra153.asyncio_CancelledError_bases0_is_BaseException:
  description: "asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException') returns True — asyncio.CancelledError inherits directly from BaseException (not from Exception); this inheritance was changed in Python 3.8 (PEP 584 / bpo-32528) to prevent accidental swallowing of cancellations by 'except Exception' handlers; BaseException is the root of the Python exception hierarchy (above Exception) — other BaseException subclasses include KeyboardInterrupt, SystemExit, and GeneratorExit; asyncio.CancelledError.__bases__[0].__name__=='BaseException' (len=13); compare: asyncio.InvalidStateError.__bases__[0].__name__=='Exception' (still inherits from Exception); asyncio.TimeoutError.__bases__[0].__name__=='OSError' (the builtin); NEW in extra153: first standalone asyncio.CancelledError.__bases__[0] name identity invariant in asyncioexc153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.CancelledError.__bases__[0].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant asyncio_extra153.asyncio_TimeoutError_module_is_builtins:
  description: "asyncio.TimeoutError.__module__.__eq__('builtins') returns True — asyncio.TimeoutError IS the Python builtin TimeoutError object (not a custom subclass); asyncio re-exports the builtin TimeoutError for convenience; TimeoutError.__module__=='builtins' (len=8) confirms this is the identical builtin object; compare: asyncio.CancelledError.__module__=='asyncio.exceptions' (len=18, a custom class) and asyncio.InvalidStateError.__module__=='asyncio.exceptions' (len=18, also custom); the asymmetry is notable: of the three asyncio exception classes (CancelledError, TimeoutError, InvalidStateError), only TimeoutError is the builtin — the other two are custom asyncio classes defined in Lib/asyncio/exceptions.py; NEW in extra153: first standalone asyncio.TimeoutError.__module__ identity invariant in asynciotimeout153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra153.asyncio_QueueEmpty_module_eq:
  description: "asyncio.QueueEmpty.__module__.__eq__('asyncio.queues') returns True — asyncio.QueueEmpty is defined in Lib/asyncio/queues.py; its __module__ is 'asyncio.queues' (len=14); QueueEmpty is raised when asyncio.Queue.get_nowait() is called on an empty queue; QueueEmpty.__module__.__len__()==14 ('asyncio.queues': 'asyncio'=7+'.'=1+'queues'=6=14); compare: asyncio.CancelledError.__module__=='asyncio.exceptions' (len=18, 4 chars longer); both QueueEmpty and QueueFull live in 'asyncio.queues' — distinct from 'asyncio.exceptions' where the cancellation/state errors reside; QueueEmpty.__name__.__len__()==10 ('QueueEmpty'); NEW in extra153: first standalone asyncio.QueueEmpty.__module__ identity invariant in asyncioqexc153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.QueueEmpty.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra153.asyncio_InvalidStateError_name_len:
  description: "asyncio.InvalidStateError.__name__.__len__() == 17 — asyncio.InvalidStateError.__name__ is 'InvalidStateError' (17 chars: 'Invalid'=7+'State'=5+'Error'=5=17); this is the longest of the three asyncio exception class names in this spec: InvalidStateError(17) > CancelledError(14) > TimeoutError(12) > QueueEmpty(10) > QueueFull(9); asyncio.InvalidStateError.__module__=='asyncio.exceptions' (len=18; same module as CancelledError); asyncio.InvalidStateError.__bases__[0].__name__=='Exception' (inherits from Exception, unlike CancelledError which inherits from BaseException); InvalidStateError is raised when a Future or Task operation is not valid for its current state (e.g. calling set_result() on a done Future); NEW in extra153: first standalone asyncio.InvalidStateError.__name__ length invariant in asyncioexc153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.InvalidStateError.__name__.__len__
  args: []
  expected: 17
