spec: inspect_extra263
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Signature class identity; inspect.getfullargspec function identity; inspect.FullArgSpec namedtuple identity."
    - "inspect.Signature.__name__ == 'Signature'; __module__ == 'inspect'; __bases__[0].__name__ == 'object'; __mro__ len == 2. Verified with Python 3.14.3."
    - "inspect.getfullargspec.__name__ == 'getfullargspec'; __module__ == 'inspect'; __qualname__ == 'getfullargspec'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec'; __module__ == 'inspect'; __bases__[0].__name__ == 'tuple'; __mro__ len == 3. Verified with Python 3.14.3."
    - "inspect.FullArgSpec._fields has 7 fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations. Verified with Python 3.14.3."
    - "inspect.FullArgSpec._fields[0] == 'args'; _fields[1] == 'varargs'. Verified with Python 3.14.3."
    - "inspect.signature.__name__ == 'signature'; __module__ == 'inspect'; __qualname__ == 'signature'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature class identity
#
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__bases__[0].__name__ == 'object'
# inspect.Signature.__mro__.__len__() == 2
#
# Signature is a pure Python class in Lib/inspect.py. Its MRO is
# (Signature, object), length 2. New to extra263.
# ---------------------------------------------------------------------------

table inspect_extra263.signature_class_identity:
  description: "inspect.Signature class __name__, __module__, __bases__, __mro__ identity; new to extra263"
  kind: python_call_eq
  category: identity
  id_prefix: inspsig263

  columns: [id, function, args, expected, description]
  rows:
    - [signature_class_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a class in Lib/inspect.py representing a callable's signature; its __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra263"]
    - [signature_class_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra263"]
    - [signature_class_base_name_eq,
       Signature.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object; its first base class is object; str.__eq__('object') returns True; new to extra263"]
    - [signature_class_mro_len_2,
       Signature.__mro__.__len__,
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature's MRO is (Signature, object), a tuple of length 2; tuple.__len__() returns 2; new to extra263"]
    - [signature_class_name_len_9,
       Signature.__name__.__len__,
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — the name 'Signature' has exactly 9 characters: S-i-g-n-a-t-u-r-e; str.__len__() returns 9; new to extra263"]

# ---------------------------------------------------------------------------
# Table 2: inspect.FullArgSpec namedtuple identity
#
# inspect.FullArgSpec.__name__ == 'FullArgSpec'
# inspect.FullArgSpec.__module__ == 'inspect'
# inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'
# inspect.FullArgSpec.__mro__.__len__() == 3
# inspect.FullArgSpec._fields.__len__() == 7
#
# FullArgSpec is a namedtuple created in Lib/inspect.py. It inherits from
# tuple, giving a 3-element MRO: (FullArgSpec, tuple, object). New to extra263.
# ---------------------------------------------------------------------------

table inspect_extra263.fullargspec_identity:
  description: "inspect.FullArgSpec namedtuple __name__, __module__, __bases__, __mro__, _fields identity; new to extra263"
  kind: python_call_eq
  category: identity
  id_prefix: inspfas263

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_name_eq,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple defined in Lib/inspect.py; its __name__ is 'FullArgSpec'; str.__eq__('FullArgSpec') returns True; new to extra263"]
    - [fullargspec_module_eq,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra263"]
    - [fullargspec_base_name_eq,
       FullArgSpec.__bases__.__getitem__(0).__name__.__eq__,
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a namedtuple that inherits from tuple; its first base class is tuple; str.__eq__('tuple') returns True; new to extra263"]
    - [fullargspec_mro_len_3,
       FullArgSpec.__mro__.__len__,
       [],
       3,
       "inspect.FullArgSpec.__mro__.__len__() == 3 — FullArgSpec's MRO is (FullArgSpec, tuple, object), a tuple of length 3; tuple.__len__() returns 3; new to extra263"]
    - [fullargspec_fields_len_7,
       FullArgSpec._fields.__len__,
       [],
       7,
       "inspect.FullArgSpec._fields.__len__() == 7 — FullArgSpec has 7 fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations; new to extra263"]

# ---------------------------------------------------------------------------
# Table 3: inspect.signature and inspect.getfullargspec function identity
#
# inspect.signature.__name__ == 'signature'
# inspect.signature.__module__ == 'inspect'
# inspect.getfullargspec.__name__ == 'getfullargspec'
# inspect.getfullargspec.__module__ == 'inspect'
#
# Both are pure Python functions in Lib/inspect.py. New to extra263.
# ---------------------------------------------------------------------------

table inspect_extra263.function_identity:
  description: "inspect.signature and inspect.getfullargspec function __name__ and __module__ identity; new to extra263"
  kind: python_call_eq
  category: identity
  id_prefix: inspfn263

  columns: [id, function, args, expected, description]
  rows:
    - [signature_fn_name_eq,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__.__eq__('signature') == True — signature is a pure Python function in Lib/inspect.py; its __name__ is 'signature'; str.__eq__('signature') returns True; new to extra263"]
    - [signature_fn_module_eq,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra263"]
    - [getfullargspec_name_eq,
       getfullargspec.__name__.__eq__,
       ["getfullargspec"],
       true,
       "inspect.getfullargspec.__name__.__eq__('getfullargspec') == True — getfullargspec is a pure Python function in Lib/inspect.py; its __name__ is 'getfullargspec'; str.__eq__('getfullargspec') returns True; new to extra263"]
    - [getfullargspec_module_eq,
       getfullargspec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getfullargspec.__module__.__eq__('inspect') == True — getfullargspec is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra263"]
    - [getfullargspec_qualname_eq,
       getfullargspec.__qualname__.__eq__,
       ["getfullargspec"],
       true,
       "inspect.getfullargspec.__qualname__.__eq__('getfullargspec') == True — getfullargspec is a top-level function so __qualname__ == __name__; str.__eq__('getfullargspec') returns True; new to extra263"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra263
# ---------------------------------------------------------------------------

invariant inspect_extra263.Signature.name_eq:
  description: "inspect.Signature.__name__.__eq__('Signature') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra263.Signature.module_eq:
  description: "inspect.Signature.__module__.__eq__('inspect') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra263.Signature.base_name_eq:
  description: "inspect.Signature.__bases__[0].__name__.__eq__('object') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: Signature.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant inspect_extra263.Signature.mro_len_2:
  description: "inspect.Signature.__mro__.__len__() == 2 — MRO is (Signature, object); new to extra263"
  category: identity
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra263.FullArgSpec.name_eq:
  description: "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra263.FullArgSpec.module_eq:
  description: "inspect.FullArgSpec.__module__.__eq__('inspect') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra263.FullArgSpec.base_name_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — namedtuple inherits from tuple; new to extra263"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__bases__.__getitem__(0).__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra263.FullArgSpec.mro_len_3:
  description: "inspect.FullArgSpec.__mro__.__len__() == 3 — MRO is (FullArgSpec, tuple, object); new to extra263"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__mro__.__len__
  args: []
  expected: 3

invariant inspect_extra263.FullArgSpec.fields_len_7:
  description: "inspect.FullArgSpec._fields.__len__() == 7 — 7 named fields; new to extra263"
  category: identity
  kind: python_call_eq
  function: FullArgSpec._fields.__len__
  args: []
  expected: 7

invariant inspect_extra263.FullArgSpec.fields_first_args:
  description: "inspect.FullArgSpec._fields[0].__eq__('args') == True — first field is 'args'; new to extra263"
  category: identity
  kind: python_call_eq
  function: FullArgSpec._fields.__getitem__(0).__eq__
  args: ["args"]
  expected: true

invariant inspect_extra263.signature.name_eq:
  description: "inspect.signature.__name__.__eq__('signature') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra263.signature.module_eq:
  description: "inspect.signature.__module__.__eq__('inspect') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra263.getfullargspec.name_eq:
  description: "inspect.getfullargspec.__name__.__eq__('getfullargspec') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: getfullargspec.__name__.__eq__
  args: ["getfullargspec"]
  expected: true

invariant inspect_extra263.getfullargspec.module_eq:
  description: "inspect.getfullargspec.__module__.__eq__('inspect') == True; new to extra263"
  category: identity
  kind: python_call_eq
  function: getfullargspec.__module__.__eq__
  args: ["inspect"]
  expected: true
