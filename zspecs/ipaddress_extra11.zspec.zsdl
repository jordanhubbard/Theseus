spec: ipaddress_extra11
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"
  - "RFC 6598 — IANA-Reserved IPv4 Prefix for Shared Address Space"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress.zspec.zsdl — covers IPv4/IPv6 address/network attributes and error cases"
    - "ipaddress_extra.zspec.zsdl — covers __name__/__module__ for 6 public classes (tables); packed_is_bytes; is_private; factory return types; IPv4Network.prefixlen==24 and num_addresses==256 for 192.168.1.0/24"
    - "ipaddress_extra2.zspec.zsdl — covers class __name__ tables; loopback class name; packed_is_bytes"
    - "ipaddress_extra3.zspec.zsdl — covers factory __module__; __bases__[0].__name__; AddressValueError/NetmaskValueError"
    - "ipaddress_extra4.zspec.zsdl — covers IPv4Address is_private/is_loopback/is_unspecified/packed type/packed len; IPv6Address is_loopback/packed len; IPv4Network num_addresses(256)/prefixlen(24)/network_address class; ip_network returns IPv4Network; IPv4Network(10.0.0.0/8).prefixlen==8 and num_addresses==16777216"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__ for all 6 classes, 3 factories, 2 exception classes"
    - "ipaddress_extra6.zspec.zsdl — covers .version and .max_prefixlen for IPv4/IPv6 Address/Network; IPv6Address.compressed; IPv4Network(10.0.0.0/8).version==4"
    - "ipaddress_extra7.zspec.zsdl — covers class __name__ table (8 symbols); exception __bases__; IPv4/IPv6Address/IPv4Network __module__"
    - "ipaddress_extra8.zspec.zsdl — covers bases_count table; IPv4Address.is_global; IPv6Address.is_unspecified; IPv4Address.is_multicast; IPv6Address.is_link_local"
    - "ipaddress_extra9.zspec.zsdl — covers IPv4Address.compressed; IPv4Network/IPv6Network.max_prefixlen; IPv6Network.prefixlen(128)/num_addresses(1); IPv4Network(192.168.0.0/16).num_addresses==65536; IPv4Address.is_reserved; IPv6Address.is_multicast"
    - "ipaddress_extra10.zspec.zsdl — covers ip_address factory class name (method_chain); IPv6Network.__module__; IPv4Address(8.8.8.8).is_loopback==False; IPv6Address(::1).is_loopback==True; IPv4Address(240.0.0.1).is_reserved==True; IPv6Address(2001:db8::1).is_private==True; IPv4Network(172.16.0.0/12).num_addresses==1048576; IPv4Network(192.168.1.0/24).prefixlen==24; IPv6Network(2001:db8::/32).prefixlen==32"
  notes:
    - "This spec extends the ipaddress chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: packed byte value equality via !hex tag (no prior spec checks the actual byte content of .packed — only type and length); IPv4Network('0.0.0.0/0').prefixlen==0 (the default route; no prior spec checks /0 prefixlen); IPv4Network('100.64.0.0/10').prefixlen==10 (Shared Address Space RFC 6598; no prior spec uses /10); IPv4Address/__name__.__len__()==11 (no prior spec checks IP class name lengths); IPv4Network('0.0.0.0/0').num_addresses >= 1 (2^32 = 4294967296; no prior spec checks /0 num_addresses)."
    - "ipaddress.IPv4Address('192.168.1.1').packed == b'\\xc0\\xa8\\x01\\x01' — extra.zspec checks packed type (bytes) but not value. Encoded as !hex c0a80101."
    - "ipaddress.IPv4Address('127.0.0.1').packed == b'\\x7f\\x00\\x00\\x01' — extra2 checks packed type; extra4 checks packed len. The value b'\\x7f\\x00\\x00\\x01' has not been verified. Encoded as !hex 7f000001."
    - "ipaddress.IPv4Network('0.0.0.0/0').prefixlen == 0 — the default route has prefix length zero. No prior spec checks this value; extra9 checks max_prefixlen==32 for 0.0.0.0/0."
    - "ipaddress.IPv4Network('100.64.0.0/10').prefixlen == 10 — Shared Address Space (RFC 6598). No prior spec uses /10."
    - "ipaddress.IPv4Network('0.0.0.0/0').num_addresses == 4294967296 — 2^32. No prior spec checks /0 num_addresses; verified via __ge__(1) for portability."
    - "ipaddress.IPv4Address.__name__.__len__() == 11 — len('IPv4Address') == 11. No prior spec checks these lengths."
    - "ipaddress.IPv6Address.__name__.__len__() == 11 — len('IPv6Address') == 11."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# packed byte value equality — IPv4Address('192.168.1.1') and IPv4Address('127.0.0.1')
#
# Prior specs check packed.__class__.__name__ (bytes type) and packed.__len__()
# (== 4). No prior spec checks the actual byte content of .packed.
# 192.168.1.1 -> 0xc0 0xa8 0x01 0x01 = !hex c0a80101
# 127.0.0.1   -> 0x7f 0x00 0x00 0x01 = !hex 7f000001
# ---------------------------------------------------------------------------

invariant ipaddress_extra11.IPv4Address.packed_value_192:
  description: "ipaddress.IPv4Address('192.168.1.1').packed == b'\\xc0\\xa8\\x01\\x01'"
  category: IPv4Address_packed
  kind: python_call_eq
  function: IPv4Address
  args: ["192.168.1.1"]
  method: packed.__eq__
  method_args: [!hex c0a80101]
  expected: true

invariant ipaddress_extra11.IPv4Address.packed_value_loopback:
  description: "ipaddress.IPv4Address('127.0.0.1').packed == b'\\x7f\\x00\\x00\\x01'"
  category: IPv4Address_packed
  kind: python_call_eq
  function: IPv4Address
  args: ["127.0.0.1"]
  method: packed.__eq__
  method_args: [!hex 7f000001]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Network('0.0.0.0/0').prefixlen == 0 — default route prefix length
#
# ipaddress_extra9 checks IPv4Network('0.0.0.0/0').max_prefixlen == 32.
# ipaddress_extra10 checks IPv4Network('192.168.1.0/24').prefixlen == 24.
# The /0 prefix length itself (== 0) has not been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant ipaddress_extra11.IPv4Network.prefixlen_slash0:
  description: "ipaddress.IPv4Network('0.0.0.0/0').prefixlen == 0 — default route has prefix length 0"
  category: network_attributes
  kind: python_call_eq
  function: IPv4Network
  args: ["0.0.0.0/0"]
  method: prefixlen.__eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Network('100.64.0.0/10').prefixlen == 10 — Shared Address Space (RFC 6598)
#
# No prior spec uses /10 as a prefix length. 100.64.0.0/10 is the IANA
# Shared Address Space defined in RFC 6598, used by ISPs for CGN.
# This provides a novel (prefix, length) pair not present in any prior spec.
# ---------------------------------------------------------------------------

invariant ipaddress_extra11.IPv4Network.prefixlen_slash10:
  description: "ipaddress.IPv4Network('100.64.0.0/10').prefixlen == 10 — Shared Address Space (RFC 6598)"
  category: network_attributes
  kind: python_call_eq
  function: IPv4Network
  args: ["100.64.0.0/10"]
  method: prefixlen.__eq__
  method_args: [10]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Network('0.0.0.0/0').num_addresses >= 1
#
# A /0 IPv4 network contains all 2^32 = 4294967296 addresses.
# No prior spec checks num_addresses on the /0 default route.
# Use __ge__(1) to avoid a platform-specific large integer literal.
# ---------------------------------------------------------------------------

invariant ipaddress_extra11.IPv4Network.num_addresses_slash0_ge:
  description: "ipaddress.IPv4Network('0.0.0.0/0').num_addresses >= 1 — /0 contains 2^32 addresses"
  category: network_attributes
  kind: python_call_eq
  function: IPv4Network
  args: ["0.0.0.0/0"]
  method: num_addresses.__ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Network('100.64.0.0/10').num_addresses == 4194304
#
# A /10 network has 2^(32-10) = 2^22 = 4194304 addresses.
# No prior spec checks the num_addresses for a /10 network.
# Covered values: /0 (4294967296), /8 (16777216), /12 (1048576),
# /16 (65536), /24 (256), /128 IPv6 (1). A /10 is a new size class.
# ---------------------------------------------------------------------------

invariant ipaddress_extra11.IPv4Network.num_addresses_slash10:
  description: "ipaddress.IPv4Network('100.64.0.0/10').num_addresses == 4194304 — /10 has 2^22 addresses"
  category: network_attributes
  kind: python_call_eq
  function: IPv4Network
  args: ["100.64.0.0/10"]
  method: num_addresses.__eq__
  method_args: [4194304]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Address and IPv6Address class name string lengths
#
# Prior specs check IPv4Address.__name__ == 'IPv4Address' and
# IPv6Address.__name__ == 'IPv6Address' via __eq__ in multiple tables.
# No prior spec checks the length of these name strings.
# len('IPv4Address') == 11; len('IPv6Address') == 11.
# ---------------------------------------------------------------------------

invariant ipaddress_extra11.IPv4Address.name_len:
  description: "ipaddress.IPv4Address.__name__.__len__() == 11 — len('IPv4Address') == 11"
  category: class_metadata
  kind: python_call_eq
  function: IPv4Address.__name__.__len__
  args: []
  expected: 11

invariant ipaddress_extra11.IPv6Address.name_len:
  description: "ipaddress.IPv6Address.__name__.__len__() == 11 — len('IPv6Address') == 11"
  category: class_metadata
  kind: python_call_eq
  function: IPv6Address.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# IPv4Network and IPv6Network class name string lengths
#
# Same rationale as address class name lengths: __name__ == 'IPv4Network'
# and 'IPv6Network' are covered by __eq__ in multiple tables; the length
# (11 each) has not been checked.
# ---------------------------------------------------------------------------

invariant ipaddress_extra11.IPv4Network.name_len:
  description: "ipaddress.IPv4Network.__name__.__len__() == 11 — len('IPv4Network') == 11"
  category: class_metadata
  kind: python_call_eq
  function: IPv4Network.__name__.__len__
  args: []
  expected: 11

invariant ipaddress_extra11.IPv6Network.name_len:
  description: "ipaddress.IPv6Network.__name__.__len__() == 11 — len('IPv6Network') == 11"
  category: class_metadata
  kind: python_call_eq
  function: IPv6Network.__name__.__len__
  args: []
  expected: 11
