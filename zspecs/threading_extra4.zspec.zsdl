spec: threading_extra4
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Extends threading.zspec.zsdl, threading_extra.zspec.zsdl, threading_extra2.zspec.zsdl, threading_extra3.zspec.zsdl."
    - "threading.zspec.zsdl covers: class __name__ checks (Thread/Lock/RLock/Condition/Semaphore/BoundedSemaphore/Event/Timer/Barrier), function __name__ checks (current_thread/main_thread/active_count/enumerate), TIMEOUT_MAX, active_count_ge_1, Lock behavior, Event, Semaphore._value, current_thread.is_alive."
    - "threading_extra.zspec.zsdl covers: class __module__ for BoundedSemaphore/Condition/Semaphore/Event/RLock; local.__name__/__module__; current_thread class name is str; get_ident returns int; TIMEOUT_MAX is float; stack_size returns int."
    - "threading_extra2.zspec.zsdl covers: class __name__ table for all primitives; current_thread/__name__, main_thread/__name__, active_count/__name__ tables."
    - "threading_extra3.zspec.zsdl covers: Barrier __name__/__module__ standalone invariants; BrokenBarrierError __name__/__bases__/__mro__; local __name__/__module__ standalone; excepthook/__name__; current_thread/__name__, main_thread/__name__ standalone."
    - "This spec adds: Thread/__module__, Lock/__class__.__name__, RLock/__module__, Condition/__module__ standalone, Semaphore/__module__ standalone, BoundedSemaphore/__module__ standalone, Event/__module__ standalone, Timer/__module__, Thread/__bases__[0].__name__, Semaphore/__bases__[0].__name__, BoundedSemaphore/__bases__[0].__name__, Event/__bases__[0].__name__, Timer/__bases__[0].__name__, active_count/__name__ and enumerate/__name__ and settrace/__name__ as standalone invariants."
    - "threading.Thread.__module__ == 'threading' — Thread is defined in threading.py."
    - "threading.RLock.__module__ == 'threading' — RLock is defined in threading.py."
    - "threading.Timer.__module__ == 'threading' — Timer is defined in threading.py."
    - "threading.Thread.__bases__[0].__name__ == 'object' — Thread inherits directly from object."
    - "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore."
    - "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer is a Thread subclass."
    - "threading.Lock().__class__.__name__ is 'lock' (lowercase) — Lock() returns a C-level lock object."
    - "threading.active_count.__name__ == 'active_count' — function name confirmed."
    - "threading.enumerate.__name__ == 'enumerate' — threading.enumerate shadows the built-in enumerate."
    - "threading.settrace.__name__ == 'settrace' — sets a trace function for all future threads."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for Thread, RLock, and Timer — standalone invariants
#
# threading_extra covers BoundedSemaphore/Condition/Semaphore/Event/RLock module
# checks in a table. This spec adds Thread, RLock, and Timer as standalone
# named invariants covering the remaining primitives.
# ---------------------------------------------------------------------------

invariant threading_extra4.Thread.module:
  description: "threading.Thread.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra4.RLock.module:
  description: "threading.RLock.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra4.Timer.module:
  description: "threading.Timer.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for Condition, Semaphore, BoundedSemaphore, Event — standalone
#
# threading_extra.zspec.zsdl covers these in a table; this spec adds them
# as standalone named invariants for independent traceability.
# ---------------------------------------------------------------------------

invariant threading_extra4.Condition.module:
  description: "threading.Condition.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra4.Semaphore.module:
  description: "threading.Semaphore.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra4.BoundedSemaphore.module:
  description: "threading.BoundedSemaphore.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra4.Event.module:
  description: "threading.Event.__module__ == 'threading'"
  category: class_modules
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# Lock() instance class name
#
# threading.Lock() returns a C-level lock object whose class name is 'lock'
# (lowercase). The class Lock itself is a C-level allocator function, not a
# Python class in the usual sense; its __name__ is 'lock' (confirmed in the
# class_names table). Here we verify the instance's __class__.__name__.
# ---------------------------------------------------------------------------

invariant threading_extra4.Lock.instance_class_name:
  description: "threading.Lock().__class__.__name__ is 'lock' (lowercase) — C-level lock type"
  category: lock
  kind: python_call_eq
  function: Lock
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["lock"]
  expected: true

# ---------------------------------------------------------------------------
# Thread.__bases__[0].__name__ — Thread inherits from object
#
# threading.Thread is a pure-Python class whose only direct base is object.
# ---------------------------------------------------------------------------

invariant threading_extra4.Thread.base:
  description: "threading.Thread.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Thread.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Semaphore.__bases__[0].__name__ — Semaphore inherits from object
# ---------------------------------------------------------------------------

invariant threading_extra4.Semaphore.base:
  description: "threading.Semaphore.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Semaphore.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# BoundedSemaphore.__bases__[0].__name__ — BoundedSemaphore extends Semaphore
#
# threading.BoundedSemaphore is a subclass of Semaphore that raises ValueError
# when the semaphore count would exceed its initial value.
# ---------------------------------------------------------------------------

invariant threading_extra4.BoundedSemaphore.base:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundedSemaphore.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Semaphore"

# ---------------------------------------------------------------------------
# Event.__bases__[0].__name__ — Event inherits from object
# ---------------------------------------------------------------------------

invariant threading_extra4.Event.base:
  description: "threading.Event.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Event.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Timer.__bases__[0].__name__ — Timer is a Thread subclass
#
# threading.Timer is a Thread that executes a function after a delay. Its
# direct base class is Thread.
# ---------------------------------------------------------------------------

invariant threading_extra4.Timer.base:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread'"
  category: class_hierarchy
  kind: python_call_eq
  function: Timer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Thread"

# ---------------------------------------------------------------------------
# Function __name__ standalone invariants
#
# threading.zspec.zsdl and threading_extra2.zspec.zsdl cover active_count and
# enumerate in tables. This spec adds them as standalone named invariants for
# unambiguous individual traceability, and adds settrace (not covered elsewhere).
# ---------------------------------------------------------------------------

invariant threading_extra4.active_count.name:
  description: "threading.active_count.__name__ == 'active_count'"
  category: function_names
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra4.enumerate.name:
  description: "threading.enumerate.__name__ == 'enumerate' — shadows the built-in enumerate"
  category: function_names
  kind: python_call_eq
  function: enumerate.__name__.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra4.settrace.name:
  description: "threading.settrace.__name__ == 'settrace'"
  category: function_names
  kind: python_call_eq
  function: settrace.__name__.__eq__
  args: ["settrace"]
  expected: true
