spec: dc2866
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/decimal_extra2851.zspec.zsdl — wave 637 predecessor (covered __rlshift__, __rrshift__, __rpow__)"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 638 theme: __rand__, __ror__, __rxor__ dict-presence checks (reflected bitwise AND, OR, XOR operators)."
    - "decimal.Decimal is a full decimal numeric type but does NOT support bitwise operations — it defines no __rand__, __ror__, or __rxor__."
    - "Unlike int (which defines all bitwise ops), Decimal arithmetic is restricted to decimal arithmetic operations."
    - "decimal.Context is a configuration object — it does NOT define any reflected bitwise operators."
    - "decimal exception hierarchy classes (DecimalException and all subclasses) do NOT define any reflected bitwise operators."
    - "Absence is uniform across all decimal types — Decimal participates in arithmetic (including __rpow__) but not bitwise ops."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rand__ dict-presence
# Absent from Decimal (no bitwise ops), Context, and all exception classes
# ---------------------------------------------------------------------------

table dc2866.rand:
  description: "__rand__ is absent from all decimal types — Decimal arithmetic does not include bitwise AND"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2866

  columns: [id, function, args, expected]
  rows:
    - ["dc2866001", "decimal.Decimal.__dict__.__contains__",          ["__rand__"], false]
    - ["dc2866002", "decimal.Context.__dict__.__contains__",          ["__rand__"], false]
    - ["dc2866003", "decimal.DecimalException.__dict__.__contains__", ["__rand__"], false]
    - ["dc2866004", "decimal.InvalidOperation.__dict__.__contains__", ["__rand__"], false]
    - ["dc2866005", "decimal.DivisionByZero.__dict__.__contains__",   ["__rand__"], false]
    - ["dc2866006", "decimal.Overflow.__dict__.__contains__",         ["__rand__"], false]

