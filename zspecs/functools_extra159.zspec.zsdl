       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in Modules/_functoolsmodule.c; its __module__ is '_functools' (the private C module), not 'functools'; str.__eq__('_functools') returns True; new to extra159"]
    - [wraps_module_eq_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is a Python decorator function defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra159"]
    - [wraps_code_co_argcount_eq_3,
       "wraps.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) takes 3 positional-or-keyword arguments; co_argcount is 3; int.__eq__(3) returns True; new to extra159"]
    - [wraps_code_co_name_eq_wraps,
       "wraps.__code__.co_name.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__code__.co_name.__eq__('wraps') == True — the code object associated with the wraps function has co_name equal to the function name 'wraps'; str.__eq__('wraps') returns True; new to extra159"]

# ---------------------------------------------------------------------------
