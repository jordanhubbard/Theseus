    - "This spec covers: functools.reduce C builtin class name ('builtin_function_or_method') and module ('_functools'); functools.wraps __module__ 'functools', __code__.co_argcount 3, __code__.co_name 'wraps'; functools.update_wrapper __code__.co_argcount 4, __code__.co_name 'update_wrapper'; functools.WRAPPER_ASSIGNMENTS.__len__() 6 (Wave 283)."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin from _functoolsmodule.c; its __class__ is builtin_function_or_method. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce lives in the private C module _functools, not in the pure-Python functools wrapper. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' — wraps is a Python function defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_argcount == 3 — wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) has 3 positional-or-keyword arguments. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_name == 'wraps' — the code object's co_name is the function's name 'wraps'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_argcount == 4 — update_wrapper(wrapper, wrapped, assigned=..., updated=...) has 4 positional-or-keyword arguments. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_name == 'update_wrapper' — the code object's co_name is 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS is ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'), 6 items. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce — class name and module
#
# Wave 283 theme: functools.reduce and functools.wraps code attributes.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__module__ == '_functools'
# functools.wraps.__module__.__eq__('functools') == True
# functools.wraps.__code__.co_argcount == 3
#
# reduce is a C builtin from _functoolsmodule.c. Its __module__ is '_functools'
# (the private C extension), not 'functools' (the Python wrapper module). wraps
# is a pure-Python function in Lib/functools.py that takes 3 arguments.
# New to extra159.
# ---------------------------------------------------------------------------

table functools_extra159.reduce_and_wraps_code_attrs:
  description: "functools.reduce: class 'builtin_function_or_method', module '_functools'; functools.wraps: module 'functools', co_argcount 3, co_name 'wraps'; wave 283; new to extra159"
