# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra249.BufferedRandom.name_eq:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra249.BufferedRandom.module_is_underscore_io:
  description: "io.BufferedRandom.__module__ == '_io' — BufferedRandom is a C extension type defined in _io, not the pure Python ABC; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra249.BufferedRandom.module_not_io:
  description: "io.BufferedRandom.__module__ != 'io' — unlike IOBase ABCs, BufferedRandom is defined in _io (C extension), not 'io'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["io"]
  expected: false

invariant io_extra249.BufferedRandom.base_name_eq:
  description: "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom directly extends the C type _BufferedIOBase; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "BufferedRandom.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra249.BufferedRandom.class_is_type:
  description: "io.BufferedRandom.__class__.__name__ == 'type' — BufferedRandom is a C extension type with plain metaclass type, not ABCMeta; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra249.BufferedRandom.name_len:
  description: "len(io.BufferedRandom.__name__) == 14 — 'BufferedRandom' has 14 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__len__
  args: []
  expected: 14

invariant io_extra249.IncrementalNewlineDecoder.name_eq:
  description: "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__name__.__eq__
  args: ["IncrementalNewlineDecoder"]
  expected: true

invariant io_extra249.IncrementalNewlineDecoder.module_is_underscore_io:
  description: "io.IncrementalNewlineDecoder.__module__ == '_io' — IncrementalNewlineDecoder is a C extension type defined in _io; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra249.IncrementalNewlineDecoder.module_not_io:
  description: "io.IncrementalNewlineDecoder.__module__ != 'io' — IncrementalNewlineDecoder is a C extension in _io, not the pure Python io wrapper; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["io"]
  expected: false

invariant io_extra249.IncrementalNewlineDecoder.base_name_eq:
  description: "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder directly extends object, not a codec ABC; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant io_extra249.IncrementalNewlineDecoder.class_is_type:
  description: "io.IncrementalNewlineDecoder.__class__.__name__ == 'type' — IncrementalNewlineDecoder metaclass is plain type, not ABCMeta; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra249.IncrementalNewlineDecoder.name_len:
  description: "len(io.IncrementalNewlineDecoder.__name__) == 25 — 'IncrementalNewlineDecoder' has 25 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__name__.__len__
  args: []
  expected: 25
