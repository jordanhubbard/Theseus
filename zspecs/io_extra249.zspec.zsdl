  id_prefix: ioincnewl249

  columns: [id, function, args, expected]
  rows:
    - [incnewl_name_len,     IncrementalNewlineDecoder.__name__.__len__,     [], 25]
    - [incnewl_module_len,   IncrementalNewlineDecoder.__module__.__len__,   [], 3]
