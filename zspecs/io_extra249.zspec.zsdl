# ---------------------------------------------------------------------------

table io_extra249.IncrementalNewlineDecoder_name_module_qualname:
  description: "io.IncrementalNewlineDecoder class identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioincnewl249

  columns: [id, function, args, expected]
  rows:
    - [incnewl_name_eq,      IncrementalNewlineDecoder.__name__.__eq__,      ["IncrementalNewlineDecoder"], true]
    - [incnewl_name_not,     IncrementalNewlineDecoder.__name__.__eq__,      ["BufferedRandom"],            false]
    - [incnewl_module_eq,    IncrementalNewlineDecoder.__module__.__eq__,    ["_io"],                       true]
    - [incnewl_module_not,   IncrementalNewlineDecoder.__module__.__eq__,    ["io"],                        false]
    - [incnewl_qualname_eq,  IncrementalNewlineDecoder.__qualname__.__eq__,  ["IncrementalNewlineDecoder"], true]

