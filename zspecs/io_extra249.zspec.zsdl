spec: io_extra249
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Lib/io.py"
    - "io_extra248.zspec.zsdl — covers io.BufferedReader and io.BufferedWriter class identity"
    - "_io_extra.zspec.zsdl — covers _io-backend types"
  notes:
    - "This spec covers: io.BufferedRandom and io.IncrementalNewlineDecoder class identity — __name__, __module__, __bases__[0].__name__."
    - "io.BufferedRandom.__module__ == '_io' — BufferedRandom is a C extension type defined in _io, not a pure Python ABC; verified Python 3.14.3 macOS."
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom directly extends the C type _BufferedIOBase; verified Python 3.14.3 macOS."
    - "io.BufferedRandom.__class__.__name__ == 'type' — BufferedRandom is a plain C type, not an ABC; metaclass is type, not ABCMeta; verified Python 3.14.3 macOS."
    - "io.IncrementalNewlineDecoder.__module__ == '_io' — IncrementalNewlineDecoder is a C extension type in _io; verified Python 3.14.3 macOS."
    - "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder directly extends object (not a codec ABC); verified Python 3.14.3 macOS."
    - "io.IncrementalNewlineDecoder.__class__.__name__ == 'type' — IncrementalNewlineDecoder metaclass is type; verified Python 3.14.3 macOS."
    - "BufferedRandom.__name__ == 'BufferedRandom' — length 14; verified Python 3.14.3 macOS."
    - "BufferedRandom.__module__ == '_io' — length 3; verified Python 3.14.3 macOS."
    - "BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — length 15; verified Python 3.14.3 macOS."
    - "IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — length 25; verified Python 3.14.3 macOS."
    - "IncrementalNewlineDecoder.__module__ == '_io' — length 3; verified Python 3.14.3 macOS."
    - "IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — length 6; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedRandom class identity — __name__, __module__, __qualname__
# BufferedRandom is a C extension type in _io; __module__ == '_io', not 'io'.
# Its metaclass is plain type (not ABCMeta).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra249.BufferedRandom_name_module_qualname:
  description: "io.BufferedRandom class identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobuffrand249

  columns: [id, function, args, expected]
  rows:
    - [buffrand_name_eq,      BufferedRandom.__name__.__eq__,      ["BufferedRandom"], true]
    - [buffrand_name_not_bw,  BufferedRandom.__name__.__eq__,      ["BufferedWriter"], false]
    - [buffrand_module_eq,    BufferedRandom.__module__.__eq__,    ["_io"],            true]
    - [buffrand_module_not,   BufferedRandom.__module__.__eq__,    ["io"],             false]
    - [buffrand_qualname_eq,  BufferedRandom.__qualname__.__eq__,  ["BufferedRandom"], true]

# ---------------------------------------------------------------------------
# io.BufferedRandom __name__, __module__, __bases__[0].__name__ string lengths
# __name__='BufferedRandom' len=14, __module__='_io' len=3,
# __bases__[0].__name__='_BufferedIOBase' len=15.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra249.BufferedRandom_name_module_lengths:
  description: "io.BufferedRandom string lengths: __name__=14, __module__=3, __qualname__=14; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobuffrand249

  columns: [id, function, args, expected]
  rows:
    - [buffrand_name_len,     BufferedRandom.__name__.__len__,     [], 14]
    - [buffrand_module_len,   BufferedRandom.__module__.__len__,   [], 3]
    - [buffrand_qualname_len, BufferedRandom.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
