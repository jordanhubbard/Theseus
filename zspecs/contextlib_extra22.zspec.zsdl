spec: contextlib_extra22
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra21.zspec.zsdl."
    - "Prior specs cover: contextmanager/__name__/__qualname__/__module__/__class__.__name__; asynccontextmanager/__name__/__qualname__/__module__/__class__.__name__; closing/__name__/__qualname__/__module__/__bases__/__mro__/__class__.__name__; suppress/__name__/__qualname__/__module__/__bases__/__mro__/__class__.__name__; redirect_stdout/__name__/__qualname__/__module__/__bases__/__mro__/__class__.__name__; redirect_stderr/__name__/__qualname__/__module__/__bases__/__mro__/__class__.__name__; ExitStack/__name__/__qualname__/__module__/__bases__/__mro__/__class__.__name__; AsyncExitStack/__name__/__qualname__/__module__/__bases__/__mro__/__class__.__name__."
    - "This spec covers: ExitStack.__enter__/__exit__ method __name__ and __qualname__; AsyncExitStack.__aenter__/__aexit__ method __name__ and __qualname__. No prior contextlib spec records these method-level identity attributes."
    - "contextlib.ExitStack.__enter__.__qualname__ == 'ExitStack.__enter__' and contextlib.ExitStack.__exit__.__qualname__ == 'ExitStack.__exit__'."
    - "contextlib.AsyncExitStack.__aenter__.__qualname__ == 'AsyncExitStack.__aenter__' and contextlib.AsyncExitStack.__aexit__.__qualname__ == 'AsyncExitStack.__aexit__'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ExitStack.__enter__ and __exit__ — method identity attributes
#
# No prior contextlib spec records __name__ or __qualname__ for ExitStack's
# context manager protocol methods. These are instance methods defined
# directly on ExitStack (not inherited), so __qualname__ reflects the
# class ownership.
# ---------------------------------------------------------------------------

table contextlib_extra22.ExitStack_cm_methods:
  description: "__name__ and __qualname__ for ExitStack.__enter__ and __exit__"
  kind: python_call_eq
  category: method_identity

  columns: [id, function, args, expected]
  rows:
    - [enter_name,     ExitStack.__enter__.__name__.__eq__,     ["__enter__"],          true]
    - [enter_qualname, ExitStack.__enter__.__qualname__.__eq__, ["ExitStack.__enter__"], true]
    - [exit_name,      ExitStack.__exit__.__name__.__eq__,      ["__exit__"],           true]
    - [exit_qualname,  ExitStack.__exit__.__qualname__.__eq__,  ["ExitStack.__exit__"],  true]

# ---------------------------------------------------------------------------
# AsyncExitStack.__aenter__ and __aexit__ — method identity attributes
#
# No prior contextlib spec records __name__ or __qualname__ for
# AsyncExitStack's async context manager protocol methods. These methods
# are defined directly on AsyncExitStack.
# ---------------------------------------------------------------------------

table contextlib_extra22.AsyncExitStack_cm_methods:
  description: "__name__ and __qualname__ for AsyncExitStack.__aenter__ and __aexit__"
  kind: python_call_eq
  category: method_identity

  columns: [id, function, args, expected]
  rows:
    - [aenter_name,     AsyncExitStack.__aenter__.__name__.__eq__,     ["__aenter__"],               true]
    - [aenter_qualname, AsyncExitStack.__aenter__.__qualname__.__eq__, ["AsyncExitStack.__aenter__"], true]
    - [aexit_name,      AsyncExitStack.__aexit__.__name__.__eq__,      ["__aexit__"],                true]
    - [aexit_qualname,  AsyncExitStack.__aexit__.__qualname__.__eq__,  ["AsyncExitStack.__aexit__"],  true]
