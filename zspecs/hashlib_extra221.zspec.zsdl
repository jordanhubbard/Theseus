spec: hashlib_extra221
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.md5().hexdigest().__len__() == 32 (128-bit digest, 2 hex chars per byte)."
    - "hashlib.sha1().hexdigest().__len__() == 40 (160-bit digest, 2 hex chars per byte)."
    - "hashlib.sha256().hexdigest().__len__() == 64 (256-bit digest, 2 hex chars per byte)."
    - "hashlib.sha512().hexdigest().__len__() == 128 (512-bit digest, 2 hex chars per byte)."
    - "hashlib.md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592'."
    - "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855'."
    - "hashlib.new.__name__ == '__hash_new'; hashlib.new.__module__ == 'hashlib'."
    - "hashlib.md5().__class__.__name__ == 'HASH'; hashlib.md5().__class__.__module__ == '_hashlib'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH object hexdigest() length checks
#
# hashlib.md5().hexdigest().__len__()    == 32
# hashlib.sha1().hexdigest().__len__()   == 40
# hashlib.sha256().hexdigest().__len__() == 64
# hashlib.sha512().hexdigest().__len__() == 128
#
# Each algorithm produces a digest of fixed bit width; the hex digest is
# exactly twice the digest_size in bytes (2 hex chars per byte).
# ---------------------------------------------------------------------------

table hashlib_extra221.hexdigest_lengths:
  description: "hashlib HASH object hexdigest() string length checks in hashlib221 namespace — wave 221 theme: md5 hexdigest is 32 chars (128-bit/16-byte * 2); sha1 is 40 chars (160-bit/20-byte * 2); sha256 is 64 chars (256-bit/32-byte * 2); sha512 is 128 chars (512-bit/64-byte * 2); these are fixed by the FIPS 180-4 digest sizes; verified with Python 3.14.3"
  kind: python_call_eq
  category: hexdigest_length
  id_prefix: hashlib221

  columns: [id, function, args, expected, description]
  rows:
    - [md5_hexdigest_len,    "hashlib.md5().hexdigest().__len__",    [], 32,  "hashlib.md5().hexdigest().__len__() == 32 — MD5 produces 128-bit (16-byte) digest; hex is 32 chars"]
    - [sha1_hexdigest_len,   "hashlib.sha1().hexdigest().__len__",   [], 40,  "hashlib.sha1().hexdigest().__len__() == 40 — SHA-1 produces 160-bit (20-byte) digest; hex is 40 chars"]
    - [sha256_hexdigest_len, "hashlib.sha256().hexdigest().__len__", [], 64,  "hashlib.sha256().hexdigest().__len__() == 64 — SHA-256 produces 256-bit (32-byte) digest; hex is 64 chars"]
    - [sha512_hexdigest_len, "hashlib.sha512().hexdigest().__len__", [], 128, "hashlib.sha512().hexdigest().__len__() == 128 — SHA-512 produces 512-bit (64-byte) digest; hex is 128 chars"]

# ---------------------------------------------------------------------------
# HASH object hexdigest() known values
#
# hashlib.md5(b'hello').hexdigest()  == '5d41402abc4b2a76b9719d911017c592'
# hashlib.sha256(b'').hexdigest()    == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855'
# ---------------------------------------------------------------------------

table hashlib_extra221.hexdigest_known_values:
  description: "hashlib HASH object hexdigest() known test-vector checks in hashlib221a namespace — wave 221 theme: md5(b'hello') is the canonical MD5 test vector '5d41402abc4b2a76b9719d911017c592'; sha256(b'') is the SHA-256 hash of the empty string per FIPS 180-4; both verified with Python 3.14.3"
  kind: python_call_eq
  category: hexdigest_values
  id_prefix: hashlib221a

  columns: [id, function, args, expected, description]
  rows:
    - [md5_hello,      "hashlib.md5(b'hello').hexdigest().__eq__",   ["5d41402abc4b2a76b9719d911017c592"],                                                 true,  "hashlib.md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592' — canonical MD5 test vector for ASCII 'hello'"]
    - [sha256_empty,   "hashlib.sha256(b'').hexdigest().__eq__",     ["e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"], true,  "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — SHA-256 of empty string per FIPS 180-4"]

# ---------------------------------------------------------------------------
# hashlib.new function identity
#
# hashlib.new.__name__   == '__hash_new'
# hashlib.new.__module__ == 'hashlib'
# ---------------------------------------------------------------------------

table hashlib_extra221.new_function_identity:
  description: "hashlib.new function __name__ and __module__ checks in hashlib221b namespace — wave 221 theme: new.__name__ == '__hash_new' (internal wrapper name); new.__module__ == 'hashlib' (defined in the Python-level hashlib module); verified with Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib221b

  columns: [id, function, args, expected, description]
  rows:
    - [new_name,   "hashlib.new.__name__.__eq__",   ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' — the hashlib.new wrapper function's internal name"]
    - [new_module, "hashlib.new.__module__.__eq__", ["hashlib"],    true, "hashlib.new.__module__ == 'hashlib' — new is defined in the Python-level hashlib module"]

# ---------------------------------------------------------------------------
# HASH object class identity
#
# hashlib.md5().__class__.__name__   == 'HASH'
# hashlib.md5().__class__.__module__ == '_hashlib'
# ---------------------------------------------------------------------------

invariant hashlib_extra221.hash_class_name:
  description: "hashlib.md5().__class__.__name__ == 'HASH' — the class of a hash object created by hashlib.md5() is named 'HASH'; this is the OpenSSL-backed HASH type from the _hashlib C extension; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true

invariant hashlib_extra221.hash_class_module:
  description: "hashlib.md5().__class__.__module__ == '_hashlib' — the HASH class is defined in the _hashlib C extension module; all OpenSSL-backed hash objects share this class; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5().__class__.__module__.__eq__"
  args: ["_hashlib"]
  expected: true
