spec: fractions_extra16
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra through fractions_extra15."
    - "fractions_extra6 covers Fraction.__mro__.__len__() == 6 and MRO[0,3] __name__."
    - "fractions_extra7 covers MRO[4,5] __name__ (Number, object)."
    - "fractions_extra8 covers Fraction.__mro__.__getitem__ at indices 1 and 2 (Rational, Real)."
    - "fractions_extra8 covers Fraction.__bases__.__len__ == 1."
    - "No prior spec covers Fraction.__bases__[0].__name__, __qualname__, or __module__ using chained notation."
    - "No prior spec covers Fraction.__qualname__.__len__ or Fraction.__bases__[0].__abstractmethods__.__len__."
    - "fractions.Fraction.__bases__[0].__name__ == 'Rational' — Fraction directly subclasses numbers.Rational."
    - "fractions.Fraction.__bases__[0].__qualname__ == 'Rational' — Rational is a top-level class."
    - "fractions.Fraction.__bases__[0].__module__ == 'numbers' — Rational is defined in the numbers module."
    - "fractions.Fraction.__qualname__.__len__() == 8 — 'Fraction' is 8 characters."
    - "len(Fraction.__bases__[0].__abstractmethods__) == 24 — Rational defines 24 abstract methods."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.__bases__[0] identity attributes
#
# Prior fractions specs use Fraction.__bases__.__getitem__ (call form) which
# returns the raw class object.  This spec records the base-class name,
# qualname, and module as string comparisons via the chained dot notation —
# a distinct expression form not previously captured.
# ---------------------------------------------------------------------------

table fractions_extra16.bases_identity:
  kind: python_call_eq
  category: class_identity
  id_prefix: base_attr

  columns: [id, function, args, expected, description]
  rows:
    - [name,     "Fraction.__bases__[0].__name__.__eq__",     ["Rational"], true, "Fraction's direct base class name is 'Rational'"]
    - [qualname, "Fraction.__bases__[0].__qualname__.__eq__", ["Rational"], true, "Rational is a top-level class — qualname equals name"]
    - [module,   "Fraction.__bases__[0].__module__.__eq__",   ["numbers"],  true, "Rational is defined in the numbers module"]

# ---------------------------------------------------------------------------
# Additional Fraction class-level attribute invariants
#
# These cover expression forms not recorded in any prior fractions_extra spec.
# ---------------------------------------------------------------------------

invariant fractions_extra16.Fraction.qualname_len:
  description: "len(fractions.Fraction.__qualname__) == 8 — 'Fraction' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__qualname__.__len__
  args: []
  expected: 8

invariant fractions_extra16.Fraction.bases_absmethods_len:
  description: "len(fractions.Fraction.__bases__[0].__abstractmethods__) == 24 — numbers.Rational defines 24 abstract methods"
  category: class_hierarchy
  kind: python_call_eq
  function: "Fraction.__bases__[0].__abstractmethods__.__len__"
  args: []
  expected: 24

invariant fractions_extra16.Fraction.bases_absmethods_contains_numerator:
  description: "fractions.Fraction.__bases__[0].__abstractmethods__ contains 'numerator' — numerator is abstract in Rational"
  category: class_hierarchy
  kind: python_call_eq
  function: "Fraction.__bases__[0].__abstractmethods__.__contains__"
  args: ["numerator"]
  expected: true

invariant fractions_extra16.Fraction.bases_absmethods_contains_denominator:
  description: "fractions.Fraction.__bases__[0].__abstractmethods__ contains 'denominator' — denominator is abstract in Rational"
  category: class_hierarchy
  kind: python_call_eq
  function: "Fraction.__bases__[0].__abstractmethods__.__contains__"
  args: ["denominator"]
  expected: true
