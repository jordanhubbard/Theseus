spec: uuid_extra2491
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
    - "uuid_extra.zspec.zsdl — covers function names, uuid4 return type/version, NAMESPACE_* constants, .int/.hex attribute types"
    - "uuid_extra161.zspec.zsdl — pre-existing; separate concerns"
    - "uuid_extra180.zspec.zsdl — pre-existing; separate concerns"
  notes:
    - "Wave extra2491, theme: __setitem__, __delitem__, and __missing__ dict-presence."
    - "Checks whether uuid.UUID defines mutable item access or missing-key protocol in its class __dict__."
    - "uuid.UUID is an immutable record type using __slots__; it defines __setattr__ to block attribute mutation but defines no item-access protocol."
    - "uuid.UUID.__dict__ contains: __doc__, __eq__, __firstlineno__, __ge__, __getstate__, __gt__, __hash__, __init__, __int__, __le__, __lt__, __module__, __repr__, __setattr__, __setstate__, __slots__, __static_attributes__, __str__, __weakref__, _from_int, bytes, bytes_le, clock_seq, clock_seq_hi_variant, clock_seq_low, fields, hex, int, is_safe, node, time, time_hi_version, time_low, time_mid, urn, variant, version."
    - "__setattr__ IS in UUID.__dict__ (used to block attribute mutation), but __setitem__ is NOT — these are orthogonal protocols."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — __setitem__ absent from class __dict__
# UUID is not a mutable mapping; no item-setting protocol is defined.
# Note: __setattr__ IS defined (to prevent attribute mutation) but __setitem__
# is a distinct protocol used for subscript assignment obj[key] = value.
# ---------------------------------------------------------------------------

table uuid_extra2491.UUID_setitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2491

  columns: [id, function, args, expected]
  rows:
    - ["uu2491001", UUID.__dict__.__contains__, ["__setitem__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID — __delitem__ absent from class __dict__
# Item deletion protocol is not defined on uuid.UUID.
# ---------------------------------------------------------------------------

table uuid_extra2491.UUID_delitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2491

  columns: [id, function, args, expected]
  rows:
    - ["uu2491002", UUID.__dict__.__contains__, ["__delitem__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID — __missing__ absent from class __dict__
# Missing-key fallback protocol is not defined on uuid.UUID.
# ---------------------------------------------------------------------------

table uuid_extra2491.UUID_missing_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2491

  columns: [id, function, args, expected]
  rows:
    - ["uu2491003", UUID.__dict__.__contains__, ["__missing__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID — __getitem__ also absent (related sanity check)
# Confirms UUID defines no item-access protocol at all.
# ---------------------------------------------------------------------------

table uuid_extra2491.UUID_getitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2491

  columns: [id, function, args, expected]
  rows:
    - ["uu2491004", UUID.__dict__.__contains__, ["__getitem__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID — real attributes present in __dict__ (positive anchors)
# Verifies that __dict__.__contains__ works correctly for UUID.
# These are attributes documented as part of the UUID public API.
# ---------------------------------------------------------------------------

table uuid_extra2491.UUID_real_attrs_present:
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2491

  columns: [id, function, args, expected]
  rows:
    - ["uu2491005", UUID.__dict__.__contains__, ["__setattr__"],  true]
    - ["uu2491006", UUID.__dict__.__contains__, ["__slots__"],    true]
    - ["uu2491007", UUID.__dict__.__contains__, ["__init__"],     true]
    - ["uu2491008", UUID.__dict__.__contains__, ["__repr__"],     true]
    - ["uu2491009", UUID.__dict__.__contains__, ["__str__"],      true]
    - ["uu2491010", UUID.__dict__.__contains__, ["__eq__"],       true]
    - ["uu2491011", UUID.__dict__.__contains__, ["__hash__"],     true]
    - ["uu2491012", UUID.__dict__.__contains__, ["hex"],          true]
    - ["uu2491013", UUID.__dict__.__contains__, ["int"],          true]
    - ["uu2491014", UUID.__dict__.__contains__, ["bytes"],        true]
    - ["uu2491015", UUID.__dict__.__contains__, ["fields"],       true]
    - ["uu2491016", UUID.__dict__.__contains__, ["urn"],          true]
    - ["uu2491017", UUID.__dict__.__contains__, ["version"],      true]
    - ["uu2491018", UUID.__dict__.__contains__, ["variant"],      true]
