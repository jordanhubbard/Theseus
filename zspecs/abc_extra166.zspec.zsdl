spec: abc_extra166
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.abstractclassmethod.__name__=='abstractclassmethod' (deprecated, still present in Python 3.14.3); abc.abstractstaticmethod.__name__=='abstractstaticmethod' (deprecated, still present); abc.abstractproperty.__bases__[0].__name__=='property' (cross-check from extra165); abc.abstractclassmethod.__bases__[0].__name__=='classmethod'; abc.abstractstaticmethod.__bases__[0].__name__=='staticmethod'. KEY FINDINGS: all three deprecated ABC decorators (abstractclassmethod, abstractstaticmethod, abstractproperty) are still present and accessible in Python 3.14.3; all three inherit from their non-abstract counterparts (property, classmethod, staticmethod respectively); all three have __module__=='abc' (len=3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractclassmethod.__name__=='abstractclassmethod' (len=19: 'abstract'=8+'classmethod'=11=19); __module__=='abc' (len=3); __bases__[0].__name__=='classmethod' (len=11: 'classmethod'=11); deprecated since Python 3.3 — use @classmethod + @abstractmethod instead. Verified with Python 3.14.3."
    - "abc.abstractstaticmethod.__name__=='abstractstaticmethod' (len=20: 'abstract'=8+'staticmethod'=12=20); __module__=='abc' (len=3); __bases__[0].__name__=='staticmethod' (len=12: 'staticmethod'=12); deprecated since Python 3.3 — use @staticmethod + @abstractmethod instead. Verified with Python 3.14.3."
    - "abc.abstractproperty.__name__=='abstractproperty' (len=16: 'abstract'=8+'property'=8=16); established in extra165; __bases__[0].__name__=='property' (len=8); deprecated since Python 3.3. Verified with Python 3.14.3."
    - "NAME LENGTH ORDERING of deprecated abc decorators: abstractproperty(16) < abstractclassmethod(19) < abstractstaticmethod(20). BASE CLASS NAME LENGTHS: property(8) < classmethod(11) < staticmethod(12). All three have __module__=='abc' (len=3). All verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractclassmethod class name and module identity — extra166
#
# abc.abstractclassmethod.__name__.__eq__('abstractclassmethod') == True
# abc.abstractclassmethod.__name__.__len__()                     == 19
# abc.abstractclassmethod.__module__.__eq__('abc')               == True
# abc.abstractclassmethod.__module__.__len__()                   == 3
# ---------------------------------------------------------------------------

table abc_extra166.abc_abstractclassmethod_identity:
  description: "abc.abstractclassmethod class name and module identity checks in abcacm166 namespace — abc.abstractclassmethod.__name__.__eq__('abstractclassmethod')==True (abstractclassmethod.__name__=='abstractclassmethod' (len=19: 'abstract'=8+'classmethod'=11=19); abc.abstractclassmethod is DEPRECATED since Python 3.3 — use @classmethod combined with @abstractmethod instead; despite being deprecated, abstractclassmethod is still present and importable in Python 3.14.3; it was the original way to mark a classmethod as abstract before Python gained support for stacking decorators); abc.abstractclassmethod.__name__.__len__()==19 ('abstractclassmethod'=19: 'abstract'=8+'classmethod'=11=19; longer than abstractproperty=16 (extra165) because 'classmethod'=11 > 'property'=8 by 3; shorter than abstractstaticmethod=20 because 'classmethod'=11 < 'staticmethod'=12 by 1); abc.abstractclassmethod.__module__.__eq__('abc')==True (abstractclassmethod.__module__=='abc' (len=3: 'a'+'b'+'c'=3); same module as all abc members); abc.abstractclassmethod.__module__.__len__()==3 ('abc'=3; the shortest module path in this spec series); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcacm166

  columns: [id, function, args, expected, description]
  rows:
    - [acm_name_eq,  abc.abstractclassmethod.__name__.__eq__,    ["abstractclassmethod"],  true,  "abstractclassmethod.__name__ == 'abstractclassmethod' (len=19: 'abstract'=8+'classmethod'=11=19; deprecated); verified with Python 3.14.3"]
    - [acm_name_len, abc.abstractclassmethod.__name__.__len__,   [],                       19,    "abstractclassmethod.__name__.__len__() == 19 ('abstractclassmethod'=19; 3 longer than abstractproperty=16); verified with Python 3.14.3"]
    - [acm_mod_eq,   abc.abstractclassmethod.__module__.__eq__,  ["abc"],                  true,  "abstractclassmethod.__module__ == 'abc' (len=3; same module as all abc classes); verified with Python 3.14.3"]
    - [acm_mod_len,  abc.abstractclassmethod.__module__.__len__, [],                       3,     "abstractclassmethod.__module__.__len__() == 3 ('abc'=3; shortest module path in spec series); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractstaticmethod class name and module identity — extra166
#
# abc.abstractstaticmethod.__name__.__eq__('abstractstaticmethod') == True
# abc.abstractstaticmethod.__name__.__len__()                      == 20
# abc.abstractstaticmethod.__module__.__eq__('abc')                == True
# abc.abstractstaticmethod.__module__.__len__()                    == 3
# ---------------------------------------------------------------------------

table abc_extra166.abc_abstractstaticmethod_identity:
  description: "abc.abstractstaticmethod class name and module identity checks in abcasm166 namespace — abc.abstractstaticmethod.__name__.__eq__('abstractstaticmethod')==True (abstractstaticmethod.__name__=='abstractstaticmethod' (len=20: 'abstract'=8+'staticmethod'=12=20); abc.abstractstaticmethod is DEPRECATED since Python 3.3 — use @staticmethod combined with @abstractmethod instead; still present and importable in Python 3.14.3); abc.abstractstaticmethod.__name__.__len__()==20 ('abstractstaticmethod'=20: 'abstract'=8+'staticmethod'=12=20; the longest of the three deprecated decorator names: abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20; 'staticmethod'=12 > 'classmethod'=11 > 'property'=8 — the name length ordering matches the base class name length ordering); abc.abstractstaticmethod.__module__.__eq__('abc')==True (abstractstaticmethod.__module__=='abc' (len=3; same as all abc members)); abc.abstractstaticmethod.__module__.__len__()==3 ('abc'=3; same as abstractclassmethod and abstractproperty modules); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcasm166

  columns: [id, function, args, expected, description]
  rows:
    - [asm_name_eq,  abc.abstractstaticmethod.__name__.__eq__,    ["abstractstaticmethod"],  true,  "abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20: 'abstract'=8+'staticmethod'=12=20; deprecated); verified with Python 3.14.3"]
    - [asm_name_len, abc.abstractstaticmethod.__name__.__len__,   [],                        20,    "abstractstaticmethod.__name__.__len__() == 20 ('abstractstaticmethod'=20; longest deprecated decorator name); verified with Python 3.14.3"]
    - [asm_mod_eq,   abc.abstractstaticmethod.__module__.__eq__,  ["abc"],                   true,  "abstractstaticmethod.__module__ == 'abc' (len=3; same module as all abc members); verified with Python 3.14.3"]
    - [asm_mod_len,  abc.abstractstaticmethod.__module__.__len__, [],                        3,     "abstractstaticmethod.__module__.__len__() == 3 ('abc'=3; same as abstractclassmethod and abstractproperty); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractclassmethod.__bases__[0].__name__ — extra166
#
# abc.abstractclassmethod.__bases__[0].__name__.__eq__('classmethod') == True
# abc.abstractclassmethod.__bases__[0].__name__.__len__()             == 11
# ---------------------------------------------------------------------------

table abc_extra166.abc_abstractclassmethod_base:
  description: "abc.abstractclassmethod base class name checks in abcacmbase166 namespace — abc.abstractclassmethod.__bases__[0].__name__.__eq__('classmethod')==True (abstractclassmethod.__bases__[0].__name__=='classmethod' (len=11: 'classmethod'=11); abstractclassmethod inherits from the built-in classmethod descriptor; a classmethod receives the class as its first argument (cls) instead of the instance (self); abstractclassmethod adds __isabstractmethod__=True signaling that the method must be overridden in concrete subclasses; the class hierarchy is: abstractclassmethod -> classmethod -> object); abc.abstractclassmethod.__bases__[0].__name__.__len__()==11 ('classmethod'=11: len 11, same as BaseProcess.__name__.__len__()==11 (coincidence); 'classmethod'=11 is 3 longer than 'property'=8 (abstractproperty's base) and 1 shorter than 'staticmethod'=12 (abstractstaticmethod's base)); abc.abstractclassmethod.__name__.__eq__('abstractclassmethod')==True (cross-check; len=19); abc.abstractclassmethod.__module__.__eq__('abc')==True (cross-check; len=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcacmbase166

  columns: [id, function, args, expected, description]
  rows:
    - [acm_base_name_eq,  "abc.abstractclassmethod.__bases__[0].__name__.__eq__",   ["classmethod"],          true,  "abstractclassmethod.__bases__[0].__name__ == 'classmethod' (len=11; inherits from built-in classmethod); verified with Python 3.14.3"]
    - [acm_base_name_len, "abc.abstractclassmethod.__bases__[0].__name__.__len__",  [],                       11,    "abstractclassmethod.__bases__[0].__name__.__len__() == 11 ('classmethod'=11; 3 longer than property=8); verified with Python 3.14.3"]
    - [acm_name_eq2,      abc.abstractclassmethod.__name__.__eq__,                  ["abstractclassmethod"],  true,  "abstractclassmethod.__name__ == 'abstractclassmethod' (cross-check; len=19); verified with Python 3.14.3"]
    - [acm_mod_eq2,       abc.abstractclassmethod.__module__.__eq__,                ["abc"],                  true,  "abstractclassmethod.__module__ == 'abc' (cross-check; len=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractstaticmethod.__bases__[0].__name__ — extra166
#
# abc.abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod') == True
# abc.abstractstaticmethod.__bases__[0].__name__.__len__()              == 12
# ---------------------------------------------------------------------------

table abc_extra166.abc_abstractstaticmethod_base:
  description: "abc.abstractstaticmethod base class name checks and cross-comparison in abcasmbase166 namespace — abc.abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod')==True (abstractstaticmethod.__bases__[0].__name__=='staticmethod' (len=12: 'staticmethod'=12); abstractstaticmethod inherits from the built-in staticmethod descriptor; a staticmethod receives neither self nor cls — it behaves like a regular function but lives in the class namespace; abstractstaticmethod adds __isabstractmethod__=True; class hierarchy: abstractstaticmethod -> staticmethod -> object); abc.abstractstaticmethod.__bases__[0].__name__.__len__()==12 ('staticmethod'=12: 1 longer than 'classmethod'=11 (abstractclassmethod's base) and 4 longer than 'property'=8 (abstractproperty's base from extra165); BASE NAME ORDERING: property(8) < classmethod(11) < staticmethod(12)); abc.abstractproperty.__bases__[0].__name__.__eq__('property')==True (cross-check from extra165: abstractproperty also inherits from its non-abstract counterpart); abc.abstractstaticmethod.__name__.__eq__('abstractstaticmethod')==True (cross-check; len=20); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcasmbase166

  columns: [id, function, args, expected, description]
  rows:
    - [asm_base_name_eq,  "abc.abstractstaticmethod.__bases__[0].__name__.__eq__",   ["staticmethod"],          true,  "abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' (len=12; inherits from built-in staticmethod); verified with Python 3.14.3"]
    - [asm_base_name_len, "abc.abstractstaticmethod.__bases__[0].__name__.__len__",  [],                        12,    "abstractstaticmethod.__bases__[0].__name__.__len__() == 12 ('staticmethod'=12; longest base name: property=8 < classmethod=11 < staticmethod=12); verified with Python 3.14.3"]
    - [ap_base_xcheck,    "abc.abstractproperty.__bases__[0].__name__.__eq__",       ["property"],              true,  "abstractproperty.__bases__[0].__name__ == 'property' (cross-check from extra165; base name len=8); verified with Python 3.14.3"]
    - [asm_name_eq2,      abc.abstractstaticmethod.__name__.__eq__,                  ["abstractstaticmethod"],  true,  "abstractstaticmethod.__name__ == 'abstractstaticmethod' (cross-check; len=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra166
# ---------------------------------------------------------------------------

invariant abc_extra166.abc_abstractclassmethod_name_eq:
  description: "abc.abstractclassmethod.__name__.__eq__('abstractclassmethod') returns True — abc.abstractclassmethod.__name__=='abstractclassmethod' (len=19: 'abstract'=8+'classmethod'=11=19); abc.abstractclassmethod is DEPRECATED since Python 3.3 — the modern idiom is to stack @classmethod and @abstractmethod; however, abstractclassmethod is still present in Python 3.14.3 and usable; a class using abstractclassmethod but not providing a concrete classmethod override cannot be instantiated (ABCMeta blocks instantiation if __abstractmethods__ is non-empty); abstractclassmethod inherits from classmethod (built-in descriptor) and sets __isabstractmethod__=True; DEPRECATED TRIO: abstractproperty(16), abstractclassmethod(19), abstractstaticmethod(20) — all deprecated in Python 3.3, all still alive in Python 3.14.3, all in the 'abc' module, all following the pattern of inheriting from the non-abstract base descriptor; NEW in extra166: first standalone abstractclassmethod.__name__ identity invariant in abcacm166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractclassmethod.__name__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra166.abc_abstractclassmethod_module_eq:
  description: "abc.abstractclassmethod.__module__.__eq__('abc') returns True — abc.abstractclassmethod.__module__=='abc' (len=3: 'a'+'b'+'c'=3); abstractclassmethod is defined in Lib/abc.py alongside ABC, ABCMeta, abstractmethod, abstractproperty, and abstractstaticmethod; all members of the abc module share __module__=='abc' (len=3); 'abc'=3 is the shortest module path in the entire spec series: 'abc'=3 < '_asyncio'=8 < 'asyncio.events'=14 < 'asyncio.runners'=15 < 'multiprocessing.context'=23 == 'multiprocessing.process'=23; abstractclassmethod.__name__='abstractclassmethod'=19 has a name 16x longer than its module path 'abc'=3 — the largest name-to-module-length ratio in this spec series (name/module: abstractclassmethod=19/3=6.3x vs abstractstaticmethod=20/3=6.7x vs abstractproperty=16/3=5.3x); NEW in extra166: first standalone abstractclassmethod.__module__ invariant in abcacm166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractclassmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra166.abc_abstractclassmethod_base_is_classmethod:
  description: "abc.abstractclassmethod.__bases__[0].__name__.__eq__('classmethod') returns True — abc.abstractclassmethod.__bases__[0].__name__=='classmethod' (len=11: 'classmethod'=11); abstractclassmethod inherits from the built-in classmethod descriptor; classmethods receive the class as the first argument (cls) and can be called on the class itself or any instance; abstractclassmethod marks such a method as abstract — subclasses must provide a concrete classmethod override or they cannot be instantiated; PATTERN: all three deprecated abc decorators follow the same pattern — each inherits from the corresponding built-in descriptor and adds __isabstractmethod__=True: abstractproperty -> property(8), abstractclassmethod -> classmethod(11), abstractstaticmethod -> staticmethod(12); the 'abstract' prefix (8 chars) is prepended to the base descriptor name in each case; BASE NAME LENGTHS: property(8) < classmethod(11) < staticmethod(12) — one char longer at each step; NEW in extra166: first standalone abstractclassmethod.__bases__[0].__name__ invariant in abcacmbase166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.abstractclassmethod.__bases__[0].__name__.__eq__"
  args: ["classmethod"]
  expected: true

invariant abc_extra166.abc_abstractstaticmethod_name_eq:
  description: "abc.abstractstaticmethod.__name__.__eq__('abstractstaticmethod') returns True — abc.abstractstaticmethod.__name__=='abstractstaticmethod' (len=20: 'abstract'=8+'staticmethod'=12=20); abc.abstractstaticmethod is DEPRECATED since Python 3.3 — use @staticmethod + @abstractmethod instead; still present in Python 3.14.3; abstractstaticmethod is the longest name among the deprecated abc decorators: abstractproperty(16) < abstractclassmethod(19) < abstractstaticmethod(20); 'abstractstaticmethod'=20 is the longest class name encountered in this abc spec series (compare: 'abstractclassmethod'=19, 'abstractproperty'=16, 'ABCMeta'=7, 'ABC'=3); abstractstaticmethod's base is 'staticmethod'=12 (the longest of the three base descriptors: property=8 < classmethod=11 < staticmethod=12) — the length ranking of the decorator names mirrors the length ranking of their base class names; NEW in extra166: first standalone abstractstaticmethod.__name__ identity invariant in abcasm166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractstaticmethod.__name__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra166.abc_abstractstaticmethod_base_is_staticmethod:
  description: "abc.abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod') returns True — abc.abstractstaticmethod.__bases__[0].__name__=='staticmethod' (len=12: 'staticmethod'=12); abstractstaticmethod inherits from the built-in staticmethod descriptor; staticmethods receive neither self nor cls — they are plain functions namespaced in a class; abstractstaticmethod marks such a method as abstract — subclasses must provide a concrete staticmethod override; the three deprecated decorators all share the 'abstract' + base_name pattern: abstractproperty(property=8), abstractclassmethod(classmethod=11), abstractstaticmethod(staticmethod=12); 'staticmethod'=12 is 1 longer than 'classmethod'=11 and 4 longer than 'property'=8; this single-char difference between classmethod(11) and staticmethod(12) propagates to the decorator name lengths: abstractclassmethod(19) vs abstractstaticmethod(20) — also differ by 1; COMPARE: abc.abstractproperty.__bases__[0].__name__=='property' (len=8; from extra165; same pattern, smallest base); NEW in extra166: first standalone abstractstaticmethod.__bases__[0].__name__ invariant in abcasmbase166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.abstractstaticmethod.__bases__[0].__name__.__eq__"
  args: ["staticmethod"]
  expected: true

invariant abc_extra166.abc_abstractproperty_base_crosscheck:
  description: "abc.abstractproperty.__bases__[0].__name__.__eq__('property') returns True — cross-check of extra165 value in extra166 namespace: abc.abstractproperty.__bases__[0].__name__=='property' (len=8: 'property'=8); established in extra165 as the key finding there; confirmed here to anchor the comparison of all three deprecated abc decorators and their base classes in one spec; COMPLETE PICTURE of deprecated abc decorator base classes: abstractproperty -> property(8) [extra165 + extra166]; abstractclassmethod -> classmethod(11) [NEW in extra166]; abstractstaticmethod -> staticmethod(12) [NEW in extra166]; all three inherit from their non-abstract built-in counterparts; all three have __module__=='abc' (len=3); all three exist in Python 3.14.3 despite being deprecated since Python 3.3; LENGTH ORDERING: property(8) < classmethod(11) < staticmethod(12); corresponding decorator lengths: abstractproperty(16) < abstractclassmethod(19) < abstractstaticmethod(20) — each increases by 3 then 1; 'abstract'=8 prefix added to each; NEW in extra166: second standalone abstractproperty.__bases__[0].__name__ cross-check invariant in abcasmbase166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true
