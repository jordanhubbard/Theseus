spec: abc_extra213
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "ABCMeta.register.__qualname__ == 'ABCMeta.register'."
    - "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'."
    - "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'."
    - "abc.abstractmethod decorates in-place: result is my_func is True after decoration."
    - "Decorated function has __isabstractmethod__ == True."
    - "isinstance(abc.ABC, type) is True because ABCMeta is a subclass of type."
    - "isinstance(abc.ABC, abc.ABCMeta) is True."
    - "A concrete subclass of ABC with no abstract methods has len(__abstractmethods__) == 0."
    - "abc.__name__ == 'abc'; abc.__spec__.name == 'abc'."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta method __name__ checks — extra213 namespace
#
# ABCMeta exposes register, __instancecheck__, and __subclasscheck__ as
# its key metaclass methods.
# ---------------------------------------------------------------------------

table abc_extra213.abcmeta_method_names:
  description: "abc.ABCMeta method __name__ checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc213metameth

  columns: [id, function, args, expected, description]
  rows:
    - [register_name,        ABCMeta.register.__name__.__eq__,          ["register"],          true, "ABCMeta.register.__name__ == 'register'"]
    - [instancecheck_name,   ABCMeta.__instancecheck__.__name__.__eq__, ["__instancecheck__"], true, "ABCMeta.__instancecheck__.__name__ == '__instancecheck__'"]
    - [subclasscheck_name,   ABCMeta.__subclasscheck__.__name__.__eq__, ["__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'"]

# ---------------------------------------------------------------------------
# ABCMeta method __qualname__ checks — extra213 namespace
# ---------------------------------------------------------------------------

table abc_extra213.abcmeta_method_qualnames:
  description: "abc.ABCMeta method __qualname__ checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc213metaqual

  columns: [id, function, args, expected, description]
  rows:
    - [register_qualname,      ABCMeta.register.__qualname__.__eq__,          ["ABCMeta.register"],          true, "ABCMeta.register.__qualname__ == 'ABCMeta.register'"]
    - [instancecheck_qualname, ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'"]
    - [subclasscheck_qualname, ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'"]

# ---------------------------------------------------------------------------
# abc module identity — extra213 namespace
# ---------------------------------------------------------------------------

table abc_extra213.module_identity:
  description: "abc module __name__ and __spec__.name checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc213modident

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,      abc.__name__.__eq__,       ["abc"], true, "abc.__name__ == 'abc'"]
    - [module_spec_name, abc.__spec__.name.__eq__,  ["abc"], true, "abc.__spec__.name == 'abc'"]

# ---------------------------------------------------------------------------
# abc class hierarchy checks — extra213 namespace
#
# ABC is an instance of ABCMeta (and therefore also of type, since ABCMeta
# inherits from type).  ABC itself is a subclass of object.
# ---------------------------------------------------------------------------

table abc_extra213.class_hierarchy:
  description: "abc.ABC class hierarchy isinstance/issubclass checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc213hier

  columns: [id, function, args, expected, description]
  rows:
    - [abc_isinstance_type,    isinstance.__call__, [abc.ABC, type],        true, "isinstance(abc.ABC, type) is True"]
    - [abc_isinstance_abcmeta, isinstance.__call__, [abc.ABC, abc.ABCMeta], true, "isinstance(abc.ABC, abc.ABCMeta) is True"]
    - [abc_issubclass_object,  issubclass.__call__, [abc.ABC, object],      true, "issubclass(abc.ABC, object) is True"]
    - [abcmeta_type_issubclass_type, issubclass.__call__, [abc.ABCMeta, type], true, "issubclass(abc.ABCMeta, type) is True"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.register __qualname__ standalone — extra213 namespace
# ---------------------------------------------------------------------------

invariant abc_extra213.abcmeta_register_qualname:
  description: "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABCMeta.__instancecheck__ __qualname__ standalone — extra213 namespace
# ---------------------------------------------------------------------------

invariant abc_extra213.abcmeta_instancecheck_qualname:
  description: "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

# ---------------------------------------------------------------------------
# abc.__name__ standalone — extra213 namespace
# ---------------------------------------------------------------------------

invariant abc_extra213.module_name:
  description: "abc.__name__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# abc.__spec__.name standalone — extra213 namespace
# ---------------------------------------------------------------------------

invariant abc_extra213.module_spec_name:
  description: "abc.__spec__.name == 'abc'"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.name.__eq__
  args: ["abc"]
  expected: true
