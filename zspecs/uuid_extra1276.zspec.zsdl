spec: uuid_extra1276
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 532 (_extra1276): class attribute TYPE checks. uuid.UUID.__subclasses__() returns a list; uuid.UUID.__mro__ and uuid.UUID.__bases__ are tuples. Same pattern applied to uuid.SafeUUID. Chained meta-checks also verify that __mro__.__class__.__bases__ and __bases__.__class__.__mro__ are tuples."
    - "uuid.UUID.__mro__ == (UUID, object). uuid.UUID.__bases__ == (object,). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID is an IntEnum subclass; SafeUUID.__mro__ == (SafeUUID, Enum, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1276.uuid_class_type_checks:
  description: "uuid.UUID __subclasses__() is a list; __mro__ and __bases__ are tuples — direct class attribute type checks"
  kind: python_call_eq
  category: class_type_checks
  id_prefix: uu1276uc
  columns: [id, function, args, expected]
  rows:
    - [uu1276uc001, uuid.UUID.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [uu1276uc002, uuid.UUID.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
    - [uu1276uc003, uuid.UUID.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [uu1276uc004, uuid.UUID.__mro__.__class__.__name__.__eq__,         ["list"],  false]
    - [uu1276uc005, uuid.UUID.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [uu1276uc006, uuid.UUID.__bases__.__class__.__name__.__eq__,       ["list"],  false]
    - [uu1276uc007, uuid.UUID.__mro__.__class__.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [uu1276uc008, uuid.UUID.__bases__.__class__.__mro__.__class__.__name__.__eq__,   ["tuple"], true]
    - [uu1276uc009, uuid.UUID.__subclasses__().__class__.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [uu1276uc010, uuid.UUID.__mro__.__class__.__name__.__eq__,         ["set"],   false]
    - [uu1276uc011, uuid.UUID.__bases__.__class__.__name__.__eq__,       ["set"],   false]
    - [uu1276uc012, uuid.UUID.__subclasses__().__class__.__name__.__eq__, ["set"],   false]

table uuid_extra1276.safeuuid_class_type_checks:
  description: "uuid.SafeUUID __subclasses__() is a list; __mro__ and __bases__ are tuples — SafeUUID is an IntEnum subclass"
  kind: python_call_eq
  category: class_type_checks
  id_prefix: uu1276sc
  columns: [id, function, args, expected]
  rows:
    - [uu1276sc001, uuid.SafeUUID.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [uu1276sc002, uuid.SafeUUID.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
    - [uu1276sc003, uuid.SafeUUID.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [uu1276sc004, uuid.SafeUUID.__mro__.__class__.__name__.__eq__,         ["list"],  false]
    - [uu1276sc005, uuid.SafeUUID.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [uu1276sc006, uuid.SafeUUID.__bases__.__class__.__name__.__eq__,       ["list"],  false]
    - [uu1276sc007, uuid.SafeUUID.__mro__.__class__.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [uu1276sc008, uuid.SafeUUID.__bases__.__class__.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [uu1276sc009, uuid.SafeUUID.__mro__.__class__.__name__.__eq__,         ["set"],   false]
    - [uu1276sc010, uuid.SafeUUID.__bases__.__class__.__name__.__eq__,       ["set"],   false]
    - [uu1276sc011, uuid.SafeUUID.__subclasses__().__class__.__name__.__eq__, ["set"],   false]
    - [uu1276sc012, uuid.SafeUUID.__subclasses__().__class__.__mro__.__class__.__name__.__eq__, ["tuple"], true]

table uuid_extra1276.class_neg_checks:
  description: "uuid.UUID and uuid.SafeUUID class attribute types are not dict, frozenset, or str — negative identity checks"
  kind: python_call_eq
  category: class_neg_checks
  id_prefix: uu1276ng
  columns: [id, function, args, expected]
  rows:
    - [uu1276ng001, uuid.UUID.__subclasses__().__class__.__name__.__eq__,     ["dict"],      false]
    - [uu1276ng002, uuid.UUID.__subclasses__().__class__.__name__.__eq__,     ["frozenset"], false]
    - [uu1276ng003, uuid.UUID.__mro__.__class__.__name__.__eq__,              ["dict"],      false]
    - [uu1276ng004, uuid.UUID.__mro__.__class__.__name__.__eq__,              ["frozenset"], false]
    - [uu1276ng005, uuid.UUID.__bases__.__class__.__name__.__eq__,            ["dict"],      false]
    - [uu1276ng006, uuid.UUID.__bases__.__class__.__name__.__eq__,            ["frozenset"], false]
    - [uu1276ng007, uuid.SafeUUID.__subclasses__().__class__.__name__.__eq__, ["dict"],      false]
    - [uu1276ng008, uuid.SafeUUID.__subclasses__().__class__.__name__.__eq__, ["frozenset"], false]
    - [uu1276ng009, uuid.SafeUUID.__mro__.__class__.__name__.__eq__,          ["dict"],      false]
    - [uu1276ng010, uuid.SafeUUID.__bases__.__class__.__name__.__eq__,        ["dict"],      false]
    - [uu1276ng011, uuid.UUID.__mro__.__class__.__bases__.__class__.__name__.__eq__,   ["list"],  false]
    - [uu1276ng012, uuid.UUID.__bases__.__class__.__mro__.__class__.__name__.__eq__,   ["list"],  false]
