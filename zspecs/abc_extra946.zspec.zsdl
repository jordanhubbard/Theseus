spec: abc_extra946
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks __module__, __qualname__, and structural identity for abc public API"
    - "abc.update_abstractmethods added in Python 3.10"
    - "abc.ABC.__abstractmethods__ is a frozenset; abc.__spec__.__name__ == 'abc'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra946.cache_token_identity:
  description: "abc.get_cache_token __module__ and __qualname__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: ab946ct
  columns: [id, function, args, expected]
  rows:
    - [ab946ct001, abc.get_cache_token.__module__.__eq__,         ["abc"],             true]
    - [ab946ct002, abc.get_cache_token.__qualname__.__eq__,       ["get_cache_token"], true]
    - [ab946ct003, abc.get_cache_token.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab946ct004, abc.update_abstractmethods.__module__.__eq__,  ["abc"],             true]
    - [ab946ct005, abc.update_abstractmethods.__qualname__.__eq__, ["update_abstractmethods"], true]
    - [ab946ct006, abc.update_abstractmethods.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table abc_extra946.abcmeta_dict_identity:
  description: "abc.ABCMeta __dict__ class name and abc.__spec__.__name__ identity"
  kind: python_call_eq
  category: structural_identity
  id_prefix: ab946di
  columns: [id, function, args, expected]
  rows:
    - [ab946di001, abc.ABCMeta.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [ab946di002, abc.ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
    - [ab946di003, abc.__spec__.__name__.__eq__,                     ["abc"],           true]
    - [ab946di004, abc.ABCMeta.__module__.__eq__,                    ["abc"],           true]
    - [ab946di005, abc.ABCMeta.__qualname__.__eq__,                  ["ABCMeta"],       true]
    - [ab946di006, abc.ABC.__module__.__eq__,                        ["abc"],           true]

table abc_extra946.abc_class_qualnames:
  description: "abc.ABC and abc.ABCMeta class __qualname__ and __class__.__name__ identity"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: ab946cq
  columns: [id, function, args, expected]
  rows:
    - [ab946cq001, abc.ABC.__qualname__.__eq__,                      ["ABC"],           true]
    - [ab946cq002, abc.ABC.__class__.__name__.__eq__,                ["ABCMeta"],       true]
    - [ab946cq003, abc.ABCMeta.__class__.__name__.__eq__,            ["type"],          true]
    - [ab946cq004, abc.abstractmethod.__module__.__eq__,             ["abc"],           true]
    - [ab946cq005, abc.abstractmethod.__qualname__.__eq__,           ["abstractmethod"], true]
    - [ab946cq006, abc.abstractmethod.__class__.__name__.__eq__,     ["type"],          true]
    - [ab946cq007, abc.__spec__.__class__.__name__.__eq__,           ["ModuleSpec"],    true]
