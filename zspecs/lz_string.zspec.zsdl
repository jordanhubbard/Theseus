spec: lz_string
version: ">=1.5.0"
backend: node(lz-string)

docs: https://www.npmjs.com/package/lz-string

provenance:
  derived_from:
    - "lz-string README — https://www.npmjs.com/package/lz-string"
    - "Test vectors verified with lz-string via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lz-string source"
  notes:
    - "lz-string is an npm package. Install: npm install lz-string"
    - "LZString.compressToBase64(str) compresses to a base64 string deterministically."
    - "LZString.decompressFromBase64(str) reverses the compression."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns compressed or decompressed string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lz_string.compressToBase64:
  kind: node_module_call_eq
  function: compressToBase64
  category: compress
  id_prefix: lzb64c

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello world"], "BYUwNmD2AEDukCcwBMg="]

table lz_string.decompressFromBase64:
  kind: node_module_call_eq
  function: decompressFromBase64
  category: decompress
  id_prefix: lzb64d

  columns: [id, args, expected]
  rows:
    - [hello, ["BYUwNmD2AEDukCcwBMg="], "hello world"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:56:29Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
