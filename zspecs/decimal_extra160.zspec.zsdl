spec: decimal_extra160
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context.__dict__ membership for key arithmetic methods using __dict__.__contains__, and Context.__dict__.__len__()."
    - "decimal.Context.__dict__.__contains__('add') == True (len('add')=3)."
    - "decimal.Context.__dict__.__contains__('sqrt') == True (len('sqrt')=4)."
    - "decimal.Context.__dict__.__contains__('divide') == True (len('divide')=6)."
    - "decimal.Context.__dict__.__contains__('quantize') == True (len('quantize')=8)."
    - "decimal.Context.__dict__.__contains__('multiply') == True (len('multiply')=8)."
    - "decimal.Context.__dict__.__contains__('create_decimal') == True (len('create_decimal')=14)."
    - "decimal.Context.__dict__.__len__() == 85 — the Context class dict has 85 entries on Python 3.14.3."
    - "Key name length ranking: add=3, sqrt=4, divide=6, quantize=multiply=8 (two-way tie), create_decimal=14."
    - "Two-way tie at 8: quantize and multiply — both 8-character method names."
    - "add (3) is the shortest key name checked — a 3-character abbreviation for addition."
    - "create_decimal (14) is the longest key name checked — a descriptive underscore-separated name."
    - "Context is the decimal arithmetic context class; it mirrors many methods from decimal.Decimal but operates with explicit context control."
    - "Context.__dict__ has 85 entries, fewer than Decimal.__dict__ (101 entries, from decimal_extra159)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context.__dict__ membership for arithmetic methods
# add (len=3), sqrt (len=4), divide (len=6)
# Three distinct lengths with no ties in this group.
# ---------------------------------------------------------------------------

table decimal_extra160.Context_dict_arithmetic_methods_group1:
  description: "decimal.Context.__dict__ membership: add (len=3), sqrt (len=4), divide (len=6) — all True; three distinct lengths, no ties in this group; add (3) is the shortest key name in this spec"
  kind: python_call_eq
  category: identity
  id_prefix: cdict160

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_add_in,     "decimal.Context.__dict__.__contains__",  ["add"],     true, "decimal.Context.__dict__.__contains__('add') == True (add is directly defined in Context.__dict__; Context.add(a, b) returns the sum of a and b with full context-controlled rounding and precision; unlike the + operator which uses the thread-local context, Context.add() uses the explicit Context object; 'add' has 3 characters — the shortest key name among the six arithmetic methods checked in this spec; add (3) < sqrt (4) < divide (6) < quantize=multiply (8) < create_decimal (14); 'add' (3) mirrors the pattern of other ultra-short Decimal API names: 'ln' (2) and 'fma' (3) in Decimal.__dict__ from decimal_extra159; Context has parallel arithmetic methods to Decimal but with explicit context control)"]
    - [ctx_sqrt_in,    "decimal.Context.__dict__.__contains__",  ["sqrt"],    true, "decimal.Context.__dict__.__contains__('sqrt') == True (sqrt is directly defined in Context.__dict__; Context.sqrt(a) returns the square root of a with precision and rounding specified by the Context; 'sqrt' has 4 characters — the second-shortest key name in this spec; sqrt (4) is 1 longer than add (3) and 2 shorter than divide (6); 'sqrt' (4 chars) is a standard mathematical abbreviation for 'square root'; Context.sqrt() computes to the precision specified in the context's prec attribute, allowing higher precision than the standard float sqrt; sqrt (4) also appears in Decimal.__dict__ (from decimal_extra159) and Context.__dict__ — both the Decimal and Context classes provide sqrt as a core mathematical operation)"]
    - [ctx_divide_in,  "decimal.Context.__dict__.__contains__",  ["divide"],  true, "decimal.Context.__dict__.__contains__('divide') == True (divide is directly defined in Context.__dict__; Context.divide(a, b) returns the quotient a / b with context-controlled precision and rounding; 'divide' has 6 characters: 'd-i-v-i-d-e'; divide (6) is the third-shortest key name in this spec — between sqrt (4) and quantize=multiply (both 8); Context.divide() enables division with a specific Context rather than the implicit thread-local context; divide (6) vs 'divmod' (6) — both are 6-character keys in Context.__dict__, coincidentally equal in length; Context.divide() raises InvalidOperation if dividing by zero per the IEEE 754 standard)"]
    - [ctx_add_len,    "decimal.Context.__dict__.__contains__",  ["multiply"], true, "decimal.Context.__dict__.__contains__('multiply') == True (multiply is directly defined in Context.__dict__; Context.multiply(a, b) returns the product of a and b using the Context's precision and rounding mode; 'multiply' has 8 characters: 'm-u-l-t-i-p-l-y'; multiply (8) is tied with quantize (also 8) — the two-way tie at 8 is the third-highest key name length in this spec; multiply and quantize are both 8-character keys in Context.__dict__; multiply (8) < create_decimal (14) — the largest gap in key name lengths in this spec (8 to 14 is a gap of 6 characters); Context.multiply() uses IEEE 754 decimal arithmetic with explicit precision from the Context rather than the default thread-local context)"]

# ---------------------------------------------------------------------------
# decimal.Context.__dict__ membership for quantize and create_decimal
# quantize (len=8) tied with multiply; create_decimal (len=14) is longest.
# Also check Context.__dict__.__len__() == 85.
# ---------------------------------------------------------------------------

table decimal_extra160.Context_dict_arithmetic_methods_group2:
  description: "decimal.Context.__dict__ membership: quantize (len=8, tied with multiply), create_decimal (len=14, longest in spec); also Context.__dict__.__len__()==85; create_decimal (14) is 6 characters longer than quantize=multiply (8)"
  kind: python_call_eq
  category: identity
  id_prefix: cdict160

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_quantize_in,        "decimal.Context.__dict__.__contains__",  ["quantize"],        true, "decimal.Context.__dict__.__contains__('quantize') == True (quantize is directly defined in Context.__dict__; Context.quantize(a, b) returns a value equal to the first operand after rounding and having the exponent of the second operand, using the Context's rounding mode; 'quantize' has 8 characters: 'q-u-a-n-t-i-z-e'; quantize (8) is tied with multiply (also 8) — the two-way tie at 8 is the second-highest grouping in this spec (after create_decimal at 14); quantize (8) also appears in Decimal.__dict__ (from decimal_extra159) — both Decimal and Context provide quantize as a core financial calculation method; Context.quantize() enables precise control over rounding for financial compliance requirements)"]
    - [ctx_create_dec_in,      "decimal.Context.__dict__.__contains__",  ["create_decimal"],  true, "decimal.Context.__dict__.__contains__('create_decimal') == True (create_decimal is directly defined in Context.__dict__; Context.create_decimal(num) converts num (int, string, float, or tuple) to a Decimal using the Context's precision and rounding settings; 'create_decimal' has 14 characters: 'create' (6) + '_' (1) + 'decimal' (7) = 14; create_decimal (14) is the longest key name in this spec — standing alone at the maximum; create_decimal (14) is 6 characters longer than quantize=multiply (both 8) — the largest gap in key name lengths within this spec; the underscore in 'create_decimal' contributes 1 character; Context.create_decimal() is particularly useful when constructing Decimal values that should respect a specific precision from the start)"]
    - [ctx_dict_len,           "decimal.Context.__dict__.__len__",        [],                 85,   "decimal.Context.__dict__.__len__() == 85 — the Context class dict has exactly 85 entries on Python 3.14.3; compare with Decimal.__dict__ (101 entries, from decimal_extra159): Context (85) has 16 fewer entries than Decimal (101); Context mirrors many Decimal arithmetic methods (add, subtract, multiply, divide, sqrt, quantize, etc.) but also includes Context-specific methods (create_decimal, create_decimal_from_float, clear_flags, clear_traps, copy, Etiny, Etop) and properties (prec, Emax, Emin, rounding, capitals, clamp); 85 entries still reflects a very rich API for an arithmetic context class; the difference of 16 entries (101 - 85 = 16) reflects that Decimal has more comparison dunders (__lt__, __le__, __eq__, __gt__, __ge__) and format dunders (__format__, __repr__, __str__, __bytes__, __int__, __float__, __complex__) that are not mirrored on Context)"]
    - [ctx_create_dec_len,     "decimal.Context.__dict__.__contains__",  ["subtract"],        true, "decimal.Context.__dict__.__contains__('subtract') == True (subtract is directly defined in Context.__dict__; Context.subtract(a, b) returns the difference a - b using the Context's precision and rounding mode; 'subtract' has 8 characters: 's-u-b-t-r-a-c-t'; subtract (8) is also 8 characters — it would join the two-way tie at 8 with quantize and multiply, making it a three-way tie at 8 if included in the core six; however, the primary six in this spec are add, sqrt, divide, quantize, multiply, create_decimal; subtract (8) confirms that 8 is a significant key name length in Context.__dict__; subtract (8) < create_decimal (14): the gap from the 8-character methods to create_decimal (14) is 6 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra160.Context_add_is_shortest_at_3:
  description: "decimal.Context.__dict__.__contains__('add') == True — 'add' (3 chars) is the shortest key name among the six arithmetic method keys checked in this spec; the ascending key name length sequence: add=3, sqrt=4, divide=6, quantize=multiply=8, create_decimal=14; 'add' (3 chars) stands alone at the minimum length; 'add' is a 3-character fundamental arithmetic operation name; Context.add() provides explicit-context controlled addition, complementing Decimal's + operator which uses the thread-local default context; 'add' (3) is the same length as 'fma' (3) which appears in both Decimal.__dict__ and Context.__dict__ — both 3-character method names are IEEE 754 arithmetic operations; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Context.__dict__.__contains__"
  args: ["add"]
  expected: true

invariant decimal_extra160.Context_quantize_multiply_tie_at_8:
  description: "decimal.Context.__dict__.__contains__('quantize') == True — 'quantize' and 'multiply' both have 8 characters, forming a two-way tie at 8 in key name length among the six arithmetic method keys in this spec; the two-way tie at 8 (quantize, multiply) is the second-highest length grouping after create_decimal (14); quantize (8) and multiply (8) are both essential IEEE 754 decimal arithmetic operations; quantize controls decimal precision/scale, multiply computes products; both are available on both Decimal and Context classes; the ascending sequence: add=3, sqrt=4, divide=6, quantize=multiply=8, create_decimal=14; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Context.__dict__.__contains__"
  args: ["quantize"]
  expected: true

invariant decimal_extra160.Context_create_decimal_is_longest_at_14:
  description: "decimal.Context.__dict__.__contains__('create_decimal') == True — 'create_decimal' (14 chars) is the longest key name in this spec; it stands alone at the maximum length 14; 'create_decimal' = 'create' (6) + '_' (1) + 'decimal' (7) = 14; the underscore-separated naming reflects the descriptive style for factory/constructor methods; create_decimal (14) is 6 characters longer than quantize=multiply (both 8) — the largest gap in key name lengths in this spec; Context.create_decimal_from_float() (another Context method) would be even longer at 26 characters; Decimal.__dict__ from decimal_extra159 does not have create_decimal — it is a Context-only method (creating a new Decimal from a Context's settings); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Context.__dict__.__contains__"
  args: ["create_decimal"]
  expected: true

invariant decimal_extra160.Context_dict_has_85_entries:
  description: "decimal.Context.__dict__.__len__() == 85 — Context's class dict has exactly 85 entries on Python 3.14.3; this is 16 fewer than Decimal.__dict__ (101 entries, from decimal_extra159); 85 entries covers all Context methods: arithmetic (add, subtract, multiply, divide, sqrt, quantize, power, fma, etc.), mathematical (abs, exp, ln, log10, minus, normalize, plus), comparison (compare, compare_signal, compare_total, compare_total_mag), rounding (to_integral, to_integral_exact, to_integral_value), logical (logical_and, logical_or, logical_xor, logical_invert), and context operations (clear_flags, clear_traps, copy, create_decimal, create_decimal_from_float, Etiny, Etop, radix); plus dunders (__new__, __repr__, __getattribute__, __setattr__, __delattr__, __init__, __copy__, __reduce__, __doc__, __module__); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Context.__dict__.__len__"
  args: []
  expected: 85

