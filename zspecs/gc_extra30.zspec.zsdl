spec: gc_extra30
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc_extra29.zspec.zsdl."
    - "Prior specs covered: gc.collect/disable/enable/isenabled/get_count/get_threshold/set_threshold/get_objects/get_referrers/get_referents/is_tracked/is_finalized/freeze/unfreeze/get_freeze_count/__name__/__module__, gc.callbacks/garbage __class__.__name__, various __qualname__ checks."
    - "This spec covers: collect.__module__.__len__() == 2, disable.__module__.__len__() == 2, enable.__module__.__len__() == 2, isenabled.__module__.__len__() == 2, collect.__name__.__len__() == 7, disable.__name__.__len__() == 7, enable.__name__.__len__() == 6, isenabled.__name__.__len__() == 9, get_count.__name__.__len__() == 9, get_threshold.__name__.__len__() == 13, set_threshold.__name__.__len__() == 13, get_objects.__name__.__len__() == 11."
    - "gc.collect.__module__ == 'gc' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.disable.__module__ == 'gc' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.enable.__module__ == 'gc' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.isenabled.__module__ == 'gc' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.collect.__name__ == 'collect' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.disable.__name__ == 'disable' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.enable.__name__ == 'enable' (len 6). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.isenabled.__name__ == 'isenabled' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_count.__name__ == 'get_count' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_threshold.__name__ == 'get_threshold' (len 13). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.set_threshold.__name__ == 'set_threshold' (len 13). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_objects.__name__ == 'get_objects' (len 11). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc.collect.__module__.__len__()
#
# collect.__module__ == 'gc', which has length 2. Prior specs record the
# __module__ string value; this spec records its length via __len__ as a
# fresh extra30-namespace invariant. gc is a C extension module with a
# 2-character name.
# ---------------------------------------------------------------------------

invariant gc_extra30.collect.module.len:
  description: "gc.collect.__module__.__len__() == 2 — 'gc' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: collect.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# gc.disable.__module__.__len__()
#
# disable.__module__ == 'gc', which has length 2.
# ---------------------------------------------------------------------------

invariant gc_extra30.disable.module.len:
