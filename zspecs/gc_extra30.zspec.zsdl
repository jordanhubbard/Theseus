# ---------------------------------------------------------------------------
# Consolidated table — all twelve __len__ invariants
#
# Covers __module__.__len__() for collect/disable/enable/isenabled (4) and
# __name__.__len__() for collect/disable/enable/isenabled/get_count/
# get_threshold/set_threshold/get_objects (8).
# ---------------------------------------------------------------------------

table gc_extra30.string_lengths:
  description: "String lengths of __module__ and __name__ attributes for gc C builtin functions"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected]
  rows:
    - [collect_module_len,       collect.__module__.__len__,       [], 2]
    - [disable_module_len,       disable.__module__.__len__,       [], 2]
    - [enable_module_len,        enable.__module__.__len__,        [], 2]
    - [isenabled_module_len,     isenabled.__module__.__len__,     [], 2]
    - [collect_name_len,         collect.__name__.__len__,         [], 7]
    - [disable_name_len,         disable.__name__.__len__,         [], 7]
    - [enable_name_len,          enable.__name__.__len__,          [], 6]
    - [isenabled_name_len,       isenabled.__name__.__len__,       [], 9]
    - [get_count_name_len,       get_count.__name__.__len__,       [], 9]
    - [get_threshold_name_len,   get_threshold.__name__.__len__,   [], 13]
    - [set_threshold_name_len,   set_threshold.__name__.__len__,   [], 13]
    - [get_objects_name_len,     get_objects.__name__.__len__,     [], 11]
