spec: threading_extra102
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra101

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra101.zspec.zsdl."
    - "This spec covers: threading.Thread method __qualname__ string lengths for __init__, start, run, join, is_alive, __repr__, getName, setName, isDaemon, setDaemon, _bootstrap, _delete; wave 258."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' (len 12). Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' (len 10). Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' (len 11). Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.__repr__.__qualname__ == 'Thread.__repr__' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.getName.__qualname__ == 'Thread.getName' (len 14). Verified with Python 3.14.3."
    - "threading.Thread.setName.__qualname__ == 'Thread.setName' (len 14). Verified with Python 3.14.3."
    - "threading.Thread.isDaemon.__qualname__ == 'Thread.isDaemon' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.setDaemon.__qualname__ == 'Thread.setDaemon' (len 16). Verified with Python 3.14.3."
    - "threading.Thread._bootstrap.__qualname__ == 'Thread._bootstrap' (len 17). Verified with Python 3.14.3."
    - "threading.Thread._delete.__qualname__ == 'Thread._delete' (len 14). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread core method __qualname__ lengths
#
# Wave 258 theme: threading.Thread public method __qualname__ lengths.
#
# threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15)
# threading.Thread.start.__qualname__ == 'Thread.start' (len 12)
# threading.Thread.run.__qualname__ == 'Thread.run' (len 10)
# threading.Thread.join.__qualname__ == 'Thread.join' (len 11)
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' (len 15)
# threading.Thread.__repr__.__qualname__ == 'Thread.__repr__' (len 15)
#
# All Thread methods are pure-Python functions in Lib/threading.py.
# __qualname__ takes the form 'ClassName.method_name'. New to extra102.
# ---------------------------------------------------------------------------

table threading_extra102.thread_core_method_qualname_lengths:
  description: "threading.Thread core methods __qualname__ lengths: __init__ 15, start 12, run 10, join 11, is_alive 15, __repr__ 15; wave 258; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread102

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_qualname_len_eq_15,
       "Thread.__init__.__qualname__.__len__",
       [],
       15,
       "threading.Thread.__init__.__qualname__.__len__() == 15 — Thread.__init__ is a pure-Python method in Lib/threading.py; its __qualname__ is 'Thread.__init__'; len('Thread.__init__') == 15 (T-h-r-e-a-d-.-_-_-i-n-i-t-_-_); new to extra102"]
    - [thread_init_qualname_eq,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread.__init__ initializes a thread with name, target, args, kwargs, and daemon; its __qualname__ is 'Thread.__init__'; str.__eq__('Thread.__init__') returns True; new to extra102"]
    - [thread_start_qualname_len_eq_12,
       "Thread.start.__qualname__.__len__",
       [],
       12,
       "threading.Thread.start.__qualname__.__len__() == 12 — Thread.start starts the thread's activity and schedules run() to be called; its __qualname__ is 'Thread.start'; len('Thread.start') == 12 (T-h-r-e-a-d-.-s-t-a-r-t); new to extra102"]
    - [thread_run_qualname_len_eq_10,
       "Thread.run.__qualname__.__len__",
       [],
       10,
       "threading.Thread.run.__qualname__.__len__() == 10 — Thread.run is the method invoked by the started thread; subclasses override it; its __qualname__ is 'Thread.run'; len('Thread.run') == 10 (T-h-r-e-a-d-.-r-u-n); new to extra102"]
    - [thread_join_qualname_len_eq_11,
       "Thread.join.__qualname__.__len__",
       [],
       11,
       "threading.Thread.join.__qualname__.__len__() == 11 — Thread.join blocks the calling thread until the thread whose join() is called terminates; its __qualname__ is 'Thread.join'; len('Thread.join') == 11 (T-h-r-e-a-d-.-j-o-i-n); new to extra102"]
    - [thread_is_alive_qualname_len_eq_15,
       "Thread.is_alive.__qualname__.__len__",
       [],
       15,
       "threading.Thread.is_alive.__qualname__.__len__() == 15 — Thread.is_alive returns True if the thread is alive (started and not yet terminated); its __qualname__ is 'Thread.is_alive'; len('Thread.is_alive') == 15 (T-h-r-e-a-d-.-i-s-_-a-l-i-v-e); new to extra102"]
    - [thread_repr_qualname_len_eq_15,
       "Thread.__repr__.__qualname__.__len__",
       [],
       15,
       "threading.Thread.__repr__.__qualname__.__len__() == 15 — Thread.__repr__ returns a string representation of the thread including name, ident, and daemon status; its __qualname__ is 'Thread.__repr__'; len('Thread.__repr__') == 15 (T-h-r-e-a-d-.-_-_-r-e-p-r-_-_); new to extra102"]
    - [thread_repr_qualname_eq,
       "Thread.__repr__.__qualname__.__eq__",
       ["Thread.__repr__"],
       true,
       "threading.Thread.__repr__.__qualname__.__eq__('Thread.__repr__') == True — Thread.__repr__ is a pure-Python method; its __qualname__ is 'Thread.__repr__'; str.__eq__('Thread.__repr__') returns True; new to extra102"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread legacy and private method __qualname__ lengths
#
# Wave 258 theme: threading.Thread legacy method __qualname__ lengths.
#
# threading.Thread.getName.__qualname__ == 'Thread.getName' (len 14)
# threading.Thread.setName.__qualname__ == 'Thread.setName' (len 14)
# threading.Thread.isDaemon.__qualname__ == 'Thread.isDaemon' (len 15)
# threading.Thread.setDaemon.__qualname__ == 'Thread.setDaemon' (len 16)
# threading.Thread._bootstrap.__qualname__ == 'Thread._bootstrap' (len 17)
# threading.Thread._delete.__qualname__ == 'Thread._delete' (len 14)
#
# getName/setName/isDaemon/setDaemon are legacy aliases kept for compatibility.
# _bootstrap and _delete are private methods used internally. New to extra102.
# ---------------------------------------------------------------------------

table threading_extra102.thread_legacy_private_qualname_lengths:
  description: "threading.Thread legacy/private method __qualname__ lengths: getName/setName 14, isDaemon 15, setDaemon 16, _bootstrap 17, _delete 14; wave 258; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread102

  columns: [id, function, args, expected, description]
  rows:
    - [thread_getname_qualname_len_eq_14,
       "Thread.getName.__qualname__.__len__",
       [],
       14,
       "threading.Thread.getName.__qualname__.__len__() == 14 — Thread.getName is a legacy method that returns the thread's name, preserved for backward compatibility; its __qualname__ is 'Thread.getName'; len('Thread.getName') == 14 (T-h-r-e-a-d-.-g-e-t-N-a-m-e); new to extra102"]
    - [thread_setname_qualname_len_eq_14,
       "Thread.setName.__qualname__.__len__",
       [],
       14,
       "threading.Thread.setName.__qualname__.__len__() == 14 — Thread.setName is a legacy method to set the thread's name, preserved for backward compatibility; its __qualname__ is 'Thread.setName'; len('Thread.setName') == 14 (T-h-r-e-a-d-.-s-e-t-N-a-m-e); new to extra102"]
    - [thread_isdaemon_qualname_len_eq_15,
       "Thread.isDaemon.__qualname__.__len__",
       [],
       15,
       "threading.Thread.isDaemon.__qualname__.__len__() == 15 — Thread.isDaemon is a legacy method returning whether the thread is a daemon thread; its __qualname__ is 'Thread.isDaemon'; len('Thread.isDaemon') == 15 (T-h-r-e-a-d-.-i-s-D-a-e-m-o-n); new to extra102"]
    - [thread_setdaemon_qualname_len_eq_16,
       "Thread.setDaemon.__qualname__.__len__",
       [],
       16,
       "threading.Thread.setDaemon.__qualname__.__len__() == 16 — Thread.setDaemon is a legacy method to set the daemon flag; its __qualname__ is 'Thread.setDaemon'; len('Thread.setDaemon') == 16 (T-h-r-e-a-d-.-s-e-t-D-a-e-m-o-n); new to extra102"]
    - [thread_bootstrap_qualname_len_eq_17,
       "Thread._bootstrap.__qualname__.__len__",
       [],
       17,
       "threading.Thread._bootstrap.__qualname__.__len__() == 17 — Thread._bootstrap is the private method that wraps the thread's actual execution, handling exception catching and cleanup; its __qualname__ is 'Thread._bootstrap'; len('Thread._bootstrap') == 17 (T-h-r-e-a-d-.-_-b-o-o-t-s-t-r-a-p); new to extra102"]
    - [thread_delete_qualname_len_eq_14,
       "Thread._delete.__qualname__.__len__",
       [],
       14,
       "threading.Thread._delete.__qualname__.__len__() == 14 — Thread._delete is a private method that removes the thread from the active threads registry upon termination; its __qualname__ is 'Thread._delete'; len('Thread._delete') == 14 (T-h-r-e-a-d-.-_-d-e-l-e-t-e); new to extra102"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread method __qualname__ equality checks
#
# Wave 258 theme: threading.Thread method __qualname__ string equality.
#
# threading.Thread.start.__qualname__ == 'Thread.start'
# threading.Thread.run.__qualname__ == 'Thread.run'
# threading.Thread.join.__qualname__ == 'Thread.join'
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'
# threading.Thread.getName.__qualname__ == 'Thread.getName'
# threading.Thread._bootstrap.__qualname__ == 'Thread._bootstrap'
#
# Equality checks confirm the exact __qualname__ strings. New to extra102.
# ---------------------------------------------------------------------------

table threading_extra102.thread_method_qualname_equality:
  description: "threading.Thread start/run/join/is_alive/getName/_bootstrap __qualname__ string equality checks; wave 258; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread102

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_qualname_eq,
       "Thread.start.__qualname__.__eq__",
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start is a pure-Python method in Lib/threading.py; its __qualname__ is 'Thread.start'; str.__eq__('Thread.start') returns True; new to extra102"]
    - [thread_run_qualname_eq,
       "Thread.run.__qualname__.__eq__",
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — Thread.run is a pure-Python method that subclasses override to define thread behavior; its __qualname__ is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra102"]
    - [thread_join_qualname_eq,
       "Thread.join.__qualname__.__eq__",
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — Thread.join blocks until the thread terminates; its __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra102"]
    - [thread_is_alive_qualname_eq,
       "Thread.is_alive.__qualname__.__eq__",
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — Thread.is_alive checks whether the thread is alive; its __qualname__ is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra102"]
    - [thread_getname_qualname_eq,
       "Thread.getName.__qualname__.__eq__",
       ["Thread.getName"],
       true,
       "threading.Thread.getName.__qualname__.__eq__('Thread.getName') == True — Thread.getName is the legacy accessor for the thread name; its __qualname__ is 'Thread.getName'; str.__eq__('Thread.getName') returns True; new to extra102"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra102
# ---------------------------------------------------------------------------

invariant threading_extra102.thread_init_qualname_len:
  description: "len(threading.Thread.__init__.__qualname__) == 15 — qualname is 'Thread.__init__'; wave 258; new to extra102"
  kind: python_call_eq
  function: Thread.__init__.__qualname__.__len__
  args: []
  expected: 15

invariant threading_extra102.thread_start_qualname:
  description: "threading.Thread.start.__qualname__ == 'Thread.start' — pure-Python method in Lib/threading.py; wave 258; new to extra102"
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra102.thread_run_qualname_len:
  description: "len(threading.Thread.run.__qualname__) == 10 — qualname is 'Thread.run'; wave 258; new to extra102"
  kind: python_call_eq
  function: Thread.run.__qualname__.__len__
  args: []
  expected: 10

invariant threading_extra102.thread_bootstrap_qualname_len:
  description: "len(threading.Thread._bootstrap.__qualname__) == 17 — qualname is 'Thread._bootstrap'; wave 258; new to extra102"
  kind: python_call_eq
  function: Thread._bootstrap.__qualname__.__len__
  args: []
  expected: 17

invariant threading_extra102.thread_setdaemon_qualname_len:
  description: "len(threading.Thread.setDaemon.__qualname__) == 16 — qualname is 'Thread.setDaemon'; wave 258; new to extra102"
  kind: python_call_eq
