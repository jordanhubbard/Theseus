spec: random_extra10
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra9.zspec.zsdl."
    - "Prior specs cover: __name__, __module__, __qualname__ for all module-level functions and classes; BPF/VERSION/RECIP_BPF; deterministic randint/choice/randrange/uniform/getrandbits/sample vectors; shuffle/choices return types; MRO length; gauss/__name__ and gauss/__qualname__; normalvariate/__name__."
    - "No prior spec covers gauss() actual value vectors with a fixed seed."
    - "No prior spec covers normalvariate() actual value vectors with a fixed seed."
    - "Random(42).gauss(0, 1) == -0.14409032957792836 — first Gaussian sample from seed 42."
    - "Random(0).gauss(0, 1) == 0.9417154046806644 — first Gaussian sample from seed 0."
    - "Random(13).gauss(0, 1) == -0.08601898621952832 — first Gaussian sample from seed 13."
    - "Random(42).normalvariate(0, 1) == 0.2453263417078634 — first normalvariate sample from seed 42."
    - "Random(0).normalvariate(0, 1) == -0.18386822109325826 — first normalvariate sample from seed 0."
    - "gauss and normalvariate both sample from a normal distribution but use different algorithms (gauss uses a fast approximation; normalvariate uses Box-Muller), so they produce different values from the same seed."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Random.gauss() — deterministic value vectors
#
# gauss(mu, sigma) returns a Gaussian-distributed float with mean mu and
# standard deviation sigma. It uses a fast, non-thread-safe algorithm.
# Prior specs only cover gauss.__name__ and gauss.__qualname__; no prior spec
# tests the actual numeric output of gauss() with a fixed seed.
# ---------------------------------------------------------------------------

invariant random_extra10.gauss.seed42_std_normal:
  description: "Random(42).gauss(0, 1) == -0.14409032957792836 — first Gaussian sample from seed 42"
  category: gauss
  kind: python_call_eq
  function: Random
  args: [42]
  method: gauss
  method_args: [0, 1]
  expected: -0.14409032957792836

invariant random_extra10.gauss.seed0_std_normal:
  description: "Random(0).gauss(0, 1) == 0.9417154046806644 — first Gaussian sample from seed 0"
  category: gauss
  kind: python_call_eq
  function: Random
  args: [0]
  method: gauss
  method_args: [0, 1]
  expected: 0.9417154046806644

invariant random_extra10.gauss.seed13_std_normal:
  description: "Random(13).gauss(0, 1) == -0.08601898621952832 — first Gaussian sample from seed 13"
  category: gauss
  kind: python_call_eq
  function: Random
  args: [13]
  method: gauss
  method_args: [0, 1]
  expected: -0.08601898621952832

# ---------------------------------------------------------------------------
# Random.normalvariate() — deterministic value vectors
#
# normalvariate(mu, sigma) samples from the same distribution as gauss() but
# uses the Box-Muller transform, which is thread-safe. Because the two
# functions consume internal state differently, they produce different output
# from the same seed. No prior spec covers normalvariate() value vectors.
# ---------------------------------------------------------------------------

invariant random_extra10.normalvariate.seed42_std_normal:
  description: "Random(42).normalvariate(0, 1) == 0.2453263417078634 — first sample from seed 42"
  category: normalvariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: normalvariate
  method_args: [0, 1]
  expected: 0.2453263417078634

invariant random_extra10.normalvariate.seed0_std_normal:
  description: "Random(0).normalvariate(0, 1) == -0.18386822109325826 — first sample from seed 0"
  category: normalvariate
  kind: python_call_eq
  function: Random
  args: [0]
  method: normalvariate
  method_args: [0, 1]
  expected: -0.18386822109325826
