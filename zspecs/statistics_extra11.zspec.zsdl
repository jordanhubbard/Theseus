spec: statistics_extra11
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras through statistics_extra10.zspec.zsdl."
    - "statistics_extra.zspec.zsdl covers NormalDist(0,1).variance==1.0, NormalDist(5,2).variance==4.0, NormalDist(0,1).cdf(0.0)==0.5."
    - "statistics_extra2.zspec.zsdl covers NormalDist.__name__, NormalDist.__module__, NormalDist(0,1).mean, NormalDist(0,1).stdev, NormalDist(0,1).variance, NormalDist(5,2).mean, NormalDist(5,2).stdev, StatisticsError.__name__, StatisticsError.__module__."
    - "statistics_extra.zspec.zsdl covers StatisticsError.__bases__[0].__name__=='ValueError'."
    - "statistics_extra6.zspec.zsdl covers NormalDist.__bases__[0].__name__=='object'."
    - "statistics_extra8.zspec.zsdl covers NormalDist(0,1).pdf(0.0)==0.3989... and NormalDist(0,1).inv_cdf(0.5)==0.0."
    - "New axis 1: NormalDist.zscore() method — not covered by any prior spec."
    - "New axis 2: NormalDist(3,4) parameter set — mean/stdev/variance for mu=3,sigma=4 not previously tested."
    - "New axis 3: NormalDist(5,2).pdf(5) == 0.19947... — non-standard-normal PDF at the mode."
    - "New axis 4: NormalDist(5,2).cdf(5) == 0.5 — CDF at the mean of a non-standard normal."
    - "statistics.NormalDist(0,1).zscore(1) == 1.0 — one stdev above the mean."
    - "statistics.NormalDist(0,1).zscore(0) == 0.0 — z-score at the mean is always 0."
    - "statistics.NormalDist(5,2).zscore(7) == 1.0 — (7-5)/2 == 1.0."
    - "statistics.NormalDist(3,4).mean == 3.0 — location parameter mu."
    - "statistics.NormalDist(3,4).stdev == 4.0 — scale parameter sigma."
    - "statistics.NormalDist(3,4).variance == 16.0 — variance == sigma**2 == 16."
    - "statistics.NormalDist(5,2).pdf(5) == 0.19947114020071635 — peak density for N(5,2)."
    - "statistics.NormalDist(5,2).cdf(5) == 0.5 — half the distribution lies below the mean."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist.zscore() — new method axis
#
# zscore(x) returns (x - mean) / stdev. No prior spec covers any zscore call.
# Three vectors: at the mean (0.0), one stdev above (1.0), and a non-trivial
# parameterization NormalDist(5,2).zscore(7) == (7-5)/2 == 1.0.
# ---------------------------------------------------------------------------

invariant statistics_extra11.NormalDist.zscore_at_mean:
  description: "statistics.NormalDist(0,1).zscore(0) == 0.0 — z-score at the mean is always 0"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: zscore
  method_args: [0]
  expected: 0.0

invariant statistics_extra11.NormalDist.zscore_one_sigma:
  description: "statistics.NormalDist(0,1).zscore(1) == 1.0 — one stdev above the mean"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: zscore
  method_args: [1]
  expected: 1.0

invariant statistics_extra11.NormalDist.zscore_non_standard:
  description: "statistics.NormalDist(5,2).zscore(7) == 1.0 — (7-5)/2 == 1.0 for N(5,2)"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [5, 2]
  method: zscore
  method_args: [7]
  expected: 1.0

# ---------------------------------------------------------------------------
# NormalDist(3, 4) — new parameter set for mean/stdev/variance
#
# statistics_extra2 covers NormalDist(0,1) and NormalDist(5,2) parameter sets.
# No prior spec uses mu=3, sigma=4 (variance==16). These are distinct vectors.
# ---------------------------------------------------------------------------

invariant statistics_extra11.NormalDist.mean_three_four:
  description: "statistics.NormalDist(3,4).mean == 3.0 — location parameter mu"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [3, 4]
  method: mean
  expected: 3.0

invariant statistics_extra11.NormalDist.stdev_three_four:
  description: "statistics.NormalDist(3,4).stdev == 4.0 — scale parameter sigma"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [3, 4]
  method: stdev
  expected: 4.0

invariant statistics_extra11.NormalDist.variance_three_four:
  description: "statistics.NormalDist(3,4).variance == 16.0 — variance == sigma**2 == 16"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [3, 4]
  method: variance
  expected: 16.0

# ---------------------------------------------------------------------------
# NormalDist(5,2).pdf(5) — PDF value at the mode of a non-standard normal
#
# statistics_extra8 covers NormalDist(0,1).pdf(0.0) == 0.3989...
# No prior spec covers pdf() for a non-standard normal. The peak density for
# N(5,2) is 1/(2*sqrt(2*pi)) ≈ 0.19947114020071635.
# ---------------------------------------------------------------------------

invariant statistics_extra11.NormalDist.pdf_non_standard_at_mode:
  description: "statistics.NormalDist(5,2).pdf(5) == 0.19947... — peak PDF for N(5,2)"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [5, 2]
  method: pdf
  method_args: [5]
  expected: 0.19947114020071635

# ---------------------------------------------------------------------------
# NormalDist(5,2).cdf(5) — CDF at the mean of a non-standard normal
#
# statistics_extra.zspec.zsdl covers NormalDist(0,1).cdf(0.0) == 0.5.
# For any normal distribution the CDF at the mean equals 0.5 by symmetry.
# NormalDist(5,2).cdf(5) verifies this holds for a non-standard parameterization.
# ---------------------------------------------------------------------------

invariant statistics_extra11.NormalDist.cdf_non_standard_at_mean:
  description: "statistics.NormalDist(5,2).cdf(5) == 0.5 — CDF at the mean is 0.5 for any normal"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [5, 2]
  method: cdf
  method_args: [5]
  expected: 0.5
