      "kind": "node_module_call_eq",
      "spec": {
        "function": "valid",
        "args": [
          "1.2.3"
        ],
        "expected": "1.2.3",
        "rfc": "Semantic Versioning 2.0.0"
      },
      "category": "valid"
    },
    {
