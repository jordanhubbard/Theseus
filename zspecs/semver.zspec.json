  "provenance": {
    "derived_from": [
      "Semantic Versioning 2.0.0 — https://semver.org/spec/v2.0.0.html",
      "npm semver package README — https://github.com/npm/node-semver#readme",
      "Test vectors verified by running semver@7.x via Node.js 22.20.0 on macOS/Darwin 25.3.0, 2026-03-31"
    ],
    "not_derived_from": [
      "semver package source: semver.js"
    ],
    "notes": [
      "This spec exercises the semver npm package via node -e inline scripts. It is a CLI-backend spec with module_name, invoking node with require('semver').",
      "All invariants use node_module_call_eq: the function is called with JSON args, the return value is JSON.stringify'd, and compared against json.dumps(expected).",
      "null return values: semver.valid() returns null for invalid version strings. JSON.stringify(null) == 'null' == json.dumps(None).",
      "Boolean return values: semver.gt/lt/eq/satisfies return true/false. JSON.stringify(true) == 'true' == json.dumps(True).",
      "Integer return values: semver.compare returns 0, 1, or -1. semver.major/minor/patch return integers.",
      "String return values: semver.valid, semver.inc, semver.maxSatisfying, semver.minSatisfying, semver.clean return strings or null."
    ],
    "created_at": "2026-03-31T00:00:00Z",
    "spec_authors": [
      "Theseus Z-layer"
    ]
  },
  "library": {
    "backend": "cli",
    "command": "node",
    "module_name": "semver",
    "soname_patterns": []
  },
  "constants": {},
  "types": {},
  "wire_formats": {},
  "functions": {},
