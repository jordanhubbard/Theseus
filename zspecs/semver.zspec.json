{
  "schema_version": "0.1",

  "identity": {
    "canonical_name": "semver",
    "spec_for_versions": ">=7.0.0",
    "api_header": "N/A — Node.js npm package",
    "public_docs_url": "https://github.com/npm/node-semver#readme",
    "rfc_references": [
      {
        "rfc": "Semantic Versioning 2.0.0",
        "title": "Semantic Versioning Specification",
        "url": "https://semver.org/spec/v2.0.0.html"
      }
    ]
  },

  "provenance": {
    "derived_from": [
      "Semantic Versioning 2.0.0 — https://semver.org/spec/v2.0.0.html",
      "npm semver package README — https://github.com/npm/node-semver#readme",
      "Test vectors verified by running semver@7.x via Node.js 22.20.0 on macOS/Darwin 25.3.0, 2026-03-31"
    ],
    "not_derived_from": [
      "semver package source: semver.js"
    ],
    "spec_authors": ["Theseus Z-layer"],
    "created_at": "2026-03-31T00:00:00Z",
    "notes": [
      "This spec exercises the semver npm package via node -e inline scripts. It is a CLI-backend spec with module_name, invoking node with require('semver').",
      "All invariants use node_module_call_eq: the function is called with JSON args, the return value is JSON.stringify'd, and compared against json.dumps(expected).",
      "null return values: semver.valid() returns null for invalid version strings. JSON.stringify(null) == 'null' == json.dumps(None).",
      "Boolean return values: semver.gt/lt/eq/satisfies return true/false. JSON.stringify(true) == 'true' == json.dumps(True).",
      "Integer return values: semver.compare returns 0, 1, or -1. semver.major/minor/patch return integers.",
      "String return values: semver.valid, semver.inc, semver.maxSatisfying, semver.minSatisfying, semver.clean return strings or null."
    ]
  },

  "library": {
    "backend": "cli",
    "command": "node",
    "module_name": "semver",
    "soname_patterns": [],
    "notes": "node must be in PATH and the semver npm package must be installed (npm install semver). Compatible with semver >= 7.0.0."
  },

  "constants": {},

  "types": {
    "semver_string": {
      "description": "A valid semantic version string in the form MAJOR.MINOR.PATCH[-prerelease][+build].",
      "fields": []
    },
    "range_string": {
      "description": "A semver range expression such as '^1.0.0', '>=2.0.0 <3.0.0', or '1.2.x'.",
      "fields": []
    }
  },

  "functions": {
    "valid": {
      "description": "Returns the cleaned version string if valid, null otherwise.",
      "parameters": [{"name": "version", "type": "string", "direction": "in"}],
      "return_type": "string | null"
    },
    "gt": {
      "description": "Returns true if v1 > v2.",
      "parameters": [
        {"name": "v1", "type": "string", "direction": "in"},
        {"name": "v2", "type": "string", "direction": "in"}
      ],
      "return_type": "boolean"
    },
    "lt": {
      "description": "Returns true if v1 < v2.",
      "parameters": [
        {"name": "v1", "type": "string", "direction": "in"},
        {"name": "v2", "type": "string", "direction": "in"}
      ],
      "return_type": "boolean"
    },
    "eq": {
      "description": "Returns true if v1 == v2.",
      "parameters": [
        {"name": "v1", "type": "string", "direction": "in"},
        {"name": "v2", "type": "string", "direction": "in"}
      ],
      "return_type": "boolean"
    },
    "compare": {
      "description": "Returns 0 if v1==v2, 1 if v1>v2, -1 if v1<v2.",
      "parameters": [
        {"name": "v1", "type": "string", "direction": "in"},
        {"name": "v2", "type": "string", "direction": "in"}
      ],
      "return_type": "integer"
    },
    "satisfies": {
      "description": "Returns true if version satisfies the range.",
      "parameters": [
        {"name": "version", "type": "string", "direction": "in"},
        {"name": "range",   "type": "string", "direction": "in"}
      ],
      "return_type": "boolean"
    },
    "major": {
      "description": "Returns the major version number.",
      "parameters": [{"name": "version", "type": "string", "direction": "in"}],
      "return_type": "integer"
    },
    "minor": {
      "description": "Returns the minor version number.",
      "parameters": [{"name": "version", "type": "string", "direction": "in"}],
      "return_type": "integer"
    },
    "patch": {
      "description": "Returns the patch version number.",
      "parameters": [{"name": "version", "type": "string", "direction": "in"}],
      "return_type": "integer"
    },
    "inc": {
      "description": "Returns the incremented version string for the given release type.",
      "parameters": [
        {"name": "version",     "type": "string", "direction": "in"},
        {"name": "release_type","type": "string", "direction": "in", "description": "One of: major, minor, patch, premajor, preminor, prepatch, prerelease"}
      ],
      "return_type": "string"
    },
    "maxSatisfying": {
      "description": "Returns the highest version in the list that satisfies the range, or null if none do.",
      "parameters": [
        {"name": "versions", "type": "string[]", "direction": "in"},
        {"name": "range",    "type": "string",   "direction": "in"}
      ],
      "return_type": "string | null"
    },
    "minSatisfying": {
      "description": "Returns the lowest version in the list that satisfies the range, or null if none do.",
      "parameters": [
        {"name": "versions", "type": "string[]", "direction": "in"},
        {"name": "range",    "type": "string",   "direction": "in"}
      ],
      "return_type": "string | null"
    },
    "clean": {
      "description": "Returns the cleaned version string (trims whitespace and leading '=' or 'v'), or null if invalid.",
      "parameters": [{"name": "version", "type": "string", "direction": "in"}],
      "return_type": "string | null"
    }
  },

  "invariants": [
    {
      "id": "semver.valid.valid_string",
      "description": "valid('1.2.3') returns '1.2.3'",
      "category": "valid",
      "kind": "node_module_call_eq",
      "rfc_reference": "Semantic Versioning 2.0.0",
      "spec": {
        "function": "valid",
        "args": ["1.2.3"],
        "expected": "1.2.3"
      }
    },
    {
      "id": "semver.valid.invalid_string",
      "description": "valid('not-a-version') returns null",
      "category": "valid",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "valid",
        "args": ["not-a-version"],
        "expected": null
      }
    },
    {
      "id": "semver.valid.v_prefix",
      "description": "valid('v1.2.3') normalises to '1.2.3'",
      "category": "valid",
      "kind": "node_module_call_eq",
      "rfc_reference": "Semantic Versioning 2.0.0",
      "spec": {
        "function": "valid",
        "args": ["v1.2.3"],
        "expected": "1.2.3"
      }
    },
    {
      "id": "semver.valid.prerelease",
      "description": "valid('1.2.3-alpha.1') returns '1.2.3-alpha.1'",
      "category": "valid",
      "kind": "node_module_call_eq",
      "rfc_reference": "Semantic Versioning 2.0.0 §9",
      "spec": {
        "function": "valid",
        "args": ["1.2.3-alpha.1"],
        "expected": "1.2.3-alpha.1"
      }
    },
    {
      "id": "semver.gt.true",
      "description": "gt('2.0.0', '1.9.9') returns true",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "gt",
        "args": ["2.0.0", "1.9.9"],
        "expected": true
      }
    },
    {
      "id": "semver.gt.false",
      "description": "gt('1.0.0', '2.0.0') returns false",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "gt",
        "args": ["1.0.0", "2.0.0"],
        "expected": false
      }
    },
    {
      "id": "semver.lt.true",
      "description": "lt('1.0.0', '2.0.0') returns true",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "lt",
        "args": ["1.0.0", "2.0.0"],
        "expected": true
      }
    },
    {
      "id": "semver.eq.true",
      "description": "eq('1.2.3', '1.2.3') returns true",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "eq",
        "args": ["1.2.3", "1.2.3"],
        "expected": true
      }
    },
    {
      "id": "semver.eq.false",
      "description": "eq('1.2.3', '1.2.4') returns false",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "eq",
        "args": ["1.2.3", "1.2.4"],
        "expected": false
      }
    },
    {
      "id": "semver.compare.equal",
      "description": "compare('1.2.3', '1.2.3') returns 0",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "compare",
        "args": ["1.2.3", "1.2.3"],
        "expected": 0
      }
    },
    {
      "id": "semver.compare.greater",
      "description": "compare('2.0.0', '1.0.0') returns 1",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "compare",
        "args": ["2.0.0", "1.0.0"],
        "expected": 1
      }
    },
    {
      "id": "semver.compare.less",
      "description": "compare('1.0.0', '2.0.0') returns -1",
      "category": "comparison",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "compare",
        "args": ["1.0.0", "2.0.0"],
        "expected": -1
      }
    },
    {
      "id": "semver.satisfies.caret_in_range",
      "description": "satisfies('1.2.3', '^1.0.0') returns true — minor/patch increments satisfy caret range",
      "category": "range",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "satisfies",
        "args": ["1.2.3", "^1.0.0"],
        "expected": true
      }
    },
    {
      "id": "semver.satisfies.caret_out_of_range",
      "description": "satisfies('2.0.0', '^1.0.0') returns false — major increment violates caret range",
      "category": "range",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "satisfies",
        "args": ["2.0.0", "^1.0.0"],
        "expected": false
      }
    },
    {
      "id": "semver.satisfies.compound_range",
      "description": "satisfies('1.5.0', '>=1.0.0 <2.0.0') returns true",
      "category": "range",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "satisfies",
        "args": ["1.5.0", ">=1.0.0 <2.0.0"],
        "expected": true
      }
    },
    {
      "id": "semver.major.extract",
      "description": "major('1.2.3') returns 1",
      "category": "fields",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "major",
        "args": ["1.2.3"],
        "expected": 1
      }
    },
    {
      "id": "semver.minor.extract",
      "description": "minor('1.2.3') returns 2",
      "category": "fields",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "minor",
        "args": ["1.2.3"],
        "expected": 2
      }
    },
    {
      "id": "semver.patch.extract",
      "description": "patch('1.2.3') returns 3",
      "category": "fields",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "patch",
        "args": ["1.2.3"],
        "expected": 3
      }
    },
    {
      "id": "semver.inc.major",
      "description": "inc('1.2.3', 'major') returns '2.0.0'",
      "category": "increment",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "inc",
        "args": ["1.2.3", "major"],
        "expected": "2.0.0"
      }
    },
    {
      "id": "semver.inc.minor",
      "description": "inc('1.2.3', 'minor') returns '1.3.0'",
      "category": "increment",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "inc",
        "args": ["1.2.3", "minor"],
        "expected": "1.3.0"
      }
    },
    {
      "id": "semver.inc.patch",
      "description": "inc('1.2.3', 'patch') returns '1.2.4'",
      "category": "increment",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "inc",
        "args": ["1.2.3", "patch"],
        "expected": "1.2.4"
      }
    },
    {
      "id": "semver.maxSatisfying.caret",
      "description": "maxSatisfying(['1.0.0','1.2.3','2.0.0'], '^1.0.0') returns '1.2.3'",
      "category": "collection",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "maxSatisfying",
        "args": [["1.0.0", "1.2.3", "2.0.0"], "^1.0.0"],
        "expected": "1.2.3"
      }
    },
    {
      "id": "semver.minSatisfying.caret",
      "description": "minSatisfying(['1.0.0','1.2.3','2.0.0'], '^1.0.0') returns '1.0.0'",
      "category": "collection",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "minSatisfying",
        "args": [["1.0.0", "1.2.3", "2.0.0"], "^1.0.0"],
        "expected": "1.0.0"
      }
    },
    {
      "id": "semver.clean.eq_v_prefix",
      "description": "clean('  =v1.5.0  ') returns '1.5.0'",
      "category": "cleanup",
      "kind": "node_module_call_eq",
      "spec": {
        "function": "clean",
        "args": ["  =v1.5.0  "],
        "expected": "1.5.0"
      }
    }
  ],

  "wire_formats": {},

  "error_model": {
    "return_code_semantics": "Functions return null for invalid input rather than throwing. node exits 0 for all invariants in this spec.",
    "stream_error_field": "null — functions return null on invalid input",
    "error_stickiness": "N/A — each function call is stateless.",
    "error_codes": []
  }
}
