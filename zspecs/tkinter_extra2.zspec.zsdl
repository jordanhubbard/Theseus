spec: tkinter_extra2
version: ">=3.9"
backend: python_module(tkinter)

docs: https://docs.python.org/3/library/tkinter.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tkinter.html — Python tkinter module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tkinter/__init__.py"
  notes:
    - "This spec extends tkinter.zspec.zsdl and tkinter_extra.zspec.zsdl."
    - "tkinter.zspec.zsdl covers: TclError __name__/__module__/__bases__; string/layout constants."
    - "tkinter_extra.zspec.zsdl covers: Tk/Frame/Widget/Misc/Variable/StringVar __name__/__module__; TclError hierarchy; StringVar hierarchy."
    - "This spec adds: Button/Label/Entry/Text/Canvas __name__; IntVar.__name__; batch table of widget class names."
    - "tkinter.Button.__name__ == 'Button' — clickable button widget."
    - "tkinter.Label.__name__ == 'Label' — text/image display widget."
    - "tkinter.Entry.__name__ == 'Entry' — single-line text input widget."
    - "tkinter.Text.__name__ == 'Text' — multi-line text editing widget."
    - "tkinter.Canvas.__name__ == 'Canvas' — general-purpose drawing widget."
    - "tkinter.IntVar.__name__ == 'IntVar' — traced integer variable, sibling of StringVar."
    - "All class name checks are safe without a running Tk display."
    - "All expected values verified with Python 3.12 tkinter on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Button — class name
# (not covered in tkinter.zspec.zsdl or tkinter_extra.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant tkinter_extra2.Button.name:
  description: "tkinter.Button.__name__ == 'Button'"
  category: class_names
  kind: python_call_eq
  function: Button.__name__.__eq__
  args: ["Button"]
  expected: true

# ---------------------------------------------------------------------------
# Label — class name
# ---------------------------------------------------------------------------

invariant tkinter_extra2.Label.name:
  description: "tkinter.Label.__name__ == 'Label'"
  category: class_names
  kind: python_call_eq
  function: Label.__name__.__eq__
  args: ["Label"]
  expected: true

# ---------------------------------------------------------------------------
# Entry — class name
# ---------------------------------------------------------------------------

invariant tkinter_extra2.Entry.name:
  description: "tkinter.Entry.__name__ == 'Entry'"
  category: class_names
  kind: python_call_eq
  function: Entry.__name__.__eq__
  args: ["Entry"]
  expected: true

# ---------------------------------------------------------------------------
# Text — class name
# ---------------------------------------------------------------------------

invariant tkinter_extra2.Text.name:
  description: "tkinter.Text.__name__ == 'Text'"
  category: class_names
  kind: python_call_eq
  function: Text.__name__.__eq__
  args: ["Text"]
  expected: true

# ---------------------------------------------------------------------------
# Canvas — class name
# ---------------------------------------------------------------------------

invariant tkinter_extra2.Canvas.name:
  description: "tkinter.Canvas.__name__ == 'Canvas'"
  category: class_names
  kind: python_call_eq
  function: Canvas.__name__.__eq__
  args: ["Canvas"]
  expected: true

# ---------------------------------------------------------------------------
# IntVar — class name
# tkinter_extra.zspec.zsdl covers StringVar.__name__ but not IntVar.__name__.
# ---------------------------------------------------------------------------

invariant tkinter_extra2.IntVar.name:
  description: "tkinter.IntVar.__name__ == 'IntVar'"
  category: class_names
  kind: python_call_eq
  function: IntVar.__name__.__eq__
  args: ["IntVar"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __name__ check for core widget classes
# Consolidates all seven widget class names (Tk, Frame, Button, Label, Entry,
# Text, Canvas) in a single table for easy coverage at a glance.
# Tk and Frame are re-expressed here as table rows; they were individual
# invariants in tkinter_extra.zspec.zsdl and are not duplicated as invariants
# in this file.
# ---------------------------------------------------------------------------

table tkinter_extra2.widget_classes.names:
  kind: python_call_eq
  category: class_names
  id_prefix: clsname

  columns: [id, function, args, expected]
  rows:
    - [Tk,     Tk.__name__.__eq__,     ["Tk"],     true]
    - [Frame,  Frame.__name__.__eq__,  ["Frame"],  true]
    - [Button, Button.__name__.__eq__, ["Button"], true]
    - [Label,  Label.__name__.__eq__,  ["Label"],  true]
    - [Entry,  Entry.__name__.__eq__,  ["Entry"],  true]
    - [Text,   Text.__name__.__eq__,   ["Text"],   true]
    - [Canvas, Canvas.__name__.__eq__, ["Canvas"], true]
