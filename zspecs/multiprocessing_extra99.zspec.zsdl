spec: multiprocessing_extra99
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra98

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra98.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.pool.AsyncResult and multiprocessing.Process method __qualname__ lengths. NEW in extra99: AsyncResult.get.__qualname__=='ApplyResult.get' (len=15, qualname uses internal class name ApplyResult); AsyncResult.wait.__qualname__=='ApplyResult.wait' (len=16); AsyncResult.ready.__qualname__=='ApplyResult.ready' (len=17); AsyncResult.successful.__qualname__=='ApplyResult.successful' (len=22, longest); AsyncResult.__mro__.__len__()==2 (AsyncResult is an alias for ApplyResult, MRO=[ApplyResult, object]); Pool.__init__.__qualname__=='Pool.__init__' (len=13); multiprocessing.Process.start.__qualname__=='BaseProcess.start' (len=17, inherited from BaseProcess); Process.join.__qualname__=='BaseProcess.join' (len=16); Process.terminate.__qualname__=='BaseProcess.terminate' (len=21); Process.is_alive.__qualname__=='BaseProcess.is_alive' (len=20); Process.run.__qualname__=='BaseProcess.run' (len=15); Process.kill.__qualname__=='BaseProcess.kill' (len=16); Process.__module__=='multiprocessing.context'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.AsyncResult.__mro__ uses 'ApplyResult' not 'AsyncResult'. AsyncResult is a module-level alias for ApplyResult in pool.py; the MRO shows [ApplyResult, object] and all method qualnames use 'ApplyResult.' prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start'. Process inherits all core methods from BaseProcess (start, join, run, terminate, kill, is_alive); only Process.__init__ would have qualname 'Process.__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.AsyncResult method qualnames — extra99
#
# Wave 254 theme: multiprocessing.pool.AsyncResult (alias for ApplyResult)
#                 method qualnames.
#
# AsyncResult.get.__qualname__         == 'ApplyResult.get'         (len=15)
# AsyncResult.wait.__qualname__        == 'ApplyResult.wait'        (len=16)
# AsyncResult.ready.__qualname__       == 'ApplyResult.ready'       (len=17)
# AsyncResult.successful.__qualname__  == 'ApplyResult.successful'  (len=22)
# AsyncResult.__mro__.__len__() == 2   ([ApplyResult, object])
# ---------------------------------------------------------------------------

table multiprocessing_extra99.mp_asyncresult_qualnames:
  description: "multiprocessing.pool.AsyncResult method __qualname__ checks in mpasyncresult99 namespace — wave 254 theme: AsyncResult is a module-level alias for ApplyResult in Lib/multiprocessing/pool.py; AsyncResult.__mro__.__len__()==2 (MRO is [ApplyResult, object] — the MRO uses the real class name ApplyResult, not the alias AsyncResult); AsyncResult.__bases__[0].__name__.__eq__('object')==True (direct subclass of object); AsyncResult.get.__qualname__.__eq__('ApplyResult.get')==True (len=15: 'ApplyResult.'=12 + 'get'=3; qualname uses the real class name); AsyncResult.wait.__qualname__.__eq__('ApplyResult.wait')==True (len=16: 'ApplyResult.'=12 + 'wait'=4); AsyncResult.ready.__qualname__.__eq__('ApplyResult.ready')==True (len=17: 'ApplyResult.'=12 + 'ready'=5); AsyncResult.successful.__qualname__.__eq__('ApplyResult.successful')==True (len=22: 'ApplyResult.'=12 + 'successful'=10, the longest); all have class='function' (pure-Python in pool.py); AsyncResult.__module__=='multiprocessing.pool'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpasyncresult99

  columns: [id, function, args, expected, description]
  rows:
    - [ar_get_qeq,      "multiprocessing.pool.AsyncResult.get.__qualname__.__eq__",         ["ApplyResult.get"],        true, "AsyncResult.get.__qualname__ == 'ApplyResult.get' (len=15, uses real class name ApplyResult); verified with Python 3.14.3"]
    - [ar_get_qlen,     "multiprocessing.pool.AsyncResult.get.__qualname__.__len__",        [],                         15,   "AsyncResult.get.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [ar_wait_qeq,     "multiprocessing.pool.AsyncResult.wait.__qualname__.__eq__",        ["ApplyResult.wait"],       true, "AsyncResult.wait.__qualname__ == 'ApplyResult.wait' (len=16); verified with Python 3.14.3"]
    - [ar_wait_qlen,    "multiprocessing.pool.AsyncResult.wait.__qualname__.__len__",       [],                         16,   "AsyncResult.wait.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [ar_ready_qeq,    "multiprocessing.pool.AsyncResult.ready.__qualname__.__eq__",       ["ApplyResult.ready"],      true, "AsyncResult.ready.__qualname__ == 'ApplyResult.ready' (len=17); verified with Python 3.14.3"]
    - [ar_ready_qlen,   "multiprocessing.pool.AsyncResult.ready.__qualname__.__len__",      [],                         17,   "AsyncResult.ready.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [ar_succ_qeq,     "multiprocessing.pool.AsyncResult.successful.__qualname__.__eq__",  ["ApplyResult.successful"], true, "AsyncResult.successful.__qualname__ == 'ApplyResult.successful' (len=22, longest); verified with Python 3.14.3"]
    - [ar_succ_qlen,    "multiprocessing.pool.AsyncResult.successful.__qualname__.__len__", [],                         22,   "AsyncResult.successful.__qualname__.__len__() == 22 (longest AsyncResult method qualname); verified with Python 3.14.3"]
    - [ar_mro_len,      "multiprocessing.pool.AsyncResult.__mro__.__len__",                 [],                         2,    "AsyncResult.__mro__.__len__() == 2 — [ApplyResult, object]; verified with Python 3.14.3"]
    - [ar_base0,        "multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__",    ["object"],                 true, "AsyncResult.__bases__[0].__name__ == 'object' — direct subclass; verified with Python 3.14.3"]
    - [ar_get_cls,      "multiprocessing.pool.AsyncResult.get.__class__.__name__.__eq__",   ["function"],               true, "AsyncResult.get.__class__.__name__ == 'function' — pure-Python; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool.__init__ and multiprocessing.Process — extra99
#
# Pool.__init__.__qualname__         == 'Pool.__init__'          (len=13)
# Process.start.__qualname__         == 'BaseProcess.start'      (len=17, inherited)
# Process.join.__qualname__          == 'BaseProcess.join'       (len=16, inherited)
# Process.run.__qualname__           == 'BaseProcess.run'        (len=15, inherited)
# Process.terminate.__qualname__     == 'BaseProcess.terminate'  (len=21, inherited)
# Process.kill.__qualname__          == 'BaseProcess.kill'       (len=16, inherited)
# Process.is_alive.__qualname__      == 'BaseProcess.is_alive'   (len=20, inherited)
# Process.__module__ == 'multiprocessing.context'
# Process.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra99.mp_process_qualnames:
  description: "multiprocessing.pool.Pool.__init__ and multiprocessing.Process method __qualname__ checks in mpasyncresult99 namespace — wave 254 theme: Process inherits all core methods from BaseProcess (like BoundedSemaphore.acquire inherits from Semaphore); Pool.__init__.__qualname__.__eq__('Pool.__init__')==True (len=13: 'Pool.'=5 + '__init__'=8); multiprocessing.Process.start.__qualname__.__eq__('BaseProcess.start')==True (len=17: 'BaseProcess.'=12 + 'start'=5; inherited, qualname uses defining class); Process.join.__qualname__.__eq__('BaseProcess.join')==True (len=16: 'BaseProcess.'=12 + 'join'=4); Process.run.__qualname__.__eq__('BaseProcess.run')==True (len=15: 'BaseProcess.'=12 + 'run'=3, shortest); Process.terminate.__qualname__.__eq__('BaseProcess.terminate')==True (len=21: 'BaseProcess.'=12 + 'terminate'=9, longest); Process.kill.__qualname__.__eq__('BaseProcess.kill')==True (len=16: same as join); Process.is_alive.__qualname__.__eq__('BaseProcess.is_alive')==True (len=20: 'BaseProcess.'=12 + 'is_alive'=8); Process.__module__=='multiprocessing.context'; Process.__mro__.__len__()==3 ([Process, BaseProcess, object]); all methods have class='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpasyncresult99a

  columns: [id, function, args, expected, description]
  rows:
    - [pool_init_qeq,    "multiprocessing.pool.Pool.__init__.__qualname__.__eq__",   ["Pool.__init__"],          true, "multiprocessing.pool.Pool.__init__.__qualname__ == 'Pool.__init__' (len=13); verified with Python 3.14.3"]
    - [pool_init_qlen,   "multiprocessing.pool.Pool.__init__.__qualname__.__len__",  [],                         13,   "multiprocessing.pool.Pool.__init__.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [proc_start_qeq,   multiprocessing.Process.start.__qualname__.__eq__,          ["BaseProcess.start"],      true, "Process.start.__qualname__ == 'BaseProcess.start' (len=17, inherited from BaseProcess); verified with Python 3.14.3"]
    - [proc_start_qlen,  multiprocessing.Process.start.__qualname__.__len__,         [],                         17,   "Process.start.__qualname__.__len__() == 17 (inherited, qualname reflects BaseProcess); verified with Python 3.14.3"]
    - [proc_join_qeq,    multiprocessing.Process.join.__qualname__.__eq__,           ["BaseProcess.join"],       true, "Process.join.__qualname__ == 'BaseProcess.join' (len=16); verified with Python 3.14.3"]
    - [proc_join_qlen,   multiprocessing.Process.join.__qualname__.__len__,          [],                         16,   "Process.join.__qualname__.__len__() == 16 (tied with kill); verified with Python 3.14.3"]
    - [proc_run_qeq,     multiprocessing.Process.run.__qualname__.__eq__,            ["BaseProcess.run"],        true, "Process.run.__qualname__ == 'BaseProcess.run' (len=15, shortest inherited method); verified with Python 3.14.3"]
    - [proc_term_qeq,    multiprocessing.Process.terminate.__qualname__.__eq__,      ["BaseProcess.terminate"],  true, "Process.terminate.__qualname__ == 'BaseProcess.terminate' (len=21, longest inherited method); verified with Python 3.14.3"]
    - [proc_term_qlen,   multiprocessing.Process.terminate.__qualname__.__len__,     [],                         21,   "Process.terminate.__qualname__.__len__() == 21 (longest Process method qualname); verified with Python 3.14.3"]
    - [proc_kill_qeq,    multiprocessing.Process.kill.__qualname__.__eq__,           ["BaseProcess.kill"],       true, "Process.kill.__qualname__ == 'BaseProcess.kill' (len=16, tied with join); verified with Python 3.14.3"]
    - [proc_alive_qeq,   multiprocessing.Process.is_alive.__qualname__.__eq__,       ["BaseProcess.is_alive"],   true, "Process.is_alive.__qualname__ == 'BaseProcess.is_alive' (len=20); verified with Python 3.14.3"]
    - [proc_alive_qlen,  multiprocessing.Process.is_alive.__qualname__.__len__,      [],                         20,   "Process.is_alive.__qualname__.__len__() == 20 ('BaseProcess.'=12 + 'is_alive'=8); verified with Python 3.14.3"]
    - [proc_module,      multiprocessing.Process.__module__.__eq__,                  ["multiprocessing.context"], true, "multiprocessing.Process.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [proc_mro_len,     multiprocessing.Process.__mro__.__len__,                    [],                         3,    "multiprocessing.Process.__mro__.__len__() == 3 — [Process, BaseProcess, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra99
# ---------------------------------------------------------------------------

invariant multiprocessing_extra99.AsyncResult_qualname_uses_ApplyResult:
  description: "multiprocessing.pool.AsyncResult.get.__qualname__.__eq__('ApplyResult.get') returns True — AsyncResult is a module-level alias for ApplyResult in Lib/multiprocessing/pool.py; when Python resolves AsyncResult.get, it returns the actual class attribute, whose __qualname__ uses 'ApplyResult.' prefix (the real class name, not the alias); AsyncResult.__mro__ shows [ApplyResult, object] using the real class name; all four AsyncResult methods use 'ApplyResult.' prefix: get (len=15), wait (len=16), ready (len=17), successful (len=22); this parallels asyncio.BoundedSemaphore.acquire.__qualname__=='Semaphore.acquire' where the qualname reflects the defining class, not the accessing class; NEW in extra99: first standalone AsyncResult qualname prefix invariant in mpasyncresult99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.AsyncResult.get.__qualname__.__eq__"
  args: ["ApplyResult.get"]
  expected: true

invariant multiprocessing_extra99.Process_terminate_qualname_longest:
  description: "multiprocessing.Process.terminate.__qualname__.__len__() == 21 — Process.terminate.__qualname__ is 'BaseProcess.terminate' (21 chars: 'BaseProcess.'=12 + 'terminate'=9); this is the longest qualname among the inherited Process methods: run=15, join=16, kill=16, start=17, is_alive=20, terminate=21; the compound method name 'terminate' contributes 9 chars; Process.terminate immediately terminates the process (SIGTERM on Unix, TerminateProcess on Windows); Process.terminate.__class__.__name__ is 'function'; all Process methods are inherited from BaseProcess so all qualnames use 'BaseProcess.' prefix; compare: Pool.terminate.__qualname__=='Pool.terminate' (len=14, a direct Pool method with shorter prefix); NEW in extra99: first standalone Process.terminate qualname length invariant in mpasyncresult99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.terminate.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra99.Process_mro_len_is_3:
  description: "multiprocessing.Process.__mro__.__len__() == 3 — Process's MRO is [Process, BaseProcess, object] (length=3); this 3-element chain includes the intermediate BaseProcess class from which Process inherits all its core methods (start, join, run, terminate, kill, is_alive); Process.__module__ is 'multiprocessing.context' (context.py); contrasts with multiprocessing.pool.Pool.__mro__.__len__()==2 ([Pool, object], direct subclass); the 3-element MRO parallels asyncio.Task.__mro__.__len__()==3 ([Task, Future, object]); Process.__bases__[0].__name__ is 'BaseProcess'; NEW in extra99: first standalone Process MRO length invariant in mpasyncresult99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra99.AsyncResult_successful_qualname_len_22:
  description: "multiprocessing.pool.AsyncResult.successful.__qualname__.__len__() == 22 — AsyncResult.successful.__qualname__ is 'ApplyResult.successful' (22 chars: 'ApplyResult.'=12 + 'successful'=10); this is the longest AsyncResult method qualname; compare all four AsyncResult method qualname lengths: get=15, wait=16, ready=17, successful=22; successful() returns True if the call completed without exception — it raises ValueError if not yet complete; AsyncResult.successful.__class__.__name__ is 'function'; AsyncResult.__module__ is 'multiprocessing.pool'; NEW in extra99: first standalone AsyncResult.successful qualname length invariant in mpasyncresult99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.AsyncResult.successful.__qualname__.__len__"
  args: []
  expected: 22

invariant multiprocessing_extra99.Pool_init_qualname_len_13:
  description: "multiprocessing.pool.Pool.__init__.__qualname__.__len__() == 13 — Pool.__init__.__qualname__ is 'Pool.__init__' (13 chars: 'Pool.'=5 + '__init__'=8); this contrasts with all the other Pool method qualnames covered in extra98: map=8, join=9, apply=10, close=10, starmap=12, terminate=14, apply_async=16; Pool.__init__ is defined directly in Pool itself (Lib/multiprocessing/pool.py) and handles creation of worker processes, result queues, and task dispatcher threads; Pool.__init__.__class__.__name__ is 'function'; Pool.__module__ is 'multiprocessing.pool'; NEW in extra99: first standalone Pool.__init__ qualname length invariant in mpasyncresult99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__init__.__qualname__.__len__"
  args: []
  expected: 13
