spec: re_extra1831
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 569 (_extra1831): descriptor protocol (__get__/__set__/__delete__/__set_name__); __call__ callable protocol; re module function attribute presence."
    - "re.Pattern and re.Match are C types; they do not define custom __init__ or __get__."
    - "re.error is a Python exception class and defines __init__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra1831.descriptor_protocol:
  description: "re types descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1831

  columns: [id, function, args, expected]
  rows:
    - ["re1831001", "re.Pattern.__dict__.__contains__", ["__get__"], false]
    - ["re1831002", "re.Pattern.__dict__.__contains__", ["__set__"], false]
    - ["re1831003", "re.Match.__dict__.__contains__", ["__get__"], false]
    - ["re1831004", "re.Match.__dict__.__contains__", ["__set__"], false]
    - ["re1831005", "re.error.__dict__.__contains__", ["__get__"], false]
    - ["re1831006", "re.RegexFlag.__dict__.__contains__", ["__get__"], false]
    - ["re1831007", "re.Pattern.__dict__.__contains__", ["__set_name__"], false]
    - ["re1831008", "re.Match.__dict__.__contains__", ["__set_name__"], false]

table re_extra1831.callable_protocol:
  description: "re types __call__ and __init__ callable protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1831

  columns: [id, function, args, expected]
  rows:
    - ["re1831101", "re.Pattern.__dict__.__contains__", ["__call__"], false]
    - ["re1831102", "re.Match.__dict__.__contains__", ["__call__"], false]
    - ["re1831103", "re.error.__dict__.__contains__", ["__call__"], false]
    - ["re1831104", "re.Pattern.__dict__.__contains__", ["__iter__"], false]
    - ["re1831105", "re.Match.__dict__.__contains__", ["__iter__"], false]
    - ["re1831106", "re.Pattern.__dict__.__contains__", ["__init__"], false]
    - ["re1831107", "re.Match.__dict__.__contains__", ["__init__"], false]
    - ["re1831108", "re.error.__dict__.__contains__", ["__init__"], true]

table re_extra1831.re_module_functions:
  description: "re module-level function dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1831

  columns: [id, function, args, expected]
  rows:
    - ["re1831201", "re.__dict__.__contains__", ["compile"], true]
    - ["re1831202", "re.__dict__.__contains__", ["match"], true]
    - ["re1831203", "re.__dict__.__contains__", ["search"], true]
    - ["re1831204", "re.__dict__.__contains__", ["findall"], true]
    - ["re1831205", "re.__dict__.__contains__", ["finditer"], true]
    - ["re1831206", "re.__dict__.__contains__", ["sub"], true]
    - ["re1831207", "re.__dict__.__contains__", ["subn"], true]
    - ["re1831208", "re.__dict__.__contains__", ["split"], true]
    - ["re1831209", "re.__dict__.__contains__", ["fullmatch"], true]
    - ["re1831210", "re.__dict__.__contains__", ["escape"], true]
