spec: functools_extra184
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.reduce and namedtuple-like behavior in functools — functools.reduce.__class__.__name__=='builtin_function_or_method'; functools.reduce.__module__=='_functools' (the C extension); functools.reduce.__name__=='reduce' (len=6); functools.reduce.__qualname__=='reduce' (len=6; equals __name__); functools.reduce.__doc__.__class__.__name__=='str'; functools.reduce.__doc__.__contains__('function')==True; functools._lru_cache_wrapper.__qualname__=='_lru_cache_wrapper' (len=18; qualname equals name — not nested class)."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is implemented in C (_functoolsmodule.c) as a C-level built-in function; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce lives in the C extension module _functools (not the pure-Python functools wrapper); its __module__ attribute is '_functools'. Verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce' — the C-level __name__ of the reduce built-in is 'reduce', 6 characters. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' — for a module-level C built-in, __qualname__ equals __name__; 'reduce' has 6 characters, the same as __name__. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — the reduce built-in has a C-level docstring accessible as a Python str. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__contains__('function') == True — reduce's docstring describes a 'function' parameter (the callable to apply); str.__contains__('function') returns True. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__qualname__ == '_lru_cache_wrapper' — _lru_cache_wrapper is a module-level C extension type (not nested), so its __qualname__ equals its __name__ '_lru_cache_wrapper', 18 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce __class__.__name__ and __module__
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__module__ == '_functools'
# functools.reduce.__module__.__len__() == 9
#
# reduce is implemented in C (_functoolsmodule.c) as a C-level built-in;
# its __class__.__name__ is 'builtin_function_or_method'. Its __module__ is
# '_functools' (the C extension, 9 chars — the leading underscore plus 'functools').
# New to extra184.
# ---------------------------------------------------------------------------

table functools_extra184.reduce_class_and_module:
  description: "functools.reduce.__class__.__name__ 'builtin_function_or_method'; __module__ '_functools' len 9; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: funcreduce184

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.reduce is a C-level built-in function implemented in _functoolsmodule.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra184"]
    - [reduce_module_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — functools.reduce is defined in the C extension _functools (_functoolsmodule.c); its __module__ attribute is the string '_functools' (not 'functools'); str.__eq__('_functools') returns True; new to extra184"]
    - [reduce_module_len_10,
       "reduce.__module__.__len__",
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — the module name '_functools' has exactly 10 characters: _-f-u-n-c-t-o-o-l-s; str.__len__() returns 10; new to extra184"]
    - [reduce_class_name_len_26,
       "reduce.__class__.__name__.__len__",
       [],
       26,
       "functools.reduce.__class__.__name__.__len__() == 26 — the class name 'builtin_function_or_method' has exactly 26 characters: b-u-i-l-t-i-n-_-f-u-n-c-t-i-o-n-_-o-r-_-m-e-t-h-o-d; str.__len__() returns 26; new to extra184"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce __name__ and __qualname__
#
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__name__.__len__() == 6
# functools.reduce.__qualname__ == 'reduce'
# functools.reduce.__qualname__.__len__() == 6
#
# For a module-level C built-in, __qualname__ equals __name__. 'reduce' has
# 6 characters. New to extra184.
# ---------------------------------------------------------------------------

table functools_extra184.reduce_name_and_qualname:
  description: "functools.reduce.__name__ 'reduce' len 6; __qualname__ 'reduce' len 6 (equals __name__); new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: funcreduce184

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       "reduce.__name__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — functools.reduce is a C-level built-in function in _functoolsmodule.c; its __name__ is 'reduce'; str.__eq__('reduce') returns True; new to extra184"]
    - [reduce_name_len_6,
       "reduce.__name__.__len__",
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — the name 'reduce' has exactly 6 characters: r-e-d-u-c-e; str.__len__() returns 6; new to extra184"]
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — for a module-level C built-in function, __qualname__ equals __name__; functools.reduce.__qualname__ is 'reduce'; str.__eq__('reduce') returns True; new to extra184"]
    - [reduce_qualname_len_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — the qualified name 'reduce' has exactly 6 characters: r-e-d-u-c-e; same length as __name__ (6); str.__len__() returns 6; new to extra184"]

# ---------------------------------------------------------------------------
# Table 3: functools.reduce __doc__ and _lru_cache_wrapper __qualname__
#
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.reduce.__doc__.__contains__('function') == True
# functools._lru_cache_wrapper.__qualname__ == '_lru_cache_wrapper'
# functools._lru_cache_wrapper.__qualname__.__len__() == 18
#
# reduce's docstring is a Python str whose __class__.__name__ is 'str'. The
# docstring mentions 'function' (the callable parameter). _lru_cache_wrapper
# is a module-level C extension type, so __qualname__ equals __name__
# '_lru_cache_wrapper' (18 chars). New to extra184.
# ---------------------------------------------------------------------------

table functools_extra184.reduce_doc_and_lru_qualname:
  description: "functools.reduce.__doc__ is str; __doc__ contains 'function'; _lru_cache_wrapper.__qualname__ '_lru_cache_wrapper' len 18 (equals __name__); new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: funcreduce184

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_class_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — functools.reduce is a C-level built-in function with a C-level docstring that is exposed as a Python str; its __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra184"]
    - [reduce_doc_contains_function,
       "reduce.__doc__.__contains__",
       ["function"],
       true,
       "functools.reduce.__doc__.__contains__('function') == True — functools.reduce's docstring describes applying a 'function' of two arguments cumulatively to the elements of an iterable; str.__contains__('function') returns True; new to extra184"]
    - [lru_cache_wrapper_qualname_eq,
       "_lru_cache_wrapper.__qualname__.__eq__",
       ["_lru_cache_wrapper"],
       true,
       "functools._lru_cache_wrapper.__qualname__.__eq__('_lru_cache_wrapper') == True — functools._lru_cache_wrapper is a module-level C extension type (not a nested class), so its __qualname__ equals its __name__ '_lru_cache_wrapper'; str.__eq__('_lru_cache_wrapper') returns True; new to extra184"]
    - [lru_cache_wrapper_qualname_len_18,
       "_lru_cache_wrapper.__qualname__.__len__",
       [],
       18,
       "functools._lru_cache_wrapper.__qualname__.__len__() == 18 — the qualified name '_lru_cache_wrapper' has exactly 18 characters: _-l-r-u-_-c-a-c-h-e-_-w-r-a-p-p-e-r; same length as __name__ (18) since qualname equals name for a module-level type; str.__len__() returns 18; new to extra184"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra184
# ---------------------------------------------------------------------------

invariant functools_extra184.reduce_class_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C-level built-in in _functoolsmodule.c; new to extra184"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra184.reduce_module_is_c_functools:
  description: "functools.reduce.__module__ == '_functools' — reduce's __module__ is the C extension '_functools', not the pure-Python 'functools'; new to extra184"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra184.reduce_name_is_reduce:
  description: "functools.reduce.__name__ == 'reduce' — C built-in with __name__ 'reduce' (6 chars); new to extra184"
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra184.reduce_qualname_equals_name:
  description: "functools.reduce.__qualname__ == 'reduce' — module-level C built-in has __qualname__ == __name__ == 'reduce' (6 chars); new to extra184"
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra184.reduce_doc_is_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce's C docstring is exposed as a Python str; new to extra184"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra184.reduce_doc_mentions_function:
  description: "functools.reduce.__doc__.__contains__('function') == True — reduce's docstring uses the word 'function' to describe its callable parameter; new to extra184"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["function"]
  expected: true

invariant functools_extra184.lru_cache_wrapper_qualname_eq_name:
  description: "functools._lru_cache_wrapper.__qualname__ == '_lru_cache_wrapper' — module-level C extension type has qualname equal to name (18 chars); new to extra184"
  kind: python_call_eq
  function: _lru_cache_wrapper.__qualname__.__eq__
  args: ["_lru_cache_wrapper"]
  expected: true

invariant functools_extra184.lru_cache_wrapper_qualname_len_18:
  description: "functools._lru_cache_wrapper.__qualname__.__len__() == 18 — '_lru_cache_wrapper' is 18 characters long; qualname equals name for module-level type; new to extra184"
  kind: python_call_eq
  function: _lru_cache_wrapper.__qualname__.__len__
  args: []
  expected: 18
