spec: uuid_extra1876
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "uuid module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party uuid libraries"
  notes:
    - "Tests attribute access protocol membership in uuid.UUID and uuid.SafeUUID"
    - "UUID uses __setattr__ to enforce immutability of fields after construction"
    - "UUID uses __slots__ for memory efficiency; SafeUUID is an IntEnum subclass with no custom __slots__"
    - "RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, RESERVED_FUTURE are module-level variant constants"
  created_at: "2026-04-12"

table uuid_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu1876-aa-001", "uuid.UUID.__dict__.__contains__", ["__getattr__"], false]
    - ["uu1876-aa-002", "uuid.UUID.__dict__.__contains__", ["__setattr__"], true]
    - ["uu1876-aa-003", "uuid.UUID.__dict__.__contains__", ["__delattr__"], false]
    - ["uu1876-aa-004", "uuid.UUID.__dict__.__contains__", ["__getattribute__"], false]
    - ["uu1876-aa-005", "uuid.SafeUUID.__dict__.__contains__", ["__getattr__"], false]
    - ["uu1876-aa-006", "uuid.SafeUUID.__dict__.__contains__", ["__setattr__"], false]
    - ["uu1876-aa-007", "uuid.SafeUUID.__dict__.__contains__", ["__delattr__"], false]
    - ["uu1876-aa-008", "uuid.SafeUUID.__dict__.__contains__", ["__getattribute__"], false]

table uuid_extra1876.introspection_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu1876-ip-001", "uuid.UUID.__dict__.__contains__", ["__dir__"], false]
    - ["uu1876-ip-002", "uuid.UUID.__dict__.__contains__", ["__sizeof__"], false]
    - ["uu1876-ip-003", "uuid.SafeUUID.__dict__.__contains__", ["__dir__"], false]
    - ["uu1876-ip-004", "uuid.SafeUUID.__dict__.__contains__", ["__sizeof__"], false]
    - ["uu1876-ip-005", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
    - ["uu1876-ip-006", "uuid.SafeUUID.__dict__.__contains__", ["__slots__"], false]
    - ["uu1876-ip-007", "uuid.UUID.__dict__.__contains__", ["__weakref__"], false]
    - ["uu1876-ip-008", "uuid.UUID.__dict__.__contains__", ["__dict__"], false]

table uuid_extra1876.uuid_reserved_constants:
  columns: [id, function, args, expected]
  rows:
    - ["uu1876-rc-001", "uuid.__dict__.__contains__", ["RESERVED_NCS"], true]
    - ["uu1876-rc-002", "uuid.__dict__.__contains__", ["RFC_4122"], true]
    - ["uu1876-rc-003", "uuid.__dict__.__contains__", ["RESERVED_MICROSOFT"], true]
    - ["uu1876-rc-004", "uuid.__dict__.__contains__", ["RESERVED_FUTURE"], true]
    - ["uu1876-rc-005", "uuid.UUID.__dict__.__contains__", ["is_safe"], true]
    - ["uu1876-rc-006", "uuid.UUID.__dict__.__contains__", ["variant"], true]
    - ["uu1876-rc-007", "uuid.UUID.__dict__.__contains__", ["version"], true]
    - ["uu1876-rc-008", "uuid.UUID.__dict__.__contains__", ["int"], true]
    - ["uu1876-rc-009", "uuid.UUID.__dict__.__contains__", ["bytes"], true]
    - ["uu1876-rc-010", "uuid.UUID.__dict__.__contains__", ["bytes_le"], true]
