spec: collections_abc_extra
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "This spec extends collections_abc.zspec.zsdl with additional identity and module checks."
    - "collections_abc.zspec.zsdl covers __name__ for all ABCs and __module__ for Sequence, Mapping, Hashable, Iterable, Callable, Set."
    - "Here we provide __module__ coverage for the ABCs not checked in the base spec: Iterator, Generator, MutableSequence, MutableMapping, MutableSet."
    - "We also add Callable.__module__ as an explicit invariant (table form in base spec; here as named invariants)."
    - "All ABC classes in collections.abc report __module__ == 'collections.abc' regardless of where they are physically defined."
    - "collections.abc.Callable.__name__ == 'Callable' — distinct from builtins.callable() function."
    - "collections.abc.Iterator is a subclass of Iterable; its __name__ is 'Iterator'."
    - "collections.abc.Generator is a subclass of Iterator; its __name__ is 'Generator'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — explicit named invariants for each ABC
# collections_abc.zspec.zsdl already covers these via a table; here we provide
# standalone invariants for the subset called out in the spec brief, plus
# Set and MutableSet for completeness.
# ---------------------------------------------------------------------------

invariant collections_abc_extra.Callable.name:
  description: "collections.abc.Callable.__name__ == 'Callable'"
  category: class_names
  kind: python_call_eq
  function: Callable.__name__.__eq__
  args: ["Callable"]
  expected: true

invariant collections_abc_extra.Callable.module:
  description: "collections.abc.Callable.__module__ == 'collections.abc'"
  category: module_checks
  kind: python_call_eq
  function: Callable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant collections_abc_extra.Iterable.name:
