  category: class_names
  kind: python_call_eq
  function: Iterable.__name__.__eq__
  args: ["Iterable"]
  expected: true

invariant collections_abc_extra.Iterable.module:
  description: "collections.abc.Iterable.__module__ == 'collections.abc'"
  category: module_checks
  kind: python_call_eq
  function: Iterable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

