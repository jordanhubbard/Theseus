# ---------------------------------------------------------------------------
# Iterator is a subclass of Iterable — hierarchy check
# Generator is a subclass of Iterator — hierarchy check
# ---------------------------------------------------------------------------

invariant collections_abc_extra.Iterator.base_is_Iterable:
  description: "collections.abc.Iterator.__bases__[0].__name__ == 'Iterable' — Iterator directly inherits from Iterable"
  category: class_hierarchy
  kind: python_call_eq
  function: Iterator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Iterable"

invariant collections_abc_extra.Generator.base_is_Iterator:
  description: "collections.abc.Generator.__bases__[0].__name__ == 'Iterator' — Generator directly inherits from Iterator"
  category: class_hierarchy
  kind: python_call_eq
  function: Generator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Iterator"

invariant collections_abc_extra.MutableSequence.base_is_Sequence:
  description: "collections.abc.MutableSequence.__bases__[0].__name__ == 'Sequence' — MutableSequence directly inherits from Sequence"
  category: class_hierarchy
  kind: python_call_eq
  function: MutableSequence.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Sequence"

invariant collections_abc_extra.MutableMapping.base_is_Mapping:
  description: "collections.abc.MutableMapping.__bases__[0].__name__ == 'Mapping' — MutableMapping directly inherits from Mapping"
  category: class_hierarchy
  kind: python_call_eq
  function: MutableMapping.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Mapping"
