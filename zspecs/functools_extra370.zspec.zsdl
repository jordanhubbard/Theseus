spec: functools_extra370
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.wraps.__name__ == 'wraps' — wraps is a pure-Python decorator function in Lib/functools.py. Verified with Python 3.14.4."
    - "functools.wraps.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.4."
    - "functools.cached_property.__name__ == 'cached_property' — cached_property is a pure-Python descriptor class in Lib/functools.py. Verified with Python 3.14.4."
    - "functools.cached_property.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.4."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object. Verified with Python 3.14.4."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple constant defined in Lib/functools.py. Verified with Python 3.14.4."
    - "len(functools.WRAPPER_ASSIGNMENTS) == 6 — in Python 3.14 the tuple contains: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'. Verified with Python 3.14.4."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — cmp_to_key is a C builtin implemented in _functools. Verified with Python 3.14.4."
    - "functools.cmp_to_key.__module__ == '_functools' — C implementation lives in _functools; functools re-exports it. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps and functools.cached_property identity
#
# functools.wraps.__name__ == 'wraps'
# functools.wraps.__module__ == 'functools'
# functools.cached_property.__name__ == 'cached_property'
# functools.cached_property.__module__ == 'functools'
# functools.cached_property.__bases__[0].__name__ == 'object'
#
# wraps is a pure-Python decorator in Lib/functools.py that copies
# __module__, __name__, __qualname__, __doc__, and __dict__ from the
# wrapped function onto the wrapper. cached_property is a pure-Python
# descriptor class that caches the result of a property method on the instance.
# ---------------------------------------------------------------------------

table functools_extra370.wraps_and_cached_property_identity:
  description: "functools.wraps decorator function and functools.cached_property descriptor class identity: __name__, __module__, base class; new to extra370"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswcp370

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_eq,
       "wraps.__name__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — wraps is a pure-Python decorator function in Lib/functools.py that updates a wrapper function to look like the wrapped function; its __name__ attribute is 'wraps'; str.__eq__('wraps') returns True; new to extra370"]
    - [wraps_module_eq,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra370"]
    - [cached_property_name_eq,
       "cached_property.__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a pure-Python descriptor class in Lib/functools.py that caches the result of a method call on the instance dict; its __name__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra370"]
    - [cached_property_module_eq,
       "cached_property.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra370"]
    - [cached_property_bases_first_eq_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra370"]

# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_ASSIGNMENTS tuple identity and functools.cmp_to_key
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
# functools.cmp_to_key.__name__ == 'cmp_to_key'
# functools.cmp_to_key.__module__ == '_functools'
#
# WRAPPER_ASSIGNMENTS is a module-level tuple constant listing the attributes
# copied from a wrapped function. In Python 3.14 it contains 6 items:
# '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'.
# cmp_to_key is a C builtin implemented in _functools and re-exported by functools.
# ---------------------------------------------------------------------------

table functools_extra370.wrapper_assignments_and_cmp_to_key_identity:
  description: "functools.WRAPPER_ASSIGNMENTS class name and length, and functools.cmp_to_key C builtin identity: __name__ and __module__; new to extra370"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswack370

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_name_eq,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py listing which attributes are copied by wraps; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra370"]
    - [wrapper_assignments_len_eq,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — in Python 3.14 WRAPPER_ASSIGNMENTS contains '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; __len__() returns 6; new to extra370"]
    - [cmp_to_key_name_eq,
       "cmp_to_key.__name__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — cmp_to_key is a C builtin implemented in Modules/_functoolsmodule.c and re-exported by functools; its __name__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra370"]
    - [cmp_to_key_module_eq,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is a C builtin whose implementation lives in the _functools extension module; even though functools re-exports it its __module__ stays '_functools'; str.__eq__('_functools') returns True; new to extra370"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra370
# ---------------------------------------------------------------------------

invariant functools_extra370.wraps_name:
  description: "functools.wraps.__name__ == 'wraps' — pure-Python decorator function in Lib/functools.py; new to extra370"
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra370.wraps_module:
  description: "functools.wraps.__module__ == 'functools' — defined in Lib/functools.py; new to extra370"
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra370.cached_property_name:
  description: "functools.cached_property.__name__ == 'cached_property' — pure-Python descriptor class in Lib/functools.py; new to extra370"
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra370.cached_property_module:
  description: "functools.cached_property.__module__ == 'functools' — defined in Lib/functools.py; new to extra370"
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra370.cached_property_bases_object:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object; new to extra370"
  kind: python_call_eq
  function: cached_property.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant functools_extra370.wrapper_assignments_class_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant listing attributes to copy; new to extra370"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra370.wrapper_assignments_len:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 — Python 3.14 adds '__annotate__' and '__type_params__' for a total of 6 entries; new to extra370"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra370.cmp_to_key_name:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' — C builtin re-exported from _functools; new to extra370"
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra370.cmp_to_key_module:
  description: "functools.cmp_to_key.__module__ == '_functools' — C implementation in _functools; functools re-exports it but __module__ stays '_functools'; new to extra370"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true
