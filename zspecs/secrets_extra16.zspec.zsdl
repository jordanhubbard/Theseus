spec: secrets_extra16
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra15.zspec.zsdl — covers token_bytes/hex/urlsafe __name__; choice/__name__; randbelow/__name__; SystemRandom.seed/uniform/randint __qualname__; SystemRandom.__module__; SystemRandom.__bases__[0].__name__."
    - "secrets_extra14.zspec.zsdl — covers SystemRandom.random/__qualname__; SystemRandom.getrandbits/__qualname__; SystemRandom.__qualname__ re-anchor; token __module__ re-anchors; DEFAULT_ENTROPY re-anchor."
    - "secrets_extra13.zspec.zsdl — covers callable __class__.__name__ table; DEFAULT_ENTROPY.__class__.__qualname__.__eq__."
    - "secrets_extra12.zspec.zsdl — covers __qualname__.__len__() for token_bytes/hex/urlsafe/choice/randbelow/randbits/SystemRandom."
    - "secrets_extra4.zspec.zsdl — covers __qualname__.__eq__ for all callables; DEFAULT_ENTROPY == 32; randbits.__qualname__."
    - "secrets_extra3.zspec.zsdl — covers token_hex/__module__, token_urlsafe/__module__, choice/__module__, randbelow/__module__, randbits/__module__."
    - "secrets_extra2.zspec.zsdl — covers token_bytes/__module__, token_hex/__module__, token_urlsafe/__module__."
  notes:
    - "This spec extends secrets through secrets_extra15; it does NOT duplicate invariants present in those files."
    - "Focus: SystemRandom.choice/shuffle/sample __qualname__ (novel — extra15 covers seed/uniform/randint; no prior spec covers choice/shuffle/sample via class attribute path); DEFAULT_ENTROPY.__class__.__name__ re-anchored from extra16 (extra13 covers __class__.__qualname__; __class__.__name__ is the same 'int' string but accessed via different attribute — new namespace anchor); token_bytes/__qualname__.__len__() re-anchored from extra16 (extra12 covers from extra12 namespace); SystemRandom.__qualname__ re-anchored from extra16 namespace."
    - "secrets.SystemRandom.choice.__qualname__ == 'Random.choice': choice is inherited from random.Random; its qualname uses the 'Random.' prefix. No prior spec accesses SystemRandom.choice.__qualname__ via the class attribute path. extra4 covers secrets.choice.__qualname__ via the module-level alias (bound method). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.shuffle.__qualname__ == 'Random.shuffle': inherited from Random. No prior spec covers shuffle.__qualname__ via any access path. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.sample.__qualname__ == 'Random.sample': inherited from Random. No prior spec covers sample.__qualname__ via any access path. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.DEFAULT_ENTROPY.__class__.__name__ == 'int': secrets_extra13 covers DEFAULT_ENTROPY.__class__.__qualname__.__eq__('int'). The __class__.__name__ attribute is a distinct accessor that returns the same string value 'int'. This invariant provides independent coverage from the extra16 namespace. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_bytes.__qualname__.__len__() == 11: secrets_extra12 covers this from extra12 namespace ('token_bytes' == 11 chars). Re-anchored from extra16 for independent regression coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__qualname__.__len__() == 9: secrets_extra12 covers this from extra12 namespace ('token_hex' == 9 chars). Re-anchored from extra16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__qualname__ == 'SystemRandom': covered by extra4 and extra14 in their namespaces. Re-anchored from extra16 for cross-namespace regression coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SystemRandom inherited method __qualname__ — choice, shuffle, sample
#
# secrets_extra15 covers SystemRandom.seed.__qualname__ (defined on
# SystemRandom itself), SystemRandom.uniform.__qualname__, and
# SystemRandom.randint.__qualname__ (both inherited from Random).
# secrets_extra14 covers SystemRandom.random.__qualname__ and
# SystemRandom.getrandbits.__qualname__ via the class attribute path.
# No prior spec covers choice, shuffle, or sample __qualname__.
# All three are inherited from random.Random; qualnames use 'Random.' prefix.
# choice len == 13 ('Random.choice'), shuffle len == 14, sample len == 13.
# ---------------------------------------------------------------------------

invariant secrets_extra16.SystemRandom.choice.qualname:
  description: "secrets.SystemRandom.choice.__qualname__ == 'Random.choice' — inherited from random.Random"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.choice.__qualname__.__eq__
  args: ["Random.choice"]
  expected: true

invariant secrets_extra16.SystemRandom.shuffle.qualname:
  description: "secrets.SystemRandom.shuffle.__qualname__ == 'Random.shuffle' — inherited from random.Random"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.shuffle.__qualname__.__eq__
  args: ["Random.shuffle"]
  expected: true

invariant secrets_extra16.SystemRandom.sample.qualname:
  description: "secrets.SystemRandom.sample.__qualname__ == 'Random.sample' — inherited from random.Random"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.sample.__qualname__.__eq__
  args: ["Random.sample"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_ENTROPY.__class__.__name__ — re-anchored from extra16 namespace
#
# secrets_extra13 covers DEFAULT_ENTROPY.__class__.__qualname__.__eq__('int').
# The __class__.__name__ accessor is a distinct attribute chain that yields
# the same 'int' string. This invariant anchors from the extra16 namespace,
# providing independent regression coverage via a different attribute path.
# ---------------------------------------------------------------------------

invariant secrets_extra16.DEFAULT_ENTROPY.class_name:
  description: "secrets.DEFAULT_ENTROPY.__class__.__name__ == 'int' — DEFAULT_ENTROPY is an int, anchored from extra16"
  category: type_metadata
  kind: python_call_eq
  function: DEFAULT_ENTROPY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# token_bytes and token_hex __qualname__.__len__() — re-anchored from extra16
#
# secrets_extra12 covers __qualname__.__len__() for token_bytes (11),
# token_hex (9), token_urlsafe (13) from the extra12 namespace.
# These invariants anchor the same length checks from the extra16 namespace
# for independent regression coverage. 'token_bytes' == 11 chars,
# 'token_hex' == 9 chars.
# ---------------------------------------------------------------------------

table secrets_extra16.token_qualname_lengths:
  description: "token_bytes and token_hex __qualname__.__len__() — anchored from extra16 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: sectql16

  columns: [id, function, args, expected]
  rows:
    - [token_bytes, token_bytes.__qualname__.__len__, [], 11]
    - [token_hex,   token_hex.__qualname__.__len__,   [],  9]

# ---------------------------------------------------------------------------
# SystemRandom.__qualname__ — re-anchored from extra16 namespace
#
# secrets_extra4 covers SystemRandom.__qualname__.__eq__('SystemRandom').
# secrets_extra14 re-anchors from extra14 namespace.
# This invariant provides a third independent anchor from the extra16 namespace.
# ---------------------------------------------------------------------------

invariant secrets_extra16.SystemRandom.qualname:
  description: "secrets.SystemRandom.__qualname__ == 'SystemRandom' — anchored from extra16 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.__qualname__.__eq__
  args: ["SystemRandom"]
  expected: true
