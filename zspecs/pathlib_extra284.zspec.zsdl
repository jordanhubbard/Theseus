spec: pathlib_extra284
version: ">=3.12"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib_extra283 covers Path.name, Path.stem, Path.suffix, Path.anchor properties."
    - "This spec focuses on Path.parts and Path.parent properties."
    - "Path('/foo/bar').parts == ('/', 'foo', 'bar') — absolute path splits root and each component."
    - "Path('foo/bar').parts == ('foo', 'bar') — relative path has no leading '/' component."
    - "Path('/').parts == ('/',) — root-only path has a single-element tuple."
    - "Path('.').parts == () — the current-directory dot path yields an empty tuple."
    - "Path('/foo/bar').parent — the parent of '/foo/bar' is '/foo' as a string."
    - "Path('/foo').parent — parent of '/foo' is '/' (the filesystem root)."
    - "Path('/').parent — parent of '/' is '/' itself (no further parent)."
    - "Path('foo/bar').parent — parent of relative 'foo/bar' is 'foo'."
    - "Path('foo').parent — parent of a bare relative name is '.' (current directory)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.parts — tuple of path components
# Absolute paths include '/' as the first element; relative paths do not.
# ---------------------------------------------------------------------------

table pathlib_extra284.path_parts_len:
  description: "pathlib.Path.parts length — number of components in the parts tuple"
  kind: python_call_eq
  category: components
  id_prefix: parts_len
  function: Path
  method: parts.__len__

  columns: [id, args, expected, description]
  rows:
    - [abs_two_deep,  ["/foo/bar"],   3, "Path('/foo/bar').parts has 3 elements: '/', 'foo', 'bar'"]
    - [rel_two_deep,  ["foo/bar"],    2, "Path('foo/bar').parts has 2 elements: 'foo', 'bar'"]
    - [root_only,     ["/"],          1, "Path('/').parts has 1 element: ('/',)"]
    - [abs_one_deep,  ["/foo"],       2, "Path('/foo').parts has 2 elements: '/', 'foo'"]
    - [rel_three,     ["a/b/c"],      3, "Path('a/b/c').parts has 3 elements: 'a', 'b', 'c'"]

# ---------------------------------------------------------------------------
# Path.parent — the logical parent of the path
# Returned as a Path object; tested via str() via method_chain.
# ---------------------------------------------------------------------------

table pathlib_extra284.path_parent_str:
  description: "pathlib.Path.parent string representation — logical parent path"
  kind: python_call_eq
  category: components
  id_prefix: parent
  function: Path
  method: parent.__str__

  columns: [id, args, expected, description]
  rows:
    - [abs_two_deep,   ["/foo/bar"],     "/foo", "Path('/foo/bar').parent == '/foo'"]
    - [abs_three_deep, ["/foo/bar/baz"], "/foo/bar", "Path('/foo/bar/baz').parent == '/foo/bar'"]
    - [abs_one_deep,   ["/foo"],         "/",    "Path('/foo').parent == '/' — parent of top-level dir is root"]
    - [root,           ["/"],            "/",    "Path('/').parent == '/' — root is its own parent"]
    - [rel_two_deep,   ["foo/bar"],      "foo",  "Path('foo/bar').parent == 'foo'"]
    - [rel_one_deep,   ["foo"],          ".",    "Path('foo').parent == '.' — bare name has cwd as parent"]

# ---------------------------------------------------------------------------
# Path.parts element access — confirm individual elements of the parts tuple
# ---------------------------------------------------------------------------

invariant pathlib_extra284.Path.parts.abs_root_element:
  description: "pathlib.Path('/foo/bar').parts[0] == '/' — first element of absolute path is the root"
  category: components
  kind: python_call_eq
  function: Path
  args: ["/foo/bar"]
  method: "parts.__getitem__"
  method_args: [0]
  expected: "/"

invariant pathlib_extra284.Path.parts.abs_first_component:
  description: "pathlib.Path('/foo/bar').parts[1] == 'foo' — second element is first directory name"
  category: components
  kind: python_call_eq
  function: Path
  args: ["/foo/bar"]
  method: "parts.__getitem__"
  method_args: [1]
  expected: "foo"

invariant pathlib_extra284.Path.parts.abs_last_component:
  description: "pathlib.Path('/foo/bar').parts[2] == 'bar' — third element is the final component"
  category: components
  kind: python_call_eq
  function: Path
  args: ["/foo/bar"]
  method: "parts.__getitem__"
  method_args: [2]
  expected: "bar"

invariant pathlib_extra284.Path.parts.rel_first_component:
  description: "pathlib.Path('foo/bar').parts[0] == 'foo' — relative path starts with first name (no root)"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo/bar"]
  method: "parts.__getitem__"
  method_args: [0]
  expected: "foo"

invariant pathlib_extra284.Path.parts.root_only_element:
  description: "pathlib.Path('/').parts[0] == '/' — root-only path has one element: '/'"
  category: components
  kind: python_call_eq
  function: Path
  args: ["/"]
  method: "parts.__getitem__"
  method_args: [0]
  expected: "/"

invariant pathlib_extra284.Path.parts.dot_is_empty_tuple:
  description: "pathlib.Path('.').parts == () — current-directory dot path yields empty parts tuple"
  category: components
  kind: python_call_eq
  function: Path
  args: ["."]
  method: parts.__len__
  expected: 0
