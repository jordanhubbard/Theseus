spec: re_extra93
version: ">=3.9"
backend: python_module(re)
extends: re_extra92

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra92."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; method qualnames; re.error/__name__; module-level function qualnames; re.RegexFlag hierarchy; re module constants; Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError attributes; re.NOFLAG value; Pattern/Match method __doc__.__len__(); re.Pattern/__dict__.__contains__; re module-level function __qualname__ for all functions; Pattern/Match __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); RegexFlag class identity; re.Pattern/Match method __qualname__ string equality; re_extra92 covered re.Pattern/Match method __qualname__ string lengths."
    - "This spec covers: re module identity — __name__, __package__, __spec__, __loader__, __file__, __doc__; plus re constants (IGNORECASE, MULTILINE, DOTALL) class names."
    - "re.__name__ == 're' — the module name is 're'."
    - "re.__package__ == 're' — the package is 're' (re is its own package in Python 3.11+)."
    - "re.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec instance."
    - "re.__spec__.name == 're' — the spec's name attribute matches the module name."
    - "re.__loader__.__class__.__name__ == 'SourceFileLoader' — re is loaded from source (.py file)."
    - "re.__file__.__class__.__name__ == 'str' — __file__ is a string path."
    - "re.__doc__.__class__.__name__ == 'str' — __doc__ is a string."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is a member of the RegexFlag IntFlag enum."
    - "re.MULTILINE.__class__.__name__ == 'RegexFlag' — MULTILINE is a member of the RegexFlag IntFlag enum."
    - "re.DOTALL.__class__.__name__ == 'RegexFlag' — DOTALL is a member of the RegexFlag IntFlag enum."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module __name__ and __package__
# re is loaded as a package in Python 3.11+ (re/__init__.py).
# __name__ == 're'; __package__ == 're'.
# ---------------------------------------------------------------------------

table re_extra93.module_name_package:
  description: "re.__name__ and re.__package__ string equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: remoduleid93

  columns: [id, function, args, expected]
  rows:
    - [re_name_eq,      __name__.__eq__,    ["re"], true]
    - [re_name_not_re2, __name__.__eq__,    ["_re"], false]
    - [re_pkg_eq_re,    __package__.__eq__, ["re"], true]
    - [re_pkg_not_empty, __package__.__eq__, [""], false]

# ---------------------------------------------------------------------------
# re module __spec__ identity
# re.__spec__ is a ModuleSpec instance; its .name attribute equals 're'.
# ---------------------------------------------------------------------------

table re_extra93.module_spec_identity:
  description: "re.__spec__.__class__.__name__ and re.__spec__.name string equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: remoduleid93

  columns: [id, function, args, expected]
  rows:
    - [spec_cls_name,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [spec_cls_not_str,   __spec__.__class__.__name__.__eq__, ["str"],        false]
    - [spec_name_eq_re,    __spec__.name.__eq__,               ["re"],         true]
    - [spec_name_not_re2,  __spec__.name.__eq__,               ["_re"],        false]

# ---------------------------------------------------------------------------
# re module __loader__ and __file__ class names
# re is loaded by SourceFileLoader from a .py file; __file__ is a str.
# ---------------------------------------------------------------------------

table re_extra93.module_loader_file:
  description: "re.__loader__.__class__.__name__ and re.__file__.__class__.__name__ string equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: remoduleid93

  columns: [id, function, args, expected]
  rows:
    - [loader_cls_name,     __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]
    - [loader_not_frozen,   __loader__.__class__.__name__.__eq__, ["FrozenImporter"],   false]
    - [file_cls_name_str,   __file__.__class__.__name__.__eq__,   ["str"],              true]
    - [file_cls_not_bytes,  __file__.__class__.__name__.__eq__,   ["bytes"],            false]

# ---------------------------------------------------------------------------
# re.__doc__ class name and re constants (IGNORECASE, MULTILINE, DOTALL) class names
# __doc__ is a str; all re flag constants are RegexFlag enum members (IntFlag subclass).
# ---------------------------------------------------------------------------

table re_extra93.doc_and_constants_class_names:
  description: "re.__doc__.__class__.__name__ and re.IGNORECASE/MULTILINE/DOTALL.__class__.__name__ string equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: remoduleid93

  columns: [id, function, args, expected]
  rows:
    - [doc_cls_name,       __doc__.__class__.__name__.__eq__,        ["str"],        true]
    - [ignorecase_cls,     IGNORECASE.__class__.__name__.__eq__,     ["RegexFlag"],  true]
    - [multiline_cls,      MULTILINE.__class__.__name__.__eq__,      ["RegexFlag"],  true]
    - [dotall_cls,         DOTALL.__class__.__name__.__eq__,         ["RegexFlag"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra93.module.name_eq_re:
  description: "re.__name__ == 're' (the module name is the canonical two-letter string 're')"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra93.module.package_eq_re:
  description: "re.__package__ == 're' (re is a package in Python 3.11+, so __package__ == '__name__')"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["re"]
  expected: true

invariant re_extra93.module.spec_class_is_ModuleSpec:
  description: "re.__spec__.__class__.__name__ == 'ModuleSpec' (module spec is always a ModuleSpec instance)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant re_extra93.module.loader_is_SourceFileLoader:
  description: "re.__loader__.__class__.__name__ == 'SourceFileLoader' (re is loaded from source, not frozen)"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant re_extra93.constants.IGNORECASE_class_is_RegexFlag:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (IGNORECASE is an IntFlag member of the RegexFlag enum)"
  category: module_identity
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
