spec: io_extra1741
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra1681.zspec.zsdl — covers __call__, __enter__/__exit__, __iter__/__next__ protocol"
    - "io_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
    - "io_extra1651.zspec.zsdl — covers __init_subclass__, __class_getitem__, module attr presence"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol — which io types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "No io type (abstract or concrete) defines __get__, __set__, __delete__, or __set_name__ in its own __dict__."
    - "io stream classes are not descriptors; they do not participate in the descriptor protocol."
    - "IOBase defines __subclasshook__ in its own __dict__ as part of the ABC virtual subclass registration mechanism."
    - "RawIOBase, BufferedIOBase, and TextIOBase do NOT define __subclasshook__ in their own __dict__; they inherit it from IOBase via ABCMeta."
    - "Concrete types (StringIO, BytesIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper) do not define __subclasshook__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table io_extra1741.descriptor_protocol
# __get__, __set__, __delete__, __set_name__ are absent from every io type's
# own __dict__. io stream classes are not descriptors.
# ---------------------------------------------------------------------------

table io_extra1741.descriptor_protocol:
  description: "io types descriptor protocol (__get__/__set__/__delete__/__set_name__) dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1741

  columns: [id, function, args, expected]
  rows:
    - ["io1741001", IOBase.__dict__.__contains__,          ["__get__"],      false]
    - ["io1741002", IOBase.__dict__.__contains__,          ["__set__"],      false]
    - ["io1741003", IOBase.__dict__.__contains__,          ["__delete__"],   false]
    - ["io1741004", IOBase.__dict__.__contains__,          ["__set_name__"], false]
    - ["io1741005", RawIOBase.__dict__.__contains__,       ["__get__"],      false]
    - ["io1741006", RawIOBase.__dict__.__contains__,       ["__set__"],      false]
    - ["io1741007", RawIOBase.__dict__.__contains__,       ["__delete__"],   false]
    - ["io1741008", BufferedIOBase.__dict__.__contains__,  ["__get__"],      false]
    - ["io1741009", BufferedIOBase.__dict__.__contains__,  ["__set__"],      false]
    - ["io1741010", BufferedIOBase.__dict__.__contains__,  ["__delete__"],   false]
    - ["io1741011", TextIOBase.__dict__.__contains__,      ["__get__"],      false]
    - ["io1741012", TextIOBase.__dict__.__contains__,      ["__set__"],      false]
    - ["io1741013", TextIOBase.__dict__.__contains__,      ["__delete__"],   false]
    - ["io1741014", StringIO.__dict__.__contains__,        ["__get__"],      false]
    - ["io1741015", BytesIO.__dict__.__contains__,         ["__get__"],      false]
    - ["io1741016", FileIO.__dict__.__contains__,          ["__get__"],      false]
    - ["io1741017", BufferedReader.__dict__.__contains__,  ["__get__"],      false]
    - ["io1741018", BufferedWriter.__dict__.__contains__,  ["__get__"],      false]
    - ["io1741019", TextIOWrapper.__dict__.__contains__,   ["__get__"],      false]
    - ["io1741020", TextIOWrapper.__dict__.__contains__,   ["__set__"],      false]

# ---------------------------------------------------------------------------
# Table io_extra1741.subclasshook_protocol
# IOBase defines __subclasshook__ in its own __dict__ as part of the ABC
# mechanism that enables isinstance() checks for virtual subclasses.
# Subclasses of IOBase do NOT re-define __subclasshook__ in their own __dict__.
# ---------------------------------------------------------------------------

table io_extra1741.subclasshook_protocol:
  description: "ABC __subclasshook__ dict-presence checks for io types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1741

  columns: [id, function, args, expected]
  rows:
    - ["io1741021", IOBase.__dict__.__contains__,          ["__subclasshook__"], true]
    - ["io1741022", RawIOBase.__dict__.__contains__,       ["__subclasshook__"], false]
    - ["io1741023", BufferedIOBase.__dict__.__contains__,  ["__subclasshook__"], false]
    - ["io1741024", TextIOBase.__dict__.__contains__,      ["__subclasshook__"], false]
    - ["io1741025", StringIO.__dict__.__contains__,        ["__subclasshook__"], false]
    - ["io1741026", BytesIO.__dict__.__contains__,         ["__subclasshook__"], false]
    - ["io1741027", FileIO.__dict__.__contains__,          ["__subclasshook__"], false]
    - ["io1741028", BufferedReader.__dict__.__contains__,  ["__subclasshook__"], false]
    - ["io1741029", BufferedWriter.__dict__.__contains__,  ["__subclasshook__"], false]
    - ["io1741030", TextIOWrapper.__dict__.__contains__,   ["__subclasshook__"], false]
