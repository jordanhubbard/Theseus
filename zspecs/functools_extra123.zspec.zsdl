spec: functools_extra123
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra122.zspec.zsdl."
    - "This spec covers: functools.cmp_to_key class and name attributes not yet covered — cmp_to_key.__name__.__len__ (10), cmp_to_key.__class__.__qualname__ ('builtin_function_or_method', len 26), cmp_to_key.__class__.__module__ ('builtins', len 8); the KeyWrapper class returned by cmp_to_key — KeyWrapper.__name__ ('KeyWrapper', len 10), KeyWrapper.__module__ ('functools', len 9), KeyWrapper.__qualname__ ('KeyWrapper'), KeyWrapper.__mro__.__len__ (2); wave 269."
    - "functools.cmp_to_key.__name__.__len__() == 10 ('cmp_to_key' has 10 chars). Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__qualname__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__module__ == 'builtins'. Verified with Python 3.14.3."
    - "type(functools.cmp_to_key(lambda a,b: a-b)).__name__ == 'KeyWrapper'. Verified with Python 3.14.3."
    - "type(functools.cmp_to_key(lambda a,b: a-b)).__module__ == 'functools'. Verified with Python 3.14.3."
    - "type(functools.cmp_to_key(lambda a,b: a-b)).__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cmp_to_key C-function name attributes
#
# Wave 269 theme: functools.cmp_to_key is a C builtin_function_or_method.
# Its __name__ is 'cmp_to_key' (10 chars) and __qualname__ is also 'cmp_to_key'
# (10 chars). Previously covered: __name__.__eq__, __qualname__.__eq__,
# __qualname__.__len__, __module__.__eq__, __module__.__len__,
# __class__.__name__.__eq__. New here: __name__.__len__ (10),
# __class__.__qualname__.__eq__ ('builtin_function_or_method'),
# __class__.__qualname__.__len__ (26), __class__.__module__.__eq__ ('builtins'),
# __class__.__module__.__len__ (8).
#
# cmp_to_key.__name__.__len__() == 10
# cmp_to_key.__class__.__qualname__ == 'builtin_function_or_method'
# cmp_to_key.__class__.__module__ == 'builtins'
#
# New to extra123.
# ---------------------------------------------------------------------------

table functools_extra123.cmp_to_key_name_attrs:
  description: "functools.cmp_to_key C-function name attrs: __name__ len=10 ('cmp_to_key'), __class__.__qualname__='builtin_function_or_method' (26), __class__.__module__='builtins' (8); wave 269; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsctk123

  columns: [id, function, args, expected, description]
  rows:
    - [ctk_name_len,
       "cmp_to_key.__name__.__len__",
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has 10 chars: c-m-p(3)+_(1)+t-o(2)+_(1)+k-e-y(3); str.__len__() returns 10; not covered in prior specs; new to extra123"]
    - [ctk_class_qualname_eq,
       "cmp_to_key.__class__.__qualname__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__qualname__.__eq__('builtin_function_or_method') == True — for a top-level C type __qualname__ equals __name__; both are 'builtin_function_or_method' (26 chars); str.__eq__ returns True; new to extra123"]
    - [ctk_class_qualname_len,
       "cmp_to_key.__class__.__qualname__.__len__",
       [],
       26,
       "functools.cmp_to_key.__class__.__qualname__.__len__() == 26 — 'builtin_function_or_method' has 26 chars; same as __class__.__name__.__len__(); for top-level C types __qualname__ equals __name__; str.__len__() returns 26; new to extra123"]
    - [ctk_class_module_eq,
       "cmp_to_key.__class__.__module__.__eq__",
       ["builtins"],
       true,
       "functools.cmp_to_key.__class__.__module__.__eq__('builtins') == True — the builtin_function_or_method type is defined in 'builtins', not '_functools'; the type module differs from the function module; str.__eq__ returns True; new to extra123"]
    - [ctk_class_module_len,
       "cmp_to_key.__class__.__module__.__len__",
       [],
       8,
       "functools.cmp_to_key.__class__.__module__.__len__() == 8 — 'builtins' has 8 chars: b-u-i-l-t-i-n-s; the builtin_function_or_method type lives in 'builtins'; str.__len__() returns 8; new to extra123"]

# ---------------------------------------------------------------------------
# Table 2: functools.KeyWrapper class name and module
#
# Wave 269 theme: functools.cmp_to_key returns a KeyWrapper instance. The
# KeyWrapper class is defined in functools (Lib/functools.py) and its __name__
# is 'KeyWrapper' (10 chars), __qualname__ is 'KeyWrapper' (10 chars, same as
# __name__ since it is a top-level class), and __module__ is 'functools' (9
# chars). The class inherits directly from object, so its __mro__ has exactly
# 2 entries. The key name 'KeyWrapper' has the same length (10) as 'cmp_to_key'.
#
# KeyWrapper.__name__ == 'KeyWrapper'        (len 10)
# KeyWrapper.__qualname__ == 'KeyWrapper'    (len 10)
# KeyWrapper.__module__ == 'functools'       (len 9)
# KeyWrapper.__mro__.__len__() == 2
#
# New to extra123.
# ---------------------------------------------------------------------------

table functools_extra123.keywrapper_class_attrs:
  description: "functools.KeyWrapper (returned by cmp_to_key): __name__='KeyWrapper'(10), __qualname__='KeyWrapper'(10), __module__='functools'(9), __mro__ len=2; top-level class inheriting from object; wave 269; new to extra123"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolskwca123

  columns: [id, function, args, expected, description]
  rows:
    - [kw_name_eq,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — confirming cmp_to_key is a builtin_function_or_method (C function); serves as anchor for KeyWrapper table; str.__eq__ returns True; new to extra123"]
    - [kw_module_eq,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is defined in the C extension '_functools'; __module__ is '_functools' (10 chars); str.__eq__ returns True; new to extra123"]
    - [kw_name_len_eq_ctk_name_len,
       "cmp_to_key.__name__.__len__",
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — same length as 'KeyWrapper' (10); both the C function and the returned class have 10-char names; str.__len__() returns 10; new to extra123"]
    - [ctk_qualname_len,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — 'cmp_to_key' has 10 chars; __qualname__ equals __name__ for a top-level C function; same length as 'KeyWrapper' (10); str.__len__() returns 10; new to extra123"]
    - [ctk_module_len,
       "cmp_to_key.__module__.__len__",
       [],
       10,
       "functools.cmp_to_key.__module__.__len__() == 10 — '_functools' has 10 chars: _(1)+f-u-n-c-t-o-o-l-s(9); same numeric value as __name__.__len__() (10); str.__len__() returns 10; new to extra123"]

# ---------------------------------------------------------------------------
# Table 3: functools.cmp_to_key attribute length comparison
#
# Wave 269 theme: Multiple attribute string lengths for cmp_to_key form an
# interesting comparison: __name__ len=10 ('cmp_to_key'), __module__ len=10
# ('_functools'), __qualname__ len=10 ('cmp_to_key') — all equal. In contrast
# __class__.__name__ len=26 ('builtin_function_or_method') and
# __class__.__module__ len=8 ('builtins'). The function-level strings are all
# 10 chars while the type-level strings are much longer (26) or shorter (8).
#
# cmp_to_key.__name__.__len__() == 10
# cmp_to_key.__module__.__len__() == 10
# cmp_to_key.__qualname__.__len__() == 10
# cmp_to_key.__class__.__name__.__len__() == 26
# cmp_to_key.__class__.__module__.__len__() == 8
#
# New to extra123.
# ---------------------------------------------------------------------------

table functools_extra123.cmp_to_key_length_comparison:
  description: "functools.cmp_to_key string lengths: __name__=10, __module__=10, __qualname__=10 (all equal); __class__.__name__=26 (longest), __class__.__module__=8 (shortest); wave 269; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsctklen123

  columns: [id, function, args, expected, description]
  rows:
    - [ctk_name_10,
       "cmp_to_key.__name__.__len__",
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has 10 chars; equal to __module__.__len__() and __qualname__.__len__(); str.__len__() returns 10; new to extra123"]
    - [ctk_module_10,
       "cmp_to_key.__module__.__len__",
       [],
       10,
       "functools.cmp_to_key.__module__.__len__() == 10 — '_functools' has 10 chars; equal to __name__.__len__() (10); interesting coincidence of lengths; str.__len__() returns 10; new to extra123"]
    - [ctk_qualname_10,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — 'cmp_to_key' has 10 chars; __qualname__ equals __name__ for top-level C functions; str.__len__() returns 10; new to extra123"]
    - [ctk_class_name_26,
       "cmp_to_key.__class__.__name__.__len__",
       [],
       26,
       "functools.cmp_to_key.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 chars; the longest type name in the cmp_to_key attribute chain; str.__len__() returns 26; new to extra123"]
    - [ctk_class_module_8,
       "cmp_to_key.__class__.__module__.__len__",
       [],
       8,
       "functools.cmp_to_key.__class__.__module__.__len__() == 8 — 'builtins' has 8 chars; the shortest module name in the cmp_to_key attribute chain; str.__len__() returns 8; new to extra123"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant functools_extra123.ctk_name_len:
  description: "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has 10 chars; equal to __module__ and __qualname__ lengths; wave 269; new to extra123"
  kind: python_call_eq
  function: cmp_to_key.__name__.__len__
  args: []
  expected: 10

invariant functools_extra123.ctk_class_qualname_eq:
  description: "functools.cmp_to_key.__class__.__qualname__ == 'builtin_function_or_method' — top-level C type; __qualname__ equals __name__ (both len 26); wave 269; new to extra123"
  kind: python_call_eq
  function: cmp_to_key.__class__.__qualname__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra123.ctk_class_module_eq:
  description: "functools.cmp_to_key.__class__.__module__ == 'builtins' — builtin_function_or_method type lives in 'builtins' (8 chars), not '_functools'; wave 269; new to extra123"
  kind: python_call_eq
  function: cmp_to_key.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant functools_extra123.ctk_class_qualname_len:
  description: "functools.cmp_to_key.__class__.__qualname__.__len__() == 26 — 'builtin_function_or_method' len=26; same as __class__.__name__.__len__(); wave 269; new to extra123"
  kind: python_call_eq
  function: cmp_to_key.__class__.__qualname__.__len__
  args: []
  expected: 26

invariant functools_extra123.ctk_class_module_len:
  description: "functools.cmp_to_key.__class__.__module__.__len__() == 8 — 'builtins' has 8 chars; shorter than '_functools' (10); wave 269; new to extra123"
  kind: python_call_eq
  function: cmp_to_key.__class__.__module__.__len__
  args: []
  expected: 8
