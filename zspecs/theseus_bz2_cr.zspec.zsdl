spec: theseus_bz2_cr
version: ">=3.8"
backend: python_cleanroom(theseus_bz2_cr)
blocks: bz2

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/bz2.html"
  not_derived_from:
    - "CPython source: Lib/bz2.py (internal implementation)"
  notes:
    - "Clean-room bz2 module. Do NOT import bz2."
    - "Uses _bz2 C extension or subprocess fallback."
    - "compress(data, compresslevel=9): return bz2-compressed bytes."
    - "decompress(data): return decompressed bytes."
    - "BZ2File(filename, mode): file-like object for bz2 files."
    - "BZ2Compressor(compresslevel=9): incremental compressor."
    - "BZ2Decompressor(): incremental decompressor."

error_model: python_exceptions

invariant theseus_bz2_cr.bz2_compress_decompress:
  description: "decompress(compress(b'hello')) == b'hello'"
  category: compress
  kind: python_call_eq
  function: bz2_compress_decompress
  args: []
  expected: true

invariant theseus_bz2_cr.bz2_magic:
  description: "compress(b'x') starts with BZ2 magic bytes b'BZh'"
  category: compress
  kind: python_call_eq
  function: bz2_magic
  args: []
  expected: true

invariant theseus_bz2_cr.bz2_round_trip:
  description: "compress then decompress longer data preserves content"
  category: decompress
  kind: python_call_eq
  function: bz2_round_trip
  args: []
  expected: true
