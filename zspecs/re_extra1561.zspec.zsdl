spec: re_extra1561
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for re classes."
    - "re.Pattern, re.Match, and re.error are not numeric types."
    - "None of these classes define __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, or __round__ in their own __dict__."
    - "re.Pattern.__dict__ contains: __class_getitem__, __copy__, __deepcopy__, __doc__, __eq__, __ge__, __gt__, __hash__, __le__, __lt__, __module__, __ne__, __repr__."
    - "re.Match.__dict__ contains: __class_getitem__, __copy__, __deepcopy__, __doc__, __getitem__, __module__, __repr__."
    - "re.error.__dict__ contains: __doc__, __firstlineno__, __init__, __module__, __static_attributes__, __weakref__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern — numeric type conversion protocol dict-presence (all False)
# ---------------------------------------------------------------------------

table re_extra1561.pattern_numeric_protocol:
  description: "re.Pattern.__dict__ does not contain any numeric type conversion dunder"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: re1561pa

  columns: [id, function, args, expected]
  rows:
    - [re1561pa001, re.Pattern.__dict__.__contains__, ["__bool__"],    false]
    - [re1561pa002, re.Pattern.__dict__.__contains__, ["__int__"],     false]
    - [re1561pa003, re.Pattern.__dict__.__contains__, ["__float__"],   false]
    - [re1561pa004, re.Pattern.__dict__.__contains__, ["__complex__"], false]
    - [re1561pa005, re.Pattern.__dict__.__contains__, ["__index__"],   false]
    - [re1561pa006, re.Pattern.__dict__.__contains__, ["__trunc__"],   false]
    - [re1561pa007, re.Pattern.__dict__.__contains__, ["__floor__"],   false]
    - [re1561pa008, re.Pattern.__dict__.__contains__, ["__ceil__"],    false]
    - [re1561pa009, re.Pattern.__dict__.__contains__, ["__round__"],   false]

