  category: dict_presence
  id_prefix: re1561pd

  columns: [id, function, args, expected]
  rows:
    - [re1561pd001, re.Pattern.__dict__.__contains__, ["__repr__"],        true]
    - [re1561pd002, re.Pattern.__dict__.__contains__, ["__eq__"],          true]
    - [re1561pd003, re.Pattern.__dict__.__contains__, ["__hash__"],        true]
    - [re1561pd004, re.Pattern.__dict__.__contains__, ["__copy__"],        true]
    - [re1561pd005, re.Pattern.__dict__.__contains__, ["__deepcopy__"],    true]
    - [re1561pd006, re.Pattern.__dict__.__contains__, ["__class_getitem__"], true]
    - [re1561pd007, re.Pattern.__dict__.__contains__, ["__ne__"],          true]
    - [re1561pd008, re.Pattern.__dict__.__contains__, ["__lt__"],          true]
    - [re1561pd009, re.Pattern.__dict__.__contains__, ["__le__"],          true]
    - [re1561pd010, re.Pattern.__dict__.__contains__, ["__gt__"],          true]
    - [re1561pd011, re.Pattern.__dict__.__contains__, ["__ge__"],          true]

