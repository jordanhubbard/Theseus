spec: abc_extra1366
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Abstract Base Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks."
    - "abc.ABCMeta, abc.ABC, abc.abstractclassmethod, abc.abstractproperty, abc.abstractstaticmethod are all type objects."
    - "__flags__, __basicsize__, and __itemsize__ are type object attributes present on every Python class."
    - "Only the types (int) of these attributes are checked — exact integer values are platform-specific."
    - "abc.abstractmethod is a function/decorator (not a type), so it does not have __flags__ and is excluded."
    - "abc.ABCMeta is a metaclass (subclass of type); its C-type attributes are still of type int."
    - "abc.abstractclassmethod and abc.abstractstaticmethod are deprecated since Python 3.3 but still present."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1366.ABCMeta_ABC_flags_basicsize_itemsize:
  description: "abc.ABCMeta and abc.ABC __flags__, __basicsize__, __itemsize__ are all of type int"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: ab1366am
  columns: [id, function, args, expected]
  rows:
    - [ab1366am001, abc.ABCMeta.__flags__.__class__.__name__.__eq__,     ["int"], true]
    - [ab1366am002, abc.ABCMeta.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [ab1366am003, abc.ABCMeta.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
    - [ab1366am004, abc.ABC.__flags__.__class__.__name__.__eq__,         ["int"], true]
    - [ab1366am005, abc.ABC.__basicsize__.__class__.__name__.__eq__,     ["int"], true]
    - [ab1366am006, abc.ABC.__itemsize__.__class__.__name__.__eq__,      ["int"], true]

