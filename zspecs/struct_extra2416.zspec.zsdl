spec: struct_extra2416
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "CPython source — Modules/_struct.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "struct.Struct is a C extension type; it does NOT define __iter__ or __next__ in its class __dict__."
    - "struct.Struct.iter_unpack returns an unpack_iterator (from _struct); that type DOES define both __iter__ and __next__."
    - "unpack_iterator is not directly accessible as a named attribute in the struct module namespace."
    - "struct.error is an exception subclass (Exception); it defines neither __iter__ nor __next__."
    - "struct.pack, struct.unpack, struct.iter_unpack are builtin_function_or_method objects; their class lacks __iter__ and __next__."
    - "The metaclass of struct.Struct is the built-in 'type'; 'type' does not define __iter__ in its __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ in class __dict__ for struct types
# ===

table struct_extra2416.iter_in_dict:
  description: "struct.Struct and struct.error do not define __iter__; builtin_function_or_method class also lacks it"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2416
  columns: [id, function, args, expected]
  rows:
    - ["st2416001", "struct.Struct.__dict__.__contains__", ["__iter__"], false]
    - ["st2416002", "struct.error.__dict__.__contains__", ["__iter__"], false]
    - ["st2416003", "struct.pack.__class__.__dict__.__contains__", ["__iter__"], false]
    - ["st2416004", "struct.iter_unpack.__class__.__dict__.__contains__", ["__iter__"], false]
    - ["st2416005", "struct.Struct.__class__.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ in class __dict__ for struct types
# ===

table struct_extra2416.next_in_dict:
  description: "struct.Struct and struct.error do not define __next__; builtin_function_or_method class also lacks it"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2416
  columns: [id, function, args, expected]
  rows:
    - ["st2416006", "struct.Struct.__dict__.__contains__", ["__next__"], false]
    - ["st2416007", "struct.error.__dict__.__contains__", ["__next__"], false]
    - ["st2416008", "struct.pack.__class__.__dict__.__contains__", ["__next__"], false]
    - ["st2416009", "struct.iter_unpack.__class__.__dict__.__contains__", ["__next__"], false]
    - ["st2416010", "struct.Struct.__class__.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: iter_unpack presence and Struct method set
# ===

table struct_extra2416.iter_unpack_method_presence:
  description: "struct.Struct.__dict__ contains iter_unpack method; struct module exposes iter_unpack as builtin"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2416
  columns: [id, function, args, expected]
  rows:
    - ["st2416011", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2416012", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st2416013", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st2416014", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2416015", "struct.Struct.__dict__.__contains__", ["pack_into"], true]

# ===
# Table 4: type identity for struct classes
# ===

table struct_extra2416.type_names:
  description: "Class __name__ for struct types and the factory function class"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2416
  columns: [id, function, args, expected]
  rows:
    - ["st2416016", "struct.Struct.__name__", [], "Struct"]
    - ["st2416017", "struct.Struct.__class__.__name__", [], "type"]
    - ["st2416018", "struct.error.__name__", [], "error"]
    - ["st2416019", "struct.pack.__class__.__name__", [], "builtin_function_or_method"]
    - ["st2416020", "struct.iter_unpack.__class__.__name__", [], "builtin_function_or_method"]
