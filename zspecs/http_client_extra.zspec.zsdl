spec: http_client_extra
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
  notes:
    - "Extends http_client.zspec.zsdl."
    - "http_client.zspec.zsdl covers: HTTP status code constants (OK, CREATED, etc.), HTTP_PORT=80, HTTPS_PORT=443, class __name__ table for HTTPResponse/HTTPConnection/HTTPSConnection/HTTPException/InvalidURL/BadStatusLine, responses dict."
    - "This spec adds: HTTPConnection.__module__, HTTPSConnection.__name__/__module__, HTTPException.__bases__[0].__name__, HTTPResponse.__name__, NotConnected.__name__, InvalidURL.__name__, RemoteDisconnected.__name__, type identity checks."
    - "http.client.HTTPConnection.__module__ == 'http.client'."
    - "http.client.HTTPException.__bases__[0].__name__ == 'Exception' — base exception class."
    - "http.client.NotConnected and InvalidURL are both subclasses of HTTPException."
    - "http.client.RemoteDisconnected is available since Python 3.5."
    - "No actual HTTP connections are made; all invariants test class metadata and constants only."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — HTTPConnection, HTTPSConnection, HTTPException,
#                     HTTPResponse, NotConnected, InvalidURL, RemoteDisconnected
# ---------------------------------------------------------------------------

invariant http_client_extra.HTTPConnection.name:
  description: "http.client.HTTPConnection.__name__ == 'HTTPConnection'"
  category: class_names
  kind: python_call_eq
  function: HTTPConnection.__name__.__eq__
  args: ["HTTPConnection"]
  expected: true

invariant http_client_extra.HTTPSConnection.name:
  description: "http.client.HTTPSConnection.__name__ == 'HTTPSConnection'"
  category: class_names
  kind: python_call_eq
  function: HTTPSConnection.__name__.__eq__
  args: ["HTTPSConnection"]
  expected: true

invariant http_client_extra.HTTPException.name:
  description: "http.client.HTTPException.__name__ == 'HTTPException'"
  category: class_names
  kind: python_call_eq
  function: HTTPException.__name__.__eq__
  args: ["HTTPException"]
  expected: true

invariant http_client_extra.HTTPResponse.name:
  description: "http.client.HTTPResponse.__name__ == 'HTTPResponse'"
  category: class_names
  kind: python_call_eq
  function: HTTPResponse.__name__.__eq__
  args: ["HTTPResponse"]
  expected: true

invariant http_client_extra.NotConnected.name:
  description: "http.client.NotConnected.__name__ == 'NotConnected'"
  category: class_names
  kind: python_call_eq
  function: NotConnected.__name__.__eq__
  args: ["NotConnected"]
  expected: true

invariant http_client_extra.InvalidURL.name:
  description: "http.client.InvalidURL.__name__ == 'InvalidURL'"
  category: class_names
  kind: python_call_eq
  function: InvalidURL.__name__.__eq__
  args: ["InvalidURL"]
  expected: true

invariant http_client_extra.RemoteDisconnected.name:
  description: "http.client.RemoteDisconnected.__name__ == 'RemoteDisconnected'"
  category: class_names
  kind: python_call_eq
  function: RemoteDisconnected.__name__.__eq__
  args: ["RemoteDisconnected"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — HTTPConnection lives in http.client
# ---------------------------------------------------------------------------

invariant http_client_extra.HTTPConnection.module:
  description: "http.client.HTTPConnection.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: HTTPConnection.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra.HTTPSConnection.module:
  description: "http.client.HTTPSConnection.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: HTTPSConnection.__module__.__eq__
  args: ["http.client"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — HTTPException inherits from Exception
# ---------------------------------------------------------------------------

invariant http_client_extra.HTTPException.base_is_Exception:
  description: "http.client.HTTPException.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: HTTPException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# NotConnected and InvalidURL both inherit from HTTPException
# ---------------------------------------------------------------------------

invariant http_client_extra.NotConnected.base_is_HTTPException:
  description: "http.client.NotConnected.__bases__[0].__name__ == 'HTTPException'"
  category: hierarchy
  kind: python_call_eq
  function: NotConnected.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HTTPException"

invariant http_client_extra.InvalidURL.base_is_HTTPException:
  description: "http.client.InvalidURL.__bases__[0].__name__ == 'HTTPException'"
  category: hierarchy
  kind: python_call_eq
  function: InvalidURL.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HTTPException"

# ---------------------------------------------------------------------------
# Type identity checks — connection and response classes are proper types
# ---------------------------------------------------------------------------

invariant http_client_extra.HTTPConnection.is_type:
  description: "http.client.HTTPConnection.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: HTTPConnection.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant http_client_extra.HTTPSConnection.is_type:
  description: "http.client.HTTPSConnection.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: HTTPSConnection.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant http_client_extra.HTTPResponse.is_type:
  description: "http.client.HTTPResponse.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: HTTPResponse.__class__.__name__.__eq__
  args: ["type"]
  expected: true
