spec: decimal_extra131
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal exception class hierarchy — DecimalException, InvalidOperation, DivisionByZero, Overflow, Inexact, Rounded — __name__, __module__, __qualname__, __bases__[0].__name__, and __mro__.__len__() checks."
    - "decimal.DecimalException.__name__ == 'DecimalException' (length 16)."
    - "decimal.DecimalException.__module__ == 'decimal' (length 7)."
    - "decimal.DecimalException.__qualname__ == 'DecimalException' (length 16)."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (length 15) — DecimalException subclasses ArithmeticError."
    - "decimal.DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' (length 16)."
    - "decimal.InvalidOperation.__mro__.__len__() == 6 — MRO is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' (length 16)."
    - "decimal.DivisionByZero.__mro__.__len__() == 7 — DivisionByZero also inherits ZeroDivisionError."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (length 7) — Overflow subclasses Inexact, which subclasses DecimalException."
    - "decimal.Overflow.__mro__.__len__() == 8."
    - "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' (length 16)."
    - "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' (length 16)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.DecimalException class identity
# __name__ == 'DecimalException' (16), __module__ == 'decimal' (7),
# __qualname__ == 'DecimalException' (16).
# __bases__[0].__name__ == 'ArithmeticError' (15). MRO length == 5.
# __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table decimal_extra131.DecimalException_class_identity:
  description: "decimal.DecimalException class identity: __name__='DecimalException' (16), __module__='decimal' (7), __qualname__='DecimalException' (16), __bases__[0].__name__='ArithmeticError' (15), __mro__.__len__()==5"
  kind: python_call_eq
  category: class_identity
  id_prefix: decexc131

  columns: [id, function, args, expected]
  rows:
    - [dexc_name_eq,      DecimalException.__name__.__eq__,                   ["DecimalException"], true]
    - [dexc_name_len,     DecimalException.__name__.__len__,                  [],                   16]
    - [dexc_module_eq,    DecimalException.__module__.__eq__,                 ["decimal"],          true]
    - [dexc_module_len,   DecimalException.__module__.__len__,                [],                   7]
    - [dexc_qualname_eq,  DecimalException.__qualname__.__eq__,               ["DecimalException"], true]
    - [dexc_qualname_len, DecimalException.__qualname__.__len__,              [],                   16]
    - [dexc_base_eq,      "DecimalException.__bases__[0].__name__.__eq__",    ["ArithmeticError"],  true]
    - [dexc_base_len,     "DecimalException.__bases__[0].__name__.__len__",   [],                   15]
    - [dexc_mro_len,      DecimalException.__mro__.__len__,                   [],                   5]
    - [dexc_cls_eq,       DecimalException.__class__.__name__.__eq__,         ["type"],             true]

# ---------------------------------------------------------------------------
# decimal.InvalidOperation and decimal.DivisionByZero class identity
# InvalidOperation.__bases__[0].__name__ == 'DecimalException' (16).
# InvalidOperation.__mro__.__len__() == 6.
# DivisionByZero.__bases__[0].__name__ == 'DecimalException' (16).
# DivisionByZero.__mro__.__len__() == 7 (also inherits ZeroDivisionError).
# ---------------------------------------------------------------------------

table decimal_extra131.InvalidOperation_and_DivisionByZero_identity:
  description: "decimal.InvalidOperation and DivisionByZero class identity: both have __bases__[0].__name__='DecimalException'; MRO lengths 6 and 7 respectively"
  kind: python_call_eq
  category: class_identity
  id_prefix: decexc131

  columns: [id, function, args, expected]
  rows:
    - [invop_name_eq,     InvalidOperation.__name__.__eq__,                   ["InvalidOperation"], true]
    - [invop_name_len,    InvalidOperation.__name__.__len__,                  [],                   16]
    - [invop_module_eq,   InvalidOperation.__module__.__eq__,                 ["decimal"],          true]
    - [invop_base_eq,     "InvalidOperation.__bases__[0].__name__.__eq__",    ["DecimalException"], true]
    - [invop_mro_len,     InvalidOperation.__mro__.__len__,                   [],                   6]
    - [divz_name_eq,      DivisionByZero.__name__.__eq__,                     ["DivisionByZero"],   true]
    - [divz_name_len,     DivisionByZero.__name__.__len__,                    [],                   14]
    - [divz_module_eq,    DivisionByZero.__module__.__eq__,                   ["decimal"],          true]
    - [divz_base_eq,      "DivisionByZero.__bases__[0].__name__.__eq__",      ["DecimalException"], true]
    - [divz_mro_len,      DivisionByZero.__mro__.__len__,                     [],                   7]

# ---------------------------------------------------------------------------
# decimal.Overflow, decimal.Inexact, and decimal.Rounded class identity
# Overflow.__bases__[0].__name__ == 'Inexact' (7); Overflow inherits via
# Inexact -> Rounded -> DecimalException. MRO length == 8.
# Inexact.__bases__[0].__name__ == 'DecimalException' (16). MRO length == 6.
# Rounded.__bases__[0].__name__ == 'DecimalException' (16). MRO length == 6.
# ---------------------------------------------------------------------------

table decimal_extra131.Overflow_Inexact_Rounded_identity:
  description: "decimal.Overflow, Inexact, Rounded class identity: Overflow base='Inexact' (mro_len=8), Inexact base='DecimalException' (mro_len=6), Rounded base='DecimalException' (mro_len=6)"
  kind: python_call_eq
  category: class_identity
  id_prefix: decexc131

  columns: [id, function, args, expected]
  rows:
    - [ovfl_name_eq,      Overflow.__name__.__eq__,                     ["Overflow"],         true]
    - [ovfl_name_len,     Overflow.__name__.__len__,                    [],                   8]
    - [ovfl_module_eq,    Overflow.__module__.__eq__,                   ["decimal"],          true]
    - [ovfl_base_eq,      "Overflow.__bases__[0].__name__.__eq__",      ["Inexact"],          true]
    - [ovfl_base_not_dec, "Overflow.__bases__[0].__name__.__eq__",      ["DecimalException"], false]
    - [ovfl_mro_len,      Overflow.__mro__.__len__,                     [],                   8]
    - [inex_name_eq,      Inexact.__name__.__eq__,                      ["Inexact"],          true]
    - [inex_base_eq,      "Inexact.__bases__[0].__name__.__eq__",       ["DecimalException"], true]
    - [inex_mro_len,      Inexact.__mro__.__len__,                      [],                   6]
    - [rnd_name_eq,       Rounded.__name__.__eq__,                      ["Rounded"],          true]
    - [rnd_base_eq,       "Rounded.__bases__[0].__name__.__eq__",       ["DecimalException"], true]
    - [rnd_mro_len,       Rounded.__mro__.__len__,                      [],                   6]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra131.DecimalException.name_is_DecimalException:
  description: "decimal.DecimalException.__name__ == 'DecimalException' (length 16; the root exception for the decimal module's signal hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra131.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (length 15; DecimalException subclasses ArithmeticError, integrating into Python's built-in numeric exception hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra131.DecimalException.mro_len_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5 (MRO is [DecimalException, ArithmeticError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra131.DivisionByZero.mro_len_7:
  description: "decimal.DivisionByZero.__mro__.__len__() == 7 (DivisionByZero inherits from both DecimalException and ZeroDivisionError, extending the MRO to 7: [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: DivisionByZero.__mro__.__len__
  args: []
  expected: 7

invariant decimal_extra131.Overflow.base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (length 7; Overflow directly extends Inexact, which in turn extends DecimalException — the MRO reflects rounding-related signal inheritance)"
  category: class_identity
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true
