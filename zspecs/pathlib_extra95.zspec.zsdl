spec: pathlib_extra95
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra94

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra94."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path.__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/etc __code__ attributes; Path/__dict__.__contains__; Path/__qualname__/__name__/__module__; Path method __qualname__ string equality."
    - "This spec covers: pathlib.Path method __qualname__ string length (complementing string equality from pathlib_extra94)."
    - "pathlib.Path.exists.__qualname__.__len__() == 11 — 'Path.exists' has 11 characters."
    - "pathlib.Path.stat.__qualname__.__len__() == 9 — 'Path.stat' has 9 characters."
    - "pathlib.Path.open.__qualname__.__len__() == 9 — 'Path.open' has 9 characters."
    - "pathlib.Path.read_text.__qualname__.__len__() == 14 — 'Path.read_text' has 14 characters."
    - "pathlib.Path.write_text.__qualname__.__len__() == 15 — 'Path.write_text' has 15 characters."
    - "pathlib.Path.read_bytes.__qualname__.__len__() == 15 — 'Path.read_bytes' has 15 characters."
    - "pathlib.Path.write_bytes.__qualname__.__len__() == 16 — 'Path.write_bytes' has 16 characters."
    - "pathlib.Path.mkdir.__qualname__.__len__() == 10 — 'Path.mkdir' has 10 characters."
    - "pathlib.Path.rmdir.__qualname__.__len__() == 10 — 'Path.rmdir' has 10 characters."
    - "pathlib.Path.unlink.__qualname__.__len__() == 11 — 'Path.unlink' has 11 characters."
    - "pathlib.Path.rename.__qualname__.__len__() == 11 — 'Path.rename' has 11 characters."
    - "pathlib.Path.replace.__qualname__.__len__() == 12 — 'Path.replace' has 12 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path file I/O method __qualname__ lengths
# exists/stat/open/read_text/write_text: qualname lengths for key I/O methods.
# Lengths derived from 'Path.<method>' format strings.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra95.Path_file_io_qualname_lengths:
  description: "pathlib.Path.exists/stat/open/read_text/write_text __qualname__ length"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibquallen95

  columns: [id, function, args, expected]
  rows:
    - [exists_qualname_len,     Path.exists.__qualname__.__len__,     [], 11]
    - [stat_qualname_len,       Path.stat.__qualname__.__len__,       [], 9]
    - [open_qualname_len,       Path.open.__qualname__.__len__,       [], 9]
    - [read_text_qualname_len,  Path.read_text.__qualname__.__len__,  [], 14]
    - [write_text_qualname_len, Path.write_text.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# pathlib.Path directory/modification method __qualname__ lengths
# read_bytes/write_bytes/mkdir/rmdir: qualname lengths.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra95.Path_bytes_dir_qualname_lengths:
  description: "pathlib.Path.read_bytes/write_bytes/mkdir/rmdir __qualname__ length"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibquallen95

  columns: [id, function, args, expected]
  rows:
    - [read_bytes_qualname_len,  Path.read_bytes.__qualname__.__len__,  [], 15]
    - [write_bytes_qualname_len, Path.write_bytes.__qualname__.__len__, [], 16]
    - [mkdir_qualname_len,       Path.mkdir.__qualname__.__len__,       [], 10]
    - [rmdir_qualname_len,       Path.rmdir.__qualname__.__len__,       [], 10]

# ---------------------------------------------------------------------------
# pathlib.Path modification method __qualname__ lengths
# unlink/rename/replace: qualname lengths.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra95.Path_modification_qualname_lengths:
  description: "pathlib.Path.unlink/rename/replace __qualname__ length"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibquallen95

  columns: [id, function, args, expected]
  rows:
    - [unlink_qualname_len,  Path.unlink.__qualname__.__len__,  [], 11]
    - [rename_qualname_len,  Path.rename.__qualname__.__len__,  [], 11]
    - [replace_qualname_len, Path.replace.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# pathlib.Path __qualname__ lengths cross-check
# stat and open share the same length (9); exists, unlink, rename share length 11;
# read_text and read_bytes share length 14/15. Cross-check inequalities.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra95.Path_qualname_lengths_cross_check:
  description: "pathlib.Path qualname length cross-checks: stat==open, exists==unlink==rename, write_text==read_bytes"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibquallen95

  columns: [id, function, args, expected]
  rows:
    - [stat_eq_open_len,         Path.stat.__qualname__.__len__,       [], 9]
    - [open_eq_stat_len,         Path.open.__qualname__.__len__,       [], 9]
    - [mkdir_eq_rmdir_len,       Path.mkdir.__qualname__.__len__,      [], 10]
    - [rmdir_eq_mkdir_len,       Path.rmdir.__qualname__.__len__,      [], 10]
    - [write_text_eq_read_bytes, Path.write_text.__qualname__.__len__, [], 15]
    - [read_bytes_eq_write_text, Path.read_bytes.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra95.Path.exists_qualname_len:
  description: "pathlib.Path.exists.__qualname__.__len__() == 11 ('Path.exists' has 11 characters)"
  category: qualname
  kind: python_call_eq
  function: Path.exists.__qualname__.__len__
  args: []
  expected: 11

invariant pathlib_extra95.Path.write_bytes_qualname_len:
  description: "pathlib.Path.write_bytes.__qualname__.__len__() == 16 ('Path.write_bytes' has 16 characters)"
  category: qualname
  kind: python_call_eq
  function: Path.write_bytes.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra95.Path.replace_qualname_len:
  description: "pathlib.Path.replace.__qualname__.__len__() == 12 ('Path.replace' has 12 characters)"
  category: qualname
  kind: python_call_eq
  function: Path.replace.__qualname__.__len__
  args: []
  expected: 12

invariant pathlib_extra95.Path.read_text_qualname_len:
  description: "pathlib.Path.read_text.__qualname__.__len__() == 14 ('Path.read_text' has 14 characters)"
  category: qualname
  kind: python_call_eq
  function: Path.read_text.__qualname__.__len__
  args: []
  expected: 14

invariant pathlib_extra95.Path.mkdir_qualname_len:
  description: "pathlib.Path.mkdir.__qualname__.__len__() == 10 ('Path.mkdir' has 10 characters)"
  category: qualname
  kind: python_call_eq
  function: Path.mkdir.__qualname__.__len__
  args: []
  expected: 10
