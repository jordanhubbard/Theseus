spec: io_extra36
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra9.zspec.zsdl — covers BytesIO/StringIO __qualname__ in table rows; IOBase.__module__ in table"
    - "io_extra31.zspec.zsdl — covers IOBase/__qualname__/__module__; RawIOBase/__qualname__/__module__; BufferedIOBase/__qualname__/__module__; TextIOBase/__qualname__/__module__"
    - "io_extra32.zspec.zsdl — covers FileIO/BytesIO/StringIO/BufferedReader/BufferedWriter/TextIOWrapper __qualname__/__module__/__bases__[0].__name__"
    - "io_extra33.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __qualname__ standalone; BytesIO/StringIO/FileIO/TextIOWrapper __qualname__ standalone; UnsupportedOperation/__qualname__/__module__/__bases__[0].__name__; io.open/__qualname__"
    - "io_extra34.zspec.zsdl — covers __module__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/BytesIO/StringIO; __name__.__len__() for same six classes"
    - "io_extra35.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for FileIO/BufferedReader/BufferedWriter/TextIOWrapper; __qualname__.__len__() for all ten io classes"
  notes:
    - "This spec extends io_extra35.zspec.zsdl."
    - "Prior specs covered: IOBase/RawIOBase/BufferedIOBase/TextIOBase/BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __name__/__module__/__qualname__, UnsupportedOperation attributes, io.open qualname, DEFAULT_BUFFER_SIZE, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for all ten io classes."
    - "This spec covers: __mro__.__len__() for IOBase, RawIOBase, BufferedIOBase, TextIOBase, StringIO, BytesIO; __bases__[0].__name__ for IOBase, RawIOBase, BufferedIOBase, TextIOBase; __qualname__.__len__() for BufferedReader.read, BufferedReader.readline, BufferedReader.read1, BufferedWriter.write, BufferedWriter.flush, FileIO.readinto."
    - "IMPORTANT: The io module wraps C-extension classes from _io. The public io.IOBase etc. are aliases for _io.IOBase which itself extends _io._IOBase. This means io.IOBase.__mro__ has 3 entries: [IOBase, _IOBase, object]."
    - "io.IOBase.__mro__ == ['IOBase', '_IOBase', 'object'] (len 3) — verified Python 3.12."
    - "io.RawIOBase.__mro__ == ['RawIOBase', '_RawIOBase', 'IOBase', '_IOBase', 'object'] (len 5) — verified Python 3.12."
    - "io.BufferedIOBase.__mro__ == ['BufferedIOBase', '_BufferedIOBase', 'IOBase', '_IOBase', 'object'] (len 5) — verified Python 3.12."
    - "io.TextIOBase.__mro__ == ['TextIOBase', '_TextIOBase', 'IOBase', '_IOBase', 'object'] (len 5) — verified Python 3.12."
    - "io.StringIO.__mro__ == ['StringIO', '_TextIOBase', '_IOBase', 'object'] (len 4) — verified Python 3.12."
    - "io.BytesIO.__mro__ == ['BytesIO', '_BufferedIOBase', '_IOBase', 'object'] (len 4) — verified Python 3.12."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — verified Python 3.12."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — verified Python 3.12."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — verified Python 3.12."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — verified Python 3.12."
    - "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (len 19) — verified Python 3.12."
    - "io.BufferedReader.readline.__qualname__ == 'BufferedReader.readline' (len 23) — verified Python 3.12."
    - "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1' (len 20) — verified Python 3.12."
    - "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (len 20) — verified Python 3.12."
    - "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (len 20) — verified Python 3.12."
    - "io.FileIO.readinto.__qualname__ == 'FileIO.readinto' (len 15) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for IOBase, RawIOBase, BufferedIOBase, TextIOBase,
# StringIO, BytesIO
#
# The io public classes alias _io C-extension classes; the MRO reflects the
# internal wrapper hierarchy:
#   IOBase         -> [IOBase, _IOBase, object]                                 -> 3
#   StringIO       -> [StringIO, _TextIOBase, _IOBase, object]                  -> 4
#   BytesIO        -> [BytesIO, _BufferedIOBase, _IOBase, object]               -> 4
#   RawIOBase      -> [RawIOBase, _RawIOBase, IOBase, _IOBase, object]          -> 5
#   BufferedIOBase -> [BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object] -> 5
#   TextIOBase     -> [TextIOBase, _TextIOBase, IOBase, _IOBase, object]        -> 5
# No prior io spec checks __mro__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table io_extra36.class_mro_depths:
  description: "__mro__.__len__() for IOBase, RawIOBase, BufferedIOBase, TextIOBase, StringIO, BytesIO"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cmd36

  columns: [id, function, args, expected]
  rows:
    - [IOBase,         IOBase.__mro__.__len__,         [], 3]
    - [StringIO,       StringIO.__mro__.__len__,       [], 4]
    - [BytesIO,        BytesIO.__mro__.__len__,        [], 4]
    - [RawIOBase,      RawIOBase.__mro__.__len__,      [], 5]
    - [BufferedIOBase, BufferedIOBase.__mro__.__len__,  [], 5]
    - [TextIOBase,     TextIOBase.__mro__.__len__,     [], 5]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for IOBase, RawIOBase, BufferedIOBase, TextIOBase
#
# The abstract base classes alias C-extension classes from _io. Each public
# io.ABC class's __bases__[0] is the corresponding private _io._ABC:
#   io.IOBase.__bases__[0].__name__         == '_IOBase'
#   io.RawIOBase.__bases__[0].__name__      == '_RawIOBase'
#   io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase'
#   io.TextIOBase.__bases__[0].__name__     == '_TextIOBase'
# io_extra32 covered __bases__[0].__name__ for concrete classes (FileIO, BytesIO,
# StringIO, BufferedReader, BufferedWriter, TextIOWrapper); no prior spec covers
# __bases__[0].__name__ for these four abstract base classes.
# Note: __bases__[0].__name__ contains '[' in the function path, so MUST be quoted.
# ---------------------------------------------------------------------------

table io_extra36.abstract_class_bases_names:
  description: "__bases__[0].__name__ for IOBase, RawIOBase, BufferedIOBase, TextIOBase"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: acbn36

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [IOBase_base,         "IOBase.__bases__[0].__name__.__eq__",         ["_IOBase"],         true, __len__, []]
    - [RawIOBase_base,      "RawIOBase.__bases__[0].__name__.__eq__",      ["_RawIOBase"],      true, __len__, []]
    - [BufferedIOBase_base, "BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, __len__, []]
    - [TextIOBase_base,     "TextIOBase.__bases__[0].__name__.__eq__",     ["_TextIOBase"],     true, __len__, []]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for BufferedReader, BufferedWriter, and FileIO methods
#
# These concrete C-extension class methods have dotted qualnames:
#   BufferedReader.read     -> 'BufferedReader.read'     -> 19
#   BufferedReader.readline -> 'BufferedReader.readline' -> 23
#   BufferedReader.read1    -> 'BufferedReader.read1'    -> 20
#   BufferedWriter.write    -> 'BufferedWriter.write'    -> 20
#   BufferedWriter.flush    -> 'BufferedWriter.flush'    -> 20
#   FileIO.readinto         -> 'FileIO.readinto'         -> 15
# No prior io spec checks __qualname__.__len__() for any of these methods.
# ---------------------------------------------------------------------------

invariant io_extra36.BufferedReader.read.qualname_len:
  description: "io.BufferedReader.read.__qualname__.__len__() == 19 — 'BufferedReader.read' has 19 characters"
  category: method_identity
  kind: python_call_eq
  function: BufferedReader.read.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra36.BufferedReader.readline.qualname_len:
  description: "io.BufferedReader.readline.__qualname__.__len__() == 23 — 'BufferedReader.readline' has 23 characters"
  category: method_identity
  kind: python_call_eq
  function: BufferedReader.readline.__qualname__.__len__
  args: []
  expected: 23

invariant io_extra36.BufferedReader.read1.qualname_len:
  description: "io.BufferedReader.read1.__qualname__.__len__() == 20 — 'BufferedReader.read1' has 20 characters"
  category: method_identity
  kind: python_call_eq
  function: BufferedReader.read1.__qualname__.__len__
  args: []
  expected: 20

invariant io_extra36.BufferedWriter.write.qualname_len:
  description: "io.BufferedWriter.write.__qualname__.__len__() == 20 — 'BufferedWriter.write' has 20 characters"
  category: method_identity
  kind: python_call_eq
  function: BufferedWriter.write.__qualname__.__len__
  args: []
  expected: 20

invariant io_extra36.BufferedWriter.flush.qualname_len:
  description: "io.BufferedWriter.flush.__qualname__.__len__() == 20 — 'BufferedWriter.flush' has 20 characters"
  category: method_identity
  kind: python_call_eq
  function: BufferedWriter.flush.__qualname__.__len__
  args: []
  expected: 20

invariant io_extra36.FileIO.readinto.qualname_len:
  description: "io.FileIO.readinto.__qualname__.__len__() == 15 — 'FileIO.readinto' has 15 characters"
  category: method_identity
  kind: python_call_eq
  function: FileIO.readinto.__qualname__.__len__
  args: []
  expected: 15
