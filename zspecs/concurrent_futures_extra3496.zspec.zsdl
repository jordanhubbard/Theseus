spec: cf3496
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (cf3496): __aenter__, __aexit__, __await__ dict-presence checks for concurrent.futures types."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async protocols)."
    - "All values False — concurrent.futures types are synchronous primitives with no async protocol support."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__aenter__): all 3 concurrent.futures classes return false for __aenter__. concurrent.futures is a synchronous thread/process pool API — it does not implement the async context manager protocol. ThreadPoolExecutor defines the synchronous __enter__/__exit__ (wave 679) but does NOT define __aenter__ in its own __dict__. concurrent.futures.Future is a synchronous result handle; no __aenter__ defined."
    - "Key finding (__aexit__): all 3 concurrent.futures classes return false for __aexit__. The async context manager exit protocol is not part of the concurrent.futures API surface. ThreadPoolExecutor's context manager support is purely synchronous (__exit__ only, confirmed wave 679). No type in this set defines __aexit__ in its own __dict__."
    - "Key finding (__await__): all 3 concurrent.futures classes return false for __await__. concurrent.futures.Future is a synchronous future — it is not awaitable in the asyncio sense. To bridge concurrent.futures with asyncio, one uses asyncio.wrap_future(), which wraps a concurrent.futures.Future in an asyncio.Future. The concurrent.futures.Future class itself does not define __await__ in its own __dict__."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (cf3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (cf3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (cf3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (cf3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (cf3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (cf3436): __le__/__gt__/__ge__ — all false for all 3."
    - "  Wave 677 (cf3451): __getitem__/__setitem__/__delitem__ — all false for all 3."
    - "  Wave 678 (cf3466): __iter__/__next__/__len__ — all false for all 3."
    - "  Wave 679 (cf3481): __enter__/__exit__/__call__ — ThreadPoolExecutor __enter__=true, __exit__=true; all others false."
    - "  Wave 680 (cf3496): __aenter__/__aexit__/__await__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# All 3 concurrent.futures classes return false for __aenter__.
# concurrent.futures is a synchronous concurrency API. Neither ThreadPoolExecutor
#   nor ProcessPoolExecutor implements the async context manager protocol.
# ThreadPoolExecutor: defines synchronous __enter__/__exit__ (confirmed wave 679),
#   but does NOT define __aenter__ in its own __dict__. 'async with executor:'
#   would raise AttributeError at runtime.
# ProcessPoolExecutor: inherits synchronous __enter__/__exit__ from Executor.
#   No __aenter__ in its own __dict__.
# concurrent.futures.Future: a synchronous result handle. Not an async context
#   manager. No __aenter__ defined in Future.__dict__.
# ---------------------------------------------------------------------------

table cf3496.aenter:
  description: "concurrent.futures types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3496

  columns: [id, function, args, expected]
  rows:
    - ["cf3496001", operator.contains, [concurrent.futures.Future.__dict__,              "__aenter__"], false]
    - ["cf3496002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__aenter__"], false]
    - ["cf3496003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__aenter__"], false]

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# All 3 concurrent.futures classes return false for __aexit__.
# The async context manager exit protocol is not part of the concurrent.futures
#   API surface. concurrent.futures types use the synchronous context manager
#   protocol only (ThreadPoolExecutor defines __exit__ in its own __dict__,
#   confirmed wave 679). No type in this set defines __aexit__.
# ThreadPoolExecutor: context manager support is entirely synchronous; no __aexit__.
# ProcessPoolExecutor: inherits synchronous __exit__ from Executor; no __aexit__.
# concurrent.futures.Future: not a context manager of any kind; no __aexit__.
# ---------------------------------------------------------------------------

table cf3496.aexit:
  description: "concurrent.futures types __aexit__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3496

  columns: [id, function, args, expected]
  rows:
    - ["cf3496004", operator.contains, [concurrent.futures.Future.__dict__,              "__aexit__"], false]
    - ["cf3496005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__aexit__"], false]
    - ["cf3496006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__aexit__"], false]

# ---------------------------------------------------------------------------
# __await__ dict-presence — operator.contains(Cls.__dict__, '__await__')
#
# All 3 concurrent.futures classes return false for __await__.
# concurrent.futures.Future is a synchronous future — it is not awaitable.
#   To bridge concurrent.futures with asyncio, use asyncio.wrap_future().
#   concurrent.futures.Future does not define __await__ in its own __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor: executor lifecycle managers.
#   Not awaitable. No __await__ defined in their own __dict__.
# ---------------------------------------------------------------------------

table cf3496.await:
  description: "concurrent.futures types __await__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3496

  columns: [id, function, args, expected]
  rows:
    - ["cf3496007", operator.contains, [concurrent.futures.Future.__dict__,              "__await__"], false]
    - ["cf3496008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__await__"], false]
    - ["cf3496009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__await__"], false]

# ---------------------------------------------------------------------------
# combined — __aenter__, __aexit__, __await__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __aenter__: false for all 3.
# __aexit__:  false for all 3.
# __await__:  false for all 3.
# All 9 values are false.
# concurrent.futures is a purely synchronous concurrency API. All three types
#   (Future, ThreadPoolExecutor, ProcessPoolExecutor) lack async protocol support
#   at the dict-contains level. The library predates Python's async/await syntax
#   and provides no native async integration — the asyncio.wrap_future() bridge
#   function exists precisely because concurrent.futures.Future does not natively
#   implement __await__.
# This wave establishes the all-false baseline for async protocols in
#   concurrent.futures, complementing wave 679's finding that ThreadPoolExecutor
#   does define the synchronous context manager protocol (__enter__/__exit__).
# ---------------------------------------------------------------------------

table cf3496.combined:
  description: "concurrent.futures types combined __aenter__/__aexit__/__await__; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3496

  columns: [id, function, args, expected]
  rows:
    - ["cf3496010", operator.contains, [concurrent.futures.Future.__dict__,              "__aenter__"], false]
    - ["cf3496011", operator.contains, [concurrent.futures.Future.__dict__,              "__aexit__"],  false]
    - ["cf3496012", operator.contains, [concurrent.futures.Future.__dict__,              "__await__"],  false]
    - ["cf3496013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__aenter__"], false]
    - ["cf3496014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__aexit__"],  false]
    - ["cf3496015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__await__"],  false]
    - ["cf3496016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__aenter__"], false]
    - ["cf3496017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__aexit__"],  false]
    - ["cf3496018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__await__"],  false]
