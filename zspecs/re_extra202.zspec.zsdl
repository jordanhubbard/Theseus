spec: re_extra202
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, and compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class names, flags, match/search/sub/split/findall"
  notes:
    - "This spec covers re class and function __doc__.__class__.__name__ identity not covered by prior re_extra specs."
    - "re.Pattern.__doc__.__class__.__name__ == 'str'; the compiled pattern type has a str docstring; confirmed Python 3.14.3 macOS."
    - "re.Match.__doc__.__class__.__name__ == 'str'; the match object type has a str docstring; confirmed Python 3.14.3 macOS."
    - "re.error.__doc__.__class__.__name__ == 'str'; the regex exception class has a str docstring; confirmed Python 3.14.3 macOS."
    - "re.RegexFlag.__doc__.__class__.__name__ == 'str'; the flag enum has a str docstring; confirmed Python 3.14.3 macOS."
    - "re.compile.__doc__.__class__.__name__ == 'str'; the compile() function has a str docstring; confirmed Python 3.14.3 macOS."
    - "re.match.__doc__.__class__.__name__ == 'str'; the match() function has a str docstring; confirmed Python 3.14.3 macOS."
    - "re.search.__doc__.__class__.__name__ == 'str'; the search() function has a str docstring; confirmed Python 3.14.3 macOS."
    - "re.sub.__doc__.__class__.__name__ == 'str'; the sub() function has a str docstring; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re class __doc__.__class__.__name__ identity
# Pattern, Match, error, RegexFlag — all 'str'
# ---------------------------------------------------------------------------

table re_extra202.class_doc_class_names:
  description: "re class __doc__.__class__.__name__: Pattern, Match, error, RegexFlag — all 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redocs202

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_doc_class_name,   re.Pattern.__doc__.__class__.__name__.__eq__,   ["str"], true, "re.Pattern.__doc__.__class__.__name__ == 'str'; type of compiled regex objects returned by re.compile(); docstring is a str; confirmed Python 3.14.3 macOS"]
    - [match_doc_class_name,     re.Match.__doc__.__class__.__name__.__eq__,     ["str"], true, "re.Match.__doc__.__class__.__name__ == 'str'; type of match objects returned by re.match() and re.search(); docstring is a str; confirmed Python 3.14.3 macOS"]
    - [error_doc_class_name,     re.error.__doc__.__class__.__name__.__eq__,     ["str"], true, "re.error.__doc__.__class__.__name__ == 'str'; exception raised for invalid regex patterns; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [regexflag_doc_class_name, re.RegexFlag.__doc__.__class__.__name__.__eq__, ["str"], true, "re.RegexFlag.__doc__.__class__.__name__ == 'str'; IntFlag enum class for regex flags; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [pattern_doc_class_name_len, re.Pattern.__doc__.__class__.__name__.__len__, [], 3, "re.Pattern.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re function __doc__.__class__.__name__ identity
# compile, match, search — all 'str'
# ---------------------------------------------------------------------------

table re_extra202.function_doc_class_names_group1:
  description: "re function __doc__.__class__.__name__: compile, match, search — all 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redocs202

  columns: [id, function, args, expected, description]
  rows:
    - [compile_doc_class_name, re.compile.__doc__.__class__.__name__.__eq__, ["str"], true, "re.compile.__doc__.__class__.__name__ == 'str'; compiles a pattern into a Pattern object; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [match_doc_class_name,   re.match.__doc__.__class__.__name__.__eq__,   ["str"], true, "re.match.__doc__.__class__.__name__ == 'str'; tries to match pattern at the start of the string; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [search_doc_class_name,  re.search.__doc__.__class__.__name__.__eq__,  ["str"], true, "re.search.__doc__.__class__.__name__ == 'str'; scans through the string for the first match; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [compile_doc_class_name_len, re.compile.__doc__.__class__.__name__.__len__, [], 3, "re.compile.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [match_doc_class_name_len, re.match.__doc__.__class__.__name__.__len__, [], 3, "re.match.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re function __doc__.__class__.__name__ identity
# sub and cross-checks — all 'str'
# ---------------------------------------------------------------------------

table re_extra202.function_doc_class_names_group2:
  description: "re function __doc__.__class__.__name__: sub and cross-checks — all 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: redocs202

  columns: [id, function, args, expected, description]
  rows:
    - [sub_doc_class_name,        re.sub.__doc__.__class__.__name__.__eq__,        ["str"], true, "re.sub.__doc__.__class__.__name__ == 'str'; substitutes occurrences of pattern in the string; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [search_doc_class_name_len, re.search.__doc__.__class__.__name__.__len__,    [], 3, "re.search.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [sub_doc_class_name_len,    re.sub.__doc__.__class__.__name__.__len__,        [], 3, "re.sub.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [error_doc_class_name_len,  re.error.__doc__.__class__.__name__.__len__,     [], 3, "re.error.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [regexflag_doc_class_name_len, re.RegexFlag.__doc__.__class__.__name__.__len__, [], 3, "re.RegexFlag.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra202.pattern_doc_class_name:
  description: "re.Pattern.__doc__.__class__.__name__ == 'str' — type of compiled regex objects; __doc__ is a non-None str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.Pattern.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra202.match_doc_class_name:
  description: "re.Match.__doc__.__class__.__name__ == 'str' — type of match objects from re.match() and re.search(); __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.Match.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra202.error_doc_class_name:
  description: "re.error.__doc__.__class__.__name__ == 'str' — exception raised for invalid regex patterns; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.error.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra202.regexflag_doc_class_name:
  description: "re.RegexFlag.__doc__.__class__.__name__ == 'str' — IntFlag enum for compile flags such as IGNORECASE; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.RegexFlag.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra202.compile_doc_class_name:
  description: "re.compile.__doc__.__class__.__name__ == 'str' — compiles a pattern string into a Pattern object; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.compile.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra202.match_func_doc_class_name:
  description: "re.match.__doc__.__class__.__name__ == 'str' — tries to match pattern at the start of the string; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.match.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra202.search_doc_class_name:
  description: "re.search.__doc__.__class__.__name__ == 'str' — scans through the string for the first location where the pattern matches; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.search.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra202.sub_doc_class_name:
  description: "re.sub.__doc__.__class__.__name__ == 'str' — substitutes occurrences of a pattern in the string; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: re.sub.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
