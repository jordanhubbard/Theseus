spec: theseus_compression_gzip_cr
version: ">=3.14"
backend: python_cleanroom(theseus_compression_gzip_cr)
blocks: compression.gzip

docs: https://docs.python.org/3/library/compression.gzip.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compression.gzip.html"
  not_derived_from:
    - "CPython source: Lib/compression/gzip.py"
  notes:
    - "Clean-room compression.gzip module (Python 3.14+). Do NOT import compression.gzip."

error_model: python_exceptions

invariant theseus_compression_gzip_cr.cgzip2_compress:
  description: "compress/decompress roundtrip works"
  category: behavior
  kind: python_call_eq
  function: cgzip2_compress
  args: []
  expected: true

invariant theseus_compression_gzip_cr.cgzip2_classes:
  description: "GzipFile and BadGzipFile classes exist"
  category: behavior
  kind: python_call_eq
  function: cgzip2_classes
  args: []
  expected: true

invariant theseus_compression_gzip_cr.cgzip2_open:
  description: "open() creates a readable compressed file"
  category: behavior
  kind: python_call_eq
  function: cgzip2_open
  args: []
  expected: true
