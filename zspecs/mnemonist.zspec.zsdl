spec: mnemonist
version: ">=0.39.0"
backend: node(mnemonist)

docs: https://yomguithereal.github.io/mnemonist/

provenance:
  derived_from:
    - "Mnemonist docs — https://yomguithereal.github.io/mnemonist/"
    - "Test vectors verified with mnemonist via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "mnemonist source"
  notes:
    - "Curated collection of data structures: Trie, BloomFilter, BiMap, BKTree, CircularBuffer, FixedDeque, Heap, etc."
    - "Install: npm install mnemonist"
    - "v0.39 CJS; named exports per data structure (Trie, BiMap, BloomFilter, ...)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructors throw on invalid options."
  stderr: "null"
  stickiness: "N/A — each instance independent."
  codes: {}

# Trie
invariant mnemonist.trie_empty_size:
  description: "Fresh Trie has size 0"
  category: Trie
  kind: node_chain_eq
  entry: constructor
  class: Trie
  entry_args: []
  chain:
    - {get: size}
  expected: 0

invariant mnemonist.trie_add_then_size:
  description: "Trie.add(word) increments size"
  category: Trie
  kind: node_chain_eq
  entry: constructor
  class: Trie
  entry_args: []
  chain:
    - {method: add, args: ["hello"], tap: true}
    - {get: size}
  expected: 1

invariant mnemonist.trie_add_then_has:
  description: "Trie.add(word) then .has(word) is true"
  category: Trie
  kind: node_chain_eq
  entry: constructor
  class: Trie
  entry_args: []
  chain:
    - {method: add, args: ["hello"], tap: true}
    - {method: has, args: ["hello"]}
  expected: true

invariant mnemonist.trie_has_unknown_false:
  description: "Trie.has on unadded word is false"
  category: Trie
  kind: node_chain_eq
  entry: constructor
  class: Trie
  entry_args: []
  chain:
    - {method: has, args: ["unknown"]}
  expected: false

invariant mnemonist.trie_two_words:
  description: "Two adds increment size to 2"
  category: Trie
  kind: node_chain_eq
  entry: constructor
  class: Trie
  entry_args: []
  chain:
    - {method: add, args: ["hello"], tap: true}
    - {method: add, args: ["help"], tap: true}
    - {get: size}
  expected: 2

# BiMap
invariant mnemonist.bimap_empty_size:
  description: "Fresh BiMap has size 0"
  category: BiMap
  kind: node_chain_eq
  entry: constructor
  class: BiMap
  entry_args: []
  chain:
    - {get: size}
  expected: 0

# Heap
invariant mnemonist.heap_empty_size:
  description: "Fresh Heap has size 0"
  category: Heap
  kind: node_chain_eq
  entry: constructor
  class: Heap
  entry_args: []
  chain:
    - {get: size}
  expected: 0

invariant mnemonist.heap_push_then_size:
  description: "Heap.push() increments size"
  category: Heap
  kind: node_chain_eq
  entry: constructor
  class: Heap
  entry_args: []
  chain:
    - {method: push, args: [3], tap: true}
    - {method: push, args: [1], tap: true}
    - {method: push, args: [2], tap: true}
    - {get: size}
  expected: 3

invariant mnemonist.heap_pop_returns_min:
  description: "Heap.pop() returns the smallest pushed value (min-heap default)"
  category: Heap
  kind: node_chain_eq
  entry: constructor
  class: Heap
  entry_args: []
  chain:
    - {method: push, args: [3], tap: true}
    - {method: push, args: [1], tap: true}
    - {method: push, args: [2], tap: true}
    - {method: pop, args: []}
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:25:41Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
