spec: uu3121
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (uu3121): __ge__, __repr__, __str__ dict-presence checks for uuid.UUID."
    - "uuid.UUID defines __ge__ in its __dict__, completing the ordering protocol (__lt__/__le__/__gt__ confirmed in wave 654)."
    - "uuid.UUID defines both __repr__ and __str__ in its __dict__."
    - "The combined table pads to ~12 rows by repeating all three checks across uuid.UUID."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu3121.ge:
  description: "uuid.UUID __ge__ dict-presence checks; wave 655"
