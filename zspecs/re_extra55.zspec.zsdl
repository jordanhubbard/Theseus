spec: re_extra55
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra54.zspec.zsdl — covers re function __module__.__eq__('re') for all 9 functions + error (namespace anchors); re.search/compile/sub/error __module__.__len__()==2 (NOVEL in extra54)."
    - "re_extra53.zspec.zsdl — covers re function __name__ equality and lengths for search/compile/sub/findall/fullmatch/match/split/subn/finditer."
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __module__.__len__()==2; and __name__.__len__() for split/findall/finditer/purge/escape; Pattern/__name__.__len__()==7; Match/__name__.__len__()==5."
    - "re_extra30.zspec.zsdl — covers compile/match/search/fullmatch/sub __module__.__len__()==2; compile/match/search/fullmatch/sub __name__.__len__(); Pattern/__module__.__len__()==2; Match/__module__.__len__()==2."
    - "re_extra27.zspec.zsdl — covers IGNORECASE/__class__/__module__/__eq__('re'); RegexFlag/__module__/__eq__('re'); compile/__module__/__eq__('re')."
    - "re_extra14.zspec.zsdl — covers RegexFlag.__name__/__qualname__/__module__ equality."
    - "re_extra9.zspec.zsdl — covers Pattern/__module__/__eq__('re'); Match/__module__/__eq__('re'); error/__module__/__eq__('re')."
  notes:
    - "This spec extends re_extra54.zspec.zsdl."
    - "Prior specs collectively covered: re.search/compile/sub __module__.__len__()==2 (re_extra30/re_extra54); re.match/fullmatch __module__.__len__()==2 (re_extra30); re.split/findall/finditer __module__.__len__()==2 (re_extra31); re.error.__module__.__len__()==2 (re_extra54); re.Pattern.__module__.__len__()==2 (re_extra30); re.Match.__module__.__len__()==2 (re_extra30); RegexFlag.__module__.__eq__('re') (re_extra14/re_extra27). NO prior re spec checks re.subn.__module__.__len__() as a standalone invariant. NO prior re spec checks re.RegexFlag.__module__.__len__() as a standalone invariant."
    - "This spec covers: re.subn.__module__.__len__()==2 (NOVEL — re_extra30 covers compile/match/search/fullmatch/sub module len; re_extra31 covers split/findall/finditer module len; re_extra54 covers search/compile/sub/error module len; no prior re spec checks subn.__module__.__len__(); subn is the one public function whose __module__.__len__() has not been checked; novel length anchor in remod55 namespace); re.RegexFlag.__module__.__len__()==2 (NOVEL — re_extra14/re_extra27 cover RegexFlag.__module__.__eq__('re'); no prior re spec checks RegexFlag.__module__.__len__(); novel length anchor in remod55 namespace); re.subn.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra6/re_extra23/re_extra28/re_extra54); re.RegexFlag.__module__.__eq__('re') (namespace anchor; covered in re_extra14/re_extra27); re.Pattern.__module__.__eq__('re') (namespace anchor; covered in re_extra9/re_extra27); re.Match.__module__.__eq__('re') (namespace anchor; covered in re_extra9/re_extra22); re.Pattern.__module__.__len__()==2 (namespace anchor; covered in re_extra30); re.Match.__module__.__len__()==2 (namespace anchor; covered in re_extra30)."
    - "re.subn.__module__ == 're' (len 2). subn is defined in Lib/re/__init__.py; its __module__ is 're'. re_extra30 covers compile/match/search/fullmatch/sub __module__.__len__()==2 and re_extra31 covers split/findall/finditer. subn is the remaining public function not yet assigned a standalone __module__.__len__() invariant. Novel length anchor in remod55. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.RegexFlag.__module__ == 're' (len 2). RegexFlag is an IntFlag enumeration defined in Lib/re/__init__.py. re_extra14 and re_extra27 cover RegexFlag.__module__.__eq__('re') equality. No prior re spec checks RegexFlag.__module__.__len__(). Novel length anchor in remod55. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Pattern.__module__ == 're'. Pattern is the compiled regex pattern type. re_extra9/re_extra27 cover this equality. Consolidated as remod55 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Match.__module__ == 're'. Match is the match object type. re_extra9/re_extra22 cover this equality. Consolidated as remod55 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Pattern.__module__.__len__() == 2. 're' has 2 characters. re_extra30 covers this. Consolidated as remod55 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Match.__module__.__len__() == 2. 're' has 2 characters. re_extra30 covers this. Consolidated as remod55 namespace anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module __module__ equality (remod55 namespace anchors)
#
# These equality values were established in many earlier namespaces. This
# table consolidates them as remod55 namespace anchors:
#
#   re.subn.__module__      == 're'   (re_extra4/re_extra6/re_extra23/re_extra28/re_extra54)
#   re.RegexFlag.__module__ == 're'   (re_extra14/re_extra27)
#   re.Pattern.__module__   == 're'   (re_extra9/re_extra27/re_extra42)
#   re.Match.__module__     == 're'   (re_extra9/re_extra22)
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra55.module_eq:
  description: "re module __module__.__eq__('re') for subn/RegexFlag/Pattern/Match — all defined in the re module; earlier namespaces cover these equality values; consolidated remod55 namespace anchors; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: remod55eq

  columns: [id, function, args, expected]
  rows:
    - [subn_module_eq,      subn.__module__.__eq__,      ["re"], true]
    - [RegexFlag_module_eq, RegexFlag.__module__.__eq__, ["re"], true]
    - [Pattern_module_eq,   Pattern.__module__.__eq__,   ["re"], true]
    - [Match_module_eq,     Match.__module__.__eq__,     ["re"], true]

# ---------------------------------------------------------------------------
# re module __module__ lengths (novel and consolidated length anchors)
#
# The __module__ attribute for all re public entities is 're' (2 characters).
#
# Novel in remod55 namespace:
#   re.subn.__module__.__len__()      == 2   (NOVEL — no prior re spec checks this)
#   re.RegexFlag.__module__.__len__() == 2   (NOVEL — no prior re spec checks this)
#
# Consolidated namespace anchors (covered in earlier specs):
#   re.Pattern.__module__.__len__()   == 2   (re_extra30)
#   re.Match.__module__.__len__()     == 2   (re_extra30)
#
# re_extra30 covers compile/match/search/fullmatch/sub __module__.__len__()==2.
# re_extra31 covers split/findall/finditer __module__.__len__()==2.
# re_extra54 covers search/compile/sub/error __module__.__len__()==2.
# subn and RegexFlag __module__.__len__() have not been checked as
# standalone invariants in any prior re spec.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra55.module_len:
  description: "re module __module__.__len__() for subn(2)/RegexFlag(2) — NOVEL: subn is the one public re function whose __module__.__len__() has not been checked (re_extra30/31/54 cover all others); RegexFlag.__module__.__len__() also novel; Pattern(2)/Match(2) consolidated from re_extra30; all 're' == 2 chars; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: remod55len

  columns: [id, function, args, expected]
  rows:
    - [subn_module_len,      subn.__module__.__len__,      [], 2]
    - [RegexFlag_module_len, RegexFlag.__module__.__len__, [], 2]
    - [Pattern_module_len,   Pattern.__module__.__len__,   [], 2]
    - [Match_module_len,     Match.__module__.__len__,     [], 2]
