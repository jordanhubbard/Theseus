spec: threading_extra279
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Condition is a pure-Python class: __module__ == 'threading', __class__.__name__ == 'type'."
    - "Condition.__name__ == 'Condition' (9 chars); Condition.__bases__[0].__name__ == 'object'."
    - "Condition.wait.__qualname__ == 'Condition.wait' (14 chars); __module__ == 'threading'."
    - "Condition.notify.__qualname__ == 'Condition.notify' (16 chars); __module__ == 'threading'."
    - "Condition.notify_all.__qualname__ == 'Condition.notify_all' (20 chars); __module__ == 'threading'."
    - "Condition.wait_for.__qualname__ == 'Condition.wait_for' (18 chars); __module__ == 'threading'."
    - "Condition does not define acquire/release directly; locking is delegated to the underlying lock."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Condition method qualnames — wait, notify, notify_all, wait_for
#
# All four are pure-Python instance methods defined in threading.Condition.
# Condition.wait.__qualname__ == 'Condition.wait' (14 chars).
# Condition.notify.__qualname__ == 'Condition.notify' (16 chars).
# Condition.notify_all.__qualname__ == 'Condition.notify_all' (20 chars).
# Condition.wait_for.__qualname__ == 'Condition.wait_for' (18 chars).
# ---------------------------------------------------------------------------

table threading_extra279.condition_method_qualnames:
  description: "threading.Condition method qualnames — wait, notify, notify_all, wait_for; qualname lengths; all pure-Python functions in threading; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex279cmq

  columns: [id, function, args, expected, description]
  rows:
    - [wa_qn_eq,  Condition.wait.__qualname__.__eq__,       ["Condition.wait"],       true, "threading.Condition.wait.__qualname__ == 'Condition.wait'; verified with Python 3.14.3"]
    - [wa_qn_len, Condition.wait.__qualname__.__len__,       [],                      14,   "threading.Condition.wait.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [wa_mod_eq, Condition.wait.__module__.__eq__,          ["threading"],            true, "threading.Condition.wait.__module__ == 'threading'; verified with Python 3.14.3"]
    - [no_qn_eq,  Condition.notify.__qualname__.__eq__,     ["Condition.notify"],     true, "threading.Condition.notify.__qualname__ == 'Condition.notify'; verified with Python 3.14.3"]
    - [no_qn_len, Condition.notify.__qualname__.__len__,     [],                      16,   "threading.Condition.notify.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [no_mod_eq, Condition.notify.__module__.__eq__,        ["threading"],            true, "threading.Condition.notify.__module__ == 'threading'; verified with Python 3.14.3"]
    - [na_qn_eq,  Condition.notify_all.__qualname__.__eq__, ["Condition.notify_all"], true, "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all'; verified with Python 3.14.3"]
    - [na_qn_len, Condition.notify_all.__qualname__.__len__, [],                      20,   "threading.Condition.notify_all.__qualname__.__len__() == 20; verified with Python 3.14.3"]
    - [wf_qn_eq,  Condition.wait_for.__qualname__.__eq__,   ["Condition.wait_for"],   true, "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for'; verified with Python 3.14.3"]
    - [wf_qn_len, Condition.wait_for.__qualname__.__len__,   [],                      18,   "threading.Condition.wait_for.__qualname__.__len__() == 18; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.Condition class identity — __name__, __module__, __bases__
#
# Condition.__name__ == 'Condition' (9 chars); __module__ == 'threading'.
# Condition.__bases__[0].__name__ == 'object' — inherits directly from object.
# ---------------------------------------------------------------------------

table threading_extra279.condition_class_identity:
  description: "threading.Condition class identity — __name__, __module__, __class__.__name__, base class; name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex279cci

  columns: [id, function, args, expected, description]
  rows:
    - [co_name_eq,  Condition.__name__.__eq__,                   ["Condition"],  true, "threading.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [co_name_len, Condition.__name__.__len__,                   [],            9,    "threading.Condition.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [co_mod_eq,   Condition.__module__.__eq__,                  ["threading"], true, "threading.Condition.__module__ == 'threading'; verified with Python 3.14.3"]
    - [co_cls_eq,   Condition.__class__.__name__.__eq__,          ["type"],      true, "threading.Condition.__class__.__name__ == 'type' (pure-Python class); verified with Python 3.14.3"]
    - [co_base_eq,  "Condition.__bases__[0].__name__.__eq__",     ["object"],    true, "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra279
# ---------------------------------------------------------------------------

invariant threading_extra279.condition_wait_qualname:
  description: "threading.Condition.wait.__qualname__ == 'Condition.wait' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Condition.wait.__qualname__.__eq__
  args: ["Condition.wait"]
  expected: true

invariant threading_extra279.condition_notify_qualname:
  description: "threading.Condition.notify.__qualname__ == 'Condition.notify' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Condition.notify.__qualname__.__eq__
  args: ["Condition.notify"]
  expected: true

invariant threading_extra279.condition_notify_all_qualname:
  description: "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__eq__
  args: ["Condition.notify_all"]
  expected: true

invariant threading_extra279.condition_notify_all_qualname_length_is_20:
  description: "threading.Condition.notify_all.__qualname__.__len__() == 20 — 'Condition.notify_all' has 20 characters"
  category: identity
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant threading_extra279.condition_wait_for_qualname:
  description: "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Condition.wait_for.__qualname__.__eq__
  args: ["Condition.wait_for"]
  expected: true

invariant threading_extra279.condition_base_is_object:
  description: "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object with no intermediate base class"
  category: identity
  kind: python_call_eq
  function: "Condition.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra279.condition_module_is_threading:
  description: "threading.Condition.__module__ == 'threading' — Condition is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra279.condition_name_length_is_9:
  description: "threading.Condition.__name__.__len__() == 9 — 'Condition' has 9 characters"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__len__
  args: []
  expected: 9
