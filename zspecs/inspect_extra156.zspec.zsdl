spec: inspect_extra156
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter.POSITIONAL_ONLY.value 0; POSITIONAL_OR_KEYWORD.value 1; VAR_POSITIONAL.value 2; KEYWORD_ONLY.value 3; VAR_KEYWORD.value 4; inspect.Parameter.empty.__class__.__name__ 'type'; inspect.Attribute.__name__ 'Attribute' (Wave 285)."
    - "inspect.Parameter.POSITIONAL_ONLY.value == 0 — ParameterKind enum values are 0-4 in declaration order. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1 — second ParameterKind enum value. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.value == 2 — third ParameterKind enum value, used for *args. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.value == 3 — fourth ParameterKind enum value, parameters after *args. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.value == 4 — fifth ParameterKind enum value, used for **kwargs. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the _empty class itself (not an instance); its __class__ is 'type' (the metaclass). Verified with Python 3.14.3."
    - "inspect.Attribute.__name__ == 'Attribute' — inspect.Attribute is a namedtuple used by classify_class_attrs; its __name__ is 'Attribute'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter kind values (POSITIONAL_ONLY through VAR_KEYWORD)
#
# Wave 285 theme: inspect.Parameter ParameterKind enum integer values.
#
# inspect.Parameter.POSITIONAL_ONLY.value == 0
# inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1
# inspect.Parameter.VAR_POSITIONAL.value == 2
# inspect.Parameter.KEYWORD_ONLY.value == 3
# inspect.Parameter.VAR_KEYWORD.value == 4
#
# inspect.Parameter.kind values are integers from the ParameterKind enum.
# The ordering is: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2,
# KEYWORD_ONLY=3, VAR_KEYWORD=4. These correspond to the five possible
# parameter kinds in Python function signatures. New to extra156.
# ---------------------------------------------------------------------------

table inspect_extra156.parameter_kind_values:
  description: "inspect.Parameter kind values: POSITIONAL_ONLY 0, POSITIONAL_OR_KEYWORD 1, VAR_POSITIONAL 2, KEYWORD_ONLY 3, VAR_KEYWORD 4; ParameterKind enum ordering; wave 285; new to extra156"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpkv156

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_value_eq_0,
       "Parameter.POSITIONAL_ONLY.value.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY is the first ParameterKind enum member; its integer value is 0; it represents parameters that can only be passed positionally (before a / separator); int.__eq__(0) returns True; new to extra156"]
    - [positional_or_keyword_value_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD is the second ParameterKind enum member; its integer value is 1; it is the most common kind representing parameters that can be passed positionally or by keyword; int.__eq__(1) returns True; new to extra156"]
    - [var_positional_value_eq_2,
       "Parameter.VAR_POSITIONAL.value.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL is the third ParameterKind enum member; its integer value is 2; it represents *args parameters that capture excess positional arguments; int.__eq__(2) returns True; new to extra156"]
    - [keyword_only_value_eq_3,
       "Parameter.KEYWORD_ONLY.value.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY is the fourth ParameterKind enum member; its integer value is 3; it represents parameters appearing after a * or *args that must be passed by keyword; int.__eq__(3) returns True; new to extra156"]
    - [var_keyword_value_eq_4,
       "Parameter.VAR_KEYWORD.value.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD is the fifth ParameterKind enum member; its integer value is 4; it represents **kwargs parameters that capture excess keyword arguments; int.__eq__(4) returns True; new to extra156"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.empty class and inspect.Attribute namedtuple name
#
# Wave 285 theme: inspect.Parameter.empty type identity and inspect.Attribute
# namedtuple __name__.
#
# inspect.Parameter.empty.__class__.__name__ == 'type'
# inspect.Attribute.__name__ == 'Attribute'
#
# inspect.Parameter.empty is the _empty class itself used as a sentinel for
# parameters with no default or annotation. It is a class object, so its
# __class__ is 'type'. inspect.Attribute is a namedtuple with fields name,
# kind, defining_class, and object, returned by classify_class_attrs().
# New to extra156.
# ---------------------------------------------------------------------------

table inspect_extra156.parameter_empty_class_and_attribute_name:
  description: "inspect.Parameter.empty.__class__.__name__ 'type' (empty is the sentinel class itself); inspect.Attribute.__name__ 'Attribute' (namedtuple); wave 285; new to extra156"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpeca156

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_empty_class_eq_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is the _empty class itself used as a sentinel for missing defaults and annotations; it is a class object whose own __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra156"]
    - [attribute_name_eq_Attribute,
       "Attribute.__name__.__eq__",
       ["Attribute"],
       true,
       "inspect.Attribute.__name__.__eq__('Attribute') == True — inspect.Attribute is a namedtuple with fields (name, kind, defining_class, object) returned by classify_class_attrs; its __name__ is 'Attribute'; str.__eq__('Attribute') returns True; new to extra156"]
    - [positional_only_value_class_eq_int,
       "Parameter.POSITIONAL_ONLY.value.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__class__.__name__.__eq__('int') == True — the value attribute of ParameterKind enum members is a Python int; POSITIONAL_ONLY.value is 0 (an int); __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra156"]
    - [var_keyword_value_class_eq_int,
       "Parameter.VAR_KEYWORD.value.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__class__.__name__.__eq__('int') == True — VAR_KEYWORD.value is 4 (an int); all ParameterKind enum members have int values; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra156"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra156
# ---------------------------------------------------------------------------

invariant inspect_extra156.positional_only_value_0:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0 — first ParameterKind enum value; positional-only parameter kind; wave 285; new to extra156"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect_extra156.positional_or_keyword_value_1:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1 — second ParameterKind enum value; most common parameter kind; wave 285; new to extra156"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.value.__eq__
  args: [1]
  expected: true

invariant inspect_extra156.var_positional_value_2:
  description: "inspect.Parameter.VAR_POSITIONAL.value == 2 — third ParameterKind enum value; *args parameter kind; wave 285; new to extra156"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.value.__eq__
  args: [2]
  expected: true

invariant inspect_extra156.keyword_only_value_3:
  description: "inspect.Parameter.KEYWORD_ONLY.value == 3 — fourth ParameterKind enum value; parameters after * or *args; wave 285; new to extra156"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.value.__eq__
  args: [3]
  expected: true

invariant inspect_extra156.var_keyword_value_4:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4 — fifth ParameterKind enum value; **kwargs parameter kind; wave 285; new to extra156"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true

invariant inspect_extra156.parameter_empty_class_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the _empty sentinel class itself; its __class__ is the metaclass type; wave 285; new to extra156"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra156.attribute_name_Attribute:
  description: "inspect.Attribute.__name__ == 'Attribute' — Attribute is a namedtuple returned by classify_class_attrs; wave 285; new to extra156"
  kind: python_call_eq
  function: Attribute.__name__.__eq__
  args: ["Attribute"]
  expected: true

