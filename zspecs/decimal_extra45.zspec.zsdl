spec: decimal_extra45
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra44.zspec.zsdl — covers DecimalException/InvalidOperation/DivisionByZero/Overflow __class__.__qualname__.__eq__('type'); getcontext/setcontext/localcontext __class__.__qualname__.__eq__('builtin_function_or_method')."
    - "decimal_extra42.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_05UP __class__.__qualname__.__eq__('str'); MIN_ETINY.__class__.__name__/__qualname__.__eq__('int')."
    - "decimal_extra25.zspec.zsdl — covers ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__name__.__eq__('str'); ROUND_HALF_EVEN.__class__.__name__.__len__()==3."
    - "decimal_extra24.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__module__.__eq__('builtins')."
    - "decimal_extra23.zspec.zsdl — covers ROUND_HALF_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_EVEN __class__.__name__.__eq__('str')."
    - "decimal_extra20.zspec.zsdl — covers all ROUND_* constant __len__() values: ROUND_UP(8)/ROUND_DOWN(10)/ROUND_HALF_UP(13)/ROUND_HALF_DOWN(15)/ROUND_CEILING(13)/ROUND_FLOOR(11)/ROUND_HALF_EVEN(15)/ROUND_05UP(10)."
    - "decimal_extra.zspec.zsdl — covers ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_CEILING/ROUND_FLOOR string equality."
    - "decimal_extra4.zspec.zsdl — covers ROUND_HALF_EVEN/ROUND_DOWN/ROUND_UP/ROUND_HALF_DOWN/ROUND_05UP string equality."
    - "decimal_extra6.zspec.zsdl — covers ROUND_HALF_EVEN/ROUND_UP/ROUND_05UP string equality."
    - "decimal_extra13.zspec.zsdl — covers ROUND_DOWN/ROUND_UP string equality."
  notes:
    - "This spec extends decimal_extra44.zspec.zsdl."
    - "Prior specs collectively covered: all ROUND_* string equality (decimal_extra/decimal_extra4/decimal_extra6/decimal_extra13); all ROUND_* string __len__() values (decimal_extra20); ROUND_HALF_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_EVEN/ROUND_UP __class__.__name__=='str' (decimal_extra23/25); ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_05UP __class__.__qualname__=='str' (decimal_extra42); ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__module__=='builtins' (decimal_extra24); ROUND_HALF_EVEN.__class__.__name__.__len__()==3 (decimal_extra25). NOT YET COVERED: ROUND_HALF_DOWN/__class__.__name__=='str' (novel — decimal_extra23 covers ROUND_HALF_UP/DOWN/CEILING/FLOOR/HALF_EVEN but NOT ROUND_HALF_DOWN; decimal_extra25 also omits ROUND_HALF_DOWN; novel); ROUND_05UP/__class__.__name__=='str' (novel — neither decimal_extra23 nor decimal_extra25 includes ROUND_05UP; novel); ROUND_HALF_EVEN/__class__.__qualname__=='str' (novel — decimal_extra42 covers CEILING/FLOOR/HALF_UP/HALF_DOWN/05UP but NOT ROUND_HALF_EVEN or ROUND_UP or ROUND_DOWN); ROUND_UP/__class__.__qualname__=='str' (novel); ROUND_DOWN/__class__.__qualname__=='str' (novel); ROUND_HALF_DOWN/__class__.__module__=='builtins' (novel — decimal_extra24 covers CEILING/FLOOR/HALF_UP only; novel); ROUND_HALF_EVEN/__class__.__module__=='builtins' (novel); ROUND_UP/__class__.__module__=='builtins' (novel); ROUND_DOWN/__class__.__module__=='builtins' (novel); ROUND_05UP/__class__.__module__=='builtins' (novel)."
    - "This spec covers: decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__('str') (NOVEL — not in decimal_extra23 or decimal_extra25; novel equality anchor for ROUND_HALF_DOWN __class__.__name__); decimal.ROUND_05UP.__class__.__name__.__eq__('str') (NOVEL — not in any prior __class__.__name__ spec for ROUND_05UP; novel); decimal.ROUND_HALF_EVEN.__class__.__qualname__.__eq__('str') (NOVEL — decimal_extra42 covers CEILING/FLOOR/HALF_UP/HALF_DOWN/05UP but not HALF_EVEN; novel __qualname__ path anchor for ROUND_HALF_EVEN); decimal.ROUND_UP.__class__.__qualname__.__eq__('str') (NOVEL — not in decimal_extra42; novel); decimal.ROUND_DOWN.__class__.__qualname__.__eq__('str') (NOVEL — not in decimal_extra42; novel); decimal.ROUND_HALF_DOWN.__class__.__module__.__eq__('builtins') (NOVEL — decimal_extra24 covers CEILING/FLOOR/HALF_UP only; novel __module__ anchor); decimal.ROUND_HALF_EVEN.__class__.__module__.__eq__('builtins') (NOVEL); decimal.ROUND_UP.__class__.__module__.__eq__('builtins') (NOVEL); decimal.ROUND_DOWN.__class__.__module__.__eq__('builtins') (NOVEL); decimal.ROUND_05UP.__class__.__module__.__eq__('builtins') (NOVEL)."
    - "decimal.ROUND_HALF_DOWN.__class__.__name__ == 'str'. ROUND_HALF_DOWN is a plain Python str constant. Its type is str; __class__.__name__=='str'. decimal_extra23 covers ROUND_HALF_UP/DOWN(missing)/CEILING/FLOOR/HALF_EVEN; decimal_extra25 also omits ROUND_HALF_DOWN. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.ROUND_05UP.__class__.__name__ == 'str'. ROUND_05UP is a plain Python str constant. Its type is str. Neither decimal_extra23 nor decimal_extra25 includes ROUND_05UP in __class__.__name__ coverage. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.ROUND_HALF_EVEN.__class__.__qualname__ == 'str'. For the builtin str type, __qualname__==__name__=='str'. decimal_extra42 covers 5 of the 8 ROUND_ constants via __class__.__qualname__ but omits ROUND_HALF_EVEN, ROUND_UP, ROUND_DOWN. Novel __qualname__ path anchor for ROUND_HALF_EVEN. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.ROUND_HALF_DOWN.__class__.__module__ == 'builtins'. The str type is a C-level builtin whose module is 'builtins'. decimal_extra24 covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP only. Novel __module__ anchor for ROUND_HALF_DOWN. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.ROUND_HALF_DOWN and ROUND_05UP __class__.__name__ equality
#
# All ROUND_* rounding mode constants are plain Python str objects. Their
# __class__.__name__ is 'str'. Prior specs cover most constants:
#   decimal_extra23: ROUND_HALF_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_EVEN
#   decimal_extra25: ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP
#
# Neither spec includes ROUND_HALF_DOWN or ROUND_05UP.
# Both equality anchors are novel in the decimal_extra45 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra45.round_class_names_novel:
  description: "decimal ROUND_HALF_DOWN and ROUND_05UP __class__.__name__.__eq__('str') — prior specs (decimal_extra23/25) cover all other ROUND_* constants via __class__.__name__; ROUND_HALF_DOWN and ROUND_05UP omitted from prior __class__.__name__ coverage; both novel equality anchors in decimal_extra45 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decround45cn

  columns: [id, function, args, expected]
  rows:
    - [ROUND_HALF_DOWN_class_name, ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true]
    - [ROUND_05UP_class_name,      ROUND_05UP.__class__.__name__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# decimal.ROUND_HALF_EVEN, ROUND_UP, ROUND_DOWN __class__.__qualname__
#
# For the builtin str type, __qualname__==__name__=='str'. decimal_extra42
# covers __class__.__qualname__ for ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/
# ROUND_HALF_DOWN/ROUND_05UP, but omits ROUND_HALF_EVEN, ROUND_UP, ROUND_DOWN.
# All three anchors are novel in the decimal_extra45 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra45.round_class_qualnames_novel:
  description: "decimal ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN __class__.__qualname__.__eq__('str') — for the builtin str type __qualname__==__name__=='str'; decimal_extra42 covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_05UP via __class__.__qualname__; ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN omitted from prior __class__.__qualname__ coverage; all three novel __qualname__ path anchors in decimal_extra45 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decround45cq

  columns: [id, function, args, expected]
  rows:
    - [ROUND_HALF_EVEN_class_qualname, ROUND_HALF_EVEN.__class__.__qualname__.__eq__, ["str"], true]
    - [ROUND_UP_class_qualname,        ROUND_UP.__class__.__qualname__.__eq__,        ["str"], true]
    - [ROUND_DOWN_class_qualname,      ROUND_DOWN.__class__.__qualname__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# decimal ROUND_* constants __class__.__module__ — novel constants
#
# The str type is a C-level builtin type whose module is 'builtins'. Therefore
# for any ROUND_* constant, __class__.__module__ == 'builtins'.
# decimal_extra24 covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP only.
# The remaining five constants are novel in the decimal_extra45 namespace:
#
#   ROUND_HALF_DOWN.__class__.__module__  == 'builtins'
#   ROUND_HALF_EVEN.__class__.__module__  == 'builtins'
#   ROUND_UP.__class__.__module__         == 'builtins'
#   ROUND_DOWN.__class__.__module__       == 'builtins'
#   ROUND_05UP.__class__.__module__       == 'builtins'
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra45.round_class_modules_novel:
  description: "decimal ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_05UP __class__.__module__.__eq__('builtins') — str is a C-level builtin type whose __module__=='builtins'; decimal_extra24 covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP only; all five novel __module__ anchors in decimal_extra45 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decround45cm

  columns: [id, function, args, expected]
  rows:
    - [ROUND_HALF_DOWN_class_module,  ROUND_HALF_DOWN.__class__.__module__.__eq__,  ["builtins"], true]
    - [ROUND_HALF_EVEN_class_module,  ROUND_HALF_EVEN.__class__.__module__.__eq__,  ["builtins"], true]
    - [ROUND_UP_class_module,         ROUND_UP.__class__.__module__.__eq__,         ["builtins"], true]
    - [ROUND_DOWN_class_module,       ROUND_DOWN.__class__.__module__.__eq__,       ["builtins"], true]
    - [ROUND_05UP_class_module,       ROUND_05UP.__class__.__module__.__eq__,       ["builtins"], true]
