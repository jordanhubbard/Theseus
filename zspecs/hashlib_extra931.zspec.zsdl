spec: hashlib_extra931
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ for hashlib functions and constructors"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra931.hash_constructors_doc_class:
  description: "hashlib hash constructor __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: hl931x
  columns: [id, function, args, expected]
  rows:
    - [hl931x001, hashlib.md5.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [hl931x002, hashlib.sha1.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [hl931x003, hashlib.sha256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl931x004, hashlib.sha512.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl931x005, hashlib.sha224.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl931x006, hashlib.sha384.__doc__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra931.hash_functions_doc_class:
  description: "hashlib utility function __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: hl931f
  columns: [id, function, args, expected]
  rows:
    - [hl931f001, hashlib.new.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [hl931f002, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [hl931f003, hashlib.scrypt.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [hl931f004, hashlib.algorithms_available.__class__.__name__.__eq__, ["set"], true]
    - [hl931f005, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]

table hashlib_extra931.doc_nonempty:
  description: "hashlib __doc__ strings are non-empty"
  kind: python_call_eq
  category: doc_nonempty
  id_prefix: hl931n
  columns: [id, function, args, expected]
  rows:
    - [hl931n001, hashlib.md5.__doc__.__len__.__gt__,    [0], true]
    - [hl931n002, hashlib.sha1.__doc__.__len__.__gt__,   [0], true]
    - [hl931n003, hashlib.sha256.__doc__.__len__.__gt__, [0], true]
    - [hl931n004, hashlib.sha512.__doc__.__len__.__gt__, [0], true]
    - [hl931n005, hashlib.new.__doc__.__len__.__gt__,    [0], true]
