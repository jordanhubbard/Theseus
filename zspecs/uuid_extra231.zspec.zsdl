spec: uuid_extra231
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra226.zspec.zsdl — covers uuid3/uuid5 str() value, version attribute, class name, str len; NAMESPACE_DNS+'python.org'"
    - "uuid_extra230.zspec.zsdl — covers uuid4/uuid1 class name, version, module, qualname, NAMESPACE_DNS class name"
    - "uuid_extra229.zspec.zsdl — covers UUID hex/int/bytes/str attribute contracts for fixed UUID string"
  notes:
    - "This spec extends uuid_extra226.zspec.zsdl and uuid_extra230.zspec.zsdl; it does NOT duplicate invariants present there."
    - "uuid_extra226 anchors uuid3/uuid5 with NAMESPACE_DNS+'python.org' str and version. This spec anchors the .hex and .int attribute values for these same vectors, and covers NAMESPACE_URL+'http://example.com' str/hex/version for both uuid3 and uuid5."
    - "uuid5(NAMESPACE_DNS,'python.org').hex == '886313e13b8a53729b900c9aee199e5d' — no prior uuid spec anchors the hex attribute for this uuid5 output. Verified Python 3.14.3."
    - "uuid5(NAMESPACE_DNS,'python.org').int == 181289448026289383154478846676280385117 — no prior uuid spec anchors the int attribute for this uuid5 output. Verified Python 3.14.3."
    - "uuid3(NAMESPACE_DNS,'python.org').hex == '6fa459eaee8a3ca4894edb77e160355e' — no prior uuid spec anchors the hex attribute for this uuid3 output. Verified Python 3.14.3."
    - "uuid3(NAMESPACE_DNS,'python.org').int == 148397667964594677437660345472754136414 — no prior uuid spec anchors the int attribute. Verified Python 3.14.3."
    - "uuid5(NAMESPACE_URL,'http://example.com') str == '8c9ddcb0-8084-5a7f-a988-1095ab18b5df'. Verified Python 3.14.3."
    - "uuid3(NAMESPACE_URL,'http://example.com') str == 'd632b50c-7913-3137-ae9a-2d93f56e70d5'. Verified Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid5(NAMESPACE_DNS, 'python.org') — hex and int attribute values
# uuid_extra226 anchors str() == '886313e1-...' and version == 5.
# This spec anchors the .hex (no-hyphen form) and .int (integer) attributes.
# ---------------------------------------------------------------------------

invariant uuid_extra231.uuid5.dns_python_org_hex:
  description: "uuid5(NAMESPACE_DNS,'python.org').hex == '886313e13b8a53729b900c9aee199e5d' — no-hyphen 32-char hex; uuid_extra226 anchors str(); this anchors hex; verified Python 3.14.3"
  category: v5
  kind: python_call_eq
  function: "uuid5(NAMESPACE_DNS, 'python.org').hex.__eq__"
  args: ["886313e13b8a53729b900c9aee199e5d"]
  expected: true

invariant uuid_extra231.uuid5.dns_python_org_int:
  description: "uuid5(NAMESPACE_DNS,'python.org').int == 181289448026289383154478846676280385117 — no prior uuid spec anchors the int value for this uuid5 vector; verified Python 3.14.3"
  category: v5
  kind: python_call_eq
  function: "uuid5(NAMESPACE_DNS, 'python.org').int.__eq__"
  args: [181289448026289383154478846676280385117]
  expected: true

invariant uuid_extra231.uuid5.dns_python_org_hex_len:
  description: "len(uuid5(NAMESPACE_DNS,'python.org').hex) == 32 — hex is always 32 lowercase hex chars; verified Python 3.14.3"
  category: v5
  kind: python_call_eq
  function: "uuid5(NAMESPACE_DNS, 'python.org').hex.__len__"
  args: []
  expected: 32

# ---------------------------------------------------------------------------
# uuid3(NAMESPACE_DNS, 'python.org') — hex and int attribute values
# uuid_extra226 anchors str() == '6fa459ea-...' and version == 3.
# This spec anchors the .hex and .int attributes.
# ---------------------------------------------------------------------------

invariant uuid_extra231.uuid3.dns_python_org_hex:
  description: "uuid3(NAMESPACE_DNS,'python.org').hex == '6fa459eaee8a3ca4894edb77e160355e' — no-hyphen 32-char hex; uuid_extra226 anchors str(); this anchors hex; verified Python 3.14.3"
  category: v3
  kind: python_call_eq
  function: "uuid3(NAMESPACE_DNS, 'python.org').hex.__eq__"
  args: ["6fa459eaee8a3ca4894edb77e160355e"]
  expected: true

invariant uuid_extra231.uuid3.dns_python_org_int:
  description: "uuid3(NAMESPACE_DNS,'python.org').int == 148397667964594677437660345472754136414 — no prior uuid spec anchors the int value for this uuid3 vector; verified Python 3.14.3"
  category: v3
  kind: python_call_eq
  function: "uuid3(NAMESPACE_DNS, 'python.org').int.__eq__"
  args: [148397667964594677437660345472754136414]
  expected: true

invariant uuid_extra231.uuid3.dns_python_org_hex_len:
  description: "len(uuid3(NAMESPACE_DNS,'python.org').hex) == 32 — hex is always 32 lowercase hex chars; verified Python 3.14.3"
  category: v3
  kind: python_call_eq
  function: "uuid3(NAMESPACE_DNS, 'python.org').hex.__len__"
  args: []
  expected: 32

# ---------------------------------------------------------------------------
# uuid5(NAMESPACE_URL, 'http://example.com') — str/hex/version
# uuid_extra226 anchors NAMESPACE_URL class name; this anchors the str output.
# ---------------------------------------------------------------------------

table uuid_extra231.uuid5.url_example_com:
  description: "uuid5(NAMESPACE_URL,'http://example.com') str/hex/version contracts; novel to uuid_extra231; verified Python 3.14.3"
  kind: python_call_eq
  category: v5
  id_prefix: uuid231v5

  columns: [id, function, args, expected]
  rows:
    - [str_eq,     "uuid5(NAMESPACE_URL, 'http://example.com').__str__",          [], "8c9ddcb0-8084-5a7f-a988-1095ab18b5df"]
    - [hex_eq,     "uuid5(NAMESPACE_URL, 'http://example.com').hex.__eq__",       ["8c9ddcb080845a7fa9881095ab18b5df"], true]
    - [version_eq, "uuid5(NAMESPACE_URL, 'http://example.com').version.__eq__",   [5],  true]
    - [class_eq,   "uuid5(NAMESPACE_URL, 'http://example.com').__class__.__name__.__eq__", ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid3(NAMESPACE_URL, 'http://example.com') — str/hex/version
# No prior uuid spec covers uuid3 with NAMESPACE_URL.
# ---------------------------------------------------------------------------

table uuid_extra231.uuid3.url_example_com:
  description: "uuid3(NAMESPACE_URL,'http://example.com') str/hex/version contracts; novel to uuid_extra231; verified Python 3.14.3"
  kind: python_call_eq
  category: v3
  id_prefix: uuid231v3

  columns: [id, function, args, expected]
  rows:
    - [str_eq,     "uuid3(NAMESPACE_URL, 'http://example.com').__str__",          [], "d632b50c-7913-3137-ae9a-2d93f56e70d5"]
    - [hex_eq,     "uuid3(NAMESPACE_URL, 'http://example.com').hex.__eq__",       ["d632b50c79133137ae9a2d93f56e70d5"], true]
    - [version_eq, "uuid3(NAMESPACE_URL, 'http://example.com').version.__eq__",   [3],  true]
    - [class_eq,   "uuid3(NAMESPACE_URL, 'http://example.com').__class__.__name__.__eq__", ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid5/uuid3 bytes attribute length (always 16 for any UUID)
# ---------------------------------------------------------------------------

invariant uuid_extra231.uuid5.dns_python_org_bytes_len:
  description: "len(uuid5(NAMESPACE_DNS,'python.org').bytes) == 16 — UUID bytes are always 16 bytes (128 bits); verified Python 3.14.3"
  category: v5
  kind: python_call_eq
  function: "uuid5(NAMESPACE_DNS, 'python.org').bytes.__len__"
  args: []
  expected: 16

invariant uuid_extra231.uuid3.dns_python_org_bytes_len:
  description: "len(uuid3(NAMESPACE_DNS,'python.org').bytes) == 16 — UUID bytes are always 16 bytes (128 bits); verified Python 3.14.3"
  category: v3
  kind: python_call_eq
  function: "uuid3(NAMESPACE_DNS, 'python.org').bytes.__len__"
  args: []
  expected: 16
