  notes:
    - "This spec does NOT duplicate invariants present in any prior struct spec."
    - "Wave 543 theme: __subclasshook__ and __instancecheck__ checks for struct.Struct and struct.error."
    - "struct.Struct is a C-level type (PyStructObject); its metaclass is the standard type, not a custom one."
    - "struct.error is a Python exception class (subclass of Exception); its metaclass is also the standard type."
    - "struct.Struct.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in struct.Struct.__dict__ == False — inherited from type metaclass. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__instancecheck__ in struct.Struct.__dict__ == False — inherited from type metaclass. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in struct.error.__dict__ == False — struct.error inherits from Exception; neither defines __subclasshook__ directly. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__instancecheck__ in struct.error.__dict__ == False — same pattern. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Both Struct and error follow the standard Python C-extension type metaclass protocol: __subclasshook__ and __instancecheck__ reside on the metaclass (type), not on the class itself."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — __subclasshook__ and __instancecheck__ type and dict checks
#
# Wave 543 theme: struct.Struct is a C-level extension type (PyStructObject).
# Its metaclass is the standard type built-in. __subclasshook__ and
# __instancecheck__ are inherited from type at the C level; both have class name
# 'builtin_function_or_method' and are absent from Struct.__dict__.
# ---------------------------------------------------------------------------

table struct_extra1441.Struct_subclasshook:
  description: "struct.Struct.__subclasshook__.__class__.__name__=='builtin_function_or_method' and not in Struct.__dict__ — Struct is C-level PyStructObject; metaclass is standard type; __subclasshook__/__instancecheck__ inherited at C level; no Python-level override; wave 543 first st1441ss anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1441ss

  columns: [id, function, args, expected, description]
  rows:
    - [st1441ss001, "Struct.__subclasshook__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true,  "struct.Struct.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [st1441ss002, "Struct.__dict__.__contains__",                        ["__subclasshook__"],           false, "struct.Struct.__dict__ does not contain '__subclasshook__' — inherited from type; not defined on Struct"]
    - [st1441ss003, "Struct.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "struct.Struct.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [st1441ss004, "Struct.__dict__.__contains__",                        ["__instancecheck__"],           false, "struct.Struct.__dict__ does not contain '__instancecheck__' — inherited from type; not defined on Struct"]
    - [st1441ss005, "Struct.__subclasshook__.__class__.__name__.__eq__",  ["classmethod_descriptor"],      false, "struct.Struct.__subclasshook__.__class__.__name__ is NOT 'classmethod_descriptor' — it is 'builtin_function_or_method'"]
    - [st1441ss006, "Struct.__instancecheck__.__class__.__name__.__eq__", ["wrapper_descriptor"],           false, "struct.Struct.__instancecheck__.__class__.__name__ is NOT 'wrapper_descriptor' — it is 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# struct.error — __subclasshook__ and __instancecheck__ type and dict checks
#
# struct.error is a Python exception class (subclass of Exception).
# It uses the standard type metaclass. __subclasshook__ and __instancecheck__
# are inherited from type; struct.error does not define either in its own __dict__.
# ---------------------------------------------------------------------------

table struct_extra1441.error_subclasshook:
  description: "struct.error.__subclasshook__.__class__.__name__=='builtin_function_or_method' and not in error.__dict__ — struct.error subclasses Exception; uses standard type metaclass; __subclasshook__/__instancecheck__ both inherited from type at C level; no Python-level override on struct.error; wave 543 first st1441es anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1441es

  columns: [id, function, args, expected, description]
  rows:
    - [st1441es001, "error.__subclasshook__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true,  "struct.error.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [st1441es002, "error.__dict__.__contains__",                        ["__subclasshook__"],           false, "struct.error.__dict__ does not contain '__subclasshook__' — inherited from type via Exception chain"]
    - [st1441es003, "error.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "struct.error.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [st1441es004, "error.__dict__.__contains__",                        ["__instancecheck__"],           false, "struct.error.__dict__ does not contain '__instancecheck__' — inherited from type via Exception chain"]
    - [st1441es005, "error.__subclasshook__.__class__.__name__.__eq__",  ["function"],                    false, "struct.error.__subclasshook__.__class__.__name__ is NOT 'function' — it is 'builtin_function_or_method'"]
    - [st1441es006, "error.__instancecheck__.__class__.__name__.__eq__", ["method_descriptor"],            false, "struct.error.__instancecheck__.__class__.__name__ is NOT 'method_descriptor' — it is 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# Symmetry: struct.Struct and struct.error share the same metaclass protocol
#
# Despite being very different types (a C-extension data type vs a Python
# exception class), both Struct and error follow the same pattern for
# __subclasshook__ and __instancecheck__: 'builtin_function_or_method', absent
# from their respective __dict__. This table confirms the symmetry.
# ---------------------------------------------------------------------------

table struct_extra1441.Struct_error_symmetry:
  description: "struct.Struct and struct.error have identical __subclasshook__/__instancecheck__ class names ('builtin_function_or_method') — both use standard type metaclass; despite being different kinds of types (C-extension data type vs Python exception), the metaclass protocol is uniform; both absent from their __dict__; wave 543 st1441sy anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1441sy

  columns: [id, function, args, expected, description]
  rows:
    - [st1441sy001, "Struct.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "struct.Struct.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'"]
    - [st1441sy002, "error.__subclasshook__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "struct.error.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'"]
    - [st1441sy003, "Struct.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "struct.Struct.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'"]
    - [st1441sy004, "error.__instancecheck__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "struct.error.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'"]
    - [st1441sy005, "Struct.__dict__.__contains__", ["__subclasshook__"], false, "struct.Struct.__dict__ missing '__subclasshook__' — C-level inheritance confirmed"]
    - [st1441sy006, "error.__dict__.__contains__",  ["__subclasshook__"], false, "struct.error.__dict__ missing '__subclasshook__' — inherited via Exception chain"]
