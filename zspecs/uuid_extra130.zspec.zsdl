spec: uuid_extra130
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality and length (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant / type(UUID.hex).__name__=='property'."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ and __name__.__len__()==8 / SafeUUID.__bases__[0].__name__=='Enum' / UUID property fget qualname lengths."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / uuid3/uuid5/getnode __qualname__.__len__() / SafeUUID metaclass/module/MRO depth."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra99."
    - "Wave 282 theme: SafeUUID class metadata (mro, metaclass, module, doc) / uuid.__spec__ attribute identity / SafeUUID member name strings."
    - "uuid.SafeUUID.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__[0].__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__[1].__name__ == 'Enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__[2].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__class__.__name__ == 'EnumType'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__doc__ == 'An enumeration.'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__doc__.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.name == 'safe'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.name == 'unsafe'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name.__eq__('uuid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.origin.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: SafeUUID.__class__.__name__ is 'EnumType' (the metaclass for all Enum subclasses in Python 3.11+), not 'type'. This reflects the EnumMeta/EnumType metaclass system."
    - "Note: SafeUUID.__bases__[0].__name__ is 'Enum' (not 'IntEnum'); uuid_extra95 confirms this. SafeUUID does NOT inherit from IntEnum despite having integer values — it inherits from plain Enum."
    - "Note: SafeUUID.__mro__ is [SafeUUID, Enum, object] — length 3. This is shorter than typical IntEnum MROs (which include int in the chain)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__.__len__()==3
# uuid.SafeUUID.__mro__[0].__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__mro__[1].__name__.__eq__('Enum')
# uuid.SafeUUID.__mro__[2].__name__.__eq__('object')
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType')
#
# Wave 282 theme: SafeUUID MRO structure and metaclass.
#
# SafeUUID.__mro__ has length 3: [SafeUUID, Enum, object]. The metaclass is
# EnumType (Python 3.11+ name for EnumMeta). uuid_extra94 anchors SafeUUID MRO
# depth and metaclass at table level; this spec anchors MRO member names under
# uuidsafe130. SafeUUID inherits from plain Enum (not IntEnum) despite having
# integer .value attributes. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra130.SafeUUID_mro_and_metaclass:
  description: "uuid.SafeUUID/__mro__/__len__()==3 / mro[0]/__name__.__eq__('SafeUUID')==True / mro[1]/__name__.__eq__('Enum')==True / mro[2]/__name__.__eq__('object')==True / SafeUUID/__class__.__name__.__eq__('EnumType')==True — SafeUUID MRO is [SafeUUID, Enum, object] (length 3); metaclass is EnumType (Python 3.11+ EnumMeta); inherits from plain Enum not IntEnum; extra94 anchors MRO depth and metaclass; first uuidsafe130 anchor for MRO member names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidsafe130

  columns: [id, function, args, expected, description]
  rows:
    - [mro_len,          "SafeUUID.__mro__.__len__",              [],            3,    "SafeUUID.__mro__ has 3 entries: [SafeUUID, Enum, object]"]
    - [mro0_name,        "SafeUUID.__mro__[0].__name__.__eq__",  ["SafeUUID"],  true, "SafeUUID.__mro__[0] is SafeUUID itself"]
    - [mro1_name,        "SafeUUID.__mro__[1].__name__.__eq__",  ["Enum"],      true, "SafeUUID.__mro__[1] is Enum (not IntEnum — SafeUUID uses plain Enum)"]
    - [mro2_name,        "SafeUUID.__mro__[2].__name__.__eq__",  ["object"],    true, "SafeUUID.__mro__[2] is object (the base of all Python types)"]
    - [metaclass_name,   SafeUUID.__class__.__name__.__eq__,      ["EnumType"],  true, "SafeUUID.__class__.__name__ is 'EnumType' (the Enum metaclass; called EnumMeta before Python 3.11)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__module__.__eq__('uuid')
# uuid.SafeUUID.__module__.__len__()==4
# uuid.SafeUUID.__doc__.__eq__('An enumeration.')
# uuid.SafeUUID.__doc__.__len__()==15
# uuid.SafeUUID.safe.name.__eq__('safe')
# uuid.SafeUUID.unsafe.name.__eq__('unsafe')
#
# Wave 282 theme: SafeUUID module, doc, and member name strings.
#
# SafeUUID.__module__ is 'uuid' (4 chars). SafeUUID.__doc__ is 'An enumeration.'
# (15 chars) — the default docstring generated for Enum subclasses. SafeUUID.safe
# and SafeUUID.unsafe have .name attributes equal to 'safe' and 'unsafe'. No
# prior uuid spec anchors these together under uuidsafe130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra130.SafeUUID_module_doc_member_names:
  description: "uuid.SafeUUID/__module__.__eq__('uuid')==True / __module__.__len__()==4 / __doc__.__eq__('An enumeration.')==True / __doc__.__len__()==15 / safe.name.__eq__('safe')==True / unsafe.name.__eq__('unsafe')==True — SafeUUID is defined in Lib/uuid.py; __doc__ is the default Enum subclass docstring 'An enumeration.' (15 chars); .name attribute reflects the enum member's identifier; no prior uuid spec anchors these together; first uuidsafe130 anchor"
  kind: python_call_eq
  category: enum_attributes
  id_prefix: uuidsafe130

  columns: [id, function, args, expected, description]
  rows:
    - [module_eq,       SafeUUID.__module__.__eq__,        ["uuid"],              true, "SafeUUID.__module__ is 'uuid' (defined in Lib/uuid.py)"]
    - [module_len,      SafeUUID.__module__.__len__,        [],                   4,    "SafeUUID.__module__.__len__() is 4 ('uuid' = 4 chars)"]
    - [doc_eq,          SafeUUID.__doc__.__eq__,            ["An enumeration."],  true, "SafeUUID.__doc__ is 'An enumeration.' (default Enum docstring, 15 chars)"]
    - [doc_len,         SafeUUID.__doc__.__len__,           [],                   15,   "SafeUUID.__doc__.__len__() is 15 ('An enumeration.' = 15 chars)"]
    - [safe_name_eq,    SafeUUID.safe.name.__eq__,          ["safe"],             true, "SafeUUID.safe.name is 'safe' (the enum member's Python identifier)"]
    - [unsafe_name_eq,  SafeUUID.unsafe.name.__eq__,        ["unsafe"],           true, "SafeUUID.unsafe.name is 'unsafe' (the enum member's Python identifier)"]

# ---------------------------------------------------------------------------
# uuid.__spec__.__class__.__name__.__eq__('ModuleSpec')
# uuid.__spec__.name.__eq__('uuid')
# uuid.__spec__.name.__len__()==4
# uuid.__spec__.origin.__class__.__name__.__eq__('str')
# uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Wave 282 theme: uuid.__spec__ and __loader__ attribute identity.
#
# uuid.__spec__ is a ModuleSpec object. Its name is 'uuid' (4 chars). Its origin
# is the path to uuid.py as a str. The loader is a SourceFileLoader instance.
# No prior uuid spec anchors __spec__.__class__.__name__, __spec__.name equality,
# or __loader__.__class__.__name__ under uuidsafe130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra130.spec_and_loader_identity:
  description: "uuid.__spec__/__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('uuid')==True / __spec__.name.__len__()==4 / __spec__.origin/__class__.__name__.__eq__('str')==True / __loader__/__class__.__name__.__eq__('SourceFileLoader')==True — uuid.__spec__ is a ModuleSpec; name is 'uuid' (4 chars); origin is the file path as a str; loader is SourceFileLoader; no prior uuid spec anchors these; first uuidsafe130 anchor for spec/loader values"
  kind: python_call_eq
  category: module_spec
  id_prefix: uuidsafe130

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name,        __spec__.__class__.__name__.__eq__,        ["ModuleSpec"],        true, "uuid.__spec__ is a ModuleSpec (importlib.machinery.ModuleSpec)"]
    - [spec_name_eq,           __spec__.name.__eq__,                      ["uuid"],              true, "uuid.__spec__.name is 'uuid' (matches uuid.__name__)"]
    - [spec_name_len,          __spec__.name.__len__,                     [],                    4,    "uuid.__spec__.name.__len__() is 4 ('uuid' = 4 chars)"]
    - [spec_origin_class_name, __spec__.origin.__class__.__name__.__eq__, ["str"],               true, "uuid.__spec__.origin is a str (path to Lib/uuid.py)"]
    - [loader_class_name,      __loader__.__class__.__name__.__eq__,      ["SourceFileLoader"],  true, "uuid.__loader__ is a SourceFileLoader (loads uuid from Lib/uuid.py)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__.__len__()==3 — standalone
#
# uuid.SafeUUID.__mro__.__len__() is 3. The MRO for SafeUUID is [SafeUUID, Enum,
# object]. This shorter MRO (3 entries) contrasts with IntEnum subclasses, which
# include int in the chain and typically have longer MROs. SafeUUID's plain Enum
# inheritance means there is no additional numeric base class between Enum and
# object. uuid_extra94 anchors MRO depth at table level; this spec anchors it as
# a standalone under uuidsafe130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra130.SafeUUID_mro_len_3:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — MRO is [SafeUUID, Enum, object]; shorter than IntEnum subclasses (which include int in the chain); SafeUUID uses plain Enum inheritance with no numeric base between Enum and object; extra94 anchors this at table level; first standalone for SafeUUID.__mro__.__len__() under uuidsafe130"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__mro__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType') — standalone
#
# uuid.SafeUUID.__class__.__name__ is 'EnumType'. EnumType is the metaclass for
# all Enum subclasses in Python 3.11+; it was previously called EnumMeta.
# This means SafeUUID is an instance of EnumType (its metaclass), not of plain
# 'type'. uuid_extra94 anchors SafeUUID metaclass at table level under a prior
# prefix; no prior uuid spec anchors SafeUUID.__class__.__name__.__eq__('EnumType')
# as a standalone under uuidsafe130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra130.SafeUUID_class_EnumType:
  description: "uuid.SafeUUID.__class__.__name__.__eq__('EnumType') == True — SafeUUID's metaclass is EnumType (Python 3.11+ name for EnumMeta); SafeUUID is an instance of EnumType (not plain 'type'); extra94 anchors this at table level; first standalone under uuidsafe130"
  category: type_identity
  kind: python_call_eq
  function: SafeUUID.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__doc__.__eq__('An enumeration.') — standalone
#
# uuid.SafeUUID.__doc__ is 'An enumeration.'. This is the default docstring
# generated for Enum subclasses that do not define their own docstring. It is
# 15 chars. The docstring is injected by the EnumType metaclass during class
# creation. No prior uuid spec anchors SafeUUID.__doc__.__eq__('An enumeration.')
# as a standalone under uuidsafe130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra130.SafeUUID_doc_eq:
  description: "uuid.SafeUUID.__doc__.__eq__('An enumeration.') == True — default Enum subclass docstring injected by EnumType metaclass; 15 chars; no prior uuid spec anchors SafeUUID.__doc__ equality as a standalone; first standalone under uuidsafe130"
  category: enum_attributes
  kind: python_call_eq
  function: SafeUUID.__doc__.__eq__
  args: ["An enumeration."]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# uuid.__spec__.__class__.__name__ is 'ModuleSpec'. The ModuleSpec class
# (importlib.machinery.ModuleSpec) stores the module's import metadata including
# name, loader, origin, and submodule_search_locations. No prior uuid spec
# anchors __spec__.__class__.__name__.__eq__('ModuleSpec') as a standalone
# under uuidsafe130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra130.spec_class_ModuleSpec:
  description: "uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — uuid.__spec__ is a ModuleSpec from importlib.machinery; stores import metadata (name, loader, origin, submodule_search_locations); no prior uuid spec anchors this as a standalone; first standalone for __spec__.__class__.__name__ under uuidsafe130"
  category: module_spec
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# uuid.__loader__.__class__.__name__ is 'SourceFileLoader'. The SourceFileLoader
# is the standard loader for pure-Python .py files. uuid is a pure-Python module
# (Lib/uuid.py), so it uses SourceFileLoader rather than ExtensionFileLoader
# (for C extensions) or BuiltinImporter (for built-in modules). No prior uuid
# spec anchors __loader__.__class__.__name__.__eq__('SourceFileLoader') as a
# standalone under uuidsafe130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra130.loader_class_SourceFileLoader:
  description: "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — uuid is a pure-Python module (Lib/uuid.py) so it uses SourceFileLoader (not ExtensionFileLoader or BuiltinImporter); no prior uuid spec anchors __loader__.__class__.__name__ as a standalone; first standalone under uuidsafe130"
  category: module_spec
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
