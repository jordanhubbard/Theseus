spec: textwrap_extra2
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec covers textwrap invariants not already in textwrap.zspec.zsdl or textwrap_extra.zspec.zsdl."
    - "TextWrapper.__name__ == 'TextWrapper' and TextWrapper.__module__ == 'textwrap' — already in textwrap_extra; this spec adds qualname, class type, and function qualname checks."
    - "fill.__name__ == 'fill', indent.__name__ == 'indent', dedent.__name__ == 'dedent', shorten.__name__ == 'shorten' — already covered; this spec adds __qualname__ checks."
    - "TextWrapper is a plain Python class (type), not a C extension type."
    - "TextWrapper.width default is 70: verified via TextWrapper.__init__.__defaults__ (first positional default)."
    - "TextWrapper.break_long_words default is True: part of the keyword-only defaults tuple."
    - "fill and indent are module-level functions; __qualname__ == __name__ for module-level definitions."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper — class identity (name, module, qualname, type)
# ---------------------------------------------------------------------------

invariant textwrap_extra2.TextWrapper.name:
  description: "TextWrapper.__name__ == 'TextWrapper'"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__name__.__eq__
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra2.TextWrapper.module:
  description: "TextWrapper.__module__ == 'textwrap'"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra2.TextWrapper.qualname:
  description: "TextWrapper.__qualname__ == 'TextWrapper' — module-level class has flat qualname"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__qualname__.__eq__
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra2.TextWrapper.is_type:
  description: "TextWrapper.__class__.__name__ == 'type' — TextWrapper is a plain Python class"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks — fill, indent, dedent, shorten
# ---------------------------------------------------------------------------

table textwrap_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [fill,    fill.__name__.__eq__,    ["fill"],    true]
    - [indent,  indent.__name__.__eq__,  ["indent"],  true]
    - [dedent,  dedent.__name__.__eq__,  ["dedent"],  true]
    - [shorten, shorten.__name__.__eq__, ["shorten"], true]

# ---------------------------------------------------------------------------
# Function __qualname__ checks — module-level functions have flat qualnames
# ---------------------------------------------------------------------------

table textwrap_extra2.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [fill,    fill.__qualname__.__eq__,    ["fill"],    true]
    - [indent,  indent.__qualname__.__eq__,  ["indent"],  true]
    - [dedent,  dedent.__qualname__.__eq__,  ["dedent"],  true]
    - [shorten, shorten.__qualname__.__eq__, ["shorten"], true]

# ---------------------------------------------------------------------------
# Function __module__ checks — all belong to textwrap
# ---------------------------------------------------------------------------

table textwrap_extra2.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [fill,    fill.__module__.__eq__,    ["textwrap"], true]
    - [indent,  indent.__module__.__eq__,  ["textwrap"], true]
    - [dedent,  dedent.__module__.__eq__,  ["textwrap"], true]
    - [shorten, shorten.__module__.__eq__, ["textwrap"], true]

# ---------------------------------------------------------------------------
# TextWrapper.width default is 70
# TextWrapper.__init__ positional defaults: (width=70, ...) — first default
# ---------------------------------------------------------------------------

invariant textwrap_extra2.TextWrapper.width_default:
  description: "TextWrapper().width == 70 — default width is 70 when no argument is supplied"
  category: defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: width
  expected: 70

# ---------------------------------------------------------------------------
# TextWrapper.break_long_words default is True
# ---------------------------------------------------------------------------

invariant textwrap_extra2.TextWrapper.break_long_words_default:
  description: "TextWrapper().break_long_words == True — break_long_words defaults to True"
  category: defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: break_long_words
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper — constructor respects width keyword argument
# (distinct from the default=70 check above; verifies kwarg plumbing)
# ---------------------------------------------------------------------------

invariant textwrap_extra2.TextWrapper.custom_width:
  description: "TextWrapper(width=120).width == 120 — constructor stores explicit width"
  category: defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 120}
  method: width
  expected: 120

# ---------------------------------------------------------------------------
# fill() — return type is str
# ---------------------------------------------------------------------------

invariant textwrap_extra2.fill.returns_str:
  description: "fill('hello world', 80).__class__.__name__ == 'str' — fill always returns a str"
  category: fill
  kind: python_call_eq
  function: fill("hello world", 80).__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# dedent() — return type is str
# ---------------------------------------------------------------------------

invariant textwrap_extra2.dedent.returns_str:
  description: "dedent('hello').__class__.__name__ == 'str' — dedent always returns a str"
  category: dedent
  kind: python_call_eq
  function: dedent("hello").__class__.__name__.__eq__
  args: ["str"]
  expected: true
