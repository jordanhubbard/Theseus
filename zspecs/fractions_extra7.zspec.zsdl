spec: fractions_extra7
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra6)."
    - "fractions_extra6 covers: MRO[0]=Fraction, MRO[3]=Complex, MRO len=6; __float__; __floor__/__ceil__/__round__; __bool__; __ge__/__ne__; __pow__."
    - "No prior spec covers MRO[4].__name__ (Number) or MRO[5].__name__ (object) by __name__.__eq__ style."
    - "No prior spec covers __trunc__."
    - "No prior spec covers __mod__ (modulo of two Fractions)."
    - "No prior spec covers __pos__ (unary plus, identity)."
    - "No prior spec covers Fraction from string '3/7' — numerator and denominator."
    - "No prior spec covers limit_denominator with n != 10 (fractions.zspec has limit_denominator; extra2 has alt vectors)."
    - "No prior spec covers as_integer_ratio()."
    - "fractions.Fraction.__mro__[4].__name__ == 'Number' — fifth MRO entry is numbers.Number."
    - "fractions.Fraction.__mro__[5].__name__ == 'object' — sixth MRO entry is object."
    - "Fraction(7, 3).__trunc__() == 2 — truncate toward zero."
    - "Fraction(-7, 3).__trunc__() == -2 — truncate toward zero for negative."
    - "Fraction(7, 3).__mod__(Fraction(1, 1)).__str__() == '1/3' — 7/3 mod 1 == 1/3."
    - "Fraction(3, 4).__pos__().__str__() == '3/4' — unary plus is identity."
    - "Fraction('3/7').numerator == 3 — parse from string."
    - "Fraction('3/7').denominator == 7 — parse from string."
    - "Fraction(1, 3).limit_denominator(2).__str__() == '1/2' — best approximation with denom <= 2."
    - "Fraction(1, 3).as_integer_ratio() == (1, 3) — returns (numerator, denominator) tuple."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO[4] and MRO[5] — remaining entries
#
# fractions_extra2 covers MRO[1]=Rational; fractions_extra5 covers MRO[2]=Real;
# fractions_extra6 covers MRO[0]=Fraction and MRO[3]=Complex.
# New here: MRO[4]=Number and MRO[5]=object.
# ---------------------------------------------------------------------------

invariant fractions_extra7.Fraction.mro_4_number:
  description: "fractions.Fraction.__mro__[4].__name__ == 'Number' — fifth MRO entry is numbers.Number"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "Number"

invariant fractions_extra7.Fraction.mro_5_object:
  description: "fractions.Fraction.__mro__[5].__name__ == 'object' — sixth MRO entry is object"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__mro__.__getitem__
  args: [5]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# __trunc__ — truncate toward zero (numeric tower integration)
#
# fractions_extra6 covers __floor__, __ceil__, __round__. No prior spec covers
# __trunc__. For positive fractions, __trunc__ matches __floor__; for negative,
# it matches __ceil__.
# ---------------------------------------------------------------------------

invariant fractions_extra7.Fraction.trunc_positive:
  description: "Fraction(7, 3).__trunc__() == 2 — truncate 7/3 toward zero"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [7, 3]
  method: __trunc__
  expected: 2

invariant fractions_extra7.Fraction.trunc_negative:
  description: "Fraction(-7, 3).__trunc__() == -2 — truncate -7/3 toward zero (not -3)"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [-7, 3]
  method: __trunc__
  expected: -2

# ---------------------------------------------------------------------------
# __mod__ — modulo of two Fraction values
#
# No prior fractions spec covers __mod__.
# Fraction(7, 3) mod Fraction(1, 1): 7/3 = 2*1 + 1/3, so result is 1/3.
# ---------------------------------------------------------------------------

invariant fractions_extra7.Fraction.mod_whole:
  description: "Fraction(7, 3).__mod__(Fraction(1, 1)).__str__() == '1/3' — 7/3 mod 1 == 1/3"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [7, 3]
  method: __mod__
  method_args: [1]
  method_chain: __str__
  expected: "1/3"

# ---------------------------------------------------------------------------
# __pos__ — unary plus is identity
#
# No prior fractions spec covers __pos__. For any Fraction x, +x == x.
# ---------------------------------------------------------------------------

invariant fractions_extra7.Fraction.pos_identity:
  description: "Fraction(3, 4).__pos__().__str__() == '3/4' — unary plus returns an equal Fraction"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __pos__
  method_chain: __str__
  expected: "3/4"

# ---------------------------------------------------------------------------
# Fraction from string — numerator and denominator
#
# fractions_extra3 covers Fraction('3/5') numerator/denominator.
# New here: Fraction('3/7') — different string, different numerator/denominator.
# ---------------------------------------------------------------------------

invariant fractions_extra7.Fraction.from_str_numerator:
  description: "Fraction('3/7').numerator == 3 — parse from '3/7' string"
  category: constructor
  kind: python_call_eq
  function: Fraction
  args: ["3/7"]
  method: numerator
  expected: 3

invariant fractions_extra7.Fraction.from_str_denominator:
  description: "Fraction('3/7').denominator == 7 — parse from '3/7' string"
  category: constructor
  kind: python_call_eq
  function: Fraction
  args: ["3/7"]
  method: denominator
  expected: 7

# ---------------------------------------------------------------------------
# limit_denominator — best rational approximation
#
# fractions.zspec and fractions_extra2 cover limit_denominator with various
# inputs. New here: Fraction(1, 3).limit_denominator(2) == 1/2.
# The best approximation of 1/3 with denominator <= 2 is 1/2.
# ---------------------------------------------------------------------------

invariant fractions_extra7.Fraction.limit_denominator_two:
  description: "Fraction(1, 3).limit_denominator(2).__str__() == '1/2' — best approx of 1/3 with denom <= 2"
  category: limit_denominator
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: limit_denominator
  method_args: [2]
  method_chain: __str__
  expected: "1/2"

# ---------------------------------------------------------------------------
# as_integer_ratio — returns (numerator, denominator) as a tuple
#
# No prior fractions spec covers as_integer_ratio().
# Fraction(1, 3).as_integer_ratio() == (1, 3).
# ---------------------------------------------------------------------------

invariant fractions_extra7.Fraction.as_integer_ratio:
  description: "Fraction(1, 3).as_integer_ratio() == (1, 3) — returns (numerator, denominator)"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: as_integer_ratio
  expected: [1, 3]
