spec: datetime_extra17
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime_extra4.zspec.zsdl — covers __qualname__ table for datetime/date/time/timedelta/timezone/tzinfo classes"
    - "datetime_extra12.zspec.zsdl — covers __qualname__ for all six classes as standalone invariants; __module__ table"
    - "datetime_extra15.zspec.zsdl — covers MINYEAR/MAXYEAR __class__.__qualname__; resolution __class__.__name__ table; six-class __qualname__ table"
    - "datetime_extra16.zspec.zsdl — covers __qualname__ for date/datetime method descriptors (today, fromisoformat, strftime, isoformat, now, strptime); time.isoformat; timedelta.__qualname__"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra16.zspec.zsdl."
    - "NEW in extra17 — Axis 1: __qualname__ for dunder operator methods on date (__add__, __sub__, __eq__, __hash__) — dotted qualnames such as 'date.__add__'."
    - "NEW in extra17 — Axis 2: __qualname__ for dunder operator methods on datetime (__add__, __sub__) — dotted qualnames such as 'datetime.__add__'."
    - "NEW in extra17 — Axis 3: __qualname__ for dunder operator methods on timedelta (__add__, __mul__) — dotted qualnames such as 'timedelta.__add__'."
    - "NEW in extra17 — Axis 4: datetime.timezone.__qualname__ == 'timezone' as standalone extra17-namespace invariant."
    - "datetime.date.__add__.__qualname__ == 'date.__add__' — verified Python 3.12."
    - "datetime.date.__sub__.__qualname__ == 'date.__sub__' — verified Python 3.12."
    - "datetime.date.__eq__.__qualname__ == 'date.__eq__' — verified Python 3.12."
    - "datetime.date.__hash__.__qualname__ == 'date.__hash__' — verified Python 3.12."
    - "datetime.datetime.__add__.__qualname__ == 'datetime.__add__' — verified Python 3.12."
    - "datetime.datetime.__sub__.__qualname__ == 'datetime.__sub__' — verified Python 3.12."
    - "datetime.timedelta.__add__.__qualname__ == 'timedelta.__add__' — verified Python 3.12."
    - "datetime.timedelta.__mul__.__qualname__ == 'timedelta.__mul__' — verified Python 3.12."
    - "datetime.timezone.__qualname__ == 'timezone' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# date dunder operator method __qualname__ values
#
# Prior specs cover __qualname__ for class-level names (date, datetime, etc.)
# and method descriptors like today/fromisoformat/strftime. No prior spec
# checks the __qualname__ of dunder operator methods on date, which are dotted
# strings such as 'date.__add__'.
# ---------------------------------------------------------------------------

table datetime_extra17.date_dunder_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [add,    "date.__add__.__qualname__.__eq__",    ["date.__add__"],    true]
    - [sub,    "date.__sub__.__qualname__.__eq__",    ["date.__sub__"],    true]
    - [eq,     "date.__eq__.__qualname__.__eq__",     ["date.__eq__"],     true]
    - [hash,   "date.__hash__.__qualname__.__eq__",   ["date.__hash__"],   true]

# ---------------------------------------------------------------------------
# datetime dunder operator method __qualname__ values
#
# No prior spec checks the __qualname__ of __add__ or __sub__ on the datetime
# class. These have dotted qualnames ('datetime.__add__', 'datetime.__sub__').
# ---------------------------------------------------------------------------

table datetime_extra17.datetime_dunder_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [add,    "datetime.__add__.__qualname__.__eq__",    ["datetime.__add__"],    true]
    - [sub,    "datetime.__sub__.__qualname__.__eq__",    ["datetime.__sub__"],    true]

# ---------------------------------------------------------------------------
# timedelta dunder operator method __qualname__ values
#
# No prior spec checks the __qualname__ of __add__ or __mul__ on timedelta.
# Both have dotted qualnames ('timedelta.__add__', 'timedelta.__mul__').
# ---------------------------------------------------------------------------

table datetime_extra17.timedelta_dunder_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [add,    "timedelta.__add__.__qualname__.__eq__",    ["timedelta.__add__"],    true]
    - [mul,    "timedelta.__mul__.__qualname__.__eq__",    ["timedelta.__mul__"],    true]

# ---------------------------------------------------------------------------
# timezone.__qualname__ — standalone extra17-namespace invariant
#
# datetime_extra4, extra12, and extra15 cover timezone.__qualname__ in tables.
# Re-anchored here as a standalone invariant in the extra17 namespace for
# systematic chain continuity alongside the novel dunder-method axes.
# ---------------------------------------------------------------------------

invariant datetime_extra17.timezone.qualname:
  description: "datetime.timezone.__qualname__ == 'timezone' — flat class qualname"
  category: class_qualnames
  kind: python_call_eq
  function: timezone.__qualname__.__eq__
  args: ["timezone"]
  expected: true
