spec: functools_extra238
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.partial __class__ and __doc__ contracts."
    - "functools.partial.__class__.__name__ == 'type' — partial is a C extension type; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object with no intermediate base. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — the docstring of partial is a plain Python str. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__contains__('partial') == True — the docstring references the word 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — partial is registered to the functools module. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' (len=7) — the class __name__ is 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial' — top-level class with unqualified qualname. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial __class__ contracts
#
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__module__ == 'functools'
# functools.partial.__name__ == 'partial' (len=7)
# functools.partial.__qualname__ == 'partial'
#
# partial is a C extension type whose metaclass is the built-in type and whose
# sole base class is object. New to extra238.
# ---------------------------------------------------------------------------

table functools_extra238.partial_class_contracts:
  description: "functools.partial __class__ contracts: metaclass is type, base is object, module and name identity; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra238classid

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_is_type,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type whose metaclass is the built-in type; __class__.__name__ is 'type'; new to extra238"]
    - [partial_base_is_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra238"]
    - [partial_module_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is registered to the functools module; __module__ is 'functools' (len=9); new to extra238"]
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C extension type for partial function application; __name__ is 'partial' (len=7); new to extra238"]
    - [partial_name_len_7,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — 'partial' has exactly 7 characters (p-a-r-t-i-a-l); str.__len__() returns 7; new to extra238"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial __doc__ contracts
#
# functools.partial.__doc__.__class__.__name__ == 'str'
# functools.partial.__doc__.__contains__('partial') == True
# functools.partial.__doc__.__len__() == 83
# functools.partial.__qualname__ == 'partial'
# functools.partial.__module__.__len__() == 9
#
# The docstring of partial is a plain Python str referencing the word 'partial'.
# New to extra238.
# ---------------------------------------------------------------------------

table functools_extra238.partial_doc_contracts:
  description: "functools.partial __doc__ contracts: docstring type is str, contains 'partial', module len=9; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra238docid

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_is_str,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — the docstring of partial is a plain Python str object; __class__.__name__ is 'str'; new to extra238"]
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — the docstring of partial contains the word 'partial'; str.__contains__('partial') returns True; new to extra238"]
    - [partial_doc_len_83,
       partial.__doc__.__len__,
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — the docstring 'Create a new function with partial application of the given arguments\\nand keywords.' has exactly 83 characters; new to extra238"]
    - [partial_qualname_eq,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a top-level class with unqualified qualname 'partial'; str.__eq__('partial') returns True; new to extra238"]
    - [partial_module_len_9,
       partial.__module__.__len__,
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — 'functools' has exactly 9 characters (f-u-n-c-t-o-o-l-s); str.__len__() returns 9; new to extra238"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra238
# ---------------------------------------------------------------------------

invariant functools_extra238.partial_class_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C extension type; new to extra238"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra238.partial_base_is_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits from object; new to extra238"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra238.partial_module_eq:
  description: "functools.partial.__module__ == 'functools'; new to extra238"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra238.partial_name_eq:
  description: "functools.partial.__name__ == 'partial' (len=7); new to extra238"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra238.partial_name_len_7:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; new to extra238"
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra238.partial_doc_class_is_str:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — docstring is a plain str; new to extra238"
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra238.partial_doc_contains_partial:
  description: "functools.partial.__doc__.__contains__('partial') == True — docstring contains 'partial'; new to extra238"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra238.partial_doc_len_83:
  description: "functools.partial.__doc__.__len__() == 83 — docstring has 83 characters; new to extra238"
  kind: python_call_eq
  function: partial.__doc__.__len__
  args: []
  expected: 83

invariant functools_extra238.partial_qualname_eq:
  description: "functools.partial.__qualname__ == 'partial' — unqualified top-level class qualname; new to extra238"
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra238.partial_module_len_9:
  description: "functools.partial.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra238"
  kind: python_call_eq
  function: partial.__module__.__len__
  args: []
  expected: 9
