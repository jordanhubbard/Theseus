spec: collections_extra29
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra28.zspec.zsdl."
    - "collections_extra28 covers: OrderedDict/ChainMap qualnames and modules; UserDict/UserList/UserString qualnames, bases, and method qualnames."
    - "collections_extra27 covers: deque.pop/popleft/extend method qualnames; defaultdict.__missing__ qualname."
    - "collections_extra26 covers: OrderedDict.__setitem__/move_to_end; Counter.update/most_common; deque.append/appendleft/rotate; ChainMap.new_child method qualnames."
    - "No prior collections spec records __qualname__/__module__ for deque/Counter/defaultdict/namedtuple as a group, or __bases__[0].__name__ for deque/Counter/defaultdict/OrderedDict together in the extra29 namespace."
    - "Focus: class __qualname__ and __module__ for deque/Counter/defaultdict/namedtuple; __bases__[0].__name__ for deque/Counter/defaultdict/OrderedDict."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — deque, Counter, defaultdict, namedtuple class qualnames
#
# deque and defaultdict are C-level types defined in Modules/_collectionsmodule.c;
# Counter and namedtuple are Python-level classes in Lib/collections/__init__.py.
# All four have simple qualnames equal to their class/function names, confirming
# they are defined at module scope (non-nested).
# No prior collections spec records all four qualnames together in the extra29
# namespace.
# ---------------------------------------------------------------------------

table collections_extra29.core_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra29.core_qualnames.deque,
       deque.__qualname__.__eq__,
       ["deque"],
       true,
       "collections.deque.__qualname__ == 'deque'"]
    - [collections_extra29.core_qualnames.counter,
       Counter.__qualname__.__eq__,
       ["Counter"],
       true,
       "collections.Counter.__qualname__ == 'Counter'"]
    - [collections_extra29.core_qualnames.defaultdict,
       defaultdict.__qualname__.__eq__,
       ["defaultdict"],
       true,
       "collections.defaultdict.__qualname__ == 'defaultdict'"]
    - [collections_extra29.core_qualnames.namedtuple,
       namedtuple.__qualname__.__eq__,
       ["namedtuple"],
       true,
       "collections.namedtuple.__qualname__ == 'namedtuple'"]

# ---------------------------------------------------------------------------
# __module__.__eq__ table — deque, Counter, defaultdict, namedtuple module membership
#
# Despite deque and defaultdict being C-level types implemented in
# Modules/_collectionsmodule.c, their __module__ attribute is 'collections',
# the public module name. Counter and namedtuple, being Python-level, also
# report 'collections'. This confirms all four are attributed to the public
# namespace.
# No prior collections spec records all four __module__ values together in
# the extra29 namespace.
# ---------------------------------------------------------------------------

table collections_extra29.core_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra29.core_modules.deque,
       deque.__module__.__eq__,
       ["collections"],
       true,
       "collections.deque.__module__ == 'collections'"]
    - [collections_extra29.core_modules.counter,
       Counter.__module__.__eq__,
       ["collections"],
       true,
       "collections.Counter.__module__ == 'collections'"]
    - [collections_extra29.core_modules.defaultdict,
       defaultdict.__module__.__eq__,
       ["collections"],
       true,
       "collections.defaultdict.__module__ == 'collections'"]
    - [collections_extra29.core_modules.namedtuple,
       namedtuple.__module__.__eq__,
       ["collections"],
       true,
       "collections.namedtuple.__module__ == 'collections'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — base classes for deque, Counter, defaultdict, OrderedDict
#
# deque is a C-level type that inherits directly from object. Counter and
# defaultdict both inherit from dict (Counter is a dict subclass; defaultdict
# is a C-level dict subclass). OrderedDict is a Python-level dict subclass.
# No prior collections spec records all four __bases__[0].__name__ values
# together in the extra29 namespace.
# ---------------------------------------------------------------------------

table collections_extra29.core_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra29.core_bases.deque,
       "deque.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "collections.deque.__bases__[0].__name__ == 'object'"]
    - [collections_extra29.core_bases.counter,
       "Counter.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.Counter.__bases__[0].__name__ == 'dict'"]
    - [collections_extra29.core_bases.defaultdict,
       "defaultdict.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.defaultdict.__bases__[0].__name__ == 'dict'"]
    - [collections_extra29.core_bases.ordereddict,
       "OrderedDict.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.OrderedDict.__bases__[0].__name__ == 'dict'"]

# ---------------------------------------------------------------------------
# deque.__qualname__.__eq__ — standalone class qualname
#
# collections.deque is a C-level type defined at module scope. Its qualname is
# 'deque', equal to its __name__, confirming it is not nested inside any other
# class or function.
# No prior collections spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra29.deque.qualname:
  description: "collections.deque.__qualname__ == 'deque'"
  category: qualnames
  kind: python_call_eq
  function: deque.__qualname__.__eq__
  args: ["deque"]
  expected: true

# ---------------------------------------------------------------------------
# deque.__module__.__eq__ — standalone module membership
#
# collections.deque is a C-level type. Despite its C implementation, its
# __module__ is 'collections', the public module name. This confirms the type
# is attributed to the public collections namespace rather than any private
# C extension module.
# No prior collections spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra29.deque.module:
  description: "collections.deque.__module__ == 'collections'"
  category: module_membership
  kind: python_call_eq
  function: deque.__module__.__eq__
  args: ["collections"]
  expected: true

# ---------------------------------------------------------------------------
# Counter.__bases__[0].__name__.__eq__ — standalone inheritance
#
# collections.Counter inherits from dict. This is the primary base class that
# gives Counter its mapping interface; Counter adds multiset counting semantics
# on top.
# No prior collections spec records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra29.Counter.base:
  description: "collections.Counter.__bases__[0].__name__ == 'dict'"
  category: inheritance
  kind: python_call_eq
  function: "Counter.__bases__[0].__name__.__eq__"
  args: ["dict"]
  expected: true
