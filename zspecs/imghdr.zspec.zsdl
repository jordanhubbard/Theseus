spec: imghdr
version: ">=3.3,<3.13"
backend: python_module(imghdr)

docs: https://docs.python.org/3/library/imghdr.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/imghdr.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "imghdr source: Lib/imghdr.py (PSF; source inspection permitted)"
  not_derived_from:
    - "Image format binary specifications beyond what is publicly documented"
  notes:
    - "The imghdr module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec applies to Python >=3.3,<3.13 only."
    - "imghdr.what(file, h=None) identifies the image type of a file or byte stream; returns a string such as 'png', 'jpeg', or None."
    - "imghdr.tests is a list of test functions registered to identify image formats."
    - "imghdr.what(b'') returns None — empty bytes are not a recognised image format."
    - "imghdr.what() accepts a filename string, a file-like object, or raw bytes via the h keyword argument."
    - "Recognised type strings include: 'rgb', 'gif', 'pbm', 'pgm', 'ppm', 'tiff', 'rast', 'xbm', 'jpeg', 'bmp', 'png', 'webp', 'exr'."
    - "All expected values verified by inspecting imghdr module on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "imghdr.what() returns None when the image type cannot be determined; it does not raise on unrecognised data. OSError may be raised when given a bad file path."
  stderr: "null"
  stickiness: "N/A — all functions are stateless with respect to module-level state (imghdr.tests may be extended at runtime but is not modified by these invariants)."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant imghdr.what_name:
  description: "imghdr.what.__name__ == 'what'"
  category: functions
  kind: python_call_eq
  function: what.__name__.__eq__
  args: ["what"]
  expected: true

invariant imghdr.what_module:
  description: "imghdr.what.__module__ == 'imghdr'"
  category: functions
  kind: python_call_eq
  function: what.__module__.__eq__
  args: ["imghdr"]
  expected: true

invariant imghdr.test_name:
  description: "imghdr.test.__name__ == 'test'"
  category: functions
  kind: python_call_eq
  function: test.__name__.__eq__
  args: ["test"]
  expected: true

invariant imghdr.testall_name:
  description: "imghdr.testall.__name__ == 'testall'"
  category: functions
  kind: python_call_eq
  function: testall.__name__.__eq__
  args: ["testall"]
  expected: true

# ---------------------------------------------------------------------------
# imghdr.tests list checks
# ---------------------------------------------------------------------------

invariant imghdr.tests_is_list:
  description: "imghdr.tests is a list"
  category: tests_registry
  kind: python_call_eq
  function: tests.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant imghdr.tests_nonempty:
  description: "len(imghdr.tests) > 0 — at least one image-type test function is registered"
  category: tests_registry
  kind: python_call_eq
  function: tests.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# what() behavioral checks
# ---------------------------------------------------------------------------

invariant imghdr.what_empty_bytes_none:
  description: "imghdr.what(None, h=b'') is None — empty bytes is not a recognised image"
  category: behavior
  kind: python_call_eq
  function: what
  args: [null]
  kwargs:
    h: !hex ""
  expected: null

invariant imghdr.what_png_header:
  description: "imghdr.what(None, h=<PNG magic bytes>) == 'png'"
  category: behavior
  kind: python_call_eq
  function: what
  args: [null]
  kwargs:
    h: !hex "89504e470d0a1a0a"
  expected: "png"

invariant imghdr.what_jpeg_header:
  description: "imghdr.what(None, h=<JPEG magic bytes>) == 'jpeg'"
  category: behavior
  kind: python_call_eq
  function: what
  args: [null]
  kwargs:
    h: !hex "ffd8ffe0"
  expected: "jpeg"

invariant imghdr.what_gif_header:
  description: "imghdr.what(None, h=<GIF89a magic bytes>) == 'gif'"
  category: behavior
  kind: python_call_eq
  function: what
  args: [null]
  kwargs:
    h: !ascii "GIF89a"
  expected: "gif"
