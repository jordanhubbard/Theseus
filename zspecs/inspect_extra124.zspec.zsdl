spec: inspect_extra124
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra123.zspec.zsdl."
    - "This spec covers: inspect.signature, inspect.getmembers, inspect.getattr_static, and inspect.getsource function __code__.co_varnames elements not previously covered; wave 275."
    - "inspect.signature.__code__.co_varnames[0] == 'obj' (len 3). Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_varnames.__len__() == 6. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_name == 'signature' (len 9). Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_varnames[0] == 'object' (len 6). Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_varnames[1] == 'predicate' (len 9). Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_varnames.__len__() == 2. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_varnames[0] == 'obj' (len 3). Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_varnames[1] == 'attr' (len 4). Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_varnames[2] == 'default' (len 7). Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_varnames.__len__() == 9. Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_varnames[0] == 'object' (len 6). Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_varnames.__len__() == 3. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_name == 'getsource' (len 9). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.signature __code__.co_varnames[0] and code attrs
#
# Wave 275 theme: inspect.signature(obj, ...) is a pure-Python function in
# Lib/inspect.py. Its co_varnames has 6 entries:
#   co_varnames[0] == 'obj'               (3 chars) — the callable to inspect
#   co_varnames[1] == 'follow_wrapped'    (14 chars) — keyword-only param
#   co_varnames[2] == 'globals'           (7 chars)  — keyword-only param
#   co_varnames[3] == 'locals'            (6 chars)  — keyword-only param
#   co_varnames[4] == 'eval_str'          (8 chars)  — keyword-only param
#   co_varnames[5] == 'annotation_format'(17 chars)  — keyword-only param
# co_argcount == 1: only 'obj' is a positional arg; the others are keyword-only.
# co_name == 'signature' (9 chars). New to extra124.
# ---------------------------------------------------------------------------

table inspect_extra124.signature_co_varnames:
  description: "inspect.signature co_varnames[0]='obj'(3); co_varnames len=6; co_argcount=1 (only 'obj' is positional); co_name='signature'(9); co_freevars len=0; wave 275; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsigcv124

  columns: [id, function, args, expected, description]
  rows:
    - [sig_cv0_eq,
       "signature.__code__.co_varnames.__getitem__",
       [0],
       "obj",
       "inspect.signature.__code__.co_varnames[0] == 'obj' — the first positional parameter of signature(obj, ...); 'obj' is the callable to be inspected; shorter than the 'object' convention used in predicates (isfunction, isclass, etc.); tuple.__getitem__(0) returns 'obj'; new to extra124"]
    - [sig_cv0_len,
       "signature.__code__.co_varnames.__getitem__(0).__len__",
       [],
       3,
       "inspect.signature.__code__.co_varnames[0].__len__() == 3 — 'obj' has 3 chars: o-b-j; shorter than 'object' (6) used in inspect predicates; str.__len__() returns 3; new to extra124"]
    - [sig_cv_len,
       "signature.__code__.co_varnames.__len__",
       [],
       6,
       "inspect.signature.__code__.co_varnames.__len__() == 6 — 6 entries: 'obj', 'follow_wrapped', 'globals', 'locals', 'eval_str', 'annotation_format'; more params than simple predicates (len=1); tuple.__len__() returns 6; new to extra124"]
    - [sig_co_argcount_eq_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — only 'obj' is a positional argument; the remaining 5 entries in co_varnames (follow_wrapped, globals, locals, eval_str, annotation_format) are keyword-only params; int.__eq__(1) returns True; new to extra124"]
    - [sig_co_name_eq,
       "signature.__code__.co_name.__eq__",
       ["signature"],
       true,
       "inspect.signature.__code__.co_name.__eq__('signature') == True — co_name matches the def statement name in Lib/inspect.py; 'signature' has 9 chars; str.__eq__('signature') returns True; new to extra124"]
    - [sig_co_freevars_len_0,
       "signature.__code__.co_freevars.__len__",
       [],
       0,
       "inspect.signature.__code__.co_freevars.__len__() == 0 — inspect.signature is a module-level function with no enclosing scope; co_freevars is empty; tuple.__len__() returns 0; new to extra124"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers and inspect.getsource co_varnames
#
# Wave 275 theme: inspect.getmembers(object, predicate=None) is a pure-Python
# function returning all members of an object. Its co_varnames has 2 entries:
#   co_varnames[0] == 'object'     (6 chars) — the object to inspect
#   co_varnames[1] == 'predicate'  (9 chars) — optional filter predicate
# co_argcount == 2: both 'object' and 'predicate' are positional params.
#
# inspect.getsource(object) returns source lines. Its co_varnames has 3 entries:
#   co_varnames[0] == 'object'  (6 chars) — the object to get source for
#   co_varnames[1] == 'lines'   (5 chars) — internal local for source lines
#   co_varnames[2] == 'lnum'    (4 chars) — internal local for line number
# co_argcount == 1: only 'object' is a declared param.
#
# New to extra124.
# ---------------------------------------------------------------------------

table inspect_extra124.getmembers_getsource_co_varnames:
  description: "inspect.getmembers co_varnames[0]='object'(6), [1]='predicate'(9); len=2; co_argcount=2; inspect.getsource co_varnames[0]='object'(6); len=3; co_argcount=1; both use 'object' param name; wave 275; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgmgscv124

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_cv0_eq,
       "getmembers.__code__.co_varnames.__getitem__",
       [0],
       "object",
       "inspect.getmembers.__code__.co_varnames[0] == 'object' — first parameter of getmembers(object, predicate=None); the object whose members are to be listed; 'object' follows the inspect module predicate convention; tuple.__getitem__(0) returns 'object'; new to extra124"]
    - [getmembers_cv1_eq,
       "getmembers.__code__.co_varnames.__getitem__",
       [1],
       "predicate",
       "inspect.getmembers.__code__.co_varnames[1] == 'predicate' — optional filter function; getmembers returns only members for which predicate(value) is true; 'predicate' has 9 chars; tuple.__getitem__(1) returns 'predicate'; new to extra124"]
    - [getmembers_cv1_len,
       "getmembers.__code__.co_varnames.__getitem__(1).__len__",
       [],
       9,
       "inspect.getmembers.__code__.co_varnames[1].__len__() == 9 — 'predicate' has 9 chars: p-r-e-d-i-c-a-t-e; longer than co_varnames[0] 'object' (6); str.__len__() returns 9; new to extra124"]
    - [getmembers_cv_len,
       "getmembers.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getmembers.__code__.co_varnames.__len__() == 2 — getmembers has 2 local variable names: 'object' and 'predicate'; both are declared parameters; tuple.__len__() returns 2; new to extra124"]
    - [getsource_cv0_eq,
       "getsource.__code__.co_varnames.__getitem__",
       [0],
       "object",
       "inspect.getsource.__code__.co_varnames[0] == 'object' — the sole declared parameter of getsource(object); the function whose source is to be retrieved; same parameter name as getmembers co_varnames[0]; tuple.__getitem__(0) returns 'object'; new to extra124"]
    - [getsource_cv_len,
       "getsource.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.getsource.__code__.co_varnames.__len__() == 3 — getsource has 3 local variable names: 'object' (declared param), 'lines' (internal), 'lnum' (internal); more than getmembers (2) but co_argcount is only 1; tuple.__len__() returns 3; new to extra124"]
    - [getsource_co_argcount_eq_1,
       "getsource.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsource.__code__.co_argcount.__eq__(1) == True — getsource(object) has 1 positional declared parameter; 'lines' and 'lnum' in co_varnames are internal locals not declared params; int.__eq__(1) returns True; new to extra124"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getattr_static co_varnames elements and length
#
# Wave 275 theme: inspect.getattr_static(obj, attr, default=...) is a
# pure-Python function that retrieves an attribute without invoking descriptors.
# Its co_varnames has 9 entries:
#   co_varnames[0] == 'obj'             (3 chars) — the object to inspect
#   co_varnames[1] == 'attr'            (4 chars) — the attribute name to get
#   co_varnames[2] == 'default'         (7 chars) — optional default value
#   co_varnames[3] == 'instance_result' (15 chars) — internal local
#   co_varnames[4] == 'objtype'         (7 chars)  — internal local
#   co_varnames[5] == 'klass'           (5 chars)  — internal local
#   co_varnames[6] == 'dict_attr'       (9 chars)  — internal local
#   co_varnames[7] == 'klass_result'    (12 chars) — internal local
#   co_varnames[8] == 'entry'           (5 chars)  — internal local
# co_argcount == 3: 'obj', 'attr', 'default' are declared positional params.
# This is the most complex co_varnames among the four inspect functions here
# (len 9 vs signature's 6, getsource's 3, getmembers's 2).
# New to extra124.
# ---------------------------------------------------------------------------

table inspect_extra124.getattr_static_co_varnames:
  description: "inspect.getattr_static co_varnames[0]='obj'(3), [1]='attr'(4), [2]='default'(7); len=9; co_argcount=3; most complex co_varnames of the four functions here; wave 275; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgascv124

  columns: [id, function, args, expected, description]
  rows:
    - [gas_cv0_eq,
       "getattr_static.__code__.co_varnames.__getitem__",
       [0],
       "obj",
       "inspect.getattr_static.__code__.co_varnames[0] == 'obj' — first parameter of getattr_static(obj, attr, default=...); uses 'obj' (3 chars) rather than 'object' (6); same as inspect.signature co_varnames[0]; tuple.__getitem__(0) returns 'obj'; new to extra124"]
    - [gas_cv1_eq,
       "getattr_static.__code__.co_varnames.__getitem__",
       [1],
       "attr",
       "inspect.getattr_static.__code__.co_varnames[1] == 'attr' — the attribute name to retrieve statically; 'attr' has 4 chars; tuple.__getitem__(1) returns 'attr'; new to extra124"]
    - [gas_cv2_eq,
       "getattr_static.__code__.co_varnames.__getitem__",
       [2],
       "default",
       "inspect.getattr_static.__code__.co_varnames[2] == 'default' — optional third parameter providing a default if the attribute is not found; 'default' has 7 chars; tuple.__getitem__(2) returns 'default'; new to extra124"]
    - [gas_cv_len,
       "getattr_static.__code__.co_varnames.__len__",
       [],
       9,
       "inspect.getattr_static.__code__.co_varnames.__len__() == 9 — 9 entries: 'obj', 'attr', 'default' (3 declared params) + 6 internal locals; the most complex co_varnames among the four inspect functions covered here; tuple.__len__() returns 9; new to extra124"]
    - [gas_co_argcount_eq_3,
       "getattr_static.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.getattr_static.__code__.co_argcount.__eq__(3) == True — getattr_static(obj, attr, default=_sentinel) has 3 declared positional params; the remaining 6 co_varnames entries are internal locals; int.__eq__(3) returns True; new to extra124"]
    - [gas_co_name_eq,
       "getattr_static.__code__.co_name.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__code__.co_name.__eq__('getattr_static') == True — co_name is the function name as it appears in the def statement; 'getattr_static' has 14 chars; str.__eq__('getattr_static') returns True; new to extra124"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra124
# ---------------------------------------------------------------------------

invariant inspect_extra124.signature_cv0_obj:
  description: "inspect.signature.__code__.co_varnames[0] == 'obj' — first positional param; 3 chars; shorter than 'object' used in predicates; wave 275; new to extra124"
  kind: python_call_eq
  function: "signature.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "obj"

invariant inspect_extra124.signature_cv_len:
  description: "inspect.signature.__code__.co_varnames.__len__() == 6 — obj + 5 keyword-only params; co_argcount=1; wave 275; new to extra124"
  kind: python_call_eq
  function: "signature.__code__.co_varnames.__len__"
  args: []
  expected: 6

invariant inspect_extra124.getmembers_cv1_predicate:
  description: "inspect.getmembers.__code__.co_varnames[1] == 'predicate' — optional filter param; 9 chars; co_argcount=2; wave 275; new to extra124"
  kind: python_call_eq
  function: "getmembers.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "predicate"

invariant inspect_extra124.getattr_static_cv_len:
  description: "inspect.getattr_static.__code__.co_varnames.__len__() == 9 — 3 params + 6 locals; most complex co_varnames of the four functions; wave 275; new to extra124"
  kind: python_call_eq
  function: "getattr_static.__code__.co_varnames.__len__"
  args: []
  expected: 9

invariant inspect_extra124.getsource_cv0_object:
  description: "inspect.getsource.__code__.co_varnames[0] == 'object' — sole declared param; 6 chars; co_argcount=1; co_varnames len=3 (includes internal locals 'lines' and 'lnum'); wave 275; new to extra124"
  kind: python_call_eq
  function: "getsource.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "object"

