spec: struct_extra109
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra108.zspec.zsdl — covers module-level function __name__ lengths / struct.error __name__/__module__/__qualname__ equality and lengths / struct.Struct.__name__ equality / struct.error MRO structure (table + invariants)."
    - "struct_extra107.zspec.zsdl — covers Struct.size/format getset_descriptor qualname equality and __objclass__.__name__ / module-level calcsize/pack/unpack qualname equality / Struct.__doc__ type (table + invariants)."
    - "struct_extra106.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack qualname equality / Struct.__init__ qualname and wrapper_descriptor type / all five methods are method_descriptor (table + invariants)."
    - "struct_extra105.zspec.zsdl — covers struct.__spec__ attributes / struct.__name__ and __package__ equality and lengths / struct.error __init__/__str__ qualnames (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualnames and __objclass__ / module-level function qualname equality for all six functions (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers Struct.__qualname__.__len__()==6 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra108; it does NOT duplicate invariants present in those files."
    - "Wave 273 theme: Struct method_descriptor __objclass__.__name__ and __objclass__.__module__ equality (pack/unpack/pack_into/unpack_from/iter_unpack) / module-level function __name__ equality (not __qualname__ or length, but the string equality call) / Struct class __module__.__eq__ and __qualname__.__eq__."
    - "struct.Struct.pack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__name__.__eq__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__.__eq__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__.__eq__('calcsize') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__.__eq__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__.__eq__('_struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__.__eq__('Struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct method_descriptors (pack, unpack, pack_into, unpack_from, iter_unpack) have a __objclass__ attribute pointing back to the Struct C class. __objclass__.__name__ == 'Struct' and __objclass__.__module__ == '_struct' for all five. struct_extra107 anchors __objclass__ for getset_descriptors (size/format); this spec anchors __objclass__ for method_descriptors (pack/unpack/pack_into/unpack_from/iter_unpack) for the first time."
    - "Note: Module-level function __name__ equality (via __eq__ call) is distinct from __qualname__ equality (covered by struct_extra104/struct_extra107) and __name__ length (covered by struct_extra108). For C-level module functions, __name__ == __qualname__, so 'pack'.__eq__('pack') == True. This is the first spec to anchor __name__ equality as an __eq__ call for module-level struct functions."
    - "Note: struct.Struct.__module__.__eq__('_struct') and Struct.__qualname__.__eq__('Struct') are new anchors not present in previous specs. struct_extra95 anchors Struct.__qualname__.__len__()==6; struct_extra108 anchors Struct.__name__.__eq__('Struct'); this spec anchors Struct.__module__ and Struct.__qualname__ equality for the first time."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.unpack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.pack_into.__objclass__.__name__.__eq__('Struct')
# struct.Struct.unpack_from.__objclass__.__name__.__eq__('Struct')
# struct.Struct.iter_unpack.__objclass__.__name__.__eq__('Struct')
#
# Wave 273 theme: Struct method_descriptor __objclass__ class name equality.
#
# method_descriptor objects have a __objclass__ attribute pointing to the class
# they are defined on. For Struct methods, __objclass__ is the Struct C class
# itself. struct_extra107 anchors __objclass__.__name__ for getset_descriptors
# (Struct.size and Struct.format). This spec anchors __objclass__.__name__ for
# the five method_descriptor methods (pack, unpack, pack_into, unpack_from,
# iter_unpack) for the first time as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra109.Struct_method_objclass_name_equality:
  description: "Struct.pack.__objclass__.__name__.__eq__('Struct')==True / Struct.unpack.__objclass__.__name__.__eq__('Struct')==True / Struct.pack_into.__objclass__.__name__.__eq__('Struct')==True / Struct.unpack_from.__objclass__.__name__.__eq__('Struct')==True / Struct.iter_unpack.__objclass__.__name__.__eq__('Struct')==True — method_descriptors have __objclass__ pointing to the defining class; all five Struct methods share __objclass__.__name__=='Struct' (the C class from _struct.c); extra107 anchors __objclass__ for getset_descriptors (size/format); first structobj109 anchor for method_descriptor __objclass__"
  kind: python_call_eq
  category: method_identity
  id_prefix: structobj109

  columns: [id, function, args, expected, description]
  rows:
    - [pack_objclass_name,       "Struct.pack.__objclass__.__name__.__eq__",       ["Struct"], true, "Struct.pack.__objclass__.__name__ is 'Struct' (the C class from _struct.c; method_descriptor's defining class)"]
    - [unpack_objclass_name,     "Struct.unpack.__objclass__.__name__.__eq__",     ["Struct"], true, "Struct.unpack.__objclass__.__name__ is 'Struct' (same C class; all five method_descriptors share the same __objclass__)"]
    - [pack_into_objclass_name,  "Struct.pack_into.__objclass__.__name__.__eq__",  ["Struct"], true, "Struct.pack_into.__objclass__.__name__ is 'Struct' (method_descriptor for writing packed bytes into buffer)"]
    - [unpack_from_objclass_name,"Struct.unpack_from.__objclass__.__name__.__eq__",["Struct"], true, "Struct.unpack_from.__objclass__.__name__ is 'Struct' (method_descriptor for reading from buffer at offset)"]
    - [iter_unpack_objclass_name,"Struct.iter_unpack.__objclass__.__name__.__eq__",["Struct"], true, "Struct.iter_unpack.__objclass__.__name__ is 'Struct' (method_descriptor returning iterator over packed records)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack')
# struct.unpack.__name__.__eq__('unpack')
# struct.calcsize.__name__.__eq__('calcsize')
# struct.pack_into.__name__.__eq__('pack_into')
# struct.Struct.pack.__objclass__.__module__.__eq__('_struct')
#
# Wave 273 theme: Module-level function __name__ equality and method __objclass__.__module__.
#
# Module-level struct functions have __name__ == __qualname__ (for C-level builtins,
# there is no class prefix). struct_extra104 anchors __qualname__ equality; struct_extra108
# anchors __name__ length. This spec anchors __name__ equality (the actual string __eq__
# call) as a new grouped table. Also anchors Struct.pack.__objclass__.__module__ == '_struct'
# (the C extension module), paralleling __objclass__.__name__ in the first table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra109.module_function_name_equality_and_objclass_module:
  description: "pack.__name__.__eq__('pack')==True / unpack.__name__.__eq__('unpack')==True / calcsize.__name__.__eq__('calcsize')==True / pack_into.__name__.__eq__('pack_into')==True / Struct.pack.__objclass__.__module__.__eq__('_struct')==True — module-level C functions have __name__==__qualname__ (no class prefix); extra104 anchors __qualname__ equality; extra108 anchors __name__ lengths; this spec anchors __name__ equality via __eq__ call; Struct.pack.__objclass__.__module__ is '_struct' (C extension); first structobj109 anchor for __name__ equality"
  kind: python_call_eq
  category: function_identity
  id_prefix: structobj109

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,       "pack.__name__.__eq__",                        ["pack"],     true, "struct.pack.__name__ is 'pack' (4 chars; __name__==__qualname__ for C-level module functions; no class prefix)"]
    - [unpack_name_eq,     "unpack.__name__.__eq__",                      ["unpack"],   true, "struct.unpack.__name__ is 'unpack' (6 chars; __name__==__qualname__ for module-level C builtin)"]
    - [calcsize_name_eq,   "calcsize.__name__.__eq__",                    ["calcsize"], true, "struct.calcsize.__name__ is 'calcsize' (8 chars; returns byte count for a packed format string)"]
    - [pack_into_name_eq,  "pack_into.__name__.__eq__",                   ["pack_into"], true, "struct.pack_into.__name__ is 'pack_into' (9 chars; writes packed bytes into buffer at offset)"]
    - [pack_objcls_module, "Struct.pack.__objclass__.__module__.__eq__",  ["_struct"],  true, "Struct.pack.__objclass__.__module__ is '_struct' (C extension; leading underscore = CPython private module convention)"]

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct')
# struct.Struct.__qualname__.__eq__('Struct')
# struct.Struct.__module__.__len__() == 7
# struct.Struct.pack.__objclass__.__module__.__eq__('_struct')
# struct.Struct.unpack.__objclass__.__name__.__eq__('Struct')
#
# Wave 273 theme: Struct class __module__/__qualname__ equality and method __objclass__ cross-checks.
#
# struct.Struct.__module__ is '_struct' (7 chars: underscore + 'struct'). This
# confirms Struct is implemented in the _struct C extension, not the Python-level
# struct module. struct.Struct.__qualname__ is 'Struct' (same as __name__; top-level
# class; no nesting). struct_extra95 anchors Struct.__qualname__.__len__()==6;
# struct_extra108 anchors Struct.__name__.__eq__('Struct'). This spec anchors
# Struct.__module__ and Struct.__qualname__ equality as a new grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra109.Struct_class_module_and_qualname_equality:
  description: "Struct.__module__.__eq__('_struct')==True / Struct.__qualname__.__eq__('Struct')==True / Struct.__module__.__len__()==7 / Struct.pack.__objclass__.__module__.__eq__('_struct')==True / Struct.unpack.__objclass__.__name__.__eq__('Struct')==True — Struct.__module__ is '_struct' (7 chars; C extension; underscore prefix); __qualname__=='Struct' (same as __name__; top-level class); extra95 anchors __qualname__.__len__()==6; extra108 anchors __name__ equality; first structobj109 anchor for __module__ and __qualname__ equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: structobj109

  columns: [id, function, args, expected, description]
  rows:
    - [struct_module_eq,         "Struct.__module__.__eq__",                    ["_struct"], true, "struct.Struct.__module__ is '_struct' (7 chars; C extension module; underscore prefix distinguishes from 'struct' Python wrapper)"]
    - [struct_qualname_eq,       "Struct.__qualname__.__eq__",                  ["Struct"],  true, "struct.Struct.__qualname__ is 'Struct' (same as __name__; top-level class not nested; extra95 anchors __qualname__.__len__()==6)"]
    - [struct_module_len,        "Struct.__module__.__len__",                   [],          7,    "struct.Struct.__module__.__len__() is 7 ('_struct': underscore + 'struct'; 7 chars)"]
    - [pack_objcls_mod,          "Struct.pack.__objclass__.__module__.__eq__",  ["_struct"], true, "Struct.pack.__objclass__.__module__ is '_struct' (method_descriptor __objclass__ is the C Struct class in _struct)"]
    - [unpack_objcls_name,       "Struct.unpack.__objclass__.__name__.__eq__",  ["Struct"],  true, "Struct.unpack.__objclass__.__name__ is 'Struct' (cross-check: all Struct method_descriptors share the same __objclass__)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.pack.__objclass__.__name__ is 'Struct'. method_descriptor objects
# have a __objclass__ attribute referencing the class they are defined on.
# For Struct.pack, __objclass__ is the _struct.Struct C class itself, whose
# __name__ is 'Struct' (6 chars, capital S). struct_extra107 anchors __objclass__
# for getset_descriptors (Struct.size and Struct.format); no prior struct spec
# anchors __objclass__.__name__ for method_descriptors (pack/unpack/etc.) as a
# standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra109.Struct_pack_objclass_name_eq:
  description: "struct.Struct.pack.__objclass__.__name__.__eq__('Struct') == True — method_descriptor __objclass__ is the defining C class; __name__ is 'Struct' (6 chars capital S); extra107 anchors __objclass__ for getset_descriptors (size/format); no prior spec anchors method_descriptor __objclass__.__name__ as standalone; first standalone under structobj109"
  category: method_identity
  kind: python_call_eq
  function: "Struct.pack.__objclass__.__name__.__eq__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct'. Struct is implemented in the _struct C
# extension module (Modules/_struct.c). The leading underscore in '_struct' is a
# CPython convention indicating a private C extension intended to be used via the
# 'struct' Python wrapper (Lib/struct.py), not imported directly. This parallels
# _hashlib (hashlib's C extension) and _socket (socket's C extension). struct_extra97
# anchors Struct.__module__.__len__()==7; struct_extra95 anchors Struct.__qualname__.__len__()==6;
# this spec anchors the __module__ string equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra109.Struct_module_eq:
  description: "struct.Struct.__module__.__eq__('_struct') == True — __module__ is '_struct' (7 chars; leading underscore is CPython convention for private C extension; parallels _hashlib and _socket); Struct is defined in Modules/_struct.c not Lib/struct.py; extra97 anchors __len__()==7; first standalone for __module__ equality under structobj109"
  category: class_identity
  kind: python_call_eq
  function: "Struct.__module__.__eq__"
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack') — standalone
#
# struct.pack.__name__ is 'pack' (4 chars: p-a-c-k). For C-level module functions,
# __name__ equals __qualname__ (no class prefix is added). struct_extra104 anchors
# struct.pack.__qualname__.__eq__('pack'); struct_extra108 anchors pack.__name__.__len__()==4.
# This spec anchors the __name__ equality as a standalone __eq__ call, confirming
# that __name__ and __qualname__ agree for module-level C builtins. No prior struct
# spec anchors pack.__name__.__eq__('pack') as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra109.pack_name_eq:
  description: "struct.pack.__name__.__eq__('pack') == True — __name__ is 'pack' (4 chars; p-a-c-k; shortest module-level struct function name); for C-level module functions __name__==__qualname__; extra104 anchors __qualname__ equality; extra108 anchors __name__.__len__()==4; first standalone for __name__ equality under structobj109"
  category: function_identity
  kind: python_call_eq
  function: "pack.__name__.__eq__"
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.__qualname__ is 'Struct'. For a top-level C type (not nested
# inside another class or function), __qualname__ equals __name__. Struct is
# declared as a top-level type in _struct.c, so __qualname__=='Struct' (6 chars,
# same as __name__=='Struct'). struct_extra95 anchors Struct.__qualname__.__len__()==6;
# struct_extra108 anchors Struct.__name__.__eq__('Struct'). This spec anchors
# Struct.__qualname__ equality as a standalone — the first spec to do so.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra109.Struct_qualname_eq:
  description: "struct.Struct.__qualname__.__eq__('Struct') == True — __qualname__ is 'Struct' (same as __name__; top-level C type from _struct.c; not nested in any outer class or function); extra95 anchors __qualname__.__len__()==6; extra108 anchors __name__.__eq__('Struct'); first standalone for __qualname__ equality under structobj109"
  category: class_identity
  kind: python_call_eq
  function: "Struct.__qualname__.__eq__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__name__.__eq__('calcsize') — standalone
#
# struct.calcsize.__name__ is 'calcsize' (8 chars: c-a-l-c-s-i-z-e). calcsize
# is a C-level builtin_function_or_method that returns the number of bytes needed
# to represent data in a given format string. Its __name__ is 'calcsize' — same
# as its __qualname__ (no class prefix for module-level functions). struct_extra107
# anchors calcsize.__qualname__.__eq__('calcsize'); struct_extra108 anchors
# calcsize.__name__.__len__()==8. This spec anchors calcsize.__name__ equality
# as a standalone for the first time under structobj109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra109.calcsize_name_eq:
  description: "struct.calcsize.__name__.__eq__('calcsize') == True — __name__ is 'calcsize' (8 chars; c-a-l-c-s-i-z-e; returns byte count for packed format string); __name__==__qualname__ for module-level C functions; extra107 anchors calcsize __qualname__ equality; extra108 anchors __name__.__len__()==8; first standalone for calcsize __name__ equality under structobj109"
  category: function_identity
  kind: python_call_eq
  function: "calcsize.__name__.__eq__"
  args: ["calcsize"]
  expected: true
