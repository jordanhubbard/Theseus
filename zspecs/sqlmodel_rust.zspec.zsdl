  kind: python_call_eq
  function: sqlmodel_has_field
  args: []
  expected: true

invariant sqlmodel_rust.version_nonempty:
  description: "sqlmodel.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: sqlmodel_version_nonempty
  args: []
  expected: true

