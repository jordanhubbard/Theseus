spec: multiprocessing_extra30
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra29.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__len__() for map/apply/close/terminate/join/apply_async/map_async/starmap/imap/starmap_async/imap_unordered, AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/AuthenticationError/ProcessError __mro__.__len__(), __all__ metadata, class __dict__.__class__.__name__.__len__() for Process/AuthenticationError/ProcessError."
    - "This spec covers: Pool.__dict__.__class__.__name__.__len__() (12); Pool.__bases__[0].__name__.__len__() (6); Pool.__qualname__.__len__() (4); Pool.__name__.__len__() (4); Pool.__module__.__len__() (20); Process.__name__.__len__() (7); Process.__qualname__.__len__() (7); Process.__module__.__len__() (23); Process.__mro__.__len__() (3 — through BaseProcess); Process.__bases__[0].__name__.__len__() (11 — 'BaseProcess'); DefaultContext method __qualname__.__len__() for get_start_method/set_start_method/get_context/active_children; BufferTooShort/__qualname__.__len__() and TimeoutError/__qualname__.__len__()."
    - "IMPORTANT: Process.__mro__.__len__() == 3, NOT 2. MRO is [Process, BaseProcess, object] — Process subclasses BaseProcess, not object directly. Prior spec28 confirmed __mro__.__len__() == 3 for Process."
    - "Pool.__mro__.__len__() == 2 — Pool is a direct subclass of object (verified in extra28/extra29)."
    - "get_start_method and set_start_method are DefaultContext-bound methods with qualname len 31."
    - "get_context.__qualname__ == 'DefaultContext.get_context' — len 26."
    - "active_children.__qualname__ == 'active_children' — len 15 (module-level function, not context-bound)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pool class metadata table — __dict__, __bases__, __qualname__, __name__, __module__
#
# Pool.__dict__.__class__.__name__ is 'mappingproxy' (12 chars). Pool.__bases__[0].__name__
# is 'object' (6 chars) — Pool is a direct subclass of object with no intermediate
# base class. Pool.__qualname__ is 'Pool' (4 chars), Pool.__name__ is 'Pool' (4 chars),
# and Pool.__module__ is 'multiprocessing.pool' (20 chars). No prior multiprocessing spec
# records these five Pool class identity values together in a combined table in the
# extra30 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra30.pool_class_metadata:
  description: "Pool class identity metadata: __dict__.__class__.__name__.__len__, __bases__[0].__name__.__len__, __qualname__.__len__, __name__.__len__, __module__.__len__"
  kind: python_call_eq
  category: class_structure
  id_prefix: poolmeta30

  columns: [id, function, args, expected, description]
  rows:
    - [dict_classname_len,
       Pool.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(Pool.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [bases_name_len,
       "Pool.__bases__[0].__name__.__len__",
       [],
       6,
       "len(Pool.__bases__[0].__name__) == 6 — 'object'"]
    - [qualname_len,
       Pool.__qualname__.__len__,
       [],
       4,
       "len(Pool.__qualname__) == 4 — 'Pool'"]
    - [name_len,
       Pool.__name__.__len__,
       [],
       4,
       "len(Pool.__name__) == 4 — 'Pool'"]
    - [module_len,
       Pool.__module__.__len__,
       [],
       20,
       "len(Pool.__module__) == 20 — 'multiprocessing.pool'"]

# ---------------------------------------------------------------------------
# Process class identity table — __name__, __qualname__, __module__, __mro__
#
# Process.__name__ is 'Process' (7 chars). Process.__qualname__ is 'Process' (7 chars).
# Process.__module__ is 'multiprocessing.context' (23 chars). Process.__mro__ has length
# 3 — [Process, BaseProcess, object] — because Process subclasses BaseProcess (not
# object directly). Process.__bases__[0].__name__ is 'BaseProcess' (11 chars). No prior
# multiprocessing spec records these five identity values together in a combined table
# in the extra30 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra30.process_class_identity:
  description: "Process class identity: __name__/__qualname__.__len__, __module__.__len__, __mro__.__len__, __bases__[0].__name__.__len__"
  kind: python_call_eq
  category: class_structure
  id_prefix: processid30

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,
       Process.__name__.__len__,
       [],
       7,
       "len(Process.__name__) == 7 — 'Process'"]
    - [qualname_len,
       Process.__qualname__.__len__,
       [],
       7,
       "len(Process.__qualname__) == 7 — 'Process'"]
    - [module_len,
       Process.__module__.__len__,
       [],
       23,
       "len(Process.__module__) == 23 — 'multiprocessing.context'"]
    - [mro_len,
       Process.__mro__.__len__,
       [],
       3,
       "len(Process.__mro__) == 3 — [Process, BaseProcess, object]"]
    - [bases_name_len,
       "Process.__bases__[0].__name__.__len__",
       [],
       11,
       "len(Process.__bases__[0].__name__) == 11 — 'BaseProcess'"]

# ---------------------------------------------------------------------------
# DefaultContext method __qualname__ lengths — extra30 namespace
#
# multiprocessing.get_start_method and set_start_method are DefaultContext-bound
# methods with __qualname__ 'DefaultContext.get_start_method' and
# 'DefaultContext.set_start_method' (both 31 chars). multiprocessing.get_context
# has __qualname__ 'DefaultContext.get_context' (26 chars). multiprocessing.active_children
# is a module-level function (not context-bound) with __qualname__ 'active_children'
# (15 chars). No prior multiprocessing spec records these four __qualname__.__len__()
# values together in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra30.default_context_method_qualname_lengths:
  description: "DefaultContext-bound and module-level method __qualname__.__len__() for get_start_method/set_start_method/get_context/active_children"
  kind: python_call_eq
  category: method_names
  id_prefix: ctxmqualnamelen30

  columns: [id, function, args, expected, description]
  rows:
    - [get_start_method,
       get_start_method.__qualname__.__len__,
       [],
       31,
       "len(get_start_method.__qualname__) == 31 — 'DefaultContext.get_start_method'"]
    - [set_start_method,
       set_start_method.__qualname__.__len__,
       [],
       31,
       "len(set_start_method.__qualname__) == 31 — 'DefaultContext.set_start_method'"]
    - [get_context,
       get_context.__qualname__.__len__,
       [],
       26,
       "len(get_context.__qualname__) == 26 — 'DefaultContext.get_context'"]
    - [active_children,
       active_children.__qualname__.__len__,
       [],
       15,
       "len(active_children.__qualname__) == 15 — 'active_children' (module-level, not context-bound)"]

# ---------------------------------------------------------------------------
# Exception __qualname__.__len__() — BufferTooShort and TimeoutError standalone
#
# multiprocessing.BufferTooShort.__qualname__ is 'BufferTooShort' (14 chars).
# multiprocessing.TimeoutError.__qualname__ is 'TimeoutError' (12 chars). No prior
# multiprocessing spec records __qualname__.__len__() for these two exceptions as
# standalone invariants in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra30.BufferTooShort_qualname_len:
  description: "multiprocessing.BufferTooShort.__qualname__.__len__() == 14 — 'BufferTooShort'"
  category: string_properties
  kind: python_call_eq
  function: BufferTooShort.__qualname__.__len__
  args: []
  expected: 14

invariant multiprocessing_extra30.TimeoutError_qualname_len:
  description: "multiprocessing.TimeoutError.__qualname__.__len__() == 12 — 'TimeoutError'"
  category: string_properties
  kind: python_call_eq
  function: TimeoutError.__qualname__.__len__
  args: []
  expected: 12

invariant multiprocessing_extra30.AuthenticationError_qualname_len:
  description: "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 — 'AuthenticationError'"
  category: string_properties
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra30.multiprocessing_name_len:
  description: "multiprocessing.__name__.__len__() == 15 — 'multiprocessing'"
  category: module_metadata
  kind: python_call_eq
  function: multiprocessing.__name__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra30.multiprocessing_package_len:
  description: "multiprocessing.__package__.__len__() == 15 — package name is 'multiprocessing'"
  category: module_metadata
  kind: python_call_eq
  function: multiprocessing.__package__.__len__
  args: []
  expected: 15
