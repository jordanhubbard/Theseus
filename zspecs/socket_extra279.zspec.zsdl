spec: socket_extra279
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 1700 — Assigned Numbers (well-known port assignments)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 1700 — Assigned Numbers (well-known port assignments)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl through socket_extra278.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra278.zspec.zsdl covers: ntohs/htons/ntohl/htonl byte-swap functions; error cases (negative/overflow); function identity."
    - "This spec focuses on: socket.getservbyname() and socket.getservbyport() — service/port lookup functions using the system /etc/services database."
    - "socket.getservbyname('http') == 80 — HTTP is well-known port 80 per RFC 1700. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyname('ftp') == 21 — FTP control is well-known port 21 per RFC 1700. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyname('ssh') == 22 — SSH is well-known port 22. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyname('smtp') == 25 — SMTP is well-known port 25 per RFC 1700. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyname('https') == 443 — HTTPS is well-known port 443. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyport(80) == 'http' — reverse lookup of port 80 returns 'http'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyport(21) == 'ftp' — reverse lookup of port 21 returns 'ftp'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyname('zzznone_service_xxx') raises OSError — unknown service names raise OSError('service/proto not found'). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyname and socket.getservbyport are both builtin_function_or_method (C-level functions from _socket). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "socket.getservbyname and socket.getservbyport raise OSError for unknown service names or ports. Return values are int (getservbyname) and str (getservbyport)."
  stderr: "null"
  stickiness: "N/A — these functions query the system service database; results are stateless per-call."
  codes: {}

# ---------------------------------------------------------------------------
# socket.getservbyname — well-known service name to port number
# These port assignments are stable across all POSIX systems.
# RFC 1700 (and its successors) define the canonical well-known ports.
# getservbyname() consults the system /etc/services database.
# ---------------------------------------------------------------------------

table socket_extra279.getservbyname_vectors:
  description: "socket.getservbyname() well-known service name to port number — http/ftp/ssh/smtp/https; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: getservbyname
  function: getservbyname
  id_prefix: gsn279
  rfc: "RFC 1700"

  columns: [id, args, expected, description]
  rows:
    - [http,  ["http"],  80,  "HTTP — well-known port 80 (RFC 1700)"]
    - [ftp,   ["ftp"],   21,  "FTP control — well-known port 21 (RFC 1700)"]
    - [ssh,   ["ssh"],   22,  "SSH — well-known port 22"]
    - [smtp,  ["smtp"],  25,  "SMTP — well-known port 25 (RFC 1700)"]
    - [https, ["https"], 443, "HTTPS — well-known port 443"]

# ---------------------------------------------------------------------------
# socket.getservbyport — port number to service name (reverse lookup)
# getservbyport() is the inverse of getservbyname(). Returns a str.
# Port 80 → 'http'; port 21 → 'ftp'; port 22 → 'ssh'; port 443 → 'https'.
# ---------------------------------------------------------------------------

table socket_extra279.getservbyport_vectors:
  description: "socket.getservbyport() port number to service name reverse lookup — 80/21/22/443; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: getservbyport
  function: getservbyport
  id_prefix: gsp279
  rfc: "RFC 1700"

  columns: [id, args, expected, description]
  rows:
    - [port_80,  [80],  "http",  "port 80 reverse lookup → 'http'"]
    - [port_21,  [21],  "ftp",   "port 21 reverse lookup → 'ftp'"]
    - [port_22,  [22],  "ssh",   "port 22 reverse lookup → 'ssh'"]
    - [port_443, [443], "https", "port 443 reverse lookup → 'https'"]

# ---------------------------------------------------------------------------
# socket.getservbyname — return type is int
# getservbyname() returns a plain Python int (not a socket constant enum).
# ---------------------------------------------------------------------------

invariant socket_extra279.getservbyname.return_type_is_int:
  description: "socket.getservbyname('http').__class__.__name__ == 'int' — getservbyname returns a Python int; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: getservbyname
  kind: python_call_eq
  function: getservbyname
  args: ["http"]
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getservbyport — return type is str
# getservbyport() returns a plain Python str (the service name from /etc/services).
# ---------------------------------------------------------------------------

invariant socket_extra279.getservbyport.return_type_is_str:
  description: "socket.getservbyport(80).__class__.__name__ == 'str' — getservbyport returns a Python str; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: getservbyport
  kind: python_call_eq
  function: getservbyport
  args: [80]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getservbyname — raises OSError for unknown service name
# An unrecognised service name triggers OSError with message
# 'service/proto not found'. The exact message is platform-defined but
# OSError is always raised. Verified on macOS Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra279.getservbyname.unknown_service_raises:
  description: "socket.getservbyname('zzznone_service_xxx') raises OSError — unknown service name triggers OSError('service/proto not found'); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: getservbyname
  args: ["zzznone_service_xxx"]
  raises: OSError

# ---------------------------------------------------------------------------
# socket.getservbyname and socket.getservbyport — function identity
# Both are C-level functions from the _socket extension module.
# ---------------------------------------------------------------------------

invariant socket_extra279.getservbyname.function_class_name:
  description: "socket.getservbyname.__class__.__name__ == 'builtin_function_or_method' — getservbyname is a C-level builtin from the _socket extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: function_identity
  kind: python_call_eq
  function: getservbyname.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra279.getservbyport.function_class_name:
  description: "socket.getservbyport.__class__.__name__ == 'builtin_function_or_method' — getservbyport is a C-level builtin from the _socket extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: function_identity
  kind: python_call_eq
  function: getservbyport.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
