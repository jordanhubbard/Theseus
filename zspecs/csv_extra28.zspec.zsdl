spec: csv_extra28
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
    - "csv_extra25.zspec.zsdl — covers __module__.__len__() for DictReader/DictWriter/Dialect/Error/reader/writer/register_dialect/field_size_limit; __name__.__len__() for DictReader/DictWriter/Dialect/Error"
    - "csv_extra26.zspec.zsdl — covers __qualname__.__len__() for Dialect/excel/excel_tab/unix_dialect/DictReader/DictWriter; DictReader.__init__/DictReader.__next__/DictWriter.writerow/DictWriter.writerows/DictWriter.writeheader __qualname__.__len__()"
    - "csv_extra27.zspec.zsdl — covers __mro__.__len__() for DictReader/DictWriter/Dialect/excel/excel_tab; __bases__[0].__name__ for DictReader/DictWriter/Dialect; DictWriter.__init__/Dialect.__init__ __qualname__.__len__()"
  notes:
    - "This spec extends csv_extra27.zspec.zsdl."
    - "Prior specs covered: reader/writer/DictReader/DictWriter/Dialect/Error __name__/__module__/__qualname__ and lengths, DictReader/DictWriter/Dialect/excel/excel_tab __mro__.__len__(), DictReader/DictWriter/Dialect __bases__[0].__name__, DictWriter.__init__/Dialect.__init__/DictReader.__init__/DictReader.__next__/DictWriter.writerow/writerows/writeheader __qualname__.__len__()."
    - "This spec covers: csv.__all__.__len__() and __class__.__name__; csv.__all__.__class__.__name__.__len__(); csv.__version__ value and type; QUOTE_* constant values (QUOTE_ALL=1, QUOTE_MINIMAL=0, QUOTE_NONNUMERIC=2, QUOTE_NONE=3, QUOTE_STRINGS=4, QUOTE_NOTNULL=5); Sniffer/__mro__.__len__(); Error/__mro__.__len__(); unix_dialect/__mro__.__len__(); Sniffer/__dict__.__class__.__name__.__len__(); Error/__dict__.__class__.__name__.__len__(); Sniffer.__init__/__qualname__.__len__(); Sniffer.sniff/__qualname__.__len__(); Error.__reduce__.__qualname__.__len__()."
    - "No prior csv spec checks csv.__all__.__len__()."
    - "No prior csv spec checks csv.__all__.__class__.__name__.__len__()."
    - "No prior csv spec checks csv.__version__."
    - "No prior csv spec checks csv.__version__.__len__()."
    - "No prior csv spec checks csv.QUOTE_ALL value."
    - "No prior csv spec checks csv.QUOTE_MINIMAL value."
    - "No prior csv spec checks csv.QUOTE_NONNUMERIC value."
    - "No prior csv spec checks csv.QUOTE_NONE value."
    - "No prior csv spec checks csv.QUOTE_STRINGS value."
    - "No prior csv spec checks csv.QUOTE_NOTNULL value."
    - "No prior csv spec checks csv.Sniffer.__mro__.__len__()."
    - "No prior csv spec checks csv.Error.__mro__.__len__()."
    - "No prior csv spec checks csv.unix_dialect.__mro__.__len__()."
    - "No prior csv spec checks csv.Sniffer.__dict__.__class__.__name__.__len__()."
    - "No prior csv spec checks csv.Error.__dict__.__class__.__name__.__len__()."
    - "No prior csv spec checks csv.Sniffer.__init__.__qualname__.__len__()."
    - "No prior csv spec checks csv.Sniffer.sniff.__qualname__.__len__()."
    - "No prior csv spec checks csv.Error.__reduce__.__qualname__.__len__()."
    - "csv.__all__ is a list with 21 elements. __class__.__name__ == 'list' — len 4."
    - "csv.__version__ == '1.0' — len 3. __class__.__name__ == 'str'."
    - "csv.QUOTE_MINIMAL == 0, QUOTE_ALL == 1, QUOTE_NONNUMERIC == 2, QUOTE_NONE == 3, QUOTE_STRINGS == 4, QUOTE_NOTNULL == 5."
    - "csv.Sniffer.__mro__ == [Sniffer, object] — len 2."
    - "csv.Error.__mro__ == [Error, Exception, BaseException, object] — len 4."
    - "csv.unix_dialect.__mro__ == [unix_dialect, Dialect, object] — len 3."
    - "csv.Sniffer.__dict__.__class__.__name__ == 'mappingproxy' — len 12."
    - "csv.Error.__dict__.__class__.__name__ == 'mappingproxy' — len 12."
    - "csv.Sniffer.__init__.__qualname__ == 'Sniffer.__init__' — len 16."
    - "csv.Sniffer.sniff.__qualname__ == 'Sniffer.sniff' — len 13."
    - "csv.Error.__reduce__.__qualname__ == 'BaseException.__reduce__' — len 24 (inherits from exception hierarchy)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# csv.__all__ membership and type
#
# csv.__all__ is a list with 21 elements covering all public API names:
# QUOTE_* constants, Error, Dialect, dialect subclasses, reader/writer,
# registration/introspection functions, DictReader/DictWriter, Sniffer.
# Its __class__.__name__ is 'list' (len 4).
# No prior csv spec checks __all__.__len__().
# ---------------------------------------------------------------------------

invariant csv_extra28.all_len:
  description: "csv.__all__.__len__() == 21 — 21 public names exported including QUOTE_* constants, classes, and functions"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 21

invariant csv_extra28.all_class_name_len:
  description: "csv.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list' (4 chars)"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# csv.__version__ constant
#
# csv exposes a __version__ string attribute '1.0' (len 3). It is the only
# standard library module in this test suite that provides a __version__
# string. No prior csv spec checks __version__.
# ---------------------------------------------------------------------------

invariant csv_extra28.version_len:
  description: "csv.__version__.__len__() == 3 — version string '1.0' has 3 characters"
  category: module_constants
  kind: python_call_eq
  function: __version__.__len__
  args: []
  expected: 3

invariant csv_extra28.version_class_name_len:
  description: "csv.__version__.__class__.__name__.__len__() == 3 — __version__ is a 'str' (3 chars)"
  category: module_constants
  kind: python_call_eq
  function: __version__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# QUOTE_* integer constants
#
# The csv module defines six quoting mode constants as plain integers:
#   QUOTE_MINIMAL    == 0  (quote only when required)
#   QUOTE_ALL        == 1  (always quote every field)
#   QUOTE_NONNUMERIC == 2  (quote all non-numeric fields)
#   QUOTE_NONE       == 3  (never quote; escape special chars)
#   QUOTE_STRINGS    == 4  (quote all string fields; Python 3.12+)
#   QUOTE_NOTNULL    == 5  (quote all non-None fields; Python 3.12+)
# No prior csv spec checks any of these values.
# ---------------------------------------------------------------------------

table csv_extra28.quote_constant_values:
  description: "csv QUOTE_* constants: QUOTE_MINIMAL (0), QUOTE_ALL (1), QUOTE_NONNUMERIC (2), QUOTE_NONE (3), QUOTE_STRINGS (4), QUOTE_NOTNULL (5)"
  kind: python_call_eq
  category: module_constants
  id_prefix: qcv28

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_MINIMAL,    QUOTE_MINIMAL.__eq__,    [0], true]
    - [QUOTE_ALL,        QUOTE_ALL.__eq__,        [1], true]
    - [QUOTE_NONNUMERIC, QUOTE_NONNUMERIC.__eq__, [2], true]
    - [QUOTE_NONE,       QUOTE_NONE.__eq__,       [3], true]
    - [QUOTE_STRINGS,    QUOTE_STRINGS.__eq__,    [4], true]
    - [QUOTE_NOTNULL,    QUOTE_NOTNULL.__eq__,    [5], true]

# ---------------------------------------------------------------------------
# __mro__.__len__() for Sniffer, Error, unix_dialect
#
# csv_extra27 covered DictReader, DictWriter, Dialect, excel, excel_tab.
# These three classes extend that coverage:
#   Sniffer      -> [Sniffer, object]                         -> 2
#   unix_dialect -> [unix_dialect, Dialect, object]           -> 3
#   Error        -> [Error, Exception, BaseException, object] -> 4
# No prior csv spec checks any of these three classes' MRO depths.
# ---------------------------------------------------------------------------

table csv_extra28.additional_class_mro_depths:
  description: "csv class __mro__.__len__() — Sniffer (2), unix_dialect (3), Error (4)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: acmd28

  columns: [id, function, args, expected]
  rows:
    - [Sniffer,      Sniffer.__mro__.__len__,      [], 2]
    - [unix_dialect, unix_dialect.__mro__.__len__,  [], 3]
    - [Error,        Error.__mro__.__len__,         [], 4]

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for Sniffer and Error
# Sniffer.__init__ and Sniffer.sniff __qualname__ lengths
# Error.__reduce__.__qualname__.__len__()
# ---------------------------------------------------------------------------

invariant csv_extra28.Sniffer.dict_class_name_len:
  description: "csv.Sniffer.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is 'mappingproxy' (12 chars)"
  category: class_introspection
  kind: python_call_eq
  function: Sniffer.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant csv_extra28.Error.dict_class_name_len:
  description: "csv.Error.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is 'mappingproxy' (12 chars)"
  category: class_introspection
  kind: python_call_eq
  function: Error.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant csv_extra28.Sniffer.init_qualname_len:
  description: "csv.Sniffer.__init__.__qualname__.__len__() == 16 — 'Sniffer.__init__' has 16 characters"
  category: method_identity
  kind: python_call_eq
  function: Sniffer.__init__.__qualname__.__len__
  args: []
  expected: 16

invariant csv_extra28.Sniffer.sniff_qualname_len:
  description: "csv.Sniffer.sniff.__qualname__.__len__() == 13 — 'Sniffer.sniff' has 13 characters"
  category: method_identity
  kind: python_call_eq
  function: Sniffer.sniff.__qualname__.__len__
  args: []
  expected: 13

invariant csv_extra28.Error.reduce_qualname_len:
  description: "csv.Error.__reduce__.__qualname__.__len__() == 24 — inherits 'BaseException.__reduce__' (24 chars) from exception hierarchy"
  category: function_identity
  kind: python_call_eq
  function: "Error.__reduce__.__qualname__.__len__"
  args: []
  expected: 24
