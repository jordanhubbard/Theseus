spec: ssl_extra19
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra18.zspec.zsdl — covers constant __class__.__name__.__len__() table; SSLError base via __getitem__; class __name__.__len__() table; HAS_SNI class name len."
    - "ssl_extra17.zspec.zsdl — covers MRO lengths (SSLError/SSLCertVerificationError/SSLContext/SSLSocket); CertificateError qualname len; SSLSocket name len; SSLError qualname len."
    - "ssl_extra16.zspec.zsdl — covers class __bases__.__len__(); CERT_NONE/OPTIONAL/REQUIRED.__int__(); VerifyMode/SSLError/SSLContext name lengths."
    - "ssl_extra13.zspec.zsdl — covers SSLContext.__bases__[0].__name__ == '_SSLContext'; SSLSocket.__bases__[0].__name__ == 'socket'."
    - "ssl_extra10.zspec.zsdl — covers Purpose.__bases__[0].__name__; Purpose.__module__/__qualname__; get_default_verify_paths __name__/__module__."
    - "ssl_extra5.zspec.zsdl — covers create_default_context.__module__ == 'ssl'."
    - "ssl_extra.zspec.zsdl — covers create_default_context.__name__; Purpose.__name__/__members__."
  notes:
    - "This spec extends ssl through ssl_extra18; it does NOT duplicate invariants present in those files."
    - "Focus: __module__.__len__() checks for SSLError/SSLContext/create_default_context/Purpose; create_default_context.__name__.__len__(); Purpose.__bases__[0].__name__.__len__(); SSLContext.__bases__[0].__name__.__len__(); HAS_ALPN and HAS_NPN class name checks as standalone invariants."
    - "ssl.SSLError.__module__.__len__() == 3: len('ssl') == 3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.__module__.__len__() == 3: len('ssl') == 3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.create_default_context.__module__.__len__() == 3: len('ssl') == 3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.create_default_context.__name__.__len__() == 22: len('create_default_context') == 22. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.Purpose.__module__.__len__() == 3: Purpose is defined in the ssl module; len('ssl') == 3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.Purpose.__bases__[0].__name__.__len__() == 10: len('_ASN1Object') == 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.__bases__[0].__name__.__len__() == 11: len('_SSLContext') == 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.HAS_ALPN.__class__.__name__ == 'bool': HAS_ALPN is a module-level bool constant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.HAS_NPN.__class__.__name__ == 'bool': HAS_NPN is a module-level bool constant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() checks — novel execution path
#
# ssl_extra5 covers create_default_context.__module__ == 'ssl' via __eq__.
# ssl.zspec covers SSLError.__module__ == 'ssl' via __eq__.
# No prior spec checks the length of the __module__ strings.
# SSLError, SSLContext, create_default_context, and Purpose are all
# defined in the 'ssl' module; len('ssl') == 3.
# ---------------------------------------------------------------------------

table ssl_extra19.module_name_lengths:
  description: "Length of __module__ string for key ssl attributes"
  kind: python_call_eq
  category: module_metadata
  id_prefix: sslmodlen19

  columns: [id, function, args, expected]
  rows:
    - [SSLError,                SSLError.__module__.__len__,                [], 3]
    - [SSLContext,              SSLContext.__module__.__len__,              [], 3]
    - [create_default_context,  create_default_context.__module__.__len__,  [], 3]
    - [Purpose,                 Purpose.__module__.__len__,                 [], 3]

# ---------------------------------------------------------------------------
# create_default_context.__name__.__len__() == 22
#
# ssl_extra covers create_default_context.__name__ == 'create_default_context'
# via __eq__. No prior spec checks the length of this function name string.
# len('create_default_context') == 22.
# ---------------------------------------------------------------------------

invariant ssl_extra19.create_default_context.name_len:
  description: "ssl.create_default_context.__name__.__len__() == 22 — len('create_default_context') == 22"
  category: function_metadata
  kind: python_call_eq
  function: create_default_context.__name__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# Purpose.__bases__[0].__name__.__len__() == 10
#
# ssl_extra10 covers Purpose.__bases__[0].__name__ == '_ASN1Object' via __eq__.
# No prior spec checks the length of '_ASN1Object': len('_ASN1Object') == 10.
# ---------------------------------------------------------------------------

invariant ssl_extra19.Purpose.base_name_len:
  description: "ssl.Purpose.__bases__[0].__name__.__len__() == 10 — len('_ASN1Object') == 10"
  category: class_hierarchy
  kind: python_call_eq
  function: "Purpose.__bases__[0].__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# SSLContext.__bases__[0].__name__.__len__() == 11
#
# ssl_extra13 covers SSLContext.__bases__[0].__name__ == '_SSLContext' via __eq__.
# No prior spec checks the length of '_SSLContext': len('_SSLContext') == 11.
# ---------------------------------------------------------------------------

invariant ssl_extra19.SSLContext.base_name_len:
  description: "ssl.SSLContext.__bases__[0].__name__.__len__() == 11 — len('_SSLContext') == 11"
  category: class_hierarchy
  kind: python_call_eq
  function: "SSLContext.__bases__[0].__name__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# HAS_ALPN and HAS_NPN __class__.__name__ == 'bool'
#
# ssl.zspec covers HAS_SNI and HAS_ALPN __class__.__name__ == 'bool' in a table.
# ssl_extra6 covers HAS_TLS_UNIQUE.__class__.__name__ == 'bool'.
# No prior spec checks HAS_NPN.__class__.__name__ as a standalone invariant.
# HAS_ALPN is covered in ssl.zspec table; HAS_NPN is not covered anywhere.
# Both are module-level bool constants: HAS_ALPN is True; HAS_NPN is False.
# ---------------------------------------------------------------------------

invariant ssl_extra19.HAS_ALPN.class_name:
  description: "ssl.HAS_ALPN.__class__.__name__ == 'bool' — HAS_ALPN is a bool constant"
  category: class_metadata
  kind: python_call_eq
  function: HAS_ALPN.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant ssl_extra19.HAS_NPN.class_name:
  description: "ssl.HAS_NPN.__class__.__name__ == 'bool' — HAS_NPN is a bool constant"
  category: class_metadata
  kind: python_call_eq
  function: HAS_NPN.__class__.__name__.__eq__
  args: ["bool"]
  expected: true
