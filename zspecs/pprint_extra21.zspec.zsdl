spec: pprint_extra21
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint_extra20.zspec.zsdl."
    - "Prior specs covered: pprint.__name__/__package__; pprint/__name__/__module__; pformat/__name__/__module__; PrettyPrinter/__name__/__module__/__qualname__; isreadable/__name__; isrecursive/__name__; saferepr/__name__; pp/__name__; PrettyPrinter.__bases__[0].__name__; various __qualname__ checks; pprint.__all__ type/length; PrettyPrinter.__init__/__repr__ qualnames; PrettyPrinter method qualnames; module-level function __qualname__ flat forms; __module__.__len__() for pprint/pformat/isreadable/PrettyPrinter."
    - "This spec covers: pprint module-level function __name__.__len__() for pprint/pformat/isreadable/isrecursive/saferepr/pp; PrettyPrinter.__name__.__len__(); PrettyPrinter.__qualname__.__len__(); PrettyPrinter method __name__.__len__() for pprint/pformat/_pprint_list/_pprint_tuple/_pprint_dict/_pprint_set; PrettyPrinter method __qualname__.__len__() cross-checks."
    - "pprint.pprint.__name__ == 'pprint'; len == 6. Verified at runtime."
    - "pprint.pformat.__name__ == 'pformat'; len == 7. Verified at runtime."
    - "pprint.isreadable.__name__ == 'isreadable'; len == 10. Verified at runtime."
    - "pprint.isrecursive.__name__ == 'isrecursive'; len == 11. Verified at runtime."
    - "pprint.saferepr.__name__ == 'saferepr'; len == 8. Verified at runtime."
    - "pprint.pp.__name__ == 'pp'; len == 2. Verified at runtime."
    - "pprint.PrettyPrinter.__name__ == 'PrettyPrinter'; len == 13. Verified at runtime."
    - "pprint.PrettyPrinter.__qualname__ == 'PrettyPrinter'; len == 13. Verified at runtime."
    - "pprint.PrettyPrinter.__init__.__name__ == '__init__'; len == 8. Verified at runtime."
    - "pprint.PrettyPrinter.__init__.__qualname__ == 'PrettyPrinter.__init__'; len == 22. Verified at runtime."
    - "pprint.PrettyPrinter.pprint.__name__ == 'pprint'; len == 6; __qualname__ == 'PrettyPrinter.pprint'; len == 20. Verified at runtime."
    - "pprint.PrettyPrinter.pformat.__name__ == 'pformat'; len == 7; __qualname__ == 'PrettyPrinter.pformat'; len == 21. Verified at runtime."
    - "pprint.PrettyPrinter._pprint_list.__name__ == '_pprint_list'; len == 12; __qualname__ len == 26. Verified at runtime."
    - "pprint.PrettyPrinter._pprint_tuple.__name__ == '_pprint_tuple'; len == 13; __qualname__ len == 27. Verified at runtime."
    - "pprint.PrettyPrinter._pprint_dict.__name__ == '_pprint_dict'; len == 12; __qualname__ len == 26. Verified at runtime."
    - "pprint.PrettyPrinter._pprint_set.__name__ == '_pprint_set'; len == 11; __qualname__ len == 25. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __name__.__len__()
#
# pprint_extra20 verified __module__.__len__() for module-level functions.
# This spec now adds __name__.__len__() checks: pprint(6), pformat(7),
# isreadable(10), isrecursive(11), saferepr(8), pp(2). These differ from the
# uniform __module__ length (all 6) because the names themselves vary.
# No prior spec verifies __name__.__len__() for these functions.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra21.pprint_func.name_len:
  description: "len(pprint.pprint.__name__) == 6 — 'pprint' is 6 characters"
  category: function_identity
  kind: python_call_eq
  function: pprint.__name__.__len__
  args: []
  expected: 6

invariant pprint_extra21.pformat.name_len:
  description: "len(pprint.pformat.__name__) == 7 — 'pformat' is 7 characters"
  category: function_identity
  kind: python_call_eq
  function: pformat.__name__.__len__
  args: []
  expected: 7

invariant pprint_extra21.isreadable.name_len:
  description: "len(pprint.isreadable.__name__) == 10 — 'isreadable' is 10 characters"
  category: function_identity
  kind: python_call_eq
  function: isreadable.__name__.__len__
  args: []
  expected: 10

invariant pprint_extra21.isrecursive.name_len:
  description: "len(pprint.isrecursive.__name__) == 11 — 'isrecursive' is 11 characters"
  category: function_identity
  kind: python_call_eq
  function: isrecursive.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# PrettyPrinter class __name__.__len__() and __qualname__.__len__()
#
# PrettyPrinter.__name__ == 'PrettyPrinter' (13 chars).
# PrettyPrinter.__qualname__ == 'PrettyPrinter' (13 chars) — same as __name__
# because the class is defined at module level (not nested).
# No prior spec verifies these lengths as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra21.PrettyPrinter.name_len:
  description: "len(pprint.PrettyPrinter.__name__) == 13 — 'PrettyPrinter' is 13 characters"
  category: class_identity
  kind: python_call_eq
  function: PrettyPrinter.__name__.__len__
  args: []
  expected: 13

invariant pprint_extra21.PrettyPrinter.qualname_len:
  description: "len(pprint.PrettyPrinter.__qualname__) == 13 — 'PrettyPrinter' is 13 characters (flat, module-level class)"
  category: class_identity
  kind: python_call_eq
  function: PrettyPrinter.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# PrettyPrinter.__init__ __name__.__len__() and __qualname__.__len__()
#
# PrettyPrinter.__init__.__name__ == '__init__' (8 chars).
# PrettyPrinter.__init__.__qualname__ == 'PrettyPrinter.__init__' (22 chars).
# No prior spec verifies these lengths as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra21.PrettyPrinter.__init__.name_len:
  description: "len(pprint.PrettyPrinter.__init__.__name__) == 8 — '__init__' is 8 characters"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.__init__.__name__.__len__
  args: []
  expected: 8

invariant pprint_extra21.PrettyPrinter.__init__.qualname_len:
  description: "len(pprint.PrettyPrinter.__init__.__qualname__) == 22 — 'PrettyPrinter.__init__' is 22 characters"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.__init__.__qualname__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# Table: module-level function __name__.__len__() cross-checks
#
# Groups __name__.__len__() for all six module-level pprint functions in one
# indexed table. Lengths vary: pprint(6), pformat(7), isreadable(10),
# isrecursive(11), saferepr(8), pp(2). Contrast with __module__.__len__()
# which is uniformly 6 for all (covered in pprint_extra20).
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra21.module_level_function_name_lengths:
  description: "pprint module-level function __name__.__len__() — varying lengths unlike the uniform __module__ length of 6"
  kind: python_call_eq
  category: function_identity
  id_prefix: pp21nln

  columns: [id, function, args, expected]
  rows:
    - [pprint_func,  pprint.__name__.__len__,      [], 6]
    - [pformat,      pformat.__name__.__len__,      [], 7]
    - [isreadable,   isreadable.__name__.__len__,   [], 10]
    - [isrecursive,  isrecursive.__name__.__len__,  [], 11]
    - [saferepr,     saferepr.__name__.__len__,      [], 8]
    - [pp,           pp.__name__.__len__,            [], 2]

# ---------------------------------------------------------------------------
# Table: PrettyPrinter method __name__.__len__() and __qualname__.__len__()
#
# Groups __name__ and __qualname__ string length checks for key PrettyPrinter
# methods in one indexed table. The dotted __qualname__ includes the class
# prefix 'PrettyPrinter.' (14 chars) so __qualname__.__len__() is always
# __name__.__len__() + 14 for non-dunder methods.
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra21.PrettyPrinter_method_name_lengths:
  description: "pprint.PrettyPrinter method __name__.__len__() and __qualname__.__len__() cross-checks"
  kind: python_call_eq
  category: function_identity
  id_prefix: pp21pmn

  columns: [id, function, args, expected]
  rows:
    - [init_name_len,          PrettyPrinter.__init__.__name__.__len__,          [], 8]
    - [init_qualname_len,      PrettyPrinter.__init__.__qualname__.__len__,      [], 22]
    - [pprint_name_len,        PrettyPrinter.pprint.__name__.__len__,            [], 6]
    - [pprint_qualname_len,    PrettyPrinter.pprint.__qualname__.__len__,        [], 20]
    - [pformat_name_len,       PrettyPrinter.pformat.__name__.__len__,           [], 7]
    - [pformat_qualname_len,   PrettyPrinter.pformat.__qualname__.__len__,       [], 21]
    - [pplist_name_len,        PrettyPrinter._pprint_list.__name__.__len__,      [], 12]
    - [pplist_qualname_len,    PrettyPrinter._pprint_list.__qualname__.__len__,  [], 26]
    - [pptuple_name_len,       PrettyPrinter._pprint_tuple.__name__.__len__,     [], 13]
    - [pptuple_qualname_len,   PrettyPrinter._pprint_tuple.__qualname__.__len__, [], 27]
    - [ppdict_name_len,        PrettyPrinter._pprint_dict.__name__.__len__,      [], 12]
    - [ppdict_qualname_len,    PrettyPrinter._pprint_dict.__qualname__.__len__,  [], 26]
    - [ppset_name_len,         PrettyPrinter._pprint_set.__name__.__len__,       [], 11]
    - [ppset_qualname_len,     PrettyPrinter._pprint_set.__qualname__.__len__,   [], 25]
