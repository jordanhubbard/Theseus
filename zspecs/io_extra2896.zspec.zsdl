    - ["io2896041", "io.RawIOBase.__dict__.__contains__",      ["__ifloordiv__"], false]
    - ["io2896042", "io.RawIOBase.__dict__.__contains__",      ["__imod__"],      false]
    - ["io2896043", "io.BufferedIOBase.__dict__.__contains__", ["__itruediv__"],  false]
    - ["io2896044", "io.BufferedIOBase.__dict__.__contains__", ["__ifloordiv__"], false]
    - ["io2896045", "io.BufferedIOBase.__dict__.__contains__", ["__imod__"],      false]
