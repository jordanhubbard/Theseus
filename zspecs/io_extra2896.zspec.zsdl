spec: io2896
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/io_extra2881.zspec.zsdl — wave 639 predecessor (covered __iadd__, __isub__, __imul__)"
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 640 theme: __itruediv__, __ifloordiv__, __imod__ dict-presence checks (in-place divide, floor-divide, modulo)."
    - "io classes are I/O stream objects, not numeric types — none define in-place arithmetic operators of any kind."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase do NOT define __itruediv__, __ifloordiv__, or __imod__."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any of these in-place division operators."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper also absent for all three."
    - "Absence is consistent across all io classes — io streams have no arithmetic semantics."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __itruediv__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io2896.itruediv:
  description: "__itruediv__ is absent from all io class __dict__s — io streams are not in-place true-division operands"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2896

  columns: [id, function, args, expected]
  rows:
    - ["io2896001", "io.IOBase.__dict__.__contains__",              ["__itruediv__"], false]
    - ["io2896002", "io.RawIOBase.__dict__.__contains__",           ["__itruediv__"], false]
    - ["io2896003", "io.BufferedIOBase.__dict__.__contains__",      ["__itruediv__"], false]
    - ["io2896004", "io.TextIOBase.__dict__.__contains__",          ["__itruediv__"], false]
    - ["io2896005", "io.BytesIO.__dict__.__contains__",             ["__itruediv__"], false]
    - ["io2896006", "io.StringIO.__dict__.__contains__",            ["__itruediv__"], false]
    - ["io2896007", "io.FileIO.__dict__.__contains__",              ["__itruediv__"], false]
    - ["io2896008", "io.BufferedReader.__dict__.__contains__",      ["__itruediv__"], false]
    - ["io2896009", "io.BufferedWriter.__dict__.__contains__",      ["__itruediv__"], false]
    - ["io2896010", "io.BufferedRandom.__dict__.__contains__",      ["__itruediv__"], false]
    - ["io2896011", "io.TextIOWrapper.__dict__.__contains__",       ["__itruediv__"], false]
    - ["io2896012", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__itruediv__"], false]

