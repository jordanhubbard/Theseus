spec: io_extra26
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra25.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __bases__[0].__name__ table; FileIO/StringIO/BytesIO base names; open.__module__; DEFAULT_BUFFER_SIZE class name"
    - "io_extra24.zspec.zsdl — covers BytesIO/StringIO/BufferedReader/BufferedWriter/TextIOWrapper/RawIOBase __name__ table and __qualname__ standalone invariants"
    - "io_extra22.zspec.zsdl — covers DEFAULT_BUFFER_SIZE and class __module__ table"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra25.zspec.zsdl."
    - "NEW: table of __qualname__ for FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper."
    - "NEW: open_code.__name__ == 'open_code'; open_code.__qualname__ == 'open_code'; open_code.__module__ == '_io'."
    - "NEW: BufferedRandom.__name__ == 'BufferedRandom'; BufferedRandom.__module__ == '_io'."
    - "io.open_code.__module__ == '_io' — open_code is a C-level builtin from the _io extension."
    - "io.BufferedRandom.__module__ == '_io' — BufferedRandom is implemented in the C extension _io."
    - "All __qualname__ values for io concrete classes equal __name__ (no nesting); verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table — FileIO, BytesIO, StringIO, BufferedReader,
#                      BufferedWriter, BufferedRandom, TextIOWrapper
#
# io_extra24 covers __qualname__ for BytesIO, StringIO, BufferedReader,
# BufferedWriter, TextIOWrapper, RawIOBase as standalone invariants.
# No prior io spec collects all seven in a single table under the extra26
# namespace, and FileIO and BufferedRandom have not appeared in any qualname
# table previously.
# ---------------------------------------------------------------------------

table io_extra26.class_qualnames:
  description: "__qualname__ for seven io concrete classes"
  kind: python_call_eq
  category: class_attrs

  columns: [id, function, args, expected]
  rows:
    - [FileIO,         FileIO.__qualname__.__eq__,         ["FileIO"],         true]
    - [BytesIO,        BytesIO.__qualname__.__eq__,        ["BytesIO"],        true]
    - [StringIO,       StringIO.__qualname__.__eq__,       ["StringIO"],       true]
    - [BufferedReader, BufferedReader.__qualname__.__eq__, ["BufferedReader"], true]
    - [BufferedWriter, BufferedWriter.__qualname__.__eq__, ["BufferedWriter"], true]
    - [BufferedRandom, BufferedRandom.__qualname__.__eq__, ["BufferedRandom"], true]
    - [TextIOWrapper,  TextIOWrapper.__qualname__.__eq__,  ["TextIOWrapper"],  true]

# ---------------------------------------------------------------------------
# open_code — __name__, __qualname__, __module__ (extra26 namespace)
#
# io.open_code is a C-level builtin; its __module__ is '_io'. No prior io
# spec covers open_code.__name__ or open_code.__qualname__ as standalone
# named invariants. io_extra25 covers open.__module__; open_code is distinct.
# ---------------------------------------------------------------------------

invariant io_extra26.open_code.name:
  description: "io.open_code.__name__ == 'open_code' — C builtin function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: open_code.__name__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra26.open_code.qualname:
  description: "io.open_code.__qualname__ == 'open_code' — qualname equals __name__ for top-level C builtins"
  category: function_attrs
  kind: python_call_eq
  function: open_code.__qualname__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra26.open_code.module:
  description: "io.open_code.__module__ == '_io' — open_code is implemented in the C extension _io"
  category: module_identity
  kind: python_call_eq
  function: open_code.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# BufferedRandom — __name__ and __module__ (extra26 namespace)
#
# No prior io spec covers BufferedRandom.__name__ or BufferedRandom.__module__
# as standalone named invariants. BufferedRandom supports both reading and
# writing and is implemented in the C extension _io.
# ---------------------------------------------------------------------------

invariant io_extra26.BufferedRandom.name:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra26.BufferedRandom.module:
  description: "io.BufferedRandom.__module__ == '_io' — BufferedRandom is implemented in the C extension _io"
  category: module_identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true
