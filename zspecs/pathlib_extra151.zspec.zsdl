spec: pathlib_extra151
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path operator method __qualname__ values and lengths, revealing that all operator dunder methods are defined on PurePath, not Path. Also covers PurePath.__str__, PurePath.__repr__, PurePath.__new__, and Path.__new__ qualnames."
    - "All operator dunders on pathlib.Path are defined on PurePath: Path.__truediv__ is PurePath.__truediv__ evaluates to True."
    - "PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' (len=20); the / path-joining operator is defined on PurePath."
    - "PurePath.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (len=21; the longest among the operator method qualnames due to the 'r' prefix)."
    - "PurePath.__eq__.__qualname__ == 'PurePath.__eq__' (len=15); PurePath.__lt__/__le__/__gt__/__ge__ all have qualname len=15 as well (all share the 'PurePath.__xx__' pattern with 6-char dunder names)."
    - "PurePath.__hash__.__qualname__ == 'PurePath.__hash__' (len=17; 2 characters longer than the comparison operators because 'hash' has 4 chars while 'eq'/'lt'/'le'/'gt'/'ge' all have 2 chars)."
    - "PurePath.__str__.__qualname__ == 'PurePath.__str__' (len=16); PurePath.__repr__.__qualname__ == 'PurePath.__repr__' (len=17; tied with __hash__)."
    - "PurePath.__new__.__qualname__ == 'PurePath.__new__' (len=16); Path.__new__.__qualname__ == 'Path.__new__' (len=12; Path does define its own __new__, unlike __init__ which is inherited from PurePath)."
    - "All operator and special methods have __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath comparison operator __qualname__ values
# __eq__, __lt__, __le__, __gt__, __ge__: all have qualname 'PurePath.__xx__' with len=15.
# __hash__: 'PurePath.__hash__' with len=17 (4-char method name vs 2-char for comparison ops).
# All are defined on PurePath, so Path.xxx.__qualname__ == PurePath.xxx.__qualname__.
# ---------------------------------------------------------------------------

table pathlib_extra151.PurePath_comparison_qualnames:
  description: "pathlib.PurePath comparison operator __qualname__ values: __eq__/__lt__/__le__/__gt__/__ge__=len15, __hash__=len17; all follow 'PurePath.__xx__' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibop151

  columns: [id, function, args, expected, description]
  rows:
    - [eq_qeq,   PurePath.__eq__.__qualname__.__eq__,   ["PurePath.__eq__"],  true, "pathlib.PurePath.__eq__.__qualname__ == 'PurePath.__eq__' (equality comparison; defined on PurePath for case-sensitive path comparison)"]
    - [eq_qlen,  PurePath.__eq__.__qualname__.__len__,  [],                    15,   "pathlib.PurePath.__eq__.__qualname__.__len__() == 15 ('PurePath.__eq__' has 15 characters)"]
    - [lt_qeq,   PurePath.__lt__.__qualname__.__eq__,   ["PurePath.__lt__"],  true, "pathlib.PurePath.__lt__.__qualname__ == 'PurePath.__lt__' (less-than; enables pathlib paths to be sorted)"]
    - [lt_qlen,  PurePath.__lt__.__qualname__.__len__,  [],                    15,   "pathlib.PurePath.__lt__.__qualname__.__len__() == 15 (tied with __eq__, __le__, __gt__, __ge__)"]
    - [le_qeq,   PurePath.__le__.__qualname__.__eq__,   ["PurePath.__le__"],  true, "pathlib.PurePath.__le__.__qualname__ == 'PurePath.__le__'"]
    - [le_qlen,  PurePath.__le__.__qualname__.__len__,  [],                    15,   "pathlib.PurePath.__le__.__qualname__.__len__() == 15"]
    - [gt_qeq,   PurePath.__gt__.__qualname__.__eq__,   ["PurePath.__gt__"],  true, "pathlib.PurePath.__gt__.__qualname__ == 'PurePath.__gt__'"]
    - [gt_qlen,  PurePath.__gt__.__qualname__.__len__,  [],                    15,   "pathlib.PurePath.__gt__.__qualname__.__len__() == 15"]
    - [ge_qeq,   PurePath.__ge__.__qualname__.__eq__,   ["PurePath.__ge__"],  true, "pathlib.PurePath.__ge__.__qualname__ == 'PurePath.__ge__'"]
    - [hash_qeq, PurePath.__hash__.__qualname__.__eq__, ["PurePath.__hash__"],true, "pathlib.PurePath.__hash__.__qualname__ == 'PurePath.__hash__' (len=17; 2 chars longer than comparison ops because 'hash' is 4 chars vs 'eq'/'lt' etc. at 2 chars)"]
    - [hash_qlen,PurePath.__hash__.__qualname__.__len__,[],                    17,   "pathlib.PurePath.__hash__.__qualname__.__len__() == 17 ('PurePath.__hash__' has 17 characters)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath division operators (__truediv__, __rtruediv__)
# __truediv__: 'PurePath.__truediv__' (len=20); the / path-joining operator.
# __rtruediv__: 'PurePath.__rtruediv__' (len=21); the reflected / operator (e.g., 'base' / path).
# Both are defined on PurePath and inherited by Path: Path.__truediv__ is PurePath.__truediv__.
# ---------------------------------------------------------------------------

table pathlib_extra151.PurePath_division_qualnames:
  description: "pathlib.PurePath.__truediv__='PurePath.__truediv__' (len=20), __rtruediv__='PurePath.__rtruediv__' (len=21); both inherited by Path"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibop151

  columns: [id, function, args, expected, description]
  rows:
    - [tdiv_qeq,   PurePath.__truediv__.__qualname__.__eq__,   ["PurePath.__truediv__"],  true, "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' (the / operator for path joining: Path('/usr') / 'bin' returns Path('/usr/bin'))"]
    - [tdiv_qlen,  PurePath.__truediv__.__qualname__.__len__,  [],                         20,   "pathlib.PurePath.__truediv__.__qualname__.__len__() == 20 ('PurePath.__truediv__' has 20 characters)"]
    - [rtdiv_qeq,  PurePath.__rtruediv__.__qualname__.__eq__,  ["PurePath.__rtruediv__"], true, "pathlib.PurePath.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (the reflected / operator: '/usr' / Path('bin') triggers __rtruediv__ on the right-hand Path)"]
    - [rtdiv_qlen, PurePath.__rtruediv__.__qualname__.__len__, [],                         21,   "pathlib.PurePath.__rtruediv__.__qualname__.__len__() == 21 ('PurePath.__rtruediv__' is the longest operator method qualname: 'r' prefix adds 1 character vs __truediv__)"]
    - [tdiv_mod,   PurePath.__truediv__.__module__.__eq__,     ["pathlib"],                true, "pathlib.PurePath.__truediv__.__module__ == 'pathlib'"]
    - [rtdiv_mod,  PurePath.__rtruediv__.__module__.__eq__,    ["pathlib"],                true, "pathlib.PurePath.__rtruediv__.__module__ == 'pathlib'"]

# ---------------------------------------------------------------------------
# pathlib PurePath.__str__, PurePath.__repr__, PurePath.__new__, Path.__new__
# PurePath.__str__: 'PurePath.__str__' (len=16).
# PurePath.__repr__: 'PurePath.__repr__' (len=17; tied with __hash__).
# PurePath.__new__: 'PurePath.__new__' (len=16; tied with __str__).
# Path.__new__: 'Path.__new__' (len=12; Path defines its own __new__ unlike __init__).
# ---------------------------------------------------------------------------

table pathlib_extra151.PurePath_str_repr_new_qualnames:
  description: "pathlib PurePath.__str__='PurePath.__str__'(16), PurePath.__repr__='PurePath.__repr__'(17), PurePath.__new__='PurePath.__new__'(16), Path.__new__='Path.__new__'(12)"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibop151

  columns: [id, function, args, expected, description]
  rows:
    - [str_qeq,       PurePath.__str__.__qualname__.__eq__,   ["PurePath.__str__"],   true, "pathlib.PurePath.__str__.__qualname__ == 'PurePath.__str__' (returns the string form of the path; Path inherits __str__ from PurePath)"]
    - [str_qlen,      PurePath.__str__.__qualname__.__len__,  [],                      16,   "pathlib.PurePath.__str__.__qualname__.__len__() == 16 ('PurePath.__str__' has 16 characters)"]
    - [repr_qeq,      PurePath.__repr__.__qualname__.__eq__,  ["PurePath.__repr__"],  true, "pathlib.PurePath.__repr__.__qualname__ == 'PurePath.__repr__' (returns e.g. \"PosixPath('/usr/bin')\")"]
    - [repr_qlen,     PurePath.__repr__.__qualname__.__len__, [],                      17,   "pathlib.PurePath.__repr__.__qualname__.__len__() == 17 ('PurePath.__repr__' has 17 characters; tied with __hash__)"]
    - [pp_new_qeq,    PurePath.__new__.__qualname__.__eq__,   ["PurePath.__new__"],   true, "pathlib.PurePath.__new__.__qualname__ == 'PurePath.__new__' (PurePath defines __new__ for path construction)"]
    - [pp_new_qlen,   PurePath.__new__.__qualname__.__len__,  [],                      16,   "pathlib.PurePath.__new__.__qualname__.__len__() == 16 ('PurePath.__new__' has 16 characters; tied with __str__)"]
    - [path_new_qeq,  Path.__new__.__qualname__.__eq__,       ["Path.__new__"],        true, "pathlib.Path.__new__.__qualname__ == 'Path.__new__' (Path defines its own __new__, unlike __init__ which is inherited from PurePath; this is how Path selects PosixPath vs WindowsPath at construction time)"]
    - [path_new_qlen, Path.__new__.__qualname__.__len__,      [],                      12,   "pathlib.Path.__new__.__qualname__.__len__() == 12 ('Path.__new__' has 12 characters; shorter than PurePath.__new__ (16) because 'Path' is 4 chars vs 'PurePath' is 8)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra151.PurePath.__truediv__qualname_eq:
  description: "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' (len=20) — the / operator for path joining (e.g., Path('/usr') / 'bin') is defined on PurePath. Path.__truediv__ is PurePath.__truediv__ evaluates to True, confirming that Path inherits this operator without overriding it."
  category: qualname
  kind: python_call_eq
  function: PurePath.__truediv__.__qualname__.__eq__
  args: ["PurePath.__truediv__"]
  expected: true

invariant pathlib_extra151.PurePath.__rtruediv__qualname_len_21:
  description: "pathlib.PurePath.__rtruediv__.__qualname__.__len__() == 21 ('PurePath.__rtruediv__' has 21 characters; the longest operator qualname in pathlib; the 'r' prefix for the reflected division operator adds 1 character vs __truediv__ (20))"
  category: qualname
  kind: python_call_eq
  function: PurePath.__rtruediv__.__qualname__.__len__
  args: []
  expected: 21

invariant pathlib_extra151.PurePath.__eq__qualname_len_15:
  description: "pathlib.PurePath.__eq__.__qualname__.__len__() == 15 ('PurePath.__eq__' has 15 characters; all five comparison operators __eq__, __lt__, __le__, __gt__, __ge__ share this length because their method names are all 2-character abbreviations wrapped in double underscores: '__xx__' is 6 chars)"
  category: qualname
  kind: python_call_eq
  function: PurePath.__eq__.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra151.PurePath.__hash__qualname_len_17:
  description: "pathlib.PurePath.__hash__.__qualname__.__len__() == 17 ('PurePath.__hash__' has 17 characters; 2 characters longer than the comparison operators (15) because 'hash' is 4 characters while 'eq', 'lt', 'le', 'gt', 'ge' are all 2 characters)"
  category: qualname
  kind: python_call_eq
  function: PurePath.__hash__.__qualname__.__len__
  args: []
  expected: 17

invariant pathlib_extra151.Path.__new__qualname_neq_PurePath:
  description: "pathlib.Path.__new__.__qualname__ == 'Path.__new__' (not 'PurePath.__new__') — Path overrides __new__ to select the correct concrete subclass (PosixPath on POSIX, WindowsPath on Windows) at instantiation time; this contrasts with __init__ which is NOT overridden by Path (Path.__init__.__qualname__ == 'PurePath.__init__')"
  category: qualname
  kind: python_call_eq
  function: Path.__new__.__qualname__.__eq__
  args: ["Path.__new__"]
  expected: true

invariant pathlib_extra151.PurePath.__str__qualname_len_16:
  description: "pathlib.PurePath.__str__.__qualname__.__len__() == 16 ('PurePath.__str__' has 16 characters; tied with PurePath.__new__ (16); both are longer than Path.__new__ (12) and shorter than PurePath.__repr__ (17) and PurePath.__hash__ (17))"
  category: qualname
  kind: python_call_eq
  function: PurePath.__str__.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra151.PurePath.__lt__module_eq_pathlib:
  description: "pathlib.PurePath.__lt__.__module__ == 'pathlib' — all pathlib operator methods have __module__ == 'pathlib'; this is consistent with their Python-level implementation in Lib/pathlib/_abc.py or Lib/pathlib/_local.py, which are part of the pathlib package"
  category: qualname
  kind: python_call_eq
  function: PurePath.__lt__.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra151.PurePath.__repr__qualname_len_17:
  description: "pathlib.PurePath.__repr__.__qualname__.__len__() == 17 ('PurePath.__repr__' has 17 characters; tied with PurePath.__hash__ at 17; both are 1 character longer than PurePath.__str__ (16) and PurePath.__new__ (16), because 'repr' and 'hash' are each 4 characters while 'str' and 'new' are 3 characters)"
  category: qualname
  kind: python_call_eq
  function: PurePath.__repr__.__qualname__.__len__
  args: []
  expected: 17

