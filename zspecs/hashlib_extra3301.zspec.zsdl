spec: hl3301
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (hl3301): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for hashlib types."
    - "Theme: __itruediv__/__ifloordiv__/__imod__ dict-presence (in-place /=, //=, %=)."
    - "All values False — hash objects do not define in-place division or modulo protocol methods in their own __dict__."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __itruediv__, __ifloordiv__, or __imod__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3301.itruediv:
  description: "hashlib types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3301
  columns: [id, function, args, expected]
  rows:
    - ["hl3301001", operator.contains, [type(hashlib.md5()).__dict__,        "__itruediv__"], false]
    - ["hl3301002", operator.contains, [type(hashlib.sha1()).__dict__,       "__itruediv__"], false]
    - ["hl3301003", operator.contains, [type(hashlib.sha256()).__dict__,     "__itruediv__"], false]
    - ["hl3301004", operator.contains, [type(hashlib.sha512()).__dict__,     "__itruediv__"], false]
    - ["hl3301005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__itruediv__"], false]

