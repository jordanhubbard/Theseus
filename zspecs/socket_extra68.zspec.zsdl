spec: socket_extra68
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra67.zspec.zsdl — covers socket.accept/__kwdefaults__/__class__/__name__=='NoneType' / socket.makefile/__kwdefaults__/__class__/__name__=='NoneType' / socket.setblocking/__kwdefaults__/__class__/__name__=='NoneType' / gethostname/__class__/__name__=='builtin_function_or_method' / gethostname/__module__.__eq__('socket') / gethostbyname/__class__/__name__=='builtin_function_or_method' / gethostbyname/__module__.__eq__('socket') / getfqdn/__class__/__name__=='function' / getfqdn/__module__.__eq__('socket') / getfqdn/__qualname__.__eq__('getfqdn') / getfqdn/__code__.co_name.__eq__('getfqdn') / getfqdn/__defaults__/__class__/__name__=='tuple' / getfqdn/__defaults__/__len__()==1 (table + invariants)."
    - "socket_extra66.zspec.zsdl — covers socket.socket/__name__/__module__/__qualname__=='socket' / socket.socket/__bases__[0].__name__=='object' / socket.socket/__mro__/__len__()==2 / accept/__defaults__/__class__/__name__=='NoneType' / makefile/__defaults__/__class__/__name__=='tuple' / makefile/__defaults__/__len__()==2 / setblocking/__defaults__/__class__/__name__=='NoneType' / settimeout/__defaults__/__class__/__name__=='NoneType' (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra67; it does NOT duplicate invariants present in those files."
    - "Wave 235 theme: socket.socket C method descriptors (connect/bind/sendall/recv) class and qualname identity + socket.socket.__doc__ docstring identity."
    - "In python_module(socket) backend, 'socket' in the module namespace refers to the socket.socket class. So 'socket.connect' means 'socket.socket.connect'."
    - "socket.socket.connect.__class__.__name__ == 'method_descriptor' — socket.socket.connect is a C method defined in the _socket C extension; unbound C methods on C types have __class__.__name__ 'method_descriptor'. No prior socket spec checks socket.connect.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__class__.__name__ == 'method_descriptor' — same reasoning as connect. No prior socket spec checks socket.bind.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__class__.__name__ == 'method_descriptor' — same reasoning. No prior socket spec checks socket.sendall.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__class__.__name__ == 'method_descriptor' — same reasoning. No prior socket spec checks socket.recv.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — C method_descriptors on C types have __qualname__ of the form 'TypeName.methodname'; for socket.connect the qualname is 'socket.connect'. No prior socket spec checks socket.connect.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — qualname is 'socket.bind'. No prior socket spec checks socket.bind.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__qualname__ == 'socket.sendall' — qualname is 'socket.sendall'. No prior socket spec checks socket.sendall.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv' — qualname is 'socket.recv'. No prior socket spec checks socket.recv.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__.__len__() == 14 — 'socket.connect': s(1)o(2)c(3)k(4)e(5)t(6).(7)c(8)o(9)n(10)n(11)e(12)c(13)t(14) = 14. No prior socket spec checks socket.connect.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__.__len__() == 11 — 'socket.bind': s-o-c-k-e-t = 6, . = 1, b-i-n-d = 4, total = 11. No prior socket spec checks socket.bind.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__qualname__.__len__() == 15 — 'socket.sendall': s-o-c-k-e-t = 6, . = 1, s-e-n-d-a-l-l = 7, total = 14... wait: s(1)o(2)c(3)k(4)e(5)t(6).(7)s(8)e(9)n(10)d(11)a(12)l(13)l(14) = 14. Let me recount: 'socket.sendall' = 6+1+7 = 14 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__.__len__() == 11 — 'socket.recv': s-o-c-k-e-t = 6, . = 1, r-e-c-v = 4, total = 11. No prior socket spec checks socket.recv.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__.__class__.__name__ == 'str' — socket.socket has a docstring explaining the socket class; __doc__.__class__.__name__ is 'str'. No prior socket spec checks socket.__doc__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__.__contains__('socket') == True — the docstring for socket.socket references 'socket'. No prior socket spec checks socket.__doc__.__contains__('socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.connect / bind / sendall / recv __class__.__name__ == 'method_descriptor'
#
# Wave 235 theme: socket C method descriptors — class identity.
#
# socket.socket.connect, bind, sendall, and recv are C methods defined in the
# _socket C extension. Unbound C methods on C extension types have
# __class__.__name__ == 'method_descriptor'. No prior socket spec checks
# __class__.__name__ for any of these four methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra68.C_method_classes:
  description: "socket.connect/__class__/__name__=='method_descriptor' / socket.bind/__class__/__name__=='method_descriptor' / socket.sendall/__class__/__name__=='method_descriptor' / socket.recv/__class__/__name__=='method_descriptor' — connect/bind/sendall/recv are C methods from the _socket extension; unbound C methods on C types have __class__.__name__=='method_descriptor'; no prior socket spec checks __class__/__name__ for these four methods; first C method descriptor class identity anchor for socket.socket core methods"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketmore68

  columns: [id, function, args, expected]
  rows:
    - [socket_connect_class_method_descriptor, socket.connect.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [socket_bind_class_method_descriptor,    socket.bind.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [socket_sendall_class_method_descriptor, socket.sendall.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [socket_recv_class_method_descriptor,    socket.recv.__class__.__name__.__eq__,    ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# socket.socket.connect / bind / sendall / recv __qualname__ equality
#
# Wave 235 theme: socket C method descriptors — qualname string equality.
#
# C method descriptors on C types have __qualname__ of the form
# 'TypeName.methodname'. For socket.socket, the type name exposed in the
# socket module namespace is 'socket', so qualnames are 'socket.connect',
# 'socket.bind', 'socket.sendall', and 'socket.recv'. No prior socket spec
# checks __qualname__ for any of these four methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra68.C_method_qualnames:
  description: "socket.connect/__qualname__.__eq__('socket.connect')==True / socket.bind/__qualname__.__eq__('socket.bind')==True / socket.sendall/__qualname__.__eq__('socket.sendall')==True / socket.recv/__qualname__.__eq__('socket.recv')==True — C method descriptors on the socket.socket type have __qualname__ 'TypeName.methodname'; the type is named 'socket' in the module namespace; no prior socket spec checks __qualname__ for connect/bind/sendall/recv; first qualname equality anchor for these four socket.socket C methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore68

  columns: [id, function, args, expected]
  rows:
    - [socket_connect_qualname_eq, socket.connect.__qualname__.__eq__, ["socket.connect"], true]
    - [socket_bind_qualname_eq,    socket.bind.__qualname__.__eq__,    ["socket.bind"],    true]
    - [socket_sendall_qualname_eq, socket.sendall.__qualname__.__eq__, ["socket.sendall"], true]
    - [socket_recv_qualname_eq,    socket.recv.__qualname__.__eq__,    ["socket.recv"],    true]

# ---------------------------------------------------------------------------
# socket.socket.connect / bind / sendall / recv __qualname__.__len__()
#
# Wave 235 theme: socket C method descriptors — qualname length values.
#
# 'socket.connect' = 14 chars, 'socket.bind' = 11 chars,
# 'socket.sendall' = 14 chars, 'socket.recv' = 11 chars.
# No prior socket spec checks __qualname__.__len__() for any of these methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra68.C_method_qualname_lengths:
  description: "socket.connect/__qualname__/__len__()==14 / socket.bind/__qualname__/__len__()==11 / socket.sendall/__qualname__/__len__()==14 / socket.recv/__qualname__/__len__()==11 — 'socket.connect'=14 chars; 'socket.bind'=11 chars; 'socket.sendall'=14 chars; 'socket.recv'=11 chars; no prior socket spec checks __qualname__/__len__() for connect/bind/sendall/recv; first qualname length anchor for these four C methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore68

  columns: [id, function, args, expected]
  rows:
    - [socket_connect_qualname_len_14, socket.connect.__qualname__.__len__, [], 14]
    - [socket_bind_qualname_len_11,    socket.bind.__qualname__.__len__,    [], 11]
    - [socket_sendall_qualname_len_14, socket.sendall.__qualname__.__len__, [], 14]
    - [socket_recv_qualname_len_11,    socket.recv.__qualname__.__len__,    [], 11]

# ---------------------------------------------------------------------------
# socket.socket.__doc__ docstring class and content
#
# Wave 235 theme: socket.socket docstring identity.
#
# socket.socket has a docstring that describes the socket class. Its __doc__
# is a str and the docstring references 'socket'. No prior socket spec checks
# socket.__doc__.__class__.__name__ or socket.__doc__.__contains__('socket').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra68.socket_doc_identity:
  description: "socket.socket/__doc__/__class__/__name__=='str' / socket.socket/__doc__.__contains__('socket')==True — socket.socket has a docstring; __doc__ is a str; the docstring references 'socket'; no prior socket spec checks socket.__doc__/__class__/__name__ or socket.__doc__.__contains__('socket'); first docstring identity anchor for socket.socket class"
  kind: python_call_eq
  category: docstrings
  id_prefix: socketmore68

  columns: [id, function, args, expected]
  rows:
    - [socket_doc_class_str,         socket.__doc__.__class__.__name__.__eq__, ["str"],    true]
    - [socket_doc_contains_socket,   socket.__doc__.__contains__,              ["socket"], true]

# ---------------------------------------------------------------------------
# socket.socket.connect.__class__.__name__.__eq__('method_descriptor') — standalone
#
# socket.socket.connect is a C method descriptor on the socket.socket C type.
# Its __class__.__name__ is 'method_descriptor'. No prior socket spec checks
# socket.connect.__class__.__name__. First C method descriptor class identity
# standalone for socket.socket.connect.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra68.socket_connect_method_descriptor:
  description: "socket.socket.connect.__class__.__name__.__eq__('method_descriptor') == True — socket.connect is a C method from the _socket extension; __class__.__name__ is 'method_descriptor'; no prior socket spec checks socket.connect.__class__.__name__; first C method descriptor class identity standalone for socket.socket.connect"
  category: class_identity
  kind: python_call_eq
  function: socket.connect.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__eq__('socket.connect') — standalone
#
# socket.socket.connect is a C method descriptor. Its __qualname__ is
# 'socket.connect'. No prior socket spec checks socket.connect.__qualname__.
# First qualname equality standalone for socket.socket.connect.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra68.socket_connect_qualname_socket_connect:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — connect is a C method descriptor; __qualname__ is 'socket.connect'; no prior socket spec checks socket.connect.__qualname__; first qualname equality standalone for socket.socket.connect"
  category: qualnames
  kind: python_call_eq
  function: socket.connect.__qualname__.__eq__
  args: ["socket.connect"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.bind.__qualname__.__len__() == 11 — standalone
#
# socket.socket.bind.__qualname__ is 'socket.bind': 6+1+4 = 11 characters.
# No prior socket spec checks socket.bind.__qualname__.__len__(). First
# qualname length standalone for socket.socket.bind.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra68.socket_bind_qualname_len_11:
  description: "socket.socket.bind.__qualname__.__len__() == 11 — 'socket.bind' is 11 characters (socket=6, .=1, bind=4); no prior socket spec checks socket.bind.__qualname__.__len__(); first qualname length standalone for socket.socket.bind"
  category: qualnames
  kind: python_call_eq
  function: socket.bind.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# socket.socket.sendall.__qualname__.__len__() == 14 — standalone
#
# socket.socket.sendall.__qualname__ is 'socket.sendall': 6+1+7 = 14 chars.
# No prior socket spec checks socket.sendall.__qualname__.__len__(). First
# qualname length standalone for socket.socket.sendall.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra68.socket_sendall_qualname_len_14:
  description: "socket.socket.sendall.__qualname__.__len__() == 14 — 'socket.sendall' is 14 characters (socket=6, .=1, sendall=7); no prior socket spec checks socket.sendall.__qualname__.__len__(); first qualname length standalone for socket.socket.sendall"
  category: qualnames
  kind: python_call_eq
  function: socket.sendall.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# socket.socket.__doc__.__contains__('socket') == True — standalone
#
# socket.socket has a docstring that describes the socket class and references
# 'socket'. No prior socket spec checks socket.__doc__.__contains__('socket').
# First docstring content standalone for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra68.socket_doc_socket:
  description: "socket.socket.__doc__.__contains__('socket') == True — socket.socket has a docstring that references 'socket'; no prior socket spec checks socket.__doc__.__contains__('socket'); first docstring content standalone for socket.socket class"
  category: docstrings
  kind: python_call_eq
  function: socket.__doc__.__contains__
  args: ["socket"]
  expected: true
