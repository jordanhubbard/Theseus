spec: typing_extra27
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra26.zspec.zsdl."
    - "Focus: __qualname__ values for typing class method qualnames (TypeVar.__or__, Generic.__class_getitem__, Generic.__init_subclass__, Protocol.__init_subclass__) and additional class qualnames (Protocol, NamedTuple, TypedDict, Any) not yet combined in the extra27 namespace."
    - "typing_extra22 covers Generic.__qualname__.__eq__ and a combined table for Generic/TypeVar/ParamSpec/TypeVarTuple qualnames."
    - "typing_extra26 covers TypeVar.__repr__.__qualname__ and module-level function qualnames in the extra26 namespace."
    - "No prior typing spec records TypeVar.__or__.__qualname__, Generic.__class_getitem__.__qualname__, Generic.__init_subclass__.__qualname__, or Protocol.__init_subclass__.__qualname__ in any invariant or table."
    - "No prior typing spec has a combined table of Protocol/NamedTuple/TypedDict/Any __qualname__.__eq__ in the extra27 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typing class method __qualname__ values — combined table
#
# TypeVar.__or__ was added in Python 3.10 (PEP 604 union syntax).
# Generic.__class_getitem__ and Generic.__init_subclass__ are defined directly
# on Generic. Protocol.__init_subclass__ is defined on Protocol.
# No prior typing spec records any of these method qualnames.
# ---------------------------------------------------------------------------

table typing_extra27.class_method_qualnames:
  description: "__qualname__.__eq__ for typing class methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [TypeVar_or,                 "TypeVar.__or__.__qualname__.__eq__",                 ["TypeVar.__or__"],                 true]
    - [Generic_class_getitem,      "Generic.__class_getitem__.__qualname__.__eq__",      ["Generic.__class_getitem__"],      true]
    - [Generic_init_subclass,      "Generic.__init_subclass__.__qualname__.__eq__",      ["Generic.__init_subclass__"],      true]
    - [Protocol_init_subclass,     "Protocol.__init_subclass__.__qualname__.__eq__",     ["Protocol.__init_subclass__"],     true]

# ---------------------------------------------------------------------------
# typing class method __qualname__.__len__() values — combined table
#
# Verifies the string length of each method __qualname__:
#   TypeVar.__or__ -> 14
#   Generic.__class_getitem__ -> 25
#   Generic.__init_subclass__ -> 25
#   Protocol.__init_subclass__ -> 26
# No prior typing spec collects these method qualname lengths together.
# ---------------------------------------------------------------------------

table typing_extra27.class_method_qualname_lens:
  description: "__qualname__.__len__() for typing class methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [TypeVar_or,             "TypeVar.__or__.__qualname__.__len__",             [], 14]
    - [Generic_class_getitem,  "Generic.__class_getitem__.__qualname__.__len__",  [], 25]
    - [Generic_init_subclass,  "Generic.__init_subclass__.__qualname__.__len__",  [], 25]
    - [Protocol_init_subclass, "Protocol.__init_subclass__.__qualname__.__len__", [], 26]

# ---------------------------------------------------------------------------
# Combined __qualname__ table for Protocol, NamedTuple, TypedDict, Any
#
# typing_extra22 covers Generic/TypeVar/ParamSpec/TypeVarTuple in a combined
# table. typing_extra19 covers TypedDict/__qualname__.__eq__ and
# NamedTuple/__qualname__.__eq__ individually. No prior spec has Protocol,
# NamedTuple, TypedDict, and Any together in a single table in the extra27
# namespace.
# Any.__qualname__ == 'Any' (it is a _SpecialForm with __qualname__ set).
# ---------------------------------------------------------------------------

table typing_extra27.class_qualnames:
  description: "__qualname__.__eq__ for typing.Protocol, NamedTuple, TypedDict, Any"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Protocol,   Protocol.__qualname__.__eq__,   ["Protocol"],   true]
    - [NamedTuple, NamedTuple.__qualname__.__eq__,  ["NamedTuple"], true]
    - [TypedDict,  TypedDict.__qualname__.__eq__,   ["TypedDict"],  true]
    - [Any,        Any.__qualname__.__eq__,         ["Any"],        true]

# ---------------------------------------------------------------------------
# Combined __qualname__.__len__() table for Protocol, NamedTuple, TypedDict, Any
#
# Verifies the string length of each class __qualname__:
#   Protocol -> 8, NamedTuple -> 10, TypedDict -> 9, Any -> 3
# No prior typing spec collects these four qualname lengths together.
# ---------------------------------------------------------------------------

table typing_extra27.class_qualname_lens:
  description: "__qualname__.__len__() for typing.Protocol, NamedTuple, TypedDict, Any"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Protocol,   Protocol.__qualname__.__len__,  [],  8]
    - [NamedTuple, NamedTuple.__qualname__.__len__, [], 10]
    - [TypedDict,  TypedDict.__qualname__.__len__,  [],  9]
    - [Any,        Any.__qualname__.__len__,        [],  3]
