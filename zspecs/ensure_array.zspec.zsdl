spec: ensure_array
version: ">=1.0.0"
backend: node(ensure-array)

docs: https://www.npmjs.com/package/ensure-array

provenance:
  derived_from:
    - "ensure-array README — https://www.npmjs.com/package/ensure-array"
    - "Test vectors verified with ensure-array via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "ensure-array source"
  notes:
    - "ensure-array is an npm package. Install: npm install ensure-array"
    - "Returns the value unchanged if it's already an array; otherwise wraps it in an array. null/undefined returns []."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ensure_array.wrap:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: ensarr

  columns: [id, args, expected]
  rows:
    - [scalar,  [1],          [1]]
    - [string,  ["hello"],    ["hello"]]
    - [already, [[1, 2, 3]],  [1, 2, 3]]
    - [null_v,  [null],       []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:39:09Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
