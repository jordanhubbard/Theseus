spec: threading_extra2731
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol — used by math.trunc(), math.floor(), math.ceil())."
    - "threading.Thread is a runnable object; it does not define numeric rounding protocols."
    - "threading.Lock (accessed as threading.Lock, actual type is _thread.lock) is a synchronization primitive; it defines acquire/release but not __trunc__, __floor__, or __ceil__."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore are synchronization primitives; none define __trunc__, __floor__, or __ceil__."
    - "threading.Timer is a Thread subclass for deferred execution; it defines none of these numeric rounding protocols."
    - "threading.Barrier is a synchronization barrier; it does not define __trunc__, __floor__, or __ceil__."
    - "threading.local is a thread-local storage object; it does not define numeric rounding protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all threading synchronization types
# ---------------------------------------------------------------------------

table threading_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all threading type __dict__s — synchronization primitives do not implement numeric truncation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2731

  columns: [id, function, args, expected]
  rows:
    - ["th2731001", "threading.Thread.__dict__.__contains__",           ["__trunc__"], false]
    - ["th2731002", "threading.Lock.__dict__.__contains__",             ["__trunc__"], false]
    - ["th2731003", "threading.Event.__dict__.__contains__",            ["__trunc__"], false]
    - ["th2731004", "threading.Condition.__dict__.__contains__",        ["__trunc__"], false]
    - ["th2731005", "threading.Semaphore.__dict__.__contains__",        ["__trunc__"], false]
    - ["th2731006", "threading.BoundedSemaphore.__dict__.__contains__", ["__trunc__"], false]
    - ["th2731007", "threading.Timer.__dict__.__contains__",            ["__trunc__"], false]
    - ["th2731008", "threading.Barrier.__dict__.__contains__",          ["__trunc__"], false]
    - ["th2731009", "threading.local.__dict__.__contains__",            ["__trunc__"], false]

