spec: decimal_extra103
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra102.zspec.zsdl."
    - "This spec covers: decimal.Decimal arithmetic operator __qualname__ values and lengths for __sub__, __abs__, __neg__, __pos__, __mod__, __pow__, __floordiv__, __radd__, __mul__."
    - "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (length 15)."
    - "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' (length 15)."
    - "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (length 15)."
    - "decimal.Decimal.__pos__.__qualname__ == 'Decimal.__pos__' (length 15)."
    - "decimal.Decimal.__mod__.__qualname__ == 'Decimal.__mod__' (length 15)."
    - "decimal.Decimal.__pow__.__qualname__ == 'Decimal.__pow__' (length 15)."
    - "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (length 15)."
    - "The 7 operators above all have qualname length 15: 'Decimal.' (8) + '__XXX__' (7 = 2+3+2)."
    - "decimal.Decimal.__floordiv__.__qualname__ == 'Decimal.__floordiv__' (length 20)."
    - "decimal.Decimal.__radd__.__qualname__ == 'Decimal.__radd__' (length 16)."
    - "type(decimal.Decimal.__sub__).__name__ == 'wrapper_descriptor' (C extension slot wrapper)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal 3-char arithmetic operator __qualname__ string equality
# __sub__, __abs__, __neg__, __pos__, __mod__, __pow__, __mul__ are wrapper_descriptor
# objects. Each qualname is 'Decimal.<dunder>' with length 15:
# 'Decimal.' (8 chars) + '__XXX__' (7 chars = 2 underscores + 3 chars + 2 underscores).
# ---------------------------------------------------------------------------

table decimal_extra103.Decimal_arith_operator_qualnames:
  description: "decimal.Decimal arithmetic operator __qualname__: __sub__/__abs__/__neg__/__pos__/__mod__/__pow__/__mul__ all equal 'Decimal.__XXX__' (length 15)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decarith103a

  columns: [id, function, args, expected, description]
  rows:
    - [dec_sub_qn,  "Decimal.__sub__.__qualname__.__eq__", ["Decimal.__sub__"], true,  "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__'"]
    - [dec_abs_qn,  "Decimal.__abs__.__qualname__.__eq__", ["Decimal.__abs__"], true,  "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__'"]
    - [dec_neg_qn,  "Decimal.__neg__.__qualname__.__eq__", ["Decimal.__neg__"], true,  "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__'"]
    - [dec_pos_qn,  "Decimal.__pos__.__qualname__.__eq__", ["Decimal.__pos__"], true,  "decimal.Decimal.__pos__.__qualname__ == 'Decimal.__pos__'"]
    - [dec_mod_qn,  "Decimal.__mod__.__qualname__.__eq__", ["Decimal.__mod__"], true,  "decimal.Decimal.__mod__.__qualname__ == 'Decimal.__mod__'"]
    - [dec_pow_qn,  "Decimal.__pow__.__qualname__.__eq__", ["Decimal.__pow__"], true,  "decimal.Decimal.__pow__.__qualname__ == 'Decimal.__pow__'"]
    - [dec_mul_qn,  "Decimal.__mul__.__qualname__.__eq__", ["Decimal.__mul__"], true,  "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__'"]
    - [dec_sub_ne_abs, "Decimal.__sub__.__qualname__.__eq__", ["Decimal.__abs__"], false, "decimal.Decimal.__sub__.__qualname__ != 'Decimal.__abs__' (__sub__ and __abs__ are distinct operators)"]

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic operator __qualname__ lengths
# All 3-char dunder names (__sub__, __abs__, __neg__, __pos__, __mod__, __pow__, __mul__)
# have qualname length 15. __floordiv__ has length 20; __radd__ has length 16.
# ---------------------------------------------------------------------------

table decimal_extra103.Decimal_arith_operator_qualname_lengths:
  description: "decimal.Decimal arithmetic operator __qualname__ lengths: __sub__/__abs__/__neg__/__pos__/__mod__/__pow__/__mul__ all length 15; __floordiv__ length 20; __radd__ length 16"
  kind: python_call_eq
  category: qualnames
  id_prefix: decarith103b

  columns: [id, function, args, expected, description]
  rows:
    - [dec_sub_qn_len,      "Decimal.__sub__.__qualname__.__len__",      [], 15, "decimal.Decimal.__sub__.__qualname__.__len__() == 15 ('Decimal.__sub__' has 15 chars)"]
    - [dec_abs_qn_len,      "Decimal.__abs__.__qualname__.__len__",      [], 15, "decimal.Decimal.__abs__.__qualname__.__len__() == 15 ('Decimal.__abs__' has 15 chars)"]
    - [dec_neg_qn_len,      "Decimal.__neg__.__qualname__.__len__",      [], 15, "decimal.Decimal.__neg__.__qualname__.__len__() == 15 ('Decimal.__neg__' has 15 chars)"]
    - [dec_pos_qn_len,      "Decimal.__pos__.__qualname__.__len__",      [], 15, "decimal.Decimal.__pos__.__qualname__.__len__() == 15 ('Decimal.__pos__' has 15 chars)"]
    - [dec_mod_qn_len,      "Decimal.__mod__.__qualname__.__len__",      [], 15, "decimal.Decimal.__mod__.__qualname__.__len__() == 15 ('Decimal.__mod__' has 15 chars)"]
    - [dec_pow_qn_len,      "Decimal.__pow__.__qualname__.__len__",      [], 15, "decimal.Decimal.__pow__.__qualname__.__len__() == 15 ('Decimal.__pow__' has 15 chars)"]
    - [dec_mul_qn_len,      "Decimal.__mul__.__qualname__.__len__",      [], 15, "decimal.Decimal.__mul__.__qualname__.__len__() == 15 ('Decimal.__mul__' has 15 chars)"]
    - [dec_floordiv_qn_len, "Decimal.__floordiv__.__qualname__.__len__", [], 20, "decimal.Decimal.__floordiv__.__qualname__.__len__() == 20 ('Decimal.__floordiv__' has 20 chars; longer 8-char dunder name)"]
    - [dec_radd_qn_len,     "Decimal.__radd__.__qualname__.__len__",     [], 16, "decimal.Decimal.__radd__.__qualname__.__len__() == 16 ('Decimal.__radd__' has 16 chars; 4-char dunder name)"]

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic operator type names and __qualname__ of floordiv/radd
# type(Decimal.__sub__).__name__ == 'wrapper_descriptor'.
# __floordiv__ and __radd__ are also wrapper_descriptor but with longer qualnames.
# ---------------------------------------------------------------------------

table decimal_extra103.Decimal_arith_operator_types:
  description: "decimal.Decimal arithmetic operator type names: __sub__/__floordiv__/__radd__ are wrapper_descriptor; __floordiv__='Decimal.__floordiv__'(20); __radd__='Decimal.__radd__'(16)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decarith103c

  columns: [id, function, args, expected, description]
  rows:
    - [dec_sub_type,         "Decimal.__sub__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true,  "type(decimal.Decimal.__sub__).__name__ == 'wrapper_descriptor' (C extension slot wrapper)"]
    - [dec_abs_type,         "Decimal.__abs__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true,  "type(decimal.Decimal.__abs__).__name__ == 'wrapper_descriptor'"]
    - [dec_floordiv_type,    "Decimal.__floordiv__.__class__.__name__.__eq__", ["wrapper_descriptor"], true,  "type(decimal.Decimal.__floordiv__).__name__ == 'wrapper_descriptor'"]
    - [dec_radd_type,        "Decimal.__radd__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true,  "type(decimal.Decimal.__radd__).__name__ == 'wrapper_descriptor'"]
    - [dec_floordiv_qn,      "Decimal.__floordiv__.__qualname__.__eq__",       ["Decimal.__floordiv__"], true, "decimal.Decimal.__floordiv__.__qualname__ == 'Decimal.__floordiv__'"]
    - [dec_radd_qn,          "Decimal.__radd__.__qualname__.__eq__",           ["Decimal.__radd__"],    true,  "decimal.Decimal.__radd__.__qualname__ == 'Decimal.__radd__'"]
    - [dec_neg_type,         "Decimal.__neg__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true,  "type(decimal.Decimal.__neg__).__name__ == 'wrapper_descriptor'"]
    - [dec_sub_ne_wrapper,   "Decimal.__sub__.__class__.__name__.__eq__",      ["method_descriptor"],  false, "type(decimal.Decimal.__sub__).__name__ != 'method_descriptor' (arithmetic dunder slots use wrapper_descriptor, not method_descriptor)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra103.Decimal.sub_qualname:
  description: "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (length 15; the arithmetic operator qualnames for the 3-char dunders __sub__/__abs__/__neg__/__pos__/__mod__/__pow__/__mul__ all have this 15-character pattern: 'Decimal.' prefix plus 7-char dunder name)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__sub__.__qualname__.__eq__"
  args: ["Decimal.__sub__"]
  expected: true

invariant decimal_extra103.Decimal.floordiv_qualname_len_20:
  description: "decimal.Decimal.__floordiv__.__qualname__.__len__() == 20 ('Decimal.__floordiv__' has 20 characters; this is longer than the 15-character pattern of 3-char dunders and longer than __truediv__ (19) and __radd__ (16))"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__floordiv__.__qualname__.__len__"
  args: []
  expected: 20

invariant decimal_extra103.Decimal.radd_qualname_len_16:
  description: "decimal.Decimal.__radd__.__qualname__.__len__() == 16 ('Decimal.__radd__' has 16 characters; the reflected operator __radd__ has a 4-char name __radd__, giving a 16-char qualname, between the 15-char 3-char dunders and the 19/20-char long dunders)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__radd__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra103.Decimal.sub_type_wrapper_descriptor:
  description: "type(decimal.Decimal.__sub__).__name__ == 'wrapper_descriptor' (arithmetic dunder slots on Decimal are C extension wrapper_descriptor objects, the same type used for comparison operators __eq__/__lt__ etc.; distinct from 'method_descriptor' used by io methods)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__sub__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra103.Decimal.mul_qualname_len_15:
  description: "decimal.Decimal.__mul__.__qualname__.__len__() == 15 ('Decimal.__mul__' has 15 characters; __mul__ shares the 15-char qualname length pattern with __sub__/__abs__/__neg__/__pos__/__mod__/__pow__ — all 3-char dunder names on Decimal)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__mul__.__qualname__.__len__"
  args: []
  expected: 15
