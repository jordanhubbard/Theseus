spec: argparse_extra5
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers __name__ table for ArgumentParser/Namespace/Action/FileType/HelpFormatter/Raw*/ArgumentDefaults*/MetavarType*/ArgumentError/ArgumentTypeError/BooleanOptionalAction, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, MRO checks"
    - "argparse_formatters.zspec.zsdl — covers formatter __name__/__module__/__bases__ (tables), FileType __name__/__module__, BooleanOptionalAction __name__/__bases__, exception __bases__"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/__name__/__module__, Namespace/__name__/__module__, HelpFormatter/__name__/__module__, ArgumentError/__name__/__module__, Action/__name__/__module__/__bases__[0], ArgumentDefaultsHelpFormatter/__name__, FileType/__name__/__module__, parse_args/__name__, add_argument/__name__"
    - "argparse_extra2.zspec.zsdl — covers ArgumentTypeError/RawText*/RawDescription*/ArgumentDefaults*/MetavarType* __module__ (table); ArgumentParser/__bases__[0].__name__, Namespace/__bases__[0].__name__, ArgumentError/__bases__[0].__name__, ArgumentTypeError/__bases__[0].__name__, HelpFormatter/__bases__[0].__name__, RawText*/__bases__[0].__name__, RawDescription*/__bases__[0].__name__, ArgumentDefaults*/__bases__[0].__name__"
    - "argparse_extra3.zspec.zsdl — covers ArgumentParser/Namespace/Action/ArgumentError/ArgumentTypeError/FileType/HelpFormatter/RawText* __name__ (table), nargs constants (table), ArgumentParser.__module__, Namespace instance class, ArgumentError/ArgumentTypeError __bases__[0].__name__, ArgumentParser().prog type"
    - "argparse_extra4.zspec.zsdl — covers __qualname__ for all public argparse classes (table)"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: module-level __name__ attribute; FileType and BooleanOptionalAction base class names; SUPPRESS and REMAINDER class names."
    - "argparse.__name__ == 'argparse' — the module's own __name__ attribute. No prior spec covers this."
    - "argparse.FileType.__bases__[0].__name__ == 'object' — FileType inherits directly from object. No prior spec covers FileType's base class."
    - "argparse.BooleanOptionalAction.__bases__[0].__name__ == 'Action' — BooleanOptionalAction inherits from Action. No prior spec covers this inheritance."
    - "argparse.SUPPRESS.__class__.__name__ == 'str' — the SUPPRESS sentinel is a plain str. argparse_extra3 covers its VALUE ('==SUPPRESS==') but not its type."
    - "argparse.REMAINDER.__class__.__name__ == 'str' — the REMAINDER sentinel is a plain str. argparse_extra3 covers its VALUE ('A...') but not its type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# argparse module __name__ attribute
#
# No prior spec covers the module's own __name__ attribute (as opposed to the
# __name__ of symbols within the module). This is a distinct axis.
# ---------------------------------------------------------------------------

invariant argparse_extra5.module_name:
  description: "argparse.__name__ == 'argparse' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["argparse"]
  expected: true

# ---------------------------------------------------------------------------
# FileType and BooleanOptionalAction base class names
#
# argparse_extra2 covers base classes for: ArgumentParser, Namespace,
# ArgumentError, ArgumentTypeError, HelpFormatter, RawText*, RawDescription*,
# ArgumentDefaults*. FileType and BooleanOptionalAction are NOT covered.
# ---------------------------------------------------------------------------

invariant argparse_extra5.FileType.base_is_object:
  description: "argparse.FileType.__bases__[0].__name__ == 'object' — FileType inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: FileType.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant argparse_extra5.BooleanOptionalAction.base_is_Action:
  description: "argparse.BooleanOptionalAction.__bases__[0].__name__ == 'Action' — BooleanOptionalAction inherits from Action"
  category: class_hierarchy
  kind: python_call_eq
  function: BooleanOptionalAction.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Action"

# ---------------------------------------------------------------------------
# SUPPRESS and REMAINDER — class name checks
#
# argparse_extra3 covers the VALUES of SUPPRESS ('==SUPPRESS==') and
# REMAINDER ('A...'). No prior spec covers their __class__.__name__.
# Both are plain str instances, not custom sentinel objects.
# ---------------------------------------------------------------------------

table argparse_extra5.sentinel_class_names:
  kind: python_call_eq
  category: sentinel_types
  id_prefix: stype

  columns: [id, function, args, expected]
  rows:
    - [SUPPRESS,   SUPPRESS.__class__.__name__.__eq__,   ["str"], true]
    - [REMAINDER,  REMAINDER.__class__.__name__.__eq__,  ["str"], true]
    - [ONE_OR_MORE, ONE_OR_MORE.__class__.__name__.__eq__, ["str"], true]
    - [ZERO_OR_MORE, ZERO_OR_MORE.__class__.__name__.__eq__, ["str"], true]
    - [OPTIONAL,   OPTIONAL.__class__.__name__.__eq__,   ["str"], true]
