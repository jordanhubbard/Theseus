spec: socket_extra30
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; socket.error/__mro__.__len__()==4; timeout/herror/gaierror __mro__.__len__()==5; socket.socket.setsockopt/getsockopt __qualname__/__qualname__.__len__()==17; settimeout/__qualname__.__len__()==17; getpeername/__qualname__.__len__()==18; settimeout/__name__.__len__()==10; getpeername/__name__.__len__()==11; setsockopt/__name__.__len__()==10; getsockopt/__name__.__len__()==10."
    - "socket_extra28.zspec.zsdl — covers socket.socket method __qualname__ and __name__ for bind/connect/listen/accept/send/recv; socket.getaddrinfo/__qualname__.__len__(); socket.setdefaulttimeout/__qualname__.__len__() and __module__.__len__()."
    - "socket_extra27.zspec.zsdl — covers __module__.__len__() for socket.socket/error/timeout/herror/gaierror; __name__.__len__() for socket.socket/error; __qualname__ for gethostname/getfqdn/inet_aton/inet_ntoa; gethostname.__module__.__len__()."
    - "socket_extra26.zspec.zsdl — covers socket.timeout/__bases__[0].__name__, socket.herror/__bases__[0].__name__, socket.gaierror/__bases__[0].__name__, socket.socket.__init__.__name__, socket.inet_aton/__name__/__module__, socket.inet_ntoa/__name__."
  notes:
    - "This spec extends socket_extra29.zspec.zsdl."
    - "Prior specs covered: socket.__name__/__package__, socket.socket/__name__/__module__/__qualname__/__bases__[0].__name__/__init__.__name__, error/timeout/herror/gaierror __name__/__module__/__bases__[0].__name__, AF_INET/AF_INET6/AF_UNIX values, SOCK_STREAM/SOCK_DGRAM values, IPPROTO_TCP/IPPROTO_UDP, gethostname/getfqdn/__name__/__module__/__qualname__, inet_aton/inet_ntoa/__name__/__module__/__qualname__, getaddrinfo/__name__/__module__/__qualname__, setdefaulttimeout/__name__/__module__, all __module__.__len__()/__name__.__len__() and __mro__.__len__() for socket/error/timeout/herror/gaierror; method __qualname__/__name__/__len__() for bind/connect/listen/accept/send/recv/setsockopt/getsockopt/settimeout/getpeername."
    - "This spec covers: socket.__all__.__len__()==238; socket.__all__.__class__.__name__=='list'; socket.AF_INET.__class__.__name__=='AddressFamily' and __class__.__name__.__len__()==13; socket.AF_INET6.__class__.__name__=='AddressFamily'; socket.SOCK_STREAM.__class__.__name__=='SocketKind' and __class__.__name__.__len__()==10; socket.SOCK_DGRAM.__class__.__name__=='SocketKind'; socket.SOL_SOCKET value==65535 and __class__.__name__=='int'; socket.IPPROTO_TCP value==6 and __class__.__name__=='int'; socket.socket.__dict__.__class__.__name__=='mappingproxy' and __len__()==12; socket.error.__dict__.__class__.__name__=='mappingproxy' and __len__()==12."
    - "socket.__all__.__len__() == 238. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — len 13. AF_INET is an IntEnum member. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — len 10. SOCK_STREAM is an IntEnum member. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET == 65535 on macOS (socket option level for socket layer). __class__.__name__ == 'int'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP == 6 (TCP protocol number). __class__.__name__ == 'int'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__name__ == 'mappingproxy' — len 12. socket.error.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__all__.__len__() and __all__.__class__.__name__
#
# No prior spec checks socket.__all__.__len__() or its class name.
# socket.__all__ is a list of 238 public names.
# ---------------------------------------------------------------------------

invariant socket_extra30.all_len:
  description: "socket.__all__.__len__() == 238 — 238 public names exported"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 238

invariant socket_extra30.all_class_name:
  description: "socket.__all__.__class__.__name__ == 'list' — __all__ is a plain list"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET and AF_INET6 __class__.__name__ and __class__.__name__.__len__()
#
# No prior spec checks __class__.__name__ for AF_INET or AF_INET6.
# Both are AddressFamily enum members (IntEnum). __class__.__name__ == 'AddressFamily' (len 13).
# AF_INET == 2, AF_INET6 == 30 on macOS.
# ---------------------------------------------------------------------------

table socket_extra30.address_family_class_names:
  description: "socket.AF_INET/AF_INET6 __class__.__name__.__eq__ — both 'AddressFamily'"
  kind: python_call_eq
  category: module_constants
  id_prefix: safc30

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_class,
       "AF_INET.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET.__class__.__name__ == 'AddressFamily' (IntEnum member)"]
    - [AF_INET6_class,
       "AF_INET6.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET6.__class__.__name__ == 'AddressFamily' (IntEnum member)"]
    - [AF_INET_class_len,
       "AF_INET.__class__.__name__.__len__",
       [],
       13,
       "len('AddressFamily') == 13"]
    - [AF_INET_value,
       "AF_INET.__eq__",
       [2],
       true,
       "socket.AF_INET == 2"]
    - [AF_INET6_value,
       "AF_INET6.__eq__",
       [30],
       true,
       "socket.AF_INET6 == 30 on macOS"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM and SOCK_DGRAM __class__.__name__ and __len__()
#
# No prior spec checks __class__.__name__ for SOCK_STREAM or SOCK_DGRAM.
# Both are SocketKind enum members (IntEnum). __class__.__name__ == 'SocketKind' (len 10).
# SOCK_STREAM == 1, SOCK_DGRAM == 2.
# ---------------------------------------------------------------------------

invariant socket_extra30.SOCK_STREAM_class_name:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum member"
  category: module_constants
  kind: python_call_eq
  function: "SOCK_STREAM.__class__.__name__.__eq__"
  args: ["SocketKind"]
  expected: true

invariant socket_extra30.SOCK_STREAM_class_name_len:
  description: "len(socket.SOCK_STREAM.__class__.__name__) == 10 — len('SocketKind') == 10"
  category: module_constants
  kind: python_call_eq
  function: "SOCK_STREAM.__class__.__name__.__len__"
  args: []
  expected: 10

table socket_extra30.sock_kind_values_and_classes:
  description: "socket.SOCK_STREAM/SOCK_DGRAM values and __class__.__name__"
  kind: python_call_eq
  category: module_constants
  id_prefix: sskvc30

  columns: [id, function, args, expected, description]
  rows:
    - [SOCK_STREAM_value,
       "SOCK_STREAM.__eq__",
       [1],
       true,
       "socket.SOCK_STREAM == 1"]
    - [SOCK_DGRAM_value,
       "SOCK_DGRAM.__eq__",
       [2],
       true,
       "socket.SOCK_DGRAM == 2"]
    - [SOCK_DGRAM_class,
       "SOCK_DGRAM.__class__.__name__.__eq__",
       ["SocketKind"],
       true,
       "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' (IntEnum member)"]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET and IPPROTO_TCP values and __class__.__name__
#
# No prior spec checks __class__.__name__ for SOL_SOCKET or IPPROTO_TCP.
# Both are plain int (not enum). SOL_SOCKET == 65535 on macOS; IPPROTO_TCP == 6.
# ---------------------------------------------------------------------------

table socket_extra30.sol_ipproto_constants:
  description: "socket.SOL_SOCKET/IPPROTO_TCP values and __class__.__name__ == 'int'"
  kind: python_call_eq
  category: module_constants
  id_prefix: ssic30

  columns: [id, function, args, expected, description]
  rows:
    - [SOL_SOCKET_value,
       "SOL_SOCKET.__eq__",
       [65535],
       true,
       "socket.SOL_SOCKET == 65535 on macOS"]
    - [SOL_SOCKET_class,
       "SOL_SOCKET.__class__.__name__.__eq__",
       ["int"],
       true,
       "socket.SOL_SOCKET.__class__.__name__ == 'int'"]
    - [IPPROTO_TCP_value,
       "IPPROTO_TCP.__eq__",
       [6],
       true,
       "socket.IPPROTO_TCP == 6 (TCP protocol number)"]
    - [IPPROTO_TCP_class,
       "IPPROTO_TCP.__class__.__name__.__eq__",
       ["int"],
       true,
       "socket.IPPROTO_TCP.__class__.__name__ == 'int'"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__class__.__name__ and socket.error.__dict__.__class__.__name__
#
# No prior spec checks __dict__.__class__.__name__ for socket.socket or socket.error.
# Class __dict__ is always a mappingproxy. __class__.__name__ == 'mappingproxy' (len 12).
# ---------------------------------------------------------------------------

invariant socket_extra30.socket_dict_class_name:
  description: "socket.socket.__dict__.__class__.__name__ == 'mappingproxy' — class namespace is a mappingproxy"
  category: class_structure
  kind: python_call_eq
  function: "socket.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant socket_extra30.socket_dict_class_name_len:
  description: "len(socket.socket.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"
  category: class_structure
  kind: python_call_eq
  function: "socket.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

table socket_extra30.class_dict_proxy_names:
  description: "socket.error.__dict__.__class__.__name__ == 'mappingproxy' and __len__() == 12"
  kind: python_call_eq
  category: class_structure
  id_prefix: scdpn30

  columns: [id, function, args, expected, description]
  rows:
    - [error_dict_class,
       "error.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "socket.error.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [error_dict_class_len,
       "error.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]
