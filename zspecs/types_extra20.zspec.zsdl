spec: types_extra20
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types_extra19.zspec.zsdl — covers FunctionType/GeneratorType/ModuleType/CodeType/MethodType/BuiltinFunctionType __bases__[0].__name__ table; __bases__.__len__ standalone invariants; CodeType/__qualname__.__len__==4; MethodType/__qualname__.__len__==6"
    - "types_extra18.zspec.zsdl — covers __name__.__eq__ table for FunctionType/LambdaType/MethodType/BuiltinFunctionType/ModuleType/GeneratorType/CoroutineType/NoneType; __name__.__len__ table"
    - "types_extra17.zspec.zsdl — covers __qualname__ table for FunctionType/LambdaType/CodeType/MappingProxyType/SimpleNamespace/GeneratorType/CoroutineType; __module__ table"
    - "types_extra16.zspec.zsdl — covers __mro__[1].__name__ for FunctionType/MethodType/CodeType/CoroutineType; standalone __qualname__.__eq__ for FunctionType/ModuleType/MethodType"
  notes:
    - "This spec extends types_extra19.zspec.zsdl."
    - "Focus: __qualname__.__len__() for types not yet measured, and __bases__ for CoroutineType/AsyncGeneratorType/BuiltinFunctionType/MappingProxyType/SimpleNamespace/FrameType/TracebackType."
    - "types_extra17 covers __qualname__.__eq__ for CoroutineType/AsyncGeneratorType/MappingProxyType/SimpleNamespace — this spec adds __len__() for those same qualnames."
    - "types.AsyncGeneratorType.__qualname__ == 'async_generator' (len 15)."
    - "types.BuiltinFunctionType.__qualname__ == 'builtin_function_or_method' (len 26)."
    - "types.MappingProxyType.__qualname__ == 'mappingproxy' (len 12)."
    - "types.SimpleNamespace.__qualname__ == 'SimpleNamespace' (len 15)."
    - "types.FrameType.__qualname__ == 'frame' (len 5); types.TracebackType.__qualname__ == 'traceback' (len 9)."
    - "CoroutineType/AsyncGeneratorType/BuiltinFunctionType/MappingProxyType/SimpleNamespace/FrameType/TracebackType all inherit directly from object (__bases__[0].__name__ == 'object')."
    - "types.BuiltinMethodType is types.BuiltinFunctionType — they are the same object."
    - "types.SimpleNamespace.__module__ == 'types'; all other listed types have __module__ == 'builtins'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for extended type set — table
# (types_extra20 namespace)
#
# types_extra17 covers __qualname__.__eq__ for CoroutineType/AsyncGeneratorType/
# MappingProxyType/SimpleNamespace. types_extra19 covers CodeType (len 4) and
# MethodType (len 6) as standalone invariants. This table adds __len__() for
# AsyncGeneratorType, BuiltinFunctionType, MappingProxyType, SimpleNamespace,
# FrameType, and TracebackType — none previously measured in a combined table.
# ---------------------------------------------------------------------------

table types_extra20.qualname_lengths:
  description: "__qualname__.__len__() for extended types module type objects"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: qlen

  columns: [id, function, args, expected]
  rows:
    - [AsyncGeneratorType,   AsyncGeneratorType.__qualname__.__len__,   [], 15]
    - [BuiltinFunctionType,  BuiltinFunctionType.__qualname__.__len__,  [], 26]
    - [MappingProxyType,     MappingProxyType.__qualname__.__len__,     [], 12]
    - [SimpleNamespace,      SimpleNamespace.__qualname__.__len__,      [], 15]
    - [FrameType,            FrameType.__qualname__.__len__,            [],  5]
    - [TracebackType,        TracebackType.__qualname__.__len__,        [],  9]
    - [CoroutineType,        CoroutineType.__qualname__.__len__,        [],  9]
    - [GeneratorType,        GeneratorType.__qualname__.__len__,        [],  9]
    - [ModuleType,           ModuleType.__qualname__.__len__,           [],  6]
    - [FunctionType,         FunctionType.__qualname__.__len__,         [],  8]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for extended type set — table
# (types_extra20 namespace)
#
# types_extra19 covers FunctionType/GeneratorType/ModuleType/CodeType/MethodType/
# BuiltinFunctionType __bases__[0].__name__ in a combined table. This table
# extends that to CoroutineType/AsyncGeneratorType/MappingProxyType/SimpleNamespace/
# FrameType/TracebackType — all inherit directly from object.
# ---------------------------------------------------------------------------

table types_extra20.extended_bases:
  description: "__bases__[0].__name__ for extended types module type objects (all inherit from object)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: extbase0

  columns: [id, function, args, expected]
  rows:
    - [CoroutineType,       "CoroutineType.__bases__.__getitem__(0).__name__.__eq__",      ["object"], true]
    - [AsyncGeneratorType,  "AsyncGeneratorType.__bases__.__getitem__(0).__name__.__eq__", ["object"], true]
    - [MappingProxyType,    "MappingProxyType.__bases__.__getitem__(0).__name__.__eq__",   ["object"], true]
    - [SimpleNamespace,     "SimpleNamespace.__bases__.__getitem__(0).__name__.__eq__",    ["object"], true]
    - [FrameType,           "FrameType.__bases__.__getitem__(0).__name__.__eq__",          ["object"], true]
    - [TracebackType,       "TracebackType.__bases__.__getitem__(0).__name__.__eq__",      ["object"], true]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for FrameType and TracebackType — standalone invariants
# (types_extra20 namespace)
#
# types_extra17 covers FunctionType/LambdaType/CodeType/MappingProxyType/
# SimpleNamespace/GeneratorType/CoroutineType __qualname__.__eq__. FrameType
# and TracebackType are not covered by any prior types spec qualname eq check.
# ---------------------------------------------------------------------------

invariant types_extra20.FrameType.qualname:
  description: "types.FrameType.__qualname__ == 'frame' — internal C-level type name"
  category: type_qualnames
  kind: python_call_eq
  function: FrameType.__qualname__.__eq__
  args: ["frame"]
  expected: true

invariant types_extra20.TracebackType.qualname:
  description: "types.TracebackType.__qualname__ == 'traceback' — internal C-level type name"
  category: type_qualnames
  kind: python_call_eq
  function: TracebackType.__qualname__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleNamespace __module__ — standalone invariant
# (types_extra20 namespace)
#
# types_extra17 covers __module__ for several types but not SimpleNamespace
# in a standalone invariant in the extra20 namespace. SimpleNamespace is
# notable because its __module__ is 'types', unlike most builtin types which
# have __module__ == 'builtins'.
# ---------------------------------------------------------------------------

invariant types_extra20.SimpleNamespace.module:
  description: "types.SimpleNamespace.__module__ == 'types' — unlike C builtin types, SimpleNamespace is defined in the types module"
  category: module_attrs
  kind: python_call_eq
  function: SimpleNamespace.__module__.__eq__
  args: ["types"]
  expected: true

invariant types_extra20.FrameType.module:
  description: "types.FrameType.__module__ == 'builtins' — frame is a C builtin type"
  category: module_attrs
  kind: python_call_eq
  function: FrameType.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant types_extra20.AsyncGeneratorType.module:
  description: "types.AsyncGeneratorType.__module__ == 'builtins' — async_generator is a C builtin type"
  category: module_attrs
  kind: python_call_eq
  function: AsyncGeneratorType.__module__.__eq__
  args: ["builtins"]
  expected: true
