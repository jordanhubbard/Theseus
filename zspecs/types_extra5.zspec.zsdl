spec: types_extra5
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types.zspec.zsdl, types_extra.zspec.zsdl, types_extra2.zspec.zsdl, types_extra3.zspec.zsdl, types_extra4.zspec.zsdl."
    - "Focus: __qualname__ checks for types not yet covered."
    - "types.FunctionType.__qualname__ == 'function' — same as __name__ for built-in types."
    - "types.MethodType.__qualname__ == 'method'."
    - "types.BuiltinFunctionType.__qualname__ == 'builtin_function_or_method'."
    - "types.ModuleType.__qualname__ == 'module'."
    - "types.GeneratorType.__qualname__ == 'generator'."
    - "types.CoroutineType.__qualname__ == 'coroutine'."
    - "types.AsyncGeneratorType.__qualname__ == 'async_generator'."
    - "types.LambdaType.__qualname__ == 'function' — LambdaType is an alias for FunctionType."
    - "types.SimpleNamespace.__qualname__ == 'SimpleNamespace'."
    - "types.MappingProxyType.__qualname__ == 'mappingproxy'."
    - "types.DynamicClassAttribute.__qualname__ == 'DynamicClassAttribute'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for core types (table)
# ---------------------------------------------------------------------------

table types_extra5.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,  FunctionType.__qualname__.__eq__,  ["function"], true]
    - [MethodType,    MethodType.__qualname__.__eq__,    ["method"],   true]
    - [GeneratorType, GeneratorType.__qualname__.__eq__, ["generator"], true]
    - [CoroutineType, CoroutineType.__qualname__.__eq__, ["coroutine"], true]
    - [ModuleType,    ModuleType.__qualname__.__eq__,    ["module"],   true]

# ---------------------------------------------------------------------------
# __qualname__ checks for additional types (standalone invariants)
# ---------------------------------------------------------------------------

invariant types_extra5.BuiltinFunctionType.qualname:
  description: "types.BuiltinFunctionType.__qualname__ == 'builtin_function_or_method'"
  category: qualnames
  kind: python_call_eq
  function: BuiltinFunctionType.__qualname__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant types_extra5.AsyncGeneratorType.qualname:
  description: "types.AsyncGeneratorType.__qualname__ == 'async_generator'"
  category: qualnames
  kind: python_call_eq
  function: AsyncGeneratorType.__qualname__.__eq__
  args: ["async_generator"]
  expected: true

invariant types_extra5.LambdaType.qualname:
  description: "types.LambdaType.__qualname__ == 'function' — LambdaType is an alias for FunctionType"
  category: qualnames
  kind: python_call_eq
  function: LambdaType.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant types_extra5.SimpleNamespace.qualname:
  description: "types.SimpleNamespace.__qualname__ == 'SimpleNamespace'"
  category: qualnames
  kind: python_call_eq
  function: SimpleNamespace.__qualname__.__eq__
  args: ["SimpleNamespace"]
  expected: true

invariant types_extra5.MappingProxyType.qualname:
  description: "types.MappingProxyType.__qualname__ == 'mappingproxy'"
  category: qualnames
  kind: python_call_eq
  function: MappingProxyType.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant types_extra5.DynamicClassAttribute.qualname:
  description: "types.DynamicClassAttribute.__qualname__ == 'DynamicClassAttribute'"
  category: qualnames
  kind: python_call_eq
  function: DynamicClassAttribute.__qualname__.__eq__
  args: ["DynamicClassAttribute"]
  expected: true
