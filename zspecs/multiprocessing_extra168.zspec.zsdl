spec: multiprocessing_extra168
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: multiprocessing.process.BaseProcess.__dict__.__contains__ checks for 'start', 'run', 'join', 'terminate', and 'kill'; multiprocessing.process.BaseProcess.__dict__.__class__.__name__=='mappingproxy'; multiprocessing.process.BaseProcess.__dict__.__len__()==27. KEY FINDINGS: All five methods ('start', 'run', 'join', 'terminate', 'kill') are in BaseProcess.__dict__ (True); multiprocessing.Process is a CONTEXT-BOUND SUBCLASS — Process.__dict__ does NOT contain these methods (only BaseProcess.__dict__ does); BaseProcess.__dict__.__class__.__name__=='mappingproxy' (read-only class namespace view); BaseProcess.__dict__.__len__()==27 (27 entries). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "KEY ARCHITECTURAL FINDING: multiprocessing.Process is a context-bound subclass created dynamically from BaseProcess. Process.__dict__ only contains: '__module__', '__firstlineno__', '_start_method', '_Popen', '_after_fork', '__static_attributes__', '__doc__' (7 entries) — the lifecycle methods (start, run, join, terminate, kill) are inherited from BaseProcess, not present in Process.__dict__ directly. This matches the pattern that Process is a context-specific wrapper while all real logic is in BaseProcess (multiprocessing.process.BaseProcess). Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__dict__.__len__()==27 (27 entries): '__module__', '__firstlineno__', '__doc__', '_Popen', '__init__', '_check_closed', 'run', 'start', 'interrupt', 'terminate', 'kill', 'join', 'is_alive', 'close', 'name', 'daemon', 'authkey', 'exitcode', 'ident', 'pid', 'sentinel', '__repr__', '_bootstrap', '_after_fork', '__static_attributes__', '__dict__', '__weakref__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.__dict__.__contains__ — start and run — extra168
#
# multiprocessing.process.BaseProcess.__dict__.__contains__('start') == True
# multiprocessing.process.BaseProcess.__dict__.__contains__('run')   == True
# ---------------------------------------------------------------------------

table multiprocessing_extra168.mp_baseprocess_dict_start_and_run:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ checks for 'start' and 'run' in mpbpstart168 namespace — multiprocessing.process.BaseProcess.__dict__.__contains__('start')==True ('start' is directly in BaseProcess.__dict__; BaseProcess.start() launches the process by calling the platform-specific _Popen class to fork/spawn/forkserver a new process; start() can only be called once per Process object; calling start() again raises AssertionError; the launched process calls _bootstrap() which eventually calls self.run()); multiprocessing.process.BaseProcess.__dict__.__contains__('run')==True ('run' is directly in BaseProcess.__dict__; BaseProcess.run() is the method that runs in the child process; the default implementation calls the target callable with the given args and kwargs; subclasses override run() to define process behavior; run() is called by _bootstrap() on the child-process side after start() forks); KEY: both 'start' and 'run' are in BaseProcess.__dict__ (NOT in multiprocessing.Process.__dict__ — Process is a context-bound subclass that inherits these methods from BaseProcess); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbpstart168

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_start,  multiprocessing.process.BaseProcess.__dict__.__contains__,  ["start"],  true,  "BaseProcess.__dict__.__contains__('start') == True (BaseProcess.start() launches child process); verified with Python 3.14.3"]
    - [bp_has_run,    multiprocessing.process.BaseProcess.__dict__.__contains__,  ["run"],    true,  "BaseProcess.__dict__.__contains__('run') == True (BaseProcess.run() executes target in child process); verified with Python 3.14.3"]
    - [bp_has_start2, multiprocessing.process.BaseProcess.__dict__.__contains__,  ["start"],  true,  "BaseProcess.__dict__.__contains__('start') == True (cross-check; start() can only be called once); verified with Python 3.14.3"]
    - [bp_has_run2,   multiprocessing.process.BaseProcess.__dict__.__contains__,  ["run"],    true,  "BaseProcess.__dict__.__contains__('run') == True (cross-check; override run() to define process behavior); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.__dict__.__contains__ — join and terminate — extra168
#
# multiprocessing.process.BaseProcess.__dict__.__contains__('join')      == True
# multiprocessing.process.BaseProcess.__dict__.__contains__('terminate') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra168.mp_baseprocess_dict_join_and_terminate:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ checks for 'join' and 'terminate' in mpbpjoin168 namespace — multiprocessing.process.BaseProcess.__dict__.__contains__('join')==True ('join' is directly in BaseProcess.__dict__; BaseProcess.join(timeout=None) blocks the calling process until the child process terminates or until timeout seconds have passed; if timeout is given and the process has not terminated, join returns without error — check is_alive() to determine if it timed out; join() must be called after start(); a process can be joined many times; a process cannot join itself; join can be used before start() after close()); multiprocessing.process.BaseProcess.__dict__.__contains__('terminate')==True ('terminate' is directly in BaseProcess.__dict__; BaseProcess.terminate() sends SIGTERM on Unix or TerminateProcess() on Windows to the child process; it does NOT wait for the process to finish — the caller should join() after terminate() to reap the child; if the process has already exited, terminate() is a no-op); KEY: both 'join' and 'terminate' are in BaseProcess.__dict__ (NOT in multiprocessing.Process.__dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbpjoin168

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_join,       multiprocessing.process.BaseProcess.__dict__.__contains__,  ["join"],       true,  "BaseProcess.__dict__.__contains__('join') == True (BaseProcess.join() blocks until child terminates); verified with Python 3.14.3"]
    - [bp_has_terminate,  multiprocessing.process.BaseProcess.__dict__.__contains__,  ["terminate"],  true,  "BaseProcess.__dict__.__contains__('terminate') == True (BaseProcess.terminate() sends SIGTERM); verified with Python 3.14.3"]
    - [bp_has_join2,      multiprocessing.process.BaseProcess.__dict__.__contains__,  ["join"],       true,  "BaseProcess.__dict__.__contains__('join') == True (cross-check; must join after terminate to reap child); verified with Python 3.14.3"]
    - [bp_has_terminate2, multiprocessing.process.BaseProcess.__dict__.__contains__,  ["terminate"],  true,  "BaseProcess.__dict__.__contains__('terminate') == True (cross-check; no-op if already exited); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.__dict__.__contains__ — kill — extra168
#
# multiprocessing.process.BaseProcess.__dict__.__contains__('kill') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra168.mp_baseprocess_dict_kill:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__ check for 'kill' and supporting cross-checks in mpbpkill168 namespace — multiprocessing.process.BaseProcess.__dict__.__contains__('kill')==True ('kill' is directly in BaseProcess.__dict__; BaseProcess.kill() sends SIGKILL on Unix or TerminateProcess() on Windows to the child process; SIGKILL is unblockable and cannot be caught by the target process (unlike SIGTERM which terminate() sends); kill() is the forceful termination method — use when terminate() fails to stop the process; like terminate(), kill() does not wait for the process to finish; the caller should join() after kill() to reap the child; on Windows, kill() and terminate() have the same effect because TerminateProcess() is the only forceful termination mechanism); multiprocessing.process.BaseProcess.__dict__.__contains__('start')==True (cross-check; start is also in BaseProcess.__dict__); multiprocessing.process.BaseProcess.__dict__.__len__()==27 (cross-check; 27 entries in BaseProcess's class dict — 'kill' is one of them); multiprocessing.process.BaseProcess.__dict__.__contains__('run')==True (cross-check; run is also in BaseProcess.__dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbpkill168

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_kill,     multiprocessing.process.BaseProcess.__dict__.__contains__,  ["kill"],   true,  "BaseProcess.__dict__.__contains__('kill') == True (BaseProcess.kill() sends SIGKILL on Unix); verified with Python 3.14.3"]
    - [bp_has_start3,   multiprocessing.process.BaseProcess.__dict__.__contains__,  ["start"],  true,  "BaseProcess.__dict__.__contains__('start') == True (cross-check; start is also in BaseProcess.__dict__); verified with Python 3.14.3"]
    - [bp_dict_len,     multiprocessing.process.BaseProcess.__dict__.__len__,       [],          27,    "BaseProcess.__dict__.__len__() == 27 (27 entries in BaseProcess class dict; Python 3.14.3); verified with Python 3.14.3"]
    - [bp_has_run3,     multiprocessing.process.BaseProcess.__dict__.__contains__,  ["run"],    true,  "BaseProcess.__dict__.__contains__('run') == True (cross-check; run, start, join, terminate, kill all in BaseProcess.__dict__); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.__dict__.__class__.__name__ — extra168
#
# multiprocessing.process.BaseProcess.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# multiprocessing.process.BaseProcess.__dict__.__len__()                                 == 27
# ---------------------------------------------------------------------------

table multiprocessing_extra168.mp_baseprocess_dict_class_and_len:
  description: "multiprocessing.process.BaseProcess.__dict__.__class__.__name__ and __len__ checks in mpbpdictcls168 namespace — multiprocessing.process.BaseProcess.__dict__.__class__.__name__.__eq__('mappingproxy')==True (BaseProcess.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); BaseProcess's class dict is a mappingproxy, same as all Python class dicts; confirmed pattern from extra166 (Future), abc_extra164 (ABC, ABCMeta), extra167 (TPE)); multiprocessing.process.BaseProcess.__dict__.__len__()==27 (BaseProcess.__dict__ has exactly 27 entries in Python 3.14.3: the 27 entries include 5 public lifecycle methods (start, run, join, terminate, kill), 5 property descriptors (name, daemon, authkey, exitcode, ident/pid), 1 sentinel property, and internal/dunder entries; BaseProcess.__dict__.__len__()==27 is the largest class dict in this spec series: ABC(7) < ABCMeta(11) < TPE(12) < Future(21) < BaseProcess(27)); multiprocessing.process.BaseProcess.__dict__.__class__.__name__.__len__()==12 (cross-check; 'mappingproxy'=12); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbpdictcls168

  columns: [id, function, args, expected, description]
  rows:
    - [bp_dict_cls_name_eq,  multiprocessing.process.BaseProcess.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],  true,  "BaseProcess.__dict__.__class__.__name__ == 'mappingproxy' (read-only class namespace view; len=12); verified with Python 3.14.3"]
    - [bp_dict_cls_name_len, multiprocessing.process.BaseProcess.__dict__.__class__.__name__.__len__, [],                12,    "BaseProcess.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12; same as all class dicts); verified with Python 3.14.3"]
    - [bp_dict_len2,         multiprocessing.process.BaseProcess.__dict__.__len__,                    [],                27,    "BaseProcess.__dict__.__len__() == 27 (27 entries; largest dict in this spec series: ABC=7 < ABCMeta=11 < TPE=12 < Future=21 < BaseProcess=27); verified with Python 3.14.3"]
    - [bp_has_join3,         multiprocessing.process.BaseProcess.__dict__.__contains__,               ["join"],          true,  "BaseProcess.__dict__.__contains__('join') == True (cross-check; 'join' is among the 27 entries); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra168
# ---------------------------------------------------------------------------

invariant multiprocessing_extra168.mp_BaseProcess_dict_has_start:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('start') returns True — multiprocessing.process.BaseProcess.__dict__.__contains__('start')==True; BaseProcess.start() is the method that launches a child process; start() calls the platform-specific Popen class to fork/spawn/forkserver a new OS process; the new process begins execution in _bootstrap() which eventually calls self.run(); start() registers the child with the global _children set for tracking; start() sets the process's sentinel (a file descriptor or Windows handle that becomes readable when the process exits); start() can only be called once — a second call raises AssertionError; KEY ARCHITECTURAL FINDING: 'start' is in BaseProcess.__dict__ (True) but NOT in multiprocessing.Process.__dict__ (False) — multiprocessing.Process is a context-bound subclass with only 7 entries in its __dict__ (context-specific overrides of _start_method, _Popen, _after_fork); all actual process lifecycle methods live in BaseProcess which Process inherits from; NEW in extra168: first standalone BaseProcess.__dict__.__contains__('start') invariant in mpbpstart168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["start"]
  expected: true

invariant multiprocessing_extra168.mp_BaseProcess_dict_has_run:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('run') returns True — multiprocessing.process.BaseProcess.__dict__.__contains__('run')==True; BaseProcess.run() is the method executed in the child process after start() forks; the default implementation calls self._target(*self._args, **self._kwargs) if _target is not None; the canonical way to define process behavior is to subclass Process and override run(), then call start(); run() executes in the CHILD process's memory space — not in the parent; run() is called by _bootstrap() which wraps it in error handling and calls _after_fork hooks; KEY: overriding run() in a Process subclass is the object-oriented API; passing target= to Process() is the functional API — both result in run() being called in the child; 'run' is in BaseProcess.__dict__ (NOT in Process.__dict__); BaseProcess.__dict__.__len__()==27 — 'run' is 1 of 27; NEW in extra168: first standalone BaseProcess.__dict__.__contains__('run') invariant in mpbpstart168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["run"]
  expected: true

invariant multiprocessing_extra168.mp_BaseProcess_dict_has_join:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('join') returns True — multiprocessing.process.BaseProcess.__dict__.__contains__('join')==True; BaseProcess.join(timeout=None) blocks the calling process until the child process terminates or until timeout expires; if timeout is given and the process has not terminated within timeout seconds, join() returns without error (is_alive() will still return True); join() is the standard way to wait for a child process to complete; after join() returns with is_alive()==False, the process's exitcode attribute is set; join() must be called after start() and cannot be called on a process that has not been started; a process cannot join itself (raises RuntimeError); calling join() after the process has already exited is safe and returns immediately; KEY PATTERN: terminate() + join() is the standard idiom for forcefully stopping and reaping a child process; 'join' is in BaseProcess.__dict__ (NOT in multiprocessing.Process.__dict__); BaseProcess.__dict__.__len__()==27; NEW in extra168: first standalone BaseProcess.__dict__.__contains__('join') invariant in mpbpjoin168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["join"]
  expected: true

invariant multiprocessing_extra168.mp_BaseProcess_dict_has_terminate:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('terminate') returns True — multiprocessing.process.BaseProcess.__dict__.__contains__('terminate')==True; BaseProcess.terminate() sends SIGTERM to the child process on Unix or calls TerminateProcess() on Windows; SIGTERM is a soft termination signal that can be caught, blocked, or ignored by the target process; the process may continue running if it catches and ignores SIGTERM; terminate() is non-blocking — it does NOT wait for the process to die; the caller should call join() after terminate() to reap the zombie process; if the process has already exited when terminate() is called, it is a no-op (no error); KEY: terminate() (SIGTERM) vs kill() (SIGKILL): terminate can be caught; kill cannot; 'terminate' is in BaseProcess.__dict__ (NOT in multiprocessing.Process.__dict__); compare: multiprocessing.cpu_count.__qualname__=='BaseContext.cpu_count' (from extra167: cpu_count is a bound method on BaseContext, while terminate is a method on BaseProcess — different base classes for different purposes); NEW in extra168: first standalone BaseProcess.__dict__.__contains__('terminate') invariant in mpbpjoin168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["terminate"]
  expected: true

invariant multiprocessing_extra168.mp_BaseProcess_dict_has_kill:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('kill') returns True — multiprocessing.process.BaseProcess.__dict__.__contains__('kill')==True; BaseProcess.kill() sends SIGKILL to the child process on Unix or calls TerminateProcess() on Windows; SIGKILL is an unconditional, unblockable kill signal — the OS terminates the process immediately without giving it a chance to clean up or run signal handlers; use kill() when terminate() fails to stop the process; on Windows, kill() and terminate() have identical effects because TerminateProcess() is always unconditional; kill() is non-blocking — call join() after kill() to reap the zombie; 'kill' is in BaseProcess.__dict__ — it is a distinct method from 'terminate' (two separate entries in BaseProcess.__dict__); compare: BaseProcess.__dict__.__len__()==27 — both 'kill' and 'terminate' are among the 27 entries; 'kill'=4 chars is shorter than 'terminate'=9 chars; LENGTH ORDERING for process control methods: run(3) < kill(4) < start=join(5) < terminate(9); NEW in extra168: first standalone BaseProcess.__dict__.__contains__('kill') invariant in mpbpkill168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__contains__
  args: ["kill"]
  expected: true

invariant multiprocessing_extra168.mp_BaseProcess_dict_class_is_mappingproxy:
  description: "multiprocessing.process.BaseProcess.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — multiprocessing.process.BaseProcess.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); BaseProcess's class dict is a mappingproxy — the universal Python class namespace type; this confirms the universal Python invariant that all class __dict__ attributes are mappingproxies: Future(extra166), ABC/ABCMeta(abc_extra164), ThreadPoolExecutor(extra167), and now BaseProcess(extra168) — all are mappingproxies; BaseProcess.__dict__.__len__()==27 (27 entries in BaseProcess's class dict — the largest in this spec series so far: ABC=7 < ABCMeta=11 < TPE=12 < Future=21 < BaseProcess=27); 'kill', 'terminate', 'join', 'start', 'run' are all among the 27 BaseProcess.__dict__ entries; NEW in extra168: first standalone BaseProcess.__dict__.__class__.__name__ invariant in mpbpdictcls168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant multiprocessing_extra168.mp_BaseProcess_dict_len:
  description: "multiprocessing.process.BaseProcess.__dict__.__len__() returns 27 — multiprocessing.process.BaseProcess.__dict__.__len__()==27 (27 entries in BaseProcess's class dict as of Python 3.14.3 on macOS/Darwin 25.4.0); the 27 entries include public lifecycle methods: run, start, interrupt, terminate, kill, join, is_alive, close; property descriptors: name, daemon, authkey, exitcode, ident, pid, sentinel; private methods: __init__, _check_closed, _bootstrap, _after_fork; internal references: _Popen; dunder entries: __module__, __firstlineno__, __doc__, __repr__, __static_attributes__, __dict__, __weakref__; BaseProcess.__dict__.__len__()==27 is the largest class dict in this spec series: abc.ABC(7) < abc.ABCMeta(11) < ThreadPoolExecutor(12) < concurrent.futures.Future(21) < BaseProcess(27) — BaseProcess owns 6 more entries than Future because it defines many lifecycle methods and property descriptors; NOTE: multiprocessing.Process.__dict__.__len__()==7 (Process is a context-bound subclass with only 7 entries — all lifecycle methods are inherited from BaseProcess, NOT redefined in Process); NEW in extra168: first standalone BaseProcess.__dict__.__len__ invariant in mpbpdictcls168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__dict__.__len__
  args: []
  expected: 27
