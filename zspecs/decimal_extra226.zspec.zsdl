spec: decimal_extra226
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.MAX_PREC, decimal.MAX_EMAX, decimal.MIN_EMIN platform limit constants and decimal.HAVE_THREADS/HAVE_CONTEXTVAR capability flags."
    - "decimal.MAX_PREC == 999999999999999999 — maximum precision on 64-bit platforms; verified Python 3.14.3 macOS."
    - "decimal.MAX_EMAX == 999999999999999999 — maximum exponent value equals MAX_PREC on 64-bit; verified Python 3.14.3 macOS."
    - "decimal.MIN_EMIN == -999999999999999999 — minimum exponent is the negation of MAX_EMAX; verified Python 3.14.3 macOS."
    - "decimal.MAX_PREC.__class__.__name__ == 'int' — all three limit constants are plain int; verified Python 3.14.3 macOS."
    - "decimal.MAX_PREC.__gt__(0) == True — maximum precision is positive; verified Python 3.14.3 macOS."
    - "decimal.MAX_EMAX.__gt__(0) == True — maximum exponent is positive; verified Python 3.14.3 macOS."
    - "decimal.MIN_EMIN.__lt__(0) == True — minimum exponent is negative; verified Python 3.14.3 macOS."
    - "decimal.HAVE_THREADS == True — decimal module compiled with thread support; verified Python 3.14.3 macOS."
    - "decimal.HAVE_CONTEXTVAR == True — decimal module compiled with contextvars support; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal platform limit constant value contracts
# MAX_PREC, MAX_EMAX, MIN_EMIN on 64-bit platforms.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra226.MAX_PREC.value:
  description: "decimal.MAX_PREC == 999999999999999999 — maximum context precision on 64-bit platforms; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra226.MAX_EMAX.value:
  description: "decimal.MAX_EMAX == 999999999999999999 — maximum exponent equals MAX_PREC on 64-bit platforms; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: MAX_EMAX.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra226.MIN_EMIN.value:
  description: "decimal.MIN_EMIN == -999999999999999999 — minimum exponent is the negation of MAX_EMAX on 64-bit platforms; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: MIN_EMIN.__eq__
  args: [-999999999999999999]
  expected: true

# ---------------------------------------------------------------------------
# decimal limit constant type contracts
# MAX_PREC, MAX_EMAX, MIN_EMIN are all plain int.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra226.limit_class_names:
  description: "decimal limit constant type contracts — MAX_PREC, MAX_EMAX, MIN_EMIN are all int; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant
  id_prefix: declimitclsname226

  columns: [id, function, args, expected]
  rows:
    - [max_prec_cls,  MAX_PREC.__class__.__name__.__eq__,  ["int"],  true]
    - [max_emax_cls,  MAX_EMAX.__class__.__name__.__eq__,  ["int"],  true]
    - [min_emin_cls,  MIN_EMIN.__class__.__name__.__eq__,  ["int"],  true]

# ---------------------------------------------------------------------------
# decimal limit constant sign contracts
# MAX_PREC > 0, MAX_EMAX > 0, MIN_EMIN < 0.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra226.MAX_PREC.positive:
  description: "decimal.MAX_PREC.__gt__(0) == True — maximum precision is a positive integer; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: MAX_PREC.__gt__
  args: [0]
  expected: true

invariant decimal_extra226.MAX_EMAX.positive:
  description: "decimal.MAX_EMAX.__gt__(0) == True — maximum exponent is a positive integer; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: MAX_EMAX.__gt__
  args: [0]
  expected: true

invariant decimal_extra226.MIN_EMIN.negative:
  description: "decimal.MIN_EMIN.__lt__(0) == True — minimum exponent is a negative integer; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: MIN_EMIN.__lt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# decimal capability flag contracts
# HAVE_THREADS and HAVE_CONTEXTVAR availability flags.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra226.HAVE_THREADS.true:
  description: "decimal.HAVE_THREADS == True — decimal module compiled with thread-local context support; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: HAVE_THREADS.__eq__
  args: [true]
  expected: true

invariant decimal_extra226.HAVE_CONTEXTVAR.true:
  description: "decimal.HAVE_CONTEXTVAR == True — decimal module compiled with contextvars support; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: HAVE_CONTEXTVAR.__eq__
  args: [true]
  expected: true
