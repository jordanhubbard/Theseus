spec: itertools_extra1891
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "itertools module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party itertools extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in itertools C types"
    - "All itertools types are synchronous; none implement __aiter__ or __anext__"
    - "None of the itertools types implement unary arithmetic dunder methods"
    - "itertools.repeat has __length_hint__ when given a finite count argument"
  created_at: "2026-04-12"

table itertools_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["it1891-ua-001", "itertools.count.__dict__.__contains__", ["__abs__"], false]
    - ["it1891-ua-002", "itertools.count.__dict__.__contains__", ["__neg__"], false]
    - ["it1891-ua-003", "itertools.count.__dict__.__contains__", ["__pos__"], false]
    - ["it1891-ua-004", "itertools.chain.__dict__.__contains__", ["__abs__"], false]
    - ["it1891-ua-005", "itertools.cycle.__dict__.__contains__", ["__abs__"], false]
    - ["it1891-ua-006", "itertools.repeat.__dict__.__contains__", ["__abs__"], false]
    - ["it1891-ua-007", "itertools.product.__dict__.__contains__", ["__abs__"], false]
    - ["it1891-ua-008", "itertools.combinations.__dict__.__contains__", ["__abs__"], false]

table itertools_extra1891.async_iteration_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["it1891-ai-001", "itertools.count.__dict__.__contains__", ["__aiter__"], false]
    - ["it1891-ai-002", "itertools.count.__dict__.__contains__", ["__anext__"], false]
    - ["it1891-ai-003", "itertools.chain.__dict__.__contains__", ["__aiter__"], false]
    - ["it1891-ai-004", "itertools.cycle.__dict__.__contains__", ["__aiter__"], false]
    - ["it1891-ai-005", "itertools.repeat.__dict__.__contains__", ["__aiter__"], false]
    - ["it1891-ai-006", "itertools.product.__dict__.__contains__", ["__aiter__"], false]
    - ["it1891-ai-007", "itertools.combinations.__dict__.__contains__", ["__aiter__"], false]
    - ["it1891-ai-008", "itertools.islice.__dict__.__contains__", ["__aiter__"], false]

table itertools_extra1891.length_hint_fspath:
  columns: [id, function, args, expected]
  rows:
    - ["it1891-lh-001", "itertools.count.__dict__.__contains__", ["__length_hint__"], false]
    - ["it1891-lh-002", "itertools.repeat.__dict__.__contains__", ["__length_hint__"], true]
    - ["it1891-lh-003", "itertools.chain.__dict__.__contains__", ["__length_hint__"], false]
    - ["it1891-lh-004", "itertools.cycle.__dict__.__contains__", ["__length_hint__"], false]
    - ["it1891-lh-005", "itertools.islice.__dict__.__contains__", ["__length_hint__"], false]
    - ["it1891-lh-006", "itertools.count.__dict__.__contains__", ["__fspath__"], false]
    - ["it1891-lh-007", "itertools.repeat.__dict__.__contains__", ["__fspath__"], false]
    - ["it1891-lh-008", "itertools.chain.__dict__.__contains__", ["__fspath__"], false]
