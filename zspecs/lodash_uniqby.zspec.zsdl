spec: lodash_uniqby
version: ">=4.0.0"
backend: node(lodash.uniqby)

docs: https://lodash.com/docs/#uniqBy

provenance:
  derived_from:
    - "lodash.uniqby README — https://www.npmjs.com/package/lodash.uniqby"
    - "Test vectors verified with lodash.uniqby@4.7.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.uniqby exports the _.uniqBy function directly as module.exports."
    - "uniqBy(array, key) returns unique elements based on the given property name."
    - "First occurrence of each unique key value is kept."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of unique elements. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_uniqby.uniqby:
  kind: node_module_call_eq
  function: ~
  category: uniqby
  id_prefix: luniqby

  columns: [id, args, expected]
  rows:
    - [by_n,  [[{"n": 1, "x": "a"}, {"n": 2, "x": "b"}, {"n": 1, "x": "c"}], "n"],
       [{"n": 1, "x": "a"}, {"n": 2, "x": "b"}]]
