spec: sklearn_decomp_rust
version: ">=3.9"
backend: rust_module(sklearn_decomp_rust)

docs: https://scikit-learn.org/stable/modules/decomposition.html

provenance:
  derived_from:
    - "https://scikit-learn.org/stable/modules/decomposition.html — sklearn decomposition"
  not_derived_from:
    - "sklearn source: sklearn/decomposition/_pca.py"
  notes:
    - "sklearn provides dimensionality reduction methods."
    - "PCA(n_components=2).fit([[1,2,3],[4,5,6],[7,8,9]]).n_components_ == 2."
    - "PCA(n_components=1).fit(data).components_.shape[0] == 1."
    - "PCA(n_components=2).fit_transform(data).shape[1] == 2."
    - "Expose pca_n_components(data, n) -> int: PCA(n_components=n).fit(data).n_components_."
    - "Expose pca_transform_ncols(data, n) -> int: PCA(n_components=n).fit_transform(data).shape[1]."
    - "All test vectors verified against scikit-learn 1.6.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pca_n_components — n_components_ attribute after fit
table sklearn_decomp_rust.pca.n_components:
  kind: python_call_eq
  category: n_components
  id_prefix: pca_nc
  function: pca_n_components

  columns: [id, args, expected]
  rows:
    - [two,  [[[1, 2, 3], [4, 5, 6], [7, 8, 9]], 2], 2]
    - [one,  [[[1, 2, 3], [4, 5, 6], [7, 8, 9]], 1], 1]

# pca_transform_ncols — transformed data column count == n_components
table sklearn_decomp_rust.pca.transform_cols:
  kind: python_call_eq
  category: transform_cols
  id_prefix: pca_tc
  function: pca_transform_ncols

  columns: [id, args, expected]
  rows:
    - [two,  [[[1, 2, 3], [4, 5, 6], [7, 8, 9]], 2], 2]
    - [one,  [[[1, 2, 3], [4, 5, 6], [7, 8, 9]], 1], 1]

