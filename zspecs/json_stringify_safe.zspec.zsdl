spec: json_stringify_safe
version: ">=5.0.1"
backend: node(json-stringify-safe)

docs: https://www.npmjs.com/package/json-stringify-safe

provenance:
  derived_from:
    - "json-stringify-safe README — https://www.npmjs.com/package/json-stringify-safe"
    - "Test vectors verified with json-stringify-safe via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "json-stringify-safe source"
  notes:
    - "json-stringify-safe is an npm package. Install: npm install json-stringify-safe"
    - "The module exports a function identical to JSON.stringify but handles circular references."
    - "Circular references are replaced with the string '[Circular ~]'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a JSON string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table json_stringify_safe.stringify:
  kind: node_module_call_eq
  function: ~
  category: serialize
  id_prefix: jsstringsafe

  columns: [id, args, expected]
  rows:
    - [simple,  [{"a": 1, "b": "hello"}],  "{\"a\":1,\"b\":\"hello\"}"]
    - [array,   [[1, 2, 3]],               "[1,2,3]"]
