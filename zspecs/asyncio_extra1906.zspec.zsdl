spec: asyncio_extra1906
version: ">=3.9"
backend: python_module(asyncio)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "asyncio.Task and asyncio.Future are C-level types; their __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "asyncio.Event, asyncio.Lock, asyncio.Queue, asyncio.Semaphore, asyncio.Condition are Python classes; none define __reversed__, __missing__, or __match_args__."
    - "asyncio exception types (TimeoutError, CancelledError, InvalidStateError) do not define __match_args__ in their own __dict__."
    - "asyncio.Task.__qualname__ == 'Task' — top-level C-accelerated class."
    - "asyncio.Future.__qualname__ == 'Future' — top-level C-accelerated class."
    - "asyncio.Event.__qualname__ == 'Event' — top-level Python class."
    - "asyncio.Lock.__qualname__ == 'Lock' — top-level Python class."
    - "asyncio.Queue.__qualname__ == 'Queue' — top-level Python class."
    - "asyncio.Semaphore.__qualname__ == 'Semaphore' — top-level Python class."
    - "asyncio.Condition.__qualname__ == 'Condition' — top-level Python class."
    - "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level Python class."
    - "asyncio.StreamReader.__qualname__ == 'StreamReader' — top-level Python class."
    - "asyncio.TimeoutError.__qualname__ == 'TimeoutError' — top-level exception class."
    - "asyncio.CancelledError.__qualname__ == 'CancelledError' — top-level exception class."
    - "asyncio.InvalidStateError.__qualname__ == 'InvalidStateError' — top-level exception class."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table asyncio_extra1906.reversed_protocol:
  kind: python_call_eq
  category: reversed_protocol
  id_prefix: as1906

  columns: [id, function, args, expected]
  rows:
    - ["as1906001", "asyncio.Task.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906002", "asyncio.Future.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906003", "asyncio.Event.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906004", "asyncio.Lock.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906005", "asyncio.Queue.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906006", "asyncio.Semaphore.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906007", "asyncio.Condition.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906008", "asyncio.TimeoutError.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906009", "asyncio.CancelledError.__dict__.__contains__", ["__reversed__"], false]
    - ["as1906010", "asyncio.InvalidStateError.__dict__.__contains__", ["__reversed__"], false]

