spec: pathlib_extra123
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec extends pathlib_extra122.zspec.zsdl."
    - "This spec covers: pathlib.Path stat-related and mutation method qualnames not yet covered."
    - "pathlib_extra101 covered stat/chmod qualnames; pathlib_extra116 covered lstat/owner/group qualnames."
    - "pathlib_extra42 covered lchmod qualname (len 11); no prior spec asserted lchmod __qualname__ equality."
    - "No prior pathlib_extra spec has asserted lchmod.__qualname__ == 'Path.lchmod' as an equality invariant."
    - "pathlib.Path.lchmod.__qualname__ == 'Path.lchmod' (len 11); lchmod does not follow symlinks."
    - "pathlib.Path.touch.__qualname__ == 'Path.touch' (len 10); creates the file if it does not exist."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (len 11); removes the file or symbolic link."
    - "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' (len 15)."
    - "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (len 16)."
    - "pathlib_extra94 and pathlib_extra98 covered touch/unlink/rename/replace/symlink_to/hardlink_to __len__() only."
    - "No prior pathlib_extra spec asserted lchmod equality, or touch/unlink/symlink_to/hardlink_to equality."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.lchmod and Path.touch qualnames
# Path.lchmod.__qualname__ == 'Path.lchmod' (11 chars).
# Path.touch.__qualname__ == 'Path.touch' (10 chars).
# pathlib_extra42 covered lchmod qualname __len__() == 11, but NOT the equality assertion.
# pathlib_extra94 covered touch qualname __len__() == 10, but NOT the equality assertion.
# lchmod is the symlink-aware counterpart to chmod: it changes permissions on the
# symlink itself rather than its target. touch creates the file if it does not exist,
# or updates its access and modification timestamps if it does.
# Both methods are defined directly on Path (qualname prefix 'Path.').
# ---------------------------------------------------------------------------

table pathlib_extra123.lchmod_touch_qualnames:
  description: "pathlib.Path.lchmod.__qualname__='Path.lchmod'(11); Path.touch.__qualname__='Path.touch'(10); lchmod sets perms on symlink itself; touch creates/updates mtime; equality assertions novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlblcht123a

  columns: [id, function, args, expected, description]
  rows:
    - [lchmod_qn_eq,   "Path.lchmod.__qualname__.__eq__",          ["Path.lchmod"], true,  "pathlib.Path.lchmod.__qualname__ == 'Path.lchmod' (11 chars; lchmod changes mode of the symlink itself, not its target; defined on Path, so qualname uses 'Path.' prefix)"]
    - [lchmod_qn_len,  "Path.lchmod.__qualname__.__len__",         [],              11,    "pathlib.Path.lchmod.__qualname__.__len__() == 11 ('Path.lchmod' has 11 characters: 'Path.'(5)+'lchmod'(6)==11)"]
    - [touch_qn_eq,    "Path.touch.__qualname__.__eq__",           ["Path.touch"],  true,  "pathlib.Path.touch.__qualname__ == 'Path.touch' (10 chars; touch creates the file or updates its timestamps; defined on Path)"]
    - [touch_qn_len,   "Path.touch.__qualname__.__len__",          [],              10,    "pathlib.Path.touch.__qualname__.__len__() == 10 ('Path.touch' has 10 characters: 'Path.'(5)+'touch'(5)==10)"]
    - [lchmod_gt_touch, "Path.lchmod.__qualname__.__len__.__gt__", [10],            true,  "len('Path.lchmod') > len('Path.touch') (11 > 10; 'lchmod'(6) is 1 char longer than 'touch'(5))"]
    - [lchmod_type,    "Path.lchmod.__class__.__name__.__eq__",    ["function"],    true,  "type(pathlib.Path.lchmod).__name__ == 'function' (lchmod is a plain Python function defined in Lib/pathlib/_local.py, not a C method_descriptor)"]
    - [touch_type,     "Path.touch.__class__.__name__.__eq__",     ["function"],    true,  "type(pathlib.Path.touch).__name__ == 'function' (touch is a plain Python function; same class as lchmod and most other Path methods)"]

# ---------------------------------------------------------------------------
# pathlib.Path.unlink and Path.symlink_to qualnames
# Path.unlink.__qualname__ == 'Path.unlink' (11 chars).
# Path.symlink_to.__qualname__ == 'Path.symlink_to' (15 chars).
# pathlib_extra98 covered unlink/symlink_to __len__() only.
# No prior pathlib_extra spec has asserted the equality for unlink or symlink_to qualnames.
# unlink removes a file or symbolic link; it raises FileNotFoundError if missing_ok=False.
# symlink_to creates a symbolic link pointing to target.
# Both have qualname prefix 'Path.' (not 'PurePath.') since they are defined on Path.
# ---------------------------------------------------------------------------

table pathlib_extra123.unlink_symlink_to_qualnames:
  description: "pathlib.Path.unlink.__qualname__='Path.unlink'(11); Path.symlink_to.__qualname__='Path.symlink_to'(15); filesystem mutation methods defined on Path; equality assertions novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlbulst123b

  columns: [id, function, args, expected, description]
  rows:
    - [unlink_qn_eq,     "Path.unlink.__qualname__.__eq__",          ["Path.unlink"],     true,  "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (11 chars; unlink removes a file or symlink; uses 'Path.' prefix because it is a filesystem operation defined on Path, not PurePath)"]
    - [unlink_qn_len,    "Path.unlink.__qualname__.__len__",         [],                  11,    "pathlib.Path.unlink.__qualname__.__len__() == 11 ('Path.unlink' has 11 characters: 'Path.'(5)+'unlink'(6)==11; same length as 'Path.lchmod')"]
    - [symto_qn_eq,      "Path.symlink_to.__qualname__.__eq__",      ["Path.symlink_to"], true,  "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' (15 chars; symlink_to creates a symlink pointing to target; uses 'Path.' prefix)"]
    - [symto_qn_len,     "Path.symlink_to.__qualname__.__len__",     [],                  15,    "pathlib.Path.symlink_to.__qualname__.__len__() == 15 ('Path.symlink_to' has 15 characters: 'Path.'(5)+'symlink_to'(10)==15)"]
    - [symto_gt_unlink,  "Path.symlink_to.__qualname__.__len__.__gt__", [11],             true,  "len('Path.symlink_to') > len('Path.unlink') (15 > 11; 'symlink_to'(10) is 4 chars longer than 'unlink'(6))"]
    - [unlink_type,      "Path.unlink.__class__.__name__.__eq__",    ["function"],        true,  "type(pathlib.Path.unlink).__name__ == 'function' (unlink is a plain Python function defined in Lib/pathlib/_local.py)"]
    - [unlink_eq_lchmod, "Path.unlink.__qualname__.__len__.__eq__",  [11],                true,  "len('Path.unlink') == len('Path.lchmod') == 11 (both unlink and lchmod have 11-char qualnames; they share the 'Path.'(5) prefix and a 6-char method name)"]

# ---------------------------------------------------------------------------
# pathlib.Path.hardlink_to qualname and length comparisons
# Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (16 chars).
# hardlink_to (16) > symlink_to (15) > lchmod (11) == unlink (11) > touch (10).
# pathlib_extra98 covered hardlink_to __len__() == 16 only; no equality assertion exists.
# hardlink_to creates a hard link; available since Python 3.10.
# hardlink_to.__qualname__ (16) is the longest stat-mutation method qualname in this spec.
# ---------------------------------------------------------------------------

table pathlib_extra123.hardlink_to_length_comparisons:
  description: "pathlib.Path.hardlink_to.__qualname__='Path.hardlink_to'(16); longest among stat/mutation methods; hardlink_to > symlink_to(15) > lchmod(11) == unlink(11) > touch(10); equality assertion novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlbhlt123c

  columns: [id, function, args, expected, description]
  rows:
    - [hlt_qn_eq,        "Path.hardlink_to.__qualname__.__eq__",           ["Path.hardlink_to"], true,  "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (16 chars; hardlink_to creates a hard link; available since Python 3.10; uses 'Path.' prefix)"]
    - [hlt_qn_len,       "Path.hardlink_to.__qualname__.__len__",          [],                   16,    "pathlib.Path.hardlink_to.__qualname__.__len__() == 16 ('Path.hardlink_to' has 16 characters: 'Path.'(5)+'hardlink_to'(11)==16)"]
    - [hlt_gt_symto,     "Path.hardlink_to.__qualname__.__len__.__gt__",   [15],                 true,  "len('Path.hardlink_to') > len('Path.symlink_to') (16 > 15; 'hardlink_to'(11) is 1 char longer than 'symlink_to'(10))"]
    - [hlt_type,         "Path.hardlink_to.__class__.__name__.__eq__",     ["function"],         true,  "type(pathlib.Path.hardlink_to).__name__ == 'function' (hardlink_to is a plain Python function defined in Lib/pathlib/_local.py)"]
    - [hlt_ne_symto_eq,  "Path.hardlink_to.__qualname__.__eq__",           ["Path.symlink_to"],  false, "pathlib.Path.hardlink_to.__qualname__ != 'Path.symlink_to' (distinct methods: hardlink_to(16) vs symlink_to(15))"]
    - [hlt_gt_lchmod,    "Path.hardlink_to.__qualname__.__len__.__gt__",   [11],                 true,  "len('Path.hardlink_to') > len('Path.lchmod') (16 > 11; hardlink_to has the longest qualname among the stat-related and mutation methods covered in this spec)"]
    - [touch_lt_unlink,  "Path.touch.__qualname__.__len__.__lt__",         [11],                 true,  "len('Path.touch') < len('Path.unlink') (10 < 11; touch(10) is the shortest mutation method qualname among those covered in this spec)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra123.Path.lchmod_qualname_eq:
  description: "pathlib.Path.lchmod.__qualname__ == 'Path.lchmod' (length 11; lchmod is the symlink-aware counterpart to chmod: it changes the file mode and permissions of the symbolic link itself rather than of the file the link points to; it is defined directly on Path (not PurePath), so its qualname carries the 'Path.' prefix (5 chars) followed by 'lchmod' (6 chars) totalling 11; lchmod is not available on all platforms (raises NotImplementedError on systems that do not support symlink permissions); pathlib_extra42 verified lchmod.__qualname__.__len__()==11 but no prior pathlib_extra spec has asserted the equality 'Path.lchmod' as a full string)"
  category: method_identity
  kind: python_call_eq
  function: "Path.lchmod.__qualname__.__eq__"
  args: ["Path.lchmod"]
  expected: true

invariant pathlib_extra123.Path.unlink_qualname_eq:
  description: "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (length 11; unlink removes the file or symbolic link at this path; it raises FileNotFoundError if the path does not exist and missing_ok=False (the default); the missing_ok keyword argument was added in Python 3.8; unlink is defined on Path (not PurePath) because it is a filesystem operation; its qualname 'Path.unlink' uses the 'Path.' prefix (5 chars) followed by 'unlink' (6 chars) totalling 11 — the same length as 'Path.lchmod'; pathlib_extra98 verified __len__()==11 but no prior spec asserted equality)"
  category: method_identity
  kind: python_call_eq
  function: "Path.unlink.__qualname__.__eq__"
  args: ["Path.unlink"]
  expected: true

invariant pathlib_extra123.Path.symlink_to_qualname_eq:
  description: "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' (length 15; symlink_to creates a symbolic link pointing to target; if target_is_directory is True on Windows, the symlink is created as a directory symlink; the method is defined on Path (not PurePath), so its qualname carries the 'Path.' prefix (5 chars) followed by 'symlink_to' (10 chars) totalling 15; 'symlink_to' (10) is the longest method-name component among the mutation methods covered in this spec except for 'hardlink_to' (11); pathlib_extra98 verified __len__()==15 but no prior spec asserted the equality 'Path.symlink_to')"
  category: method_identity
  kind: python_call_eq
  function: "Path.symlink_to.__qualname__.__eq__"
  args: ["Path.symlink_to"]
  expected: true

invariant pathlib_extra123.Path.hardlink_to_qualname_eq:
  description: "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (length 16; hardlink_to creates a hard link pointing to this path; it was added in Python 3.10 as the preferred replacement for the older os.link-based approach; the qualname uses the 'Path.' prefix (5 chars) followed by 'hardlink_to' (11 chars) totalling 16; 'Path.hardlink_to' (16) is the longest qualname among the stat-related and filesystem-mutation Path methods covered in pathlib_extra123; pathlib_extra98 verified __len__()==16 but no prior spec asserted the full string equality)"
  category: method_identity
  kind: python_call_eq
  function: "Path.hardlink_to.__qualname__.__eq__"
  args: ["Path.hardlink_to"]
  expected: true

invariant pathlib_extra123.Path.touch_qualname_eq:
  description: "pathlib.Path.touch.__qualname__ == 'Path.touch' (length 10; touch creates the file at this path if it does not exist, or updates its access and modification timestamps if it does; it accepts optional mode and exist_ok keyword arguments; the qualname uses the 'Path.' prefix (5 chars) followed by 'touch' (5 chars) totalling 10; touch (10) is the shortest qualname among the mutation methods covered in this spec: touch(10) < lchmod(11) == unlink(11) < symlink_to(15) < hardlink_to(16); pathlib_extra94 verified __len__()==10 but no prior spec asserted the equality 'Path.touch')"
  category: method_identity
  kind: python_call_eq
  function: "Path.touch.__qualname__.__eq__"
  args: ["Path.touch"]
  expected: true
