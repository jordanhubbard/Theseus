    - [tpe_mod_eq,          ThreadPoolExecutor.__module__.__eq__,                       ["concurrent.futures.thread"],   true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [tpe_mod_len,         ThreadPoolExecutor.__module__.__len__,                      [],                              25,   "concurrent.futures.ThreadPoolExecutor.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [tpe_base_eq,         "ThreadPoolExecutor.__bases__[0].__name__.__eq__",          ["Executor"],                   true, "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
    - [tpe_base_len,        "ThreadPoolExecutor.__bases__[0].__name__.__len__",         [],                              8,    "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__len__() == 8; verified with Python 3.14.3"]
    - [tpe_submit_name_eq,  ThreadPoolExecutor.submit.__name__.__eq__,                  ["submit"],                     true, "concurrent.futures.ThreadPoolExecutor.submit.__name__ == 'submit'; verified with Python 3.14.3"]
    - [tpe_submit_qn_eq,    ThreadPoolExecutor.submit.__qualname__.__eq__,              ["ThreadPoolExecutor.submit"],  true, "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'; verified with Python 3.14.3"]
    - [tpe_submit_qn_len,   ThreadPoolExecutor.submit.__qualname__.__len__,             [],                              25,   "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [tpe_map_name_eq,     ThreadPoolExecutor.map.__name__.__eq__,                     ["map"],                        true, "concurrent.futures.ThreadPoolExecutor.map.__name__ == 'map'; verified with Python 3.14.3"]
    - [tpe_map_qn_eq,       ThreadPoolExecutor.map.__qualname__.__eq__,                 ["Executor.map"],               true, "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — map is inherited from Executor unchanged; verified with Python 3.14.3"]
    - [tpe_map_qn_len,      ThreadPoolExecutor.map.__qualname__.__len__,                [],                              12,   "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [tpe_shut_name_eq,    ThreadPoolExecutor.shutdown.__name__.__eq__,                ["shutdown"],                   true, "concurrent.futures.ThreadPoolExecutor.shutdown.__name__ == 'shutdown'; verified with Python 3.14.3"]
