spec: concurrent_futures_extra254
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); __module__ == 'concurrent.futures.thread' (len=25); __bases__[0].__name__ == 'Executor' (len=8)."
    - "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19); __module__ == 'concurrent.futures.process' (len=26); __bases__[0].__name__ == 'Executor' (len=8)."
    - "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25); ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26) — both submit methods are defined on their own class."
    - "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12) — map is inherited from Executor; ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23) — PPE overrides map."
    - "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27); ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28) — both implement their own shutdown."
    - "ProcessPoolExecutor.__module__ (len=26) is one char longer than ThreadPoolExecutor.__module__ (len=25) — 'process' vs 'thread'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

