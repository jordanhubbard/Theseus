    - [tpe_shut_qn_len,     ThreadPoolExecutor.shutdown.__qualname__.__len__,           [],                              27,   "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27; verified with Python 3.14.3"]

