table concurrent_futures_extra254.thread_pool_executor_identity:
  description: "concurrent.futures.ThreadPoolExecutor(len=18) class identity — inherits from Executor(len=8); defined in concurrent.futures.thread(len=25); submit.__qualname__ == 'ThreadPoolExecutor.submit'(len=25); map.__qualname__ == 'Executor.map'(len=12) — inherited from Executor; shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'(len=27); verified with Python 3.14.3"
