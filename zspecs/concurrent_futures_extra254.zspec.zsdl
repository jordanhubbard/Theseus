# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra254
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra254.tpe_map_inherited_from_executor:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map') returns True — ThreadPoolExecutor does not override map; it inherits Executor.map (qualname len=12) unchanged; in contrast ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23) — PPE provides its own map implementation; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra254.both_executors_share_executor_base:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — both ThreadPoolExecutor and ProcessPoolExecutor share 'Executor'(len=8) as their single base class, providing the common executor interface including map, submit, and shutdown; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true
