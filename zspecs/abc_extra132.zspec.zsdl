spec: abc_extra132
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABCMeta.__new__ qualname, module, and code object attributes. ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15); ABCMeta.__new__.__module__=='abc' (len=3); ABCMeta.__new__.__code__.co_argcount==4 (mcls, name, bases, namespace); ABCMeta.__new__.__code__.co_varnames.__len__()==6 ('mcls','name','bases','namespace','kwargs','cls'); 'namespace' in co_varnames==True; ABCMeta.register.__qualname__=='ABCMeta.register' (len=16); ABCMeta.__module__=='abc' (len=3); ABCMeta.__name__=='ABCMeta' (len=7). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ABCMeta.__init__.__qualname__ is 'type.__init__' (not 'ABCMeta.__init__') because ABCMeta does not define its own __init__ — it inherits from type. ABCMeta.__init__ is a wrapper_descriptor with no __code__ attribute. ABCMeta.__new__.__code__.co_kwonlyargcount==0; all 4 positional params (mcls, name, bases, namespace) are regular positional args. ABCMeta.__bases__[0].__name__=='type'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ qualname and module — extra132
#
# abc.ABCMeta.__new__.__qualname__  == 'ABCMeta.__new__' (len=15)
# abc.ABCMeta.__new__.__module__    == 'abc'              (len=3)
# ---------------------------------------------------------------------------

table abc_extra132.abcmeta_new_identity:
  description: "abc.ABCMeta.__new__ qualname and module identity checks — __new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15); __new__.__module__.__eq__('abc')==True (len=3: the abc module is just 'abc'); ABCMeta.__new__.__code__.co_argcount==4 (mcls, name, bases, namespace); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnew132

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,   abc.ABCMeta.__new__.__qualname__.__eq__,  ["ABCMeta.__new__"], true, "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [qn_len,  abc.ABCMeta.__new__.__qualname__.__len__,  [],                 15,   "abc.ABCMeta.__new__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [mod_eq,  abc.ABCMeta.__new__.__module__.__eq__,    ["abc"],             true, "abc.ABCMeta.__new__.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_len, abc.ABCMeta.__new__.__module__.__len__,    [],                 3,    "abc.ABCMeta.__new__.__module__.__len__() == 3; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ code object attributes — extra132
#
# abc.ABCMeta.__new__.__code__.co_argcount   == 4
# abc.ABCMeta.__new__.__code__.co_varnames   has len 6
# 'namespace' in abc.ABCMeta.__new__.__code__.co_varnames == True
# 'mcls' in abc.ABCMeta.__new__.__code__.co_varnames      == True
# ---------------------------------------------------------------------------

table abc_extra132.abcmeta_new_code:
  description: "abc.ABCMeta.__new__ code object attribute checks — co_argcount==4 (mcls, name, bases, namespace — the four positional args to __new__); co_varnames.__len__()==6 ('mcls','name','bases','namespace','kwargs','cls' — adds kwargs and cls as local vars); 'namespace' in co_varnames==True; 'mcls' in co_varnames==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnewcode132

  columns: [id, function, args, expected, description]
  rows:
    - [argc,            abc.ABCMeta.__new__.__code__.co_argcount.__eq__,              [4],           true, "abc.ABCMeta.__new__.__code__.co_argcount == 4 (mcls, name, bases, namespace); verified with Python 3.14.3"]
    - [varnames_len,    abc.ABCMeta.__new__.__code__.co_varnames.__len__,              [],           6,    "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6; verified with Python 3.14.3"]
    - [namespace_in,    abc.ABCMeta.__new__.__code__.co_varnames.__contains__,        ["namespace"], true, "abc.ABCMeta.__new__.__code__.co_varnames contains 'namespace'; verified with Python 3.14.3"]
    - [mcls_in,         abc.ABCMeta.__new__.__code__.co_varnames.__contains__,        ["mcls"],      true, "abc.ABCMeta.__new__.__code__.co_varnames contains 'mcls'; verified with Python 3.14.3"]
    - [cls_in,          abc.ABCMeta.__new__.__code__.co_varnames.__contains__,        ["cls"],       true, "abc.ABCMeta.__new__.__code__.co_varnames contains 'cls'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta class identity — extra132
#
# abc.ABCMeta.__name__            == 'ABCMeta' (len=7)
# abc.ABCMeta.__module__          == 'abc'     (len=3)
# abc.ABCMeta.__bases__[0].__name__ == 'type'  (len=4)
# ---------------------------------------------------------------------------

table abc_extra132.abcmeta_class_identity:
  description: "abc.ABCMeta class identity checks — ABCMeta.__name__.__eq__('ABCMeta')==True (len=7); ABCMeta.__module__.__eq__('abc')==True (len=3); ABCMeta.__bases__[0].__name__.__eq__('type')==True (len=4 — ABCMeta inherits from type, making it a metaclass); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta132

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,     abc.ABCMeta.__name__.__eq__,                     ["ABCMeta"], true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [name_len,    abc.ABCMeta.__name__.__len__,                     [],         7,    "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [mod_eq,      abc.ABCMeta.__module__.__eq__,                   ["abc"],     true, "abc.ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_len,     abc.ABCMeta.__module__.__len__,                   [],         3,    "abc.ABCMeta.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [base0_eq,    "abc.ABCMeta.__bases__[0].__name__.__eq__",      ["type"],    true, "abc.ABCMeta.__bases__[0].__name__ == 'type' (len=4); verified with Python 3.14.3"]
    - [base0_len,   "abc.ABCMeta.__bases__[0].__name__.__len__",      [],         4,    "abc.ABCMeta.__bases__[0].__name__.__len__() == 4 ('type'=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.register qualname and module — extra132
#
# abc.ABCMeta.register.__qualname__  == 'ABCMeta.register' (len=16)
# abc.ABCMeta.register.__module__    == 'abc'              (len=3)
# abc.ABCMeta.register.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table abc_extra132.abcmeta_register_identity:
  description: "abc.ABCMeta.register qualname, module, and co_argcount checks — register.__qualname__.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16); register.__module__.__eq__('abc')==True (len=3); register.__code__.co_argcount==2 (cls, subclass); register.__code__.co_varnames.__len__()==2 (only cls and subclass); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcreg132

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        abc.ABCMeta.register.__qualname__.__eq__,            ["ABCMeta.register"], true, "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [qn_len,       abc.ABCMeta.register.__qualname__.__len__,            [],                  16,   "abc.ABCMeta.register.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [mod_eq,       abc.ABCMeta.register.__module__.__eq__,              ["abc"],              true, "abc.ABCMeta.register.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [argc,         abc.ABCMeta.register.__code__.co_argcount.__eq__,    [2],                 true, "abc.ABCMeta.register.__code__.co_argcount == 2 (cls, subclass); verified with Python 3.14.3"]
    - [varnames_len, abc.ABCMeta.register.__code__.co_varnames.__len__,    [],                 2,    "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2 ('cls', 'subclass'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra132
# ---------------------------------------------------------------------------

invariant abc_extra132.abcmeta_new_qualname_len_15:
  description: "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — ABCMeta.__new__.__qualname__ is 'ABCMeta.__new__' (15 chars: 'ABCMeta'=7+'.'=1+'__new__'=7=15); ABCMeta.__new__.__module__ is 'abc' (len=3); co_argcount==4 (mcls, name, bases, namespace); co_varnames.__len__()==6; NEW in extra132: first standalone ABCMeta.__new__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant abc_extra132.abcmeta_new_co_argcount_4:
  description: "abc.ABCMeta.__new__.__code__.co_argcount == 4 — ABCMeta.__new__ takes (mcls, name, bases, namespace) as its four positional arguments; mcls is the metaclass (ABCMeta itself), name is the class name string, bases is the tuple of base classes, namespace is the class namespace dict; co_varnames.__len__()==6 (also has kwargs and cls as local variables); NEW in extra132: first standalone ABCMeta.__new__ co_argcount invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_argcount
  args: []
  expected: 4

invariant abc_extra132.abcmeta_new_co_varnames_len_6:
  description: "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6 — ABCMeta.__new__.__code__.co_varnames is ('mcls', 'name', 'bases', 'namespace', 'kwargs', 'cls'); len 6; co_argcount==4 (first 4 are the positional params); the extra 2 locals are 'kwargs' (captures **kwargs) and 'cls' (the created class); 'namespace' is in co_varnames (True); 'cls' is in co_varnames (True); NEW in extra132: first standalone ABCMeta.__new__ co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant abc_extra132.abcmeta_name_len_7:
  description: "abc.ABCMeta.__name__.__len__() == 7 — ABCMeta.__name__ is 'ABCMeta' (7 chars: 'ABC'=3+'Meta'=4=7); ABCMeta.__module__ is 'abc' (len=3); ABCMeta.__bases__[0].__name__ is 'type' (len=4); ABCMeta.__new__ qualname len==15; register qualname len==16; NEW in extra132: first standalone ABCMeta.__name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra132.abcmeta_register_qualname_len_16:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — ABCMeta.register.__qualname__ is 'ABCMeta.register' (16 chars: 'ABCMeta'=7+'.'=1+'register'=8=16); register qualname (16) is one longer than __new__ qualname (15); register.__code__.co_argcount==2 (cls, subclass); register.__code__.co_varnames.__len__()==2; NEW in extra132: first standalone ABCMeta.register qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16
