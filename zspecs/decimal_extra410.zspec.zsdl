spec: decimal_extra410
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Decimal methods as_tuple, as_integer_ratio, is_finite, is_infinite, is_nan, is_zero, is_signed each report __name__ matching their Python-level name"
    - "as_integer_ratio is available from Python 3.9 onward"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal method __name__ identity — tuple/ratio conversion and predicates
# ---------------------------------------------------------------------------

table decimal_extra410.decimal_method_names:
  description: "decimal.Decimal method __name__ identity — as_tuple, as_integer_ratio, is_finite, is_infinite, is_nan, is_zero, is_signed; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decdecmeth410

  columns: [id, function, args, expected]
  rows:
    - [as_tuple_name,          decimal.Decimal.as_tuple.__name__.__eq__,          ["as_tuple"],          true]
    - [as_integer_ratio_name,  decimal.Decimal.as_integer_ratio.__name__.__eq__,  ["as_integer_ratio"],  true]
    - [is_finite_name,         decimal.Decimal.is_finite.__name__.__eq__,         ["is_finite"],         true]
    - [is_infinite_name,       decimal.Decimal.is_infinite.__name__.__eq__,       ["is_infinite"],       true]
    - [is_nan_name,            decimal.Decimal.is_nan.__name__.__eq__,            ["is_nan"],            true]
    - [is_zero_name,           decimal.Decimal.is_zero.__name__.__eq__,           ["is_zero"],           true]
    - [is_signed_name,         decimal.Decimal.is_signed.__name__.__eq__,         ["is_signed"],         true]
