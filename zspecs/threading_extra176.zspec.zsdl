spec: threading_extra176
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.RLock function identity — threading.RLock is a factory function (not a class); threading.RLock.__name__=='RLock' (len=5); threading.RLock.__module__=='threading'; threading.RLock.__class__.__name__=='function'; threading.RLock.__mro__ raises AttributeError (function has no __mro__); threading.Condition.__name__=='Condition' (len=9); threading.Condition.__module__=='threading'; threading.Condition.__mro__.__len__()==2 (Condition > object); threading.Timer.__name__=='Timer' (len=5; same len as RLock.__name__); threading.Timer.__mro__.__len__()==3 (Timer > Thread > object); threading.Timer.__bases__[0].__name__=='Thread'."
    - "threading.RLock is a function — on Python 3.14.3 threading.RLock is a factory function defined in Lib/threading.py that creates _RLock instances (the actual C extension lock type from _threadmodule.c); it is NOT a class, so threading.RLock.__mro__ raises AttributeError. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' — the factory function has __name__ 'RLock', 5 characters. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' — the RLock factory function is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — since RLock is a Python function, its __class__ is the 'function' type. Verified with Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition' — threading.Condition is a Python class in Lib/threading.py; its __name__ is 'Condition', 9 characters. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading' — Condition is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Condition.__mro__.__len__() == 2 — Condition inherits directly from object; its MRO is (Condition, object). Verified with Python 3.14.3."
    - "threading.Timer.__name__ == 'Timer' — Timer is a Python class in Lib/threading.py; its __name__ is 'Timer', 5 characters (same length as 'RLock'). Verified with Python 3.14.3."
    - "threading.Timer.__mro__.__len__() == 3 — Timer inherits from Thread which inherits from object; its MRO is (Timer, Thread, object), length 3. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer's only direct base class is Thread; __bases__[0].__name__ is 'Thread'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock function __name__, __module__, and __class__
#
# threading.RLock.__name__ == 'RLock'
# threading.RLock.__name__.__len__() == 5
# threading.RLock.__module__ == 'threading'
# threading.RLock.__class__.__name__ == 'function'
#
# On Python 3.14.3 threading.RLock is a factory function (not a class) defined
# in Lib/threading.py. It returns instances of the internal _RLock class (the
# C extension type). As a Python function its __class__ is 'function', its
# __name__ is 'RLock' (5 chars), and its __module__ is 'threading'. New to
# extra176.
# ---------------------------------------------------------------------------

table threading_extra176.rlock_function_name_module_class:
  description: "threading.RLock: function; __name__ 'RLock' len 5; __module__ 'threading'; __class__.__name__ 'function'; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlock176

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq,
       "RLock.__name__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — threading.RLock is a factory function in Lib/threading.py that creates reentrant lock instances; as a Python function its __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra176"]
    - [rlock_name_len_5,
       "RLock.__name__.__len__",
       [],
       5,
       "threading.RLock.__name__.__len__() == 5 — the name 'RLock' has exactly 5 characters: R-L-o-c-k; str.__len__() returns 5; new to extra176"]
    - [rlock_module_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — the RLock factory function is defined in Lib/threading.py; its __module__ is the string 'threading'; str.__eq__('threading') returns True; new to extra176"]
    - [rlock_class_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a Python function (not a class); its __class__ is the built-in 'function' type; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock.__mro__ raises AttributeError; RLock module len
#
# threading.RLock.__mro__ raises AttributeError
# threading.RLock.__module__.__len__() == 9
# threading.RLock.__name__.__class__.__name__ == 'str'
# threading.RLock.__class__.__name__ != 'type'
#
# Since RLock is a function, accessing __mro__ raises AttributeError
# ('function' object has no attribute '__mro__'). The module name 'threading'
# is 9 characters long. New to extra176.
# ---------------------------------------------------------------------------

table threading_extra176.rlock_mro_raises_and_module_len:
  description: "threading.RLock.__mro__ raises AttributeError (function has no __mro__); module len 9; __name__.__class__ 'str'; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlock176

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_module_len_9,
       "RLock.__module__.__len__",
       [],
       9,
       "threading.RLock.__module__.__len__() == 9 — the module name 'threading' has exactly 9 characters: t-h-r-e-a-d-i-n-g; str.__len__() returns 9; new to extra176"]
    - [rlock_name_class_str,
       "RLock.__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.RLock.__name__.__class__.__name__.__eq__('str') == True — RLock.__name__ is the string 'RLock', a str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra176"]
    - [rlock_class_not_type,
       "RLock.__class__.__name__.__eq__",
       ["type"],
       false,
       "threading.RLock.__class__.__name__.__eq__('type') == False — threading.RLock is a function, not a class/type object; its __class__.__name__ is 'function', not 'type'; str.__eq__('type') returns False; new to extra176"]
    - [rlock_module_class_str,
       "RLock.__module__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.RLock.__module__.__class__.__name__.__eq__('str') == True — RLock.__module__ is the string 'threading', a str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition class __name__, __module__, __mro__
#
# threading.Condition.__name__ == 'Condition'
# threading.Condition.__name__.__len__() == 9
# threading.Condition.__module__ == 'threading'
# threading.Condition.__mro__.__len__() == 2
#
# threading.Condition is a Python class in Lib/threading.py implementing a
# condition variable synchronization primitive. It inherits directly from
# object; its MRO is (Condition, object), length 2. New to extra176.
# ---------------------------------------------------------------------------

table threading_extra176.condition_name_module_mro:
  description: "threading.Condition.__name__ 'Condition' len 9; __module__ 'threading'; __mro__ len 2; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlock176

  columns: [id, function, args, expected, description]
  rows:
    - [condition_name_eq,
       "Condition.__name__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — threading.Condition is a Python class in Lib/threading.py implementing condition variable synchronization, allowing threads to wait for some condition to become true; its __name__ is 'Condition'; str.__eq__('Condition') returns True; new to extra176"]
    - [condition_name_len_9,
       "Condition.__name__.__len__",
       [],
       9,
       "threading.Condition.__name__.__len__() == 9 — the name 'Condition' has exactly 9 characters: C-o-n-d-i-t-i-o-n; str.__len__() returns 9; new to extra176"]
    - [condition_module_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — threading.Condition is a Python class defined in Lib/threading.py; its __module__ is the string 'threading'; str.__eq__('threading') returns True; new to extra176"]
    - [condition_mro_len_2,
       "Condition.__mro__.__len__",
       [],
       2,
       "threading.Condition.__mro__.__len__() == 2 — threading.Condition is a Python class defined in Lib/threading.py that implements condition variable synchronization; it inherits directly from object with no intermediate base classes; its __mro__ is (Condition, object), a tuple of length 2; tuple.__len__() returns 2; new to extra176"]

# ---------------------------------------------------------------------------
# Table 4: threading.Timer class identity — __name__, __mro__, __bases__
#
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__name__.__len__() == 5
# threading.Timer.__mro__.__len__() == 3
# threading.Timer.__bases__[0].__name__ == 'Thread'
#
# threading.Timer is a Python class in Lib/threading.py that represents an
# action to be run after a delay. It inherits from Thread, which in turn
# inherits from object, giving a 3-element MRO: (Timer, Thread, object).
# __name__ is 'Timer' (5 chars, same length as 'RLock'). New to extra176.
# ---------------------------------------------------------------------------

table threading_extra176.timer_name_mro_bases:
  description: "threading.Timer.__name__ 'Timer' len 5; __mro__ len 3 (Timer>Thread>object); __bases__[0] 'Thread'; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlock176

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — threading.Timer is a Python class in Lib/threading.py representing an action (a callable) to run after a specified interval; it inherits from Thread; its __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra176"]
    - [timer_name_len_5,
       "Timer.__name__.__len__",
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — the name 'Timer' has exactly 5 characters: T-i-m-e-r; same length as 'RLock' (5); str.__len__() returns 5; new to extra176"]
    - [timer_mro_len_3,
       "Timer.__mro__.__len__",
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — threading.Timer is a Python class in Lib/threading.py that inherits from Thread, which inherits from object; its MRO is (Timer, Thread, object), a tuple of length 3; tuple.__len__() returns 3; new to extra176"]
    - ["timer_bases_0_thread",
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — threading.Timer inherits directly from threading.Thread; its only direct base class is Thread; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Table 5: threading.Timer __mro__ entries cross-check
#
# threading.Timer.__mro__[0].__name__ == 'Timer'
# threading.Timer.__mro__[1].__name__ == 'Thread'
# threading.Timer.__mro__[2].__name__ == 'object'
# threading.Timer.__module__ == 'threading'
#
# Cross-checks confirming each entry in Timer's 3-element MRO. The MRO is
# (Timer, Thread, object). Timer is also in the 'threading' module. New to
# extra176.
# ---------------------------------------------------------------------------

table threading_extra176.timer_mro_entries:
  description: "threading.Timer.__mro__: mro[0] 'Timer', mro[1] 'Thread', mro[2] 'object'; __module__ 'threading'; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlock176

  columns: [id, function, args, expected, description]
  rows:
    - ["timer_mro_0_timer",
       "Timer.__mro__[0].__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__mro__[0].__name__.__eq__('Timer') == True — the first entry in Timer.__mro__ is the Timer class itself; its __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra176"]
    - ["timer_mro_1_thread",
       "Timer.__mro__[1].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__mro__[1].__name__.__eq__('Thread') == True — the second entry in Timer.__mro__ is Thread, Timer's direct parent class; its __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra176"]
    - ["timer_mro_2_object",
       "Timer.__mro__[2].__name__.__eq__",
       ["object"],
       true,
       "threading.Timer.__mro__[2].__name__.__eq__('object') == True — the third and final entry in Timer.__mro__ is the root base class object; its __name__ is 'object'; str.__eq__('object') returns True; new to extra176"]
    - [timer_module_threading,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — threading.Timer is a Python class defined in Lib/threading.py; its __module__ is the string 'threading'; str.__eq__('threading') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra176
# ---------------------------------------------------------------------------

invariant threading_extra176.rlock_name_rlock:
  description: "threading.RLock.__name__ == 'RLock' — RLock is a factory function in Lib/threading.py with __name__ 'RLock' (5 chars); new to extra176"
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra176.rlock_module_threading:
  description: "threading.RLock.__module__ == 'threading' — the RLock factory function is defined in Lib/threading.py; new to extra176"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra176.rlock_class_function:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a Python function (not a class); its __class__.__name__ is 'function'; new to extra176"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra176.rlock_mro_raises:
  description: "threading.RLock.__mro__ raises AttributeError — RLock is a function, not a class; function objects have no __mro__ attribute; new to extra176"
  kind: python_call_raises
  function: "RLock.__mro__.__len__"
  args: []
  expected: AttributeError

invariant threading_extra176.condition_name_condition:
  description: "threading.Condition.__name__ == 'Condition' — Python class in Lib/threading.py with __name__ 'Condition' (9 chars); new to extra176"
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra176.condition_mro_len_2:
  description: "threading.Condition.__mro__.__len__() == 2 — Condition inherits directly from object; MRO is (Condition, object); new to extra176"
  kind: python_call_eq
  function: Condition.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra176.timer_name_timer:
  description: "threading.Timer.__name__ == 'Timer' — Python class in Lib/threading.py with __name__ 'Timer' (5 chars, same length as 'RLock'); new to extra176"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra176.timer_mro_len_3:
  description: "threading.Timer.__mro__.__len__() == 3 — Timer inherits from Thread which inherits from object; MRO is (Timer, Thread, object); new to extra176"
  kind: python_call_eq
  function: Timer.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra176.timer_bases_0_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer's only direct base class is Thread; new to extra176"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true
