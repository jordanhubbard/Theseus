    - ["re3421005", operator.contains, [re.Match.__dict__,     "__eq__"], false]
    - ["re3421006", operator.contains, [re.RegexFlag.__dict__, "__eq__"], false]

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# No re class defines __lt__ in its own __dict__; all false.
# re.Pattern and re.Match are not types that define ordering.
# re.RegexFlag is an IntFlag subclass but __lt__ is not stored in
# re.RegexFlag.__dict__ itself.
# ---------------------------------------------------------------------------

table re3421.lt:
  description: "re types __lt__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3421

  columns: [id, function, args, expected]
  rows:
    - ["re3421007", operator.contains, [re.Pattern.__dict__,   "__lt__"], false]
    - ["re3421008", operator.contains, [re.Match.__dict__,     "__lt__"], false]
    - ["re3421009", operator.contains, [re.RegexFlag.__dict__, "__lt__"], false]

# ---------------------------------------------------------------------------
# combined — __hash__, __eq__, __lt__ across all 3 re subjects
#
# 3 classes x 3 methods = 9 rows.
# All nine values are false; re types do not implement hash, equality,
# or ordering protocols in their own __dict__s. re.RegexFlag is an
# IntFlag subclass; __hash__, __eq__, __lt__ are not stored in
# re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

