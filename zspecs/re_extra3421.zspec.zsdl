spec: re3421
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 675 (re3421): __hash__, __eq__, __lt__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __hash__/__eq__/__lt__ dict-presence (hash(x), x==y, x<y)."
    - "No re class defines __hash__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; hash() is not explicitly defined. re.RegexFlag is an IntFlag enum but __hash__ is not present in re.RegexFlag.__dict__."
    - "No re class defines __eq__ in its own __dict__: re.Pattern, re.Match, and re.RegexFlag do not implement custom equality comparison in their own __dict__s."
    - "No re class defines __lt__ in its own __dict__: re.Pattern, re.Match, and re.RegexFlag do not implement ordering in their own __dict__s."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all hash/equality/ordering operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# No re class defines __hash__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but hash() support is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3421.hash:
  description: "re types __hash__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3421

  columns: [id, function, args, expected]
  rows:
    - ["re3421001", operator.contains, [re.Pattern.__dict__,   "__hash__"], false]
    - ["re3421002", operator.contains, [re.Match.__dict__,     "__hash__"], false]
    - ["re3421003", operator.contains, [re.RegexFlag.__dict__, "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# No re class defines __eq__ in its own __dict__; all false.
# re types do not implement custom equality comparison in their own __dict__s.
# re.RegexFlag (IntFlag) does not define __eq__ in its own __dict__.
# ---------------------------------------------------------------------------

table re3421.eq:
  description: "re types __eq__ dict-presence checks; wave 675"
