spec: uuid_extra276
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — UUID namespace constants and their properties"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Namespace UUIDs are defined in RFC 4122 and are fixed constants"
    - "NAMESPACE_DNS hex is 6ba7b8109dad11d180b400c04fd430c8 (version 1 UUID)"
    - "NAMESPACE_URL hex is 6ba7b8119dad11d180b400c04fd430c8 (version 1 UUID)"
    - "NAMESPACE_OID hex is 6ba7b8129dad11d180b400c04fd430c8 (version 1 UUID)"
    - "NAMESPACE_X500 hex is 6ba7b8149dad11d180b400c04fd430c8 (version 1 UUID)"
    - "All namespace UUIDs are version 1 as per RFC 4122"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra276.namespace_class_names:
  description: "uuid namespace constants are all UUID instances"
  kind: python_call_eq
  category: identity
  id_prefix: uns

  columns: [id, function, args, expected, description]
  rows:
    - [uns001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true, "NAMESPACE_DNS is a UUID instance"]
    - [uns002, uuid.NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true, "NAMESPACE_URL is a UUID instance"]
    - [uns003, uuid.NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true, "NAMESPACE_OID is a UUID instance"]
    - [uns004, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true, "NAMESPACE_X500 is a UUID instance"]

table uuid_extra276.namespace_versions:
  description: "uuid namespace constants are all version 1 UUIDs per RFC 4122"
  kind: python_call_eq
  category: identity
  id_prefix: unv

  columns: [id, function, args, expected, description]
  rows:
    - [unv001, uuid.NAMESPACE_DNS.version.__eq__,  [1], true, "NAMESPACE_DNS is version 1"]
    - [unv002, uuid.NAMESPACE_URL.version.__eq__,  [1], true, "NAMESPACE_URL is version 1"]
    - [unv003, uuid.NAMESPACE_OID.version.__eq__,  [1], true, "NAMESPACE_OID is version 1"]
    - [unv004, uuid.NAMESPACE_X500.version.__eq__, [1], true, "NAMESPACE_X500 is version 1"]

invariant uuid_extra276.namespace_dns_hex:
  description: "NAMESPACE_DNS has the RFC 4122-specified hex value"
  category: identity
  kind: python_call_eq
  function: uuid.NAMESPACE_DNS.hex.__eq__
  args: ["6ba7b8109dad11d180b400c04fd430c8"]
  expected: true

invariant uuid_extra276.namespace_url_hex:
  description: "NAMESPACE_URL has the RFC 4122-specified hex value"
  category: identity
  kind: python_call_eq
  function: uuid.NAMESPACE_URL.hex.__eq__
  args: ["6ba7b8119dad11d180b400c04fd430c8"]
  expected: true

invariant uuid_extra276.uuid4_name:
  description: "uuid.uuid4 function is named uuid4"
  category: identity
  kind: python_call_eq
  function: uuid.uuid4.__name__.__eq__
  args: ["uuid4"]
  expected: true

invariant uuid_extra276.uuid3_name:
  description: "uuid.uuid3 function is named uuid3"
  category: identity
  kind: python_call_eq
  function: uuid.uuid3.__name__.__eq__
  args: ["uuid3"]
  expected: true

invariant uuid_extra276.uuid5_name:
  description: "uuid.uuid5 function is named uuid5"
  category: identity
  kind: python_call_eq
  function: uuid.uuid5.__name__.__eq__
  args: ["uuid5"]
  expected: true
