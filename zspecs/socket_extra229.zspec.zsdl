spec: socket_extra229
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.create_connection.__name__ == 'create_connection' — Python function in socket.py; 17 characters."
    - "socket.create_connection.__module__ == 'socket' — defined in the socket module."
    - "socket.create_server.__name__ == 'create_server' — Python function added in Python 3.8; 13 characters."
    - "socket.create_server.__module__ == 'socket' — defined in the socket module."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo' — C builtin from _socket; 11 characters."
    - "socket.getaddrinfo.__module__ == 'socket' — exposed as socket.getaddrinfo."
    - "socket.getnameinfo.__name__ == 'getnameinfo' — C builtin from _socket; 11 characters."
    - "socket.getnameinfo.__module__ == '_socket' — __module__ reflects C extension origin."
    - "socket.getfqdn.__name__ == 'getfqdn' — Python function in socket.py; 7 characters."
    - "socket.socketpair.__name__ == 'socketpair' — Python function in socket.py; 10 characters."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.create_connection function identity contracts
#
# socket.create_connection.__name__    == 'create_connection'
# socket.create_connection.__module__  == 'socket'
# socket.create_connection.__qualname__ == 'create_connection'
# len('create_connection') == 17
#
# create_connection is a high-level convenience function that creates a TCP
# connection to (host, port). It is defined in Lib/socket.py. It handles
# address resolution and connects, returning a connected socket object.
# ---------------------------------------------------------------------------

table socket_extra229.create_connection_identity:
  description: "create_connection.__name__=='create_connection'; __module__=='socket'; __qualname__=='create_connection'; __name__.__len__()==17; function identity; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: socket229

  columns: [id, function, args, expected, description]
  rows:
    - [create_connection_name_eq,
       "create_connection.__name__.__eq__",
       ["create_connection"],
       true,
       "socket.create_connection.__name__.__eq__('create_connection') == True — create_connection is a Python convenience function for TCP connections; __name__ is 'create_connection' (17 characters); new anchor in extra229 namespace; verified Python 3.14.3"]
    - [create_connection_module_eq,
       "create_connection.__module__.__eq__",
       ["socket"],
       true,
       "socket.create_connection.__module__.__eq__('socket') == True — create_connection is a Python function defined in Lib/socket.py; __module__ is 'socket'; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [create_connection_qualname_eq,
       "create_connection.__qualname__.__eq__",
       ["create_connection"],
       true,
       "socket.create_connection.__qualname__.__eq__('create_connection') == True — create_connection is a top-level function so __qualname__ equals __name__; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [create_connection_name_len_17,
       "create_connection.__name__.__len__",
       [],
       17,
       "socket.create_connection.__name__.__len__() == 17 — the string 'create_connection' has 17 characters; portable length anchor; new anchor in extra229 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.create_server function identity contracts
#
# socket.create_server.__name__    == 'create_server'
# socket.create_server.__module__  == 'socket'
# socket.create_server.__qualname__ == 'create_server'
# len('create_server') == 13
#
# create_server is a convenience function added in Python 3.8 that creates a
# server socket bound to the given address. It is defined in Lib/socket.py.
# ---------------------------------------------------------------------------

table socket_extra229.create_server_identity:
  description: "create_server.__name__=='create_server'; __module__=='socket'; __qualname__=='create_server'; __name__.__len__()==13; function identity; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: socket229a

  columns: [id, function, args, expected, description]
  rows:
    - [create_server_name_eq,
       "create_server.__name__.__eq__",
       ["create_server"],
       true,
       "socket.create_server.__name__.__eq__('create_server') == True — create_server is a Python convenience function added in Python 3.8 for creating server sockets; __name__ is 'create_server' (13 characters); new anchor in extra229 namespace; verified Python 3.14.3"]
    - [create_server_module_eq,
       "create_server.__module__.__eq__",
       ["socket"],
       true,
       "socket.create_server.__module__.__eq__('socket') == True — create_server is defined in Lib/socket.py; __module__ is 'socket'; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [create_server_qualname_eq,
       "create_server.__qualname__.__eq__",
       ["create_server"],
       true,
       "socket.create_server.__qualname__.__eq__('create_server') == True — create_server is a top-level function so __qualname__ equals __name__; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [create_server_name_len_13,
       "create_server.__name__.__len__",
       [],
       13,
       "socket.create_server.__name__.__len__() == 13 — the string 'create_server' has 13 characters; 4 shorter than create_connection; portable length anchor; new anchor in extra229 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo and socket.getnameinfo function identity contracts
#
# socket.getaddrinfo.__name__   == 'getaddrinfo'
# socket.getaddrinfo.__module__ == 'socket'
# socket.getnameinfo.__name__   == 'getnameinfo'
# socket.getnameinfo.__module__ == '_socket'
#
# getaddrinfo resolves a hostname and service to socket address structures.
# getnameinfo translates a socket address to a host/service pair.
# Both have 11-character names. getaddrinfo.__module__ is 'socket' while
# getnameinfo.__module__ is '_socket' (the C builtin).
# ---------------------------------------------------------------------------

table socket_extra229.getaddrinfo_getnameinfo_identity:
  description: "getaddrinfo.__name__=='getaddrinfo'; getaddrinfo.__module__=='socket'; getnameinfo.__name__=='getnameinfo'; getnameinfo.__module__=='_socket'; name identity; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: socket229b

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_name_eq,
       "getaddrinfo.__name__.__eq__",
       ["getaddrinfo"],
       true,
       "socket.getaddrinfo.__name__.__eq__('getaddrinfo') == True — getaddrinfo resolves hostnames and services to socket addresses; __name__ is 'getaddrinfo' (11 characters); new anchor in extra229 namespace; verified Python 3.14.3"]
    - [getaddrinfo_module_eq_socket,
       "getaddrinfo.__module__.__eq__",
       ["socket"],
       true,
       "socket.getaddrinfo.__module__.__eq__('socket') == True — socket.getaddrinfo.__module__ is 'socket' (the Python-level module); new anchor in extra229 namespace; verified Python 3.14.3"]
    - [getnameinfo_name_eq,
       "getnameinfo.__name__.__eq__",
       ["getnameinfo"],
       true,
       "socket.getnameinfo.__name__.__eq__('getnameinfo') == True — getnameinfo translates a socket address to hostname/service pair; __name__ is 'getnameinfo' (11 characters); same length as getaddrinfo; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [getnameinfo_module_eq_socket,
       "getnameinfo.__module__.__eq__",
       ["_socket"],
       true,
       "socket.getnameinfo.__module__.__eq__('_socket') == True — getnameinfo is a C builtin from the _socket extension; __module__ is '_socket'; contrasts with getaddrinfo.__module__=='socket'; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [getaddrinfo_name_len_11,
       "getaddrinfo.__name__.__len__",
       [],
       11,
       "socket.getaddrinfo.__name__.__len__() == 11 — the string 'getaddrinfo' has 11 characters; same length as getnameinfo; portable length anchor; new anchor in extra229 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.getfqdn and socket.socketpair function identity contracts
#
# socket.getfqdn.__name__    == 'getfqdn'
# socket.getfqdn.__module__  == 'socket'
# socket.socketpair.__name__ == 'socketpair'
# socket.socketpair.__module__ == 'socket'
#
# getfqdn returns the fully qualified domain name. socketpair creates a pair
# of connected sockets. Both are Python functions defined in socket.py.
# ---------------------------------------------------------------------------

table socket_extra229.getfqdn_socketpair_identity:
  description: "getfqdn.__name__=='getfqdn'; getfqdn.__module__=='socket'; socketpair.__name__=='socketpair'; socketpair.__module__=='socket'; function identity; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: socket229c

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_name_eq,
       "getfqdn.__name__.__eq__",
       ["getfqdn"],
       true,
       "socket.getfqdn.__name__.__eq__('getfqdn') == True — getfqdn returns the fully qualified domain name; __name__ is 'getfqdn' (7 characters); new anchor in extra229 namespace; verified Python 3.14.3"]
    - [getfqdn_module_eq,
       "getfqdn.__module__.__eq__",
       ["socket"],
       true,
       "socket.getfqdn.__module__.__eq__('socket') == True — getfqdn is a Python function defined in Lib/socket.py; __module__ is 'socket'; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [socketpair_name_eq,
       "socketpair.__name__.__eq__",
       ["socketpair"],
       true,
       "socket.socketpair.__name__.__eq__('socketpair') == True — socketpair creates a pair of connected sockets; __name__ is 'socketpair' (10 characters); new anchor in extra229 namespace; verified Python 3.14.3"]
    - [socketpair_module_eq,
       "socketpair.__module__.__eq__",
       ["socket"],
       true,
       "socket.socketpair.__module__.__eq__('socket') == True — socketpair is defined in Lib/socket.py; __module__ is 'socket'; new anchor in extra229 namespace; verified Python 3.14.3"]
    - [getfqdn_name_len_7,
       "getfqdn.__name__.__len__",
       [],
       7,
       "socket.getfqdn.__name__.__len__() == 7 — the string 'getfqdn' has 7 characters; portable length anchor; new anchor in extra229 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra229.create_connection_name_eq:
  description: "socket.create_connection.__name__.__eq__('create_connection') == True — create_connection is a high-level Python convenience function in Lib/socket.py that creates a TCP socket connection to a (host, port) address pair; it handles address resolution via getaddrinfo and attempts each address until one connects; the __name__ attribute is 'create_connection' (17 characters); prior socket specs anchor lower-level functions; extra229 is the first namespace to anchor create_connection.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "create_connection.__name__.__eq__"
  args: ["create_connection"]
  expected: true

invariant socket_extra229.create_server_name_eq:
  description: "socket.create_server.__name__.__eq__('create_server') == True — create_server is a Python convenience function added in Python 3.8 (socket.py) that creates and binds a server socket; it simplifies server setup compared to the raw socket API; __name__ is 'create_server' (13 characters); 4 characters shorter than create_connection; extra229 is the first namespace to anchor create_server.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "create_server.__name__.__eq__"
  args: ["create_server"]
  expected: true

invariant socket_extra229.getnameinfo_module_eq_socket:
  description: "socket.getnameinfo.__module__.__eq__('_socket') == True — getnameinfo is a C builtin function from the _socket extension module; it translates a socket address tuple to a (host, port) string pair; its __module__ attribute is '_socket' reflecting the C implementation; this contrasts with getaddrinfo.__module__=='socket'; prior socket specs anchor getnameinfo name but extra229 is the first to anchor getnameinfo.__module__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "getnameinfo.__module__.__eq__"
  args: ["_socket"]
  expected: true
