spec: abc_extra168
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.abstractproperty.__mro__.__len__()==3 (abstractproperty > property > object); abc.abstractclassmethod.__mro__.__len__()==3 (abstractclassmethod > classmethod > object); abc.abstractstaticmethod.__mro__.__len__()==3 (abstractstaticmethod > staticmethod > object); abc.ABCMeta.__mro__.__len__()==3 (ABCMeta > type > object) cross-checked with abc.ABC.__mro__.__len__()==2 (ABC > object); abc.abstractmethod.__name__.__eq__('abstractmethod')==True and __module__.__eq__('abc')==True (abstractmethod is a FUNCTION not a class — it has no __mro__). KEY FINDINGS: all three deprecated abstract descriptors (abstractproperty, abstractclassmethod, abstractstaticmethod) have MRO len=3 (themselves > base_descriptor > object); ABCMeta.__mro__.__len__()==3 (ABCMeta > type > object); ABC.__mro__.__len__()==2 (ABC > object — ABC is a plain class instance of ABCMeta); abc.abstractmethod is a Python function (not a class) — it has __name__=='abstractmethod' and __module__=='abc' but NO __mro__. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractproperty.__mro__.__len__()==3: MRO: [abc.abstractproperty, property, object]. abstractproperty extends the built-in property descriptor. Verified with Python 3.14.3."
    - "abc.abstractclassmethod.__mro__.__len__()==3: MRO: [abc.abstractclassmethod, classmethod, object]. abstractclassmethod extends the built-in classmethod descriptor. Verified with Python 3.14.3."
    - "abc.abstractstaticmethod.__mro__.__len__()==3: MRO: [abc.abstractstaticmethod, staticmethod, object]. abstractstaticmethod extends the built-in staticmethod descriptor. Verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__.__len__()==3: MRO: [abc.ABCMeta, type, object]. ABCMeta is a subclass of type (the metaclass for ordinary classes). Verified with Python 3.14.3."
    - "abc.ABC.__mro__.__len__()==2: MRO: [abc.ABC, object]. ABC is a simple class whose metaclass is ABCMeta; abc.ABC itself has no intermediate bases — just ABC > object. Verified with Python 3.14.3."
    - "abc.abstractmethod is a function: type(abc.abstractmethod)==<class 'function'>; abc.abstractmethod.__name__=='abstractmethod' (len=14); abc.abstractmethod.__module__=='abc'. abstractmethod has no __mro__ attribute. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractproperty, abstractclassmethod, abstractstaticmethod MRO lengths — extra168
#
# abc.abstractproperty.__mro__.__len__()       == 3
# abc.abstractclassmethod.__mro__.__len__()    == 3
# abc.abstractstaticmethod.__mro__.__len__()   == 3
# ---------------------------------------------------------------------------

table abc_extra168.abc_deprecated_decorators_mro_len:
  description: "abc.abstractproperty, abstractclassmethod, and abstractstaticmethod MRO length checks in abcdeprecmro168 namespace — abc.abstractproperty.__mro__.__len__()==3 (MRO: [abc.abstractproperty, property, object]; abstractproperty inherits from the built-in property descriptor — confirmed in extra165/166 via __bases__[0].__name__=='property'; the 3-entry MRO reflects: 0=abstractproperty, 1=property (the built-in), 2=object; deprecated since Python 3.3 but still present in Python 3.14.3); abc.abstractclassmethod.__mro__.__len__()==3 (MRO: [abc.abstractclassmethod, classmethod, object]; abstractclassmethod inherits from the built-in classmethod descriptor; same structure as abstractproperty but with classmethod at index 1); abc.abstractstaticmethod.__mro__.__len__()==3 (MRO: [abc.abstractstaticmethod, staticmethod, object]; abstractstaticmethod inherits from the built-in staticmethod descriptor; same 3-entry MRO structure); KEY PATTERN: all three deprecated abstract decorators have IDENTICAL MRO lengths (3) — each is a direct subclass of its corresponding built-in descriptor; the only difference is the base descriptor at index 1 (property=8 / classmethod=11 / staticmethod=12 chars); MRO ORDERING: all three are equal at 3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdeprecmro168

  columns: [id, function, args, expected, description]
  rows:
    - [ap_mro_len,   abc.abstractproperty.__mro__.__len__,        [],  3,  "abstractproperty.__mro__.__len__() == 3 (abstractproperty > property > object); verified with Python 3.14.3"]
    - [acm_mro_len,  abc.abstractclassmethod.__mro__.__len__,     [],  3,  "abstractclassmethod.__mro__.__len__() == 3 (abstractclassmethod > classmethod > object); verified with Python 3.14.3"]
    - [asm_mro_len,  abc.abstractstaticmethod.__mro__.__len__,    [],  3,  "abstractstaticmethod.__mro__.__len__() == 3 (abstractstaticmethod > staticmethod > object); verified with Python 3.14.3"]
    - [abcmeta_mro_xchk, abc.ABCMeta.__mro__.__len__,            [],  3,  "ABCMeta.__mro__.__len__() == 3 (cross-check; ABCMeta > type > object; same length as the deprecated decorators); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta MRO length — extra168
#
# abc.ABCMeta.__mro__.__len__() == 3
# MRO: [ABCMeta, type, object]
# ---------------------------------------------------------------------------

table abc_extra168.abc_ABCMeta_mro_len:
  description: "abc.ABCMeta MRO length and entry name checks in abcabcmetamro168 namespace — abc.ABCMeta.__mro__.__len__()==3 (ABCMeta is a metaclass that inherits from type; MRO: [abc.ABCMeta, type, object]; ABCMeta.__mro__[0].__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); ABCMeta.__mro__[1].__name__=='type' (the standard Python metaclass; ABCMeta IS-A type); ABCMeta.__mro__[2].__name__=='object' (universal base); KEY: ABCMeta.__mro__.__len__()==3 equals the MRO lengths of abstractproperty, abstractclassmethod, abstractstaticmethod (all 3) — an interesting coincidence that the metaclass and the deprecated decorators all share MRO length 3; abc.ABC.__mro__.__len__()==2 (cross-check: ABC is a plain class whose metaclass is ABCMeta; ABC > object gives len=2; ABC is an INSTANCE of ABCMeta, not a subclass of it); CONTRAST: abc.ABCMeta.__mro__.__len__()==3 (ABCMeta is a SUBCLASS of type) while abc.ABC.__mro__.__len__()==2 (ABC is an INSTANCE of ABCMeta); the mro distinction reflects the metaclass vs class distinction; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetamro168

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mro_len,   abc.ABCMeta.__mro__.__len__,               [],          3,     "ABCMeta.__mro__.__len__() == 3 (ABCMeta > type > object; metaclass inherits from type); verified with Python 3.14.3"]
    - [abcmeta_mro0_name, "abc.ABCMeta.__mro__[0].__name__.__eq__",    ["ABCMeta"], true,  "ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; the metaclass itself); verified with Python 3.14.3"]
    - [abcmeta_mro1_name, "abc.ABCMeta.__mro__[1].__name__.__eq__",    ["type"],    true,  "ABCMeta.__mro__[1].__name__ == 'type' (ABCMeta IS-A type; standard metaclass); verified with Python 3.14.3"]
    - [abc_mro_xchk,      abc.ABC.__mro__.__len__,                    [],          2,     "ABC.__mro__.__len__() == 2 (cross-check; ABC > object; ABC is instance of ABCMeta, not subclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC MRO length cross-check — extra168
#
# abc.ABC.__mro__.__len__() == 2
# MRO: [ABC, object]
# ---------------------------------------------------------------------------

table abc_extra168.abc_ABC_mro_len:
  description: "abc.ABC MRO length and class identity checks in abcabcmro168 namespace — abc.ABC.__mro__.__len__()==2 (abc.ABC is a helper class with ABCMeta as its metaclass; MRO: [abc.ABC, object]; ABC itself has no intermediate bases — it is a plain class with just ABC > object; any class that inherits from abc.ABC automatically uses ABCMeta as its metaclass and gains ABC infrastructure); abc.ABC.__mro__[0].__name__.__eq__('ABC')==True (entry 0: 'ABC'=3; the shortest class name in this spec: 'ABC'=3 < 'ABCMeta'=7 < 'abstractproperty'=16 < 'abstractclassmethod'=19 < 'abstractstaticmethod'=20); abc.ABC.__mro__[1].__name__.__eq__('object')==True (entry 1: universal base; ABC inherits directly from object); abc.ABC.__class__.__name__.__eq__('ABCMeta')==True (ABC's metaclass is ABCMeta — abc.ABC is an INSTANCE of ABCMeta; abc.ABC.__class__ is abc.ABCMeta; CONTRAST: ABCMeta is a SUBCLASS of type, while ABC is an INSTANCE of ABCMeta); abc.ABCMeta.__mro__.__len__()==3 (cross-check: ABCMeta has 3-entry MRO vs ABC's 2-entry; the metaclass has a longer chain because it inherits from type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmro168

  columns: [id, function, args, expected, description]
  rows:
    - [abc_mro_len,        abc.ABC.__mro__.__len__,                  [],          2,     "ABC.__mro__.__len__() == 2 (ABC > object; direct inheritance from object only); verified with Python 3.14.3"]
    - [abc_mro0_name,      "abc.ABC.__mro__[0].__name__.__eq__",       ["ABC"],     true,  "ABC.__mro__[0].__name__ == 'ABC' (len=3; shortest class name in this spec); verified with Python 3.14.3"]
    - [abc_mro1_name,      "abc.ABC.__mro__[1].__name__.__eq__",       ["object"],  true,  "ABC.__mro__[1].__name__ == 'object' (ABC inherits directly from object; entry 1 of 2); verified with Python 3.14.3"]
    - [abc_class_name,     abc.ABC.__class__.__name__.__eq__,        ["ABCMeta"], true,  "ABC.__class__.__name__ == 'ABCMeta' (ABC is an INSTANCE of ABCMeta — its metaclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod as function — extra168
#
# abc.abstractmethod is a function (not a class); it has __name__ and __module__
# abc.abstractmethod.__name__.__eq__('abstractmethod') == True
# abc.abstractmethod.__module__.__eq__('abc')          == True
# ---------------------------------------------------------------------------

table abc_extra168.abc_abstractmethod_function_identity:
  description: "abc.abstractmethod function identity checks in abcabstractmeth168 namespace — abc.abstractmethod.__name__.__eq__('abstractmethod')==True (abc.abstractmethod is a PYTHON FUNCTION (not a class); type(abc.abstractmethod) is <class 'function'>; it has __name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14); abc.abstractmethod is the ONLY member of the abc module that is a function rather than a class — ABCMeta, ABC, abstractproperty, abstractclassmethod, and abstractstaticmethod are all classes); abc.abstractmethod.__name__.__len__()==14 ('abstractmethod'=14: 'abstract'=8+'method'=6=14; compare: 'abstractproperty'=16 is 2 longer; 'abstractclassmethod'=19 is 5 longer; 'abstractstaticmethod'=20 is 6 longer); abc.abstractmethod.__module__.__eq__('abc')==True (abstractmethod.__module__=='abc' (len=3); same module as all other abc members); IMPORTANT: abc.abstractmethod has NO __mro__ attribute because it is a function, not a class; 'function' objects have __name__, __module__, __doc__, __qualname__, __annotations__, __code__, __globals__, etc. but NOT __mro__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabstractmeth168

  columns: [id, function, args, expected, description]
  rows:
    - [am_name_eq,   abc.abstractmethod.__name__.__eq__,    ["abstractmethod"],  true,  "abstractmethod.__name__ == 'abstractmethod' (len=14: 'abstract'=8+'method'=6=14; function not class); verified with Python 3.14.3"]
    - [am_name_len,  abc.abstractmethod.__name__.__len__,   [],                  14,    "abstractmethod.__name__.__len__() == 14 ('abstractmethod'=14; 2 shorter than abstractproperty=16); verified with Python 3.14.3"]
    - [am_mod_eq,    abc.abstractmethod.__module__.__eq__,  ["abc"],             true,  "abstractmethod.__module__ == 'abc' (len=3; same module as ABCMeta, ABC, abstractproperty, etc.); verified with Python 3.14.3"]
    - [am_mod_len,   abc.abstractmethod.__module__.__len__, [],                  3,     "abstractmethod.__module__.__len__() == 3 ('abc'=3; shortest module path in spec series); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra168
# ---------------------------------------------------------------------------

invariant abc_extra168.abc_abstractproperty_mro_len:
  description: "abc.abstractproperty.__mro__.__len__() returns 3 — abc.abstractproperty.__mro__.__len__()==3; MRO: [abc.abstractproperty, property, object]; abstractproperty inherits from the built-in property descriptor (established in extra165: abstractproperty.__bases__[0].__name__=='property'); the 3-entry MRO gives abstractproperty the full property interface (fget, fset, fdel, __get__, __set__, __delete__) while adding __isabstractmethod__=True; deprecated since Python 3.3 — use @property + @abstractmethod instead; MRO INDEX MAPPING: [0]=abstractproperty itself (len=16: 'abstract'=8+'property'=8=16), [1]=property (built-in, len=8), [2]=object (universal base); COMPARISON within spec: all three deprecated decorators have MRO len=3; ABCMeta also has MRO len=3 (but via type, not property); ABC has MRO len=2; CROSS-MODULE: cf.Future.__mro__.__len__()==2 and cf.Executor.__mro__.__len__()==2 from extra170 — root classes have shorter MROs than subclasses; NEW in extra168: first standalone abstractproperty.__mro__.__len__ invariant in abcdeprecmro168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra168.abc_abstractclassmethod_mro_len:
  description: "abc.abstractclassmethod.__mro__.__len__() returns 3 — abc.abstractclassmethod.__mro__.__len__()==3; MRO: [abc.abstractclassmethod, classmethod, object]; abstractclassmethod inherits from the built-in classmethod descriptor (established in extra166: abstractclassmethod.__bases__[0].__name__=='classmethod'); the 3-entry MRO gives abstractclassmethod all classmethod behavior while adding __isabstractmethod__=True; deprecated since Python 3.3 — use @classmethod + @abstractmethod instead; KEY: abstractclassmethod.__mro__.__len__()==3 == abstractproperty.__mro__.__len__()==3 == abstractstaticmethod.__mro__.__len__()==3 — all three deprecated abstract decorators share MRO length 3; this makes sense: they all follow the same pattern (extend a built-in descriptor, add abstractness); the MRO lengths encode the inheritance depth: class_itself(0) > built_in_descriptor(1) > object(2) = 3 entries; NAME LENGTHS of the three deprecated decorators: abstractproperty(16) < abstractclassmethod(19) < abstractstaticmethod(20) — all different; MRO LENGTHS: all equal at 3; NEW in extra168: first standalone abstractclassmethod.__mro__.__len__ invariant in abcdeprecmro168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractclassmethod.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra168.abc_abstractstaticmethod_mro_len:
  description: "abc.abstractstaticmethod.__mro__.__len__() returns 3 — abc.abstractstaticmethod.__mro__.__len__()==3; MRO: [abc.abstractstaticmethod, staticmethod, object]; abstractstaticmethod inherits from the built-in staticmethod descriptor (established in extra166: abstractstaticmethod.__bases__[0].__name__=='staticmethod'); deprecated since Python 3.3 — use @staticmethod + @abstractmethod instead; abstractstaticmethod.__mro__.__len__()==3 completes the trio: all three deprecated abstract decorators (abstractproperty, abstractclassmethod, abstractstaticmethod) have identical MRO lengths of 3; STRUCTURAL UNIFORMITY: the three deprecated decorators have: same module ('abc'=3), same MRO length (3), same MRO structure (themselves > built-in_descriptor > object), same deprecated status (since Python 3.3), same presence in Python 3.14.3; their differences are: names (16/19/20 chars), base descriptors (property/classmethod/staticmethod), semantics (property access / class binding / no binding); NEW in extra168: first standalone abstractstaticmethod.__mro__.__len__ invariant in abcdeprecmro168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractstaticmethod.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra168.abc_ABCMeta_mro_len:
  description: "abc.ABCMeta.__mro__.__len__() returns 3 — abc.ABCMeta.__mro__.__len__()==3; MRO: [abc.ABCMeta, type, object]; ABCMeta is a metaclass — a class whose instances are classes themselves; ABCMeta inherits from type (the standard Python metaclass); ABCMeta adds the ABC machinery: __abstractmethods__ tracking, register() for virtual subclasses, __subclasshook__ protocol; KEY DISTINCTION: ABCMeta.__mro__.__len__()==3 (ABCMeta IS-A type — it is a subclass of type in the class hierarchy) while abc.ABC.__mro__.__len__()==2 (ABC > object — ABC is an INSTANCE of ABCMeta, not a subclass; it is created by the ABCMeta metaclass); the distinction between being a metaclass subclass (ABCMeta) and being a class with that metaclass (ABC) is fundamental to Python's object model; ABCMeta.__mro__[1].__name__=='type' (the Python metaclass); COINCIDENCE: ABCMeta.__mro__.__len__()==3 == abstractproperty/abstractclassmethod/abstractstaticmethod.__mro__.__len__()==3 — all share MRO length 3; NEW in extra168: first standalone ABCMeta.__mro__.__len__ invariant in abcabcmetamro168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra168.abc_ABC_mro_len:
  description: "abc.ABC.__mro__.__len__() returns 2 — abc.ABC.__mro__.__len__()==2; MRO: [abc.ABC, object]; ABC is a helper class that simplifies creating ABCs without explicitly specifying ABCMeta as the metaclass; any class inheriting from abc.ABC automatically uses ABCMeta as its metaclass; ABC itself has only object as its base class — ABC > object (len=2); DISTINCTION: ABC.__mro__.__len__()==2 (ABC is an INSTANCE of ABCMeta but has a 2-entry MRO because ABC is a regular class from the class hierarchy perspective — just with a special metaclass); ABCMeta.__mro__.__len__()==3 (ABCMeta is a SUBCLASS of type — it extends the metaclass hierarchy); this 2-vs-3 difference encodes the instance/subclass distinction at the metaclass level; COMPARISON: abc.ABC.__mro__.__len__()==2 matches multiprocessing.pool.Pool.__mro__.__len__()==2 and asyncio.Future.__mro__.__len__()==2 — all are root classes with direct object inheritance; NEW in extra168: first standalone ABC.__mro__.__len__ invariant providing contrast with ABCMeta's 3-entry MRO in abcabcmro168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra168.abc_abstractmethod_name_eq:
  description: "abc.abstractmethod.__name__.__eq__('abstractmethod') returns True — abc.abstractmethod.__name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14); abc.abstractmethod is a Python FUNCTION that acts as a decorator; when applied to a method in an ABC body, it sets __isabstractmethod__=True on that method; ABCMeta then collects all methods where __isabstractmethod__==True into __abstractmethods__, and ABC instantiation is blocked until all abstract methods are overridden; CRITICAL DISTINCTION: abstractmethod is a FUNCTION (not a class) — it has no __mro__; contrast with abstractproperty, abstractclassmethod, abstractstaticmethod which ARE classes (subclasses of property, classmethod, staticmethod respectively) and DO have __mro__; abstractmethod's function nature is by design — it works on any callable (regular methods, classmethods after stacking, staticmethods after stacking) whereas the deprecated class-based decorators each handle only one descriptor type; 'abstractmethod'=14: same length as asyncio.get_event_loop.__name__='get_event_loop'=14 (from extra171; coincidence); NEW in extra168: first standalone abstractmethod.__name__ identity invariant in abcabstractmeth168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra168.abc_abstractmethod_module_eq:
  description: "abc.abstractmethod.__module__.__eq__('abc') returns True — abc.abstractmethod.__module__=='abc' (len=3: 'a'+'b'+'c'=3); abstractmethod is defined in Lib/abc.py alongside ABCMeta, ABC, abstractproperty, abstractclassmethod, and abstractstaticmethod; all abc module members share __module__=='abc' (len=3); 'abc'=3 is the shortest module path in the spec series: 'abc'=3 < '_asyncio'=8 < 'asyncio.tasks'=13 < 'asyncio.events'=14 < 'asyncio.runners'=15 < 'multiprocessing.process'=23 < 'multiprocessing.managers'=24 == 'concurrent.futures._base'=24; abstractmethod's __module__=='abc' confirms it is defined in the same file as all other abc objects — abc is a small, self-contained module (Lib/abc.py is under 200 lines) despite providing fundamental Python infrastructure; abstractmethod is the MODERN replacement for the three deprecated class-based decorators (abstractproperty, abstractclassmethod, abstractstaticmethod) — all three are now replaced by stacking @abstractmethod with @property, @classmethod, or @staticmethod respectively; NEW in extra168: first standalone abstractmethod.__module__ invariant in abcabstractmeth168 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

