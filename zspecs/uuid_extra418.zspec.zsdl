spec: uuid_extra418
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.__name__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.RFC_4122).__name__ == 'str'. uuid.RFC_4122 == 'specified in RFC 4122'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.RESERVED_NCS).__name__ == 'str'. uuid.RESERVED_NCS == 'reserved for NCS compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.RESERVED_MICROSOFT).__name__ == 'str'. uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.RESERVED_FUTURE).__name__ == 'str'. uuid.RESERVED_FUTURE == 'reserved for future definition'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid is a pure-Python module. Its module-level identity attributes (__name__, __package__) follow standard Python module conventions. The RFC_4122 and RESERVED_* constants are plain str objects describing the UUID variant categories. __spec__ is a ModuleSpec instance created by importlib, holding the module's loader, origin, and submodule search paths."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module-level identity attributes
#
# Wave 418 theme: uuid module identity and reserved constant type identity.
#
# uuid is a pure-Python module. Its __name__ and __package__ follow standard
# Python module conventions: __name__ is the unqualified module name 'uuid',
# and __package__ is '' (empty string) since uuid is a top-level module.
# __spec__.__class__.__name__ is 'ModuleSpec', confirming importlib loaded it.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra418.module_name:
  description: "uuid.__name__.__eq__('uuid') == True — the module's __name__ is the bare module name 'uuid', standard Python module identity; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra418.module_package:
  description: "uuid.__package__.__eq__('') == True — uuid is a top-level module so __package__ is the empty string, not a package name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant uuid_extra418.module_spec_class:
  description: "uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — importlib creates a ModuleSpec object for every imported module, stored as __spec__; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# uuid reserved variant constant type identity
#
# uuid.RFC_4122 and the RESERVED_* constants are plain Python str objects
# that label the four UUID variant categories defined in RFC 4122. Each
# constant's type is 'str'. This can be verified by checking the __class__
# __name__ of each constant.
#
# Constants covered:
#   RFC_4122          — 'specified in RFC 4122'
#   RESERVED_NCS      — 'reserved for NCS compatibility'
#   RESERVED_MICROSOFT — 'reserved for Microsoft compatibility'
#   RESERVED_FUTURE   — 'reserved for future definition'
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra418.reserved_constant_types:
  description: "uuid.RFC_4122 and RESERVED_* constants are plain str objects — type(uuid.RFC_4122).__name__ == 'str'; these variant labels are module-level string constants, not enum members; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidrc418

  columns: [id, function, args, expected]
  rows:
    - [rfc_4122_type,           RFC_4122.__class__.__name__.__eq__,           ["str"], true]
    - [reserved_ncs_type,       RESERVED_NCS.__class__.__name__.__eq__,       ["str"], true]
    - [reserved_microsoft_type, RESERVED_MICROSOFT.__class__.__name__.__eq__, ["str"], true]
    - [reserved_future_type,    RESERVED_FUTURE.__class__.__name__.__eq__,    ["str"], true]
