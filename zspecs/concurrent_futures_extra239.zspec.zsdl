spec: concurrent_futures_extra239
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers concurrent.futures wait() return_when constants and Future state strings."
    - "FIRST_COMPLETED == 'FIRST_COMPLETED' — string constant; 15 characters."
    - "FIRST_EXCEPTION == 'FIRST_EXCEPTION' — string constant; 15 characters."
    - "ALL_COMPLETED == 'ALL_COMPLETED' — string constant; 13 characters."
    - "All three constants are str instances exported from concurrent.futures top-level namespace."
    - "_base.PENDING == 'PENDING' — Future state string; 7 characters; in concurrent.futures._base."
    - "_base.RUNNING == 'RUNNING' — Future state string; 7 characters; in concurrent.futures._base."
    - "_base.CANCELLED == 'CANCELLED' — Future state string; 9 characters; in concurrent.futures._base."
    - "_base.FINISHED == 'FINISHED' — Future state string; 8 characters; in concurrent.futures._base."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures wait() return_when constants
#
# FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are string constants
# exported from the concurrent.futures top-level namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra239.when_constants:
  description: "concurrent.futures return_when constants: FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED; new to extra239"
  kind: python_call_eq
  category: constants
  id_prefix: cf239when

  columns: [id, function, args, expected, description]
  rows:
    - [fc_eq,
       FIRST_COMPLETED.__eq__,
       ["FIRST_COMPLETED"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True — string constant value; new to extra239"]
    - [fe_eq,
       FIRST_EXCEPTION.__eq__,
       ["FIRST_EXCEPTION"],
       true,
       "concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True — string constant value; new to extra239"]
    - [ac_eq,
       ALL_COMPLETED.__eq__,
       ["ALL_COMPLETED"],
       true,
       "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') == True — string constant value; new to extra239"]
    - [fc_len_15,
       FIRST_COMPLETED.__len__,
       [],
       15,
       "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' has 15 characters; new to extra239"]
    - [ac_len_13,
       ALL_COMPLETED.__len__,
       [],
       13,
       "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 'ALL_COMPLETED' has 13 characters; new to extra239"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures return_when constants __class__.__name__
#
# All three constants are plain str instances.
# ---------------------------------------------------------------------------

table concurrent_futures_extra239.when_constants_class:
  description: "concurrent.futures return_when constants are str instances; new to extra239"
  kind: python_call_eq
  category: constants
  id_prefix: cf239when

  columns: [id, function, args, expected, description]
  rows:
    - [fc_class_str,
       FIRST_COMPLETED.__class__.__name__.__eq__,
       ["str"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — plain string constant; new to extra239"]
    - [fe_class_str,
       FIRST_EXCEPTION.__class__.__name__.__eq__,
       ["str"],
       true,
       "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str' — plain string constant; new to extra239"]
    - [ac_class_str,
       ALL_COMPLETED.__class__.__name__.__eq__,
       ["str"],
       true,
       "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — plain string constant; new to extra239"]

# ---------------------------------------------------------------------------
# Table 3: Future state string constants in concurrent.futures._base
#
# PENDING, RUNNING, CANCELLED, FINISHED are module-level string constants
# in concurrent.futures._base, accessible via _base attribute after import.
# ---------------------------------------------------------------------------

table concurrent_futures_extra239.state_constants:
  description: "concurrent.futures._base Future state constants: PENDING, RUNNING, CANCELLED, FINISHED; new to extra239"
  kind: python_call_eq
  category: constants
  id_prefix: cf239state

  columns: [id, function, args, expected, description]
  rows:
    - [pending_eq,
       _base.PENDING.__eq__,
       ["PENDING"],
       true,
       "concurrent.futures._base.PENDING.__eq__('PENDING') == True — Future state string constant; new to extra239"]
    - [running_eq,
       _base.RUNNING.__eq__,
       ["RUNNING"],
       true,
       "concurrent.futures._base.RUNNING.__eq__('RUNNING') == True — Future state string constant; new to extra239"]
    - [cancelled_eq,
       _base.CANCELLED.__eq__,
       ["CANCELLED"],
       true,
       "concurrent.futures._base.CANCELLED.__eq__('CANCELLED') == True — Future state string constant; new to extra239"]
    - [finished_eq,
       _base.FINISHED.__eq__,
       ["FINISHED"],
       true,
       "concurrent.futures._base.FINISHED.__eq__('FINISHED') == True — Future state string constant; new to extra239"]
    - [pending_len_7,
       _base.PENDING.__len__,
       [],
       7,
       "concurrent.futures._base.PENDING.__len__() == 7 — 'PENDING' has 7 characters; new to extra239"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra239
# ---------------------------------------------------------------------------

