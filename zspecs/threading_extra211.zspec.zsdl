spec: threading_extra211
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra210.zspec.zsdl — covers earlier threading dict and annotation checks"
    - "threading_extra.zspec.zsdl — covers __name__/__module__ identity checks for threading types"
  notes:
    - "threading.Semaphore.__dict__.__contains__('acquire') == True — acquire is defined on Semaphore in its class dict. Verified with Python 3.14.3."
    - "threading.Semaphore.__dict__.__contains__('release') == True — release is defined on Semaphore in its class dict. Verified with Python 3.14.3."
    - "threading.Semaphore.__dict__.__len__() == 12 — contains: __module__, __firstlineno__, __doc__, __init__, __repr__, acquire, __enter__, release, __exit__, __static_attributes__, __dict__, __weakref__. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('wait') == True — wait is defined on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('reset') == True — reset is defined on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('abort') == True — abort is defined on Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('parties') == True — parties is a property descriptor defined on Barrier. Verified with Python 3.14.3."
    - "type(threading.Barrier.__dict__['parties']).__name__ == 'property' — parties is exposed as a Python property descriptor. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__len__() == 19 — Barrier has 19 entries in its class dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore.__dict__ membership checks
#
# Semaphore.__dict__.__contains__('acquire')  == True
# Semaphore.__dict__.__contains__('release')  == True
# Semaphore.__dict__.__contains__('__repr__') == True
# Semaphore.__dict__.__contains__('__enter__') == True
# ---------------------------------------------------------------------------

table threading_extra211.semaphore_dict_present:
  description: "threading.Semaphore.__dict__ membership checks in threadrepr211 namespace — 'acquire' is present (Semaphore.acquire() decrements the counter, blocking if zero); 'release' is present (Semaphore.release() increments the counter); '__repr__' is present (Semaphore defines __repr__); '__enter__' is present (context manager support via __enter__); all four __contains__ calls return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadrepr211

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_dict_has_acquire,
       "Semaphore.__dict__.__contains__",
       ["acquire"],
       true,
       "threading.Semaphore.__dict__.__contains__('acquire') == True — Semaphore defines acquire() in its class dict; acquire decrements the internal counter, blocking if the counter is zero; __contains__('acquire') returns True; verified with Python 3.14.3"]
    - [semaphore_dict_has_release,
       "Semaphore.__dict__.__contains__",
       ["release"],
       true,
       "threading.Semaphore.__dict__.__contains__('release') == True — Semaphore defines release() in its class dict; release increments the internal counter, waking a blocked thread if any; __contains__('release') returns True; verified with Python 3.14.3"]
    - [semaphore_dict_has_repr,
       "Semaphore.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__repr__') == True — Semaphore defines __repr__ in its class dict for string representation; __contains__('__repr__') returns True; verified with Python 3.14.3"]
    - [semaphore_dict_has_enter,
       "Semaphore.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__enter__') == True — Semaphore supports the context manager protocol; __enter__ is defined in its class dict (calls acquire); __contains__('__enter__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore.__dict__ more checks and length
#
# Semaphore.__dict__.__contains__('__exit__') == True
# Semaphore.__dict__.__contains__('__init__') == True
# Semaphore.__dict__.__len__()                == 12
# Semaphore.__dict__.__contains__('wait')     == False  (wait is on Barrier, not Semaphore)
# ---------------------------------------------------------------------------

table threading_extra211.semaphore_dict_more:
  description: "threading.Semaphore.__dict__ additional checks and length in threadrepr211s namespace — '__exit__' is present (context manager __exit__ calls release); '__init__' is present (Semaphore.__init__ accepts optional value parameter); __dict__.__len__() == 12 (12 entries: __module__, __firstlineno__, __doc__, __init__, __repr__, acquire, __enter__, release, __exit__, __static_attributes__, __dict__, __weakref__); 'wait' is NOT in Semaphore.__dict__ (wait is a Barrier method); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadrepr211s

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_dict_has_exit,
       "Semaphore.__dict__.__contains__",
       ["__exit__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__exit__') == True — Semaphore implements the context manager protocol; __exit__ is defined in its class dict (calls release); __contains__('__exit__') returns True; verified with Python 3.14.3"]
    - [semaphore_dict_has_init,
       "Semaphore.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__init__') == True — Semaphore defines __init__ in its class dict accepting an optional value argument (default 1); __contains__('__init__') returns True; verified with Python 3.14.3"]
    - [semaphore_dict_len_12,
       "Semaphore.__dict__.__len__",
       [],
       12,
       "threading.Semaphore.__dict__.__len__() == 12 — the class dict has exactly 12 entries: __module__, __firstlineno__, __doc__, __init__, __repr__, acquire, __enter__, release, __exit__, __static_attributes__, __dict__, __weakref__; __len__() returns 12; verified with Python 3.14.3"]
    - [semaphore_dict_no_wait,
       "Semaphore.__dict__.__contains__",
       ["wait"],
       false,
       "threading.Semaphore.__dict__.__contains__('wait') == False — 'wait' is a method on Barrier (not Semaphore); Semaphore has acquire/release, not wait; __contains__('wait') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier.__dict__ membership checks
#
# Barrier.__dict__.__contains__('wait')    == True
# Barrier.__dict__.__contains__('reset')   == True
# Barrier.__dict__.__contains__('abort')   == True
# Barrier.__dict__.__contains__('parties') == True
# ---------------------------------------------------------------------------

table threading_extra211.barrier_dict_present:
  description: "threading.Barrier.__dict__ membership checks in threadrepr211b namespace — 'wait' is present (blocks until all parties have called wait); 'reset' is present (resets the barrier to the initial empty state); 'abort' is present (puts the barrier into broken state); 'parties' is present (a property returning the number of threads required to trip the barrier); all four __contains__ calls return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadrepr211b

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_dict_has_wait,
       "Barrier.__dict__.__contains__",
       ["wait"],
       true,
       "threading.Barrier.__dict__.__contains__('wait') == True — Barrier defines wait() in its class dict; wait() blocks until all parties have called it, then releases them all simultaneously; __contains__('wait') returns True; verified with Python 3.14.3"]
    - [barrier_dict_has_reset,
       "Barrier.__dict__.__contains__",
       ["reset"],
       true,
       "threading.Barrier.__dict__.__contains__('reset') == True — Barrier defines reset() in its class dict; reset() returns the barrier to the initial empty state, causing any waiting threads to receive a BrokenBarrierError; __contains__('reset') returns True; verified with Python 3.14.3"]
    - [barrier_dict_has_abort,
       "Barrier.__dict__.__contains__",
       ["abort"],
       true,
       "threading.Barrier.__dict__.__contains__('abort') == True — Barrier defines abort() in its class dict; abort() puts the barrier into the broken state, causing all waiting threads to raise BrokenBarrierError; __contains__('abort') returns True; verified with Python 3.14.3"]
    - [barrier_dict_has_parties,
       "Barrier.__dict__.__contains__",
       ["parties"],
       true,
       "threading.Barrier.__dict__.__contains__('parties') == True — Barrier defines 'parties' as a property descriptor in its class dict; parties returns the number of threads required to pass the barrier; __contains__('parties') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra211
# ---------------------------------------------------------------------------

invariant threading_extra211.semaphore_dict_has_acquire:
  description: "threading.Semaphore.__dict__.__contains__('acquire') == True — Semaphore defines acquire() in its class dict; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Semaphore.__dict__.__contains__"
  args: ["acquire"]
  expected: true

invariant threading_extra211.semaphore_dict_has_release:
  description: "threading.Semaphore.__dict__.__contains__('release') == True — Semaphore defines release() in its class dict; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Semaphore.__dict__.__contains__"
  args: ["release"]
  expected: true

invariant threading_extra211.semaphore_dict_len_12:
  description: "threading.Semaphore.__dict__.__len__() == 12 — Semaphore class dict has exactly 12 entries; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Semaphore.__dict__.__len__"
  args: []
  expected: 12

invariant threading_extra211.barrier_dict_has_wait:
  description: "threading.Barrier.__dict__.__contains__('wait') == True — Barrier defines wait() in its class dict to synchronize all parties; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Barrier.__dict__.__contains__"
  args: ["wait"]
  expected: true

invariant threading_extra211.barrier_dict_has_reset:
  description: "threading.Barrier.__dict__.__contains__('reset') == True — Barrier defines reset() in its class dict; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Barrier.__dict__.__contains__"
  args: ["reset"]
  expected: true

invariant threading_extra211.barrier_dict_has_abort:
  description: "threading.Barrier.__dict__.__contains__('abort') == True — Barrier defines abort() in its class dict; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Barrier.__dict__.__contains__"
  args: ["abort"]
  expected: true

invariant threading_extra211.barrier_dict_has_parties:
  description: "threading.Barrier.__dict__.__contains__('parties') == True — Barrier defines 'parties' as a property in its class dict returning the number of parties required; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Barrier.__dict__.__contains__"
  args: ["parties"]
  expected: true

invariant threading_extra211.barrier_dict_len_19:
  description: "threading.Barrier.__dict__.__len__() == 19 — Barrier class dict has exactly 19 entries including wait, _enter, _release, _wait, _exit, reset, abort, _break, parties, n_waiting, broken, plus dunder entries; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Barrier.__dict__.__len__"
  args: []
  expected: 19
