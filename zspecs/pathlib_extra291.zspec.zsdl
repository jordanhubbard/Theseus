spec: pathlib_extra291
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py, Lib/pathlib/_abc.py"
  notes:
    - "PurePath.__bases__[0].__name__ is 'object' (PurePath is a root class)"
    - "Path.__bases__[0].__name__ is 'PurePath' in Python 3.12+"
    - "Path.home and Path.cwd are classmethods; __qualname__ reflects the class they belong to"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra291.class_names:
  description: "__name__ for PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath"
  kind: python_call_eq
  category: identity
  id_prefix: pl291n

  columns: [id, function, args, expected, description]
  rows:
    - [pl291n001, pathlib.PurePath.__name__.__eq__, ["PurePath"], true, "PurePath __name__"]
    - [pl291n002, pathlib.PurePosixPath.__name__.__eq__, ["PurePosixPath"], true, "PurePosixPath __name__"]
    - [pl291n003, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true, "PureWindowsPath __name__"]
    - [pl291n004, pathlib.Path.__name__.__eq__, ["Path"], true, "Path __name__"]
    - [pl291n005, pathlib.PosixPath.__name__.__eq__, ["PosixPath"], true, "PosixPath __name__"]
    - [pl291n006, pathlib.WindowsPath.__name__.__eq__, ["WindowsPath"], true, "WindowsPath __name__"]

table pathlib_extra291.base_class_names:
  description: "__bases__[0].__name__ for pathlib class hierarchy"
  kind: python_call_eq
  category: identity
  id_prefix: pl291b

  columns: [id, function, args, expected, description]
  rows:
    - [pl291b001, "pathlib.PurePath.__bases__[0].__name__.__eq__", ["object"], true, "PurePath base is object"]
    - [pl291b002, "pathlib.PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"], true, "PurePosixPath base is PurePath"]
    - [pl291b003, "pathlib.PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"], true, "PureWindowsPath base is PurePath"]
    - [pl291b004, "pathlib.Path.__bases__[0].__name__.__eq__", ["PurePath"], true, "Path base is PurePath"]
    - [pl291b005, "pathlib.PosixPath.__bases__[0].__name__.__eq__", ["Path"], true, "PosixPath base is Path"]
    - [pl291b006, "pathlib.WindowsPath.__bases__[0].__name__.__eq__", ["Path"], true, "WindowsPath base is Path"]

invariant pathlib_extra291.purepath_module:
  description: "pathlib.PurePath.__module__ is 'pathlib'"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra291.path_module:
  description: "pathlib.Path.__module__ is 'pathlib'"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra291.path_home_qualname:
  description: "pathlib.Path.home.__qualname__ is 'Path.home'"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.home.__qualname__.__eq__
  args: ["Path.home"]
  expected: true

invariant pathlib_extra291.path_cwd_qualname:
  description: "pathlib.Path.cwd.__qualname__ is 'Path.cwd'"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.cwd.__qualname__.__eq__
  args: ["Path.cwd"]
  expected: true
