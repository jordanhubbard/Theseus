spec: concurrent_futures_extra133
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html#future-objects

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html#future-objects — Python concurrent.futures.Future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: wave 259 theme — concurrent.futures.Future method qualnames, lengths, and co_argcount. Future.set_result.__qualname__=='Future.set_result' (len=17); Future.set_exception.__qualname__=='Future.set_exception' (len=20); Future.running.__qualname__=='Future.running' (len=14); Future.cancel.__qualname__=='Future.cancel' (len=13); Future.result.__qualname__=='Future.result' (len=13); Future.done.__qualname__=='Future.done' (len=11); Future.set_result.__code__.co_argcount==2; Future.set_exception.__code__.co_argcount==2; Future.running.__code__.co_argcount==1; Future.cancel.__code__.co_argcount==1; Future.result.__code__.co_argcount==2; Future.__name__=='Future' (len=6); Future.__module__=='concurrent.futures._base' (len=24); Future.__bases__[0].__name__=='object'; Future.__mro__.__len__()==2; Future.__dict__.__class__.__name__=='mappingproxy'; Future.__dict__.__len__()==21. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__module__ is 'concurrent.futures._base' (len=24) — the private submodule where Future is implemented. Future.__mro__.__len__()==2 ([Future, object]) — flat hierarchy. Future.__dict__.__len__()==21 — includes all methods plus dunders. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

