    - [set_exception_argc, concurrent.futures.Future.set_exception.__code__.co_argcount.__eq__, [2], true, "concurrent.futures.Future.set_exception.__code__.co_argcount == 2 (self + exception); verified with Python 3.14.3"]
    - [running_argc,       concurrent.futures.Future.running.__code__.co_argcount.__eq__,       [1], true, "concurrent.futures.Future.running.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [cancel_argc,        concurrent.futures.Future.cancel.__code__.co_argcount.__eq__,        [1], true, "concurrent.futures.Future.cancel.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [result_argc,        concurrent.futures.Future.result.__code__.co_argcount.__eq__,        [2], true, "concurrent.futures.Future.result.__code__.co_argcount == 2 (self + timeout); verified with Python 3.14.3"]

