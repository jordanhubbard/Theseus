invariant concurrent_futures_extra133.Future_set_exception_qualname_len_20:
  description: "concurrent.futures.Future.set_exception.__qualname__.__len__() == 20 — Future.set_exception.__qualname__ is 'Future.set_exception' (20 chars: 'Future'=6 + '.'=1 + 'set_exception'=13 = 20); this is the longest method qualname among Future's methods: set_exception=20 > set_result=17 > running=14 > cancel=result=13 > done=11; set_exception.__code__.co_argcount==2 (self + exception object); Future.__module__ is 'concurrent.futures._base' (len=24); NEW in extra133: first standalone Future.set_exception qualname length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.set_exception.__qualname__.__len__
  args: []
  expected: 20

invariant concurrent_futures_extra133.Future_module_len_24:
  description: "concurrent.futures.Future.__module__.__len__() == 24 — Future.__module__ is 'concurrent.futures._base' (24 chars: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + '_base'=5 = 24); Future is NOT defined in 'concurrent.futures' directly — it is in the private _base submodule; Future.__mro__.__len__()==2; Future.__dict__.__len__()==21; NEW in extra133: first standalone Future module length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra133.Future_dict_len_21:
  description: "concurrent.futures.Future.__dict__.__len__() == 21 — Future's class __dict__ has 21 entries counting all methods (cancel, cancelled, running, done, result, exception, add_done_callback, set_running_or_notify_cancel, set_result, set_exception) plus __doc__, __repr__, __init__, __iter__, __await__, and other dunders; Future.__dict__.__class__.__name__ is 'mappingproxy'; Future.__mro__.__len__()==2; NEW in extra133: first standalone Future dict length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__len__
  args: []
  expected: 21

invariant concurrent_futures_extra133.Future_running_qualname_len_14:
  description: "concurrent.futures.Future.running.__qualname__.__len__() == 14 — Future.running.__qualname__ is 'Future.running' (14 chars: 'Future'=6 + '.'=1 + 'running'=7 = 14); running.__code__.co_argcount==1 (self only — a no-arg predicate that returns True when the future is in RUNNING state); compare with done.__qualname__.__len__()==11 ('Future.done': 'done'=4) and cancel.__qualname__.__len__()==13; NEW in extra133: first standalone Future.running qualname length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.running.__qualname__.__len__
  args: []
  expected: 14

invariant concurrent_futures_extra133.Future_set_result_argc_2:
  description: "concurrent.futures.Future.set_result.__code__.co_argcount.__eq__(2) returns True — Future.set_result takes (self, result): self is the Future instance, result is the value to set; future.set_result(value) makes the future done with result value; set_exception also has co_argcount==2 (self + exception); running.co_argcount==1 (self only); Future.set_result.__qualname__.__len__()==17 ('Future.set_result'); NEW in extra133: first standalone Future.set_result co_argcount invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.set_result.__code__.co_argcount.__eq__
  args: [2]
  expected: true
