table concurrent_futures_extra133.cf_future_method_qualnames:
  description: "concurrent.futures.Future method qualname equality checks in cffutqn133 namespace — wave 259 theme: Future method qualnames; Future.set_result.__qualname__.__eq__('Future.set_result')==True (len=17: 'Future'=6+'.'=1+'set_result'=10=17); Future.set_exception.__qualname__.__eq__('Future.set_exception')==True (len=20: 'set_exception'=13, longest method name in this set); Future.running.__qualname__.__eq__('Future.running')==True (len=14: 'running'=7); Future.cancel.__qualname__.__eq__('Future.cancel')==True (len=13: 'cancel'=6); Future.result.__qualname__.__eq__('Future.result')==True (len=13: 'result'=6, tied with cancel); Future.done.__qualname__.__eq__('Future.done')==True (len=11: 'done'=4, shortest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutqn133

  columns: [id, function, args, expected, description]
  rows:
    - [set_result_qn_eq,    concurrent.futures.Future.set_result.__qualname__.__eq__,    ["Future.set_result"],    true, "concurrent.futures.Future.set_result.__qualname__ == 'Future.set_result' (len=17); verified with Python 3.14.3"]
    - [set_exception_qn_eq, concurrent.futures.Future.set_exception.__qualname__.__eq__, ["Future.set_exception"], true, "concurrent.futures.Future.set_exception.__qualname__ == 'Future.set_exception' (len=20); verified with Python 3.14.3"]
    - [running_qn_eq,       concurrent.futures.Future.running.__qualname__.__eq__,       ["Future.running"],       true, "concurrent.futures.Future.running.__qualname__ == 'Future.running' (len=14); verified with Python 3.14.3"]
    - [cancel_qn_eq,        concurrent.futures.Future.cancel.__qualname__.__eq__,        ["Future.cancel"],        true, "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel' (len=13); verified with Python 3.14.3"]
    - [result_qn_eq,        concurrent.futures.Future.result.__qualname__.__eq__,        ["Future.result"],        true, "concurrent.futures.Future.result.__qualname__ == 'Future.result' (len=13, tied with cancel); verified with Python 3.14.3"]
    - [done_qn_eq,          concurrent.futures.Future.done.__qualname__.__eq__,          ["Future.done"],          true, "concurrent.futures.Future.done.__qualname__ == 'Future.done' (len=11, shortest); verified with Python 3.14.3"]

