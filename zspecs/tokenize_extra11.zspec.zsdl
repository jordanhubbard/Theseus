spec: tokenize_extra11
version: ">=3.12"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL int type checks; function __name__ checks"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo/__name__/__module__, TokenError/__name__/bases, function __name__ table, constants int type checks"
    - "tokenize_extra6.zspec.zsdl — covers token constant exact values (ENDMARKER=0, TYPE_COMMENT=57, COMMENT=65, NL=66, ERRORTOKEN=67)"
    - "tokenize_extra7.zspec.zsdl — covers NAME=1/NUMBER=2/STRING=3/NEWLINE=4 exact values (table); INDENT=5/DEDENT=6/OP=55/ENCODING=68 exact values"
    - "tokenize_extra8.zspec.zsdl — covers tokenize/__module__ and generate_tokens/__module__ standalone; core constant exact values standalone"
    - "tokenize_extra9.zspec.zsdl — covers FSTRING_MIDDLE/TSTRING_* constants; N_TOKENS; TYPE_IGNORE; TokenInfo._make/_asdict/_replace __qualname__; untokenize/open __module__; detect_encoding/tokenize __qualname__"
    - "tokenize_extra10.zspec.zsdl — covers tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__; TokenError/__name__/__module__; TokenInfo/__name__/__module__; NAME/NUMBER/STRING/COMMENT exact values"
  notes:
    - "This spec extends tokenize_extra10.zspec.zsdl."
    - "tokenize.Untokenizer.__name__ == 'Untokenizer' — no prior tokenize spec covers Untokenizer.__name__ as a standalone invariant in the extra11 namespace."
    - "tokenize.Untokenizer.__qualname__ == 'Untokenizer' — no prior tokenize spec covers Untokenizer.__qualname__."
    - "tokenize.Untokenizer.__module__ == 'tokenize' — no prior tokenize spec covers Untokenizer.__module__."
    - "tokenize.Untokenizer.__bases__[0].__name__ == 'object' — no prior tokenize spec covers Untokenizer base class."
    - "tokenize.TokenError.__bases__[0].__name__ == 'Exception' — tokenize_extra covers this in extra namespace; distinct standalone invariant in extra11."
    - "tokenize.TokenInfo.__bases__[0].__name__ == 'TokenInfo' — the NamedTuple base pattern; no prior spec covers this in extra11 namespace."
    - "tokenize.TokenInfo._fields is a tuple of 5 field names — no prior spec verifies _fields.__class__.__name__ or len in the extra11 namespace."
    - "tokenize.TokenInfo._fields[0] == 'type' through _fields[4] == 'line' — not covered in any prior tokenize spec."
    - "tokenize.open.__name__ == 'open' — tokenize_extra9 covers open/__module__; __name__ standalone is new in extra11."
    - "tokenize.untokenize.__name__ == 'untokenize' — no prior tokenize spec covers untokenize/__name__ as standalone in extra11."
    - "tokenize.cookie_re.__class__.__name__ == 'Pattern' — no prior tokenize spec covers cookie_re class identity."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TokenInfo._fields — tuple of named fields
# (tokenize_extra11 namespace)
#
# No prior tokenize spec covers _fields field names or class identity.
# TokenInfo is a NamedTuple with fields: type, string, start, end, line.
# ---------------------------------------------------------------------------

table tokenize_extra11.TokenInfo_fields:
  kind: python_call_eq
  category: named_tuple_fields
  id_prefix: ti_field

  columns: [id, function, args, expected]
  rows:
    - [field0, "TokenInfo._fields.__getitem__", [0], "type"]
    - [field1, "TokenInfo._fields.__getitem__", [1], "string"]
    - [field2, "TokenInfo._fields.__getitem__", [2], "start"]
    - [field3, "TokenInfo._fields.__getitem__", [3], "end"]
    - [field4, "TokenInfo._fields.__getitem__", [4], "line"]

# ---------------------------------------------------------------------------
# TokenInfo._fields class and length
# (tokenize_extra11 namespace)
#
# No prior tokenize spec verifies _fields class identity or length.
# ---------------------------------------------------------------------------

invariant tokenize_extra11.TokenInfo.fields_class_is_tuple:
  description: "tokenize.TokenInfo._fields.__class__.__name__ == 'tuple'"
  category: class_names
  kind: python_call_eq
  function: TokenInfo._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant tokenize_extra11.TokenInfo.fields_len_is_5:
  description: "len(tokenize.TokenInfo._fields) == 5 — five named fields: type, string, start, end, line"
  category: named_tuple_fields
  kind: python_call_eq
  function: TokenInfo._fields.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Untokenizer class identity — __name__, __qualname__, __module__, base class
# (tokenize_extra11 namespace)
#
# No prior tokenize spec covers any Untokenizer attribute.
# ---------------------------------------------------------------------------

invariant tokenize_extra11.Untokenizer.name:
  description: "tokenize.Untokenizer.__name__ == 'Untokenizer'"
  category: class_names
  kind: python_call_eq
  function: Untokenizer.__name__.__eq__
  args: ["Untokenizer"]
  expected: true

invariant tokenize_extra11.Untokenizer.qualname:
  description: "tokenize.Untokenizer.__qualname__ == 'Untokenizer'"
  category: function_qualnames
  kind: python_call_eq
  function: Untokenizer.__qualname__.__eq__
  args: ["Untokenizer"]
  expected: true

invariant tokenize_extra11.Untokenizer.module:
  description: "tokenize.Untokenizer.__module__ == 'tokenize'"
  category: module_attrs
  kind: python_call_eq
  function: Untokenizer.__module__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra11.Untokenizer.base_is_object:
  description: "tokenize.Untokenizer.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Untokenizer.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# TokenError base class and TokenInfo base class
# (tokenize_extra11 namespace)
#
# tokenize_extra covers TokenError.__bases__ in the tokenize_extra namespace;
# distinct standalone invariants in tokenize_extra11 namespace.
# ---------------------------------------------------------------------------

invariant tokenize_extra11.TokenError.base_is_Exception:
  description: "tokenize.TokenError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: "TokenError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# open and untokenize function __name__
# (tokenize_extra11 namespace)
#
# tokenize_extra9 covers open/__module__ and untokenize/__module__.
# __name__ standalone is new in the tokenize_extra11 namespace.
# ---------------------------------------------------------------------------

table tokenize_extra11.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [open,        open.__name__.__eq__,        ["open"],        true]
    - [untokenize,  untokenize.__name__.__eq__,  ["untokenize"],  true]

# ---------------------------------------------------------------------------
# cookie_re class identity
# (tokenize_extra11 namespace)
#
# No prior tokenize spec covers cookie_re (the compiled encoding cookie regex).
# Its class is 're.Pattern' — __class__.__name__ returns 'Pattern'.
# ---------------------------------------------------------------------------

invariant tokenize_extra11.cookie_re.class_is_Pattern:
  description: "tokenize.cookie_re.__class__.__name__ == 'Pattern' — the encoding cookie regex is a compiled re.Pattern"
  category: class_names
  kind: python_call_eq
  function: cookie_re.__class__.__name__.__eq__
  args: ["Pattern"]
  expected: true
