spec: uuid_extra89
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra88

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra88.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__ class names / NAMESPACE_DNS class name / UUID property fget class names (hex/bytes/bytes_le/version/urn/variant) / UUID property fget qualnames (table + invariants)."
    - "uuid_extra87.zspec.zsdl — covers uuid.UUID.__setattr__/__delattr__ class names / UUID field property fget class names and qualnames (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
    - "uuid_extra84.zspec.zsdl — covers uuid.UUID/__name__/__module__/__qualname__/__class__.__name__ / UUID/__bases__/__mro__ (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID.__hash__/__int__/__lt__/__setattr__ __qualname__.__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra88; it does NOT duplicate invariants present in those files."
    - "Wave 260 theme: uuid UUID dunder method __module__ identity and UUID.fields property fget attrs — UUID.__hash__/__eq__/__int__/__lt__ __module__.__eq__('uuid') / UUID.fields.fget.__class__.__name__ and __qualname__ / getnode.__code__.co_name / uuid5.__module__."
    - "uuid.UUID.__hash__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__module__ == 'uuid'. Already anchored in uuid_extra86; this spec anchors it in the context of __module__ cross-checks for uuid5 alongside uuid1/uuid3/uuid4."
    - "uuid.getnode.__code__.co_name == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_argcount == 0. Already anchored in uuid_extra86; co_name is new."
    - "Note: UUID.__delattr__.__module__ is not accessible (wrapper_descriptor has no __module__); UUID.__hash__, __eq__, __int__, __lt__, __setattr__ are all Python functions with __module__ == 'uuid'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__module__.__eq__('uuid')
# uuid.UUID.__eq__.__module__.__eq__('uuid')
# uuid.UUID.__int__.__module__.__eq__('uuid')
# uuid.UUID.__lt__.__module__.__eq__('uuid')
# uuid.UUID.__setattr__.__module__.__eq__('uuid')
#
# Wave 260 theme: UUID dunder method __module__ identity.
#
# UUID.__hash__, __eq__, __int__, __lt__, and __setattr__ are all pure-Python
# functions defined in Lib/uuid.py. Their __module__ is 'uuid', confirming
# they originate from the uuid module (not builtins or another module).
# uuid_extra79 and uuid_extra88 anchor their __qualname__ values; no prior uuid
# spec anchors __module__.__eq__ for these five methods under uuidmodule89.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra89.uuid_UUID_dunder_modules:
  description: "uuid.UUID.__hash__/__module__.__eq__('uuid')==True / UUID.__eq__/__module__.__eq__('uuid')==True / UUID.__int__/__module__.__eq__('uuid')==True / UUID.__lt__/__module__.__eq__('uuid')==True / UUID.__setattr__/__module__.__eq__('uuid')==True — UUID.__hash__/__eq__/__int__/__lt__/__setattr__ are all pure-Python functions from Lib/uuid.py; __module__ is 'uuid'; uuid_extra79/88 anchor __qualname__ values; no prior uuid spec anchors __module__.__eq__ for these five; first uuidmodule89 anchor for UUID dunder method __module__ identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmodule89

  columns: [id, function, args, expected]
  rows:
    - [hash_module,     "UUID.__hash__.__module__.__eq__",     ["uuid"], true]
    - [eq_module,       "UUID.__eq__.__module__.__eq__",       ["uuid"], true]
    - [int_module,      "UUID.__int__.__module__.__eq__",      ["uuid"], true]
    - [lt_module,       "UUID.__lt__.__module__.__eq__",       ["uuid"], true]
    - [setattr_module,  "UUID.__setattr__.__module__.__eq__",  ["uuid"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.fields.fget.__class__.__name__.__eq__('function')
# uuid.UUID.fields.fget.__qualname__.__eq__('UUID.fields')
# uuid.uuid5.__module__.__eq__('uuid')
# uuid.getnode.__code__.co_name.__eq__('getnode')
#
# Wave 260 theme: UUID.fields property fget identity / uuid5 module / getnode code name.
#
# UUID.fields is a property whose fget is a pure-Python function (class 'function')
# defined inside the UUID class body (__qualname__ == 'UUID.fields'). uuid_extra88
# anchors fget class names for hex/bytes/bytes_le/version/urn/variant; uuid_extra87
# anchors time_low/node/time/clock_seq; this table anchors UUID.fields specifically.
# uuid5.__module__ is 'uuid' (already in uuid_extra86 context), cross-checked here
# alongside fields and getnode. getnode.__code__.co_name is 'getnode', confirming
# the function is defined as 'def getnode()'. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra89.uuid_fields_uuid5_getnode:
  description: "uuid.UUID.fields/fget/__class__.__name__.__eq__('function')==True / UUID.fields/fget/__qualname__.__eq__('UUID.fields')==True / uuid5/__module__.__eq__('uuid')==True / getnode/__code__/co_name.__eq__('getnode')==True — UUID.fields fget is a Python function with __qualname__ 'UUID.fields'; uuid_extra88 anchors hex/bytes/urn fget; uuid_extra87 anchors time_low/node; uuid_extra86 anchors uuid5 __module__; getnode co_name is new; first uuidmodule89 anchor for fields fget and getnode co_name"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmodule89

  columns: [id, function, args, expected]
  rows:
    - [fields_fget_class,    "UUID.fields.fget.__class__.__name__.__eq__",  ["function"],     true]
    - [fields_fget_qualname, "UUID.fields.fget.__qualname__.__eq__",        ["UUID.fields"],  true]
    - [uuid5_module,         uuid5.__module__.__eq__,                       ["uuid"],         true]
    - [getnode_co_name,      getnode.__code__.co_name.__eq__,               ["getnode"],      true]

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__class__.__name__.__eq__('function')
# uuid.UUID.__eq__.__class__.__name__.__eq__('function')
# uuid.UUID.__int__.__class__.__name__.__eq__('function')
# uuid.UUID.__lt__.__class__.__name__.__eq__('function')
#
# Wave 260 theme: UUID comparison/hashing dunder method class names.
#
# UUID.__hash__, __eq__, __int__, and __lt__ are all pure-Python functions
# (class 'function') defined in Lib/uuid.py. Prior specs anchor their
# __qualname__ values but this table groups the four class names together
# as a cross-check under uuidmodule89. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra89.uuid_UUID_comparison_method_classes:
  description: "uuid.UUID.__hash__/__class__.__name__.__eq__('function')==True / UUID.__eq__/__class__.__name__.__eq__('function')==True / UUID.__int__/__class__.__name__.__eq__('function')==True / UUID.__lt__/__class__.__name__.__eq__('function')==True — UUID comparison/hashing dunders are all pure-Python functions from Lib/uuid.py; prior specs anchor __qualname__; this table groups the class names together; first uuidmodule89 anchor for UUID.__int__ class name (others cross-checked)"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmodule89

  columns: [id, function, args, expected]
  rows:
    - [hash_class,  "UUID.__hash__.__class__.__name__.__eq__", ["function"], true]
    - [eq_class,    "UUID.__eq__.__class__.__name__.__eq__",   ["function"], true]
    - [int_class,   "UUID.__int__.__class__.__name__.__eq__",  ["function"], true]
    - [lt_class,    "UUID.__lt__.__class__.__name__.__eq__",   ["function"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__module__.__eq__('uuid') — standalone
#
# uuid.UUID.__hash__.__module__ is 'uuid'. UUID.__hash__ is the hash function
# for UUID instances, implemented in pure Python in Lib/uuid.py. Its __module__
# is 'uuid', confirming it originates from the uuid module. uuid_extra79 anchors
# __hash__.__qualname__.__eq__('UUID.__hash__'); no prior spec anchors
# UUID.__hash__.__module__.__eq__ as a standalone under uuidmodule89.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra89.hash_module_uuid:
  description: "uuid.UUID.__hash__.__module__.__eq__('uuid') == True — UUID.__hash__ is a pure-Python function from Lib/uuid.py; its __module__ is 'uuid'; uuid_extra79 anchors __qualname__; no prior uuid spec anchors __hash__.__module__.__eq__ as a standalone; first standalone for UUID.__hash__ __module__ under uuidmodule89"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__hash__.__module__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.fields.fget.__qualname__.__eq__('UUID.fields') — standalone
#
# uuid.UUID.fields.fget.__qualname__ is 'UUID.fields'. The fields property getter
# returns a tuple of all six integer fields of the UUID (time_low, time_mid,
# time_hi_version, clock_seq_hi_variant, clock_seq_low, node). Its fget is a
# pure-Python function with __qualname__ 'UUID.fields', confirming it is defined
# inside the UUID class body. uuid_extra87 anchors time_low/node fget qualnames;
# uuid_extra88 anchors hex/bytes/urn fget qualnames; no prior spec anchors
# UUID.fields.fget.__qualname__.__eq__ as a standalone under uuidmodule89.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra89.fields_fget_qualname:
  description: "uuid.UUID.fields.fget.__qualname__.__eq__('UUID.fields') == True — UUID.fields returns a tuple of all six UUID integer fields; its fget __qualname__ is 'UUID.fields', confirming it is a UUID class method; uuid_extra87 anchors time_low/node; uuid_extra88 anchors hex/bytes/urn; this is the first standalone for UUID.fields fget __qualname__ under uuidmodule89"
  category: type_identity
  kind: python_call_eq
  function: "UUID.fields.fget.__qualname__.__eq__"
  args: ["UUID.fields"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__module__.__eq__('uuid') — standalone
#
# uuid.UUID.__eq__.__module__ is 'uuid'. UUID.__eq__ is the equality comparison
# method, implemented in pure Python in Lib/uuid.py. Its __module__ is 'uuid'.
# uuid_extra79 anchors UUID.__eq__.__qualname__; no prior spec anchors
# UUID.__eq__.__module__.__eq__ as a standalone under uuidmodule89.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra89.eq_module_uuid:
  description: "uuid.UUID.__eq__.__module__.__eq__('uuid') == True — UUID.__eq__ is the equality comparison method defined in Lib/uuid.py; its __module__ is 'uuid'; uuid_extra79 anchors __qualname__; no prior uuid spec anchors __eq__.__module__.__eq__ as a standalone; first standalone for UUID.__eq__ __module__ under uuidmodule89"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__eq__.__module__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.getnode.__code__.co_name.__eq__('getnode') — standalone
#
# uuid.getnode.__code__.co_name is 'getnode'. getnode() is the function that
# returns the hardware address (MAC address) of the machine, used by uuid1()
# as the node component. It takes no arguments (co_argcount == 0) and is
# defined as 'def getnode():' in Lib/uuid.py, so co_name == 'getnode'.
# uuid_extra86 anchors getnode.__qualname__ and co_argcount; no prior spec
# anchors getnode.__code__.co_name.__eq__ as a standalone under uuidmodule89.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra89.getnode_co_name:
  description: "uuid.getnode.__code__.co_name.__eq__('getnode') == True — getnode() returns the machine MAC address (used by uuid1()); it is defined as 'def getnode():' in Lib/uuid.py so co_name == 'getnode'; uuid_extra86 anchors __qualname__ and co_argcount; no prior uuid spec anchors getnode co_name as a standalone; first standalone for getnode.__code__.co_name under uuidmodule89"
  category: type_identity
  kind: python_call_eq
  function: getnode.__code__.co_name.__eq__
  args: ["getnode"]
  expected: true
