spec: signal_extra15
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "This spec extends signal_extra14.zspec.zsdl."
    - "Prior specs covered: signal numbers (SIGINT=2, SIGTERM=15, etc.), SIG_DFL/SIG_IGN values and as Handlers members, signal/__name__, Signals/__name__/__qualname__, Handlers/__name__/__qualname__, getsignal/__name__, raise_signal/__name__, strsignal for various signals, valid_signals() return type, SIG_DFL/SIG_IGN.__eq__ values, Signals/Handlers __name__.__len__(), signal/getsignal/raise_signal __qualname__/__module__ (extra12/extra13), signal.signal/__qualname__/getsignal/__qualname__/raise_signal/__qualname__/strsignal/__name__/__qualname__/valid_signals/__name__/__qualname__ (extra14), signal/getsignal/raise_signal/strsignal __module__.__len__() (extra14)."
    - "This spec covers: signal.signal.__name__.__len__(), signal.getsignal.__name__.__len__(), signal.raise_signal.__name__.__len__(), signal.strsignal.__name__.__len__(), signal.valid_signals.__name__.__len__(), signal.Signals.__module__.__len__(), signal.Handlers.__module__.__len__(), signal.alarm.__module__.__len__(), signal.alarm.__name__.__len__(), signal.pause.__module__.__len__(), signal.set_wakeup_fd.__module__.__len__(), signal.set_wakeup_fd.__name__.__len__()."
    - "signal.signal.__name__.__len__() == 6 — len('signal') == 6; extra14 checks signal.signal.__module__.__len__()==6 and signal.signal.__name__.__eq__('signal') (extra13); no prior signal spec checks __name__.__len__() on signal.signal."
    - "signal.getsignal.__name__.__len__() == 9 — len('getsignal') == 9; no prior signal spec checks getsignal.__name__.__len__()."
    - "signal.raise_signal.__name__.__len__() == 12 — len('raise_signal') == 12; no prior signal spec checks raise_signal.__name__.__len__()."
    - "signal.strsignal.__name__.__len__() == 9 — len('strsignal') == 9; no prior signal spec checks strsignal.__name__.__len__()."
    - "signal.valid_signals.__name__.__len__() == 13 — len('valid_signals') == 13; no prior signal spec checks valid_signals.__name__.__len__()."
    - "signal.Signals.__module__.__len__() == 6 — Signals.__module__ == 'signal' (len 6); extra12 checks Signals.__module__.__eq__; no prior spec checks Signals.__module__.__len__()."
    - "signal.Handlers.__module__.__len__() == 6 — Handlers.__module__ == 'signal' (len 6); extra12 checks Handlers.__module__.__eq__; no prior spec checks Handlers.__module__.__len__()."
    - "signal.alarm.__module__.__len__() == 7 — alarm is a C built-in from '_signal' (len 7); no prior signal spec checks alarm.__module__.__len__()."
    - "signal.alarm.__name__.__len__() == 5 — len('alarm') == 5; no prior signal spec checks alarm.__name__.__len__()."
    - "signal.pause.__module__.__len__() == 7 — pause is a C built-in from '_signal' (len 7); no prior signal spec checks pause.__module__.__len__()."
    - "signal.set_wakeup_fd.__module__.__len__() == 7 — set_wakeup_fd is a C built-in from '_signal' (len 7); no prior signal spec checks set_wakeup_fd.__module__.__len__()."
    - "signal.set_wakeup_fd.__name__.__len__() == 13 — len('set_wakeup_fd') == 13; no prior signal spec checks set_wakeup_fd.__name__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# signal, getsignal, raise_signal, strsignal, valid_signals __name__ string lengths
#
# extra13 checks __name__.__eq__ for signal/getsignal/raise_signal in a table.
# extra14 checks __name__.__eq__ for strsignal and valid_signals as standalone
# invariants. No prior signal spec checks __name__.__len__() on any of these
# five functions. Note: signal.signal.__name__ == 'signal' (len 6) is coincident
# with the module name length, but the attribute path is distinct.
# ---------------------------------------------------------------------------

table signal_extra15.function_name_lengths:
  description: "signal/getsignal/raise_signal/strsignal/valid_signals __name__ string lengths — no prior spec checks __name__.__len__() on these functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnlen15

  columns: [id, function, args, expected]
  rows:
    - [signal,        signal.__name__.__len__,        [], 6]
    - [getsignal,     getsignal.__name__.__len__,     [], 9]
    - [raise_signal,  raise_signal.__name__.__len__,  [], 12]
    - [strsignal,     strsignal.__name__.__len__,     [], 9]
    - [valid_signals, valid_signals.__name__.__len__, [], 13]

# ---------------------------------------------------------------------------
# signal.Signals and signal.Handlers __module__ string lengths
#
# signal_extra12 checks Signals.__module__.__eq__('signal') and
# Handlers.__module__.__eq__('signal') in a table. No prior signal spec checks
# Signals.__module__.__len__() or Handlers.__module__.__len__(). Both enum
# classes are defined in the Python-level 'signal' module (len 6), not in
# the C '_signal' extension.
# ---------------------------------------------------------------------------

invariant signal_extra15.Signals.module_len:
  description: "signal.Signals.__module__.__len__() == 6 — len('signal') == 6; extra12 checks Signals.__module__.__eq__; no prior spec checks Signals.__module__.__len__()"
  category: enum_identity
  kind: python_call_eq
  function: Signals.__module__.__len__
  args: []
  expected: 6

invariant signal_extra15.Handlers.module_len:
  description: "signal.Handlers.__module__.__len__() == 6 — len('signal') == 6; extra12 checks Handlers.__module__.__eq__; no prior spec checks Handlers.__module__.__len__()"
  category: enum_identity
  kind: python_call_eq
  function: Handlers.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# signal.alarm and signal.pause __module__ string lengths
#
# signal.alarm and signal.pause are C built-in functions from the '_signal'
# extension module (len 7). No prior signal spec checks alarm.__module__.__len__()
# or pause.__module__.__len__(). These are lower-level POSIX wrappers that
# were not covered in earlier __module__.__len__() waves (extra14 covered
# signal/getsignal/raise_signal/strsignal).
# ---------------------------------------------------------------------------

invariant signal_extra15.alarm.module_len:
  description: "signal.alarm.__module__.__len__() == 7 — '_signal' (len 7); no prior signal spec checks alarm.__module__.__len__()"
  category: function_modules
  kind: python_call_eq
  function: alarm.__module__.__len__
  args: []
  expected: 7

invariant signal_extra15.alarm.name_len:
  description: "signal.alarm.__name__.__len__() == 5 — len('alarm') == 5; no prior signal spec checks alarm.__name__.__len__()"
  category: function_identity
  kind: python_call_eq
  function: alarm.__name__.__len__
  args: []
  expected: 5

invariant signal_extra15.pause.module_len:
  description: "signal.pause.__module__.__len__() == 7 — '_signal' (len 7); no prior signal spec checks pause.__module__.__len__()"
  category: function_modules
  kind: python_call_eq
  function: pause.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# signal.set_wakeup_fd __module__ and __name__ string lengths
#
# signal.set_wakeup_fd is a C built-in from '_signal' (len 7). Its __name__
# is 'set_wakeup_fd' (len 13). No prior signal spec checks any attribute on
# set_wakeup_fd beyond its existence. The __name__ length is the same as
# valid_signals.__name__.__len__() == 13, providing a useful cross-check.
# ---------------------------------------------------------------------------

invariant signal_extra15.set_wakeup_fd.module_len:
  description: "signal.set_wakeup_fd.__module__.__len__() == 7 — '_signal' (len 7); no prior signal spec checks set_wakeup_fd.__module__.__len__()"
  category: function_modules
  kind: python_call_eq
  function: set_wakeup_fd.__module__.__len__
  args: []
  expected: 7

invariant signal_extra15.set_wakeup_fd.name_len:
  description: "signal.set_wakeup_fd.__name__.__len__() == 13 — len('set_wakeup_fd') == 13; no prior signal spec checks set_wakeup_fd.__name__.__len__()"
  category: function_identity
  kind: python_call_eq
  function: set_wakeup_fd.__name__.__len__
  args: []
  expected: 13
