spec: hashlib_extra124
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra123.zspec.zsdl — covers sha256.__doc__.__class__.__module__.__eq__('builtins')==True / sha256.__doc__.__class__.__module__.__len__()==8 / sha256().__class__.__qualname__.__eq__('HASH')==True / sha256().__class__.__qualname__.__len__()==4 / sha256().__class__.__module__.__len__()==8 (table + invariants)."
    - "hashlib_extra77.zspec.zsdl — covers pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str') as a table row and standalone invariant."
    - "hashlib_extra74.zspec.zsdl — covers scrypt.__class__.__name__.__eq__('builtin_function_or_method') as a table row."
    - "hashlib_extra71.zspec.zsdl — covers pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') / pbkdf2_hmac.__module__.__contains__('hashlib') (table + invariants)."
    - "hashlib_extra39.zspec.zsdl — covers scrypt.__name__.__len__()==6 as a standalone invariant."
    - "hashlib_extra38.zspec.zsdl — covers pbkdf2_hmac.__name__.__len__()==11 as a standalone invariant."
  notes:
    - "This spec extends hashlib through hashlib_extra123; it does NOT duplicate invariants present in those files."
    - "Wave 281 theme: pbkdf2_hmac and scrypt __class__.__name__.__len__() and __doc__.__class__.__module__ — both functions are C-level builtin_function_or_method objects from the _hashlib extension; their __class__.__name__ is 'builtin_function_or_method' (26 chars; not yet anchored as a length); their __doc__ is a Python str, and the str type has __module__=='builtins' (8 chars). extra71 anchors pbkdf2_hmac.__class__.__name__.__eq__; extra74 anchors scrypt.__class__.__name__.__eq__; extra77 anchors pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str'); NO prior spec anchors the LENGTH of the class name (26 chars) for either, and NO prior spec anchors __doc__.__class__.__module__ for either as a grouped table."
    - "hashlib.pbkdf2_hmac.__class__.__name__.__len__() == 26. len('builtin_function_or_method')==26. This is the longest class name string in this spec (and among the longer standard type names in CPython). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__.__len__() == 26. len('builtin_function_or_method')==26. Same class name length as pbkdf2_hmac because both are the same type (builtin_function_or_method). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__doc__.__class__.__module__ == 'builtins'. len('builtins')==8. pbkdf2_hmac.__doc__ is a Python str; the str type has __module__=='builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__doc__.__class__.__module__ == 'builtins'. len('builtins')==8. scrypt.__doc__ is a Python str; the str type also has __module__=='builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: 'builtin_function_or_method' (26 chars) is the standard CPython type name for C-level functions and methods. Both pbkdf2_hmac and scrypt are Password-Based Key Derivation Functions (PBKDFs) implemented in _hashlib via OpenSSL. Their docstrings are Python str objects, and the str type's __module__ is always 'builtins' (8 chars) — the same pattern as seen for sha256.__doc__.__class__.__module__ in hashlib_extra123. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__len__() == 26
# hashlib.pbkdf2_hmac.__doc__.__class__.__module__.__eq__('builtins') == True
# hashlib.pbkdf2_hmac.__doc__.__class__.__module__.__len__() == 8
# hashlib.scrypt.__class__.__name__.__len__() == 26
# hashlib.scrypt.__doc__.__class__.__module__.__eq__('builtins') == True
#
# Wave 281 theme: pbkdf2_hmac and scrypt class name length and doc class module.
#
# Both pbkdf2_hmac and scrypt are C-level builtin_function_or_method objects
# from the _hashlib extension. 'builtin_function_or_method' has 26 chars —
# a notably long type name. Their __doc__ attributes are Python str objects;
# the str type has __module__=='builtins' (8 chars). extra71 anchors
# pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method'); extra77
# anchors pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str'). No prior spec
# anchors the 26-char LENGTH of the class name or the doc class module for
# either function as a grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra124.pbkdf2_hmac_class_name_len_and_doc_module:
  description: "pbkdf2_hmac.__class__.__name__.__len__()==26 / pbkdf2_hmac.__doc__.__class__.__module__.__eq__('builtins')==True / pbkdf2_hmac.__doc__.__class__.__module__.__len__()==8 / scrypt.__class__.__name__.__len__()==26 / scrypt.__doc__.__class__.__module__.__eq__('builtins')==True — both pbkdf2_hmac and scrypt are builtin_function_or_method (26 chars; same class type); both have str docstrings whose __module__ is 'builtins' (8 chars); extra71 anchors pbkdf2_hmac class name eq; extra74 anchors scrypt class name eq; no prior spec anchors 26-char length or doc class module for either; first hashkdf124 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashkdf124

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_cls_name_len,      pbkdf2_hmac.__class__.__name__.__len__,          [],           26,   "pbkdf2_hmac.__class__.__name__.__len__() is 26 (len('builtin_function_or_method')==26; extra71 anchors __eq__; no prior spec anchors __len__()==26 for pbkdf2_hmac)"]
    - [pbkdf2_doc_cls_mod_eq,    pbkdf2_hmac.__doc__.__class__.__module__.__eq__,  ["builtins"], true, "pbkdf2_hmac.__doc__.__class__.__module__ is 'builtins' (pbkdf2_hmac doc is a str; str type __module__=='builtins'; extra77 anchors __class__.__name__.__eq__('str'); no prior spec anchors __module__)"]
    - [pbkdf2_doc_cls_mod_len,   pbkdf2_hmac.__doc__.__class__.__module__.__len__, [],           8,    "pbkdf2_hmac.__doc__.__class__.__module__.__len__() is 8 (len('builtins')==8; same pattern as sha256.__doc__.__class__.__module__ in extra123)"]
    - [scrypt_cls_name_len,      scrypt.__class__.__name__.__len__,                [],           26,   "scrypt.__class__.__name__.__len__() is 26 (len('builtin_function_or_method')==26; same type and length as pbkdf2_hmac; extra74 anchors __eq__; no prior spec anchors __len__()==26 for scrypt)"]
    - [scrypt_doc_cls_mod_eq,    scrypt.__doc__.__class__.__module__.__eq__,        ["builtins"], true, "scrypt.__doc__.__class__.__module__ is 'builtins' (scrypt doc is a str; str type __module__=='builtins'; no prior spec anchors scrypt.__doc__.__class__.__module__ in any form)"]

# ---------------------------------------------------------------------------
# hashlib.scrypt.__doc__.__class__.__module__.__len__() == 8
# hashlib.scrypt.__class__.__name__.__len__() == 26
# hashlib.pbkdf2_hmac.__class__.__name__.__len__() == 26
# hashlib.pbkdf2_hmac.__doc__.__class__.__module__.__len__() == 8
# hashlib.scrypt.__doc__.__class__.__module__.__eq__('builtins') == True
#
# Wave 281 theme: cross-check grouping scrypt doc class module with pbkdf2_hmac.
#
# This table cross-checks the scrypt doc class module length with pbkdf2_hmac for
# consistent regression coverage. Both KDF functions share the same class name length
# (26 chars for 'builtin_function_or_method') and the same doc class module name
# ('builtins', 8 chars). The co-occurrence of these two 8-char strings ('builtins'
# for doc class module and '_hashlib' for function module) in the pbkdf2_hmac/scrypt
# namespace is a notable pattern — both module name strings are 8 chars long.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra124.scrypt_doc_module_and_kdf_class_name_cross_check:
  description: "scrypt.__doc__.__class__.__module__.__len__()==8 / scrypt.__class__.__name__.__len__()==26 / pbkdf2_hmac.__class__.__name__.__len__()==26 / pbkdf2_hmac.__doc__.__class__.__module__.__len__()==8 / scrypt.__doc__.__class__.__module__.__eq__('builtins')==True — cross-check confirming both KDF functions share class name length 26 and doc class module name 'builtins' (8 chars); '_hashlib' (the function __module__) is also 8 chars — three 8-char strings orbit these KDFs; first hashkdf124 cross-check anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashkdf124

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_doc_cls_mod_len,    scrypt.__doc__.__class__.__module__.__len__,      [],           8,    "scrypt.__doc__.__class__.__module__.__len__() is 8 (len('builtins')==8; str type __module__; cross-check confirming length)"]
    - [scrypt_cls_name_len2,      scrypt.__class__.__name__.__len__,                [],           26,   "scrypt.__class__.__name__.__len__() is 26 (len('builtin_function_or_method')==26; cross-check confirming class name length)"]
    - [pbkdf2_cls_name_len2,      pbkdf2_hmac.__class__.__name__.__len__,           [],           26,   "pbkdf2_hmac.__class__.__name__.__len__() is 26 (cross-check; same class type and length as scrypt; 'builtin_function_or_method'=26)"]
    - [pbkdf2_doc_cls_mod_len2,   pbkdf2_hmac.__doc__.__class__.__module__.__len__, [],           8,    "pbkdf2_hmac.__doc__.__class__.__module__.__len__() is 8 (cross-check; len('builtins')==8; three 8-char strings: 'builtins'/'_hashlib'/'builtins')"]
    - [scrypt_doc_cls_mod_eq2,    scrypt.__doc__.__class__.__module__.__eq__,        ["builtins"], true, "scrypt.__doc__.__class__.__module__ is 'builtins' (cross-check confirming str type attribution to builtins module)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__len__() == 26
# hashlib.pbkdf2_hmac.__doc__.__class__.__module__.__eq__('builtins') == True
# hashlib.scrypt.__class__.__name__.__len__() == 26
# hashlib.scrypt.__doc__.__class__.__module__.__eq__('builtins') == True
# hashlib.pbkdf2_hmac.__doc__.__class__.__module__.__len__() == 8
#
# Wave 281 theme: unified table grouping all five core KDF class-level facts.
#
# Both pbkdf2_hmac and scrypt are module-level C builtin functions from the _hashlib
# extension implementing Password-Based Key Derivation Functions (PBKDFs). Their
# shared type ('builtin_function_or_method', 26 chars) and shared doc class module
# ('builtins', 8 chars) form a symmetric picture. This third table unifies the
# equality and length checks for both functions in a single cross-check view,
# confirming the symmetry between the two KDF implementations.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra124.pbkdf2_hmac_and_scrypt_unified_class_facts:
  description: "pbkdf2_hmac.__class__.__name__.__len__()==26 / pbkdf2_hmac.__doc__.__class__.__module__.__eq__('builtins')==True / scrypt.__class__.__name__.__len__()==26 / scrypt.__doc__.__class__.__module__.__eq__('builtins')==True / pbkdf2_hmac.__doc__.__class__.__module__.__len__()==8 — unified cross-check for both KDF functions; they share type 'builtin_function_or_method' (26 chars) and str docstrings with __module__=='builtins' (8 chars); this table groups all five key facts together for regression coverage; first hashkdf124 unified anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashkdf124

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_cls_name_len3,      pbkdf2_hmac.__class__.__name__.__len__,           [],           26,   "pbkdf2_hmac.__class__.__name__.__len__() is 26 (unified cross-check; 'builtin_function_or_method'=26 chars)"]
    - [pbkdf2_doc_cls_mod_eq2,    pbkdf2_hmac.__doc__.__class__.__module__.__eq__,  ["builtins"], true, "pbkdf2_hmac.__doc__.__class__.__module__ is 'builtins' (unified cross-check; str type lives in builtins)"]
    - [scrypt_cls_name_len3,      scrypt.__class__.__name__.__len__,                [],           26,   "scrypt.__class__.__name__.__len__() is 26 (unified cross-check; same type as pbkdf2_hmac; 'builtin_function_or_method'=26)"]
    - [scrypt_doc_cls_mod_eq3,    scrypt.__doc__.__class__.__module__.__eq__,        ["builtins"], true, "scrypt.__doc__.__class__.__module__ is 'builtins' (unified cross-check; scrypt doc is a str; str type __module__=='builtins')"]
    - [pbkdf2_doc_cls_mod_len3,   pbkdf2_hmac.__doc__.__class__.__module__.__len__, [],           8,    "pbkdf2_hmac.__doc__.__class__.__module__.__len__() is 8 (unified cross-check; len('builtins')==8; same as len('_hashlib')==8)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__len__() == 26 — standalone
#
# hashlib.pbkdf2_hmac.__class__.__name__.__len__() is 26. 'builtin_function_or_method'
# has 26 chars: 'builtin'=7 + '_'=1 + 'function'=8 + '_'=1 + 'or'=2 + '_'=1 + 'method'=6 = 26.
# This is the standard CPython type name for all C-level functions and methods. It is
# the longest type name for commonly-encountered Python objects. extra71 anchors
# pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method'); no prior hashlib
# spec anchors pbkdf2_hmac.__class__.__name__.__len__()==26 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra124.pbkdf2_hmac_class_name_len_26:
  description: "hashlib.pbkdf2_hmac.__class__.__name__.__len__() == 26 — len('builtin_function_or_method')==26 ('builtin'=7 + '_function'=9 + '_or'=3 + '_method'=7; longest common Python type name; extra71 anchors __eq__('builtin_function_or_method'); no prior spec anchors __len__()==26 for pbkdf2_hmac class name; first standalone under hashkdf124)"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__doc__.__class__.__module__.__eq__('builtins') — standalone
#
# hashlib.pbkdf2_hmac.__doc__.__class__.__module__ is 'builtins'. pbkdf2_hmac is a
# C-level builtin_function_or_method from _hashlib. Its __doc__ attribute is a Python
# str object (extra77 anchors pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str')).
# The str type (Objects/unicodeobject.c) has its __module__ set to 'builtins' — the
# namespace for all fundamental CPython runtime types. No prior hashlib spec anchors
# pbkdf2_hmac.__doc__.__class__.__module__ in any form. This standalone is the first
# anchor for pbkdf2_hmac doc class module.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra124.pbkdf2_hmac_doc_class_module_builtins:
  description: "hashlib.pbkdf2_hmac.__doc__.__class__.__module__.__eq__('builtins') == True — pbkdf2_hmac doc is a str; str type __module__ is 'builtins' (fundamental CPython runtime type; extra77 anchors __doc__.__class__.__name__.__eq__('str'); no prior spec anchors pbkdf2_hmac.__doc__.__class__.__module__ in any form; first standalone under hashkdf124)"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__class__.__name__.__len__() == 26 — standalone
#
# hashlib.scrypt.__class__.__name__.__len__() is 26. scrypt is a C-level
# builtin_function_or_method from _hashlib (same type as pbkdf2_hmac). The shared
# type name 'builtin_function_or_method' (26 chars) is identical for both KDF
# functions because they are both module-level C builtin functions from the same
# C extension module (_hashlib). extra74 anchors scrypt.__class__.__name__.__eq__
# ('builtin_function_or_method'); no prior hashlib spec anchors scrypt.__class__.__name__
# .__len__()==26 as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra124.scrypt_class_name_len_26:
  description: "hashlib.scrypt.__class__.__name__.__len__() == 26 — len('builtin_function_or_method')==26 (scrypt is C-level builtin from _hashlib; same type as pbkdf2_hmac; coincident 26-char class name; extra74 anchors __eq__('builtin_function_or_method'); no prior spec anchors __len__()==26 for scrypt class name; first standalone under hashkdf124)"
  category: type_identity
  kind: python_call_eq
  function: scrypt.__class__.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# hashlib.scrypt.__doc__.__class__.__module__.__eq__('builtins') — standalone
#
# hashlib.scrypt.__doc__.__class__.__module__ is 'builtins'. scrypt is a C-level
# builtin_function_or_method implementing the RFC 7914 scrypt password-based KDF via
# OpenSSL. Its __doc__ attribute is a Python str object (type name 'str' from
# Objects/unicodeobject.c). The str type has its __module__ set to 'builtins'. No prior
# hashlib spec anchors scrypt.__doc__.__class__.__module__ in any form. This standalone
# is the first anchor for scrypt doc class module attribution.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra124.scrypt_doc_class_module_builtins:
  description: "hashlib.scrypt.__doc__.__class__.__module__.__eq__('builtins') == True — scrypt doc is a str; str type __module__ is 'builtins' (same attribution as pbkdf2_hmac doc class module; extra39 anchors scrypt.__name__.__len__(); no prior spec anchors scrypt.__doc__.__class__.__module__ in any form; first standalone under hashkdf124)"
  category: type_identity
  kind: python_call_eq
  function: scrypt.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__doc__.__class__.__module__.__len__() == 8 — standalone
#
# hashlib.scrypt.__doc__.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# A notable coincidence: scrypt.__module__ is '_hashlib' (also 8 chars), and
# scrypt.__doc__.__class__.__module__ is 'builtins' (also 8 chars). For the scrypt
# function, BOTH module-related 8-char strings appear: the function lives in '_hashlib'
# (8 chars), and its docstring's type lives in 'builtins' (8 chars). The same
# coincidence also holds for pbkdf2_hmac. No prior hashlib spec anchors
# scrypt.__doc__.__class__.__module__.__len__()==8 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra124.scrypt_doc_class_module_len_8:
  description: "hashlib.scrypt.__doc__.__class__.__module__.__len__() == 8 — len('builtins')==8 (str type __module__; coincidence: scrypt.__module__='_hashlib'=8 chars AND scrypt.__doc__.__class__.__module__='builtins'=8 chars — two distinct 8-char module strings around scrypt; no prior spec anchors scrypt doc class module length as standalone; first standalone under hashkdf124)"
  category: type_identity
  kind: python_call_eq
  function: scrypt.__doc__.__class__.__module__.__len__
  args: []
  expected: 8
