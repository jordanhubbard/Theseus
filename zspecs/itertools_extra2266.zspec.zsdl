spec: itertools_extra2266
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of itertools C extension types."
    - "itertools.chain: only __class_getitem__ present (True); all pickling and copy protocol keys absent."
    - "itertools.cycle, itertools.count, itertools.islice: all protocol keys absent."
    - "itertools.combinations, itertools.permutations, itertools.product: __sizeof__ present (True); all other pickling/copy keys absent."
    - "itertools.chain.__reduce__ absent — chain does not implement a custom pickle protocol at the class level."
    - "itertools.count.__reduce__ absent — count also does not define __reduce__ in its class __dict__ despite being picklable via object.__reduce_ex__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra2266.chain_pickle:
  description: "itertools.chain pickle/copy protocol dict-presence — only __class_getitem__ present; __reduce__ and copy keys absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2266

  columns: [id, function, args, expected]
  rows:
    - ["it2266001", "itertools.chain.__dict__.__contains__", ["__reduce__"], false]
    - ["it2266002", "itertools.chain.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["it2266003", "itertools.chain.__dict__.__contains__", ["__getstate__"], false]
    - ["it2266004", "itertools.chain.__dict__.__contains__", ["__setstate__"], false]
    - ["it2266005", "itertools.chain.__dict__.__contains__", ["__getnewargs__"], false]
    - ["it2266006", "itertools.chain.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["it2266007", "itertools.chain.__dict__.__contains__", ["__copy__"], false]
    - ["it2266008", "itertools.chain.__dict__.__contains__", ["__deepcopy__"], false]
    - ["it2266009", "itertools.chain.__dict__.__contains__", ["__sizeof__"], false]
    - ["it2266010", "itertools.chain.__dict__.__contains__", ["__class_getitem__"], true]
    - ["it2266011", "itertools.chain.__dict__.__contains__", ["__init_subclass__"], false]

