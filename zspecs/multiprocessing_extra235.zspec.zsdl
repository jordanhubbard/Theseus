spec: multiprocessing_extra235
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Lock — Lock"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.RLock — RLock"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py (internal implementation)"
  notes:
    - "This spec covers multiprocessing.Lock and multiprocessing.RLock function identity."
    - "multiprocessing.Lock and multiprocessing.RLock are bound methods of BaseContext."
    - "Lock.__module__ == 'multiprocessing.context' (len=23) — defined in Lib/multiprocessing/context.py."
    - "RLock.__module__ == 'multiprocessing.context' (len=23) — same module as Lock."
    - "Lock.__class__.__name__ == 'method' (len=6) — bound method of BaseContext, not a plain function."
    - "RLock.__class__.__name__ == 'method' (len=6) — same class as Lock."
    - "Lock.__qualname__ == 'BaseContext.Lock' (len=16) — prefixed with BaseContext class name."
    - "RLock.__qualname__ == 'BaseContext.RLock' (len=17) — prefixed with BaseContext class name."
    - "Lock.__name__ == 'Lock' (len=4); RLock.__name__ == 'RLock' (len=5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Lock function identity
#
# Lock is a bound method of BaseContext.
# Lock.__name__ == 'Lock' (len=4)
# Lock.__module__ == 'multiprocessing.context' (len=23)
# Lock.__qualname__ == 'BaseContext.Lock' (len=16)
# Lock.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra235.lock_identity:
  description: "multiprocessing.Lock function identity checks — Lock is a bound method of BaseContext defined in multiprocessing.context; Lock.__name__.__eq__('Lock')==True (len=4); Lock.__module__.__eq__('multiprocessing.context')==True (len=23); Lock.__qualname__.__eq__('BaseContext.Lock')==True (len=16, prefixed with BaseContext); Lock.__class__.__name__.__eq__('method')==True (bound method, not a plain function); Lock.__name__.__len__()==4; Lock.__module__.__len__()==23; Lock.__qualname__.__len__()==16; verified with Python 3.14.3"
  kind: python_call_eq
  category: lock_identity
  id_prefix: mplock235

  columns: [id, function, args, expected, description]
  rows:
    - [lk_name_eq,    Lock.__name__.__eq__,           ["Lock"],                    true, "multiprocessing.Lock.__name__ == 'Lock'; verified with Python 3.14.3"]
    - [lk_name_len,   Lock.__name__.__len__,          [],                          4,    "multiprocessing.Lock.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [lk_module_eq,  Lock.__module__.__eq__,         ["multiprocessing.context"], true, "multiprocessing.Lock.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [lk_module_len, Lock.__module__.__len__,        [],                          23,   "multiprocessing.Lock.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [lk_qname_eq,   Lock.__qualname__.__eq__,       ["BaseContext.Lock"],        true, "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock' (bound method of BaseContext); verified with Python 3.14.3"]
    - [lk_qname_len,  Lock.__qualname__.__len__,      [],                          16,   "multiprocessing.Lock.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [lk_cls_nm,     Lock.__class__.__name__.__eq__, ["method"],                  true, "multiprocessing.Lock.__class__.__name__ == 'method' (bound method); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.RLock function identity
#
# RLock is a bound method of BaseContext.
# RLock.__name__ == 'RLock' (len=5)
# RLock.__module__ == 'multiprocessing.context' (len=23)
# RLock.__qualname__ == 'BaseContext.RLock' (len=17)
# RLock.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra235.rlock_identity:
  description: "multiprocessing.RLock function identity checks — RLock is a bound method of BaseContext defined in multiprocessing.context; RLock.__name__.__eq__('RLock')==True (len=5, one more than Lock.__name__.__len__()==4); RLock.__module__.__eq__('multiprocessing.context')==True (len=23, same module as Lock); RLock.__qualname__.__eq__('BaseContext.RLock')==True (len=17, one more than Lock.__qualname__.__len__()==16); RLock.__class__.__name__.__eq__('method')==True (bound method, same class as Lock); verified with Python 3.14.3"
  kind: python_call_eq
  category: rlock_identity
  id_prefix: mprlock235

  columns: [id, function, args, expected, description]
  rows:
    - [rl_name_eq,    RLock.__name__.__eq__,           ["RLock"],                   true, "multiprocessing.RLock.__name__ == 'RLock'; verified with Python 3.14.3"]
    - [rl_name_len,   RLock.__name__.__len__,          [],                          5,    "multiprocessing.RLock.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [rl_module_eq,  RLock.__module__.__eq__,         ["multiprocessing.context"], true, "multiprocessing.RLock.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [rl_module_len, RLock.__module__.__len__,        [],                          23,   "multiprocessing.RLock.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [rl_qname_eq,   RLock.__qualname__.__eq__,       ["BaseContext.RLock"],       true, "multiprocessing.RLock.__qualname__ == 'BaseContext.RLock' (bound method of BaseContext); verified with Python 3.14.3"]
    - [rl_qname_len,  RLock.__qualname__.__len__,      [],                          17,   "multiprocessing.RLock.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [rl_cls_nm,     RLock.__class__.__name__.__eq__, ["method"],                  true, "multiprocessing.RLock.__class__.__name__ == 'method' (bound method); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra235
# ---------------------------------------------------------------------------

invariant multiprocessing_extra235.lock_module_is_context:
  description: "multiprocessing.Lock.__module__.__eq__('multiprocessing.context') returns True — Lock is a bound method of BaseContext defined in Lib/multiprocessing/context.py; __module__ == 'multiprocessing.context' (len=23 = 'multiprocessing'=15 + '.'=1 + 'context'=7); same module as RLock; Lock.__name__ is 'Lock' (len=4); Lock.__qualname__ is 'BaseContext.Lock' (len=16); Lock.__class__.__name__ == 'method'; NEW in extra235: first standalone Lock module invariant in mplock235 namespace; verified with Python 3.14.3"
  category: lock_identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra235.rlock_module_is_context:
  description: "multiprocessing.RLock.__module__.__eq__('multiprocessing.context') returns True — RLock is a bound method of BaseContext defined in Lib/multiprocessing/context.py; __module__ == 'multiprocessing.context' (len=23, same as Lock); RLock.__name__ is 'RLock' (len=5, one more than Lock.__name__.__len__()==4); RLock.__qualname__ is 'BaseContext.RLock' (len=17, one more than Lock.__qualname__.__len__()==16); RLock.__class__.__name__ == 'method'; NEW in extra235: first standalone RLock module invariant in mprlock235 namespace; verified with Python 3.14.3"
  category: rlock_identity
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra235.lock_class_is_method:
  description: "multiprocessing.Lock.__class__.__name__.__eq__('method') returns True — Lock is a bound method (not a plain function) because it is bound to the default context BaseContext instance; __class__.__name__ == 'method' (len=6); contrast with multiprocessing.active_children.__class__.__name__ == 'function' (plain function, not bound); Lock.__name__ == 'Lock' (len=4); Lock.__qualname__ == 'BaseContext.Lock' (len=16); Lock.__module__ == 'multiprocessing.context' (len=23); NEW in extra235: first standalone Lock class invariant; verified with Python 3.14.3"
  category: lock_identity
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra235.rlock_class_is_method:
  description: "multiprocessing.RLock.__class__.__name__.__eq__('method') returns True — RLock is a bound method bound to the default context BaseContext instance; __class__.__name__ == 'method' (len=6, same as Lock.__class__.__name__); RLock.__name__ == 'RLock' (len=5); RLock.__qualname__ == 'BaseContext.RLock' (len=17); RLock.__module__ == 'multiprocessing.context' (len=23); NEW in extra235: first standalone RLock class invariant; verified with Python 3.14.3"
  category: rlock_identity
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra235.lock_qualname_basecontext:
  description: "multiprocessing.Lock.__qualname__.__eq__('BaseContext.Lock') returns True — Lock's qualname reveals it is a method of BaseContext; __qualname__ == 'BaseContext.Lock' (len=16 = len('BaseContext.')=12 + len('Lock')=4); compare RLock.__qualname__ == 'BaseContext.RLock' (len=17 = 12+5); Lock.__name__ is just 'Lock' (len=4, without the class prefix); Lock.__module__ == 'multiprocessing.context' (len=23); NEW in extra235: first standalone Lock qualname invariant; verified with Python 3.14.3"
  category: lock_identity
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["BaseContext.Lock"]
  expected: true

invariant multiprocessing_extra235.rlock_qualname_basecontext:
  description: "multiprocessing.RLock.__qualname__.__eq__('BaseContext.RLock') returns True — RLock's qualname reveals it is a method of BaseContext; __qualname__ == 'BaseContext.RLock' (len=17 = len('BaseContext.')=12 + len('RLock')=5); compare Lock.__qualname__ == 'BaseContext.Lock' (len=16 = 12+4); RLock.__name__ is just 'RLock' (len=5, without the class prefix); RLock.__module__ == 'multiprocessing.context' (len=23); NEW in extra235: first standalone RLock qualname invariant; verified with Python 3.14.3"
  category: rlock_identity
  kind: python_call_eq
  function: RLock.__qualname__.__eq__
  args: ["BaseContext.RLock"]
  expected: true
