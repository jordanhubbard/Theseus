spec: hashlib_extra105
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra99

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s __class__.__name__=='type' and __module__=='_blake2' and __qualname__ equality / new __class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__/__module__/__class__.__name__ equality / file_digest identity / __all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers algorithms_guaranteed membership / new/__qualname__.__len__()==10 / new/__qualname__.__eq__('__hash_new') (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers module-level identity attrs / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ equality (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers algorithms_available/algorithms_guaranteed set class identity / sha256/sha512/sha1/md5 __class__.__name__ (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 265 theme: constructor __qualname__.__len__() values / blake2b/blake2s __mro__ and __bases__ / pbkdf2_hmac and scrypt identity."
    - "hashlib.md5.__qualname__.__len__() == 11 ('openssl_md5'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__.__len__() == 12 ('openssl_sha1'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__.__len__() == 14 ('openssl_sha224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__.__len__() == 14 ('openssl_sha256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__.__len__() == 14 ('openssl_sha384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__.__len__() == 14 ('openssl_sha512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__qualname__.__len__() == 16 ('openssl_sha3_224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__.__len__() == 16 ('openssl_sha3_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__qualname__.__len__() == 16 ('openssl_sha3_384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__.__len__() == 16 ('openssl_sha3_512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__.__len__() == 17 ('openssl_shake_128'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__qualname__.__len__() == 17 ('openssl_shake_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__.__len__() == 7 ('blake2b'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__.__len__() == 7 ('blake2s'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha224/__qualname__.__len__()==sha256/__qualname__.__len__()==sha384/__qualname__.__len__()==sha512/__qualname__.__len__()==14 (all 'openssl_sha' + 3 digits)."
    - "Note: sha3_224/__qualname__.__len__()==sha3_256/__qualname__.__len__()==sha3_384/__qualname__.__len__()==sha3_512/__qualname__.__len__()==16 (all 'openssl_sha3_' + 3 digits)."
    - "Note: shake_128/__qualname__.__len__()==shake_256/__qualname__.__len__()==17 (all 'openssl_shake_' + 3 digits)."
    - "Note: blake2b/__qualname__.__len__()==blake2s/__qualname__.__len__()==7 (no 'openssl_' prefix for the _blake2 C extension class)."
    - "Note: blake2b and blake2s each have __mro__ of depth 2: the class itself and object, because they are C-extension types with no intermediate Python base class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11
# hashlib.sha1.__qualname__.__len__()==12
# hashlib.sha224.__qualname__.__len__()==14
# hashlib.sha256.__qualname__.__len__()==14
# hashlib.sha384.__qualname__.__len__()==14
# hashlib.sha512.__qualname__.__len__()==14
#
# Wave 265 theme: core SHA family constructor __qualname__.__len__() values.
#
# hashlib_extra99 anchors __name__.__eq__ equality for these six constructors;
# hashlib_extra95 anchors __qualname__.__eq__ equality. This table first anchors
# __qualname__.__len__() for each. md5 has the shortest (11, 'openssl_md5'),
# sha1 is 12 ('openssl_sha1'), and the sha224/sha256/sha384/sha512 quartet all
# share length 14 ('openssl_sha' + 3-digit variant number).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra105.core_sha_qualname_lengths:
  description: "hashlib.md5/__qualname__/__len__()==11 / sha1/__qualname__/__len__()==12 / sha224/__qualname__/__len__()==14 / sha256/__qualname__/__len__()==14 / sha384/__qualname__/__len__()==14 / sha512/__qualname__/__len__()==14 — extra99 anchors __name__ equality; extra95 anchors __qualname__ equality; sha224/sha256/sha384/sha512 share length 14 ('openssl_sha' + 3-digit variant); first hashlibqlen105 anchor for core SHA constructor __qualname__.__len__()"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen105

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qlen,    md5.__qualname__.__len__,    [], 11, "'openssl_md5' is 11 chars"]
    - [sha1_qlen,   sha1.__qualname__.__len__,   [], 12, "'openssl_sha1' is 12 chars"]
    - [sha224_qlen, sha224.__qualname__.__len__,  [], 14, "'openssl_sha224' is 14 chars"]
    - [sha256_qlen, sha256.__qualname__.__len__,  [], 14, "'openssl_sha256' is 14 chars"]
    - [sha384_qlen, sha384.__qualname__.__len__,  [], 14, "'openssl_sha384' is 14 chars"]
    - [sha512_qlen, sha512.__qualname__.__len__,  [], 14, "'openssl_sha512' is 14 chars"]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__qualname__.__len__()==16
# hashlib.sha3_256.__qualname__.__len__()==16
# hashlib.sha3_384.__qualname__.__len__()==16
# hashlib.sha3_512.__qualname__.__len__()==16
# hashlib.shake_128.__qualname__.__len__()==17
# hashlib.shake_256.__qualname__.__len__()==17
#
# Wave 265 theme: SHA-3 and SHAKE constructor __qualname__.__len__() values.
#
# hashlib_extra98 anchors __qualname__.__eq__ equality for sha3_*/shake_*.
# This table first anchors __qualname__.__len__(). All four sha3_* share
# length 16 ('openssl_sha3_' + 3-digit variant number). Both shake_* share
# length 17 ('openssl_shake_' + 3-digit variant number).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra105.sha3_shake_qualname_lengths:
  description: "hashlib.sha3_224/__qualname__/__len__()==16 / sha3_256/__qualname__/__len__()==16 / sha3_384/__qualname__/__len__()==16 / sha3_512/__qualname__/__len__()==16 / shake_128/__qualname__/__len__()==17 / shake_256/__qualname__/__len__()==17 — extra98 anchors __qualname__ equality; sha3_* share length 16 ('openssl_sha3_' + 3 digits); shake_* share length 17 ('openssl_shake_' + 3 digits); first hashlibqlen105 anchor for sha3_*/shake_* __qualname__.__len__()"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen105

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_qlen,  sha3_224.__qualname__.__len__,  [], 16, "'openssl_sha3_224' is 16 chars"]
    - [sha3_256_qlen,  sha3_256.__qualname__.__len__,  [], 16, "'openssl_sha3_256' is 16 chars"]
    - [sha3_384_qlen,  sha3_384.__qualname__.__len__,  [], 16, "'openssl_sha3_384' is 16 chars"]
    - [sha3_512_qlen,  sha3_512.__qualname__.__len__,  [], 16, "'openssl_sha3_512' is 16 chars"]
    - [shake_128_qlen, shake_128.__qualname__.__len__,  [], 17, "'openssl_shake_128' is 17 chars"]
    - [shake_256_qlen, shake_256.__qualname__.__len__,  [], 17, "'openssl_shake_256' is 17 chars"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__len__()==7
# hashlib.blake2s.__qualname__.__len__()==7
# hashlib.blake2b.__mro__.__len__()==2
# hashlib.blake2s.__mro__.__len__()==2
# hashlib.blake2b.__bases__[0].__name__.__eq__('object')
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.scrypt.__module__.__eq__('_hashlib')
# hashlib.scrypt.__qualname__.__eq__('scrypt')
#
# Wave 265 theme: blake2 qualname lengths + MRO + pbkdf2_hmac/scrypt identity.
#
# blake2b and blake2s are C-extension classes (not OpenSSL builtins), so their
# __qualname__ lacks the 'openssl_' prefix. __qualname__ is just the class name
# itself: 'blake2b' (7) and 'blake2s' (7). As C-extension type objects that
# inherit only from object, their MRO has depth 2. pbkdf2_hmac and scrypt are
# OpenSSL-backed C builtins (builtin_function_or_method) from the _hashlib
# extension. No prior spec anchors blake2 __qualname__.__len__() or MRO depth,
# or pbkdf2_hmac/scrypt __module__ under hashlibqlen105.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra105.blake2_mro_and_kdf_identity:
  description: "hashlib.blake2b/__qualname__/__len__()==7 / blake2s/__qualname__/__len__()==7 / blake2b/__mro__/__len__()==2 / blake2s/__mro__/__len__()==2 / blake2b/__bases__[0]/__name__.__eq__('object')==True / pbkdf2_hmac/__module__.__eq__('_hashlib')==True / scrypt/__module__.__eq__('_hashlib')==True / scrypt/__qualname__.__eq__('scrypt')==True — blake2 lacks 'openssl_' prefix; MRO depth 2 (class + object); pbkdf2_hmac/scrypt are _hashlib C builtins; first hashlibqlen105 anchor for blake2 qualname lengths and KDF identity"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen105

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_qlen,         blake2b.__qualname__.__len__,              [],           7,    "'blake2b' is 7 chars, no 'openssl_' prefix"]
    - [blake2s_qlen,         blake2s.__qualname__.__len__,              [],           7,    "'blake2s' is 7 chars, no 'openssl_' prefix"]
    - [blake2b_mro_len,      blake2b.__mro__.__len__,                   [],           2,    "MRO depth 2: blake2b itself + object"]
    - [blake2s_mro_len,      blake2s.__mro__.__len__,                   [],           2,    "MRO depth 2: blake2s itself + object"]
    - [blake2b_base_object,  "blake2b.__bases__[0].__name__.__eq__",    ["object"],   true, "blake2b's only base class is object"]
    - [pbkdf2_module,        pbkdf2_hmac.__module__.__eq__,             ["_hashlib"],  true, "pbkdf2_hmac is a C builtin from the _hashlib OpenSSL extension"]
    - [scrypt_module,        scrypt.__module__.__eq__,                  ["_hashlib"],  true, "scrypt is a C builtin from the _hashlib OpenSSL extension"]
    - [scrypt_qualname,      scrypt.__qualname__.__eq__,                ["scrypt"],    true, "scrypt.__qualname__ is 'scrypt' (6 chars), no 'openssl_' prefix in name"]

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11 — standalone
#
# hashlib.md5.__qualname__.__len__() is 11. md5.__qualname__ is 'openssl_md5'
# (11 chars). The 'openssl_' prefix (8 chars) plus the algorithm abbreviation
# 'md5' (3 chars) gives 11. Among the core SHA family, md5 has the shortest
# __qualname__ because 'md5' is the shortest algorithm name (3 chars vs sha1=4,
# sha224/sha256/sha384/sha512=6 chars). hashlib_extra99 anchors md5.__name__.__eq__;
# no prior spec anchors md5.__qualname__.__len__()==11 as a standalone under
# hashlibqlen105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra105.md5_qualname_len_11:
  description: "hashlib.md5.__qualname__.__len__() == 11 — md5.__qualname__ is 'openssl_md5' (11 chars); 'openssl_' (8) + 'md5' (3) = 11; md5 has the shortest qualname among the core SHA family; extra99 anchors md5.__name__.__eq__; first standalone for md5.__qualname__.__len__() under hashlibqlen105"
  category: qualname_lengths
  kind: python_call_eq
  function: md5.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__len__()==16 — standalone
#
# hashlib.sha3_256.__qualname__.__len__() is 16. sha3_256.__qualname__ is
# 'openssl_sha3_256' (16 chars). The 'openssl_sha3_' prefix (13 chars) plus
# the number '256' (3 chars) gives 16. All four sha3_* constructors share
# this length of 16. hashlib_extra98 anchors sha3_256.__qualname__.__eq__;
# no prior spec anchors sha3_256.__qualname__.__len__()==16 as a standalone
# under hashlibqlen105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra105.sha3_256_qualname_len_16:
  description: "hashlib.sha3_256.__qualname__.__len__() == 16 — sha3_256.__qualname__ is 'openssl_sha3_256' (16 chars); 'openssl_sha3_' (13) + '256' (3) = 16; all four sha3_* constructors share length 16; extra98 anchors sha3_256.__qualname__.__eq__; first standalone for sha3_256.__qualname__.__len__() under hashlibqlen105"
  category: qualname_lengths
  kind: python_call_eq
  function: sha3_256.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# hashlib.blake2b.__mro__.__len__()==2 — standalone
#
# hashlib.blake2b.__mro__.__len__() is 2. The MRO of blake2b contains only
# two entries: the blake2b class itself and object. This is the minimal MRO
# for any Python class, confirming that blake2b (a C-extension type from the
# _blake2 module) has no intermediate Python base class between itself and
# object. hashlib_extra99 anchors blake2b.__class__.__name__.__eq__('type');
# no prior spec anchors blake2b.__mro__.__len__()==2 as a standalone under
# hashlibqlen105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra105.blake2b_mro_len_2:
  description: "hashlib.blake2b.__mro__.__len__() == 2 — MRO contains only blake2b and object; minimal MRO depth for a C-extension type with no intermediate Python base; blake2b from _blake2 module inherits directly from object; extra99 anchors blake2b.__class__.__name__.__eq__('type'); first standalone for blake2b.__mro__.__len__() under hashlibqlen105"
  category: qualname_lengths
  kind: python_call_eq
  function: blake2b.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib'. pbkdf2_hmac is a Password-Based
# Key Derivation Function (PBKDF2) implemented as a C builtin in the _hashlib
# extension. It accepts a hash name, password, salt, and iteration count. As a
# C builtin from _hashlib, its __module__ is '_hashlib' rather than 'hashlib'.
# No prior hashlib spec anchors pbkdf2_hmac.__module__.__eq__('_hashlib') as a
# standalone under hashlibqlen105. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra105.pbkdf2_hmac_module_hashlib:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — pbkdf2_hmac is a PBKDF2 implementation as a C builtin in the _hashlib OpenSSL extension; __module__ is '_hashlib' (not 'hashlib'), placing it in the C layer; no prior hashlib spec anchors pbkdf2_hmac.__module__ as a standalone; first standalone for pbkdf2_hmac.__module__ under hashlibqlen105"
  category: qualname_lengths
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true
