spec: inspect_extra222
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect function __qualname__ identity contracts."
    - "inspect.isfunction.__qualname__ == 'isfunction'. Verified with Python 3.14.3."
    - "inspect.isclass.__qualname__ == 'isclass'. Verified with Python 3.14.3."
    - "inspect.ismodule.__qualname__ == 'ismodule'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__qualname__ == 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.isroutine.__qualname__ == 'isroutine'. Verified with Python 3.14.3."
    - "inspect.signature.__qualname__ == 'signature'. Verified with Python 3.14.3."
    - "inspect.getmembers.__qualname__ == 'getmembers'. Verified with Python 3.14.3."
    - "inspect.getsource.__qualname__ == 'getsource'. Verified with Python 3.14.3."
    - "inspect.getfile.__qualname__ == 'getfile'. Verified with Python 3.14.3."
    - "inspect.getdoc.__qualname__ == 'getdoc'. Verified with Python 3.14.3."
    - "inspect.getmodule.__qualname__ == 'getmodule'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect predicate function __qualname__ checks
#
# Verified with Python 3.14.3:
#   isfunction.__qualname__ == 'isfunction'
#   isclass.__qualname__ == 'isclass'
#   ismodule.__qualname__ == 'ismodule'
#   isbuiltin.__qualname__ == 'isbuiltin'
#   isroutine.__qualname__ == 'isroutine'
# ---------------------------------------------------------------------------

table inspect_extra222.predicate_qualnames:
  description: "inspect predicate function __qualname__ identity checks; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra222predqualname

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_qualname_eq,
       isfunction.__qualname__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — isfunction is defined at module scope in Lib/inspect.py; __qualname__ is the simple name 'isfunction'; str.__eq__('isfunction') returns True; new to extra222"]
    - [isclass_qualname_eq,
       isclass.__qualname__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__qualname__.__eq__('isclass') == True — isclass is defined at module scope in Lib/inspect.py; __qualname__ is 'isclass'; str.__eq__('isclass') returns True; new to extra222"]
    - [ismodule_qualname_eq,
       ismodule.__qualname__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__qualname__.__eq__('ismodule') == True — ismodule is defined at module scope in Lib/inspect.py; __qualname__ is 'ismodule'; str.__eq__('ismodule') returns True; new to extra222"]
    - [isbuiltin_qualname_eq,
       isbuiltin.__qualname__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__qualname__.__eq__('isbuiltin') == True — isbuiltin is defined at module scope in Lib/inspect.py; __qualname__ is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra222"]
    - [isroutine_qualname_eq,
       isroutine.__qualname__.__eq__,
       ["isroutine"],
       true,
       "inspect.isroutine.__qualname__.__eq__('isroutine') == True — isroutine is defined at module scope in Lib/inspect.py; __qualname__ is 'isroutine'; str.__eq__('isroutine') returns True; new to extra222"]

# ---------------------------------------------------------------------------
# Table 2: inspect utility function __qualname__ checks
#
# Verified with Python 3.14.3:
#   signature.__qualname__ == 'signature'
#   getmembers.__qualname__ == 'getmembers'
#   getsource.__qualname__ == 'getsource'
#   getfile.__qualname__ == 'getfile'
#   getdoc.__qualname__ == 'getdoc'
#   getmodule.__qualname__ == 'getmodule'
# ---------------------------------------------------------------------------

table inspect_extra222.utility_qualnames:
  description: "inspect utility function __qualname__ identity checks; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra222utilqualname

  columns: [id, function, args, expected, description]
  rows:
    - [signature_qualname_eq,
       signature.__qualname__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — signature is defined at module scope in Lib/inspect.py; __qualname__ is 'signature' (not 'Signature'); str.__eq__('signature') returns True; new to extra222"]
    - [getmembers_qualname_eq,
       getmembers.__qualname__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — getmembers is defined at module scope in Lib/inspect.py; __qualname__ is 'getmembers'; str.__eq__('getmembers') returns True; new to extra222"]
    - [getsource_qualname_eq,
       getsource.__qualname__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__qualname__.__eq__('getsource') == True — getsource is defined at module scope in Lib/inspect.py; __qualname__ is 'getsource'; str.__eq__('getsource') returns True; new to extra222"]
    - [getfile_qualname_eq,
       getfile.__qualname__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__qualname__.__eq__('getfile') == True — getfile is defined at module scope in Lib/inspect.py; __qualname__ is 'getfile'; str.__eq__('getfile') returns True; new to extra222"]
    - [getdoc_qualname_eq,
       getdoc.__qualname__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__qualname__.__eq__('getdoc') == True — getdoc is defined at module scope in Lib/inspect.py; __qualname__ is 'getdoc'; str.__eq__('getdoc') returns True; new to extra222"]
    - [getmodule_qualname_eq,
       getmodule.__qualname__.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__qualname__.__eq__('getmodule') == True — getmodule is defined at module scope in Lib/inspect.py; __qualname__ is 'getmodule'; str.__eq__('getmodule') returns True; new to extra222"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra222
# ---------------------------------------------------------------------------

invariant inspect_extra222.isfunction_qualname:
  description: "inspect.isfunction.__qualname__.__eq__('isfunction') == True — 'isfunction' __qualname__ is 'isfunction'; new to extra222"
  kind: python_call_eq
  function: isfunction.__qualname__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra222.isclass_qualname:
  description: "inspect.isclass.__qualname__.__eq__('isclass') == True — 'isclass' __qualname__ is 'isclass'; new to extra222"
  kind: python_call_eq
  function: isclass.__qualname__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra222.ismodule_qualname:
  description: "inspect.ismodule.__qualname__.__eq__('ismodule') == True — 'ismodule' __qualname__ is 'ismodule'; new to extra222"
  kind: python_call_eq
  function: ismodule.__qualname__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra222.isbuiltin_qualname:
  description: "inspect.isbuiltin.__qualname__.__eq__('isbuiltin') == True — 'isbuiltin' __qualname__ is 'isbuiltin'; new to extra222"
  kind: python_call_eq
  function: isbuiltin.__qualname__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra222.isroutine_qualname:
  description: "inspect.isroutine.__qualname__.__eq__('isroutine') == True — 'isroutine' __qualname__ is 'isroutine'; new to extra222"
  kind: python_call_eq
  function: isroutine.__qualname__.__eq__
  args: ["isroutine"]
  expected: true

invariant inspect_extra222.signature_qualname:
  description: "inspect.signature.__qualname__.__eq__('signature') == True — 'signature' __qualname__ is 'signature'; new to extra222"
  kind: python_call_eq
  function: signature.__qualname__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra222.getmembers_qualname:
  description: "inspect.getmembers.__qualname__.__eq__('getmembers') == True — 'getmembers' __qualname__ is 'getmembers'; new to extra222"
  kind: python_call_eq
  function: getmembers.__qualname__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra222.getsource_qualname:
  description: "inspect.getsource.__qualname__.__eq__('getsource') == True — 'getsource' __qualname__ is 'getsource'; new to extra222"
  kind: python_call_eq
  function: getsource.__qualname__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra222.getfile_qualname:
  description: "inspect.getfile.__qualname__.__eq__('getfile') == True — 'getfile' __qualname__ is 'getfile'; new to extra222"
  kind: python_call_eq
  function: getfile.__qualname__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra222.getdoc_qualname:
  description: "inspect.getdoc.__qualname__.__eq__('getdoc') == True — 'getdoc' __qualname__ is 'getdoc'; new to extra222"
  kind: python_call_eq
  function: getdoc.__qualname__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra222.getmodule_qualname:
  description: "inspect.getmodule.__qualname__.__eq__('getmodule') == True — 'getmodule' __qualname__ is 'getmodule'; new to extra222"
  kind: python_call_eq
  function: getmodule.__qualname__.__eq__
  args: ["getmodule"]
  expected: true
