spec: is_sorted
version: ">=1.0.5"
backend: node(is-sorted)

docs: https://www.npmjs.com/package/is-sorted

provenance:
  derived_from:
    - "is-sorted README — https://www.npmjs.com/package/is-sorted"
    - "Test vectors verified with is-sorted via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-sorted source"
  notes:
    - "is-sorted is an npm package. Install: npm install is-sorted"
    - "Returns true if the array is sorted in ascending order."
    - "Empty arrays return true."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_sorted.isSorted:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: issorted

  columns: [id, args, expected]
  rows:
    - [sorted,    [[1, 2, 3]],     true]
    - [equal,     [[1, 1, 2]],     true]
    - [empty,     [[]],            true]
    - [unsorted,  [[3, 1, 2]],     false]
    - [reverse,   [[3, 2, 1]],     false]
