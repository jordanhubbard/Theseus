spec: concurrent_futures_extra175
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.ThreadPoolExecutor init attributes — concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs); concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames length==6 (also includes ctxkwargs); concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, mp_context, initializer, initargs); concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames length==7 (also includes max_tasks_per_child, queue_size). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5. The signature is __init__(self, max_workers=None, thread_name_prefix='', initializer=None, initargs=()). co_argcount counts positional/keyword parameters including self, giving 5. co_varnames includes additional local vars; len==6 (adds ctxkwargs). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames == ('self', 'max_workers', 'thread_name_prefix', 'initializer', 'initargs', 'ctxkwargs'). The 6th variable ctxkwargs is an internal local variable beyond the 5 co_argcount parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5. The signature is __init__(self, max_workers=None, mp_context=None, initializer=None, initargs=()). co_argcount is 5. co_varnames has 7 entries: adds max_tasks_per_child and queue_size as local variables. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__name__ == '__init__' (len=8: '__'=2+'init'=4+'__'=2=8). concurrent.futures.ProcessPoolExecutor.__init__.__name__ == '__init__' (len=8; same). Both executor classes have the standard __init__ dunder name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.ThreadPoolExecutor.__init__ code attributes
#
# concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5
# (self, max_workers, thread_name_prefix, initializer, initargs)
# concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames len == 6
# (adds ctxkwargs as a local variable beyond co_argcount)
#
# co_argcount counts positional/keyword parameters including self (5 total).
# co_varnames also contains local variables allocated inside __init__.
# In Python 3.14.3, ThreadPoolExecutor.__init__ has 1 extra local (ctxkwargs).
# New to extra175.
# ---------------------------------------------------------------------------

table concurrent_futures_extra175.thread_pool_init_code_attrs:
  description: "ThreadPoolExecutor.__init__.__code__.co_argcount==5; co_varnames len==6; __name__=='__init__' len==8; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: cfinit175

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_co_argcount_5,
       "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__",
       [5],
       true,
       "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5) == True — ThreadPoolExecutor.__init__(self, max_workers, thread_name_prefix, initializer, initargs) has 5 positional parameters including self; co_argcount counts all positional/keyword params; int.__eq__(5) returns True; new to extra175"]
    - [tpe_init_co_varnames_len_6,
       "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__len__",
       [],
       6,
       "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6 — co_varnames contains the 5 co_argcount params plus 1 local variable (ctxkwargs) allocated inside __init__; tuple.__len__() returns 6; new to extra175"]
    - [tpe_init_name_eq,
       "concurrent.futures.ThreadPoolExecutor.__init__.__name__.__eq__",
       ["__init__"],
       true,
       "concurrent.futures.ThreadPoolExecutor.__init__.__name__.__eq__('__init__') == True — the initializer method's __name__ is the standard dunder '__init__' (8 chars: '__'=2+'init'=4+'__'=2=8); str.__eq__('__init__') returns True; new to extra175"]
    - [tpe_init_name_len_8,
       "concurrent.futures.ThreadPoolExecutor.__init__.__name__.__len__",
       [],
       8,
       "concurrent.futures.ThreadPoolExecutor.__init__.__name__.__len__() == 8 — '__init__' has 8 characters: '__'=2+'init'=4+'__'=2=8; standard dunder name length for constructors; str.__len__() returns 8; new to extra175"]
    - [tpe_init_co_varnames_0_self,
       "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames[0] == 'self' — the first entry in co_varnames is always 'self' for unbound instance methods; confirms ThreadPoolExecutor.__init__ is a normal instance method; tuple.__getitem__(0) returns 'self'; new to extra175"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.ProcessPoolExecutor.__init__ code attributes
#
# concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5
# (self, max_workers, mp_context, initializer, initargs)
# concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames len == 7
# (adds max_tasks_per_child and queue_size as local variables)
#
# co_argcount is 5 for ProcessPoolExecutor just like ThreadPoolExecutor.
# co_varnames has 7 entries (5 params + 2 locals: max_tasks_per_child, queue_size).
# New to extra175.
# ---------------------------------------------------------------------------

table concurrent_futures_extra175.process_pool_init_code_attrs:
  description: "ProcessPoolExecutor.__init__.__code__.co_argcount==5; co_varnames len==7; __name__=='__init__' len==8; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: cfinit175

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_init_co_argcount_5,
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__",
       [5],
       true,
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__(5) == True — ProcessPoolExecutor.__init__(self, max_workers, mp_context, initializer, initargs) has 5 positional parameters including self; co_argcount counts positional/keyword params; int.__eq__(5) returns True; new to extra175"]
    - [ppe_init_co_varnames_len_7,
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__",
       [],
       7,
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__() == 7 — co_varnames contains the 5 co_argcount params plus 2 local variables (max_tasks_per_child, queue_size) allocated inside __init__; tuple.__len__() returns 7; new to extra175"]
    - [ppe_init_name_eq,
       "concurrent.futures.ProcessPoolExecutor.__init__.__name__.__eq__",
       ["__init__"],
       true,
       "concurrent.futures.ProcessPoolExecutor.__init__.__name__.__eq__('__init__') == True — ProcessPoolExecutor's initializer __name__ is '__init__' (8 chars); same standard dunder name as ThreadPoolExecutor.__init__; str.__eq__('__init__') returns True; new to extra175"]
    - [ppe_init_co_varnames_0_self,
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames[0] == 'self' — the first co_varnames entry is 'self'; confirms ProcessPoolExecutor.__init__ is a normal instance method; tuple.__getitem__(0) returns 'self'; new to extra175"]
    - [ppe_init_co_varnames_len_gt_tpe,
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__",
       [],
       7,
       "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__() == 7 confirming it is 1 longer than ThreadPoolExecutor co_varnames len==6; ProcessPoolExecutor has 2 extra locals (max_tasks_per_child, queue_size) vs ThreadPoolExecutor's 1 extra local (ctxkwargs); tuple.__len__() returns 7; new to extra175"]

# ---------------------------------------------------------------------------
# Table 3: ThreadPoolExecutor and ProcessPoolExecutor __init__ qualname attrs
#
# concurrent.futures.ThreadPoolExecutor.__init__.__qualname__
#   == 'ThreadPoolExecutor.__init__' (len=27)
# concurrent.futures.ProcessPoolExecutor.__init__.__qualname__
#   == 'ProcessPoolExecutor.__init__' (len=28)
#
# __qualname__ uses dot notation for methods inside classes.
# 'ThreadPoolExecutor.__init__' = 'ThreadPoolExecutor'=18 + '.'=1 + '__init__'=8 = 27
# 'ProcessPoolExecutor.__init__' = 'ProcessPoolExecutor'=19 + '.'=1 + '__init__'=8 = 28
# ProcessPoolExecutor qualname is 1 char longer (Process vs Thread: Process=7, Thread=6).
# New to extra175.
# ---------------------------------------------------------------------------

table concurrent_futures_extra175.executor_init_qualnames:
  description: "ThreadPoolExecutor.__init__.__qualname__ 'ThreadPoolExecutor.__init__' len 27; ProcessPoolExecutor.__init__.__qualname__ 'ProcessPoolExecutor.__init__' len 28; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: cfinit175

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_qualname_eq,
       "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__",
       ["ThreadPoolExecutor.__init__"],
       true,
       "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') == True — __qualname__ uses dot notation for class methods; 'ThreadPoolExecutor.__init__' has 27 chars: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27; str.__eq__('ThreadPoolExecutor.__init__') returns True; new to extra175"]
    - [tpe_init_qualname_len_27,
       "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__",
       [],
       27,
       "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 — 'ThreadPoolExecutor.__init__' has 27 characters: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27; 1 shorter than ProcessPoolExecutor.__init__ qualname (28); str.__len__() returns 27; new to extra175"]
    - [ppe_init_qualname_eq,
       "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__",
       ["ProcessPoolExecutor.__init__"],
       true,
       "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__('ProcessPoolExecutor.__init__') == True — __qualname__ for ProcessPoolExecutor's __init__; 'ProcessPoolExecutor.__init__' has 28 chars: 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28; str.__eq__('ProcessPoolExecutor.__init__') returns True; new to extra175"]
    - [ppe_init_qualname_len_28,
       "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__",
       [],
       28,
       "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.__init__' has 28 characters: 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28; 1 longer than ThreadPoolExecutor.__init__ qualname (27) because 'Process'=7 > 'Thread'=6; str.__len__() returns 28; new to extra175"]
    - [tpe_init_qualname_has_dot,
       "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__contains__",
       ["."],
       true,
       "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__contains__('.') == True — all class method qualnames contain a dot separating class name from method name; 'ThreadPoolExecutor.__init__' contains '.' at position 18; str.__contains__('.') returns True; new to extra175"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra175
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra175.tpe_init_co_argcount_5:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5 — params: self, max_workers, thread_name_prefix, initializer, initargs; new to extra175"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__"
  args: [5]
  expected: true

invariant concurrent_futures_extra175.tpe_init_co_varnames_len_6:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6 — 5 params + 1 local (ctxkwargs); new to extra175"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__len__"
  args: []
