invariant concurrent_futures_extra175.ppe_init_co_argcount_5:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5 — params: self, max_workers, mp_context, initializer, initargs; same count as ThreadPoolExecutor; new to extra175"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__"
  args: [5]
  expected: true

invariant concurrent_futures_extra175.ppe_init_co_varnames_len_7:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__() == 7 — 5 params + 2 locals (max_tasks_per_child, queue_size); 1 more than ThreadPoolExecutor (6); new to extra175"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__"
  args: []
  expected: 7

invariant concurrent_futures_extra175.tpe_init_qualname_len_27:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 — 'ThreadPoolExecutor.__init__' = 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27; new to extra175"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__"
