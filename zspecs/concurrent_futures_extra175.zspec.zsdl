invariant concurrent_futures_extra175.ppe_init_qualname_len_28:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.__init__' = 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28; 1 longer than ThreadPoolExecutor (27); new to extra175"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__"
