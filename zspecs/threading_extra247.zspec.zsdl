spec: threading_extra247
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra246.zspec.zsdl — covers Thread.daemon and Thread.ident property identity"
    - "threading_extra245.zspec.zsdl — covers Barrier class identity and method names"
    - "threading_extra244.zspec.zsdl — covers TIMEOUT_MAX and local class identity"
    - "threading_extra243.zspec.zsdl — covers current_thread, active_count, enumerate function identity"
  notes:
    - "This spec covers threading.Thread.name and threading.Thread.native_id property identity contracts."
    - "threading.Thread.name is a property with both fget and fset. Verified with Python 3.14.3."
    - "threading.Thread.name.__class__.__name__ == 'property'. Verified with Python 3.14.3."
    - "threading.Thread.name.fget.__name__ == 'name' (len=4). Verified with Python 3.14.3."
    - "threading.Thread.name.fget.__qualname__ == 'Thread.name' (len=11). Verified with Python 3.14.3."
    - "threading.Thread.name.fget.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.name.fset.__name__ == 'name' (len=4). Verified with Python 3.14.3."
    - "threading.Thread.name.fset.__qualname__ == 'Thread.name' (len=11). Verified with Python 3.14.3."
    - "threading.Thread.native_id was added in Python 3.8. Verified present in Python 3.14.3."
    - "threading.Thread.native_id.__class__.__name__ == 'property'. Verified with Python 3.14.3."
    - "threading.Thread.native_id.fget.__name__ == 'native_id' (len=9). Verified with Python 3.14.3."
    - "threading.Thread.native_id.fget.__qualname__ == 'Thread.native_id' (len=16). Verified with Python 3.14.3."
    - "threading.Thread.native_id.fget.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.native_id.fset is None — native_id is a read-only property. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.name property identity contracts
#
# threading.Thread.name.__class__.__name__ == 'property'
# threading.Thread.name.__class__.__module__ == 'builtins'
# threading.Thread.name.fget.__name__ == 'name' (len=4)
# threading.Thread.name.fget.__qualname__ == 'Thread.name' (len=11)
# threading.Thread.name.fget.__module__ == 'threading'
#
# Thread.name is a property descriptor on Thread in Lib/threading.py. New to extra247.
# ---------------------------------------------------------------------------

table threading_extra247.thr247prop2_name_identity:
  description: "threading.Thread.name property identity: class, fget name, qualname, module; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: thr247prop2

  columns: [id, function, args, expected, description]
  rows:
    - [name_class_is_property,
       Thread.name.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.name.__class__.__name__.__eq__('property') == True — name is a property descriptor on Thread; __class__.__name__ is 'property'; new to extra247"]
    - [name_class_module_builtins,
       Thread.name.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.Thread.name.__class__.__module__.__eq__('builtins') == True — property is defined in the builtins module; new to extra247"]
    - [name_fget_name_eq,
       Thread.name.fget.__name__.__eq__,
       ["name"],
       true,
       "threading.Thread.name.fget.__name__.__eq__('name') == True — the fget function for the name property is named 'name' (len=4); new to extra247"]
    - [name_fget_qualname_eq,
       Thread.name.fget.__qualname__.__eq__,
       ["Thread.name"],
       true,
       "threading.Thread.name.fget.__qualname__.__eq__('Thread.name') == True — fget __qualname__ is 'Thread.name' (len=11); includes the class name; new to extra247"]
    - [name_fget_module_eq,
       Thread.name.fget.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.name.fget.__module__.__eq__('threading') == True — fget is defined in Lib/threading.py; __module__ is 'threading'; new to extra247"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.name fget/fset lengths and class checks
#
# threading.Thread.name.fget.__name__.__len__() == 4
# threading.Thread.name.fget.__qualname__.__len__() == 11
# threading.Thread.name.fget.__class__.__name__ == 'function'
# threading.Thread.name.fset.__name__ == 'name' (len=4)
# threading.Thread.name.fset.__qualname__ == 'Thread.name' (len=11)
#
# name has both fget and fset (it is a read-write property). New to extra247.
# ---------------------------------------------------------------------------

table threading_extra247.thr247prop2_name_extra:
  description: "threading.Thread.name fget/fset name lengths, fset identity; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: thr247prop2b

  columns: [id, function, args, expected, description]
  rows:
    - [name_fget_name_len_4,
       Thread.name.fget.__name__.__len__,
       [],
       4,
       "threading.Thread.name.fget.__name__.__len__() == 4 — 'name' has exactly 4 characters; str.__len__() returns 4; new to extra247"]
    - [name_fget_qualname_len_11,
       Thread.name.fget.__qualname__.__len__,
       [],
       11,
       "threading.Thread.name.fget.__qualname__.__len__() == 11 — 'Thread.name' has exactly 11 characters; str.__len__() returns 11; new to extra247"]
    - [name_fget_class_is_function,
       Thread.name.fget.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.name.fget.__class__.__name__.__eq__('function') == True — fget is a plain Python function; __class__.__name__ is 'function'; new to extra247"]
    - [name_fset_name_eq,
       Thread.name.fset.__name__.__eq__,
       ["name"],
       true,
       "threading.Thread.name.fset.__name__.__eq__('name') == True — the fset function for the name property is also named 'name' (len=4); new to extra247"]
    - [name_fset_qualname_eq,
       Thread.name.fset.__qualname__.__eq__,
       ["Thread.name"],
       true,
       "threading.Thread.name.fset.__qualname__.__eq__('Thread.name') == True — fset __qualname__ is 'Thread.name' (len=11); same qualified name as fget; new to extra247"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.native_id property identity contracts
#
# threading.Thread.native_id.__class__.__name__ == 'property'
# threading.Thread.native_id.__class__.__module__ == 'builtins'
# threading.Thread.native_id.fget.__name__ == 'native_id' (len=9)
# threading.Thread.native_id.fget.__qualname__ == 'Thread.native_id' (len=16)
# threading.Thread.native_id.fget.__module__ == 'threading'
#
# native_id is a read-only property (no fset) added in Python 3.8. New to extra247.
# ---------------------------------------------------------------------------

table threading_extra247.thr247prop2_nativeid_identity:
  description: "threading.Thread.native_id property identity: class, fget name, qualname, module; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: thr247prop2c

  columns: [id, function, args, expected, description]
  rows:
    - [nativeid_class_is_property,
       Thread.native_id.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.native_id.__class__.__name__.__eq__('property') == True — native_id is a read-only property descriptor on Thread (added Python 3.8); __class__.__name__ is 'property'; new to extra247"]
    - [nativeid_class_module_builtins,
       Thread.native_id.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.Thread.native_id.__class__.__module__.__eq__('builtins') == True — property is defined in the builtins module; new to extra247"]
    - [nativeid_fget_name_eq,
       Thread.native_id.fget.__name__.__eq__,
       ["native_id"],
       true,
       "threading.Thread.native_id.fget.__name__.__eq__('native_id') == True — the fget function for the native_id property is named 'native_id' (len=9); new to extra247"]
    - [nativeid_fget_qualname_eq,
       Thread.native_id.fget.__qualname__.__eq__,
       ["Thread.native_id"],
       true,
       "threading.Thread.native_id.fget.__qualname__.__eq__('Thread.native_id') == True — fget __qualname__ is 'Thread.native_id' (len=16); includes the class name; new to extra247"]
    - [nativeid_fget_module_eq,
       Thread.native_id.fget.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.native_id.fget.__module__.__eq__('threading') == True — fget is defined in Lib/threading.py; __module__ is 'threading'; new to extra247"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread.native_id fget lengths and content checks
#
# threading.Thread.native_id.fget.__name__.__len__() == 9
# threading.Thread.native_id.fget.__qualname__.__len__() == 16
# threading.Thread.native_id.fget.__class__.__name__ == 'function'
# threading.Thread.native_id.fget.__name__.__contains__('native') == True
# threading.Thread.native_id.fget.__qualname__.__contains__('Thread') == True
#
# New to extra247.
# ---------------------------------------------------------------------------

table threading_extra247.thr247prop2_nativeid_extra:
  description: "threading.Thread.native_id fget name lengths and content checks; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: thr247prop2d

  columns: [id, function, args, expected, description]
  rows:
    - [nativeid_fget_name_len_9,
       Thread.native_id.fget.__name__.__len__,
       [],
       9,
       "threading.Thread.native_id.fget.__name__.__len__() == 9 — 'native_id' has exactly 9 characters; str.__len__() returns 9; new to extra247"]
    - [nativeid_fget_qualname_len_16,
       Thread.native_id.fget.__qualname__.__len__,
       [],
       16,
       "threading.Thread.native_id.fget.__qualname__.__len__() == 16 — 'Thread.native_id' has exactly 16 characters; str.__len__() returns 16; new to extra247"]
    - [nativeid_fget_class_is_function,
       Thread.native_id.fget.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.native_id.fget.__class__.__name__.__eq__('function') == True — fget is a plain Python function; __class__.__name__ is 'function'; new to extra247"]
    - [nativeid_fget_name_contains_native,
       Thread.native_id.fget.__name__.__contains__,
       ["native"],
       true,
       "threading.Thread.native_id.fget.__name__.__contains__('native') == True — 'native_id' contains 'native'; new to extra247"]
    - [nativeid_fget_qualname_contains_thread,
       Thread.native_id.fget.__qualname__.__contains__,
       ["Thread"],
       true,
       "threading.Thread.native_id.fget.__qualname__.__contains__('Thread') == True — 'Thread.native_id' contains 'Thread'; confirms the property fget is scoped to Thread; new to extra247"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra247
# ---------------------------------------------------------------------------

invariant threading_extra247.name_class_is_property:
  description: "threading.Thread.name.__class__.__name__ == 'property'; new to extra247"
  kind: python_call_eq
  function: Thread.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra247.name_fget_name_eq:
  description: "threading.Thread.name.fget.__name__ == 'name' (len=4); new to extra247"
  kind: python_call_eq
  function: Thread.name.fget.__name__.__eq__
  args: ["name"]
  expected: true

invariant threading_extra247.name_fget_qualname_eq:
  description: "threading.Thread.name.fget.__qualname__ == 'Thread.name' (len=11); new to extra247"
  kind: python_call_eq
  function: Thread.name.fget.__qualname__.__eq__
  args: ["Thread.name"]
  expected: true

invariant threading_extra247.name_fget_module_eq:
  description: "threading.Thread.name.fget.__module__ == 'threading' — defined in Lib/threading.py; new to extra247"
  kind: python_call_eq
  function: Thread.name.fget.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra247.name_fget_name_len_4:
  description: "threading.Thread.name.fget.__name__.__len__() == 4; new to extra247"
  kind: python_call_eq
  function: Thread.name.fget.__name__.__len__
  args: []
  expected: 4

invariant threading_extra247.name_fset_name_eq:
  description: "threading.Thread.name.fset.__name__ == 'name' (len=4); new to extra247"
  kind: python_call_eq
  function: Thread.name.fset.__name__.__eq__
  args: ["name"]
  expected: true

invariant threading_extra247.nativeid_class_is_property:
  description: "threading.Thread.native_id.__class__.__name__ == 'property' (added Python 3.8); new to extra247"
  kind: python_call_eq
  function: Thread.native_id.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra247.nativeid_fget_name_eq:
  description: "threading.Thread.native_id.fget.__name__ == 'native_id' (len=9); new to extra247"
  kind: python_call_eq
  function: Thread.native_id.fget.__name__.__eq__
  args: ["native_id"]
  expected: true

invariant threading_extra247.nativeid_fget_qualname_eq:
  description: "threading.Thread.native_id.fget.__qualname__ == 'Thread.native_id' (len=16); new to extra247"
  kind: python_call_eq
  function: Thread.native_id.fget.__qualname__.__eq__
  args: ["Thread.native_id"]
  expected: true

invariant threading_extra247.nativeid_fget_module_eq:
  description: "threading.Thread.native_id.fget.__module__ == 'threading' — defined in Lib/threading.py; new to extra247"
  kind: python_call_eq
  function: Thread.native_id.fget.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra247.nativeid_fget_name_len_9:
  description: "threading.Thread.native_id.fget.__name__.__len__() == 9; new to extra247"
  kind: python_call_eq
  function: Thread.native_id.fget.__name__.__len__
  args: []
  expected: 9

invariant threading_extra247.nativeid_fget_qualname_len_16:
  description: "threading.Thread.native_id.fget.__qualname__.__len__() == 16; new to extra247"
  kind: python_call_eq
  function: Thread.native_id.fget.__qualname__.__len__
  args: []
  expected: 16
