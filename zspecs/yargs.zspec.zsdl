spec: yargs
version: ">=17.0.0"
backend: node(yargs)

docs: https://github.com/yargs/yargs#readme

provenance:
  derived_from:
    - "yargs README — https://github.com/yargs/yargs#readme"
    - "Test vectors verified with yargs via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "yargs source"
  notes:
    - "yargs is an npm package. Install: npm install yargs"
    - "Usage: const yargs = require('yargs'); yargs(argv).parseSync()"
    - "yargs(argv) returns a configured instance; .parseSync() returns the parsed object."
    - "$0 is yargs' script-name field; it is empty string when argv is passed explicitly."
    - "yargs the full package is distinct from yargs-parser (which only parses); yargs adds commands, help, completion, etc."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Returns a parsed-arguments object including '_' (positional), '$0' (script name), and parsed flags."
  stderr: "null"
  stickiness: "N/A — each yargs(argv) creates an independent instance."
  codes: {}

# yargs(argv).parseSync() — node_factory_call_eq fits this two-step pattern.

table yargs.parse:
  kind: node_factory_call_eq
  category: parse
  factory: ~
  method: parseSync
  method_args: []
  id_prefix: parse

  columns: [id, factory_args, expected]
  rows:
    - [long_flag,        [["--foo", "bar"]],        {_: [], foo: "bar",   "$0": ""}]
    - [equals_syntax,    [["--port=8080"]],          {_: [], port: 8080,   "$0": ""}]
    - [negation,         [["--no-color"]],           {_: [], color: false, "$0": ""}]
    - [combined_short,   [["-abc"]],                 {_: [], a: true, b: true, c: true, "$0": ""}]
    - [positional_args,  [["pos1", "pos2"]],         {_: ["pos1", "pos2"], "$0": ""}]
    - [empty_argv,       [[]],                        {_: [], "$0": ""}]
    - [numeric_coercion, [["--n", "42"]],            {_: [], n: 42, "$0": ""}]
    - [mixed,            [["--name=Alice", "-x", "5"]], {_: [], name: "Alice", x: 5, "$0": ""}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:41:41Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
