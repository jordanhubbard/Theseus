spec: abc_extra214
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.get_cache_token.__module__ == '_abc' on CPython 3.14 — provided by the C accelerator."
    - "abc.get_cache_token() returns an integer (class 'int') that increments on ABC registration."
    - "abc.ABC.__module__ == 'abc' and abc.ABC.__name__ == 'ABC'."
    - "abc.ABCMeta.__call__.__qualname__ == 'type.__call__' — ABCMeta inherits __call__ from type."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' — defined directly on ABCMeta."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.get_cache_token function identity — extra214 namespace
# ---------------------------------------------------------------------------

table abc_extra214.get_cache_token_identity:
  description: "abc.get_cache_token __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: abc214gctident

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name,   get_cache_token.__name__.__eq__,   ["get_cache_token"], true, "abc.get_cache_token.__name__ == 'get_cache_token'"]
    - [gct_module, get_cache_token.__module__.__eq__, ["_abc"],            true, "abc.get_cache_token.__module__ == '_abc' (C accelerator)"]

# ---------------------------------------------------------------------------
# abc.get_cache_token() return type — extra214 namespace
# ---------------------------------------------------------------------------

invariant abc_extra214.get_cache_token_returns_int:
  description: "abc.get_cache_token() returns an int — cache token is an integer"
  category: behavior
  kind: python_call_eq
  function: abc.get_cache_token().__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABC class identity — extra214 namespace
# ---------------------------------------------------------------------------

table abc_extra214.abc_class_identity:
  description: "abc.ABC class __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: abc214abcident

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name,   ABC.__name__.__eq__,   ["ABC"], true, "abc.ABC.__name__ == 'ABC'"]
    - [abc_module, ABC.__module__.__eq__, ["abc"],  true, "abc.ABC.__module__ == 'abc'"]

# ---------------------------------------------------------------------------
# abc.ABCMeta method identity — extra214 namespace
# ---------------------------------------------------------------------------

table abc_extra214.abcmeta_method_identity:
  description: "abc.ABCMeta method __name__ and __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: abc214metaident

  columns: [id, function, args, expected, description]
  rows:
    - [call_qualname,      ABCMeta.__call__.__qualname__.__eq__,         ["type.__call__"],            true, "ABCMeta.__call__.__qualname__ == 'type.__call__' (inherited from type)"]
    - [register_name,      ABCMeta.register.__name__.__eq__,             ["register"],                 true, "ABCMeta.register.__name__ == 'register'"]
    - [register_qualname,  ABCMeta.register.__qualname__.__eq__,         ["ABCMeta.register"],         true, "ABCMeta.register.__qualname__ == 'ABCMeta.register'"]
    - [icheck_name,        ABCMeta.__instancecheck__.__name__.__eq__,    ["__instancecheck__"],        true, "ABCMeta.__instancecheck__.__name__ == '__instancecheck__'"]
    - [scheck_name,        ABCMeta.__subclasscheck__.__name__.__eq__,    ["__subclasscheck__"],        true, "ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'"]

# ---------------------------------------------------------------------------
# abc.ABCMeta __instancecheck__ and __subclasscheck__ qualnames — extra214
# ---------------------------------------------------------------------------

invariant abc_extra214.instancecheck_qualname:
  description: "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra214.subclasscheck_qualname:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true
