spec: object_keys
version: ">=1.1.1"
backend: node(object-keys)

docs: https://www.npmjs.com/package/object-keys

provenance:
  derived_from:
    - "object-keys README — https://www.npmjs.com/package/object-keys"
    - "Test vectors verified with object-keys via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-keys source"
  notes:
    - "object-keys is an npm package. Install: npm install object-keys"
    - "Returns an array of an object's own enumerable property names."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_keys.keys:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: okeys

  columns: [id, args, expected]
  rows:
    - [two,    [{"a": 1, "b": 2}],       ["a", "b"]]
    - [empty,  [{}],                     []]
    - [one,    [{"x": 42}],              ["x"]]

