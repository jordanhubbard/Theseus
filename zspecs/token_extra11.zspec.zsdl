spec: token_extra11
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token_extra10.zspec.zsdl — covers NAME/NUMBER/STRING/OP/NEWLINE/ENDMARKER/INDENT/DEDENT/COMMENT/ENCODING/NL/ERRORTOKEN __class__.__name__ == 'int' via __eq__"
    - "token_extra9.zspec.zsdl — covers tok_name/EXACT_TOKEN_TYPES __class__.__name__=='dict'; ISEOF/ISTERMINAL/ISNONTERMINAL __qualname__; tok_name indices 11-16; EXACT_TOKEN_TYPES exact values"
    - "token_extra.zspec.zsdl — covers int type checks for all major constants; tok_name/EXACT_TOKEN_TYPES is_dict; NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
    - "token_extra2.zspec.zsdl — covers tok_name min_length>=50 via __len__; ENDMARKER==0 exact value; tok_name[0-4]"
    - "token_extra4.zspec.zsdl — covers INDENT==5/DEDENT==6 exact values"
  notes:
    - "This spec extends token_extra10.zspec.zsdl."
    - "Focus: tok_name.__len__() == 71 and EXACT_TOKEN_TYPES.__len__() == 48 as standalone invariants; standalone exact-value invariants for OP, NEWLINE, ENDMARKER that were not covered individually in the token_extra11 namespace."
    - "token.tok_name.__len__() == 71 — token_extra2 covers __len__() >= 50 via a comparison; exact value 71 as a standalone __eq__ invariant in the token_extra11 namespace is new."
    - "token.EXACT_TOKEN_TYPES.__len__() == 48 — no prior token spec covers this exact length as a standalone invariant."
    - "token.OP == 55 — no prior token spec covers OP exact value as a standalone invariant (token_extra covers type only)."
    - "token.NEWLINE == 4 — token_extra covers NEWLINE exact value in the token_extra namespace; distinct standalone invariant in token_extra11 namespace."
    - "token.ENDMARKER == 0 — token_extra2 covers ENDMARKER==0 in token_extra2 namespace; distinct standalone invariant in token_extra11 namespace."
    - "token.NAME == 1, token.NUMBER == 2, token.STRING == 3 — token_extra covers these in the token_extra namespace; distinct standalone invariants in token_extra11 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tok_name and EXACT_TOKEN_TYPES exact lengths
# (token_extra11 namespace)
#
# token_extra2 covers tok_name.__len__() >= 50 as a comparison invariant.
# No prior token spec verifies tok_name.__len__() == 71 as a standalone __eq__
# invariant. No prior token spec covers EXACT_TOKEN_TYPES.__len__() == 48.
# ---------------------------------------------------------------------------

invariant token_extra11.tok_name.len_is_71:
  description: "token.tok_name.__len__() == 71 — tok_name dict has 71 entries"
  category: dict_lengths
  kind: python_call_eq
  function: tok_name.__len__
  args: []
  expected: 71

invariant token_extra11.EXACT_TOKEN_TYPES.len_is_48:
  description: "token.EXACT_TOKEN_TYPES.__len__() == 48 — EXACT_TOKEN_TYPES dict has 48 entries"
  category: dict_lengths
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__len__
  args: []
  expected: 48

# ---------------------------------------------------------------------------
# Core token constant exact values — standalone invariants
# (token_extra11 namespace)
#
# token_extra covers NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values in the
# token_extra namespace. token_extra2 covers ENDMARKER==0. No prior spec covers
# OP == 55 as a standalone invariant. All six are distinct in token_extra11.
# ---------------------------------------------------------------------------

table token_extra11.core_constant_values:
  description: "Exact integer values for core token constants"
  kind: python_call_eq
  category: constant_values
  id_prefix: cval

  columns: [id, function, args, expected]
  rows:
    - [ENDMARKER, ENDMARKER.__eq__, [0],  true]
    - [NAME,      NAME.__eq__,      [1],  true]
    - [NUMBER,    NUMBER.__eq__,    [2],  true]
    - [STRING,    STRING.__eq__,    [3],  true]
    - [NEWLINE,   NEWLINE.__eq__,   [4],  true]
    - [OP,        OP.__eq__,        [55], true]
