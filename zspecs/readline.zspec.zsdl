spec: readline
version: ">=3.0"
backend: python_module(readline)

docs: https://docs.python.org/3/library/readline.html

provenance:
  derived_from:
    - "Python readline documentation — https://docs.python.org/3/library/readline.html"
    - "Test vectors verified by running Python 3.14.3 readline module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/readline.c"
  notes:
    - "readline is a POSIX-only module (available on macOS and Linux; not available on Windows)."
    - "On macOS, Python may be linked against libedit rather than GNU readline; the API is compatible but not identical."
    - "get_history_length() returns the maximum number of history lines saved to file; -1 means unlimited (the initial default)."
    - "get_current_history_length() returns the number of lines currently in the in-memory history buffer."
    - "set_history_length(n) sets the max lines written by write_history_file; -1 means save all."
    - "add_history(line) appends a string to the in-memory history list."
    - "parse_and_bind(string) executes a readline init-file command (e.g. 'tab: complete')."
    - "remove_history_item(pos) and replace_history_item(pos, line) edit history by zero-based index."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — readline API surface
# ---------------------------------------------------------------------------

table readline.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [parse_and_bind,             parse_and_bind.__name__.__eq__,             ["parse_and_bind"],             true]
    - [read_history_file,          read_history_file.__name__.__eq__,          ["read_history_file"],          true]
    - [write_history_file,         write_history_file.__name__.__eq__,         ["write_history_file"],         true]
    - [get_history_length,         get_history_length.__name__.__eq__,         ["get_history_length"],         true]
    - [set_history_length,         set_history_length.__name__.__eq__,         ["set_history_length"],         true]
    - [clear_history,              clear_history.__name__.__eq__,              ["clear_history"],              true]
    - [get_current_history_length, get_current_history_length.__name__.__eq__, ["get_current_history_length"], true]
    - [get_history_item,           get_history_item.__name__.__eq__,           ["get_history_item"],           true]
    - [remove_history_item,        remove_history_item.__name__.__eq__,        ["remove_history_item"],        true]
    - [replace_history_item,       replace_history_item.__name__.__eq__,       ["replace_history_item"],       true]
    - [add_history,                add_history.__name__.__eq__,                ["add_history"],                true]

# ---------------------------------------------------------------------------
# Behavioral — history length defaults and current history count
# ---------------------------------------------------------------------------

invariant readline.behavior.get_history_length_default:
  description: "readline.get_history_length() == -1 — initial value means unlimited"
  category: behavior
  kind: python_call_eq
  function: get_history_length
  args: []
  expected: -1

invariant readline.behavior.get_current_history_length_nonneg:
  description: "readline.get_current_history_length() >= 0 — in-memory history is never negative"
  category: behavior
  kind: python_call_eq
  function: get_current_history_length
  args: []
  method: __ge__
  method_args: [0]
  expected: true

