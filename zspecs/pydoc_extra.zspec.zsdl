spec: pydoc_extra
version: ">=3.9"
backend: python_module(pydoc)

docs: https://docs.python.org/3/library/pydoc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pydoc.html — Python pydoc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pydoc.py"
  notes:
    - "This spec covers pydoc behaviors not in pydoc.zspec.zsdl."
    - "pydoc.locate() searches for an object by dotted name, returning None if not found."
    - "pydoc.render_doc() generates documentation for an object as a string."
    - "pydoc.resolve() resolves a string to an object and its name, returning (object, name)."
    - "pydoc.TextDoc.__name__ == 'TextDoc' and pydoc.TextDoc.__module__ == 'pydoc'."
    - "pydoc.HTMLDoc.__name__ == 'HTMLDoc' — generates HTML-formatted documentation."
    - "pydoc.Doc.__name__ == 'Doc' — base class for TextDoc and HTMLDoc."
    - "pydoc.ModuleScanner.__name__ == 'ModuleScanner' — scans installed modules."
    - "pydoc.Helper.__name__ == 'Helper' — implements the interactive help() system."
    - "pydoc.plaintext is a module-level singleton instance of TextDoc."
    - "pydoc.html is a module-level singleton instance of HTMLDoc."
    - "pydoc.help is a module-level singleton instance of Helper."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — locate, render_doc, resolve
# ---------------------------------------------------------------------------

invariant pydoc_extra.locate.name:
  description: "pydoc.locate.__name__ == 'locate'"
  category: functions
  kind: python_call_eq
  function: locate.__name__.__eq__
  args: ["locate"]
  expected: true

invariant pydoc_extra.render_doc.name:
  description: "pydoc.render_doc.__name__ == 'render_doc'"
  category: functions
  kind: python_call_eq
  function: render_doc.__name__.__eq__
  args: ["render_doc"]
  expected: true

invariant pydoc_extra.resolve.name:
  description: "pydoc.resolve.__name__ == 'resolve'"
  category: functions
  kind: python_call_eq
  function: resolve.__name__.__eq__
  args: ["resolve"]
  expected: true

# ---------------------------------------------------------------------------
# TextDoc class — name and module
# ---------------------------------------------------------------------------

invariant pydoc_extra.TextDoc.name:
  description: "pydoc.TextDoc.__name__ == 'TextDoc'"
  category: classes
  kind: python_call_eq
  function: TextDoc.__name__.__eq__
  args: ["TextDoc"]
  expected: true

invariant pydoc_extra.TextDoc.module:
  description: "pydoc.TextDoc.__module__ == 'pydoc'"
  category: classes
  kind: python_call_eq
  function: TextDoc.__module__.__eq__
  args: ["pydoc"]
  expected: true

# ---------------------------------------------------------------------------
# HTMLDoc class — name and module
# ---------------------------------------------------------------------------

invariant pydoc_extra.HTMLDoc.name:
  description: "pydoc.HTMLDoc.__name__ == 'HTMLDoc'"
  category: classes
  kind: python_call_eq
  function: HTMLDoc.__name__.__eq__
  args: ["HTMLDoc"]
  expected: true

invariant pydoc_extra.HTMLDoc.module:
  description: "pydoc.HTMLDoc.__module__ == 'pydoc'"
  category: classes
  kind: python_call_eq
  function: HTMLDoc.__module__.__eq__
  args: ["pydoc"]
  expected: true

# ---------------------------------------------------------------------------
# Doc class — base class for documentation formatters
# ---------------------------------------------------------------------------

invariant pydoc_extra.Doc.name:
  description: "pydoc.Doc.__name__ == 'Doc'"
  category: classes
  kind: python_call_eq
  function: Doc.__name__.__eq__
  args: ["Doc"]
  expected: true

invariant pydoc_extra.Doc.module:
  description: "pydoc.Doc.__module__ == 'pydoc'"
  category: classes
  kind: python_call_eq
  function: Doc.__module__.__eq__
  args: ["pydoc"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleScanner class — name and module
# ---------------------------------------------------------------------------

invariant pydoc_extra.ModuleScanner.name:
  description: "pydoc.ModuleScanner.__name__ == 'ModuleScanner'"
  category: classes
  kind: python_call_eq
  function: ModuleScanner.__name__.__eq__
  args: ["ModuleScanner"]
  expected: true

invariant pydoc_extra.ModuleScanner.module:
  description: "pydoc.ModuleScanner.__module__ == 'pydoc'"
  category: classes
  kind: python_call_eq
  function: ModuleScanner.__module__.__eq__
  args: ["pydoc"]
  expected: true

# ---------------------------------------------------------------------------
# Helper class — name and module
# ---------------------------------------------------------------------------

invariant pydoc_extra.Helper.name:
  description: "pydoc.Helper.__name__ == 'Helper'"
  category: classes
  kind: python_call_eq
  function: Helper.__name__.__eq__
  args: ["Helper"]
  expected: true

invariant pydoc_extra.Helper.module:
  description: "pydoc.Helper.__module__ == 'pydoc'"
  category: classes
  kind: python_call_eq
  function: Helper.__module__.__eq__
  args: ["pydoc"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level singleton instances
#
# pydoc.plaintext is an instance of TextDoc, pydoc.html is an instance of
# HTMLDoc, and pydoc.help is an instance of Helper.
# ---------------------------------------------------------------------------

invariant pydoc_extra.plaintext.class_name:
  description: "pydoc.plaintext.__class__.__name__ == 'TextDoc'"
  category: singletons
  kind: python_call_eq
  function: plaintext.__class__.__name__.__eq__
  args: ["TextDoc"]
  expected: true

invariant pydoc_extra.html_singleton.class_name:
  description: "pydoc.html.__class__.__name__ == 'HTMLDoc'"
  category: singletons
  kind: python_call_eq
  function: html.__class__.__name__.__eq__
  args: ["HTMLDoc"]
  expected: true

invariant pydoc_extra.help_singleton.class_name:
  description: "pydoc.help.__class__.__name__ == 'Helper'"
  category: singletons
  kind: python_call_eq
  function: help.__class__.__name__.__eq__
  args: ["Helper"]
  expected: true

# ---------------------------------------------------------------------------
# Function callability checks
# ---------------------------------------------------------------------------

invariant pydoc_extra.locate.is_callable:
  description: "pydoc.locate is a function"
  category: functions
  kind: python_call_eq
  function: locate.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pydoc_extra.render_doc.is_callable:
  description: "pydoc.render_doc is a function"
  category: functions
  kind: python_call_eq
  function: render_doc.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pydoc_extra.resolve.is_callable:
  description: "pydoc.resolve is a function"
  category: functions
  kind: python_call_eq
  function: resolve.__class__.__name__.__eq__
  args: ["function"]
  expected: true
