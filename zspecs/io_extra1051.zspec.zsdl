spec: io_extra1051
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io class __init_subclass__ qualnames, __module__ identity, and class hierarchy properties"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1051.init_subclass_qualnames:
  description: "io class __init_subclass__.__qualname__ identity (should equal object.__init_subclass__)"
  kind: python_call_eq
  category: init_subclass_qualnames
  id_prefix: io1051x
  columns: [id, function, args, expected]
  rows:
    - [io1051x001, io.IOBase.__init_subclass__.__qualname__.__eq__,      ["object.__init_subclass__"], true]
    - [io1051x002, io.FileIO.__init_subclass__.__qualname__.__eq__,      ["object.__init_subclass__"], true]
    - [io1051x003, io.BytesIO.__init_subclass__.__qualname__.__eq__,     ["object.__init_subclass__"], true]
    - [io1051x004, io.StringIO.__init_subclass__.__qualname__.__eq__,    ["object.__init_subclass__"], true]
    - [io1051x005, io.TextIOWrapper.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [io1051x006, io.RawIOBase.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"], true]
    - [io1051x007, io.BufferedIOBase.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]

table io_extra1051.module_identity:
  description: "io class __module__ identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: io1051m
  columns: [id, function, args, expected]
  rows:
    - [io1051m001, io.UnsupportedOperation.__module__.__eq__,  ["io"],      true]
    - [io1051m002, io.BlockingIOError.__module__.__eq__,       ["builtins"], true]
    - [io1051m003, io.IOBase.__module__.__eq__,                ["io"],      true]
    - [io1051m004, io.FileIO.__module__.__eq__,                ["io"],      true]
    - [io1051m005, io.BytesIO.__module__.__eq__,               ["io"],      true]
    - [io1051m006, io.StringIO.__module__.__eq__,              ["io"],      true]
    - [io1051m007, io.TextIOWrapper.__module__.__eq__,         ["io"],      true]

table io_extra1051.class_name_identity:
  description: "io class __name__ identity checks"
  kind: python_call_eq
  category: class_name_identity
  id_prefix: io1051n
  columns: [id, function, args, expected]
  rows:
    - [io1051n001, io.IOBase.__name__.__eq__,              ["IOBase"],             true]
    - [io1051n002, io.RawIOBase.__name__.__eq__,           ["RawIOBase"],          true]
    - [io1051n003, io.BufferedIOBase.__name__.__eq__,      ["BufferedIOBase"],     true]
    - [io1051n004, io.TextIOBase.__name__.__eq__,          ["TextIOBase"],         true]
    - [io1051n005, io.UnsupportedOperation.__name__.__eq__, ["UnsupportedOperation"], true]
    - [io1051n006, io.BlockingIOError.__name__.__eq__,     ["BlockingIOError"],    true]
    - [io1051n007, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"],      true]
