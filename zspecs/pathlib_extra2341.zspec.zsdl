spec: pathlib_extra2341
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra.zspec.zsdl — covers class names, module membership, operator behavior"
  notes:
    - "Theme: __slots__ contents for pathlib slotted classes."
    - "pathlib was refactored in Python 3.12; all concrete path classes now use __slots__."
    - "PurePath defines __slots__ with 8 entries: _raw_paths, _drv, _root, _tail_cached, _str, _str_normcase_cached, _parts_normcase_cached, _hash."
    - "PurePosixPath, PureWindowsPath, PosixPath define __slots__ = () — empty, inheriting from PurePath."
    - "Path defines __slots__ = ('_info',) — one additional slot for the OS stat cache object."
    - "All expected values verified by running Python 3.14 pathlib on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# PurePath — __slots__ declared with 8 members
# ---------------------------------------------------------------------------

table pathlib_extra2341.purepath_slots:
  kind: python_call_eq
  category: slots
  id_prefix: pp2341

  columns: [id, function, args, expected]
  rows:
    - ["pp2341001", PurePath.__dict__.__contains__,               ["__slots__"],               true]
    - ["pp2341002", PurePath.__slots__.__contains__,              ["_raw_paths"],               true]
    - ["pp2341003", PurePath.__slots__.__contains__,              ["_drv"],                     true]
    - ["pp2341004", PurePath.__slots__.__contains__,              ["_root"],                    true]
    - ["pp2341005", PurePath.__slots__.__contains__,              ["_tail_cached"],             true]
    - ["pp2341006", PurePath.__slots__.__contains__,              ["_str"],                     true]
    - ["pp2341007", PurePath.__slots__.__contains__,              ["_str_normcase_cached"],     true]
    - ["pp2341008", PurePath.__slots__.__contains__,              ["_parts_normcase_cached"],   true]
    - ["pp2341009", PurePath.__slots__.__contains__,              ["_hash"],                    true]
    - ["pp2341010", PurePath.__slots__.__contains__,              ["_nonexistent_"],            false]
    - ["pp2341011", PurePath.__slots__.__len__,                   [],                           8]

# ---------------------------------------------------------------------------
# Path — __slots__ with 1 entry (_info), PurePosixPath/PureWindowsPath/PosixPath empty
# ---------------------------------------------------------------------------

table pathlib_extra2341.path_slots:
  kind: python_call_eq
  category: slots
  id_prefix: pp2341

  columns: [id, function, args, expected]
  rows:
    - ["pp2341012", Path.__dict__.__contains__,           ["__slots__"],   true]
    - ["pp2341013", Path.__slots__.__contains__,          ["_info"],        true]
    - ["pp2341014", Path.__slots__.__contains__,          ["_drv"],         false]
    - ["pp2341015", Path.__slots__.__len__,               [],               1]
    - ["pp2341016", PurePosixPath.__dict__.__contains__,  ["__slots__"],   true]
    - ["pp2341017", PurePosixPath.__slots__.__len__,      [],               0]
    - ["pp2341018", PureWindowsPath.__dict__.__contains__, ["__slots__"],  true]
    - ["pp2341019", PureWindowsPath.__slots__.__len__,    [],               0]
    - ["pp2341020", PosixPath.__dict__.__contains__,      ["__slots__"],   true]
    - ["pp2341021", PosixPath.__slots__.__len__,          [],               0]
    - ["pp2341022", PurePosixPath.__slots__.__contains__, ["_info"],        false]
