spec: operator_extra22
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra21.zspec.zsdl."
    - "operator_extra21 covers: __bases__[0].__name__.__eq__ for attrgetter/itemgetter/methodcaller; qualname and __module__ for same three."
    - "operator_extra20 covers: __name__.__eq__ for add/sub/mul/truediv/floordiv/mod/pow/neg; arithmetic call results table; truediv float invariant."
    - "No prior operator spec records __qualname__.__eq__ for the comparison functions (lt/gt/eq/ne/le/ge) together in the extra22 namespace."
    - "All comparison functions (lt/gt/eq/ne/le/ge) plus arithmetic functions (add/mul/sub/truediv) have __module__ == '_operator' — all are C builtins."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — six comparison functions
#
# Verifies that each comparison function has a simple qualname equal to its
# attribute name. All six are C builtins in _operator with no nested scope.
# No prior operator spec records all six comparison function qualnames in one
# table in the extra22 namespace.
# ---------------------------------------------------------------------------

table operator_extra22.comparison_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra22.comparison_qualnames.lt,
       lt.__qualname__.__eq__,
       ["lt"],
       true,
       "operator.lt.__qualname__ == 'lt'"]
    - [operator_extra22.comparison_qualnames.gt,
       gt.__qualname__.__eq__,
       ["gt"],
       true,
       "operator.gt.__qualname__ == 'gt'"]
    - [operator_extra22.comparison_qualnames.eq,
       eq.__qualname__.__eq__,
       ["eq"],
       true,
       "operator.eq.__qualname__ == 'eq'"]
    - [operator_extra22.comparison_qualnames.ne,
       ne.__qualname__.__eq__,
       ["ne"],
       true,
       "operator.ne.__qualname__ == 'ne'"]
    - [operator_extra22.comparison_qualnames.le,
       le.__qualname__.__eq__,
       ["le"],
       true,
       "operator.le.__qualname__ == 'le'"]
    - [operator_extra22.comparison_qualnames.ge,
       ge.__qualname__.__eq__,
       ["ge"],
       true,
       "operator.ge.__qualname__ == 'ge'"]

# ---------------------------------------------------------------------------
# add.__qualname__.__eq__ — standalone qualname invariant
#
# operator.add is a C builtin in _operator. Its qualname is 'add', matching
# its attribute name on the operator module.
# No prior operator spec records this in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra22.add.qualname:
  description: "operator.add.__qualname__ == 'add' — simple qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: add.__qualname__.__eq__
  args: ["add"]
  expected: true

# ---------------------------------------------------------------------------
# mul.__qualname__.__eq__ — standalone qualname invariant
#
# operator.mul is a C builtin in _operator. Its qualname is 'mul'.
# No prior operator spec records this in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra22.mul.qualname:
  description: "operator.mul.__qualname__ == 'mul' — simple qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: mul.__qualname__.__eq__
  args: ["mul"]
  expected: true

# ---------------------------------------------------------------------------
# lt.__qualname__.__eq__ — standalone qualname invariant
#
# operator.lt is a C builtin in _operator. Its qualname is 'lt'.
# No prior operator spec records this in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra22.lt.qualname:
  description: "operator.lt.__qualname__ == 'lt' — simple qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: lt.__qualname__.__eq__
  args: ["lt"]
  expected: true

# ---------------------------------------------------------------------------
# gt.__qualname__.__eq__ — standalone qualname invariant
#
# operator.gt is a C builtin in _operator. Its qualname is 'gt'.
# No prior operator spec records this in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra22.gt.qualname:
  description: "operator.gt.__qualname__ == 'gt' — simple qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: gt.__qualname__.__eq__
  args: ["gt"]
  expected: true

# ---------------------------------------------------------------------------
# eq.__qualname__.__eq__ — standalone qualname invariant
#
# operator.eq is a C builtin in _operator. Its qualname is 'eq'.
# No prior operator spec records this in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra22.eq.qualname:
  description: "operator.eq.__qualname__ == 'eq' — simple qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: eq.__qualname__.__eq__
  args: ["eq"]
  expected: true

# ---------------------------------------------------------------------------
# add.__module__.__eq__ — C extension module anchor
#
# operator.add (and all arithmetic/comparison functions) are implemented in
# the _operator C extension, so __module__ == '_operator', not 'operator'.
# No prior operator spec records this in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra22.add.module:
  description: "operator.add.__module__ == '_operator' — add is a C builtin in _operator"
  category: function_attrs
  kind: python_call_eq
  function: add.__module__.__eq__
  args: ["_operator"]
  expected: true
