spec: math_trig_rust
version: ">=3.9"
backend: rust_module(math_trig_rust)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "Trigonometric and angle conversion functions not covered in math_rust or math_extra_rust."
    - "degrees(pi) == 180.0, degrees(2*pi) == 360.0 — exact conversions."
    - "sinh(0) == 0.0, cosh(0) == 1.0, tanh(0) == 0.0 — exact hyperbolic values at 0."
    - "log1p(0) == 0.0 — log(1 + 0) == 0 (exact)."
    - "expm1(0) == 0.0 — e^0 - 1 == 0 (exact)."
    - "atan2(0, 1) == 0.0 — angle of positive x-axis (exact)."
    - "radians(0) == 0.0 (exact)."
    - "All test vectors verified against Python 3.14.3 math module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# degrees — convert radians to degrees
table math_trig_rust.degrees.vectors:
  kind: python_call_eq
  category: degrees
  id_prefix: mt_deg
  function: degrees

  columns: [id, args, expected]
  rows:
    - [pi_to_180, [3.141592653589793], 180.0]
    - [two_pi_to_360, [6.283185307179586], 360.0]
    - [zero, [0.0], 0.0]

# radians — convert degrees to radians (exact at 0)
invariant math_trig_rust.radians.zero:
  description: "radians(0) == 0.0"
  category: radians
  kind: python_call_eq
  function: radians
  args: [0]
  expected: 0.0

# Hyperbolic functions — exact at 0
table math_trig_rust.hyperbolic.vectors:
  kind: python_call_eq
  category: hyperbolic
  id_prefix: mt_hyp

  columns: [id, function, args, expected]
  rows:
    - [sinh_zero, sinh, [0.0], 0.0]
    - [cosh_zero, cosh, [0.0], 1.0]
    - [tanh_zero, tanh, [0.0], 0.0]

# Special exponential/logarithm at 0 (exact values)
table math_trig_rust.special_zero.vectors:
  kind: python_call_eq
  category: special
  id_prefix: mt_sp0

  columns: [id, function, args, expected]
  rows:
    - [log1p_zero,  log1p,  [0.0], 0.0]
    - [expm1_zero,  expm1,  [0.0], 0.0]
    - [atan2_x_axis, atan2, [0.0, 1.0], 0.0]

# tau constant
invariant math_trig_rust.tau:
  description: "math.tau == 2 * math.pi == 6.283185307179586"
  category: constants
  kind: python_call_eq
  function: tau.__eq__
  args: [6.283185307179586]
  expected: true

