spec: p_debounce
version: ">=5.0.0"
backend: node(p-debounce)
esm: true

docs: https://github.com/sindresorhus/p-debounce#readme

provenance:
  derived_from:
    - "p-debounce README — https://github.com/sindresorhus/p-debounce#readme"
    - "Test vectors verified with p-debounce via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-debounce source"
  notes:
    - "Promise-aware debounce: wraps an async function so rapid calls collapse into a single trailing invocation."
    - "Install: npm install p-debounce"
    - "v5 ESM only; default export pDebounce(fn, wait, [options]) → debounced. Has .promise() variant."
    - "Spec covers shape only — JSON entry_args cannot pass async-function inputs."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws synchronously only on invalid args; underlying fn errors propagate via the returned promise."
  stderr: "null"
  stickiness: "Each call to pDebounce returns a new debounced wrapper with its own pending state."
  codes: {}

invariant p_debounce.default_export_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant p_debounce.default_name:
  description: "Default function name is 'pDebounce'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "pDebounce"

invariant p_debounce.default_arity:
  description: "Default function takes 2 args (fn, wait)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 2

invariant p_debounce.has_promise_static:
  description: ".promise() variant exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.promise.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:19:05Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
