spec: uuid_extra2596
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence — checking whether uuid.UUID implements the descriptor protocol in its own class __dict__."
    - "uuid.UUID.__dict__.__contains__('__get__') == False — UUID instances are value objects, not attribute descriptors. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__set__') == False — UUID does not define __set__; it is not a data descriptor. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__delete__') == False — UUID does not define __delete__, confirming non-descriptor status. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__set_name__') == False — __set_name__ is also absent; uuid.UUID has no descriptor protocol hook."
    - "Note: uuid.UUID.__dict__ contains member_descriptor and getset_descriptor typed values (int, is_safe, __weakref__) but the UUID class itself does not implement __get__/__set__/__delete__."
    - "uuid.UUID defines a rich set of value-object dunders: __eq__, __hash__, __int__, __lt__, __gt__, __le__, __ge__, __str__, __repr__, __setattr__ — none of which are descriptor protocol methods."
    - "uuid.UUID.__dict__.__contains__('hex') == True — hex is a property returning the UUID as a 32-char hex string."
    - "uuid.UUID.__dict__.__contains__('bytes') == True — bytes is a property returning the 16-byte big-endian representation."
    - "uuid.UUID.__dict__.__contains__('version') == True — version is a property returning the UUID version number (1-5)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ absence — uuid.UUID does not implement the non-data descriptor protocol
#
# For a class to be usable as a non-data descriptor, it must define __get__
# in its own __dict__. uuid.UUID does not. UUID instances are immutable
# value objects that hold a 128-bit integer, not attribute descriptors.
# ---------------------------------------------------------------------------

table uuid_extra2596.get_absent:
  description: "__get__ is absent from uuid.UUID.__dict__ — UUID instances are value objects, not non-data descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2596

  columns: [id, function, args, expected]
  rows:
    - ["uu2596001", "uuid.UUID.__dict__.__contains__", ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ absence — uuid.UUID does not implement the data descriptor write protocol
#
# A data descriptor must define __set__ (and/or __delete__). uuid.UUID
# defines neither. In fact, uuid.UUID overrides __setattr__ to make instances
# immutable, but that is the opposite of a descriptor write hook.
# ---------------------------------------------------------------------------

table uuid_extra2596.set_absent:
  description: "__set__ is absent from uuid.UUID.__dict__ — UUID instances do not implement the data descriptor write protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2596

  columns: [id, function, args, expected]
  rows:
    - ["uu2596002", "uuid.UUID.__dict__.__contains__", ["__set__"],      false]
    - ["uu2596003", "uuid.UUID.__dict__.__contains__", ["__delete__"],   false]
    - ["uu2596004", "uuid.UUID.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Value-object dunders present in uuid.UUID.__dict__
#
# These True entries confirm that uuid.UUID has a rich __dict__ with a
# genuine value-object API, contrasting with the absent descriptor protocol.
# uuid.UUID is sortable, hashable, comparable, and representable.
# ---------------------------------------------------------------------------

table uuid_extra2596.value_object_dunders_present:
  description: "Value-object dunders are present in uuid.UUID.__dict__, contrasting with absent descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2596

  columns: [id, function, args, expected]
  rows:
    - ["uu2596005", "uuid.UUID.__dict__.__contains__", ["__eq__"],      true]
    - ["uu2596006", "uuid.UUID.__dict__.__contains__", ["__hash__"],    true]
    - ["uu2596007", "uuid.UUID.__dict__.__contains__", ["__int__"],     true]
    - ["uu2596008", "uuid.UUID.__dict__.__contains__", ["__lt__"],      true]
    - ["uu2596009", "uuid.UUID.__dict__.__contains__", ["__gt__"],      true]
    - ["uu2596010", "uuid.UUID.__dict__.__contains__", ["__str__"],     true]
    - ["uu2596011", "uuid.UUID.__dict__.__contains__", ["__repr__"],    true]
    - ["uu2596012", "uuid.UUID.__dict__.__contains__", ["__setattr__"], true]

# ---------------------------------------------------------------------------
# UUID-domain property descriptors present in uuid.UUID.__dict__
#
# uuid.UUID exposes its value through property descriptors defined directly
# in its __dict__. These are domain-specific APIs, not the descriptor protocol.
# The class has descriptors IN it, but is not itself a descriptor.
# ---------------------------------------------------------------------------

table uuid_extra2596.uuid_properties_present:
  description: "UUID-domain property descriptors are present in uuid.UUID.__dict__ — the class contains descriptors but is not one"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2596

  columns: [id, function, args, expected]
  rows:
    - ["uu2596013", "uuid.UUID.__dict__.__contains__", ["hex"],      true]
    - ["uu2596014", "uuid.UUID.__dict__.__contains__", ["bytes"],    true]
    - ["uu2596015", "uuid.UUID.__dict__.__contains__", ["version"],  true]
    - ["uu2596016", "uuid.UUID.__dict__.__contains__", ["variant"],  true]
    - ["uu2596017", "uuid.UUID.__dict__.__contains__", ["fields"],   true]
    - ["uu2596018", "uuid.UUID.__dict__.__contains__", ["urn"],      true]
    - ["uu2596019", "uuid.UUID.__dict__.__contains__", ["node"],     true]
    - ["uu2596020", "uuid.UUID.__dict__.__contains__", ["time"],     true]
