spec: dbm
version: ">=3.0"
backend: python_module(dbm)

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/dbm.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "dbm source: Lib/dbm/__init__.py (PSF; source inspection permitted)"
  not_derived_from:
    - "dbm source: underlying C library implementations (gdbm, ndbm, etc.)"
  notes:
    - "dbm.error is a tuple of exception classes, not a single exception class."
    - "dbm.whichdb(filename) returns None when the file does not exist."
    - "dbm.whichdb(filename) returns a string naming the backend module when the file can be identified."
    - "dbm._names lists the available backend module names in priority order (e.g. ['dbm.sqlite3', 'dbm.gnu', 'dbm.ndbm', 'dbm.dumb'])."
    - "dbm.dumb.error is OSError (an alias)."
    - "dbm.dumb._Database provides a pure-Python fallback implementation always available."
    - "dbm.open() flag values: 'r' read-only, 'w' read-write, 'c' create-or-open, 'n' always create new."
    - "All expected values verified by running Python 3.12 dbm module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name metadata
# ---------------------------------------------------------------------------

table dbm.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [open,    open.__name__.__eq__,    ["open"],    true]
    - [whichdb, whichdb.__name__.__eq__,  ["whichdb"], true]

# ---------------------------------------------------------------------------
# whichdb — returns None for a nonexistent path
# ---------------------------------------------------------------------------

invariant dbm.whichdb_nonexistent_returns_none:
  description: "dbm.whichdb('/nonexistent_path/nope.db') == None — unrecognised or missing file returns None"
  category: whichdb
  kind: python_call_eq
  function: whichdb
  args: ["/nonexistent_path/nope.db"]
  expected: ~

# ---------------------------------------------------------------------------
# dbm.error — is a tuple of exception types
# ---------------------------------------------------------------------------

invariant dbm.error_is_tuple:
  description: "isinstance(dbm.error, tuple) == True — dbm.error is a tuple of exception classes"
  category: error_type
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
