spec: pathlib_extra258
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib.PurePath method identity: __truediv__, joinpath, relative_to, is_relative_to, with_name, with_suffix, with_stem, as_posix, as_uri."
    - "All pathlib.PurePath methods are Python functions (not C-level method_descriptors); their __class__.__name__ is 'function'."
    - "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__'; all PurePath methods use the 'PurePath.' prefix."
    - "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath', etc. — all methods are defined directly on PurePath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePath method __name__ identity
#
# __truediv__, joinpath, relative_to, is_relative_to, with_name, with_suffix,
# with_stem, as_posix, as_uri are all Python functions defined in Lib/pathlib/.
# Their __name__ values match the method name exactly.
# ---------------------------------------------------------------------------

table pathlib_extra258.purepath_method_names:
  description: "pathlib.PurePath method __name__ identity — __truediv__, joinpath, relative_to, is_relative_to, with_name, with_suffix, with_stem, as_posix, as_uri; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: plxppmn258

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_name,
       "PurePath.__truediv__.__name__.__eq__",
       ["__truediv__"],
       true,
       "pathlib.PurePath.__truediv__.__name__.__eq__('__truediv__') == True — PurePath.__truediv__ is a Python function implementing the / operator for path joining; its __name__ is '__truediv__'; str.__eq__('__truediv__') returns True; new to extra258"]
    - [joinpath_name,
       "PurePath.joinpath.__name__.__eq__",
       ["joinpath"],
       true,
       "pathlib.PurePath.joinpath.__name__.__eq__('joinpath') == True — PurePath.joinpath is a Python function for combining a path with one or more arguments; its __name__ is 'joinpath'; str.__eq__('joinpath') returns True; new to extra258"]
    - [relative_to_name,
       "PurePath.relative_to.__name__.__eq__",
       ["relative_to"],
       true,
       "pathlib.PurePath.relative_to.__name__.__eq__('relative_to') == True — PurePath.relative_to is a Python function returning the path relative to another path; its __name__ is 'relative_to'; str.__eq__('relative_to') returns True; new to extra258"]
    - [is_relative_to_name,
       "PurePath.is_relative_to.__name__.__eq__",
       ["is_relative_to"],
       true,
       "pathlib.PurePath.is_relative_to.__name__.__eq__('is_relative_to') == True — PurePath.is_relative_to is a Python function testing whether the path is relative to another path; its __name__ is 'is_relative_to'; str.__eq__('is_relative_to') returns True; new to extra258"]
    - [with_name_name,
       "PurePath.with_name.__name__.__eq__",
       ["with_name"],
       true,
       "pathlib.PurePath.with_name.__name__.__eq__('with_name') == True — PurePath.with_name is a Python function returning a new path with the final component replaced; its __name__ is 'with_name'; str.__eq__('with_name') returns True; new to extra258"]
    - [with_suffix_name,
       "PurePath.with_suffix.__name__.__eq__",
       ["with_suffix"],
       true,
       "pathlib.PurePath.with_suffix.__name__.__eq__('with_suffix') == True — PurePath.with_suffix is a Python function returning a new path with the file extension replaced; its __name__ is 'with_suffix'; str.__eq__('with_suffix') returns True; new to extra258"]
    - [with_stem_name,
       "PurePath.with_stem.__name__.__eq__",
       ["with_stem"],
       true,
       "pathlib.PurePath.with_stem.__name__.__eq__('with_stem') == True — PurePath.with_stem is a Python function returning a new path with the stem (name without suffix) replaced; its __name__ is 'with_stem'; str.__eq__('with_stem') returns True; new to extra258"]
    - [as_posix_name,
       "PurePath.as_posix.__name__.__eq__",
       ["as_posix"],
       true,
       "pathlib.PurePath.as_posix.__name__.__eq__('as_posix') == True — PurePath.as_posix is a Python function returning the path as a POSIX string with forward slashes; its __name__ is 'as_posix'; str.__eq__('as_posix') returns True; new to extra258"]
    - [as_uri_name,
       "PurePath.as_uri.__name__.__eq__",
       ["as_uri"],
       true,
       "pathlib.PurePath.as_uri.__name__.__eq__('as_uri') == True — PurePath.as_uri is a Python function returning the path as a file URI; its __name__ is 'as_uri'; str.__eq__('as_uri') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.PurePath method __qualname__ identity
#
# All PurePath methods are defined directly on PurePath, so their __qualname__
# values carry the 'PurePath.' prefix.
# ---------------------------------------------------------------------------

table pathlib_extra258.purepath_method_qualnames:
  description: "pathlib.PurePath method __qualname__ identity — all use 'PurePath.' prefix; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: plxppmq258

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_qualname,
       "PurePath.__truediv__.__qualname__.__eq__",
       ["PurePath.__truediv__"],
       true,
       "pathlib.PurePath.__truediv__.__qualname__.__eq__('PurePath.__truediv__') == True — __truediv__ is defined directly on PurePath; its __qualname__ is 'PurePath.__truediv__'; str.__eq__('PurePath.__truediv__') returns True; new to extra258"]
    - [joinpath_qualname,
       "PurePath.joinpath.__qualname__.__eq__",
       ["PurePath.joinpath"],
       true,
       "pathlib.PurePath.joinpath.__qualname__.__eq__('PurePath.joinpath') == True — joinpath is defined directly on PurePath; its __qualname__ is 'PurePath.joinpath'; str.__eq__('PurePath.joinpath') returns True; new to extra258"]
    - [relative_to_qualname,
       "PurePath.relative_to.__qualname__.__eq__",
       ["PurePath.relative_to"],
       true,
       "pathlib.PurePath.relative_to.__qualname__.__eq__('PurePath.relative_to') == True — relative_to is defined directly on PurePath; its __qualname__ is 'PurePath.relative_to'; str.__eq__('PurePath.relative_to') returns True; new to extra258"]
    - [is_relative_to_qualname,
       "PurePath.is_relative_to.__qualname__.__eq__",
       ["PurePath.is_relative_to"],
       true,
       "pathlib.PurePath.is_relative_to.__qualname__.__eq__('PurePath.is_relative_to') == True — is_relative_to is defined directly on PurePath; its __qualname__ is 'PurePath.is_relative_to'; str.__eq__('PurePath.is_relative_to') returns True; new to extra258"]
    - [with_name_qualname,
       "PurePath.with_name.__qualname__.__eq__",
       ["PurePath.with_name"],
       true,
       "pathlib.PurePath.with_name.__qualname__.__eq__('PurePath.with_name') == True — with_name is defined directly on PurePath; its __qualname__ is 'PurePath.with_name'; str.__eq__('PurePath.with_name') returns True; new to extra258"]
    - [with_suffix_qualname,
       "PurePath.with_suffix.__qualname__.__eq__",
       ["PurePath.with_suffix"],
       true,
       "pathlib.PurePath.with_suffix.__qualname__.__eq__('PurePath.with_suffix') == True — with_suffix is defined directly on PurePath; its __qualname__ is 'PurePath.with_suffix'; str.__eq__('PurePath.with_suffix') returns True; new to extra258"]
    - [with_stem_qualname,
       "PurePath.with_stem.__qualname__.__eq__",
       ["PurePath.with_stem"],
       true,
       "pathlib.PurePath.with_stem.__qualname__.__eq__('PurePath.with_stem') == True — with_stem is defined directly on PurePath; its __qualname__ is 'PurePath.with_stem'; str.__eq__('PurePath.with_stem') returns True; new to extra258"]
    - [as_posix_qualname,
       "PurePath.as_posix.__qualname__.__eq__",
       ["PurePath.as_posix"],
       true,
       "pathlib.PurePath.as_posix.__qualname__.__eq__('PurePath.as_posix') == True — as_posix is defined directly on PurePath; its __qualname__ is 'PurePath.as_posix'; str.__eq__('PurePath.as_posix') returns True; new to extra258"]
    - [as_uri_qualname,
       "PurePath.as_uri.__qualname__.__eq__",
       ["PurePath.as_uri"],
       true,
       "pathlib.PurePath.as_uri.__qualname__.__eq__('PurePath.as_uri') == True — as_uri is defined directly on PurePath; its __qualname__ is 'PurePath.as_uri'; str.__eq__('PurePath.as_uri') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePath method __class__.__name__ — all are 'function'
#
# Unlike C-extension classes, PurePath methods are pure Python functions
# defined in Lib/pathlib/. Their __class__.__name__ is 'function', not
# 'method_descriptor'.
# ---------------------------------------------------------------------------

table pathlib_extra258.purepath_method_class_names:
  description: "pathlib.PurePath method __class__.__name__ — all are 'function' (pure Python); new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: plxppmcn258

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_class,
       "PurePath.__truediv__.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.PurePath.__truediv__.__class__.__name__.__eq__('function') == True — PurePath.__truediv__ is a pure Python function, not a C-level method_descriptor; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra258"]
    - [joinpath_class,
       "PurePath.joinpath.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.PurePath.joinpath.__class__.__name__.__eq__('function') == True — PurePath.joinpath is a pure Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra258"]
    - [relative_to_class,
       "PurePath.relative_to.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.PurePath.relative_to.__class__.__name__.__eq__('function') == True — PurePath.relative_to is a pure Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra258"]
    - [with_name_class,
       "PurePath.with_name.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.PurePath.with_name.__class__.__name__.__eq__('function') == True — PurePath.with_name is a pure Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra258"]
    - [as_posix_class,
       "PurePath.as_posix.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.PurePath.as_posix.__class__.__name__.__eq__('function') == True — PurePath.as_posix is a pure Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra258"]
    - [as_uri_class,
       "PurePath.as_uri.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.PurePath.as_uri.__class__.__name__.__eq__('function') == True — PurePath.as_uri is a pure Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra258
# ---------------------------------------------------------------------------

invariant pathlib_extra258.purepath_truediv_name:
  description: "pathlib.PurePath.__truediv__.__name__ == '__truediv__' — __truediv__ implements the / operator for path joining; new to extra258"
  kind: python_call_eq
  function: PurePath.__truediv__.__name__.__eq__
  args: ["__truediv__"]
  expected: true

invariant pathlib_extra258.purepath_joinpath_name:
  description: "pathlib.PurePath.joinpath.__name__ == 'joinpath' — joinpath combines a path with one or more arguments; new to extra258"
  kind: python_call_eq
  function: PurePath.joinpath.__name__.__eq__
  args: ["joinpath"]
  expected: true

invariant pathlib_extra258.purepath_joinpath_qualname:
  description: "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath' — joinpath is defined directly on PurePath; new to extra258"
  kind: python_call_eq
  function: PurePath.joinpath.__qualname__.__eq__
  args: ["PurePath.joinpath"]
  expected: true

invariant pathlib_extra258.purepath_joinpath_is_function:
  description: "pathlib.PurePath.joinpath.__class__.__name__ == 'function' — PurePath methods are pure Python, not C-level method_descriptors; new to extra258"
  kind: python_call_eq
  function: PurePath.joinpath.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra258.purepath_with_stem_name:
  description: "pathlib.PurePath.with_stem.__name__ == 'with_stem' — with_stem returns a new path with the stem replaced (added in Python 3.9); new to extra258"
  kind: python_call_eq
  function: PurePath.with_stem.__name__.__eq__
  args: ["with_stem"]
  expected: true

invariant pathlib_extra258.purepath_as_uri_name:
  description: "pathlib.PurePath.as_uri.__name__ == 'as_uri' — as_uri returns the path as a file:// URI; new to extra258"
  kind: python_call_eq
  function: PurePath.as_uri.__name__.__eq__
  args: ["as_uri"]
  expected: true

invariant pathlib_extra258.purepath_truediv_qualname:
  description: "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' — __truediv__ is defined directly on PurePath; new to extra258"
  kind: python_call_eq
  function: PurePath.__truediv__.__qualname__.__eq__
  args: ["PurePath.__truediv__"]
  expected: true
