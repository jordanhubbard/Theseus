spec: ndjson
version: ">=2.0.0"
backend: node(ndjson)

docs: https://github.com/maxogden/ndjson#readme

provenance:
  derived_from:
    - "ndjson README — https://github.com/maxogden/ndjson#readme"
    - "ndjson.org spec (newline-delimited JSON)"
    - "Test vectors verified with ndjson via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "ndjson source"
  notes:
    - "Streaming newline-delimited JSON — parse() converts a byte stream into a Transform stream of JS objects, stringify() does the reverse."
    - "Install: npm install ndjson"
    - "v2 CJS; named exports parse / stringify."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Stream emits 'error' events on malformed JSON lines."
  stderr: "null"
  stickiness: "Streams maintain internal buffers."
  codes: {}

invariant ndjson.has_parse:
  description: "parse is a function (Transform-stream factory)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "parse.constructor.name"}
  expected: "Function"

invariant ndjson.has_stringify:
  description: "stringify is a function (Transform-stream factory)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "stringify.constructor.name"}
  expected: "Function"

invariant ndjson.parse_returns_Transform:
  description: "parse() returns a Transform stream"
  category: stream
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Transform"

invariant ndjson.stringify_returns_Transform:
  description: "stringify() returns a Transform stream"
  category: stream
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Transform"

invariant ndjson.parse_stream_is_readable:
  description: "parse() stream has readable=true"
  category: stream
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: []
  chain:
    - {get: readable}
  expected: true

invariant ndjson.parse_stream_is_writable:
  description: "parse() stream has writable=true"
  category: stream
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: []
  chain:
    - {get: writable}
  expected: true

invariant ndjson.stringify_stream_is_readable:
  description: "stringify() stream has readable=true"
  category: stream
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: []
  chain:
    - {get: readable}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:40:52Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
