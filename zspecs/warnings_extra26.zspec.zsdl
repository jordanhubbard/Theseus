spec: warnings_extra26
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "warnings_extra25.zspec.zsdl — covers __mro__.__len__() for WarningMessage (2), catch_warnings (2), UserWarning (5), DeprecationWarning (5); __bases__[0].__name__.__len__() for WarningMessage/DeprecationWarning/UserWarning; WarningMessage.__init__/__qualname__.__len__()==23; WarningMessage.__str__/__qualname__.__len__()==22; catch_warnings.__init__/__qualname__.__len__()==23."
    - "warnings_extra24.zspec.zsdl — covers warn/warn_explicit/simplefilter/filterwarnings/resetwarnings __module__.__len__() and __name__.__len__(), catch_warnings method __qualname__.__len__() (__init__=23, __enter__=24, __exit__=23, __repr__=23)."
  notes:
    - "This spec extends warnings_extra25.zspec.zsdl."
    - "Prior specs covered: WarningMessage/catch_warnings/UserWarning/DeprecationWarning __mro__/__bases__[0].__name__, WarningMessage/__str__/__init__/__qualname__.__len__(), catch_warnings method __qualname__.__len__(), module-level function __name__/__module__ lengths."
    - "This spec covers NEW angles: warnings.__all__.__len__()==9; warnings.__all__.__class__.__name__=='list' (len 4); warnings.filters.__class__.__name__=='list' (len 4); warnings.defaultaction=='default' (__len__()==7, __class__.__name__=='str', len 3); warnings.onceregistry.__class__.__name__=='dict' (len 4); WarningMessage/__dict__.__class__.__name__=='mappingproxy' (len 12) and same for catch_warnings; module-level function __qualname__.__len__() for warn (4)/filterwarnings (14)/simplefilter (12)."
    - "warnings.__all__.__len__() == 9 — 9 public names exported. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.__all__.__class__.__name__ == 'list' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.filters.__class__.__name__ == 'list' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.defaultaction == 'default' (__len__()==7). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.defaultaction.__class__.__name__ == 'str' (len 3). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.onceregistry.__class__.__name__ == 'dict' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.WarningMessage.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Same for catch_warnings. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.warn.__qualname__ == 'warn' (len 4). warnings.filterwarnings.__qualname__ == 'filterwarnings' (len 14). warnings.simplefilter.__qualname__ == 'simplefilter' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings.__all__.__len__() and __all__.__class__.__name__.__len__()
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__ for
# the warnings module. warnings.__all__ exports 9 public names and is a list.
# ---------------------------------------------------------------------------

invariant warnings_extra26.all.len:
  description: "warnings.__all__.__len__() == 9 — 9 public names exported"
  category: module_membership
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 9

invariant warnings_extra26.all.class.name.len:
  description: "warnings.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_membership
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Module-level constants: filters, defaultaction, onceregistry
#
# No prior spec checks class names of module-level state variables.
# filters is a list; defaultaction is the str 'default' (len 7);
# onceregistry is a dict.
# ---------------------------------------------------------------------------

invariant warnings_extra26.defaultaction.len:
  description: "warnings.defaultaction.__len__() == 7 — value is 'default'"
  category: module_constants
  kind: python_call_eq
  function: defaultaction.__len__
  args: []
  expected: 7

invariant warnings_extra26.defaultaction.class.name.len:
  description: "warnings.defaultaction.__class__.__name__.__len__() == 3 — defaultaction is a 'str'"
  category: module_constants
  kind: python_call_eq
  function: defaultaction.__class__.__name__.__len__
  args: []
  expected: 3

invariant warnings_extra26.filters.class.name.len:
  description: "warnings.filters.__class__.__name__.__len__() == 4 — filters is a 'list'"
  category: module_constants
  kind: python_call_eq
  function: filters.__class__.__name__.__len__
  args: []
  expected: 4

invariant warnings_extra26.onceregistry.class.name.len:
  description: "warnings.onceregistry.__class__.__name__.__len__() == 4 — onceregistry is a 'dict'"
  category: module_constants
  kind: python_call_eq
  function: onceregistry.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() for WarningMessage and
# catch_warnings
#
# No prior spec checks __dict__.__class__.__name__.__len__() for any warnings
# class. Both WarningMessage and catch_warnings expose their namespace via a
# mappingproxy (len 12).
# ---------------------------------------------------------------------------

invariant warnings_extra26.WarningMessage.dict.class.name.len:
  description: "warnings.WarningMessage.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: module_constants
  kind: python_call_eq
  function: WarningMessage.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant warnings_extra26.catch_warnings.dict.class.name.len:
  description: "warnings.catch_warnings.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: module_constants
  kind: python_call_eq
  function: catch_warnings.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: warnings.__all__ membership and module-level constant class names
#
# Groups __all__ membership checks and class names of state variables filters,
# defaultaction, onceregistry. No prior spec groups these together.
# ---------------------------------------------------------------------------

table warnings_extra26.all_and_module_constants:
  description: "warnings.__all__.__len__() (9), __all__.__class__.__name__.__len__() (4), and module constant class name lengths — filters/list (4), defaultaction/str (3), onceregistry/dict (4)"
  kind: python_call_eq
  category: module_membership

  columns: [id, function, args, expected, description]
  rows:
    - [all_len,
       __all__.__len__,
       [],
       9,
       "len(warnings.__all__) == 9"]
    - [all_class_name_len,
       __all__.__class__.__name__.__len__,
       [],
       4,
       "len('list') == 4 — __all__.__class__.__name__"]
    - [filters_class_name_len,
       filters.__class__.__name__.__len__,
       [],
       4,
       "len('list') == 4 — filters.__class__.__name__"]
    - [defaultaction_class_name_len,
       defaultaction.__class__.__name__.__len__,
       [],
       3,
       "len('str') == 3 — defaultaction.__class__.__name__"]
    - [defaultaction_len,
       defaultaction.__len__,
       [],
       7,
       "len('default') == 7 — defaultaction value length"]
    - [onceregistry_class_name_len,
       onceregistry.__class__.__name__.__len__,
       [],
       4,
       "len('dict') == 4 — onceregistry.__class__.__name__"]

# ---------------------------------------------------------------------------
# Table: class __dict__ type and function __qualname__.__len__() values
#
# Groups class dict type name lengths and module-level function qualname
# lengths. No prior spec covers warn/__qualname__.__len__() or
# filterwarnings/__qualname__.__len__() or simplefilter/__qualname__.__len__().
# warn=4, filterwarnings=14, simplefilter=12.
# WarningMessage and catch_warnings both have mappingproxy dicts (len 12).
# ---------------------------------------------------------------------------

table warnings_extra26.dict_class_and_function_qualnames:
  description: "warnings class __dict__.__class__.__name__.__len__() (WarningMessage/catch_warnings both 12) and function __qualname__.__len__() (warn=4, filterwarnings=14, simplefilter=12)"
  kind: python_call_eq
  category: module_constants

  columns: [id, function, args, expected, description]
  rows:
    - [WarningMessage_dict_class_name_len,
       WarningMessage.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — WarningMessage.__dict__.__class__.__name__"]
    - [catch_warnings_dict_class_name_len,
       catch_warnings.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — catch_warnings.__dict__.__class__.__name__"]
    - [warn_qualname_len,
       warn.__qualname__.__len__,
       [],
       4,
       "len('warn') == 4"]
    - [filterwarnings_qualname_len,
       filterwarnings.__qualname__.__len__,
       [],
       14,
       "len('filterwarnings') == 14"]
    - [simplefilter_qualname_len,
       simplefilter.__qualname__.__len__,
       [],
       12,
       "len('simplefilter') == 12"]
