spec: is_local_path
version: ">=0.1.6"
backend: node(is-local-path)

docs: https://www.npmjs.com/package/is-local-path

provenance:
  derived_from:
    - "is-local-path README — https://www.npmjs.com/package/is-local-path"
    - "Test vectors verified with is-local-path via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-local-path source"
  notes:
    - "is-local-path is an npm package. Install: npm install is-local-path"
    - "Returns true if the path is local (relative or absolute), not a URL."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_local_path.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: islp

  columns: [id, args, expected]
  rows:
    - [url,      ["http://example.com"],  false]
    - [relative, ["./foo/bar"],           true]
    - [absolute, ["/absolute/path"],      true]
    - [dotdot,   ["../parent"],           true]

