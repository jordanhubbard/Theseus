spec: sanitize_filename
version: ">=1.0.0"
backend: node(sanitize-filename)

docs: https://github.com/parshap/node-sanitize-filename#readme

provenance:
  derived_from:
    - "sanitize-filename README — https://github.com/parshap/node-sanitize-filename#readme"
    - "Microsoft Win32 reserved-name list (CON, PRN, AUX, NUL, COM1-9, LPT1-9)"
    - "Test vectors verified with sanitize-filename via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "sanitize-filename source"
  notes:
    - "Strips characters that are invalid in filenames on common filesystems."
    - "Install: npm install sanitize-filename"
    - "v1 CJS; the module export IS the sanitize function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant sanitize_filename.removes_path_separator:
  description: "Forward slash is stripped"
  category: stripping
  kind: node_chain_eq
  entry: module
  entry_args: ["hello/world.txt"]
  chain: []
  expected: "helloworld.txt"

invariant sanitize_filename.removes_pipes_and_questions:
  description: "|, ?, <, > are all stripped"
  category: stripping
  kind: node_chain_eq
  entry: module
  entry_args: ["foo|bar?baz<test>.txt"]
  chain: []
  expected: "foobarbaztest.txt"

invariant sanitize_filename.windows_reserved_blanked:
  description: "Windows reserved name CON.txt becomes empty"
  category: reserved
  kind: node_chain_eq
  entry: module
  entry_args: ["CON.txt"]
  chain: []
  expected: ""

invariant sanitize_filename.empty_input_empty_output:
  description: "Empty input passes through as empty"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain: []
  expected: ""

invariant sanitize_filename.valid_passthrough:
  description: "A clean filename is unchanged"
  category: passthrough
  kind: node_chain_eq
  entry: module
  entry_args: ["valid-file_name.txt"]
  chain: []
  expected: "valid-file_name.txt"

invariant sanitize_filename.replacement_option:
  description: "{replacement: '_'} replaces stripped characters instead of dropping them"
  category: options
  kind: node_chain_eq
  entry: module
  entry_args: ["foo*bar", {replacement: "_"}]
  chain: []
  expected: "foo_bar"

invariant sanitize_filename.strips_colon_and_quote:
  description: "Colon and double-quote are stripped (Windows + classic Mac filesystems disallow them)"
  category: stripping
  kind: node_chain_eq
  entry: module
  entry_args: ["foo:bar\"baz.txt"]
  chain: []
  expected: "foobarbaz.txt"

invariant sanitize_filename.strips_backslash:
  description: "Backslash (Windows path separator) is stripped"
  category: stripping
  kind: node_chain_eq
  entry: module
  entry_args: ["foo\\bar.txt"]
  chain: []
  expected: "foobar.txt"
