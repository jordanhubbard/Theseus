spec: threading_extra89
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra88

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra88.zspec.zsdl."
    - "This spec covers: threading class __name__ and __module__ string equality for Thread, Timer, Semaphore, BoundedSemaphore, Condition, Event, Barrier (Wave 250)."
    - "threading.Thread.__name__ == 'Thread' — pure-Python class in Lib/threading.py; __name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__name__ == 'Timer' — pure-Python subclass of Thread; __name__ is 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__ == 'Semaphore' — pure-Python class; __name__ is 'Semaphore'. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — pure-Python subclass of Semaphore; __name__ is 'BoundedSemaphore'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition' — pure-Python class; __name__ is 'Condition'. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event' — pure-Python class; __name__ is 'Event'. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' — pure-Python class; __name__ is 'Barrier'. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.__qualname__ == 'Thread' — module-level class; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "threading.Timer.__qualname__ == 'Timer' — module-level class; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore' — module-level class; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread/Timer __name__ and __module__ strings
#
# Wave 250 theme: threading class __name__ and __module__ string equality — Thread/Timer.
#
# threading.Thread.__name__.__eq__('Thread')     == True
# threading.Thread.__module__.__eq__('threading') == True
# threading.Timer.__name__.__eq__('Timer')       == True
# threading.Timer.__module__.__eq__('threading') == True
#
# Prior spec extra88 checked __bases__[0].__name__ and __mro__.__len__(). This spec (extra89) checks __name__ and __module__. New to extra89.
# ---------------------------------------------------------------------------

table threading_extra89.thread_timer_name_module:
  description: "Thread/Timer __name__==Thread/Timer and __module__==threading; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingnames89

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_name_eq_Thread,
       Thread.__name__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is the base threading class defined in Lib/threading.py; __name__ is the unqualified class name 'Thread' (6 chars); str.__eq__('Thread') returns True; prior spec extra88 checked Thread.__bases__[0].__name__ and Thread.__mro__.__len__(); this spec (extra89) checks __name__; new to extra89"]
    - [Thread_module_eq_threading,
       Thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; its __module__ attribute is the string 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Thread.__module__ via threadingnames89; new to extra89"]
    - [Timer_name_eq_Timer,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a pure-Python subclass of Thread defined in Lib/threading.py that runs a function after a specified delay; __name__ is 'Timer' (5 chars); str.__eq__('Timer') returns True; prior spec extra88 checked Timer.__bases__[0].__name__ and Timer.__mro__.__len__(); this spec (extra89) checks __name__; new to extra89"]
    - [Timer_module_eq_threading,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; its __module__ attribute is the string 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Timer.__module__ via threadingnames89; new to extra89"]

# ---------------------------------------------------------------------------
# Semaphore/BoundedSemaphore __name__ and __module__ strings
#
# Wave 250 theme: threading class __name__ and __module__ string equality — Semaphore/BoundedSemaphore.
#
# threading.Semaphore.__name__.__eq__('Semaphore')             == True
# threading.Semaphore.__module__.__eq__('threading')           == True
# threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True
# threading.BoundedSemaphore.__module__.__eq__('threading')    == True
#
# No prior threading spec checks __name__ or __module__ for these classes via threadingnames89. New to extra89.
# ---------------------------------------------------------------------------

table threading_extra89.semaphore_boundedsemaphore_name_module:
  description: "Semaphore/BoundedSemaphore __name__ and __module__==threading; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingnames89

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_name_eq_Semaphore,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a pure-Python synchronization class defined in Lib/threading.py; __name__ is 'Semaphore' (9 chars); str.__eq__('Semaphore') returns True; prior spec extra88 checked Semaphore.__bases__[0].__name__ and Semaphore.__mro__.__len__(); this spec (extra89) checks __name__; new to extra89"]
    - [Semaphore_module_eq_threading,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; its __module__ attribute is the string 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Semaphore.__module__ via threadingnames89; new to extra89"]
    - [BoundedSemaphore_name_eq_BoundedSemaphore,
       BoundedSemaphore.__name__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — BoundedSemaphore is a pure-Python subclass of Semaphore defined in Lib/threading.py that adds an upper bound to the semaphore counter; __name__ is 'BoundedSemaphore' (16 chars); str.__eq__('BoundedSemaphore') returns True; prior spec extra88 checked BoundedSemaphore.__bases__[0].__name__; this spec (extra89) checks __name__; new to extra89"]
    - [BoundedSemaphore_module_eq_threading,
       BoundedSemaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in Lib/threading.py; its __module__ attribute is the string 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks BoundedSemaphore.__module__ via threadingnames89; new to extra89"]

# ---------------------------------------------------------------------------
# Condition/Event/Barrier __name__ and __module__ strings
#
# Wave 250 theme: threading class __name__ and __module__ string equality — Condition/Event/Barrier.
#
# threading.Condition.__name__.__eq__('Condition')   == True
# threading.Condition.__module__.__eq__('threading') == True
# threading.Event.__name__.__eq__('Event')           == True
# threading.Barrier.__name__.__eq__('Barrier')       == True
#
# No prior threading spec checks __name__ or __module__ for these classes via threadingnames89. New to extra89.
# ---------------------------------------------------------------------------

table threading_extra89.condition_event_barrier_name_module:
  description: "Condition/Event/Barrier __name__ and Condition __module__==threading; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingnames89

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_name_eq_Condition,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a pure-Python synchronization class defined in Lib/threading.py used for inter-thread synchronization; __name__ is 'Condition' (9 chars); str.__eq__('Condition') returns True; prior spec extra88 checked Condition.__bases__[0].__name__ and Condition.__mro__.__len__(); this spec (extra89) checks __name__; new to extra89"]
    - [Condition_module_eq_threading,
       Condition.__module__.__eq__,
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; its __module__ attribute is the string 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Condition.__module__ via threadingnames89; new to extra89"]
    - [Event_name_eq_Event,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a pure-Python synchronization class defined in Lib/threading.py used for signaling between threads; __name__ is 'Event' (5 chars); str.__eq__('Event') returns True; prior spec extra88 checked Event.__bases__[0].__name__; this spec (extra89) checks __name__; new to extra89"]
    - [Barrier_name_eq_Barrier,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a pure-Python synchronization class defined in Lib/threading.py used to block threads until a fixed number have reached the barrier; __name__ is 'Barrier' (7 chars); str.__eq__('Barrier') returns True; prior spec extra88 checked Barrier.__bases__[0].__name__ and Barrier.__mro__.__len__(); this spec (extra89) checks __name__; new to extra89"]

# ---------------------------------------------------------------------------
# __qualname__ cross-checks: Thread, Timer, Semaphore __qualname__ strings
# For module-level classes, __qualname__ == __name__.
#
# Wave 250 theme: threading class __qualname__ string equality cross-checks.
#
# threading.Thread.__qualname__.__eq__('Thread')       == True
# threading.Timer.__qualname__.__eq__('Timer')         == True
# threading.Semaphore.__qualname__.__eq__('Semaphore') == True
# threading.Event.__module__.__eq__('threading')       == True
#
# No prior threading spec checks __qualname__ for these classes via threadingnames89. New to extra89.
# ---------------------------------------------------------------------------

table threading_extra89.qualname_cross_checks:
  description: "Thread/Timer/Semaphore __qualname__ strings + Event __module__; module-level classes have __qualname__==__name__; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingnames89

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_qualname_eq_Thread,
       Thread.__qualname__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is a module-level class defined in Lib/threading.py; for a top-level class __qualname__ equals __name__; __qualname__ is 'Thread' (6 chars); str.__eq__('Thread') returns True; no prior threading spec checks Thread.__qualname__ via threadingnames89; new to extra89"]
    - [Timer_qualname_eq_Timer,
       Timer.__qualname__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is a module-level class defined in Lib/threading.py; for a top-level class __qualname__ equals __name__; __qualname__ is 'Timer' (5 chars); str.__eq__('Timer') returns True; no prior threading spec checks Timer.__qualname__ via threadingnames89; new to extra89"]
    - [Semaphore_qualname_eq_Semaphore,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is a module-level class defined in Lib/threading.py; for a top-level class __qualname__ equals __name__; __qualname__ is 'Semaphore' (9 chars); str.__eq__('Semaphore') returns True; no prior threading spec checks Semaphore.__qualname__ via threadingnames89; new to extra89"]
    - [Event_module_eq_threading,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; its __module__ attribute is the string 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Event.__module__ via threadingnames89; new to extra89"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra89
# ---------------------------------------------------------------------------

invariant threading_extra89.Thread_name_eq_Thread:
  description: "threading.Thread.__name__.__eq__('Thread') == True — Thread class __name__ is 'Thread'; wave 250; new to extra89"
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra89.Thread_module_eq_threading:
  description: "threading.Thread.__module__.__eq__('threading') == True — Thread __module__ is 'threading'; wave 250; new to extra89"
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra89.BoundedSemaphore_name_eq_BoundedSemaphore:
  description: "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — BoundedSemaphore class __name__ is 'BoundedSemaphore'; wave 250; new to extra89"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant threading_extra89.Barrier_name_eq_Barrier:
  description: "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier class __name__ is 'Barrier'; wave 250; new to extra89"
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra89.Timer_qualname_eq_Timer:
  description: "threading.Timer.__qualname__.__eq__('Timer') == True — Timer module-level class __qualname__ equals __name__ == 'Timer'; wave 250; new to extra89"
  kind: python_call_eq
  function: Timer.__qualname__.__eq__
  args: ["Timer"]
  expected: true
