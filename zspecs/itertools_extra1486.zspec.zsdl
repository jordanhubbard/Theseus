error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain and count — __enter__ and __exit__ absence checks
#
# Wave 546 theme: itertools.chain and itertools.count — chaining iterables
# and producing unbounded arithmetic sequences.
#
# itertools.chain.__dict__.__contains__("__enter__") == False
# itertools.chain.__dict__.__contains__("__exit__") == False
# itertools.count.__dict__.__contains__("__enter__") == False
# itertools.count.__dict__.__contains__("__exit__") == False
#
# chain and count are C-implemented iterator types. They are lazy iterators
# that yield values on demand. Neither implements the context manager protocol.
# New to extra1486.
# ---------------------------------------------------------------------------

table itertools_extra1486.chain_count_context_manager_absence:
  description: "itertools.chain and count have no __enter__ or __exit__ in __dict__; both are lazy iterators, not context managers; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1486cc

  columns: [id, function, args, expected, description]
  rows:
    - [it1486cc001,
       "chain.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.chain.__dict__.__contains__('__enter__') == False — chain is a C-implemented iterator that lazily chains multiple iterables end-to-end; it does not implement the context manager protocol; __enter__ is not in chain.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cc002,
       "chain.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.chain.__dict__.__contains__('__exit__') == False — chain cannot be used as a context manager; __exit__ is not defined in chain.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cc003,
       "chain.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.chain.__dict__.__contains__('__iter__') == True — chain IS an iterator and defines __iter__ in its __dict__; the iterator protocol is its primary interface, not the context manager protocol; verified with Python 3.12; new to extra1486"]
    - [it1486cc004,
       "count.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.count.__dict__.__contains__('__enter__') == False — count is a C-implemented iterator that produces an unbounded arithmetic sequence; it does not implement the context manager protocol; __enter__ is not in count.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cc005,
       "count.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.count.__dict__.__contains__('__exit__') == False — count cannot be used as a context manager; __exit__ is not defined in count.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cc006,
       "count.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.count.__dict__.__contains__('__iter__') == True — count IS an iterator and defines __iter__ in its __dict__; the iterator protocol is its primary interface, not the context manager protocol; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 2: itertools.cycle, repeat, accumulate — absence checks
#
# Wave 546 theme: itertools.cycle, repeat, accumulate — cycling, repeating,
# and accumulating iterators.
#
# itertools.cycle.__dict__.__contains__("__enter__") == False
# itertools.cycle.__dict__.__contains__("__exit__") == False
# itertools.repeat.__dict__.__contains__("__enter__") == False
# itertools.repeat.__dict__.__contains__("__exit__") == False
# itertools.accumulate.__dict__.__contains__("__enter__") == False
# itertools.accumulate.__dict__.__contains__("__exit__") == False
#
# All three are C-implemented lazy iterators. None implements the context
# manager protocol. New to extra1486.
# ---------------------------------------------------------------------------

table itertools_extra1486.cycle_repeat_accumulate_context_manager_absence:
  description: "itertools.cycle, repeat, and accumulate have no __enter__ or __exit__ in __dict__; all are lazy iterators, not context managers; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1486cr

  columns: [id, function, args, expected, description]
  rows:
    - [it1486cr001,
       "cycle.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.cycle.__dict__.__contains__('__enter__') == False — cycle is a C-implemented iterator that repeatedly cycles through an iterable indefinitely; it does not implement the context manager protocol; __enter__ is not in cycle.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cr002,
       "cycle.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.cycle.__dict__.__contains__('__exit__') == False — cycle cannot be used as a context manager; __exit__ is not defined in cycle.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cr003,
       "repeat.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.repeat.__dict__.__contains__('__enter__') == False — repeat is a C-implemented iterator that yields the same object a specified number of times (or infinitely); it does not implement the context manager protocol; __enter__ is not in repeat.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cr004,
       "repeat.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.repeat.__dict__.__contains__('__exit__') == False — repeat cannot be used as a context manager; __exit__ is not defined in repeat.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cr005,
       "accumulate.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__enter__') == False — accumulate is a C-implemented iterator that yields accumulated sums or other binary function results; it does not implement the context manager protocol; __enter__ is not in accumulate.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cr006,
       "accumulate.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__exit__') == False — accumulate cannot be used as a context manager; __exit__ is not defined in accumulate.__dict__; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations, product, islice — absence checks
#
# Wave 546 theme: itertools.combinations, product, islice — combinatoric
# and slicing iterators.
#
# itertools.combinations.__dict__.__contains__("__enter__") == False
# itertools.combinations.__dict__.__contains__("__exit__") == False
# itertools.product.__dict__.__contains__("__enter__") == False
# itertools.product.__dict__.__contains__("__exit__") == False
# itertools.islice.__dict__.__contains__("__enter__") == False
# itertools.islice.__dict__.__contains__("__exit__") == False
#
# All three are C-implemented lazy iterators. None implements the context
# manager protocol. New to extra1486.
# ---------------------------------------------------------------------------

table itertools_extra1486.combinations_product_islice_context_manager_absence:
  description: "itertools.combinations, product, and islice have no __enter__ or __exit__ in __dict__; all are lazy iterators, not context managers; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1486cp

  columns: [id, function, args, expected, description]
  rows:
    - [it1486cp001,
       "combinations.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.combinations.__dict__.__contains__('__enter__') == False — combinations is a C-implemented iterator that yields r-length tuples of elements from the input iterable in sorted order; it does not implement the context manager protocol; __enter__ is not in combinations.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cp002,
       "combinations.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.combinations.__dict__.__contains__('__exit__') == False — combinations cannot be used as a context manager; __exit__ is not defined in combinations.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cp003,
       "product.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.product.__dict__.__contains__('__enter__') == False — product is a C-implemented iterator that yields the Cartesian product of input iterables; it does not implement the context manager protocol; __enter__ is not in product.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cp004,
       "product.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.product.__dict__.__contains__('__exit__') == False — product cannot be used as a context manager; __exit__ is not defined in product.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cp005,
       "islice.__dict__.__contains__",
       ["__enter__"],
       false,
       "itertools.islice.__dict__.__contains__('__enter__') == False — islice is a C-implemented iterator that returns selected elements from an iterator using start/stop/step semantics without materializing the slice; it does not implement the context manager protocol; __enter__ is not in islice.__dict__; verified with Python 3.12; new to extra1486"]
    - [it1486cp006,
       "islice.__dict__.__contains__",
       ["__exit__"],
       false,
       "itertools.islice.__dict__.__contains__('__exit__') == False — islice cannot be used as a context manager; __exit__ is not defined in islice.__dict__; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1486
# ---------------------------------------------------------------------------

invariant itertools_extra1486.chain_no_enter:
  description: "itertools.chain.__dict__ does not contain '__enter__' — chain is a lazy iterator, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant itertools_extra1486.chain_no_exit:
  description: "itertools.chain.__dict__ does not contain '__exit__' — chain does not implement the context manager protocol; wave 546; new to extra1486"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__exit__"]
  expected: false

invariant itertools_extra1486.cycle_no_enter:
  description: "itertools.cycle.__dict__ does not contain '__enter__' — cycle is a lazy repeating iterator, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: cycle.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant itertools_extra1486.repeat_no_enter:
  description: "itertools.repeat.__dict__ does not contain '__enter__' — repeat is a lazy constant iterator, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: repeat.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant itertools_extra1486.product_no_enter:
  description: "itertools.product.__dict__ does not contain '__enter__' — product is a Cartesian-product iterator, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: product.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant itertools_extra1486.islice_no_enter:
  description: "itertools.islice.__dict__ does not contain '__enter__' — islice is a lazy slicing iterator, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: islice.__dict__.__contains__
  args: ["__enter__"]
  expected: false
