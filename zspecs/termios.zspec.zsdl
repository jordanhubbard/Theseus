spec: termios
version: ">=3.0"
backend: python_module(termios)

docs: https://docs.python.org/3/library/termios.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/termios.html — Python termios module documentation"
    - "POSIX.1-2017 — termios(3) terminal I/O interface specification"
    - "IEEE Std 1003.1 — TCSANOW=0, TCSADRAIN=1, TCSAFLUSH=2 (standardized across macOS and Linux)"
    - "Test vectors verified by running Python 3.14.3 termios module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/termios.c"
  notes:
    - "termios is POSIX-only; it is not available on Windows. All invariants apply to macOS and Linux."
    - "tcgetattr(fd) returns a list of 7 elements: [iflag, oflag, cflag, lflag, ispeed, ospeed, cc]."
    - "tcsetattr(fd, when, attrs) — 'when' must be TCSANOW, TCSADRAIN, or TCSAFLUSH."
    - "TCSANOW=0, TCSADRAIN=1, TCSAFLUSH=2 are standardized POSIX values uniform across macOS and Linux."
    - "ECHO, ICANON, NOFLSH are lflag bits; their exact integer values are platform-specific and not pinned here."
    - "ECHO enables character echoing. ICANON enables canonical (line-buffered) mode. NOFLSH disables flush after signal."
    - "tcsendbreak, tcdrain, tcflush, tcflow wrap the corresponding POSIX terminal control functions."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function names
# ---------------------------------------------------------------------------

invariant termios.function.tcgetattr_name:
  description: "termios.tcgetattr.__name__ == 'tcgetattr'"
  category: function_names
  kind: python_call_eq
  function: tcgetattr.__name__.__eq__
  args: ["tcgetattr"]
  expected: true

invariant termios.function.tcsetattr_name:
  description: "termios.tcsetattr.__name__ == 'tcsetattr'"
  category: function_names
  kind: python_call_eq
  function: tcsetattr.__name__.__eq__
  args: ["tcsetattr"]
  expected: true

invariant termios.function.tcsendbreak_name:
  description: "termios.tcsendbreak.__name__ == 'tcsendbreak'"
  category: function_names
  kind: python_call_eq
  function: tcsendbreak.__name__.__eq__
  args: ["tcsendbreak"]
  expected: true

invariant termios.function.tcdrain_name:
  description: "termios.tcdrain.__name__ == 'tcdrain'"
  category: function_names
  kind: python_call_eq
  function: tcdrain.__name__.__eq__
  args: ["tcdrain"]
  expected: true

invariant termios.function.tcflush_name:
  description: "termios.tcflush.__name__ == 'tcflush'"
  category: function_names
  kind: python_call_eq
  function: tcflush.__name__.__eq__
  args: ["tcflush"]
  expected: true

invariant termios.function.tcflow_name:
  description: "termios.tcflow.__name__ == 'tcflow'"
  category: function_names
  kind: python_call_eq
  function: tcflow.__name__.__eq__
  args: ["tcflow"]
  expected: true

# ---------------------------------------------------------------------------
# TCSANOW / TCSADRAIN / TCSAFLUSH — standardized POSIX values
# ---------------------------------------------------------------------------

invariant termios.constants.tcsanow:
  description: "termios.TCSANOW == 0 — change terminal attrs immediately (POSIX)"
  category: constants
  kind: python_call_eq
  function: TCSANOW.__eq__
  args: [0]
  expected: true

invariant termios.constants.tcsadrain:
  description: "termios.TCSADRAIN == 1 — change after output drains (POSIX)"
  category: constants
  kind: python_call_eq
  function: TCSADRAIN.__eq__
  args: [1]
  expected: true

invariant termios.constants.tcsaflush:
  description: "termios.TCSAFLUSH == 2 — change after output drains, discard input (POSIX)"
  category: constants
  kind: python_call_eq
  function: TCSAFLUSH.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# lflag bit constants — type checks only (values are platform-specific)
# ---------------------------------------------------------------------------

invariant termios.constants.echo_is_int:
  description: "termios.ECHO is an int — lflag bit enabling character echoing"
  category: constants
  kind: python_call_eq
  function: ECHO.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant termios.constants.icanon_is_int:
  description: "termios.ICANON is an int — lflag bit enabling canonical (line-buffered) mode"
  category: constants
  kind: python_call_eq
  function: ICANON.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant termios.constants.noflsh_is_int:
  description: "termios.NOFLSH is an int — lflag bit disabling flush after signal"
  category: constants
  kind: python_call_eq
  function: NOFLSH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ECHO is positive — sanity check that it is a non-zero bitmask
# ---------------------------------------------------------------------------

invariant termios.constants.echo_positive:
  description: "termios.ECHO > 0 — ECHO bitmask is a positive integer on all POSIX platforms"
  category: constants
  kind: python_call_eq
  function: ECHO.__gt__
  args: [0]
  expected: true
