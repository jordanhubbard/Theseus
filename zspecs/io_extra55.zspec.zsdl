spec: io_extra55
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra54.zspec.zsdl — covers io concrete class __class__.__qualname__.__eq__('type') for FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper; IOBase.__class__.__qualname__.__eq__('ABCMeta'); open.__class__.__qualname__.__eq__('builtin_function_or_method'); DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int')."
    - "io_extra53.zspec.zsdl — covers concrete io class __class__.__name__.__len__()==4; IOBase.__class__.__name__.__eq__('ABCMeta'); open.__name__/__qualname__.__len__()==4; open.__class__.__name__.__eq__('builtin_function_or_method')."
    - "io_extra50.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__len__()."
    - "io_extra49.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__eq__()."
    - "io_extra33.zspec.zsdl — covers open.__qualname__.__eq__('open')."
    - "io_extra3.zspec.zsdl — covers open.__name__.__eq__('open')."
  notes:
    - "This spec extends io_extra54.zspec.zsdl."
    - "Prior specs collectively covered: all concrete io class __qualname__ equality and lengths (io_extra49/io_extra50); concrete io class __class__.__name__/__qualname__ equality (io_extra4/io_extra53/io_extra54); IOBase.__class__.__name__/__qualname__ equality (io_extra53/io_extra54); open identity attributes (io_extra3/io_extra33/io_extra53/io_extra54); DEFAULT_BUFFER_SIZE.__class__.__qualname__ (io_extra54). NO prior io spec checks the __qualname__ attribute of any method attached to BytesIO or StringIO (i.e., BytesIO.read.__qualname__ etc). NO prior io spec checks the __len__ of those method __qualname__ strings. All nine __qualname__.__len__() anchors in this spec are novel."
    - "This spec covers: io.BytesIO.read.__qualname__.__len__()==12 (NOVEL — 'BytesIO.read' is 12 chars; no prior io spec checks BytesIO.read.__qualname__ or its length; novel); io.BytesIO.write.__qualname__.__len__()==13 (NOVEL — 'BytesIO.write' is 13 chars; novel); io.BytesIO.seek.__qualname__.__len__()==12 (NOVEL — 'BytesIO.seek' is 12 chars; novel); io.BytesIO.tell.__qualname__.__len__()==12 (NOVEL — 'BytesIO.tell' is 12 chars; novel); io.BytesIO.getvalue.__qualname__.__len__()==16 (NOVEL — 'BytesIO.getvalue' is 16 chars; novel); io.StringIO.read.__qualname__.__len__()==13 (NOVEL — 'StringIO.read' is 13 chars; novel); io.StringIO.write.__qualname__.__len__()==14 (NOVEL — 'StringIO.write' is 14 chars; novel); io.StringIO.seek.__qualname__.__len__()==13 (NOVEL — 'StringIO.seek' is 13 chars; novel); io.StringIO.getvalue.__qualname__.__len__()==17 (NOVEL — 'StringIO.getvalue' is 17 chars; novel)."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read'. BytesIO is a C-extension type in _io; its method read has __qualname__ 'BytesIO.read'. Length == 12. No prior io spec checks BytesIO.read.__qualname__ or its length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.write.__qualname__ == 'BytesIO.write'. Length == 13. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.seek.__qualname__ == 'BytesIO.seek'. Length == 12. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.tell.__qualname__ == 'BytesIO.tell'. Length == 12. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue'. Length == 16. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.read.__qualname__ == 'StringIO.read'. Length == 13. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.write.__qualname__ == 'StringIO.write'. Length == 14. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.seek.__qualname__ == 'StringIO.seek'. Length == 13. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue'. Length == 17. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ lengths
#
# BytesIO is a C-extension type in _io. Its methods carry __qualname__ strings
# of the form 'BytesIO.<methodname>'. The lengths are:
#
#   BytesIO.read.__qualname__     == 'BytesIO.read'     -> len 12
#   BytesIO.write.__qualname__    == 'BytesIO.write'    -> len 13
#   BytesIO.seek.__qualname__     == 'BytesIO.seek'     -> len 12
#   BytesIO.tell.__qualname__     == 'BytesIO.tell'     -> len 12
#   BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' -> len 16
#
# No prior io spec checks __qualname__ for any method of BytesIO or StringIO.
# All five length anchors are novel in the io_extra55 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra55.bytesio_method_qualname_lens:
  description: "io.BytesIO method __qualname__.__len__() for read/write/seek/tell/getvalue — qualname strings are 'BytesIO.<method>'; no prior io spec checks __qualname__ or its length for any BytesIO method; all five novel length anchors in io_extra55 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: iomethlen55

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_read_qualname_len,     "BytesIO.read.__qualname__.__len__",     [], 12]
    - [BytesIO_write_qualname_len,    "BytesIO.write.__qualname__.__len__",    [], 13]
    - [BytesIO_seek_qualname_len,     "BytesIO.seek.__qualname__.__len__",     [], 12]
    - [BytesIO_tell_qualname_len,     "BytesIO.tell.__qualname__.__len__",     [], 12]
    - [BytesIO_getvalue_qualname_len, "BytesIO.getvalue.__qualname__.__len__", [], 16]

# ---------------------------------------------------------------------------
# io.StringIO method __qualname__ lengths
#
# StringIO is a C-extension type in _io. Its methods carry __qualname__ strings
# of the form 'StringIO.<methodname>'. The lengths are:
#
#   StringIO.read.__qualname__     == 'StringIO.read'     -> len 13
#   StringIO.write.__qualname__    == 'StringIO.write'    -> len 14
#   StringIO.seek.__qualname__     == 'StringIO.seek'     -> len 13
#   StringIO.getvalue.__qualname__ == 'StringIO.getvalue' -> len 17
#
# No prior io spec checks __qualname__ or its length for any StringIO method.
# All four length anchors are novel in the io_extra55 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra55.stringio_method_qualname_lens:
  description: "io.StringIO method __qualname__.__len__() for read/write/seek/getvalue — qualname strings are 'StringIO.<method>'; no prior io spec checks __qualname__ or its length for any StringIO method; all four novel length anchors in io_extra55 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: iomethlen55s

  columns: [id, function, args, expected]
  rows:
    - [StringIO_read_qualname_len,     "StringIO.read.__qualname__.__len__",     [], 13]
    - [StringIO_write_qualname_len,    "StringIO.write.__qualname__.__len__",    [], 14]
    - [StringIO_seek_qualname_len,     "StringIO.seek.__qualname__.__len__",     [], 13]
    - [StringIO_getvalue_qualname_len, "StringIO.getvalue.__qualname__.__len__", [], 17]
