spec: genericpath_extra
version: ">=3.0"
backend: python_module(genericpath)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.path.html"
    - "CPython source: Lib/genericpath.py (PSF; name and module checks only)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/genericpath.py implementation internals"
  notes:
    - "This spec covers aspects not in genericpath.zspec.zsdl."
    - "exists.__module__ == 'genericpath' confirms the module attribution."
    - "isabs is present in genericpath on some platforms; confirmed importable on macOS/Darwin."
    - "samefile is present in genericpath; it raises OSError if either path is inaccessible."
    - "getctime is present in genericpath; semantics differ by OS (creation time on Windows, inode change time on POSIX)."
    - "All __name__ checks are identity invariants independent of OS behaviour."
    - "All expected values verified by running Python 3.12 genericpath module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks (supplementing genericpath.zspec.zsdl function_names table)
# ---------------------------------------------------------------------------

invariant genericpath_extra.functions.exists_name:
  description: "exists.__name__ == 'exists'"
  category: functions
  kind: python_call_eq
  function: exists.__name__.__eq__
  args: ["exists"]
  expected: true

invariant genericpath_extra.functions.exists_module:
  description: "exists.__module__ == 'genericpath'"
  category: functions
  kind: python_call_eq
  function: exists.__module__.__eq__
  args: ["genericpath"]
  expected: true

invariant genericpath_extra.functions.isfile_name:
  description: "isfile.__name__ == 'isfile'"
  category: functions
  kind: python_call_eq
  function: isfile.__name__.__eq__
  args: ["isfile"]
  expected: true

invariant genericpath_extra.functions.isdir_name:
  description: "isdir.__name__ == 'isdir'"
  category: functions
  kind: python_call_eq
  function: isdir.__name__.__eq__
  args: ["isdir"]
  expected: true

invariant genericpath_extra.functions.islink_name:
  description: "islink.__name__ == 'islink'"
