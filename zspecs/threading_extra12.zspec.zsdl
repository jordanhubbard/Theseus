spec: threading_extra12
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra11."
    - "threading_extra11 covers: Thread.start/run/join/is_alive __qualname__; Semaphore.acquire/release __qualname__; Condition.wait/notify __qualname__; Barrier.wait __qualname__; BoundedSemaphore MRO[1]/__name__ and MRO[2]/__name__; TIMEOUT_MAX value and __class__.__name__."
    - "threading_extra8 covers: __qualname__ table for Thread/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier/local; Lock.__qualname__; current_thread/main_thread/active_count __qualname__."
    - "threading_extra6 covers: Event().__class__.__name__ == 'Event'; Semaphore().__class__.__name__ == 'Semaphore'; Condition().__class__.__name__ == 'Condition'; active_count().__class__.__name__ == 'int'; active_count() >= 1; current_thread().__class__.__name__; main_thread().__class__.__name__."
    - "threading_extra11 covers Condition.notify.__qualname__. NOT yet covered: Condition.notify_all.__qualname__."
    - "NOT yet covered in any prior spec: Event.set.__qualname__, Event.clear.__qualname__, Event.wait.__qualname__."
    - "NOT yet covered: Barrier.reset.__qualname__, Barrier.abort.__qualname__."
    - "NOT yet covered: BoundedSemaphore.acquire.__qualname__, BoundedSemaphore.release.__qualname__."
    - "NOT yet covered: Barrier(2).parties == 2 — parties attribute of Barrier instance."
    - "NOT yet covered: Barrier(3).n_waiting == 0 — n_waiting attribute of a fresh Barrier."
    - "NOT yet covered: Barrier(2).broken == False — fresh Barrier is not broken."
    - "NOT yet covered: Event().is_set().__class__.__name__ == 'bool' — return type of is_set()."
    - "NOT yet covered: Lock().locked().__class__.__name__ == 'bool' — return type of locked()."
    - "NOT yet covered: Semaphore(5)._value == 5 — initial _value with non-default argument."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' — method qualname includes class prefix."
    - "threading.Event.set.__qualname__ == 'Event.set' — method qualname includes class prefix."
    - "threading.Event.clear.__qualname__ == 'Event.clear' — method qualname includes class prefix."
    - "threading.Event.wait.__qualname__ == 'Event.wait' — method qualname includes class prefix."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' — method qualname includes class prefix."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' — method qualname includes class prefix."
    - "threading.BoundedSemaphore.acquire.__qualname__ == 'BoundedSemaphore.acquire'."
    - "threading.BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release'."
    - "threading.Barrier(2).parties == 2 — parties reflects constructor argument."
    - "threading.Barrier(3).n_waiting == 0 — no threads are waiting on a fresh Barrier."
    - "threading.Barrier(2).broken == False — a fresh Barrier is not in the broken state."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Event method __qualname__ checks
#
# threading_extra11 covers Condition.wait/notify __qualname__ and
# Thread.start/run/join/is_alive __qualname__. No prior spec checks
# __qualname__ for Event.set, Event.clear, or Event.wait.
# ---------------------------------------------------------------------------

table threading_extra12.Event_method_qualnames:
  description: "Event instance methods have __qualname__ == 'Event.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: evqname

  columns: [id, function, args, expected]
  rows:
    - [set,   Event.set.__qualname__.__eq__,   ["Event.set"],   true]
    - [clear, Event.clear.__qualname__.__eq__, ["Event.clear"], true]
    - [wait,  Event.wait.__qualname__.__eq__,  ["Event.wait"],  true]

# ---------------------------------------------------------------------------
# Condition.notify_all method __qualname__
#
# threading_extra11 covers Condition.wait and Condition.notify __qualname__.
# No prior spec checks Condition.notify_all.__qualname__.
# ---------------------------------------------------------------------------

invariant threading_extra12.Condition_notify_all.qualname:
  description: "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all'"
  category: method_qualnames
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__eq__
  args: ["Condition.notify_all"]
  expected: true

# ---------------------------------------------------------------------------
# Barrier method __qualname__ checks — reset and abort
#
# threading_extra11 covers Barrier.wait.__qualname__. No prior spec covers
# Barrier.reset or Barrier.abort method qualnames.
# ---------------------------------------------------------------------------

invariant threading_extra12.Barrier_reset.qualname:
  description: "threading.Barrier.reset.__qualname__ == 'Barrier.reset'"
  category: method_qualnames
  kind: python_call_eq
  function: Barrier.reset.__qualname__.__eq__
  args: ["Barrier.reset"]
  expected: true

invariant threading_extra12.Barrier_abort.qualname:
  description: "threading.Barrier.abort.__qualname__ == 'Barrier.abort'"
  category: method_qualnames
  kind: python_call_eq
  function: Barrier.abort.__qualname__.__eq__
  args: ["Barrier.abort"]
  expected: true

# ---------------------------------------------------------------------------
# BoundedSemaphore method __qualname__ checks
#
# threading_extra11 covers Semaphore.acquire and Semaphore.release __qualname__.
# No prior spec checks BoundedSemaphore.acquire or BoundedSemaphore.release
# __qualname__. BoundedSemaphore inherits from Semaphore but overrides release;
# __qualname__ is prefixed with BoundedSemaphore.
# ---------------------------------------------------------------------------

invariant threading_extra12.BoundedSemaphore_acquire.qualname:
  description: "threading.BoundedSemaphore.acquire.__qualname__ == 'BoundedSemaphore.acquire'"
  category: method_qualnames
  kind: python_call_eq
  function: BoundedSemaphore.acquire.__qualname__.__eq__
  args: ["BoundedSemaphore.acquire"]
  expected: true

invariant threading_extra12.BoundedSemaphore_release.qualname:
  description: "threading.BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release'"
  category: method_qualnames
  kind: python_call_eq
  function: BoundedSemaphore.release.__qualname__.__eq__
  args: ["BoundedSemaphore.release"]
  expected: true

# ---------------------------------------------------------------------------
# Barrier instance attributes — parties, n_waiting, broken
#
# threading_sync.zspec.zsdl covers Barrier parties/n_waiting/broken at a
# behavioral level but has been listed as covered only there. No prior
# threading_extra spec explicitly covers these as python_call_eq invariants.
# ---------------------------------------------------------------------------

invariant threading_extra12.Barrier.parties:
  description: "threading.Barrier(2).parties == 2 — parties reflects the constructor argument"
  category: barrier_attrs
  kind: python_call_eq
  function: Barrier
  args: [2]
  method: parties
  expected: 2

invariant threading_extra12.Barrier.n_waiting:
  description: "threading.Barrier(3).n_waiting == 0 — a fresh Barrier has no waiting threads"
  category: barrier_attrs
  kind: python_call_eq
  function: Barrier
  args: [3]
  method: n_waiting
  expected: 0

invariant threading_extra12.Barrier.broken_false:
  description: "threading.Barrier(2).broken == False — a fresh Barrier is not broken"
  category: barrier_attrs
  kind: python_call_eq
  function: Barrier
  args: [2]
  method: broken
  expected: false

# ---------------------------------------------------------------------------
# Return type checks — is_set() and locked() return bool
#
# No prior threading spec checks the __class__.__name__ of the return value
# of Event.is_set() or Lock.locked(). Both should be 'bool' (Python bool).
# ---------------------------------------------------------------------------

invariant threading_extra12.Event.is_set_returns_bool:
  description: "threading.Event().is_set().__class__.__name__ == 'bool' — is_set() returns a bool"
  category: return_types
  kind: python_call_eq
  function: Event
  args: []
  method: is_set.__class__.__name__.__eq__
  method_args: ["bool"]
  expected: true

invariant threading_extra12.Lock.locked_returns_bool:
  description: "threading.Lock().locked().__class__.__name__ == 'bool' — locked() returns a bool"
  category: return_types
  kind: python_call_eq
  function: Lock
  args: []
  method: locked.__class__.__name__.__eq__
  method_args: ["bool"]
  expected: true
