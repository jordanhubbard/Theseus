spec: hashlib_extra318
version: ">=3.6"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, and hashlib_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "sha3_256 block_size == 136 bytes (1088 bits, the rate r of Keccak-p[1600] at capacity 512)."
    - "sha3_512 block_size == 72 bytes (576 bits, the rate r of Keccak-p[1600] at capacity 1024)."
    - "sha3_256 digest_size == 32 bytes (256 bits); sha3_512 digest_size == 64 bytes (512 bits)."
    - "sha3_256(b'hello').hexdigest().__len__() == 64 — 32-byte digest expressed as 64 hex characters."
    - "sha3_512(b'hello').hexdigest().__len__() == 128 — 64-byte digest expressed as 128 hex characters."
    - "On macOS/Darwin with OpenSSL, shake_128.__name__ == 'openssl_shake_128' and shake_256.__name__ == 'openssl_shake_256'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha3_256 — hexdigest length, digest_size, block_size
# ---------------------------------------------------------------------------

invariant hashlib_extra318.sha3_256.hexdigest_len:
  description: "sha3_256(b'hello').hexdigest().__len__() == 64 — 32-byte digest as 64 hex chars"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: [!ascii "hello"]
  method: hexdigest
  method_args: []
  method_chain: __len__
  method_chain_args: []
  expected: 64

invariant hashlib_extra318.sha3_256.digest_size_eq:
  description: "sha3_256(b'hello').digest_size.__eq__(32) — 256 bits = 32 bytes"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: [!ascii "hello"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra318.sha3_256.block_size_eq:
  description: "sha3_256(b'hello').block_size.__eq__(136) — rate r = 1088 bits = 136 bytes (FIPS 202)"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: [!ascii "hello"]
  method: block_size.__eq__
  method_args: [136]
  expected: true

# ---------------------------------------------------------------------------
# sha3_512 — hexdigest length, digest_size, block_size
# ---------------------------------------------------------------------------

invariant hashlib_extra318.sha3_512.hexdigest_len:
  description: "sha3_512(b'hello').hexdigest().__len__() == 128 — 64-byte digest as 128 hex chars"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: [!ascii "hello"]
  method: hexdigest
  method_args: []
  method_chain: __len__
  method_chain_args: []
  expected: 128

invariant hashlib_extra318.sha3_512.digest_size_eq:
  description: "sha3_512(b'hello').digest_size.__eq__(64) — 512 bits = 64 bytes"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: [!ascii "hello"]
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra318.sha3_512.block_size_eq:
  description: "sha3_512(b'hello').block_size.__eq__(72) — rate r = 576 bits = 72 bytes (FIPS 202)"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: [!ascii "hello"]
  method: block_size.__eq__
  method_args: [72]
  expected: true

# ---------------------------------------------------------------------------
# shake_128 / shake_256 — __name__ checks
# On macOS/Darwin with OpenSSL backend the name includes the 'openssl_' prefix.
# ---------------------------------------------------------------------------

invariant hashlib_extra318.shake_128.name:
  description: "hashlib.shake_128.__name__ == 'openssl_shake_128' on macOS/Darwin with OpenSSL"
  category: class_metadata
  kind: python_call_eq
  function: shake_128.__name__.__eq__
  args: ["openssl_shake_128"]
  expected: true

invariant hashlib_extra318.shake_256.name:
  description: "hashlib.shake_256.__name__ == 'openssl_shake_256' on macOS/Darwin with OpenSSL"
  category: class_metadata
  kind: python_call_eq
  function: shake_256.__name__.__eq__
  args: ["openssl_shake_256"]
  expected: true
