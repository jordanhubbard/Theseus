spec: is_negative
version: ">=2.1.0"
backend: node(is-negative)

docs: https://www.npmjs.com/package/is-negative

provenance:
  derived_from:
    - "is-negative README — https://www.npmjs.com/package/is-negative"
    - "Test vectors verified with is-negative via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-negative source"
  notes:
    - "is-negative is an npm package. Install: npm install is-negative"
    - "Returns true if the number is less than zero."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_negative.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: isneg

  columns: [id, args, expected]
  rows:
    - [negative,  [-5],   true]
    - [zero,      [0],    false]
    - [positive,  [5],    false]
