spec: in3481
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (in3481): __enter__, __exit__, __call__ dict-presence checks for inspect types."
    - "All values false — inspect introspection types have no custom enter/exit/call in their own __dict__."
    - "None of the inspect types define __enter__, __exit__, or __call__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement context manager or callable protocols directly in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3481.enter:
  description: "inspect types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3481
  columns: [id, function, args, expected]
  rows:
    - ["in3481001", operator.contains, [inspect.Parameter.__dict__,           "__enter__"], false]
    - ["in3481002", operator.contains, [inspect.Signature.__dict__,           "__enter__"], false]
    - ["in3481003", operator.contains, [inspect.BoundArguments.__dict__,      "__enter__"], false]
    - ["in3481004", operator.contains, [inspect.FrameInfo.__dict__,           "__enter__"], false]
    - ["in3481005", operator.contains, [inspect.ArgInfo.__dict__,             "__enter__"], false]
    - ["in3481006", operator.contains, [inspect.FullArgSpec.__dict__,         "__enter__"], false]
    - ["in3481007", operator.contains, [inspect.Attribute.__dict__,           "__enter__"], false]
    - ["in3481008", operator.contains, [inspect.ClassFoundException.__dict__, "__enter__"], false]
    - ["in3481009", operator.contains, [inspect.EndOfBlock.__dict__,          "__enter__"], false]

