spec: th3241
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 663 (th3241): __rtruediv__, __rfloordiv__, __rmod__ dict-presence checks for threading types."
    - "Theme: __rtruediv__, __rfloordiv__, __rmod__ dict-presence (reflected division/modulo)."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — these types have no reflected division/modulo protocol."
    - "None of the threading types define __rtruediv__, __rfloordiv__, or __rmod__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3241.rtruediv:
  description: "threading types __rtruediv__ dict-presence checks; wave 663"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3241
  columns: [id, function, args, expected]
  rows:
    - ["th3241001", operator.contains, [threading.Thread.__dict__,           "__rtruediv__"], false]
    - ["th3241002", operator.contains, [threading.Event.__dict__,            "__rtruediv__"], false]
    - ["th3241003", operator.contains, [threading.Condition.__dict__,        "__rtruediv__"], false]
    - ["th3241004", operator.contains, [threading.Semaphore.__dict__,        "__rtruediv__"], false]
    - ["th3241005", operator.contains, [threading.BoundedSemaphore.__dict__, "__rtruediv__"], false]
    - ["th3241006", operator.contains, [threading.Timer.__dict__,            "__rtruediv__"], false]
    - ["th3241007", operator.contains, [threading.Barrier.__dict__,          "__rtruediv__"], false]
    - ["th3241008", operator.contains, [threading.local.__dict__,            "__rtruediv__"], false]
    - ["th3241009", operator.contains, [type(threading.Lock()).__dict__,     "__rtruediv__"], false]
    - ["th3241010", operator.contains, [type(threading.RLock()).__dict__,    "__rtruediv__"], false]

