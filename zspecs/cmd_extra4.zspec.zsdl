spec: cmd_extra4
version: ">=3.9"
backend: python_module(cmd)

docs: https://docs.python.org/3/library/cmd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmd.html — Python cmd module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cmd.py"
  notes:
    - "This spec extends cmd.zspec.zsdl and cmd_extra through cmd_extra3.zspec.zsdl."
    - "cmd covers: Cmd.__name__/__module__; Cmd() instance attrs (prompt/intro/use_rawinput/cmdqueue/ruler/doc_header/misc_header/undoc_header); IDENTCHARS contains 'a'/'A'/'0'/'_'."
    - "cmd_extra covers: Cmd.__name__/__module__; method names table (cmdloop/onecmd/default/do_help/emptyline/precmd/postcmd/parseline); IDENTCHARS type/nonempty.'_'/'a'."
    - "cmd_extra2 covers: Cmd.__bases__[0].__name__=='object'; Cmd.__qualname__; PROMPT type+value; identchars/ruler/lastcmd/doc_header class attr types; ruler value."
    - "cmd_extra3 covers: Cmd.__bases__.__len__==1; __name__/__module__/__qualname__ type checks; cmdloop/onecmd/default method __qualname__; misc_header/undoc_header class attr types."
    - "This spec adds: do_help/emptyline/precmd/postcmd/parseline method __qualname__; IDENTCHARS contains 'z'/'9'; doc_header/misc_header/undoc_header class attr values; lastcmd value; Cmd.__mro__ length."
    - "cmd.Cmd.do_help.__qualname__ == 'Cmd.do_help' — method qualname includes enclosing class."
    - "cmd.IDENTCHARS contains 'z' — all lowercase letters including 'z' are valid identifier chars."
    - "cmd.IDENTCHARS contains '9' — all decimal digits including '9' are valid identifier chars."
    - "len(cmd.Cmd.__mro__) == 2 — Cmd MRO is [Cmd, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cmd method __qualname__ — do_help, emptyline, precmd, postcmd, parseline
# cmd_extra3 covers cmdloop/onecmd/default; these five are new here.
# ---------------------------------------------------------------------------

invariant cmd_extra4.Cmd.do_help_qualname:
  description: "cmd.Cmd.do_help.__qualname__ == 'Cmd.do_help'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.do_help.__qualname__.__eq__
  args: ["Cmd.do_help"]
  expected: true

invariant cmd_extra4.Cmd.emptyline_qualname:
  description: "cmd.Cmd.emptyline.__qualname__ == 'Cmd.emptyline'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.emptyline.__qualname__.__eq__
  args: ["Cmd.emptyline"]
  expected: true

invariant cmd_extra4.Cmd.precmd_qualname:
  description: "cmd.Cmd.precmd.__qualname__ == 'Cmd.precmd'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.precmd.__qualname__.__eq__
  args: ["Cmd.precmd"]
  expected: true

invariant cmd_extra4.Cmd.postcmd_qualname:
  description: "cmd.Cmd.postcmd.__qualname__ == 'Cmd.postcmd'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.postcmd.__qualname__.__eq__
  args: ["Cmd.postcmd"]
  expected: true

invariant cmd_extra4.Cmd.parseline_qualname:
  description: "cmd.Cmd.parseline.__qualname__ == 'Cmd.parseline'"
  category: method_qualnames
  kind: python_call_eq
  function: Cmd.parseline.__qualname__.__eq__
  args: ["Cmd.parseline"]
  expected: true

# ---------------------------------------------------------------------------
# IDENTCHARS — additional character membership checks
# cmd/cmd_extra cover 'a', 'A', '0', '_'; 'z' and '9' are new.
# ---------------------------------------------------------------------------

invariant cmd_extra4.IDENTCHARS.contains_z:
  description: "cmd.IDENTCHARS contains 'z' — all lowercase letters including 'z' are valid identifier chars"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["z"]
  expected: true

invariant cmd_extra4.IDENTCHARS.contains_9:
  description: "cmd.IDENTCHARS contains '9' — all decimal digits including '9' are valid identifier chars"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["9"]
  expected: true

invariant cmd_extra4.IDENTCHARS.len:
  description: "len(cmd.IDENTCHARS) == 63 — 26 lower + 26 upper + 10 digits + 1 underscore"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__len__
  args: []
  expected: 63

# ---------------------------------------------------------------------------
# Cmd class-level attribute values — doc_header, misc_header, undoc_header, lastcmd
# cmd_extra3 confirms type (str) for misc_header/undoc_header; values are new.
# cmd covers instance-level values via Cmd(); these are the class-level defaults.
# ---------------------------------------------------------------------------

invariant cmd_extra4.Cmd.doc_header_value:
  description: "cmd.Cmd.doc_header == 'Documented commands (type help <topic>):'"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.doc_header.__eq__
  args: ["Documented commands (type help <topic>):"]
  expected: true

invariant cmd_extra4.Cmd.misc_header_value:
  description: "cmd.Cmd.misc_header == 'Miscellaneous help topics:'"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.misc_header.__eq__
  args: ["Miscellaneous help topics:"]
  expected: true

invariant cmd_extra4.Cmd.undoc_header_value:
  description: "cmd.Cmd.undoc_header == 'Undocumented commands:'"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.undoc_header.__eq__
  args: ["Undocumented commands:"]
  expected: true

invariant cmd_extra4.Cmd.lastcmd_value:
  description: "cmd.Cmd.lastcmd == '' — lastcmd class attribute defaults to empty string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.lastcmd.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# Cmd.__mro__ length — [Cmd, object]
# cmd_extra2 confirms __bases__[0].__name__=='object'; MRO length is new.
# ---------------------------------------------------------------------------

invariant cmd_extra4.Cmd.mro_len:
  description: "len(cmd.Cmd.__mro__) == 2 — MRO is [Cmd, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Cmd.__mro__.__len__
  args: []
  expected: 2
