       "asyncio.Queue.qsize.__name__.__len__() == 5 — same length as 'empty'; both mid-tier in length ordering; new to asyncio_extra189"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Queue long compound-name methods and length ordering
#
# asyncio.Queue.put_nowait.__name__.__eq__('put_nowait') == True (len=10)
# asyncio.Queue.get_nowait.__name__.__eq__('get_nowait') == True (len=10)
# Length ordering: put(3)==get(3) < full(4)==join(4) < qsize(5)==empty(5) < put_nowait(10)==get_nowait(10)
# ---------------------------------------------------------------------------

table asyncio_extra189.queue_long_names_and_ordering:
  description: "asyncio.Queue long method names put_nowait(10), get_nowait(10) and full length ordering; verified with Python 3.14.3; new to asyncio_extra189"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue189

  columns: [id, function, args, expected, description]
  rows:
    - [put_nowait_name_eq,
       Queue.put_nowait.__name__.__eq__,
       ["put_nowait"],
       true,
       "asyncio.Queue.put_nowait.__name__.__eq__('put_nowait') == True — method name is 'put_nowait', len=10; str.__eq__ returns True; new to asyncio_extra189"]
    - [get_nowait_name_eq,
       Queue.get_nowait.__name__.__eq__,
       ["get_nowait"],
       true,
       "asyncio.Queue.get_nowait.__name__.__eq__('get_nowait') == True — method name is 'get_nowait', len=10; str.__eq__ returns True; new to asyncio_extra189"]
    - [put_nowait_name_len,
       Queue.put_nowait.__name__.__len__,
       [],
       10,
       "asyncio.Queue.put_nowait.__name__.__len__() == 10 — 'put_nowait' has 10 characters; longest Queue method name; str.__len__() returns 10; new to asyncio_extra189"]
    - [get_nowait_name_len,
       Queue.get_nowait.__name__.__len__,
       [],
       10,
       "asyncio.Queue.get_nowait.__name__.__len__() == 10 — 'get_nowait' has 10 characters; same length as 'put_nowait'; str.__len__() returns 10; new to asyncio_extra189"]
    - [put_name_len_ordering,
       Queue.put.__name__.__len__,
       [],
       3,
       "asyncio.Queue.put.__name__.__len__() == 3 — ordering anchor: shortest name; put(3) < put_nowait(10); str.__len__() returns 3; new to asyncio_extra189"]

