    - [empty_name_eq,
       Queue.empty.__name__.__eq__,
       ["empty"],
       true,
       "asyncio.Queue.empty.__name__.__eq__('empty') == True — method name is 'empty', len=5; str.__eq__ returns True; new to asyncio_extra189"]
    - [qsize_name_len,
       Queue.qsize.__name__.__len__,
       [],
       5,
       "asyncio.Queue.qsize.__name__.__len__() == 5 — 'qsize' has 5 characters: q-s-i-z-e; str.__len__() returns 5; new to asyncio_extra189"]
    - [empty_name_len,
       Queue.empty.__name__.__len__,
       [],
       5,
       "asyncio.Queue.empty.__name__.__len__() == 5 — 'empty' has 5 characters: e-m-p-t-y; str.__len__() returns 5; new to asyncio_extra189"]
    - [qsize_empty_len_eq,
       Queue.qsize.__name__.__len__,
