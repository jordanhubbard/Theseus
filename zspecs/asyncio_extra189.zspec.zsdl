spec: asyncio_extra189
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio.Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.Queue.put.__name__ == 'put' (len=3)"
    - "asyncio.Queue.get.__name__ == 'get' (len=3)"
    - "asyncio.Queue.put_nowait.__name__ == 'put_nowait' (len=10)"
    - "asyncio.Queue.get_nowait.__name__ == 'get_nowait' (len=10)"
    - "asyncio.Queue.qsize.__name__ == 'qsize' (len=5)"
    - "asyncio.Queue.empty.__name__ == 'empty' (len=5)"
    - "asyncio.Queue.full.__name__ == 'full' (len=4)"
    - "asyncio.Queue.join.__name__ == 'join' (len=4)"
    - "Length ordering: put(3)==get(3) < full(4)==join(4) < qsize(5)==empty(5) < put_nowait(10)==get_nowait(10)"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue short-name methods (put, get, full, join)
#
# asyncio.Queue.put.__name__.__eq__('put') == True (len=3)
# asyncio.Queue.get.__name__.__eq__('get') == True (len=3)
# asyncio.Queue.full.__name__.__eq__('full') == True (len=4)
# asyncio.Queue.join.__name__.__eq__('join') == True (len=4)
# ---------------------------------------------------------------------------

table asyncio_extra189.queue_short_names:
  description: "asyncio.Queue short method names: put(3), get(3), full(4), join(4); verified with Python 3.14.3; new to asyncio_extra189"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue189

  columns: [id, function, args, expected, description]
  rows:
    - [put_name_eq,
       Queue.put.__name__.__eq__,
       ["put"],
       true,
       "asyncio.Queue.put.__name__.__eq__('put') == True — method name is 'put', len=3; str.__eq__ returns True; new to asyncio_extra189"]
    - [get_name_eq,
       Queue.get.__name__.__eq__,
       ["get"],
       true,
       "asyncio.Queue.get.__name__.__eq__('get') == True — method name is 'get', len=3; str.__eq__ returns True; new to asyncio_extra189"]
    - [full_name_eq,
       Queue.full.__name__.__eq__,
       ["full"],
       true,
       "asyncio.Queue.full.__name__.__eq__('full') == True — method name is 'full', len=4; str.__eq__ returns True; new to asyncio_extra189"]
    - [join_name_eq,
       Queue.join.__name__.__eq__,
       ["join"],
       true,
       "asyncio.Queue.join.__name__.__eq__('join') == True — method name is 'join', len=4; str.__eq__ returns True; new to asyncio_extra189"]
    - [put_name_len,
       Queue.put.__name__.__len__,
       [],
       3,
       "asyncio.Queue.put.__name__.__len__() == 3 — 'put' has 3 characters; str.__len__() returns 3; new to asyncio_extra189"]

