spec: array_slice
version: ">=1.1.0"
backend: node(array-slice)

docs: https://www.npmjs.com/package/array-slice

provenance:
  derived_from:
    - "array-slice README — https://www.npmjs.com/package/array-slice"
    - "Test vectors verified with array-slice via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "array-slice source"
  notes:
    - "array-slice is an npm package. Install: npm install array-slice"
    - "Extracts a portion of an array, similar to Array.prototype.slice."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_slice.slice:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: aslice

  columns: [id, args, expected]
  rows:
    - [range,  [[1, 2, 3, 4, 5], 1, 3],  [2, 3]]
    - [from,   [[1, 2, 3, 4, 5], 2],     [3, 4, 5]]
