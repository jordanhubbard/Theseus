spec: dice_coefficient
version: ">=2.1.1"
backend: node(dice-coefficient)

docs: https://www.npmjs.com/package/dice-coefficient

provenance:
  derived_from:
    - "dice-coefficient README — https://www.npmjs.com/package/dice-coefficient"
    - "Test vectors verified with dice-coefficient via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "dice-coefficient source"
  notes:
    - "dice-coefficient is an npm package. Install: npm install dice-coefficient"
    - "Returns the Sorensen-Dice similarity coefficient between two strings (0 to 1)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number between 0 and 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table dice_coefficient.diceCoefficient:
  kind: node_module_call_eq
  function: diceCoefficient
  category: similarity
  id_prefix: dice

  columns: [id, args, expected]
  rows:
    - [identical,  ["hello", "hello"],  1]
    - [no_match,   ["abc",   "xyz"],    0]
    - [partial,    ["night", "nacht"],  0.25]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:21:14Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
