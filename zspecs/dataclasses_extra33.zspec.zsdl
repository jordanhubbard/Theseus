spec: dataclasses_extra33
version: ">=3.10"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra32.zspec.zsdl."
    - "Prior specs covered: all function/class __name__/__module__/__qualname__/__bases__; FrozenInstanceError/__mro__.__len__()==5; InitVar/__mro__.__len__()==2; Field method __qualname__.__len__(); KW_ONLY/__class__.__qualname__.__len__()==13; MISSING/__class__.__qualname__.__len__()==13; make_dataclass/__qualname__.__len__()==14; InitVar/__qualname__.__len__()==7."
    - "This spec covers: dataclasses.__all__.__len__()==13 and .__class__.__name__.__len__()==4; __dict__.__class__.__name__.__len__()==12 for Field/FrozenInstanceError/InitVar; module-level function __qualname__.__len__() for field/fields/asdict/astuple/replace/is_dataclass/dataclass/make_dataclass; FrozenInstanceError.__bases__[0].__name__.__len__()==14; MISSING/__class__.__name__.__len__()==13; KW_ONLY/__class__.__name__.__len__()==13."
    - "dataclasses.__all__.__len__() == 13 — thirteen public names exported by dataclasses."
    - "dataclasses.__all__.__class__.__name__ == 'list' (len=4) — __all__ is a plain list."
    - "Field, FrozenInstanceError, and InitVar all have __dict__.__class__.__name__ == 'mappingproxy' (len=12)."
    - "dataclasses.field.__qualname__ == 'field' (len=5) — shortest module-level function qualname."
    - "dataclasses.fields.__qualname__ == 'fields' (len=6); asdict.__qualname__ == 'asdict' (len=6)."
    - "dataclasses.astuple.__qualname__ == 'astuple' (len=7); replace.__qualname__ == 'replace' (len=7)."
    - "dataclasses.is_dataclass.__qualname__ == 'is_dataclass' (len=12)."
    - "dataclasses.dataclass.__qualname__ == 'dataclass' (len=9)."
    - "dataclasses.make_dataclass.__qualname__ == 'make_dataclass' (len=14) — longest module-level function qualname."
    - "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' (len=14)."
    - "MISSING.__class__.__name__ == '_MISSING_TYPE' (len=13); KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' (len=13)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table for dataclasses classes
# (extra33 namespace)
#
# Field, FrozenInstanceError, and InitVar are the three public class objects
# in the dataclasses module. All have __dict__.__class__.__name__ ==
# 'mappingproxy' (12 characters), the standard read-only namespace wrapper
# for Python classes. No prior dataclasses spec records all three together
# in the extra33 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra33.class_dict_class_name_lens:
  description: "__dict__.__class__.__name__.__len__() for dataclasses classes — all equal 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_attrs
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__dict__.__class__.__name__.__len__,               [], 12]
    - [FrozenInstanceError, FrozenInstanceError.__dict__.__class__.__name__.__len__, [], 12]
    - [InitVar,             InitVar.__dict__.__class__.__name__.__len__,             [], 12]

# ---------------------------------------------------------------------------
# Module-level function __qualname__.__len__() table (extra33 namespace)
#
# All module-level functions in dataclasses are defined at top-level scope,
# so __qualname__ == __name__ for each. Lengths in ascending order:
#   field -> 5, fields -> 6, asdict -> 6, astuple -> 7, replace -> 7,
#   dataclass -> 9, is_dataclass -> 12, make_dataclass -> 14.
# field (5) is shortest; make_dataclass (14) is longest. No prior dataclasses
# spec records all eight together in the extra33 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra33.function_qualname_lens:
  description: "__qualname__.__len__() for dataclasses module-level functions"
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: function_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [field,          field.__qualname__.__len__,          [], 5]
    - [fields,         fields.__qualname__.__len__,         [], 6]
    - [asdict,         asdict.__qualname__.__len__,         [], 6]
    - [astuple,        astuple.__qualname__.__len__,        [], 7]
    - [replace,        replace.__qualname__.__len__,        [], 7]
    - [dataclass,      dataclass.__qualname__.__len__,      [], 9]
    - [is_dataclass,   is_dataclass.__qualname__.__len__,   [], 12]
    - [make_dataclass, make_dataclass.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# dataclasses.__all__.__len__() == 13 — standalone (extra33 namespace)
#
# The dataclasses module exports exactly thirteen public names via __all__.
# No prior dataclasses spec records this standalone count in the extra33
# namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra33.all_len:
  description: "len(dataclasses.__all__) == 13 — thirteen public names exported by dataclasses"
  category: module_attrs
  kind: python_call_eq
  function: dataclasses.__all__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# dataclasses.__all__.__class__.__name__.__len__() == 4 — standalone
# (extra33 namespace)
#
# dataclasses.__all__ is a plain Python list, so __class__.__name__ == 'list'
# (4 characters). No prior dataclasses spec records this in the extra33
# namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra33.all_class_name_len:
  description: "len(dataclasses.__all__.__class__.__name__) == 4 — __all__ is a list"
  category: module_attrs
  kind: python_call_eq
  function: dataclasses.__all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# FrozenInstanceError.__bases__[0].__name__.__len__() == 14 — standalone
# (extra33 namespace)
#
# FrozenInstanceError inherits from AttributeError. 'AttributeError' has 14
# characters — the longest direct base-class name among the three public
# dataclasses classes. FrozenInstanceError is raised when code attempts to
# assign to a field of a frozen dataclass instance. No prior dataclasses spec
# records this standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra33.FrozenInstanceError.base_name_len:
  description: "len(dataclasses.FrozenInstanceError.__bases__[0].__name__) == 14 — direct base is 'AttributeError'"
  category: class_hierarchy
  kind: python_call_eq
  function: "FrozenInstanceError.__bases__[0].__name__.__len__"
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# MISSING.__class__.__name__.__len__() == 13 — standalone (extra33 namespace)
#
# MISSING is an instance of the private class _MISSING_TYPE. That class name
# has 13 characters. MISSING is used as the default sentinel for field()
# arguments that have not been supplied. No prior dataclasses spec records
# this standalone .__name__ (vs .__qualname__) in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra33.MISSING.class_name_len:
  description: "len(dataclasses.MISSING.__class__.__name__) == 13 — '_MISSING_TYPE' sentinel class name"
  category: sentinel_class_attrs
  kind: python_call_eq
  function: MISSING.__class__.__name__.__len__
  args: []
  expected: 13
