spec: tarfile_extra10
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "This spec extends tarfile.zspec.zsdl through tarfile_extra9.zspec.zsdl."
    - "tarfile_extra9 covers: TarInfo devmajor/devminor/size/mtime defaults; AREGTYPE value/class; TarError.__mro__[1]/[2]; ExFileObject class is type; TarInfo filename_archive_tar; TarInfo.linkname default."
    - "tarfile_extra8 covers: TarInfo uid/gid/mode defaults; GNU flag __class__.__name__; is_tarfile __module__/__class__.__name__; open __class__.__name__."
    - "tarfile_extra7 covers: LNKTYPE/CHRTYPE/BLKTYPE/FIFOTYPE eq bool form; ENCODING eq bool form; BLOCKSIZE/RECORDSIZE class names; TarFile/TarInfo/TarError/ReadError/CompressionError __class__.__name__=='type'; StreamError __name__."
    - "tarfile_extra6 covers: GNU extension flag decode; ExFileObject metadata; ExtractError/CompressionError/HeaderError/StreamError __module__ and bases."
    - "tarfile_extra4 covers: __qualname__ for TarFile/TarInfo/exceptions/functions; format constant class names as int."
    - "tarfile_extra2 covers: TarFile/__module__, TarInfo/__module__, CompressionError/__bases__[0].__name__=='TarError', REGULAR_TYPES/SUPPORTED_TYPES."
    - "No prior spec covers: tarfile.ReadError.__mro__[1].__name__ == 'TarError' — ReadError MRO depth 1."
    - "No prior spec covers: tarfile.ReadError.__mro__[2].__name__ == 'Exception' — ReadError MRO depth 2."
    - "No prior spec covers: tarfile.CompressionError.__mro__[1].__name__ == 'TarError' — CompressionError MRO depth 1."
    - "No prior spec covers: tarfile.CompressionError.__mro__[2].__name__ == 'Exception' — CompressionError MRO depth 2."
    - "No prior spec covers: tarfile.DEFAULT_FORMAT.__class__.__name__ == 'int' — DEFAULT_FORMAT is an int constant."
    - "No prior spec covers: tarfile.open.__module__ == 'tarfile' — open function is defined in the tarfile module."
    - "No prior spec covers: tarfile.TarInfo('x.txt').type == b'0' — default type byte is REGTYPE."
    - "tarfile.ReadError.__mro__: [ReadError, TarError, Exception, BaseException, object]."
    - "tarfile.CompressionError.__mro__: [CompressionError, TarError, Exception, BaseException, object]."
    - "tarfile.DEFAULT_FORMAT == 2 (PAX_FORMAT); __class__.__name__ == 'int' — same pattern as GNU/PAX/USTAR covered in extra4, but DEFAULT_FORMAT itself was not checked."
    - "tarfile.TarInfo default type byte b'0' == REGTYPE; consistent with base spec TarInfo construction coverage but confirming via type attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ReadError.__mro__ depth 1 and depth 2
# tarfile_extra9 covers TarError.__mro__[1].__name__ == 'Exception' and
# TarError.__mro__[2].__name__ == 'BaseException'.
# No prior spec checks ReadError.__mro__[N] for any N.
# ReadError.__mro__: [ReadError, TarError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant tarfile_extra10.ReadError.mro_index1:
  description: "tarfile.ReadError.__mro__[1].__name__ == 'TarError' — ReadError MRO depth 1 is TarError"
  category: class_hierarchy
  kind: python_call_eq
  function: ReadError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "TarError"

invariant tarfile_extra10.ReadError.mro_index2:
  description: "tarfile.ReadError.__mro__[2].__name__ == 'Exception' — ReadError MRO depth 2 is Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: ReadError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# CompressionError.__mro__ depth 1 and depth 2
# tarfile_extra2 and tarfile_extra6 cover CompressionError.__bases__[0].__name__ == 'TarError'
# (bases form). No prior spec checks CompressionError.__mro__[N] for any N.
# CompressionError.__mro__: [CompressionError, TarError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant tarfile_extra10.CompressionError.mro_index1:
  description: "tarfile.CompressionError.__mro__[1].__name__ == 'TarError' — CompressionError MRO depth 1"
  category: class_hierarchy
  kind: python_call_eq
  function: CompressionError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "TarError"

invariant tarfile_extra10.CompressionError.mro_index2:
  description: "tarfile.CompressionError.__mro__[2].__name__ == 'Exception' — CompressionError MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: CompressionError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# DEFAULT_FORMAT.__class__.__name__ == 'int'
# tarfile_extra4 checks GNU_FORMAT, PAX_FORMAT, and USTAR_FORMAT class names as 'int'.
# No prior spec checks DEFAULT_FORMAT.__class__.__name__.
# DEFAULT_FORMAT == 2 (PAX_FORMAT on CPython 3.9+); it is also an int constant.
# ---------------------------------------------------------------------------

invariant tarfile_extra10.DEFAULT_FORMAT.class_name:
  description: "tarfile.DEFAULT_FORMAT.__class__.__name__ == 'int' — DEFAULT_FORMAT is an int constant"
  category: constants
  kind: python_call_eq
  function: DEFAULT_FORMAT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# open.__module__ == 'tarfile'
# tarfile_extra8 checks open.__class__.__name__ == 'method'.
# tarfile_extra4 checks open.__qualname__ == 'TarFile.open'.
# No prior spec checks open.__module__.
# open is the classmethod tarfile.open (alias for TarFile.open); its __module__
# is 'tarfile' because it is defined in the tarfile module.
# ---------------------------------------------------------------------------

invariant tarfile_extra10.open.module:
  description: "tarfile.open.__module__ == 'tarfile' — open is defined in the tarfile module"
  category: functions
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["tarfile"]
  expected: true

# ---------------------------------------------------------------------------
# TarInfo default type byte == REGTYPE (b'0')
# Base spec covers TarInfo construction and REGTYPE constant value.
# No prior spec checks TarInfo('x.txt').type (the .type attribute of a freshly
# constructed TarInfo) — distinct from REGTYPE == b'0' as a standalone constant.
# A freshly constructed TarInfo defaults its type to REGTYPE (b'0').
# ---------------------------------------------------------------------------

invariant tarfile_extra10.TarInfo.type_default:
  description: "tarfile.TarInfo('x.txt').type == b'0' — default type attribute is REGTYPE"
  category: tarinfo
  kind: python_call_eq
  function: TarInfo
  args: ["x.txt"]
  method: type
  expected: !ascii "0"
