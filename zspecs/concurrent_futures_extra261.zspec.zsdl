spec: concurrent_futures_extra261
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.thread.__name__ == 'concurrent.futures.thread' (full dotted name)."
    - "concurrent.futures.thread.__package__ == 'concurrent.futures'."
    - "concurrent.futures.thread.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "concurrent.futures.process.__name__ == 'concurrent.futures.process'."
    - "concurrent.futures.process.__package__ == 'concurrent.futures'."
    - "concurrent.futures.process.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; __module__ == 'concurrent.futures.thread'."
    - "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.thread submodule identity
#
# concurrent.futures.thread is the submodule implementing ThreadPoolExecutor.
# Its __name__ is the full dotted name; __package__ is 'concurrent.futures'.
# The loader is a SourceFileLoader (concrete .py source file).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra261.thread_module.name:
  description: "concurrent.futures.thread.__name__ == 'concurrent.futures.thread'"
  category: identity
  kind: python_call_eq
  function: thread.__name__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra261.thread_module.package:
  description: "concurrent.futures.thread.__package__ == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: thread.__package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra261.thread_module.loader_class:
  description: "concurrent.futures.thread.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: thread.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures.process submodule identity
#
# concurrent.futures.process is the submodule implementing ProcessPoolExecutor.
# Its __name__ is the full dotted name; __package__ is 'concurrent.futures'.
# The loader is a SourceFileLoader (concrete .py source file).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra261.process_module.name:
  description: "concurrent.futures.process.__name__ == 'concurrent.futures.process'"
  category: identity
  kind: python_call_eq
  function: process.__name__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra261.process_module.package:
  description: "concurrent.futures.process.__package__ == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: process.__package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra261.process_module.loader_class:
  description: "concurrent.futures.process.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: process.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadPoolExecutor — class identity
#
# ThreadPoolExecutor is defined in concurrent.futures.thread and inherits from
# Executor. Its __module__ reflects the submodule where it is implemented.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra261.thread_pool_executor.name:
  description: "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__name__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra261.thread_pool_executor.module:
  description: "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra261.thread_pool_executor.base:
  description: "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Executor"
