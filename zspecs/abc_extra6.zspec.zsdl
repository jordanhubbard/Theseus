spec: abc_extra6
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra5.zspec.zsdl."
    - "Focus: __qualname__ attributes and deprecated abstract decorators."
    - "abc.ABC.__name__ == 'ABC' — the class name, not its metaclass."
    - "abc.ABC.__qualname__ == 'ABC'."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta'."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' — already in abc_extra5 via abstractclassmethod.deprecated_name; this spec adds the distinct qualname checks for deprecated members."
    - "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' — deprecated since 3.3, still present."
    - "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' — deprecated since 3.3, still present."
    - "abc.abstractproperty.__qualname__ == 'abstractproperty' — deprecated since 3.3, still present."
    - "abc.get_cache_token.__name__ == 'get_cache_token' (Python 3.9+)."
    - "abc.get_cache_token.__module__ == 'abc'."
    - "abc.ABC.__name__ == 'ABC' — not previously tested directly via __name__.__eq__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — ABC, ABCMeta, abstractmethod
# abc_extra5 covers __name__ for abstractmethod and get_cache_token;
# this spec focuses on __qualname__ for all key members.
# ---------------------------------------------------------------------------

table abc_extra6.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ABC,           ABC.__qualname__.__eq__,           ["ABC"],           true]
    - [ABCMeta,       ABCMeta.__qualname__.__eq__,       ["ABCMeta"],       true]
    - [abstractmethod, abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]

# ---------------------------------------------------------------------------
# ABC.__name__ — direct __name__ check (abc_extra5 tests __class__.__name__)
# ---------------------------------------------------------------------------

invariant abc_extra6.ABC.name:
  description: "abc.ABC.__name__ == 'ABC'"
  category: class_names
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token — __module__ attribute (Python 3.9+)
# abc_extra5 covers __name__ for get_cache_token; this adds __module__.
# ---------------------------------------------------------------------------

invariant abc_extra6.get_cache_token.module:
  description: "abc.get_cache_token.__module__ == 'abc'"
  category: module
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# Deprecated abstract decorators — qualname checks
# abstractclassmethod, abstractstaticmethod, abstractproperty are deprecated
# since Python 3.3 but remain in the module through at least Python 3.12.
# ---------------------------------------------------------------------------

invariant abc_extra6.abstractclassmethod.qualname:
  description: "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod'"
  category: deprecated
  kind: python_call_eq
  function: abstractclassmethod.__qualname__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra6.abstractstaticmethod.qualname:
  description: "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod'"
  category: deprecated
  kind: python_call_eq
  function: abstractstaticmethod.__qualname__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra6.abstractproperty.qualname:
  description: "abc.abstractproperty.__qualname__ == 'abstractproperty'"
  category: deprecated
  kind: python_call_eq
  function: abstractproperty.__qualname__.__eq__
  args: ["abstractproperty"]
  expected: true

# ---------------------------------------------------------------------------
# Deprecated decorators — __name__ checks (distinct from qualname checks above)
# ---------------------------------------------------------------------------

invariant abc_extra6.abstractclassmethod.name:
  description: "abc.abstractclassmethod.__name__ == 'abstractclassmethod'"
  category: deprecated
  kind: python_call_eq
  function: abstractclassmethod.__name__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra6.abstractstaticmethod.name:
  description: "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod'"
  category: deprecated
  kind: python_call_eq
  function: abstractstaticmethod.__name__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra6.abstractproperty.name:
  description: "abc.abstractproperty.__name__ == 'abstractproperty'"
  category: deprecated
  kind: python_call_eq
  function: abstractproperty.__name__.__eq__
  args: ["abstractproperty"]
  expected: true
