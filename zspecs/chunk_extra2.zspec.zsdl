spec: chunk_extra2
version: ">=3.9,<3.13"
backend: python_module(chunk)

docs: https://docs.python.org/3.11/library/chunk.html

provenance:
  derived_from:
    - "https://docs.python.org/3.11/library/chunk.html — Python chunk documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/chunk.py"
  notes:
    - "This spec extends chunk.zspec.zsdl and chunk_extra.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Chunk.__qualname__ — not covered in prior specs
# ---------------------------------------------------------------------------

invariant chunk_extra2.Chunk.qualname:
  description: "chunk.Chunk.__qualname__ == 'Chunk'"
  category: class_names
  kind: python_call_eq
  function: Chunk.__qualname__.__eq__
  args: ["Chunk"]
  expected: true

# ---------------------------------------------------------------------------
# Chunk.__bases__ length — exactly one base class (object)
# (prior specs check __bases__[0].__name__; length is new)
# ---------------------------------------------------------------------------

invariant chunk_extra2.Chunk.bases_len:
  description: "len(chunk.Chunk.__bases__) == 1 — Chunk has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Chunk.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Method __qualname__ checks — getname and getsize
# (prior specs check __name__; __qualname__ is new)
# ---------------------------------------------------------------------------

invariant chunk_extra2.Chunk.getname_qualname:
  description: "chunk.Chunk.getname.__qualname__ == 'Chunk.getname'"
  category: method_names
  kind: python_call_eq
  function: Chunk.getname.__qualname__.__eq__
  args: ["Chunk.getname"]
  expected: true

invariant chunk_extra2.Chunk.getsize_qualname:
  description: "chunk.Chunk.getsize.__qualname__ == 'Chunk.getsize'"
  category: method_names
  kind: python_call_eq
  function: Chunk.getsize.__qualname__.__eq__
  args: ["Chunk.getsize"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __qualname__ for all public methods on Chunk
# (prior specs only check __name__; __qualname__ is new for all methods)
# ---------------------------------------------------------------------------

table chunk_extra2.Chunk.method_qualnames:
  kind: python_call_eq
  category: method_names
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [getname, Chunk.getname.__qualname__.__eq__, ["Chunk.getname"], true, "chunk.Chunk.getname.__qualname__ == 'Chunk.getname'"]
    - [getsize, Chunk.getsize.__qualname__.__eq__, ["Chunk.getsize"], true, "chunk.Chunk.getsize.__qualname__ == 'Chunk.getsize'"]
    - [read,    Chunk.read.__qualname__.__eq__,    ["Chunk.read"],    true, "chunk.Chunk.read.__qualname__ == 'Chunk.read'"]
    - [seek,    Chunk.seek.__qualname__.__eq__,    ["Chunk.seek"],    true, "chunk.Chunk.seek.__qualname__ == 'Chunk.seek'"]
    - [tell,    Chunk.tell.__qualname__.__eq__,    ["Chunk.tell"],    true, "chunk.Chunk.tell.__qualname__ == 'Chunk.tell'"]
    - [close,   Chunk.close.__qualname__.__eq__,   ["Chunk.close"],   true, "chunk.Chunk.close.__qualname__ == 'Chunk.close'"]
    - [skip,    Chunk.skip.__qualname__.__eq__,    ["Chunk.skip"],    true, "chunk.Chunk.skip.__qualname__ == 'Chunk.skip'"]
    - [isatty,  Chunk.isatty.__qualname__.__eq__,  ["Chunk.isatty"],  true, "chunk.Chunk.isatty.__qualname__ == 'Chunk.isatty'"]
