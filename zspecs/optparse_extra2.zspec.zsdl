spec: optparse_extra2
version: ">=3.9"
backend: python_module(optparse)

docs: https://docs.python.org/3/library/optparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/optparse.html — Python optparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/optparse.py"
  notes:
    - "Extends optparse.zspec.zsdl and optparse_extra.zspec.zsdl with new axes."
    - "optparse.zspec.zsdl covers: class_names table (OptionParser/Option/OptionGroup/Values/OptionError/OptionConflictError/OptionValueError/BadOptionError/AmbiguousOptionError/IndentedHelpFormatter/TitledHelpFormatter __name__); OptionParser().allow_interspersed_args; OptionParser().version; MRO checks for OptionConflictError/OptionValueError/AmbiguousOptionError."
    - "optparse_extra.zspec.zsdl covers: OptionParser/Option/OptionGroup __name__/__module__; OptParseError __name__/__bases__[0].__name__; OptionError/OptionValueError/BadOptionError/AmbiguousOptionError/OptionConflictError __name__/__bases__[0].__name__."
    - "This spec adds: __qualname__ for all public optparse classes; Values/__module__; IndentedHelpFormatter/__module__/__bases__[0].__name__; TitledHelpFormatter/__module__/__bases__[0].__name__; HelpFormatter/__qualname__; OptionParser().description default is None."
    - "All __qualname__ values == their class identifier — all optparse public classes are module-level (not nested)."
    - "optparse.Values.__module__ == 'optparse' — covered by name in optparse.zspec.zsdl table but module not checked."
    - "optparse.IndentedHelpFormatter.__bases__[0].__name__ == 'HelpFormatter'."
    - "optparse.TitledHelpFormatter.__bases__[0].__name__ == 'HelpFormatter'."
    - "optparse.OptionParser().description == None — the description attribute is None when not supplied."
    - "All expected values verified by running Python 3.12 optparse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for all public optparse classes
#
# No prior optparse spec covers __qualname__ for any class.
# All optparse public classes are module-level so __qualname__ == __name__.
# ---------------------------------------------------------------------------

table optparse_extra2.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [OptionParser,          OptionParser.__qualname__.__eq__,          ["OptionParser"],          true]
    - [Option,                Option.__qualname__.__eq__,                ["Option"],                true]
    - [OptionGroup,           OptionGroup.__qualname__.__eq__,           ["OptionGroup"],           true]
    - [Values,                Values.__qualname__.__eq__,                ["Values"],                true]
    - [HelpFormatter,         HelpFormatter.__qualname__.__eq__,         ["HelpFormatter"],         true]
    - [IndentedHelpFormatter, IndentedHelpFormatter.__qualname__.__eq__, ["IndentedHelpFormatter"], true]
    - [TitledHelpFormatter,   TitledHelpFormatter.__qualname__.__eq__,   ["TitledHelpFormatter"],   true]
    - [OptParseError,         OptParseError.__qualname__.__eq__,         ["OptParseError"],         true]
    - [OptionError,           OptionError.__qualname__.__eq__,           ["OptionError"],           true]
    - [OptionValueError,      OptionValueError.__qualname__.__eq__,      ["OptionValueError"],      true]
    - [BadOptionError,        BadOptionError.__qualname__.__eq__,        ["BadOptionError"],        true]
    - [AmbiguousOptionError,  AmbiguousOptionError.__qualname__.__eq__,  ["AmbiguousOptionError"],  true]
    - [OptionConflictError,   OptionConflictError.__qualname__.__eq__,   ["OptionConflictError"],   true]

# ---------------------------------------------------------------------------
# Values.__module__ — confirmed as 'optparse'
#
# optparse.zspec.zsdl checks Values.__name__ in the class_names table.
# optparse_extra checks __module__ for OptionParser/Option/OptionGroup but
# not for Values. Checked here as a standalone invariant.
# ---------------------------------------------------------------------------

invariant optparse_extra2.Values.module:
  description: "optparse.Values.__module__ == 'optparse'"
  category: class_modules
  kind: python_call_eq
  function: Values.__module__.__eq__
  args: ["optparse"]
  expected: true

# ---------------------------------------------------------------------------
# IndentedHelpFormatter and TitledHelpFormatter — module and base class
#
# optparse.zspec.zsdl checks __name__ for both formatters in the class_names
# table. No prior spec checks their __module__ or their __bases__[0].__name__.
# Both inherit directly from HelpFormatter.
# ---------------------------------------------------------------------------

invariant optparse_extra2.IndentedHelpFormatter.module:
  description: "optparse.IndentedHelpFormatter.__module__ == 'optparse'"
  category: class_modules
  kind: python_call_eq
  function: IndentedHelpFormatter.__module__.__eq__
  args: ["optparse"]
  expected: true

invariant optparse_extra2.IndentedHelpFormatter.base_class:
  description: "optparse.IndentedHelpFormatter.__bases__[0].__name__ == 'HelpFormatter'"
  category: class_hierarchy
  kind: python_call_eq
  function: IndentedHelpFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "HelpFormatter"

invariant optparse_extra2.TitledHelpFormatter.module:
  description: "optparse.TitledHelpFormatter.__module__ == 'optparse'"
  category: class_modules
  kind: python_call_eq
  function: TitledHelpFormatter.__module__.__eq__
  args: ["optparse"]
  expected: true

invariant optparse_extra2.TitledHelpFormatter.base_class:
  description: "optparse.TitledHelpFormatter.__bases__[0].__name__ == 'HelpFormatter'"
  category: class_hierarchy
  kind: python_call_eq
  function: TitledHelpFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "HelpFormatter"

# ---------------------------------------------------------------------------
# OptionParser().description — defaults to None
#
# optparse.zspec.zsdl checks allow_interspersed_args and version defaults.
# No prior spec checks the description attribute, which is None when omitted.
# ---------------------------------------------------------------------------

invariant optparse_extra2.OptionParser.description_default:
  description: "optparse.OptionParser().description == None when no description is supplied"
  category: defaults
  kind: python_call_eq
  function: OptionParser
  args: []
  method: description
  method_args: []
  expected: null
