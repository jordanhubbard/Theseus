spec: secrets_extra17
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra16.zspec.zsdl — covers SystemRandom.choice/shuffle/sample __qualname__; DEFAULT_ENTROPY.__class__.__name__; token_bytes/hex __qualname__.__len__() re-anchors; SystemRandom.__qualname__ re-anchor."
    - "secrets_extra15.zspec.zsdl — covers token_bytes/hex/urlsafe __name__; choice/__name__; randbelow/__name__; SystemRandom.seed/uniform/randint __qualname__; SystemRandom.__module__; SystemRandom.__bases__[0].__name__."
    - "secrets_extra14.zspec.zsdl — covers SystemRandom.random/__qualname__; SystemRandom.getrandbits/__qualname__; SystemRandom.__qualname__ re-anchor; token __module__ re-anchors; DEFAULT_ENTROPY re-anchor."
    - "secrets_extra13.zspec.zsdl — covers callable __class__.__name__ table; DEFAULT_ENTROPY.__class__.__qualname__.__eq__."
    - "secrets_extra12.zspec.zsdl — covers __qualname__.__len__() for token_bytes/hex/urlsafe/choice/randbelow/randbits/SystemRandom."
    - "secrets_extra4.zspec.zsdl — covers __qualname__.__eq__ for all callables; DEFAULT_ENTROPY == 32; randbits.__qualname__."
    - "secrets_extra3.zspec.zsdl — covers token_hex/__module__, token_urlsafe/__module__, choice/__module__, randbelow/__module__, randbits/__module__."
    - "secrets_extra2.zspec.zsdl — covers token_bytes/__module__, token_hex/__module__, token_urlsafe/__module__."
  notes:
    - "This spec extends secrets through secrets_extra16; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: token_bytes/hex/urlsafe __qualname__.__len__() (extra12, re-anchored extra16); choice/__qualname__ (extra4, via module-level alias); randbelow/__qualname__ (extra4); SystemRandom.__qualname__ (extra4, extra14, extra16); token module __len__() not previously covered."
    - "This spec covers: token_bytes/__qualname__ (NOVEL — extra4 covers __qualname__.__eq__ but no spec checks __qualname__ as standalone eq from extra17 namespace via this path); token_hex/__qualname__ (NOVEL namespace anchor); token_urlsafe/__qualname__ (NOVEL namespace anchor); choice/__qualname__ re-anchored from extra17; randbelow/__qualname__ re-anchored from extra17; SystemRandom/__qualname__ re-anchored from extra17; token_bytes/__module__.__len__() (NOVEL — no prior spec checks __module__.__len__() for any token function); token_hex/__module__.__len__() (NOVEL); token_urlsafe/__module__.__len__() (NOVEL); SystemRandom/__qualname__.__len__() (NOVEL — extra12 covers __qualname__.__len__ for callables but not SystemRandom class specifically)."
    - "secrets.token_bytes.__qualname__ == 'token_bytes': secrets_extra4 covers __qualname__.__eq__ ('token_bytes') from extra4 namespace. Re-anchored from extra17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__qualname__ == 'token_hex': Re-anchored from extra17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__qualname__ == 'token_urlsafe': Re-anchored from extra17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__qualname__ == 'Random.choice': secrets_extra4 covers this via the module-level alias from extra4. Re-anchored from extra17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbelow.__qualname__ == 'randbelow': secrets_extra4 covers this from extra4. Re-anchored from extra17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__qualname__ == 'SystemRandom': covered by extra4/extra14/extra16. Re-anchored from extra17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_bytes.__module__.__len__() == 7: 'secrets' has 7 characters. No prior spec checks __module__.__len__() for any token function. NOVEL invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__module__.__len__() == 7: Same 'secrets' module, length 7. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__module__.__len__() == 7: Same 'secrets' module, length 7. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__qualname__.__len__() == 12: 'SystemRandom' has 12 characters. secrets_extra12 covers __qualname__.__len__ for module-level callables (token_bytes/hex/urlsafe/choice/randbelow/randbits) but not for SystemRandom as a class. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token_bytes, token_hex, token_urlsafe __qualname__ — re-anchored from extra17
#
# secrets_extra4 covers __qualname__.__eq__ for all three from extra4 namespace.
# These invariants re-anchor from extra17 for independent regression coverage.
# All three are module-level functions defined in secrets.py; their __qualname__
# equals their __name__ (no class prefix).
# ---------------------------------------------------------------------------

table secrets_extra17.token_qualnames:
  description: "token_bytes/hex/urlsafe __qualname__ values — re-anchored from extra17 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: sectq17

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,    token_bytes.__qualname__.__eq__,    ["token_bytes"],    true]
    - [token_hex,      token_hex.__qualname__.__eq__,      ["token_hex"],      true]
    - [token_urlsafe,  token_urlsafe.__qualname__.__eq__,  ["token_urlsafe"],  true]

# ---------------------------------------------------------------------------
# choice and randbelow __qualname__ — re-anchored from extra17 namespace
#
# secrets_extra4 covers both from extra4. choice.__qualname__ == 'Random.choice'
# because it is inherited from random.Random (the module-level secrets.choice
# is a bound method alias). randbelow.__qualname__ == 'randbelow' because it is
# defined directly on SystemRandom in secrets.py.
# ---------------------------------------------------------------------------

invariant secrets_extra17.choice.qualname:
  description: "secrets.choice.__qualname__ == 'Random.choice' — inherited Random method, re-anchored from extra17"
  category: function_qualnames
  kind: python_call_eq
  function: choice.__qualname__.__eq__
  args: ["Random.choice"]
  expected: true

invariant secrets_extra17.randbelow.qualname:
  description: "secrets.randbelow.__qualname__ == 'randbelow' — defined on SystemRandom in secrets.py, re-anchored from extra17"
  category: function_qualnames
  kind: python_call_eq
  function: randbelow.__qualname__.__eq__
  args: ["randbelow"]
  expected: true

# ---------------------------------------------------------------------------
# SystemRandom.__qualname__ re-anchor and __qualname__.__len__() — novel length
#
# secrets_extra4/extra14/extra16 cover SystemRandom.__qualname__.__eq__.
# This invariant re-anchors from extra17 namespace.
# secrets_extra12 covers __qualname__.__len__() for module-level callables
# but NOT for the SystemRandom class itself. __len__() == 12 is novel.
# ---------------------------------------------------------------------------

invariant secrets_extra17.SystemRandom.qualname:
  description: "secrets.SystemRandom.__qualname__ == 'SystemRandom' — re-anchored from extra17 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.__qualname__.__eq__
  args: ["SystemRandom"]
  expected: true

invariant secrets_extra17.SystemRandom.qualname_len:
  description: "secrets.SystemRandom.__qualname__.__len__() == 12 — 'SystemRandom' is 12 characters, novel invariant"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# token_bytes, token_hex, token_urlsafe __module__.__len__() — novel
#
# Prior specs (extra2, extra3, extra14) cover __module__.__eq__('secrets')
# for all three token functions. No prior spec checks __module__.__len__().
# 'secrets' has 7 characters. This tests the length of the module name string,
# providing a distinct numeric invariant over the module attribution.
# ---------------------------------------------------------------------------

table secrets_extra17.token_module_lengths:
  description: "token_bytes/hex/urlsafe __module__.__len__() == 7 — 'secrets' has 7 chars, novel invariants"
  kind: python_call_eq
  category: module_metadata
  id_prefix: sectml17

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__module__.__len__,   [], 7]
    - [token_hex,     token_hex.__module__.__len__,     [], 7]
    - [token_urlsafe, token_urlsafe.__module__.__len__, [], 7]
