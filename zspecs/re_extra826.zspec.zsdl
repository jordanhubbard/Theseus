spec: re_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/re/__init__.py"
    - "cpython/Modules/_sre.c"
  not_derived_from:
    - "any third-party regex library"
  notes:
    - "Covers __qualname__ values for re.Pattern and re.Match methods"
    - "All qualnames follow the 'ClassName.method_name' pattern"
  created_at: "2026-04-12"

table re_extra826.pattern_qualnames:
  description: "Verify __qualname__ strings for re.Pattern methods"
  kind: python_call_eq
  category: qualname
  id_prefix: re826pt
  columns: [id, function, args, expected]
  rows:
    - [re826pt001, "re.Pattern.match.__qualname__.__eq__", ["Pattern.match"], true]
    - [re826pt002, "re.Pattern.search.__qualname__.__eq__", ["Pattern.search"], true]
    - [re826pt003, "re.Pattern.fullmatch.__qualname__.__eq__", ["Pattern.fullmatch"], true]
    - [re826pt004, "re.Pattern.split.__qualname__.__eq__", ["Pattern.split"], true]
    - [re826pt005, "re.Pattern.findall.__qualname__.__eq__", ["Pattern.findall"], true]
    - [re826pt006, "re.Pattern.finditer.__qualname__.__eq__", ["Pattern.finditer"], true]
    - [re826pt007, "re.Pattern.sub.__qualname__.__eq__", ["Pattern.sub"], true]
    - [re826pt008, "re.Pattern.subn.__qualname__.__eq__", ["Pattern.subn"], true]

table re_extra826.match_qualnames:
  description: "Verify __qualname__ strings for re.Match methods"
  kind: python_call_eq
  category: qualname
  id_prefix: re826mx
  columns: [id, function, args, expected]
  rows:
    - [re826mx001, "re.Match.group.__qualname__.__eq__", ["Match.group"], true]
    - [re826mx002, "re.Match.groups.__qualname__.__eq__", ["Match.groups"], true]
    - [re826mx003, "re.Match.groupdict.__qualname__.__eq__", ["Match.groupdict"], true]
    - [re826mx004, "re.Match.span.__qualname__.__eq__", ["Match.span"], true]
