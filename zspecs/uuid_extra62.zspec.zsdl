spec: uuid_extra62
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra61.zspec.zsdl — covers uuid.__name__/__spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__ / __file__.__contains__('.py') / UUID.__dict__.__class__.__name__=='mappingproxy' / UUID.__dict__.__contains__('__init__'/'__repr__'/'__str__'/'__hash__'/'__eq__') (table + invariants)."
    - "uuid_extra60.zspec.zsdl — covers UUID.__repr__/__str__/__hash__/__eq__ co_name and co_argcount (table) / SafeUUID/__class__/__name__=='type' / SafeUUID/__name__/'module'/'qualname' (table) / SafeUUID/__bases__[0].__name__=='IntEnum' (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra61; it does NOT duplicate invariants present in those files."
    - "Wave 237 theme: UUID class method qualnames + uuid module function code objects."
    - "uuid.UUID.__init__.__code__.co_name == '__init__' — the code object name for UUID.__init__. uuid_extra60 covers co_name for __repr__/__str__/__hash__/__eq__; this spec extends to __init__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7 — UUID.__init__ takes self plus 6 positional args (hex, bytes, bytes_le, fields, int, version); is_safe is keyword-only (not in co_argcount). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_name == '__str__' — covered by uuid_extra60; this spec re-anchors alongside novel code object facts. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_argcount == 1 — UUID.__str__ takes only self. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_name == 'uuid4' — the code object name for module-level uuid4. No prior uuid spec checks uuid4.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_argcount == 0 — uuid4 takes no arguments. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_name == 'uuid1' — the code object name for module-level uuid1. No prior uuid spec checks uuid1.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_argcount == 2 — uuid1 takes node and clock_seq (both defaulting to None). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__code__.co_argcount == 1 — UUID.__hash__ takes only self. uuid_extra60 covers co_name for __hash__; this spec adds co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__init__ code object co_name and co_argcount
#
# Wave 237 theme: UUID.__init__ code object identity.
#
# uuid.UUID.__init__ is defined in Lib/uuid.py. Its code object co_name is
# '__init__' and co_argcount is 7 (self + hex, bytes, bytes_le, fields,
# int, version — is_safe is keyword-only and not counted in co_argcount).
# uuid_extra60 covers co_name for __repr__/__str__/__hash__/__eq__;
# this spec extends to __init__. No prior uuid spec checks __init__.__code__
# co_name or co_argcount in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra62.UUID_init_code:
  description: "uuid.UUID.__init__.__code__.co_name.__eq__('__init__')==True / UUID.__init__.__code__.co_argcount.__eq__(7)==True — UUID.__init__ is a Python method in Lib/uuid.py; co_name is '__init__'; co_argcount is 7 (self + 6 positional args); uuid_extra60 covers co_name for __repr__/__str__/__hash__/__eq__; this spec extends to __init__; no prior uuid spec checks __init__.__code__ co_name or co_argcount; first code object anchor for UUID.__init__"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidmore62

  columns: [id, function, args, expected]
  rows:
    - [UUID_init_co_name,     UUID.__init__.__code__.co_name.__eq__,     ["__init__"], true]
    - [UUID_init_co_argcount, UUID.__init__.__code__.co_argcount.__eq__,  [7],          true]

# ---------------------------------------------------------------------------
# UUID.__str__ co_argcount and UUID.__hash__ co_argcount
#
# Wave 237 theme: UUID method code object argcounts.
#
# uuid_extra60 covers co_name for __str__ and __hash__ but not co_argcount.
# UUID.__str__.__code__.co_argcount == 1 (just self).
# UUID.__hash__.__code__.co_argcount == 1 (just self).
# No prior uuid spec checks __str__.__code__.co_argcount or
# __hash__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra62.UUID_methods_argcount:
  description: "uuid.UUID.__str__.__code__.co_argcount.__eq__(1)==True / UUID.__hash__.__code__.co_argcount.__eq__(1)==True — UUID.__str__ and UUID.__hash__ both take only self; uuid_extra60 covers co_name for these methods; this spec adds co_argcount; no prior uuid spec checks __str__ or __hash__ co_argcount; first co_argcount anchor for UUID.__str__ and UUID.__hash__"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidmore62

  columns: [id, function, args, expected]
  rows:
    - [UUID_str_co_argcount,  UUID.__str__.__code__.co_argcount.__eq__,  [1], true]
    - [UUID_hash_co_argcount, UUID.__hash__.__code__.co_argcount.__eq__, [1], true]

# ---------------------------------------------------------------------------
# uuid4 code object co_name and co_argcount
#
# Wave 237 theme: uuid4 function code object identity.
#
# uuid.uuid4 is a module-level Python function in Lib/uuid.py. Its code
# object co_name is 'uuid4' and co_argcount is 0 (no arguments).
# No prior uuid spec checks uuid4.__code__.co_name or co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra62.uuid4_code:
  description: "uuid.uuid4.__code__.co_name.__eq__('uuid4')==True / uuid4.__code__.co_argcount.__eq__(0)==True — uuid4 is a module-level Python function in Lib/uuid.py; co_name is 'uuid4'; co_argcount is 0; no prior uuid spec checks uuid4.__code__.co_name or co_argcount; first code object anchor for uuid4"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidmore62

  columns: [id, function, args, expected]
  rows:
    - [uuid4_co_name,     uuid4.__code__.co_name.__eq__,     ["uuid4"], true]
    - [uuid4_co_argcount, uuid4.__code__.co_argcount.__eq__,  [0],       true]

# ---------------------------------------------------------------------------
# uuid1 code object co_name and co_argcount
#
# Wave 237 theme: uuid1 function code object identity.
#
# uuid.uuid1 is a module-level Python function in Lib/uuid.py. Its code
# object co_name is 'uuid1' and co_argcount is 2 (node and clock_seq,
# both defaulting to None). No prior uuid spec checks uuid1.__code__.co_name
# or co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra62.uuid1_code:
  description: "uuid.uuid1.__code__.co_name.__eq__('uuid1')==True / uuid1.__code__.co_argcount.__eq__(2)==True — uuid1 is a module-level Python function in Lib/uuid.py; co_name is 'uuid1'; co_argcount is 2 (node, clock_seq); no prior uuid spec checks uuid1.__code__.co_name or co_argcount; first code object anchor for uuid1"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidmore62

  columns: [id, function, args, expected]
  rows:
    - [uuid1_co_name,     uuid1.__code__.co_name.__eq__,     ["uuid1"], true]
    - [uuid1_co_argcount, uuid1.__code__.co_argcount.__eq__,  [2],       true]

# ---------------------------------------------------------------------------
# UUID.__init__.__code__.co_name.__eq__('__init__') — standalone
#
# uuid.UUID.__init__ is defined in Lib/uuid.py. Its code object co_name is
# '__init__'. uuid_extra60 covers co_name for __repr__/__str__/__hash__/__eq__.
# No prior uuid spec checks __init__.__code__.co_name.
# First code object co_name standalone for UUID.__init__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra62.UUID_init_co_name:
  description: "uuid.UUID.__init__.__code__.co_name.__eq__('__init__') == True — UUID.__init__ is defined in Lib/uuid.py; code object co_name is '__init__'; uuid_extra60 covers co_name for __repr__/__str__/__hash__/__eq__; no prior uuid spec checks __init__.__code__.co_name; first code object co_name standalone for UUID.__init__"
  category: code_objects
  kind: python_call_eq
  function: UUID.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__init__.__code__.co_argcount.__eq__(7) — standalone
#
# uuid.UUID.__init__ takes self plus 6 positional args (hex, bytes, bytes_le,
# fields, int, version); is_safe is keyword-only and not in co_argcount.
# co_argcount is 7. No prior uuid spec checks __init__.__code__.co_argcount.
# First co_argcount standalone for UUID.__init__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra62.UUID_init_co_argcount:
  description: "uuid.UUID.__init__.__code__.co_argcount.__eq__(7) == True — UUID.__init__ takes self + 6 positional args (hex, bytes, bytes_le, fields, int, version); is_safe is keyword-only; co_argcount == 7; no prior uuid spec checks __init__.__code__.co_argcount; first co_argcount standalone for UUID.__init__"
  category: code_objects
  kind: python_call_eq
  function: UUID.__init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# uuid4.__code__.co_name.__eq__('uuid4') — standalone
#
# uuid.uuid4 is a module-level Python function. Code object co_name is 'uuid4'.
# No prior uuid spec checks uuid4.__code__.co_name.
# First code object co_name standalone for uuid4.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra62.uuid4_co_name:
  description: "uuid.uuid4.__code__.co_name.__eq__('uuid4') == True — uuid4 is a module-level Python function in Lib/uuid.py; co_name is 'uuid4'; no prior uuid spec checks uuid4.__code__.co_name; first code object co_name standalone for uuid4"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_name.__eq__
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid1.__code__.co_name.__eq__('uuid1') — standalone
#
# uuid.uuid1 is a module-level Python function. Code object co_name is 'uuid1'.
# No prior uuid spec checks uuid1.__code__.co_name.
# First code object co_name standalone for uuid1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra62.uuid1_co_name:
  description: "uuid.uuid1.__code__.co_name.__eq__('uuid1') == True — uuid1 is a module-level Python function in Lib/uuid.py; co_name is 'uuid1'; no prior uuid spec checks uuid1.__code__.co_name; first code object co_name standalone for uuid1"
  category: code_objects
  kind: python_call_eq
  function: uuid1.__code__.co_name.__eq__
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__hash__.__code__.co_argcount.__eq__(1) — standalone
#
# uuid.UUID.__hash__ takes only self; co_argcount is 1. uuid_extra60 covers
# co_name for __hash__. No prior uuid spec checks __hash__.__code__.co_argcount.
# First co_argcount standalone for UUID.__hash__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra62.UUID_hash_co_argcount:
  description: "uuid.UUID.__hash__.__code__.co_argcount.__eq__(1) == True — UUID.__hash__ takes only self; co_argcount == 1; uuid_extra60 covers co_name for __hash__; no prior uuid spec checks __hash__.__code__.co_argcount; first co_argcount standalone for UUID.__hash__"
  category: code_objects
  kind: python_call_eq
  function: UUID.__hash__.__code__.co_argcount.__eq__
  args: [1]
  expected: true
