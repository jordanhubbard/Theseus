    - ["it2536-012", "islice.__dict__.__contains__", ["__fspath__"], false]
    - ["it2536-013", "repeat.__dict__.__contains__", ["__format__"], false]
    - ["it2536-014", "repeat.__dict__.__contains__", ["__bytes__"], false]
