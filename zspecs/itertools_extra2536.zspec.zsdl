spec: itertools_extra2536
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: __format__, __bytes__, and __fspath__ dict-presence checks for itertools classes."
    - "Theme: custom formatting, bytes conversion, and filesystem path protocol dict-presence — checking whether classes define __format__, __bytes__, or __fspath__ in their class __dict__."
    - "All itertools classes covered here are lazy iterator types implemented in C; none define __format__, __bytes__, or __fspath__ in their class __dict__."
    - "itertools.chain lazily chains multiple iterables into a single sequence; it is a traversal type with no custom formatting, bytes representation, or path semantics. Verified with Python 3.14."
    - "itertools.cycle repeatedly cycles over an iterable's elements indefinitely; it is a looping iterator with no formatting, bytes-conversion, or filesystem path protocol. Verified with Python 3.14."
    - "itertools.count generates an infinite arithmetic sequence; despite its numeric nature, the class itself defines no __format__, __bytes__, or __fspath__ in its __dict__ — it produces values, it is not a value representation. Verified with Python 3.14."
    - "itertools.islice slices an iterable lazily by position; it is a filtering iterator with no formatting or path protocol. Verified with Python 3.14."
    - "itertools.repeat yields a single value a fixed or infinite number of times; it is a source iterator, not a data representation type. Verified with Python 3.14."
    - "itertools.product, itertools.permutations, itertools.combinations, and itertools.combinations_with_replacement are combinatorial iterators; they enumerate structured sequences but define no custom formatting, bytes, or path protocol. Verified with Python 3.14."
    - "itertools.compress, itertools.dropwhile, itertools.takewhile, and itertools.filterfalse are filter-style iterators that select elements based on a condition; they carry no format, bytes, or fspath protocol in their own __dict__. Verified with Python 3.14."
    - "itertools.groupby groups consecutive elements by a key function; itertools.starmap applies a function to argument tuples; itertools.accumulate produces running aggregates; itertools.pairwise yields consecutive overlapping pairs. None define __format__, __bytes__, or __fspath__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain, itertools.cycle, itertools.count
#
# Theme: __format__, __bytes__, __fspath__ absent from chain, cycle, count.__dict__.
# chain lazily chains iterables; cycle repeats them indefinitely; count produces
# an infinite arithmetic sequence. All three are C iterator types with no custom
# formatting, bytes conversion, or filesystem path protocol in their class __dict__.
# ---------------------------------------------------------------------------

table itertools_extra2536.chain_cycle_count_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from itertools.chain, cycle, count __dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: it2536

  columns: [id, function, args, expected]
  rows:
    - ["it2536-001", "chain.__dict__.__contains__", ["__format__"], false]
    - ["it2536-002", "chain.__dict__.__contains__", ["__bytes__"], false]
    - ["it2536-003", "chain.__dict__.__contains__", ["__fspath__"], false]
    - ["it2536-004", "cycle.__dict__.__contains__", ["__format__"], false]
    - ["it2536-005", "cycle.__dict__.__contains__", ["__bytes__"], false]
    - ["it2536-006", "cycle.__dict__.__contains__", ["__fspath__"], false]
    - ["it2536-007", "count.__dict__.__contains__", ["__format__"], false]
    - ["it2536-008", "count.__dict__.__contains__", ["__bytes__"], false]
    - ["it2536-009", "count.__dict__.__contains__", ["__fspath__"], false]

