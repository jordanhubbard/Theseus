spec: urllib_parse_extra11
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __name__; urlparse/urlsplit/urljoin/urlencode __name__; _fields content"
    - "urllib_parse_extra2.zspec.zsdl — covers quote/unquote/quote_plus/unquote_plus/parse_qs/parse_qsl __name__"
    - "urllib_parse_extra3.zspec.zsdl — covers urlparse scheme/netloc/path; quote/unquote value vectors"
    - "urllib_parse_extra4.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __qualname__; function qualnames"
    - "urllib_parse_extra5.zspec.zsdl — covers quote_plus/unquote_plus/parse_qs/parse_qsl qualnames; urlparse.__module__"
    - "urllib_parse_extra6.zspec.zsdl — covers result type __module__; function __module__ for urlsplit/urljoin/urlencode/quote/unquote"
    - "urllib_parse_extra7.zspec.zsdl — covers function __module__ for quote_plus/unquote_plus/parse_qs/parse_qsl/urldefrag; urlsplit behavioral; urldefrag behavioral"
    - "urllib_parse_extra8.zspec.zsdl — covers urlsplit port/fragment/username/password; urlunparse/urlunsplit behavioral; quote_plus numeric; unquote_plus plus_to_space"
    - "urllib_parse_extra9.zspec.zsdl — covers function __class__.__name__ type checks; DefragResult/_SplitResult/ParseResult _fields length; parse_qs empty string"
    - "urllib_parse_extra10.zspec.zsdl — covers quote_from_bytes/unquote_to_bytes identity and behavioral; SplitResult._fields[2..4]; ParseResult._fields[4..5]; urlsplit scheme/netloc/path"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl through urllib_parse_extra10.zspec.zsdl."
    - "urllib.parse.quote('hello world') == 'hello%20world' — space is encoded as %20 (default safe='/')."
    - "urllib.parse.quote('/path/to/file', safe='') == '%2Fpath%2Fto%2Ffile' — safe='' causes slashes to encode."
    - "urllib.parse.unquote('hello%20world') == 'hello world' — %20 decodes to space."
    - "urllib.parse.urlencode({'key': 'value', 'foo': 'bar'}) returns a str — key ordering follows dict insertion order in Python 3.7+."
    - "urllib.parse.urlparse('https://example.com/path').__class__.__name__ == 'ParseResult'."
    - "urllib.parse.urljoin('http://example.com/', 'path') == 'http://example.com/path'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# urllib.parse.quote — behavioral vectors with default and explicit safe=''
#
# urllib_parse_extra3 covers quote('hello') and quote('%') as raw value checks.
# The space-to-%20 encoding and slash encoding with safe='' are new axes.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra11.quote.space:
  description: "urllib.parse.quote('hello world') == 'hello%20world' — space encodes to %20"
  category: quote
  kind: python_call_eq
  function: quote
  args: ["hello world"]
  expected: "hello%20world"

invariant urllib_parse_extra11.quote.slash_safe_empty:
  description: "urllib.parse.quote('/path/to/file', safe='') == '%2Fpath%2Fto%2Ffile' — slashes encode when safe=''"
  category: quote
  kind: python_call_eq
  function: quote
  args: ["/path/to/file"]
  kwargs: {safe: ""}
  expected: "%2Fpath%2Fto%2Ffile"

# ---------------------------------------------------------------------------
# urllib.parse.unquote — percent-decode %20 to space
#
# urllib_parse_extra3 covers unquote('hello') == 'hello' and unquote('%26') == '&'.
# The %20-to-space decode is a new vector.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra11.unquote.percent20:
  description: "urllib.parse.unquote('hello%20world') == 'hello world' — %20 decodes to space"
  category: unquote
  kind: python_call_eq
  function: unquote
  args: ["hello%20world"]
  expected: "hello world"

# ---------------------------------------------------------------------------
# urllib.parse.urlencode — return type is str
#
# urllib_parse_extra covers urlencode.__name__; no prior spec tests the return
# type of urlencode. Key order in Python 3.7+ dicts is insertion order, so
# {'key': 'value', 'foo': 'bar'} → 'key=value&foo=bar', but testing the
# class name is safer than testing the exact string value.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra11.urlencode.return_class:
  description: "urllib.parse.urlencode({'key': 'value', 'foo': 'bar'}).__class__.__name__ == 'str'"
  category: urlencode
  kind: python_call_eq
  function: urlencode
  args: [{"key": "value", "foo": "bar"}]
  method: __class__
  method_args: []
  expected: "str"

# ---------------------------------------------------------------------------
# urllib.parse.urlparse — result type is ParseResult
#
# urllib_parse_extra covers ParseResult.__name__; urllib_parse_extra3 covers
# urlparse scheme/netloc/path. The __class__.__name__ of the return value
# as a direct behavioral check on urlparse itself is new.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra11.urlparse.result_class:
  description: "urllib.parse.urlparse('https://example.com/path').__class__.__name__ == 'ParseResult'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["https://example.com/path"]
  method: __class__
  method_args: []
  expected: "ParseResult"

# ---------------------------------------------------------------------------
# urllib.parse.urljoin — simple relative path join
#
# urllib_parse_extra covers urljoin.__name__; no prior spec checks the return
# value of urljoin with a trailing-slash base and a bare relative path.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra11.urljoin.relative_path:
  description: "urllib.parse.urljoin('http://example.com/', 'path') == 'http://example.com/path'"
  category: urljoin
  kind: python_call_eq
  function: urljoin
  args: ["http://example.com/", "path"]
  expected: "http://example.com/path"
