spec: multiprocessing_extra706
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers multiprocessing.pool.Pool lifecycle methods and AsyncResult, MapResult, IMapIterator identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra706.pool_method_identity:
  description: "Identity checks for multiprocessing.pool.Pool method qualnames"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp706pm
  columns: [id, function, args, expected]
  rows:
    - [mp706pm001, multiprocessing.pool.Pool.terminate.__qualname__.__eq__, ["Pool.terminate"], true]
    - [mp706pm002, multiprocessing.pool.Pool.join.__qualname__.__eq__, ["Pool.join"], true]
    - [mp706pm003, multiprocessing.pool.Pool.__enter__.__qualname__.__eq__, ["Pool.__enter__"], true]
    - [mp706pm004, multiprocessing.pool.Pool.__exit__.__qualname__.__eq__, ["Pool.__exit__"], true]

table multiprocessing_extra706.async_result_identity:
  description: "Identity checks for multiprocessing.pool.AsyncResult class and method qualnames"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp706ar
  columns: [id, function, args, expected]
  rows:
    - [mp706ar001, multiprocessing.pool.AsyncResult.__qualname__.__eq__, ["AsyncResult"], true]
    - [mp706ar002, multiprocessing.pool.AsyncResult.__module__.__eq__, ["multiprocessing.pool"], true]
    - [mp706ar003, multiprocessing.pool.AsyncResult.get.__qualname__.__eq__, ["AsyncResult.get"], true]
    - [mp706ar004, multiprocessing.pool.AsyncResult.wait.__qualname__.__eq__, ["AsyncResult.wait"], true]
    - [mp706ar005, multiprocessing.pool.AsyncResult.ready.__qualname__.__eq__, ["AsyncResult.ready"], true]
    - [mp706ar006, multiprocessing.pool.AsyncResult.successful.__qualname__.__eq__, ["AsyncResult.successful"], true]

table multiprocessing_extra706.result_type_identity:
  description: "Identity checks for multiprocessing.pool MapResult and IMapIterator class qualnames"
