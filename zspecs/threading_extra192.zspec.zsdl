spec: threading_extra192
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Event.__name__ == 'Event' (len=5); Event is a regular Python class defined in the threading module; verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' (len=9); Event is defined in Lib/threading.py; verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object'; Event inherits directly from object with no intermediary base; verified with Python 3.14.3."
    - "threading.Event.__init__.__qualname__ == 'Event.__init__' (len=14); the qualified name encodes the containing class; verified with Python 3.14.3."
    - "threading.Event.set.__name__ == 'set' (len=3); sets the internal flag to True, waking all waiting threads; verified with Python 3.14.3."
    - "threading.Event.wait.__name__ == 'wait' (len=4); blocks until the internal flag is true; verified with Python 3.14.3."
    - "threading.Event.clear.__name__ == 'clear' (len=5); resets the internal flag to False; verified with Python 3.14.3."
    - "threading.Event.is_set.__name__ == 'is_set' (len=6); returns True if and only if the internal flag is true; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Event class identity — __name__, __module__, __bases__
#
# threading.Event.__name__              == 'Event' (len=5)
# threading.Event.__module__            == 'threading' (len=9)
# threading.Event.__bases__[0].__name__ == 'object'
#
# Event is a regular Python class defined in Lib/threading.py that implements
# a simple flag-based signalling primitive. It inherits directly from object.
# New to extra192.
# ---------------------------------------------------------------------------

table threading_extra192.event_class_identity:
  description: "threading.Event class identity: __name__=='Event'(len=5); __module__=='threading'(len=9); __bases__[0].__name__=='object'; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: threadingevent192

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a Python-level synchronization primitive class; __name__ is 'Event' (len=5: E-v-e-n-t); str.__eq__('Event') returns True; verified with Python 3.14.3; new to extra192"]
    - [event_name_len,
       Event.__name__.__len__,
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters: E-v-e-n-t; str.__len__() returns 5; verified with Python 3.14.3; new to extra192"]
    - [event_module_eq,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading' (len=9: t-h-r-e-a-d-i-n-g); str.__eq__('threading') returns True; verified with Python 3.14.3; new to extra192"]
    - [event_module_len,
       Event.__module__.__len__,
       [],
       9,
       "threading.Event.__module__.__len__() == 9 — 'threading' has 9 characters: t-h-r-e-a-d-i-n-g; str.__len__() returns 9; verified with Python 3.14.3; new to extra192"]
    - [event_bases_object,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event inherits directly from object with no intermediary base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event method __name__ values — set, wait, clear, is_set
#
# threading.Event.set.__name__    == 'set' (len=3)
# threading.Event.wait.__name__   == 'wait' (len=4)
# threading.Event.clear.__name__  == 'clear' (len=5)
# threading.Event.is_set.__name__ == 'is_set' (len=6)
#
# These four methods are the public API of Event. set() wakes all waiters;
# wait() blocks until the flag is set; clear() resets the flag; is_set()
# queries the flag. The __name__ values match their method name strings.
# New to extra192.
# ---------------------------------------------------------------------------

table threading_extra192.event_method_names:
  description: "threading.Event method __name__ values: set.__name__=='set'(len=3); wait.__name__=='wait'(len=4); clear.__name__=='clear'(len=5); is_set.__name__=='is_set'(len=6); new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: threadingevent192

  columns: [id, function, args, expected, description]
  rows:
    - [set_name_eq,
       Event.set.__name__.__eq__,
       ["set"],
       true,
       "threading.Event.set.__name__.__eq__('set') == True — set() sets the internal flag to True and wakes all threads waiting on wait(); __name__ is 'set' (len=3: s-e-t); str.__eq__('set') returns True; verified with Python 3.14.3; new to extra192"]
    - [set_name_len,
       Event.set.__name__.__len__,
       [],
       3,
       "threading.Event.set.__name__.__len__() == 3 — 'set' has 3 characters: s-e-t; str.__len__() returns 3; verified with Python 3.14.3; new to extra192"]
    - [wait_name_eq,
       Event.wait.__name__.__eq__,
       ["wait"],
       true,
       "threading.Event.wait.__name__.__eq__('wait') == True — wait() blocks until the internal flag is true or an optional timeout expires; __name__ is 'wait' (len=4: w-a-i-t); str.__eq__('wait') returns True; verified with Python 3.14.3; new to extra192"]
    - [wait_name_len,
       Event.wait.__name__.__len__,
       [],
       4,
       "threading.Event.wait.__name__.__len__() == 4 — 'wait' has 4 characters: w-a-i-t; str.__len__() returns 4; verified with Python 3.14.3; new to extra192"]
    - [clear_name_eq,
       Event.clear.__name__.__eq__,
       ["clear"],
       true,
       "threading.Event.clear.__name__.__eq__('clear') == True — clear() resets the internal flag to False so subsequent wait() calls block again; __name__ is 'clear' (len=5: c-l-e-a-r); str.__eq__('clear') returns True; verified with Python 3.14.3; new to extra192"]
    - [is_set_name_eq,
       Event.is_set.__name__.__eq__,
       ["is_set"],
       true,
       "threading.Event.is_set.__name__.__eq__('is_set') == True — is_set() returns True if the internal flag is set; __name__ is 'is_set' (len=6: i-s-_-s-e-t); str.__eq__('is_set') returns True; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 3: threading.Event.__init__.__qualname__ identity
#
# threading.Event.__init__.__qualname__ == 'Event.__init__' (len=14)
#
# The qualified name of Event.__init__ encodes the containing class name
# followed by a dot and the method name. 'Event.__init__' has 14 characters:
# 'Event' (5) + '.' (1) + '__init__' (8). New to extra192.
# ---------------------------------------------------------------------------

table threading_extra192.event_init_qualname:
  description: "threading.Event.__init__.__qualname__ identity: __qualname__=='Event.__init__'(len=14); encodes containing class and method name; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: threadingevent192

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,
       Event.__init__.__qualname__.__eq__,
       ["Event.__init__"],
       true,
       "threading.Event.__init__.__qualname__.__eq__('Event.__init__') == True — the __qualname__ of a method encodes its containing class; 'Event.__init__' is the qualified name: 'Event' (5 chars) + '.' (1 char) + '__init__' (8 chars) = 14 chars total; str.__eq__('Event.__init__') returns True; verified with Python 3.14.3; new to extra192"]
    - [init_qualname_len,
       Event.__init__.__qualname__.__len__,
       [],
       14,
       "threading.Event.__init__.__qualname__.__len__() == 14 — 'Event.__init__' has 14 characters: E-v-e-n-t-.-_-_-i-n-i-t-_-_; 5 for 'Event' + 1 for '.' + 8 for '__init__'; str.__len__() returns 14; verified with Python 3.14.3; new to extra192"]
    - [is_set_name_len,
       Event.is_set.__name__.__len__,
       [],
       6,
       "threading.Event.is_set.__name__.__len__() == 6 — 'is_set' has 6 characters: i-s-_-s-e-t; is_set is the preferred modern name (not the deprecated isSet alias); str.__len__() returns 6; verified with Python 3.14.3; new to extra192"]
    - [clear_name_len,
       Event.clear.__name__.__len__,
       [],
       5,
       "threading.Event.clear.__name__.__len__() == 5 — 'clear' has 5 characters: c-l-e-a-r; str.__len__() returns 5; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra192
# ---------------------------------------------------------------------------

invariant threading_extra192.event_name_eq:
  description: "threading.Event.__name__.__eq__('Event') == True — Event is the Python-level flag-based signalling class in the threading module; __name__ is 'Event' (len=5); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra192.event_module_eq:
  description: "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading' (len=9); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra192.event_bases_object:
  description: "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event inherits directly from object with no intermediary base; __bases__[0].__name__ is 'object'; verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra192.event_init_qualname_eq:
  description: "threading.Event.__init__.__qualname__.__eq__('Event.__init__') == True — the qualified name encodes the class and method: 'Event.__init__' (len=14: 5+1+8); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Event.__init__.__qualname__.__eq__
  args: ["Event.__init__"]
  expected: true

invariant threading_extra192.event_set_name_eq:
  description: "threading.Event.set.__name__.__eq__('set') == True — set() signals the event by setting the internal flag to True and waking all waiters; __name__ is 'set' (len=3); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Event.set.__name__.__eq__
  args: ["set"]
  expected: true

invariant threading_extra192.event_wait_name_eq:
  description: "threading.Event.wait.__name__.__eq__('wait') == True — wait() blocks the calling thread until the internal flag is true; __name__ is 'wait' (len=4); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Event.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra192.event_clear_name_eq:
  description: "threading.Event.clear.__name__.__eq__('clear') == True — clear() resets the internal flag to False; subsequent wait() calls will block; __name__ is 'clear' (len=5); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Event.clear.__name__.__eq__
  args: ["clear"]
  expected: true

invariant threading_extra192.event_is_set_name_eq:
  description: "threading.Event.is_set.__name__.__eq__('is_set') == True — is_set() returns True iff the internal flag is set; __name__ is 'is_set' (len=6: i-s-_-s-e-t); not 'isSet' (the old deprecated alias); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Event.is_set.__name__.__eq__
  args: ["is_set"]
  expected: true
