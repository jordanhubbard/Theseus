spec: logging_extra13
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra12.zspec.zsdl."
    - "logging_extra12 covers MRO lengths for NullHandler/Filter/LogRecord/Filterer/FileHandler; NullHandler base class; getLevelName string->int for INFO/WARNING/ERROR/CRITICAL/NOTSET."
    - "logging_extra10 covers getLevelName int->str for DEBUG; getLevelName str->int for DEBUG."
    - "logging_extra12 covers getLevelName str->int for INFO/WARNING/ERROR/CRITICAL/NOTSET."
    - "NOT yet covered: logging.CRITICAL == 50 as a standalone module-level constant invariant."
    - "NOT yet covered: logging.ERROR == 40 as a standalone module-level constant invariant."
    - "NOT yet covered: logging.WARNING == 30 as a standalone module-level constant invariant."
    - "NOT yet covered: logging.INFO == 20 as a standalone module-level constant invariant."
    - "NOT yet covered: logging.DEBUG == 10 as a standalone module-level constant invariant."
    - "NOT yet covered: logging.NOTSET == 0 as a standalone module-level constant invariant."
    - "NOT yet covered: logging.getLevelName(10) == 'DEBUG' as a standalone invariant (int->str direction for DEBUG)."
    - "NOT yet covered: logging.getLevelName('WARNING') == 30 verified via int equality (already in extra12 as str->int)."
    - "NOT yet covered: getLogger.__name__ == 'getLogger' as a standalone invariant."
    - "NOT yet covered: basicConfig.__name__ == 'basicConfig' as a standalone invariant."
    - "NOT yet covered: disable.__name__ == 'disable' as a standalone invariant."
    - "NOT yet covered: captureWarnings.__name__ == 'captureWarnings' as a standalone invariant."
    - "logging.CRITICAL == 50, ERROR == 40, WARNING == 30, INFO == 20, DEBUG == 10, NOTSET == 0 — all verified."
    - "logging.getLevelName(10) == 'DEBUG' — integer-to-name direction for the DEBUG level."
    - "getLogger, basicConfig, disable, captureWarnings are module-level functions with matching __name__ strings."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level level constants — CRITICAL, ERROR, WARNING, INFO, DEBUG, NOTSET
#
# These integer constants are the canonical numeric logging levels. No prior
# spec asserts them as standalone module-constant invariants using the
# __eq__ predicate form. logging_extra12 covers the string->int direction
# via getLevelName; this spec records the constants directly.
# ---------------------------------------------------------------------------

invariant logging_extra13.CRITICAL.value:
  description: "logging.CRITICAL == 50 — module-level integer constant"
  category: level_constants
  kind: python_call_eq
  function: CRITICAL.__eq__
  args: [50]
  expected: true

invariant logging_extra13.ERROR.value:
  description: "logging.ERROR == 40 — module-level integer constant"
  category: level_constants
  kind: python_call_eq
  function: ERROR.__eq__
  args: [40]
  expected: true

invariant logging_extra13.WARNING.value:
  description: "logging.WARNING == 30 — module-level integer constant"
  category: level_constants
  kind: python_call_eq
  function: WARNING.__eq__
  args: [30]
  expected: true

invariant logging_extra13.INFO.value:
  description: "logging.INFO == 20 — module-level integer constant"
  category: level_constants
  kind: python_call_eq
  function: INFO.__eq__
  args: [20]
  expected: true

invariant logging_extra13.DEBUG.value:
  description: "logging.DEBUG == 10 — module-level integer constant"
  category: level_constants
  kind: python_call_eq
  function: DEBUG.__eq__
  args: [10]
  expected: true

invariant logging_extra13.NOTSET.value:
  description: "logging.NOTSET == 0 — module-level integer constant"
  category: level_constants
  kind: python_call_eq
  function: NOTSET.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# getLevelName — integer → name direction for DEBUG
#
# logging_extra10 documents getLevelName(int)->str. No prior spec records
# getLevelName(10) == 'DEBUG' as a standalone invariant using __eq__ predicate
# form. This is the int-to-name direction for the lowest standard level.
# ---------------------------------------------------------------------------

invariant logging_extra13.getLevelName.debug_int_to_str:
  description: "logging.getLevelName(10) == 'DEBUG' — integer-to-name direction"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [10]
  method: __eq__
  method_args: ["DEBUG"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __name__ checks
#
# No prior logging spec records __name__ for getLogger, basicConfig, disable,
# or captureWarnings as standalone __eq__ invariants. These are all top-level
# functions whose __name__ matches their unqualified identifier.
# ---------------------------------------------------------------------------

invariant logging_extra13.getLogger.name:
  description: "logging.getLogger.__name__ == 'getLogger'"
  category: function_names
  kind: python_call_eq
  function: getLogger.__name__.__eq__
  args: ["getLogger"]
  expected: true

invariant logging_extra13.basicConfig.name:
  description: "logging.basicConfig.__name__ == 'basicConfig'"
  category: function_names
  kind: python_call_eq
  function: basicConfig.__name__.__eq__
  args: ["basicConfig"]
  expected: true

invariant logging_extra13.disable.name:
  description: "logging.disable.__name__ == 'disable'"
  category: function_names
  kind: python_call_eq
  function: disable.__name__.__eq__
  args: ["disable"]
  expected: true

invariant logging_extra13.captureWarnings.name:
  description: "logging.captureWarnings.__name__ == 'captureWarnings'"
  category: function_names
  kind: python_call_eq
  function: captureWarnings.__name__.__eq__
  args: ["captureWarnings"]
  expected: true
