spec: struct_extra2296
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "struct.Struct is a C extension type from _struct; __module__ == '_struct'."
    - "struct.error is a pure-Python exception class re-exported from the struct wrapper; __module__ == 'struct'."
    - "struct.Struct.__qualname__ == 'Struct', struct.Struct.__name__ == 'Struct'."
    - "struct.error.__qualname__ == 'error', struct.error.__name__ == 'error'."
    - "struct module itself: __name__ == 'struct', __package__ == ''."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2296.struct_class_module:
  description: "struct.Struct __module__, __qualname__, __name__ — C extension type from _struct"
  kind: python_call_eq
  category: module_identity
  id_prefix: st2296

  columns: [id, function, args, expected]
  rows:
    - ["st2296001", "struct.Struct.__module__", [], "_struct"]
    - ["st2296002", "struct.Struct.__qualname__", [], "Struct"]
    - ["st2296003", "struct.Struct.__name__", [], "Struct"]

table struct_extra2296.error_class_module:
  description: "struct.error __module__, __qualname__, __name__ — pure Python exception"
  kind: python_call_eq
  category: module_identity
  id_prefix: st2296

  columns: [id, function, args, expected]
  rows:
    - ["st2296004", "struct.error.__module__", [], "struct"]
    - ["st2296005", "struct.error.__qualname__", [], "error"]
    - ["st2296006", "struct.error.__name__", [], "error"]

table struct_extra2296.module_level:
  description: "struct module-level identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: st2296

  columns: [id, function, args, expected]
  rows:
    - ["st2296007", "struct.__name__", [], "struct"]
    - ["st2296008", "struct.__package__", [], ""]

table struct_extra2296.c_vs_python_cross_check:
  description: "Cross-check: Struct (C extension) vs error (pure Python) — different __module__ values"
  kind: python_call_eq
  category: module_identity
  id_prefix: st2296

  columns: [id, function, args, expected]
  rows:
    - ["st2296009", "struct.Struct.__module__", [], "_struct"]
    - ["st2296010", "struct.error.__module__", [], "struct"]
    - ["st2296011", "struct.Struct.__qualname__", [], "Struct"]
    - ["st2296012", "struct.error.__qualname__", [], "error"]
    - ["st2296013", "struct.Struct.__name__", [], "Struct"]
    - ["st2296014", "struct.error.__name__", [], "error"]
    - ["st2296015", "struct.__name__", [], "struct"]
    - ["st2296016", "struct.__package__", [], ""]
    - ["st2296017", "struct.Struct.__module__", [], "_struct"]
    - ["st2296018", "struct.error.__module__", [], "struct"]
    - ["st2296019", "struct.Struct.__qualname__", [], "Struct"]
    - ["st2296020", "struct.error.__qualname__", [], "error"]
