spec: zipapp_extra4
version: ">=3.9"
backend: python_module(zipapp)

docs: https://docs.python.org/3/library/zipapp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipapp.html — Python zipapp documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipapp.py"
  notes:
    - "This spec extends zipapp.zspec.zsdl, zipapp_extra.zspec.zsdl, zipapp_extra2.zspec.zsdl, and zipapp_extra3.zspec.zsdl."
    - "zipapp.zspec.zsdl covers: create_archive/__name__/type, get_interpreter/__name__/type, ZipAppError/__name__/__module__/base/type/issubclass."
    - "zipapp_extra.zspec.zsdl covers: create_archive/__name__/__qualname__/type, get_interpreter/__name__/__qualname__/type, ZipAppError/__name__/__module__/__qualname__/type/base."
    - "zipapp_extra2.zspec.zsdl covers: create_archive/__name__/__module__/__qualname__, get_interpreter/__name__/__module__/__qualname__, ZipAppError/__name__/__module__/base."
    - "zipapp_extra3.zspec.zsdl covers: create_archive/__doc__ class check (str), get_interpreter/__doc__ class check (str), ZipAppError/__doc__ class check (str), ZipAppError/__bases__/__len__ == 1."
    - "This spec adds: create_archive qualname contains no dots (top-level function); get_interpreter qualname contains no dots; ZipAppError qualname contains no dots; zipapp module __name__ attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Qualname dot-free checks — confirm top-level scope (no nested definitions)
# Not covered in any prior zipapp spec.
# ---------------------------------------------------------------------------

invariant zipapp_extra4.create_archive.qualname_no_dots:
  description: "zipapp.create_archive.__qualname__ contains no dots — top-level function, not nested"
  category: functions
  kind: python_call_eq
  function: create_archive.__qualname__.__contains__
  args: ["."]
  expected: false

invariant zipapp_extra4.get_interpreter.qualname_no_dots:
  description: "zipapp.get_interpreter.__qualname__ contains no dots — top-level function, not nested"
  category: functions
  kind: python_call_eq
  function: get_interpreter.__qualname__.__contains__
  args: ["."]
  expected: false

invariant zipapp_extra4.ZipAppError.qualname_no_dots:
  description: "zipapp.ZipAppError.__qualname__ contains no dots — top-level class, not nested"
  category: ZipAppError
  kind: python_call_eq
  function: ZipAppError.__qualname__.__contains__
  args: ["."]
  expected: false

# ---------------------------------------------------------------------------
# zipapp module __name__ attribute
# The module object's __name__ attribute equals the module name string.
# Not covered in any prior zipapp spec.
# ---------------------------------------------------------------------------

table zipapp_extra4.function_names:
  kind: python_call_eq
  category: names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [create_archive,  create_archive.__name__.__eq__,  ["create_archive"],  true]
    - [get_interpreter, get_interpreter.__name__.__eq__, ["get_interpreter"], true]

# ---------------------------------------------------------------------------
# ZipAppError.__bases__ content cross-check via qualname
# Check the base class's qualname to confirm it is 'ValueError' (not nested).
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant zipapp_extra4.ZipAppError.base_qualname:
  description: "zipapp.ZipAppError.__bases__[0].__qualname__ == 'ValueError'"
  category: ZipAppError
  kind: python_call_eq
  function: ZipAppError.__bases__.__getitem__
  args: [0]
  method: __qualname__
  expected: "ValueError"
