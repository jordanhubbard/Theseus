spec: functools_extra241
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.lru_cache and functools.cache decorator function identity contracts."
    - "functools.lru_cache.__name__ == 'lru_cache' (len=9) — the decorator function name. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' (len=9) — lru_cache is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len=9) — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a Python function. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('maxsize') == True — docstring mentions maxsize parameter. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' (len=5) — the simple cache decorator name. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' (len=9) — cache is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache' (len=5) — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.cache.__class__.__name__ == 'function' — cache is a Python function. Verified with Python 3.14.3."
    - "functools.cache.__doc__.__contains__('unbounded') == True — docstring describes it as unbounded cache. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache function identity contracts
#
# functools.lru_cache.__name__ == 'lru_cache' (len=9)
# functools.lru_cache.__module__ == 'functools' (len=9)
# functools.lru_cache.__qualname__ == 'lru_cache' (len=9)
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__doc__.__contains__('maxsize') == True
#
# lru_cache is a Python function (decorator) in Lib/functools.py. New to extra241.
# ---------------------------------------------------------------------------

table functools_extra241.lru_cache_function_identity:
  description: "functools.lru_cache decorator function identity: name, module, qualname, class, doc contains maxsize; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra241lrucacheid

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a Python decorator function in Lib/functools.py; __name__ is 'lru_cache' (len=9); new to extra241"]
    - [lru_cache_name_len_9,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has exactly 9 characters (l-r-u-_-c-a-c-h-e); str.__len__() returns 9; new to extra241"]
    - [lru_cache_module_eq,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra241"]
    - [lru_cache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a top-level function with unqualified qualname 'lru_cache'; new to extra241"]
    - [lru_cache_class_is_function,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a Python function; its __class__ is the built-in function type; new to extra241"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache doc and length contracts
#
# functools.lru_cache.__doc__.__contains__('maxsize') == True
# functools.lru_cache.__doc__.__contains__('typed') == True
# functools.lru_cache.__doc__.__class__.__name__ == 'str'
# functools.lru_cache.__module__.__len__() == 9
# functools.lru_cache.__qualname__.__len__() == 9
#
# lru_cache docstring describes maxsize and typed parameters. New to extra241.
# ---------------------------------------------------------------------------

table functools_extra241.lru_cache_doc_and_lengths:
  description: "functools.lru_cache doc contains 'maxsize' and 'typed'; module length 9; qualname length 9; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra241lrucachedoc

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_doc_contains_maxsize,
       lru_cache.__doc__.__contains__,
       ["maxsize"],
       true,
       "functools.lru_cache.__doc__.__contains__('maxsize') == True — docstring describes the maxsize parameter controlling cache capacity; str.__contains__('maxsize') returns True; new to extra241"]
    - [lru_cache_doc_contains_typed,
       lru_cache.__doc__.__contains__,
       ["typed"],
       true,
       "functools.lru_cache.__doc__.__contains__('typed') == True — docstring describes the typed parameter controlling type-based cache keys; str.__contains__('typed') returns True; new to extra241"]
    - [lru_cache_doc_class_is_str,
       lru_cache.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__name__.__eq__('str') == True — the lru_cache docstring is a plain Python str object; new to extra241"]
    - [lru_cache_module_len_9,
       lru_cache.__module__.__len__,
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — 'functools' has exactly 9 characters (f-u-n-c-t-o-o-l-s); str.__len__() returns 9; new to extra241"]
    - [lru_cache_qualname_len_9,
       lru_cache.__qualname__.__len__,
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — 'lru_cache' qualname has exactly 9 characters; str.__len__() returns 9; new to extra241"]

# ---------------------------------------------------------------------------
# Table 3: functools.cache function identity and doc contracts
#
# functools.cache.__name__ == 'cache' (len=5)
# functools.cache.__module__ == 'functools' (len=9)
# functools.cache.__qualname__ == 'cache' (len=5)
# functools.cache.__class__.__name__ == 'function'
# functools.cache.__doc__.__contains__('unbounded') == True
#
# cache is a simple unbounded cache decorator in Lib/functools.py. New to extra241.
# ---------------------------------------------------------------------------

table functools_extra241.cache_function_identity:
  description: "functools.cache decorator identity: name, module, qualname, class is function; doc contains 'unbounded'; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra241cacheid

  columns: [id, function, args, expected, description]
  rows:
    - [cache_name_eq,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — cache is a Python decorator function in Lib/functools.py; __name__ is 'cache' (len=5); new to extra241"]
    - [cache_name_len_5,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' has exactly 5 characters (c-a-c-h-e); str.__len__() returns 5; new to extra241"]
    - [cache_module_eq,
       cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra241"]
    - [cache_qualname_eq,
       cache.__qualname__.__eq__,
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — cache is a top-level function with unqualified qualname 'cache'; new to extra241"]
    - [cache_doc_contains_unbounded,
       cache.__doc__.__contains__,
       ["unbounded"],
       true,
       "functools.cache.__doc__.__contains__('unbounded') == True — docstring describes it as 'Simple lightweight unbounded cache'; str.__contains__('unbounded') returns True; new to extra241"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra241
# ---------------------------------------------------------------------------

invariant functools_extra241.lru_cache_name_eq:
  description: "functools.lru_cache.__name__ == 'lru_cache' (len=9); new to extra241"
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra241.lru_cache_name_len_9:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra241"
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra241.lru_cache_module_eq:
  description: "functools.lru_cache.__module__ == 'functools'; new to extra241"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra241.lru_cache_module_len_9:
  description: "functools.lru_cache.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra241"
  kind: python_call_eq
  function: lru_cache.__module__.__len__
  args: []
  expected: 9

invariant functools_extra241.lru_cache_qualname_eq:
  description: "functools.lru_cache.__qualname__ == 'lru_cache'; new to extra241"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra241.lru_cache_class_is_function:
  description: "functools.lru_cache.__class__.__name__ == 'function'; new to extra241"
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra241.lru_cache_doc_contains_maxsize:
  description: "functools.lru_cache.__doc__.__contains__('maxsize') == True; new to extra241"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["maxsize"]
  expected: true

invariant functools_extra241.lru_cache_doc_contains_typed:
  description: "functools.lru_cache.__doc__.__contains__('typed') == True; new to extra241"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["typed"]
  expected: true

invariant functools_extra241.cache_name_eq:
  description: "functools.cache.__name__ == 'cache' (len=5); new to extra241"
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra241.cache_name_len_5:
  description: "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters; new to extra241"
  kind: python_call_eq
  function: cache.__name__.__len__
  args: []
  expected: 5

invariant functools_extra241.cache_module_eq:
  description: "functools.cache.__module__ == 'functools'; new to extra241"
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra241.cache_qualname_eq:
  description: "functools.cache.__qualname__ == 'cache'; new to extra241"
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra241.cache_doc_contains_unbounded:
  description: "functools.cache.__doc__.__contains__('unbounded') == True; new to extra241"
  kind: python_call_eq
  function: cache.__doc__.__contains__
  args: ["unbounded"]
  expected: true

invariant functools_extra241.cache_class_is_function:
  description: "functools.cache.__class__.__name__ == 'function'; new to extra241"
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true
