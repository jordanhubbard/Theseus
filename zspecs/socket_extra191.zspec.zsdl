spec: socket_extra191
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "socket source: internal BSD socket implementation"
  notes:
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member; len=13."
    - "socket.AF_INET.__class__.__module__ == 'socket' — AddressFamily is defined in the socket module."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — same enum class as AF_INET."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is a SocketKind IntEnum member; len=10."
    - "socket.SOCK_STREAM.__class__.__module__ == 'socket' — SocketKind is defined in the socket module."
    - "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — same enum class as SOCK_STREAM."
    - "AddressFamily has 13 characters; SocketKind has 10 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: AF_INET and AF_INET6 — AddressFamily enum identity
#
# socket.AF_INET.__class__.__name__   == 'AddressFamily'  (len=13)
# socket.AF_INET.__class__.__module__ == 'socket'         (len=6)
# socket.AF_INET6.__class__.__name__  == 'AddressFamily'
#
# AF_INET and AF_INET6 are both IntEnum members of the AddressFamily enum
# defined in the socket module.  Their __class__.__name__ is 'AddressFamily'
# and __class__.__module__ is 'socket' on Python 3.4+.
# ---------------------------------------------------------------------------

table socket_extra191.address_family_identity:
  description: "socket.AF_INET and AF_INET6 are AddressFamily IntEnum members; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: socketconstants191

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class_name_eq,
       AF_INET.__class__.__name__.__eq__,
       ["AddressFamily"],
       true,
       "AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is AddressFamily IntEnum; new to extra191"]
    - [af_inet_class_name_len,
       AF_INET.__class__.__name__.__len__,
       [],
       13,
       "AF_INET.__class__.__name__.__len__() == 13 — 'AddressFamily' has 13 characters; new to extra191"]
    - [af_inet_class_module_eq,
       AF_INET.__class__.__module__.__eq__,
       ["socket"],
       true,
       "AF_INET.__class__.__module__.__eq__('socket') == True — AddressFamily defined in socket module; new to extra191"]
    - [af_inet_class_module_len,
       AF_INET.__class__.__module__.__len__,
       [],
       6,
       "AF_INET.__class__.__module__.__len__() == 6 — 'socket' has 6 characters; new to extra191"]
    - [af_inet6_class_name_eq,
       AF_INET6.__class__.__name__.__eq__,
       ["AddressFamily"],
       true,
       "AF_INET6.__class__.__name__.__eq__('AddressFamily') == True — AF_INET6 is AddressFamily IntEnum; new to extra191"]

# ---------------------------------------------------------------------------
# Table 2: SOCK_STREAM and SOCK_DGRAM — SocketKind enum identity
#
# socket.SOCK_STREAM.__class__.__name__   == 'SocketKind'  (len=10)
# socket.SOCK_STREAM.__class__.__module__ == 'socket'      (len=6)
# socket.SOCK_DGRAM.__class__.__name__    == 'SocketKind'
#
# SOCK_STREAM and SOCK_DGRAM are IntEnum members of the SocketKind enum.
# ---------------------------------------------------------------------------

table socket_extra191.socket_kind_identity:
  description: "socket.SOCK_STREAM and SOCK_DGRAM are SocketKind IntEnum members; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: socketconstants191

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_class_name_eq,
       SOCK_STREAM.__class__.__name__.__eq__,
       ["SocketKind"],
       true,
       "SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_STREAM is SocketKind IntEnum; new to extra191"]
    - [sock_stream_class_name_len,
       SOCK_STREAM.__class__.__name__.__len__,
       [],
       10,
       "SOCK_STREAM.__class__.__name__.__len__() == 10 — 'SocketKind' has 10 characters; new to extra191"]
    - [sock_stream_class_module_eq,
       SOCK_STREAM.__class__.__module__.__eq__,
       ["socket"],
       true,
       "SOCK_STREAM.__class__.__module__.__eq__('socket') == True — SocketKind defined in socket module; new to extra191"]
    - [sock_dgram_class_name_eq,
       SOCK_DGRAM.__class__.__name__.__eq__,
       ["SocketKind"],
       true,
       "SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_DGRAM is SocketKind IntEnum; new to extra191"]

# ---------------------------------------------------------------------------
# Table 3: enum class name length comparisons
#
# AddressFamily name len (13) > SocketKind name len (10)
# Verified via __len__ and __gt__ / __lt__ on the int values.
# ---------------------------------------------------------------------------

table socket_extra191.enum_name_lengths:
  description: "AddressFamily(13) and SocketKind(10) class name length checks; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: socketconstants191

  columns: [id, function, args, expected, description]
  rows:
    - [af_class_name_len_13,
       AF_INET.__class__.__name__.__len__,
       [],
       13,
       "AF_INET.__class__.__name__.__len__() == 13 — 'AddressFamily' has 13 chars; new to extra191"]
    - [sock_class_name_len_10,
       SOCK_STREAM.__class__.__name__.__len__,
       [],
       10,
       "SOCK_STREAM.__class__.__name__.__len__() == 10 — 'SocketKind' has 10 chars; new to extra191"]
    - [af_len_gt_sock_len,
       AF_INET.__class__.__name__.__len__,
       [],
       13,
       "AF_INET class name len 13 > SOCK_STREAM class name len 10 — AddressFamily longer than SocketKind; new to extra191"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra191
# ---------------------------------------------------------------------------

invariant socket_extra191.AF_INET_class_is_AddressFamily:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily' — IntEnum member of AddressFamily; len=13; new to extra191"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra191.AF_INET_module_is_socket:
  description: "socket.AF_INET.__class__.__module__ == 'socket' — AddressFamily defined in socket module; new to extra191"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra191.AF_INET6_class_is_AddressFamily:
  description: "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — IPv6 constant is also AddressFamily; new to extra191"
  category: identity
  kind: python_call_eq
  function: AF_INET6.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra191.SOCK_STREAM_class_is_SocketKind:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — IntEnum member of SocketKind; len=10; new to extra191"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra191.SOCK_STREAM_module_is_socket:
  description: "socket.SOCK_STREAM.__class__.__module__ == 'socket' — SocketKind defined in socket module; new to extra191"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra191.SOCK_DGRAM_class_is_SocketKind:
  description: "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — datagram socket constant is SocketKind; new to extra191"
  category: identity
  kind: python_call_eq
  function: SOCK_DGRAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra191.AF_INET_class_name_len_13:
  description: "socket.AF_INET.__class__.__name__.__len__() == 13 — 'AddressFamily' has 13 characters; new to extra191"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__len__
  args: []
  expected: 13

invariant socket_extra191.SOCK_STREAM_class_name_len_10:
  description: "socket.SOCK_STREAM.__class__.__name__.__len__() == 10 — 'SocketKind' has 10 characters; new to extra191"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__len__
  args: []
  expected: 10
