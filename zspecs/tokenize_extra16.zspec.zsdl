spec: tokenize_extra16
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize_extra15.zspec.zsdl — covers detect_encoding/open/generate_tokens/tokenize __module__ (table); TokenInfo/__module__ and TokenError/__module__ standalone; TokenError.__bases__[0].__name__=='Exception'; TokenInfo._asdict/__qualname__ standalone; generate_tokens/tokenize __qualname__ standalone"
    - "tokenize_extra14.zspec.zsdl — covers TokenInfo._fields/__class__.__name__=='tuple' and __len__()==5 standalone; COMMENT==65 standalone; NL/__class__.__name__=='int' standalone; ENCODING/__class__.__name__=='int' standalone; Untokenizer/__qualname__ and Untokenizer.untokenize/__qualname__ standalone"
    - "tokenize_extra13.zspec.zsdl — covers TokenInfo/__qualname__.__len__()==9; TokenError/__qualname__.__len__()==10; COMMENT/__class__.__name__=='int' standalone; NUMBER/__class__.__name__=='int' standalone"
    - "tokenize_extra12.zspec.zsdl — covers generate_tokens/open/untokenize __qualname__.__eq__; TokenInfo/__qualname__.__eq__; TokenError/__qualname__.__eq__; qualname __len__() for tokenize/generate_tokens/detect_encoding/open/untokenize"
    - "tokenize_extra11.zspec.zsdl — covers TokenInfo._fields class/len (table); Untokenizer __name__/__qualname__/__module__/base; TokenError base; open/__name__ and untokenize/__name__"
    - "tokenize_extra10.zspec.zsdl — covers tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__; TokenError/__name__/__module__; TokenInfo/__name__/__module__"
    - "tokenize_extra9.zspec.zsdl — covers tokenize/__qualname__.__eq__ and detect_encoding/__qualname__.__eq__; TokenInfo._make/_asdict/_replace __qualname__; untokenize/open __module__"
  notes:
    - "This spec extends tokenize_extra15.zspec.zsdl."
    - "Focus: TokenInfo.__bases__[0].__name__ (the namedtuple-generated base class); TokenInfo._make/__qualname__ and _replace/__qualname__ standalone in tokenize_extra16 namespace; Untokenizer.add_whitespace/__qualname__ and Untokenizer.compat/__qualname__; cookie_re.__class__.__name__ and __qualname__ standalone."
    - "tokenize.TokenInfo.__bases__[0].__name__ == 'TokenInfo' — Python namedtuple creates a base class sharing the same name; no prior tokenize spec covers this as a standalone __eq__ invariant."
    - "tokenize.TokenInfo._make.__qualname__ == 'TokenInfo._make' — tokenize_extra9 covers this in its namespace; distinct standalone invariant in tokenize_extra16 namespace."
    - "tokenize.TokenInfo._replace.__qualname__ == 'TokenInfo._replace' — tokenize_extra9 covers this in its namespace; distinct standalone invariant in tokenize_extra16 namespace."
    - "tokenize.Untokenizer.add_whitespace.__qualname__ == 'Untokenizer.add_whitespace' — no prior tokenize spec covers this method __qualname__."
    - "tokenize.Untokenizer.compat.__qualname__ == 'Untokenizer.compat' — no prior tokenize spec covers this method __qualname__."
    - "tokenize.cookie_re.__class__.__name__ == 'Pattern' — cookie_re is a compiled regular expression; no prior tokenize spec covers cookie_re class name."
    - "tokenize.cookie_re.__class__.__qualname__ == 'Pattern' — no prior tokenize spec covers cookie_re.__class__.__qualname__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TokenInfo.__bases__[0].__name__ — standalone invariant
# (tokenize_extra16 namespace)
#
# Python's namedtuple machinery creates an anonymous base class that shares
# the type name. TokenInfo.__bases__[0].__name__ is 'TokenInfo', not 'tuple'
# or 'NamedTuple'. No prior tokenize spec covers this as a standalone invariant.
# ---------------------------------------------------------------------------

invariant tokenize_extra16.TokenInfo.base_name_is_TokenInfo:
  description: "tokenize.TokenInfo.__bases__[0].__name__ == 'TokenInfo' — namedtuple base class shares the type name"
  category: class_bases
  kind: python_call_eq
  function: "TokenInfo.__bases__[0].__name__.__eq__"
  args: ["TokenInfo"]
  expected: true

# ---------------------------------------------------------------------------
# TokenInfo._make and _replace __qualname__ — standalone invariants
# (tokenize_extra16 namespace)
#
# tokenize_extra9 covers _make/_asdict/_replace __qualname__ in its namespace.
# tokenize_extra15 covers _asdict/__qualname__ as a distinct standalone.
# _make and _replace as standalone invariants in the tokenize_extra16 namespace
# are novel.
# ---------------------------------------------------------------------------

invariant tokenize_extra16.TokenInfo_make.qualname:
  description: "tokenize.TokenInfo._make.__qualname__ == 'TokenInfo._make'"
  category: method_qualnames
  kind: python_call_eq
  function: TokenInfo._make.__qualname__.__eq__
  args: ["TokenInfo._make"]
  expected: true

invariant tokenize_extra16.TokenInfo_replace.qualname:
  description: "tokenize.TokenInfo._replace.__qualname__ == 'TokenInfo._replace'"
  category: method_qualnames
  kind: python_call_eq
  function: TokenInfo._replace.__qualname__.__eq__
  args: ["TokenInfo._replace"]
  expected: true

# ---------------------------------------------------------------------------
# Untokenizer.add_whitespace and Untokenizer.compat __qualname__
# (tokenize_extra16 namespace)
#
# tokenize_extra14 covers Untokenizer/__qualname__ and
# Untokenizer.untokenize/__qualname__. No prior tokenize spec covers
# Untokenizer.add_whitespace or Untokenizer.compat __qualname__.
# ---------------------------------------------------------------------------

invariant tokenize_extra16.Untokenizer_add_whitespace.qualname:
  description: "tokenize.Untokenizer.add_whitespace.__qualname__ == 'Untokenizer.add_whitespace'"
  category: method_qualnames
  kind: python_call_eq
  function: Untokenizer.add_whitespace.__qualname__.__eq__
  args: ["Untokenizer.add_whitespace"]
  expected: true

invariant tokenize_extra16.Untokenizer_compat.qualname:
  description: "tokenize.Untokenizer.compat.__qualname__ == 'Untokenizer.compat'"
  category: method_qualnames
  kind: python_call_eq
  function: Untokenizer.compat.__qualname__.__eq__
  args: ["Untokenizer.compat"]
  expected: true

# ---------------------------------------------------------------------------
# cookie_re __class__.__name__ and __class__.__qualname__
# (tokenize_extra16 namespace)
#
# tokenize.cookie_re is a compiled re.Pattern object used to detect encoding
# declarations in source files. No prior tokenize spec covers cookie_re
# class name or qualname. Both __name__ and __qualname__ are 'Pattern'.
# ---------------------------------------------------------------------------

invariant tokenize_extra16.cookie_re.class_name_is_Pattern:
  description: "tokenize.cookie_re.__class__.__name__ == 'Pattern' — cookie_re is a compiled re.Pattern"
  category: class_names
  kind: python_call_eq
  function: cookie_re.__class__.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant tokenize_extra16.cookie_re.class_qualname_is_Pattern:
  description: "tokenize.cookie_re.__class__.__qualname__ == 'Pattern' — compiled re.Pattern __qualname__ is 'Pattern'"
  category: class_names
  kind: python_call_eq
  function: cookie_re.__class__.__qualname__.__eq__
  args: ["Pattern"]
  expected: true
