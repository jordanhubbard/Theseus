spec: hashlib_extra198
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "hashlib.md5.__name__ == 'openssl_md5' (len=11) — on macOS/Darwin with OpenSSL, the md5 constructor is the openssl_md5 builtin."
    - "hashlib.sha1.__name__ == 'openssl_sha1' (len=12) — OpenSSL-backed SHA-1 wrapper on macOS/Darwin."
    - "hashlib.sha224.__name__ == 'openssl_sha224' (len=14); hashlib.sha384.__name__ == 'openssl_sha384' (len=14); hashlib.sha512.__name__ == 'openssl_sha512' (len=14) — OpenSSL-backed constructors."
    - "hashlib.sha256.__name__ == 'openssl_sha256' (len=14) — OpenSSL-backed SHA-256 wrapper on macOS/Darwin."
    - "hashlib.blake2b.__name__ == 'blake2b' (len=7); hashlib.blake2s.__name__ == 'blake2s' (len=7) — BLAKE2 constructors are not OpenSSL-backed on macOS and retain their canonical names."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH constructor __name__ lengths — md5, sha1, sha224
# ---------------------------------------------------------------------------

table hashlibnamelens2198.short_names:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibnamelens2198

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_len,    md5.__name__.__len__,    [], 11, "len(hashlib.md5.__name__) == 11 ('openssl_md5' has 11 characters)"]
    - [sha1_name_len,   sha1.__name__.__len__,   [], 12, "len(hashlib.sha1.__name__) == 12 ('openssl_sha1' has 12 characters)"]
    - [sha224_name_len, sha224.__name__.__len__, [], 14, "len(hashlib.sha224.__name__) == 14 ('openssl_sha224' has 14 characters)"]

# ---------------------------------------------------------------------------
# HASH constructor __name__ lengths — sha384, sha512, sha256
# ---------------------------------------------------------------------------

table hashlibnamelens2198.sha_names:
  kind: python_call_eq
  category: name_lengths
