  columns: [id, function, args, expected, description]
  rows:
    - [sha384_name_len, sha384.__name__.__len__, [], 14, "len(hashlib.sha384.__name__) == 14 ('openssl_sha384' has 14 characters)"]
    - [sha512_name_len, sha512.__name__.__len__, [], 14, "len(hashlib.sha512.__name__) == 14 ('openssl_sha512' has 14 characters)"]
    - [sha256_name_len, sha256.__name__.__len__, [], 14, "len(hashlib.sha256.__name__) == 14 ('openssl_sha256' has 14 characters)"]

# ---------------------------------------------------------------------------
# BLAKE2 constructor __name__ lengths — blake2b, blake2s
# BLAKE2 constructors are not OpenSSL-backed on macOS; names are 7 characters.
# ---------------------------------------------------------------------------

table hashlibnamelens2198.blake2_names:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibnamelens2198

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_len, blake2b.__name__.__len__, [], 7, "len(hashlib.blake2b.__name__) == 7 ('blake2b' has 7 characters — native BLAKE2, not OpenSSL-backed)"]
    - [blake2s_name_len, blake2s.__name__.__len__, [], 7, "len(hashlib.blake2s.__name__) == 7 ('blake2s' has 7 characters — native BLAKE2, not OpenSSL-backed)"]

