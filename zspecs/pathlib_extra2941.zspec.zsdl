spec: pp2941
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class __dict__ unary operator presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib.py, Lib/pathlib/_local.py"
  notes:
    - "pathlib classes are filesystem path types; they do not define numeric unary operators."
    - "operator.contains(cls.__dict__, '__neg__') is False for all pathlib classes — paths are not numeric."
    - "operator.contains(cls.__dict__, '__pos__') is False for all pathlib classes."
    - "operator.contains(cls.__dict__, '__abs__') is False for all pathlib classes."
    - "PurePath, PurePosixPath, PureWindowsPath are pure (no I/O) path types."
    - "Path is the concrete I/O path type; also defines no numeric unary operators."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — unary negation operator in own __dict__
#
# None of the pathlib classes define __neg__ in their own __dict__.
# These are filesystem path abstractions, not numeric types.
# ---------------------------------------------------------------------------

table pp2941.neg:
  description: "operator.contains(cls.__dict__, '__neg__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppn2941

  columns: [id, function, args, expected]
  rows:
    - ["ppn2941_001", operator.contains, [pathlib.PurePath.__dict__,        "__neg__"], false]
    - ["ppn2941_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__neg__"], false]
    - ["ppn2941_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__neg__"], false]
    - ["ppn2941_004", operator.contains, [pathlib.Path.__dict__,            "__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — unary positive operator in own __dict__
#
# None of the pathlib classes define __pos__ in their own __dict__.
# ---------------------------------------------------------------------------

table pp2941.pos:
  description: "operator.contains(cls.__dict__, '__pos__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppp2941

  columns: [id, function, args, expected]
  rows:
    - ["ppp2941_001", operator.contains, [pathlib.PurePath.__dict__,        "__pos__"], false]
    - ["ppp2941_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__pos__"], false]
    - ["ppp2941_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__pos__"], false]
    - ["ppp2941_004", operator.contains, [pathlib.Path.__dict__,            "__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — absolute value operator in own __dict__
#
# None of the pathlib classes define __abs__ in their own __dict__.
# ---------------------------------------------------------------------------

table pp2941.abs:
  description: "operator.contains(cls.__dict__, '__abs__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppa2941

  columns: [id, function, args, expected]
  rows:
    - ["ppa2941_001", operator.contains, [pathlib.PurePath.__dict__,        "__abs__"], false]
    - ["ppa2941_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__abs__"], false]
    - ["ppa2941_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__abs__"], false]
    - ["ppa2941_004", operator.contains, [pathlib.Path.__dict__,            "__abs__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all pathlib classes
#
# Cross-check table confirming that no pathlib class defines any of the three
# unary numeric operators in its own __dict__.
# ---------------------------------------------------------------------------

table pp2941.combined:
  description: "Combined: no pathlib class defines __neg__, __pos__, or __abs__ in its own __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppx2941

  columns: [id, function, args, expected]
  rows:
    - ["ppx2941_001", operator.contains, [pathlib.PurePath.__dict__,       "__neg__"], false]
    - ["ppx2941_002", operator.contains, [pathlib.PurePath.__dict__,       "__pos__"], false]
    - ["ppx2941_003", operator.contains, [pathlib.PurePath.__dict__,       "__abs__"], false]
    - ["ppx2941_004", operator.contains, [pathlib.PurePosixPath.__dict__,  "__neg__"], false]
    - ["ppx2941_005", operator.contains, [pathlib.PurePosixPath.__dict__,  "__pos__"], false]
    - ["ppx2941_006", operator.contains, [pathlib.PurePosixPath.__dict__,  "__abs__"], false]
    - ["ppx2941_007", operator.contains, [pathlib.PureWindowsPath.__dict__, "__neg__"], false]
    - ["ppx2941_008", operator.contains, [pathlib.PureWindowsPath.__dict__, "__pos__"], false]
    - ["ppx2941_009", operator.contains, [pathlib.PureWindowsPath.__dict__, "__abs__"], false]
    - ["ppx2941_010", operator.contains, [pathlib.Path.__dict__,           "__neg__"], false]
    - ["ppx2941_011", operator.contains, [pathlib.Path.__dict__,           "__pos__"], false]
    - ["ppx2941_012", operator.contains, [pathlib.Path.__dict__,           "__abs__"], false]
