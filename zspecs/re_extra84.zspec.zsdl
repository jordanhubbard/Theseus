  category: qualname
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__eq__
  args: ["Pattern.fullmatch"]
  expected: true

invariant re_extra84.Match_group.qualname_eq:
  description: "re.Match.group.__qualname__ == 'Match.group' (length 11)"
  category: qualname
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra84.Match_end.qualname_eq:
  description: "re.Match.end.__qualname__ == 'Match.end' (length 9)"
