spec: re_extra84
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra83."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern/Match method __doc__.__class__.__name__; Match method __qualname__ values and lengths; re module function __code__ attributes; Pattern/Match identity (__name__/__module__/__bases__/__mro__); Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError __name__ and __module__."
    - "This spec covers: re.Pattern.match/__qualname__ string equality; re.Pattern.search/__qualname__ equality; re.Pattern.findall/__qualname__ equality; re.Pattern.finditer/__qualname__ equality; re.Pattern.sub/__qualname__ equality; re.Pattern.subn/__qualname__ equality; re.Pattern.split/__qualname__ equality; re.Pattern.fullmatch/__qualname__ equality; re.Match.group/__qualname__ equality; re.Match.groups/__qualname__ equality; re.Match.start/__qualname__ equality; re.Match.end/__qualname__ equality; re.Match.span/__qualname__ equality."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' — length 13."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' — length 14."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' — length 15."
    - "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' — length 16."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' — length 11."
    - "re.Pattern.subn.__qualname__ == 'Pattern.subn' — length 12."
    - "re.Pattern.split.__qualname__ == 'Pattern.split' — length 13."
    - "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' — length 17."
    - "re.Match.group.__qualname__ == 'Match.group' — length 11."
    - "re.Match.groups.__qualname__ == 'Match.groups' — length 12."
    - "re.Match.start.__qualname__ == 'Match.start' — length 11."
    - "re.Match.end.__qualname__ == 'Match.end' — length 9."
    - "re.Match.span.__qualname__ == 'Match.span' — length 10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.match and re.Pattern.search __qualname__ string equality
# Pattern.match.__qualname__ == 'Pattern.match' (len 13).
# Pattern.search.__qualname__ == 'Pattern.search' (len 14).
# Not covered in any prior re spec (prior specs covered lengths only, not __eq__).
# ---------------------------------------------------------------------------

table re_extra84.Pattern_match_search_qualname_eq:
  description: "Pattern.match and Pattern.search __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: reextra84

  columns: [id, function, args, expected]
  rows:
    - [pat_match_qn_eq,  Pattern.match.__qualname__.__eq__,   ["Pattern.match"],   true]
    - [pat_search_qn_eq, Pattern.search.__qualname__.__eq__,  ["Pattern.search"],  true]

# ---------------------------------------------------------------------------
# re.Pattern.findall, finditer, sub, subn __qualname__ string equality
# findall: 'Pattern.findall' (len 15); finditer: 'Pattern.finditer' (len 16).
# sub: 'Pattern.sub' (len 11); subn: 'Pattern.subn' (len 12).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra84.Pattern_findall_finditer_sub_subn_qualname_eq:
  description: "Pattern.findall, finditer, sub, subn __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: reextra84

  columns: [id, function, args, expected]
  rows:
    - [pat_findall_qn_eq,  Pattern.findall.__qualname__.__eq__,  ["Pattern.findall"],  true]
    - [pat_finditer_qn_eq, Pattern.finditer.__qualname__.__eq__, ["Pattern.finditer"], true]
    - [pat_sub_qn_eq,      Pattern.sub.__qualname__.__eq__,      ["Pattern.sub"],      true]
    - [pat_subn_qn_eq,     Pattern.subn.__qualname__.__eq__,     ["Pattern.subn"],     true]

# ---------------------------------------------------------------------------
# re.Pattern.split and re.Pattern.fullmatch __qualname__ string equality
# split: 'Pattern.split' (len 13); fullmatch: 'Pattern.fullmatch' (len 17).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra84.Pattern_split_fullmatch_qualname_eq:
  description: "Pattern.split and Pattern.fullmatch __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: reextra84

  columns: [id, function, args, expected]
  rows:
    - [pat_split_qn_eq,     Pattern.split.__qualname__.__eq__,     ["Pattern.split"],     true]
    - [pat_fullmatch_qn_eq, Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true]

# ---------------------------------------------------------------------------
# re.Match.group, groups, start, end, span __qualname__ string equality
# group: 'Match.group' (len 11); groups: 'Match.groups' (len 12).
# start: 'Match.start' (len 11); end: 'Match.end' (len 9); span: 'Match.span' (len 10).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra84.Match_method_qualname_eq:
  description: "Match.group, groups, start, end, span __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: reextra84

  columns: [id, function, args, expected]
  rows:
    - [mat_group_qn_eq,  Match.group.__qualname__.__eq__,  ["Match.group"],  true]
    - [mat_groups_qn_eq, Match.groups.__qualname__.__eq__, ["Match.groups"], true]
    - [mat_start_qn_eq,  Match.start.__qualname__.__eq__,  ["Match.start"],  true]
    - [mat_end_qn_eq,    Match.end.__qualname__.__eq__,    ["Match.end"],    true]
    - [mat_span_qn_eq,   Match.span.__qualname__.__eq__,   ["Match.span"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra84.Pattern_match.qualname_eq:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' (length 13)"
  category: qualname
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra84.Pattern_search.qualname_eq:
  description: "re.Pattern.search.__qualname__ == 'Pattern.search' (length 14)"
  category: qualname
  kind: python_call_eq
  function: Pattern.search.__qualname__.__eq__
  args: ["Pattern.search"]
  expected: true

invariant re_extra84.Pattern_fullmatch.qualname_eq:
