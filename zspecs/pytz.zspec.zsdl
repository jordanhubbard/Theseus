spec: pytz
version: ">=2020.1"
backend: python_module(pytz)

docs: https://pythonhosted.org/pytz/

provenance:
  derived_from:
    - "pytz documentation — https://pythonhosted.org/pytz/"
    - "IANA Time Zone Database — https://www.iana.org/time-zones"
    - "Test vectors verified with pytz 2024.x on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "pytz source: pytz/__init__.py"
    - "pytz source: pytz/tzinfo.py"
  notes:
    - "pytz.utc and pytz.UTC are the same object; both have .zone == 'UTC'."
    - "pytz.ZERO == timedelta(0); pytz.HOUR == timedelta(hours=1)."
    - "all_timezones contains 500+ entries; exact count varies by tzdata version."
    - "pytz.timezone('UTC').zone and str(pytz.timezone('UTC')) are both 'UTC'."
    - "pytz.exceptions.UnknownTimeZoneError is raised for invalid timezone names."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version (category: version) — __version__ attribute
# ---------------------------------------------------------------------------

invariant pytz.version.contains_dot:
  description: "pytz.__version__ contains a dot — it is a dotted version or date string"
  category: version
  kind: python_call_eq
  function: "__version__.__contains__"
  args: ["."]
  expected: true

invariant pytz.version.is_string:
  description: "pytz.__version__.__class__.__name__ == 'str' — version is a string"
  category: version
  kind: python_call_eq
  function: "__version__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# utc (category: utc) — pytz.utc / pytz.UTC
# ---------------------------------------------------------------------------

invariant pytz.utc.str_eq_UTC:
  description: "str(pytz.utc) == 'UTC' — the UTC singleton prints as 'UTC'"
  category: utc
  kind: python_call_eq
  function: "utc.__str__"
  args: []
  expected: "UTC"

invariant pytz.utc.zone_eq_UTC:
  description: "pytz.utc.zone == 'UTC' — the UTC singleton .zone attribute is 'UTC'"
  category: utc
  kind: python_call_eq
  function: "utc.zone.__eq__"
  args: ["UTC"]
  expected: true

invariant pytz.UTC.zone_eq_UTC:
  description: "pytz.UTC.zone == 'UTC' — the uppercase UTC alias .zone attribute is 'UTC'"
  category: utc
  kind: python_call_eq
  function: "UTC.zone.__eq__"
  args: ["UTC"]
  expected: true

# ---------------------------------------------------------------------------
# timezone (category: timezone) — pytz.timezone() lookup
# ---------------------------------------------------------------------------

invariant pytz.timezone.utc_zone:
  description: "pytz.timezone('UTC').zone == 'UTC'"
  category: timezone
  kind: python_call_eq
  function: timezone
  args: ["UTC"]
  method: zone
  expected: "UTC"

invariant pytz.timezone.america_new_york_zone:
  description: "pytz.timezone('America/New_York').zone == 'America/New_York'"
  category: timezone
  kind: python_call_eq
  function: timezone
  args: ["America/New_York"]
  method: zone
  expected: "America/New_York"

invariant pytz.timezone.europe_london_zone:
  description: "pytz.timezone('Europe/London').zone == 'Europe/London'"
  category: timezone
  kind: python_call_eq
  function: timezone
  args: ["Europe/London"]
  method: zone
  expected: "Europe/London"

# ---------------------------------------------------------------------------
# all_timezones (category: all_timezones) — membership and size
# ---------------------------------------------------------------------------

invariant pytz.all_timezones.contains_UTC:
  description: "'UTC' is in pytz.all_timezones"
  category: all_timezones
  kind: python_set_contains
  attribute: all_timezones
  must_contain: ["UTC"]

invariant pytz.all_timezones.contains_america_new_york:
  description: "'America/New_York' is in pytz.all_timezones"
  category: all_timezones
  kind: python_set_contains
  attribute: all_timezones
  must_contain: ["America/New_York"]

invariant pytz.all_timezones.length_gt_400:
  description: "len(pytz.all_timezones) > 400 — IANA database has many zones"
  category: all_timezones
  kind: python_call_eq
  function: "all_timezones.__len__"
  args: []
  method: "__gt__"
  method_args: [400]
  expected: true

# ---------------------------------------------------------------------------
# common_timezones (category: common) — membership
# ---------------------------------------------------------------------------

invariant pytz.common_timezones.contains_UTC:
  description: "'UTC' is in pytz.common_timezones"
  category: common
  kind: python_set_contains
  attribute: common_timezones
  must_contain: ["UTC"]

# ---------------------------------------------------------------------------
# exceptions (category: exceptions) — UnknownTimeZoneError
# ---------------------------------------------------------------------------

invariant pytz.exceptions.UnknownTimeZoneError.name:
  description: "pytz.exceptions.UnknownTimeZoneError.__name__ == 'UnknownTimeZoneError'"
  category: exceptions
  kind: python_call_eq
  function: "exceptions.UnknownTimeZoneError.__name__.__eq__"
  args: ["UnknownTimeZoneError"]
  expected: true

invariant pytz.exceptions.timezone_invalid_raises:
  description: "pytz.timezone('Not/A/Timezone') raises UnknownTimeZoneError"
  category: exceptions
  kind: python_call_raises
  function: timezone
  args: ["Not/A/Timezone"]
  expected_exception: "pytz.exceptions.UnknownTimeZoneError"

# ---------------------------------------------------------------------------
# constants (category: constants) — ZERO and HOUR
# ---------------------------------------------------------------------------

invariant pytz.ZERO.str_eq:
  description: "str(pytz.ZERO) == '0:00:00' — timedelta(0)"
  category: constants
  kind: python_call_eq
  function: "ZERO.__str__"
  args: []
  expected: "0:00:00"

invariant pytz.HOUR.str_eq:
  description: "str(pytz.HOUR) == '1:00:00' — timedelta(hours=1)"
  category: constants
  kind: python_call_eq
  function: "HOUR.__str__"
  args: []
  expected: "1:00:00"

