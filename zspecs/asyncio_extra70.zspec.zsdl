# Semaphore.__doc__.__contains__('Semaphore') == True
# ---------------------------------------------------------------------------

table asyncio_extra70.Event_Semaphore_doc:
  description: "asyncio Event/__doc__.__class__.__name__ and Semaphore/__doc__.__class__.__name__ and __doc__.__contains__ checks in asynciomod70 namespace — wave 236 theme: synchronization class doc content; Event.__doc__.__class__.__name__=='str' (Event is a pure Python class with a docstring); Event.__doc__.__contains__('Event')==True; Semaphore.__doc__.__class__.__name__=='str'; Semaphore.__doc__.__contains__('Semaphore')==True; NEW in extra70: first __doc__.__class__.__name__ and __doc__.__contains__ checks for Event and Semaphore in the asynciomod70 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: asynciomod70a

  columns: [id, function, args, expected, description]
  rows:
    - [event_doc_class,       Event.__doc__.__class__.__name__.__eq__,     ["str"],       true, "Event.__doc__.__class__.__name__ == 'str' — asyncio.Event is a pure Python class in asyncio/locks.py with a docstring; Event.__doc__ is a str; __doc__.__class__.__name__ is 'str'; NEW in extra70: first __doc__.__class__.__name__.__eq__('str') check for Event in the asynciomod70 namespace; verified with Python 3.14.3"]
    - [event_doc_Event,       Event.__doc__.__contains__,                  ["Event"],     true, "Event.__doc__.__contains__('Event') == True — asyncio.Event's docstring references the class name 'Event'; __doc__.__contains__('Event') returns True; NEW in extra70: first __doc__.__contains__('Event') check for Event in the asynciomod70 namespace; verified with Python 3.14.3"]
    - [semaphore_doc_class,   Semaphore.__doc__.__class__.__name__.__eq__, ["str"],       true, "Semaphore.__doc__.__class__.__name__ == 'str' — asyncio.Semaphore is a pure Python class in asyncio/locks.py with a docstring; Semaphore.__doc__ is a str; __doc__.__class__.__name__ is 'str'; NEW in extra70: first __doc__.__class__.__name__.__eq__('str') check for Semaphore in the asynciomod70 namespace; verified with Python 3.14.3"]
    - [semaphore_doc_content, Semaphore.__doc__.__contains__,              ["Semaphore"], true, "Semaphore.__doc__.__contains__('Semaphore') == True — asyncio.Semaphore's docstring references the class name 'Semaphore'; __doc__.__contains__('Semaphore') returns True; NEW in extra70: first __doc__.__contains__('Semaphore') check for Semaphore in the asynciomod70 namespace; verified with Python 3.14.3"]

