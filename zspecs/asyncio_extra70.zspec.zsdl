invariant asyncio_extra70.asyncio_name_asyncio:
  description: "asyncio.__name__.__eq__('asyncio') returns True — asyncio is a package; its __name__ attribute is the fully-qualified module name 'asyncio'; __name__.__eq__('asyncio') returns True; NEW in extra70: first standalone __name__.__eq__('asyncio') invariant for the asyncio module object in the asynciomod70 namespace; wave 236 first module name identity invariant for asyncio; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.__name__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra70.asyncio_loader_SourceFileLoader:
  description: "asyncio.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — asyncio is a package loaded via importlib; its __loader__ is a SourceFileLoader instance that loaded asyncio/__init__.py; __loader__.__class__.__name__ is 'SourceFileLoader'; __eq__('SourceFileLoader') returns True; NEW in extra70: first standalone __loader__.__class__.__name__ invariant for asyncio in the asynciomod70 namespace; wave 236 first loader class name invariant for asyncio; verified with Python 3.14.3"
  category: identity
