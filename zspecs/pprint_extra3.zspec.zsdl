spec: pprint_extra3
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl, pprint_extra.zspec.zsdl, and pprint_extra2.zspec.zsdl."
    - "pprint.zspec.zsdl: pformat primitives/containers, isreadable/isrecursive/saferepr tables, PrettyPrinter.__name__, function type checks."
    - "pprint_extra.zspec.zsdl: PrettyPrinter.__name__, PrettyPrinter.__module__, pformat/pprint/isreadable/isrecursive/saferepr __name__, pformat(42), pformat('hello')."
    - "pprint_extra2.zspec.zsdl: pformat([1,2,3]), pformat({}), pformat(''), isreadable([1,2,3]), isreadable({}), isrecursive([1,2,3]), isrecursive([])."
    - "Focus: __qualname__ attributes for pprint/pformat/isreadable/isrecursive/saferepr/PrettyPrinter; __module__ for pprint (the function); behavioral: isreadable(42), isrecursive([1,2,3]), saferepr(42)."
    - "pprint.pprint.__qualname__ == 'pprint' — module-level function has a flat qualname."
    - "pprint.pformat.__qualname__ == 'pformat' — module-level function has a flat qualname."
    - "pprint.isreadable.__qualname__ == 'isreadable' — module-level function has a flat qualname."
    - "pprint.isrecursive.__qualname__ == 'isrecursive' — module-level function has a flat qualname."
    - "pprint.saferepr.__qualname__ == 'saferepr' — module-level function has a flat qualname."
    - "pprint.PrettyPrinter.__qualname__ == 'PrettyPrinter' — module-level class has a flat qualname."
    - "pprint.pprint.__module__ == 'pprint' — the pprint function belongs to the pprint module."
    - "pprint.PrettyPrinter.__module__ == 'pprint' — PrettyPrinter class belongs to the pprint module."
    - "pprint.isreadable(42) == True — integers have a readable repr."
    - "pprint.isrecursive([1, 2, 3]) == False — a plain list has no recursive references."
    - "pprint.saferepr(42) == '42' — integer repr is its decimal string form."
    - "Lambdas (pprint.isreadable(lambda x: x) == False) cannot be expressed as a ZSDL arg (args must be simple YAML types) and are omitted from this spec."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — module-level functions and class
#
# All pprint public names are defined at module top level; their __qualname__
# equals their simple name (no nesting or closure prefix).
# ---------------------------------------------------------------------------

table pprint_extra3.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [pprint,        pprint.__qualname__.__eq__,        ["pprint"],        true]
    - [pformat,       pformat.__qualname__.__eq__,       ["pformat"],       true]
    - [isreadable,    isreadable.__qualname__.__eq__,    ["isreadable"],    true]
    - [isrecursive,   isrecursive.__qualname__.__eq__,   ["isrecursive"],   true]
    - [saferepr,      saferepr.__qualname__.__eq__,      ["saferepr"],      true]
    - [PrettyPrinter, PrettyPrinter.__qualname__.__eq__, ["PrettyPrinter"], true]

# ---------------------------------------------------------------------------
# __module__ — pprint function and PrettyPrinter class
# ---------------------------------------------------------------------------

invariant pprint_extra3.pprint.module:
  description: "pprint.pprint.__module__ == 'pprint' — the pprint function belongs to the pprint module"
  category: module
  kind: python_call_eq
  function: pprint.__module__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra3.PrettyPrinter.module:
  description: "pprint.PrettyPrinter.__module__ == 'pprint' — PrettyPrinter class belongs to the pprint module"
  category: module
  kind: python_call_eq
  function: PrettyPrinter.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — isreadable, isrecursive, saferepr
# ---------------------------------------------------------------------------

invariant pprint_extra3.isreadable.on_int:
  description: "pprint.isreadable(42) == True — integers have a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [42]
  expected: true

invariant pprint_extra3.isrecursive.plain_list:
  description: "pprint.isrecursive([1, 2, 3]) == False — a plain list has no recursive references"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [[1, 2, 3]]
  expected: false

invariant pprint_extra3.saferepr.on_int:
  description: "pprint.saferepr(42) == '42' — integer repr is its decimal string form"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [42]
  expected: "42"
