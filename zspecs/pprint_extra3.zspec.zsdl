spec: pprint_extra3
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
    - "pprint.zspec.zsdl — covers function names (pformat, pprint, isreadable, isrecursive, saferepr), PrettyPrinter class name, PrettyPrinter.__module__"
    - "pprint_extra.zspec.zsdl — covers pformat({'a':1}), pformat([1,2,3]), isreadable(42), isrecursive([]), saferepr('hello'), PrettyPrinter().__class__.__name__"
    - "pprint_extra2.zspec.zsdl — covers pprint.__name__, pformat.__name__, PrettyPrinter.__name__, PrettyPrinter.__bases__[0].__name__, pp.__name__, pformat(42), pformat('hello'), pformat(None), pformat(True)"
  notes:
    - "pprint.pformat.__module__ == 'pprint' — pformat belongs to the pprint module."
    - "pprint.pprint.__module__ == 'pprint' — the pprint function belongs to the pprint module."
    - "pprint.isreadable.__module__ == 'pprint' — isreadable belongs to the pprint module."
    - "pprint.isrecursive.__module__ == 'pprint' — isrecursive belongs to the pprint module."
    - "pprint.saferepr.__module__ == 'pprint' — saferepr belongs to the pprint module."
    - "pprint.PrettyPrinter.__module__ == 'pprint' — PrettyPrinter class belongs to the pprint module."
    - "pprint.pformat({}) == '{}' — an empty dict formats as a two-character string."
    - "pprint.pformat([]) == '[]' — an empty list formats as a two-character string."
    - "pprint.isreadable(None) == True — None has a readable repr."
    - "pprint.isreadable({'a': 1}) == True — a simple dict has a readable repr."
    - "pprint.saferepr(42) == '42' — integer repr is its decimal string form."
    - "pprint.saferepr(None) == 'None' — None repr is the string 'None'."
    - "pprint.saferepr([1, 2, 3]) == '[1, 2, 3]' — short list repr fits on one line."
    - "pprint.saferepr(True) == 'True' — bool repr is 'True'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module affiliation — pformat
# ---------------------------------------------------------------------------

invariant pprint_extra3.pformat.module:
  description: "pprint.pformat.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: pformat.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — pprint (the function)
# ---------------------------------------------------------------------------

invariant pprint_extra3.pprint.module:
  description: "pprint.pprint.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: pprint.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — isreadable
# ---------------------------------------------------------------------------

invariant pprint_extra3.isreadable.module:
  description: "pprint.isreadable.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: isreadable.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — isrecursive
# ---------------------------------------------------------------------------

invariant pprint_extra3.isrecursive.module:
  description: "pprint.isrecursive.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: isrecursive.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — saferepr
# ---------------------------------------------------------------------------

invariant pprint_extra3.saferepr.module:
  description: "pprint.saferepr.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: saferepr.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — PrettyPrinter class
# ---------------------------------------------------------------------------

invariant pprint_extra3.PrettyPrinter.module:
  description: "pprint.PrettyPrinter.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: PrettyPrinter.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# pformat() — empty containers
# ---------------------------------------------------------------------------

invariant pprint_extra3.pformat.empty_dict:
  description: "pprint.pformat({}) == '{}'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [{}]
  expected: "{}"

invariant pprint_extra3.pformat.empty_list:
  description: "pprint.pformat([]) == '[]'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [[]]
  expected: "[]"

# ---------------------------------------------------------------------------
# isreadable() — readable objects
# ---------------------------------------------------------------------------

invariant pprint_extra3.isreadable.none:
  description: "pprint.isreadable(None) == True — None has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [null]
  expected: true

invariant pprint_extra3.isreadable.simple_dict:
  description: "pprint.isreadable({'a': 1}) == True — a simple dict has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [{"a": 1}]
  expected: true

# ---------------------------------------------------------------------------
# saferepr() — standard types
# ---------------------------------------------------------------------------

invariant pprint_extra3.saferepr.int:
  description: "pprint.saferepr(42) == '42'"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [42]
  expected: "42"

invariant pprint_extra3.saferepr.none:
  description: "pprint.saferepr(None) == 'None'"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [null]
  expected: "None"

invariant pprint_extra3.saferepr.list:
  description: "pprint.saferepr([1, 2, 3]) == '[1, 2, 3]'"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [[1, 2, 3]]
  expected: "[1, 2, 3]"

invariant pprint_extra3.saferepr.bool_true:
  description: "pprint.saferepr(True) == 'True'"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [true]
  expected: "True"
