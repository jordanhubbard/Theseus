spec: multiprocessing_extra736
version: ">=3.9"
backend: python_module(multiprocessing)
docs: "Behavioral spec for multiprocessing.managers.BaseManager and related class identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers"
  not_derived_from: []
  notes: "Covers BaseManager, SyncManager, and BaseProxy qualname and module identity checks"
  created_at: "2026-04-12"

table multiprocessing_extra736.manager_qualnames:
  description: "multiprocessing.managers.BaseManager identity and method qualname checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: mp736xx
  columns: [id, function, args, expected]
  rows:
    - ["mp736xx001", "multiprocessing.managers.BaseManager.__qualname__.__eq__", ["BaseManager"], true]
    - ["mp736xx002", "multiprocessing.managers.BaseManager.__module__.__eq__", ["multiprocessing.managers"], true]
    - ["mp736xx003", "multiprocessing.managers.BaseManager.__doc__.__class__.__name__.__eq__", ["str"], true]
    - ["mp736xx004", "multiprocessing.managers.BaseManager.start.__qualname__.__eq__", ["BaseManager.start"], true]
    - ["mp736xx005", "multiprocessing.managers.BaseManager.connect.__qualname__.__eq__", ["BaseManager.connect"], true]
    - ["mp736xx006", "multiprocessing.managers.BaseManager.shutdown.__qualname__.__eq__", ["BaseManager.shutdown"], true]
    - ["mp736xx007", "multiprocessing.managers.BaseManager.register.__qualname__.__eq__", ["BaseManager.register"], true]
    - ["mp736xx008", "multiprocessing.managers.BaseManager.__enter__.__qualname__.__eq__", ["BaseManager.__enter__"], true]
    - ["mp736xx009", "multiprocessing.managers.BaseManager.__exit__.__qualname__.__eq__", ["BaseManager.__exit__"], true]
    - ["mp736xx010", "multiprocessing.managers.SyncManager.__qualname__.__eq__", ["SyncManager"], true]
    - ["mp736xx011", "multiprocessing.managers.SyncManager.__module__.__eq__", ["multiprocessing.managers"], true]
    - ["mp736xx012", "multiprocessing.managers.BaseProxy.__qualname__.__eq__", ["BaseProxy"], true]
