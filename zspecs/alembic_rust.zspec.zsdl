spec: alembic_rust
version: ">=3.9"
backend: rust_module(alembic_rust)

docs: https://alembic.sqlalchemy.org/en/latest/

provenance:
  derived_from:
    - "https://alembic.sqlalchemy.org/en/latest/ — Alembic documentation"
  not_derived_from:
    - "alembic source: alembic/__init__.py"
  notes:
    - "Alembic provides database migrations for SQLAlchemy."
    - "alembic.__version__ is a non-empty string."
    - "alembic.config.Config is available."
    - "alembic.config.Config.__name__ == 'Config'."
    - "alembic.command is available."
    - "Expose alembic_version_nonempty() -> bool: len(alembic.__version__) > 0."
    - "Expose alembic_config_name() -> str: alembic.config.Config.__name__."
    - "Expose alembic_has_command() -> bool: hasattr(alembic, 'command')."
    - "All test vectors verified against alembic 1.15.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# alembic_version_nonempty — version non-empty
invariant alembic_rust.version.nonempty:
  description: "alembic.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: alembic_version_nonempty
  args: []
  expected: true

# alembic_config_name — Config class name
invariant alembic_rust.config.class_name:
  description: "alembic.config.Config.__name__ == 'Config'"
  category: config
  kind: python_call_eq
  function: alembic_config_name
  args: []
  expected: "Config"

# alembic_has_command — command module present
invariant alembic_rust.module.has_command:
  description: "alembic.command is available"
  category: module
  kind: python_call_eq
  function: alembic_has_command
  args: []
  expected: true

