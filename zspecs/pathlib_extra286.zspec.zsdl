spec: pathlib_extra286
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "pathlib_extra99 covers pathlib class identity (PurePath, Path, PosixPath, WindowsPath) and MRO lengths."
    - "This spec focuses on Path.with_name() and Path.with_suffix() instance method return values."
    - "Path('/foo/bar').with_name('baz').name == 'baz' — with_name replaces the final component."
    - "Path('/foo/bar').with_name('baz').parent == Path('/foo') — parent directory is unchanged."
    - "Path('/foo/bar.txt').with_suffix('.py').name == 'bar.py' — with_suffix replaces the extension."
    - "Path('/foo/bar.txt').with_suffix('.py').suffix == '.py' — the new suffix is '.py'."
    - "Path('/foo').with_suffix('.txt').name == 'foo.txt' — with_suffix works on a path with no prior extension."
    - "Path('/foo').with_suffix('.txt').suffix == '.txt' — the suffix attribute reflects the new extension."
    - "Path('/foo/bar.txt').stem == 'bar' — stem is the name without the suffix."
    - "Path('/foo/bar.txt').suffix == '.txt' — suffix includes the leading dot."
    - "Path('/foo/bar').suffix == '' — a path with no extension has an empty-string suffix."
    - "Path('/a/b/c').parent.name == 'b' — parent.name is the final component of the parent path."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.with_name() — replaces the final path component
# Path('/foo/bar').with_name('baz') -> Path('/foo/baz')
# Path('/foo/bar.txt').with_name('qux.py') -> Path('/foo/qux.py')
# The parent directory is always preserved.
# ---------------------------------------------------------------------------

table pathlib_extra286.with_name_results:
  description: "Path.with_name() replaces the final component; .name and .parent of the result"
  kind: python_call_eq
  category: path_transforms
  id_prefix: withname286

  columns: [id, function, args, expected, description]
  rows:
    - [bar_name,    "Path('/foo/bar').with_name('baz').name.__eq__",   ["baz"],  true,  "Path('/foo/bar').with_name('baz').name == 'baz'"]
    - [bar_pname,   "Path('/foo/bar').with_name('baz').parent.name.__eq__", ["foo"], true, "Path('/foo/bar').with_name('baz').parent.name == 'foo'"]
    - [txt_name,    "Path('/foo/bar.txt').with_name('qux.py').name.__eq__", ["qux.py"], true, "Path('/foo/bar.txt').with_name('qux.py').name == 'qux.py'"]

# ---------------------------------------------------------------------------
# Path.with_suffix() — replaces the file extension
# Path('/foo/bar.txt').with_suffix('.py') -> Path('/foo/bar.py')
# Path('/foo').with_suffix('.txt') -> Path('/foo.txt')   (no prior extension)
# The .suffix attribute on the result reflects the new extension.
# ---------------------------------------------------------------------------

table pathlib_extra286.with_suffix_results:
  description: "Path.with_suffix() replaces the extension; .name and .suffix of the result"
  kind: python_call_eq
  category: path_transforms
  id_prefix: withsuffix286

  columns: [id, function, args, expected, description]
  rows:
    - [barpy_name,   "Path('/foo/bar.txt').with_suffix('.py').name.__eq__",   ["bar.py"], true,  "Path('/foo/bar.txt').with_suffix('.py').name == 'bar.py'"]
    - [barpy_suffix, "Path('/foo/bar.txt').with_suffix('.py').suffix.__eq__", [".py"],    true,  "Path('/foo/bar.txt').with_suffix('.py').suffix == '.py'"]
    - [footxt_name,  "Path('/foo').with_suffix('.txt').name.__eq__",          ["foo.txt"], true, "Path('/foo').with_suffix('.txt').name == 'foo.txt'"]
    - [footxt_suffix,"Path('/foo').with_suffix('.txt').suffix.__eq__",        [".txt"],   true,  "Path('/foo').with_suffix('.txt').suffix == '.txt'"]
    - [bar_stem,     "Path('/foo/bar.txt').stem.__eq__",                      ["bar"],    true,  "Path('/foo/bar.txt').stem == 'bar' — stem is name without suffix"]
    - [bar_suffix,   "Path('/foo/bar.txt').suffix.__eq__",                    [".txt"],   true,  "Path('/foo/bar.txt').suffix == '.txt' — suffix includes leading dot"]
    - [nosuffix,     "Path('/foo/bar').suffix.__eq__",                        [""],       true,  "Path('/foo/bar').suffix == '' — empty string when no extension"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra286.with_name.name_is_baz:
  description: "Path('/foo/bar').with_name('baz').name == 'baz' — with_name() replaces only the final path component"
  category: path_transforms
  kind: python_call_eq
  function: "Path('/foo/bar').with_name('baz').name.__eq__"
  args: ["baz"]
  expected: true

invariant pathlib_extra286.with_suffix.barpy_name:
  description: "Path('/foo/bar.txt').with_suffix('.py').name == 'bar.py' — with_suffix() swaps the extension, keeping the stem"
  category: path_transforms
  kind: python_call_eq
  function: "Path('/foo/bar.txt').with_suffix('.py').name.__eq__"
  args: ["bar.py"]
  expected: true

invariant pathlib_extra286.with_suffix.footxt_name:
  description: "Path('/foo').with_suffix('.txt').name == 'foo.txt' — with_suffix() adds an extension when the path previously had none"
  category: path_transforms
  kind: python_call_eq
  function: "Path('/foo').with_suffix('.txt').name.__eq__"
  args: ["foo.txt"]
  expected: true

invariant pathlib_extra286.suffix.txt_has_dot:
  description: "Path('/foo/bar.txt').suffix == '.txt' — the suffix attribute includes the leading dot"
  category: path_attrs
  kind: python_call_eq
  function: "Path('/foo/bar.txt').suffix.__eq__"
  args: [".txt"]
  expected: true

invariant pathlib_extra286.suffix.empty_when_no_ext:
  description: "Path('/foo/bar').suffix == '' — a path with no extension has an empty-string suffix attribute"
  category: path_attrs
  kind: python_call_eq
  function: "Path('/foo/bar').suffix.__eq__"
  args: [""]
  expected: true

invariant pathlib_extra286.stem.bar_from_bartxt:
  description: "Path('/foo/bar.txt').stem == 'bar' — stem is the name without the final extension"
  category: path_attrs
  kind: python_call_eq
  function: "Path('/foo/bar.txt').stem.__eq__"
  args: ["bar"]
  expected: true

invariant pathlib_extra286.parent.name_is_b:
  description: "Path('/a/b/c').parent.name == 'b' — parent.name gives the final component of the parent directory"
  category: path_attrs
  kind: python_call_eq
  function: "Path('/a/b/c').parent.name.__eq__"
  args: ["b"]
  expected: true
