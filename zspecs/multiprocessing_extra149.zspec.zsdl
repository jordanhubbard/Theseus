spec: multiprocessing_extra149
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec covers: multiprocessing.__dict__.__len__()==58 and multiprocessing.__dict__.__class__.__name__=='dict'; also multiprocessing.pool.__dict__.__len__()==43, multiprocessing.queues.__dict__.__len__()==31, multiprocessing.synchronize.__dict__.__len__()==29; submodule __name__ lengths: multiprocessing.__name__ len=15, pool len=20, queues len=22, synchronize len=27 (longest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__dict__.__len__()==58 (58 entries at import time; previous spec148 noted 53 entries but on Python 3.14.3 the count is 58 — version-specific additions). multiprocessing.__dict__.__class__.__name__=='dict' (module __dict__ is a plain dict, not mappingproxy). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.__dict__.__len__()==43 (vs 42 noted in extra147 — a small version delta on Python 3.14.3). multiprocessing.synchronize.__dict__.__len__()==29 (synchronize.py contains Lock, RLock, BoundedSemaphore, Semaphore, Condition, Event, Barrier, and SemLock). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__dict__ size and class name — extra149
#
# multiprocessing.__dict__.__len__()                == 58
# multiprocessing.__dict__.__class__.__name__       == 'dict'
# multiprocessing.__dict__.__class__.__name__.__len__() == 4
# multiprocessing.__name__.__len__()                == 15
# ---------------------------------------------------------------------------

table multiprocessing_extra149.mp_dict_len_and_class:
  description: "multiprocessing.__dict__ size and class name checks in mpdict149 namespace — multiprocessing.__dict__.__len__()==58 (the multiprocessing package top-level __dict__ has 58 entries; these include re-exported public names Process, Pool, Queue, Pipe, Manager, Lock, Event, Value, Array, cpu_count, current_process, parent_process, active_children, and many more, plus module-level dunders); multiprocessing.__dict__.__class__.__name__.__eq__('dict')==True (module __dict__ is a plain dict, not mappingproxy; len('dict')==4); multiprocessing.__dict__.__class__.__name__.__len__()==4; multiprocessing.__name__.__eq__('multiprocessing')==True (len=15: 'multiprocessing'=15 chars); multiprocessing.__name__.__len__()==15; compare: asyncio.__dict__.__len__()==136, concurrent.futures.__dict__.__len__()==28, multiprocessing.__dict__.__len__()==58; NEW in extra149: first multiprocessing.__dict__ size spec in mpdict149 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: namespace
  id_prefix: mpdict149

  columns: [id, function, args, expected, description]
  rows:
    - [dict_len,      multiprocessing.__dict__.__len__,                        [],                  58,    "multiprocessing.__dict__.__len__() == 58; verified with Python 3.14.3"]
    - [dict_cls_eq,   multiprocessing.__dict__.__class__.__name__.__eq__,      ["dict"],            true,  "multiprocessing.__dict__.__class__.__name__ == 'dict' (plain dict, not mappingproxy); verified with Python 3.14.3"]
    - [dict_cls_len,  multiprocessing.__dict__.__class__.__name__.__len__,     [],                  4,     "multiprocessing.__dict__.__class__.__name__.__len__() == 4 ('dict'); verified with Python 3.14.3"]
    - [name_eq,       multiprocessing.__name__.__eq__,                         ["multiprocessing"], true,  "multiprocessing.__name__ == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [name_len,      multiprocessing.__name__.__len__,                        [],                  15,    "multiprocessing.__name__.__len__() == 15; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing submodule __dict__ sizes — extra149
#
# multiprocessing.pool.__dict__.__len__()        == 43  (largest)
# multiprocessing.queues.__dict__.__len__()      == 31
# multiprocessing.synchronize.__dict__.__len__() == 29  (smallest of the three)
# ---------------------------------------------------------------------------

table multiprocessing_extra149.mp_submodule_dict_sizes:
  description: "multiprocessing submodule __dict__ size checks in mpdict149 namespace — multiprocessing.pool.__dict__.__len__()==43 (largest submodule: pool.py contains Pool and its extensive private helper classes and functions for worker pool management, result handling, and task queuing; len('multiprocessing.pool')==20); multiprocessing.queues.__dict__.__len__()==31 (second-largest: queues.py contains Queue, JoinableQueue, SimpleQueue, and their private helpers; len('multiprocessing.queues')==22); multiprocessing.synchronize.__dict__.__len__()==29 (smallest: synchronize.py contains Lock, RLock, BoundedSemaphore, Semaphore, Condition, Event, Barrier, and SemLock; len('multiprocessing.synchronize')==27, the longest submodule name); dict size ordering: pool(43) > queues(31) > synchronize(29); all submodule __dict__ are plain dicts; verified with Python 3.14.3"
  kind: python_call_eq
  category: namespace
  id_prefix: mpsubdict149

  columns: [id, function, args, expected, description]
  rows:
    - [pool_len,        multiprocessing.pool.__dict__.__len__,         [],  43,  "multiprocessing.pool.__dict__.__len__() == 43 (largest submodule); verified with Python 3.14.3"]
    - [queues_len,      multiprocessing.queues.__dict__.__len__,       [],  31,  "multiprocessing.queues.__dict__.__len__() == 31; verified with Python 3.14.3"]
    - [synchronize_len, multiprocessing.synchronize.__dict__.__len__,  [],  29,  "multiprocessing.synchronize.__dict__.__len__() == 29 (smallest of the three); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing submodule __name__ lengths — extra149
#
# multiprocessing.pool.__name__.__len__()        == 20  ('multiprocessing.pool')
# multiprocessing.queues.__name__.__len__()      == 22  ('multiprocessing.queues')
# multiprocessing.synchronize.__name__.__len__() == 27  ('multiprocessing.synchronize'; longest)
# ---------------------------------------------------------------------------

table multiprocessing_extra149.mp_submodule_name_lengths:
  description: "multiprocessing submodule __name__ length checks in mpdict149 namespace — multiprocessing.synchronize.__name__.__len__()==27 ('multiprocessing.synchronize': 'multiprocessing'=15+'.'=1+'synchronize'=11=27; the longest submodule name in this spec and the only submodule with an 11-char suffix); multiprocessing.queues.__name__.__len__()==22 ('multiprocessing.queues': 'multiprocessing'=15+'.'=1+'queues'=6=22); multiprocessing.pool.__name__.__len__()==20 ('multiprocessing.pool': 'multiprocessing'=15+'.'=1+'pool'=4=20; shortest submodule name); name length ordering: synchronize(27) > queues(22) > pool(20); inversely, the dict size ordering is pool(43) > queues(31) > synchronize(29) — the longest-named module is NOT the largest; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsubname149

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_len,        multiprocessing.pool.__name__.__len__,         [],  20,  "multiprocessing.pool.__name__.__len__() == 20 ('multiprocessing.pool'; shortest name); verified with Python 3.14.3"]
    - [queues_name_len,      multiprocessing.queues.__name__.__len__,       [],  22,  "multiprocessing.queues.__name__.__len__() == 22 ('multiprocessing.queues'); verified with Python 3.14.3"]
    - [synchronize_name_len, multiprocessing.synchronize.__name__.__len__,  [],  27,  "multiprocessing.synchronize.__name__.__len__() == 27 ('multiprocessing.synchronize'; longest name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra149
# ---------------------------------------------------------------------------

invariant multiprocessing_extra149.mp_dict_len_58:
  description: "multiprocessing.__dict__.__len__() == 58 — the multiprocessing package top-level __dict__ has 58 entries; multiprocessing re-exports from context, pool, queues, synchronize, and other submodules; compare: asyncio.__dict__.__len__()==136 (much larger aggregator), concurrent.futures.__dict__.__len__()==28 (smaller top-level), multiprocessing.__dict__.__len__()==58 (mid-range); multiprocessing.__dict__.__class__.__name__=='dict' (plain module dict); multiprocessing.__name__=='multiprocessing' (len=15); NEW in extra149: first standalone multiprocessing.__dict__ length invariant in mpdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: multiprocessing.__dict__.__len__
  args: []
  expected: 58

invariant multiprocessing_extra149.mp_dict_class_is_dict:
  description: "multiprocessing.__dict__.__class__.__name__.__eq__('dict') returns True — multiprocessing.__dict__.__class__.__name__ is 'dict' (4 chars); module-level __dict__ is always a plain dict; this distinguishes it from class __dict__ objects (which are mappingproxy, 12 chars); multiprocessing.__dict__.__class__.__name__.__len__()==4; multiprocessing.__dict__.__len__()==58; both multiprocessing.__dict__ and asyncio.__dict__ and concurrent.futures.__dict__ are all plain dicts (all are modules not classes); NEW in extra149: first standalone multiprocessing.__dict__ class name invariant in mpdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: multiprocessing.__dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant multiprocessing_extra149.mp_pool_dict_len_43:
  description: "multiprocessing.pool.__dict__.__len__() == 43 — multiprocessing.pool is the largest of the three submodules in this spec with 43 entries; pool.py contains Pool (the worker pool class) plus extensive private infrastructure: _PoolCache, _WorkerHandlerThread, _TaskHandlerThread, _ResultHandlerThread, _worker, ApplyResult (AsyncResult), MapResult, IMapIterator, IMapUnorderedIterator, and module-level constants and helpers; multiprocessing.pool.__name__=='multiprocessing.pool' (len=20, shortest submodule name); compare: pool(43) > queues(31) > synchronize(29); NEW in extra149: first standalone multiprocessing.pool.__dict__ length invariant in mpdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: multiprocessing.pool.__dict__.__len__
  args: []
  expected: 43

invariant multiprocessing_extra149.mp_queues_dict_len_31:
  description: "multiprocessing.queues.__dict__.__len__() == 31 — multiprocessing.queues is the second-largest submodule in this spec with 31 entries; queues.py contains Queue, JoinableQueue, SimpleQueue, and their associated private helpers for inter-process communication via pipes and semaphores; multiprocessing.queues.__name__=='multiprocessing.queues' (len=22); compare: pool(43) > queues(31) > synchronize(29); queues(31) is slightly larger than synchronize(29) because Queue has more internal state management than the synchronization primitives; NEW in extra149: first standalone multiprocessing.queues.__dict__ length invariant in mpdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: multiprocessing.queues.__dict__.__len__
  args: []
  expected: 31

invariant multiprocessing_extra149.mp_synchronize_dict_len_29:
  description: "multiprocessing.synchronize.__dict__.__len__() == 29 — multiprocessing.synchronize is the smallest of the three submodules in this spec with 29 entries; synchronize.py contains the inter-process synchronization primitives: Lock, RLock, BoundedSemaphore, Semaphore, Condition, Event, Barrier, and SemLock (the low-level semaphore lock class); multiprocessing.synchronize.__name__=='multiprocessing.synchronize' (len=27, the longest submodule name in this spec — an inverse correlation with dict size: the longest-named module has the fewest dict entries); compare: pool(43) > queues(31) > synchronize(29); NEW in extra149: first standalone multiprocessing.synchronize.__dict__ length invariant in mpdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: multiprocessing.synchronize.__dict__.__len__
  args: []
  expected: 29

invariant multiprocessing_extra149.mp_synchronize_name_len_27:
  description: "multiprocessing.synchronize.__name__.__len__() == 27 — multiprocessing.synchronize.__name__ is 'multiprocessing.synchronize' (27 chars: 'multiprocessing'=15+'.'=1+'synchronize'=11=27); this is the longest submodule name in this spec (synchronize(27) > queues(22) > pool(20)); 'synchronize' has 11 chars, the longest suffix among the three submodules ('pool'=4, 'queues'=6, 'synchronize'=11); multiprocessing.synchronize.__dict__.__len__()==29 (despite having the longest name, synchronize has the smallest dict — 29 vs pool's 43); NEW in extra149: first standalone multiprocessing.synchronize.__name__ length invariant in mpdict149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.__name__.__len__
  args: []
  expected: 27

