spec: re_extra125
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module function __code__.co_consts tuple lengths and co_consts.__contains__(None) checks not yet covered."
    - "re_extra67 covered co_varnames[0]=='pattern'; re_extra107 covered co_name and co_argcount; re_extra124 covered co_varnames[1] and co_varnames[2] for all major re functions."
    - "NO prior re spec asserts co_consts.__len__() for any re module function."
    - "re.compile.__code__.co_consts has length 1 (docstring only; compile is a simple two-line function)."
    - "re.search.__code__.co_consts has length 1 (docstring only)."
    - "re.match.__code__.co_consts has length 1 (docstring only)."
    - "re.fullmatch.__code__.co_consts has length 1 (docstring only)."
    - "re.findall.__code__.co_consts has length 1 (docstring only)."
    - "re.finditer.__code__.co_consts has length 1 (docstring only)."
    - "re.sub.__code__.co_consts has length 7 (docstring + 5 error strings + None + stacklevel tuple)."
    - "re.subn.__code__.co_consts has length 7 (docstring + 5 error strings + None + stacklevel tuple)."
    - "re.split.__code__.co_consts has length 7 (same structure as sub/subn due to backward-compat argument handling)."
    - "re.compile.__code__.co_consts.__contains__(None) == False (simple functions have no None in co_consts)."
    - "re.sub.__code__.co_consts.__contains__(None) == True (sub's argument-handling code includes None as a sentinel)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function co_consts lengths: simple scan functions (len=1)
# compile, search, match, fullmatch, findall, finditer all have exactly 1
# co_const: the docstring tuple. These functions delegate directly to the
# internal _compile() or pattern object methods with no branching or
# error-handling constants in their bytecode.
# NO prior re spec asserts co_consts.__len__() for any re function.
# ---------------------------------------------------------------------------

table re_extra125.re_functions_co_consts_len_1:
  description: "re module simple scan function co_consts lengths: compile/search/match/fullmatch/findall/finditer all have co_consts.__len__()==1 (docstring only; no error constants needed); all assertions novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: recc125a

  columns: [id, function, args, expected, description]
  rows:
    - [compile_cc_len,   "compile.__code__.co_consts.__len__",   [],  1,  "re.compile.__code__.co_consts.__len__() == 1 (co_consts contains only the function docstring; compile(pattern, flags=0) simply delegates to the internal _compile() function with no branching constants)"]
    - [search_cc_len,    "search.__code__.co_consts.__len__",    [],  1,  "re.search.__code__.co_consts.__len__() == 1 (co_consts contains only the docstring; search delegates to _compile(pattern, flags).search(string) with no additional constants)"]
    - [match_cc_len,     "match.__code__.co_consts.__len__",     [],  1,  "re.match.__code__.co_consts.__len__() == 1 (co_consts contains only the docstring; match delegates to _compile(pattern, flags).match(string) with no additional constants)"]
    - [fullmatch_cc_len, "fullmatch.__code__.co_consts.__len__", [],  1,  "re.fullmatch.__code__.co_consts.__len__() == 1 (co_consts contains only the docstring; fullmatch delegates to _compile(pattern, flags).fullmatch(string) with no extra constants)"]
    - [findall_cc_len,   "findall.__code__.co_consts.__len__",   [],  1,  "re.findall.__code__.co_consts.__len__() == 1 (co_consts contains only the docstring; findall delegates to _compile(pattern, flags).findall(string) with no extra constants)"]
    - [finditer_cc_len,  "finditer.__code__.co_consts.__len__",  [],  1,  "re.finditer.__code__.co_consts.__len__() == 1 (co_consts contains only the docstring; finditer delegates to _compile(pattern, flags).finditer(string) with no extra constants)"]
    - [compile_ne_7,     "compile.__code__.co_consts.__len__.__eq__", [7], false, "re.compile.__code__.co_consts.__len__() != 7 (compile has only 1 constant unlike sub/subn/split which have 7 due to backward-compatibility argument-handling code)"]
    - [search_cc_cls,    "search.__code__.co_consts.__class__.__name__.__eq__", ["tuple"], true, "re.search.__code__.co_consts.__class__.__name__ == 'tuple' (co_consts is always a tuple; it holds all compile-time constant values referenced in the function bytecode)"]

# ---------------------------------------------------------------------------
# re module function co_consts lengths: complex functions (len=7)
# sub, subn, and split all have 7 co_consts because they include
# backward-compatibility argument-handling code for deprecated positional
# 'count'/'maxsplit'/'flags' arguments. Their co_consts include:
#   [0] docstring, [1-3] error message strings, [4] None, [5] warning msg, [6] ('stacklevel',)
# ---------------------------------------------------------------------------

table re_extra125.re_functions_co_consts_len_7:
  description: "re module complex function co_consts lengths: sub/subn/split all have co_consts.__len__()==7 due to backward-compatibility argument handling; all contain None at co_consts[4]; all assertions novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: recc125b

  columns: [id, function, args, expected, description]
  rows:
    - [sub_cc_len,       "sub.__code__.co_consts.__len__",         [],     7,     "re.sub.__code__.co_consts.__len__() == 7 (sub has 7 constants: docstring + error messages for 'count'/'flags' conflicts + positional-arg count error + None + warning string + ('stacklevel',) tuple; the extra constants implement backward-compatible positional argument detection)"]
    - [subn_cc_len,      "subn.__code__.co_consts.__len__",        [],     7,     "re.subn.__code__.co_consts.__len__() == 7 (subn mirrors sub's argument structure; it also handles deprecated positional 'count' and 'flags' arguments; same 7-constant co_consts structure as sub)"]
    - [split_cc_len,     "split.__code__.co_consts.__len__",       [],     7,     "re.split.__code__.co_consts.__len__() == 7 (split handles deprecated positional 'maxsplit' and 'flags' arguments with the same backward-compatibility code structure as sub/subn; 7 constants total)"]
    - [sub_cc_has_none,  "sub.__code__.co_consts.__contains__",    [null], true,  "re.sub.__code__.co_consts.__contains__(None) == True (None appears as co_consts[4] in sub; it is used as a sentinel value in the argument-handling code that detects whether optional keyword arguments were passed as positional arguments)"]
    - [subn_cc_has_none, "subn.__code__.co_consts.__contains__",   [null], true,  "re.subn.__code__.co_consts.__contains__(None) == True (same structure as sub; None at co_consts[4] is used in the backward-compatible positional argument detection logic)"]
    - [split_cc_has_none,"split.__code__.co_consts.__contains__",  [null], true,  "re.split.__code__.co_consts.__contains__(None) == True (same structure as sub/subn; None appears in split's argument-handling code)"]
    - [sub_gt_compile,   "sub.__code__.co_consts.__len__.__gt__",  [1],    true,  "re.sub.__code__.co_consts.__len__() > re.compile.__code__.co_consts.__len__() (7 > 1; sub's backward-compatibility code adds 6 more constants beyond the simple docstring that compile has)"]
    - [subn_eq_sub,      "subn.__code__.co_consts.__len__.__eq__", [7],    true,  "re.subn.__code__.co_consts.__len__() == re.sub.__code__.co_consts.__len__() == 7 (subn and sub share identical co_consts length; both implement the same argument-handling backward-compatibility code)"]

# ---------------------------------------------------------------------------
# re module function co_consts: contains(None) distinction
# Simple functions (compile/search/match/fullmatch/findall/finditer) do NOT
# contain None in co_consts. Complex functions (sub/subn/split) DO contain None.
# This distinguishes the two groups clearly.
# Also verifies co_consts[0] is a str (docstring) for all functions.
# ---------------------------------------------------------------------------

table re_extra125.re_functions_co_consts_none_distinction:
  description: "re module function co_consts: simple scan functions (compile/search/match/findall) do NOT contain None; sub/subn/split DO contain None; co_consts[0] is always a str docstring; all assertions novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: recc125c

  columns: [id, function, args, expected, description]
  rows:
    - [compile_no_none,  "compile.__code__.co_consts.__contains__",  [null], false, "re.compile.__code__.co_consts.__contains__(None) == False (compile's co_consts has only the docstring; no None sentinel is needed because compile has no complex argument-dispatch logic)"]
    - [search_no_none,   "search.__code__.co_consts.__contains__",   [null], false, "re.search.__code__.co_consts.__contains__(None) == False (search's co_consts has only the docstring; simple delegation function with no backward-compat argument handling)"]
    - [match_no_none,    "match.__code__.co_consts.__contains__",    [null], false, "re.match.__code__.co_consts.__contains__(None) == False (match's co_consts has only the docstring; same simple delegation pattern as search and compile)"]
    - [findall_no_none,  "findall.__code__.co_consts.__contains__",  [null], false, "re.findall.__code__.co_consts.__contains__(None) == False (findall's co_consts has only the docstring; no complex argument-handling code needed)"]
    - [compile_cc0_cls,  "compile.__code__.co_consts[0].__class__.__name__.__eq__", ["str"], true, "re.compile.__code__.co_consts[0].__class__.__name__ == 'str' (the first co_const is the docstring, always a str object; co_consts[0] is the function's docstring for all re module functions)"]
    - [search_cc0_cls,   "search.__code__.co_consts[0].__class__.__name__.__eq__",  ["str"], true, "re.search.__code__.co_consts[0].__class__.__name__ == 'str' (search's docstring is also a str; co_consts[0] is the function docstring for all re module functions)"]
    - [sub_cc0_cls,      "sub.__code__.co_consts[0].__class__.__name__.__eq__",     ["str"], true, "re.sub.__code__.co_consts[0].__class__.__name__ == 'str' (sub's docstring is also a str at co_consts[0]; even though sub has 7 co_consts, the docstring is always first)"]
    - [split_no_compile_len, "split.__code__.co_consts.__len__.__eq__", [1],        false, "re.split.__code__.co_consts.__len__() != 1 (split has 7 co_consts due to its backward-compatibility maxsplit/flags argument handling, not just a docstring like compile)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra125.compile.co_consts_len_1:
  description: "re.compile.__code__.co_consts.__len__() == 1 (compile(pattern, flags=0) is a simple two-line function that delegates directly to _compile(pattern, flags) and returns the compiled Pattern object; its only co_const is the docstring 'Compile a regular expression pattern, returning a Pattern object.' at 65 chars; no error message strings, no None sentinels, no tuple constants; this makes compile's co_consts the smallest of all common re functions; no prior re spec asserts co_consts.__len__() for any re function); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "compile.__code__.co_consts.__len__"
  args: []
  expected: 1

invariant re_extra125.sub.co_consts_len_7:
  description: "re.sub.__code__.co_consts.__len__() == 7 (sub has 7 co_consts because it implements backward-compatible positional argument detection for its 'count' and 'flags' parameters; the 7 constants are: [0] docstring(str), [1] \"sub() got multiple values for argument 'count'\"(str), [2] \"sub() got multiple values for argument 'flags'\"(str), [3] 'sub() takes from 3 to 5 positional arguments but %d were given'(str), [4] None(NoneType), [5] \"'count' is passed as positional argument\"(str), [6] ('stacklevel',)(tuple); no prior re spec asserts co_consts.__len__() for sub); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "sub.__code__.co_consts.__len__"
  args: []
  expected: 7

invariant re_extra125.sub.co_consts_contains_None:
  description: "re.sub.__code__.co_consts.__contains__(None) == True (None appears at co_consts[4] in re.sub; it is used as a sentinel in the argument-dispatch code that detects whether 'count' or 'flags' were accidentally passed as positional arguments by calling code that predates the keyword-only argument reform; sub/subn/split all contain None in co_consts for this reason, while simple delegation functions like compile/search/match/findall/finditer do not; this is the first re spec to assert co_consts.__contains__ for any re function); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "sub.__code__.co_consts.__contains__"
  args: [null]
  expected: true

invariant re_extra125.compile.co_consts_no_None:
  description: "re.compile.__code__.co_consts.__contains__(None) == False (compile's co_consts tuple contains only the docstring string and nothing else; None is not present because compile has no argument-dispatch sentinel logic; this contrasts with sub/subn/split which all contain None at co_consts[4]; the absence of None in compile's co_consts confirms that compile is a simple delegation function with no backward-compatibility complexity); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "compile.__code__.co_consts.__contains__"
  args: [null]
  expected: false

invariant re_extra125.split.co_consts_len_7:
  description: "re.split.__code__.co_consts.__len__() == 7 (split, like sub and subn, has 7 co_consts due to backward-compatible positional argument detection for its 'maxsplit' and 'flags' parameters; the structure mirrors sub/subn: docstring at [0], error messages at [1-3], None at [4], warning at [5], ('stacklevel',) at [6]; split was updated alongside sub/subn to add deprecation warnings for positional 'maxsplit' usage; no prior re spec asserts co_consts.__len__() for split); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "split.__code__.co_consts.__len__"
  args: []
  expected: 7

