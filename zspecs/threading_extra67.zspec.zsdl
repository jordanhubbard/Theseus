invariant threading_extra67.Thread_init_co_stacksize_int:
  description: "threading.Thread.__init__.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is always a plain int; wave 232 co_stacksize chains; new to extra67"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant threading_extra67.Thread_doc_str:
  description: "threading.Thread.__doc__.__class__.__name__.__eq__('str') == True — Thread class docstring is a str; wave 232 Thread doc content; new to extra67"
  kind: python_call_eq
  function: Thread.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra67.Thread_doc_thread:
  description: "threading.Thread.__doc__.__contains__('thread') == True — 'thread' appears in Thread class docstring; wave 232 Thread doc content; new to extra67"
