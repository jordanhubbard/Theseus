spec: threading_extra67
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra66.zspec.zsdl."
    - "Wave 232 theme: co_consts class name, co_nlocals class name, and co_stacksize class name for Thread.__init__/Thread.start/current_thread; Thread.__doc__ content."
    - "Thread.__init__.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple of constants in CPython code objects. Verified with Python 3.14.3."
    - "Thread.start.__code__.co_consts.__class__.__name__ == 'tuple' — same invariant for Thread.start. Verified with Python 3.14.3."
    - "current_thread.__code__.co_consts.__class__.__name__ == 'tuple' — current_thread is a module-level pure-Python function; co_consts is a tuple. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is the count of local variables, stored as a Python int. Verified with Python 3.14.3."
    - "Thread.start.__code__.co_nlocals.__class__.__name__ == 'int' — same invariant for Thread.start. Verified with Python 3.14.3."
    - "current_thread.__code__.co_nlocals.__class__.__name__ == 'int' — same invariant for current_thread. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack size, stored as a Python int. Verified with Python 3.14.3."
    - "Thread.start.__code__.co_stacksize.__class__.__name__ == 'int' — same invariant for Thread.start. Verified with Python 3.14.3."
    - "current_thread.__code__.co_stacksize.__class__.__name__ == 'int' — same invariant for current_thread. Verified with Python 3.14.3."
    - "Thread.__doc__.__class__.__name__ == 'str' — Thread has a docstring stored as a str. Verified with Python 3.14.3."
    - "Thread.__doc__.__contains__('thread') == True — the word 'thread' appears in the Thread class docstring. Verified with Python 3.14.3."
    - "Prior threading_extra66 covered co_varnames, co_filename, and co_flags for Thread.__init__/Thread.start/Thread.run/current_thread."
    - "No prior threading spec checks co_consts.__class__.__name__, co_nlocals.__class__.__name__, co_stacksize.__class__.__name__, or Thread.__doc__ content. All checks in this spec are new to extra67."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading __code__.co_consts.__class__.__name__ — extra67
#
# Wave 232 theme: co_consts is always a tuple.
#
# co_consts (PyCodeObject.co_consts) is a tuple of constants used by the
# bytecode (literals, None, docstrings, nested code objects, etc.). In CPython
# this attribute is always stored as a Python tuple.
#
# Thread.__init__.__code__.co_consts.__class__.__name__ == 'tuple'
# Thread.start.__code__.co_consts.__class__.__name__ == 'tuple'
# current_thread.__code__.co_consts.__class__.__name__ == 'tuple'
#
# All are pure-Python functions in Lib/threading.py.
# No prior threading spec checks co_consts.__class__.__name__. New to extra67.
# ---------------------------------------------------------------------------

table threading_extra67.co_consts_class_name:
  description: "threading function __code__.co_consts.__class__.__name__.__eq__('tuple')==true — co_consts is always a tuple in CPython; wave 232 co_consts chains; new to extra67"
  kind: python_call_eq
  category: co_consts
  id_prefix: thrdcode4_67

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_consts_class_name_eq_tuple,
       Thread.__init__.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Thread.__init__.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — Thread.__init__ is a pure-Python method (Lib/threading.py); its __code__ is a PyCodeObject; PyCodeObject.co_consts is a tuple of constants used by the bytecode (including None, literal strings, and nested code objects); the tuple built-in type has __name__ == 'tuple' (5 chars); __eq__ returns True; no prior threading spec checks co_consts.__class__.__name__ for Thread.__init__; new to extra67"]
    - [thread_start_code_co_consts_class_name_eq_tuple,
       Thread.start.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Thread.start.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — Thread.start is a pure-Python method (Lib/threading.py); its co_consts is a tuple of bytecode constants; tuple.__name__ == 'tuple'; __eq__ returns True; no prior threading spec checks co_consts.__class__.__name__ for Thread.start; new to extra67"]
    - [current_thread_code_co_consts_class_name_eq_tuple,
       current_thread.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.current_thread.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — current_thread is a pure-Python module-level function (Lib/threading.py); its co_consts is a tuple of bytecode constants; tuple.__name__ == 'tuple'; __eq__ returns True; no prior threading spec checks co_consts.__class__.__name__ for current_thread; new to extra67"]

# ---------------------------------------------------------------------------
# threading __code__.co_nlocals.__class__.__name__ — extra67
#
# Wave 232 theme: co_nlocals is always an int.
#
# co_nlocals (PyCodeObject.co_nlocals) stores the number of local variables
# (including parameters) used by the function. In CPython this field is
# always a plain Python int.
#
# Thread.__init__.__code__.co_nlocals.__class__.__name__ == 'int'
# Thread.start.__code__.co_nlocals.__class__.__name__ == 'int'
# current_thread.__code__.co_nlocals.__class__.__name__ == 'int'
#
# No prior threading spec checks co_nlocals.__class__.__name__. New to extra67.
# ---------------------------------------------------------------------------

table threading_extra67.co_nlocals_class_name:
  description: "threading function __code__.co_nlocals.__class__.__name__.__eq__('int')==true — co_nlocals is always a plain int; wave 232 co_nlocals chains; new to extra67"
  kind: python_call_eq
  category: co_nlocals
  id_prefix: thrdcode4_67

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_nlocals_class_name_eq_int,
       Thread.__init__.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.Thread.__init__.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — Thread.__init__ is a pure-Python method (Lib/threading.py); its __code__ is a PyCodeObject; PyCodeObject.co_nlocals is the count of local variables (including parameters such as self, group, target, name, args, kwargs, daemon, context) stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior threading spec checks co_nlocals.__class__.__name__ for Thread.__init__; new to extra67"]
    - [thread_start_code_co_nlocals_class_name_eq_int,
       Thread.start.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.Thread.start.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — Thread.start is a pure-Python method (Lib/threading.py); co_nlocals is the count of local variables stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior threading spec checks co_nlocals.__class__.__name__ for Thread.start; new to extra67"]
    - [current_thread_code_co_nlocals_class_name_eq_int,
       current_thread.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.current_thread.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — current_thread is a pure-Python module-level function (Lib/threading.py); co_nlocals is the count of local variables stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior threading spec checks co_nlocals.__class__.__name__ for current_thread; new to extra67"]

# ---------------------------------------------------------------------------
# threading __code__.co_stacksize.__class__.__name__ — extra67
#
# Wave 232 theme: co_stacksize is always an int.
#
# co_stacksize (PyCodeObject.co_stacksize) stores the required stack space
# for the function's evaluation stack. In CPython this field is always a
# plain Python int.
#
# Thread.__init__.__code__.co_stacksize.__class__.__name__ == 'int'
# Thread.start.__code__.co_stacksize.__class__.__name__ == 'int'
# current_thread.__code__.co_stacksize.__class__.__name__ == 'int'
#
# No prior threading spec checks co_stacksize.__class__.__name__. New to extra67.
# ---------------------------------------------------------------------------

table threading_extra67.co_stacksize_class_name:
  description: "threading function __code__.co_stacksize.__class__.__name__.__eq__('int')==true — co_stacksize is always a plain int; wave 232 co_stacksize chains; new to extra67"
  kind: python_call_eq
  category: co_stacksize
  id_prefix: thrdcode4_67

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_stacksize_class_name_eq_int,
       Thread.__init__.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.Thread.__init__.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — Thread.__init__ is a pure-Python method (Lib/threading.py); its __code__ is a PyCodeObject; PyCodeObject.co_stacksize is the required evaluation stack depth stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior threading spec checks co_stacksize.__class__.__name__ for Thread.__init__; new to extra67"]
    - [thread_start_code_co_stacksize_class_name_eq_int,
       Thread.start.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.Thread.start.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — Thread.start is a pure-Python method (Lib/threading.py); co_stacksize is the required evaluation stack depth stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior threading spec checks co_stacksize.__class__.__name__ for Thread.start; new to extra67"]
    - [current_thread_code_co_stacksize_class_name_eq_int,
       current_thread.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.current_thread.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — current_thread is a pure-Python module-level function (Lib/threading.py); co_stacksize is the required evaluation stack depth stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior threading spec checks co_stacksize.__class__.__name__ for current_thread; new to extra67"]

# ---------------------------------------------------------------------------
# threading.Thread.__doc__ content — extra67
#
# Wave 232 theme: Thread has a str docstring containing 'thread'.
#
# Thread.__doc__.__class__.__name__ == 'str'
# Thread.__doc__.__contains__('thread') == True
#
# Thread is a pure-Python class in Lib/threading.py with a class-level
# docstring that describes what a Thread object is. The word 'thread'
# (lowercase) appears in the docstring body.
#
# No prior threading spec checks Thread.__doc__. New to extra67.
# ---------------------------------------------------------------------------

table threading_extra67.Thread_doc_contains:
  description: "Thread.__doc__ is a str and contains 'thread'; wave 232 Thread doc content; new to extra67"
  kind: python_call_eq
  category: thread_doc
  id_prefix: thrdcode4_67

  columns: [id, function, args, expected, description]
  rows:
    - [thread_doc_class_name_eq_str,
       Thread.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__doc__.__class__.__name__.__eq__('str') == True — Thread is a pure-Python class (Lib/threading.py) that has a class-level docstring describing the Thread class; the docstring is stored as a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior threading spec checks Thread.__doc__.__class__.__name__; new to extra67"]
    - [thread_doc_contains_thread,
       Thread.__doc__.__contains__,
       ["thread"],
       true,
       "threading.Thread.__doc__.__contains__('thread') == True — Thread is a pure-Python class (Lib/threading.py) that represents a thread of control; its class docstring describes what a thread is and how Thread objects are used; the word 'thread' (lowercase) appears in the docstring body; str.__contains__ returns True at the first occurrence; no prior threading spec checks Thread.__doc__.__contains__('thread'); new to extra67"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant threading_extra67.Thread_init_co_consts_tuple:
  description: "threading.Thread.__init__.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple in CPython; wave 232 co_consts chains; new to extra67"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra67.Thread_init_co_nlocals_int:
