spec: uuid_extra237
version: ">=3.2"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid_extra.zspec.zsdl and uuid_extra2.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "uuid_extra.zspec.zsdl covers: UUID.__name__; UUID.__module__; uuid1/3/4/5 __name__ table; uuid4 return class/version; NAMESPACE_* class names (table); UUID.int/hex attribute types."
    - "uuid_extra2.zspec.zsdl covers: uuid1/3/4/5 __name__ standalone; NAMESPACE_* class names standalone; RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE value/type."
    - "UUID.__repr__.__name__ == '__repr__' — Python method dunder name is always its bare dunder string."
    - "UUID.__repr__.__qualname__ == 'UUID.__repr__' — qualname includes the enclosing class name."
    - "UUID.__str__.__name__ == '__str__' and UUID.__str__.__qualname__ == 'UUID.__str__'."
    - "UUID.__hash__.__name__ == '__hash__' and UUID.__hash__.__qualname__ == 'UUID.__hash__'."
    - "UUID.__eq__.__name__ == '__eq__' and UUID.__eq__.__qualname__ == 'UUID.__eq__'."
    - "UUID.__lt__.__name__ == '__lt__' and UUID.__lt__.__qualname__ == 'UUID.__lt__'."
    - "UUID.__int__.__name__ == '__int__' and UUID.__int__.__qualname__ == 'UUID.__int__'."
    - "UUID.__repr__, UUID.__str__, UUID.__hash__, UUID.__eq__, UUID.__lt__, UUID.__int__ are all Python functions (class 'function')."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__repr__ method identity
# ---------------------------------------------------------------------------

invariant uuid237repr.UUID.repr_name:
  description: "uuid.UUID.__repr__.__name__ == '__repr__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true

invariant uuid237repr.UUID.repr_qualname:
  description: "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__repr__.__qualname__.__eq__
  args: ["UUID.__repr__"]
  expected: true

invariant uuid237repr.UUID.repr_class_name:
  description: "uuid.UUID.__repr__.__class__.__name__ == 'function'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__repr__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__str__ method identity
# ---------------------------------------------------------------------------

invariant uuid237repr.UUID.str_name:
  description: "uuid.UUID.__str__.__name__ == '__str__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true

invariant uuid237repr.UUID.str_qualname:
  description: "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__eq__
  args: ["UUID.__str__"]
  expected: true

invariant uuid237repr.UUID.str_class_name:
  description: "uuid.UUID.__str__.__class__.__name__ == 'function'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__str__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__hash__ method identity
# ---------------------------------------------------------------------------

invariant uuid237repr.UUID.hash_name:
  description: "uuid.UUID.__hash__.__name__ == '__hash__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__hash__.__name__.__eq__
  args: ["__hash__"]
  expected: true

invariant uuid237repr.UUID.hash_qualname:
  description: "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__hash__.__qualname__.__eq__
  args: ["UUID.__hash__"]
  expected: true

invariant uuid237repr.UUID.hash_class_name:
  description: "uuid.UUID.__hash__.__class__.__name__ == 'function'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__hash__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__eq__ and UUID.__lt__ method identity (comparison operators)
# ---------------------------------------------------------------------------

table uuid237repr.comparison_methods:
  description: "UUID comparison dunder methods have correct __name__ and __qualname__"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuid237repr

  columns: [id, function, args, expected]
  rows:
    - [eq_name,       UUID.__eq__.__name__.__eq__,       ["__eq__"],       true]
    - [eq_qualname,   UUID.__eq__.__qualname__.__eq__,   ["UUID.__eq__"],  true]
    - [lt_name,       UUID.__lt__.__name__.__eq__,       ["__lt__"],       true]
    - [lt_qualname,   UUID.__lt__.__qualname__.__eq__,   ["UUID.__lt__"],  true]

# ---------------------------------------------------------------------------
# UUID.__int__ method identity
# ---------------------------------------------------------------------------

invariant uuid237repr.UUID.int_name:
  description: "uuid.UUID.__int__.__name__ == '__int__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__int__.__name__.__eq__
  args: ["__int__"]
  expected: true

invariant uuid237repr.UUID.int_qualname:
  description: "uuid.UUID.__int__.__qualname__ == 'UUID.__int__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__int__.__qualname__.__eq__
  args: ["UUID.__int__"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__init__ method identity
# ---------------------------------------------------------------------------

invariant uuid237repr.UUID.init_name:
  description: "uuid.UUID.__init__.__name__ == '__init__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant uuid237repr.UUID.init_qualname:
  description: "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'"
  category: method_identity
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true
