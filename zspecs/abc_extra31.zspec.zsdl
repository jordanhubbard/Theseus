spec: abc_extra31
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra30.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta(3)/ABC(2), ABC/__ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasscheck__/__qualname__.__len__()==25, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, ABCMeta.register.__qualname__.__len__()==16, abstractmethod.__name__.__len__()==14, get_cache_token.__name__.__len__()==15, abc.__name__.__len__()==3, ABCMeta mro entry name lengths, ABC mro entry name lengths, ABCMeta.__subclasshook__/__qualname__.__len__()==24, issubclass/isinstance behavioral invariants, abstractmethod.__class__.__name__.__len__()==8, ABC.__doc__.__class__.__name__.__len__()==3, update_abstractmethods/__name__.__len__()==22, ABC.__module__.__len__()==3, ABCMeta.__prepare__.__qualname__.__len__()==19, ABCMeta.__prepare__.__name__.__len__()==11, ABCMeta.__init__.__qualname__.__len__()==13, ABCMeta.__getattribute__.__qualname__.__len__()==21."
    - "This spec covers: ABCMeta.__call__.__qualname__.__len__()==13 ('type.__call__'); ABCMeta.__repr__.__qualname__.__len__()==13 ('type.__repr__'); ABCMeta.__setattr__.__qualname__.__len__()==16 ('type.__setattr__'); ABCMeta.__delattr__.__qualname__.__len__()==16 ('type.__delattr__'); abstractmethod.__code__.__class__.__name__.__len__()==4 ('code'); ABC.__subclasshook__.__qualname__.__len__()==20 ('ABC.__subclasshook__')."
    - "ABCMeta.__call__ and ABCMeta.__repr__ are both inherited from type; their qualnames 'type.__call__' and 'type.__repr__' share the same length (13)."
    - "ABCMeta.__setattr__ and ABCMeta.__delattr__ are both inherited from type; their qualnames 'type.__setattr__' and 'type.__delattr__' share the same length (16)."
    - "The __qualname__ of inherited methods reveals the true owner: type, not ABCMeta. ABCMeta defines __new__, __instancecheck__, __subclasscheck__, __subclasshook__, and __prepare__ itself — those carry the 'ABCMeta.' prefix."
    - "abstractmethod is a class (type == 'type') with an __init__ method. abstractmethod.__code__ accesses the code object of the abstractmethod function/class body. Its __class__.__name__ == 'code' (4 chars)."
    - "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (20 chars): 'ABC' (3) + '.' (1) + '__subclasshook__' (16) = 20. This differs from ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars) — ABC's is shorter because 'ABC' (3) < 'ABCMeta' (7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta inherited-from-type dunder method __qualname__ lengths — extra31
#
# ABCMeta is a subclass of type. Several special methods are inherited from
# type and NOT overridden by ABCMeta, so their __qualname__ carries 'type.'
# as the prefix rather than 'ABCMeta.':
#   ABCMeta.__call__.__qualname__    == 'type.__call__'    (13 chars)
#   ABCMeta.__repr__.__qualname__    == 'type.__repr__'    (13 chars)
#   ABCMeta.__setattr__.__qualname__ == 'type.__setattr__' (16 chars)
#   ABCMeta.__delattr__.__qualname__ == 'type.__delattr__' (16 chars)
# __call__ and __repr__ share the same qualname length (13): 'type.' (5) +
# '__call__' (8) = 13, and 'type.' (5) + '__repr__' (8) = 13.
# __setattr__ and __delattr__ share the same qualname length (16): 'type.' (5) +
# '__setattr__' (11) = 16, and 'type.' (5) + '__delattr__' (11) = 16.
# No prior abc spec has captured these four __qualname__.__len__() values.
# ---------------------------------------------------------------------------

table abc_extra31.abcmeta_type_inherited_qualname_lengths:
  description: "ABCMeta methods inherited from type: __qualname__.__len__() in extra31 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmetatypelen31

  columns: [id, function, args, expected, description]
  rows:
    - [call,     ABCMeta.__call__.__qualname__.__len__,    [], 13, "'type.__call__' (13 chars) — inherited from type; __call__ and __repr__ share the same length"]
    - [repr,     ABCMeta.__repr__.__qualname__.__len__,    [], 13, "'type.__repr__' (13 chars) — inherited from type; same length as __call__"]
    - [setattr,  ABCMeta.__setattr__.__qualname__.__len__, [], 16, "'type.__setattr__' (16 chars) — inherited from type; __setattr__ and __delattr__ share the same length"]
    - [delattr,  ABCMeta.__delattr__.__qualname__.__len__, [], 16, "'type.__delattr__' (16 chars) — inherited from type; same length as __setattr__"]

# ---------------------------------------------------------------------------
# abstractmethod.__code__.__class__.__name__.__len__() — extra31 namespace
#
# abstractmethod is a class in Python. Its __code__ attribute is the code
# object for the abstractmethod function body (the __init__ that marks
# __isabstractmethod__). The code object's class is named 'code':
#   abstractmethod.__code__.__class__.__name__ == 'code' (4 chars)
# This is a novel attribute path combining class introspection (__code__),
# type introspection (__class__), and name retrieval (__name__).__len__().
# No prior abc spec has captured this value.
# ---------------------------------------------------------------------------

invariant abc_extra31.abstractmethod_code_class_name_len:
  description: "abc.abstractmethod.__code__.__class__.__name__.__len__() == 4 — the code object's class is named 'code' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__code__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# ABC.__subclasshook__.__qualname__.__len__() — extra31 namespace
#
# ABC defines __subclasshook__ as a classmethod. Its __qualname__ is:
#   ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (20 chars)
# This is distinct from ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__'
# (24 chars, covered in extra28). ABC's version is 4 chars shorter because
# 'ABC' (3) is 4 characters shorter than 'ABCMeta' (7).
# No prior abc spec has captured ABC.__subclasshook__.__qualname__.__len__() == 20.
# (extra10 captures the __qualname__ string equality; extra21 captures the __name__;
# but neither captures __qualname__.__len__() as a function call.)
# ---------------------------------------------------------------------------

invariant abc_extra31.ABC_subclasshook_qualname_len:
  description: "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — 'ABC.__subclasshook__' has 20 characters; 4 shorter than ABCMeta.__subclasshook__.__qualname__ (24)"
  category: method_names
  kind: python_call_eq
  function: ABC.__subclasshook__.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# Standalone invariants — extra31
# ---------------------------------------------------------------------------

invariant abc_extra31.ABCMeta_call_qualname_len:
  description: "abc.ABCMeta.__call__.__qualname__.__len__() == 13 — resolves to 'type.__call__' (13 chars); ABCMeta does not define its own __call__"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__call__.__qualname__.__len__
  args: []
  expected: 13

invariant abc_extra31.ABCMeta_setattr_qualname_len:
  description: "abc.ABCMeta.__setattr__.__qualname__.__len__() == 16 — resolves to 'type.__setattr__' (16 chars); inherited from type with no ABCMeta override"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__setattr__.__qualname__.__len__
  args: []
  expected: 16
