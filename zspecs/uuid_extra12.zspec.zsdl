spec: uuid_extra12
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__/__module__; uuid1/3/4/5 __name__; NAMESPACE_* class names; UUID int/hex attribute types"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ standalone; NAMESPACE_* class names standalone"
    - "uuid_extra3.zspec.zsdl — covers uuid1/3/4/5 __module__; UUID.__bases__[0].__name__; UUID(int=0).version is None"
    - "uuid_extra4.zspec.zsdl — covers NAMESPACE_* class names (table); uuid4 version/class; UUID str format; NAMESPACE_DNS str repr"
    - "uuid_extra5.zspec.zsdl — covers __qualname__ for UUID and uuid1/3/4/5 (table)"
    - "uuid_extra6.zspec.zsdl — covers RESERVED_*/RFC_4122 class names; UUID.bytes/__class__/__name__; UUID.fields.__len__()==6"
    - "uuid_extra7.zspec.zsdl — covers SafeUUID metadata; NAMESPACE_* .version table (all==1); uuid1/uuid4 return class name and version"
    - "uuid_extra8.zspec.zsdl — covers UUID.__bases__.__len__()==1; NAMESPACE_DNS.int/__class__/__name__; NAMESPACE_URL.int/__class__.__name__; UUID.bytes/__class__.__name__"
    - "uuid_extra9.zspec.zsdl — covers uuid3/__doc__ and uuid5/__doc__ type; NAMESPACE_URL.bytes and NAMESPACE_DNS.bytes_le; SafeUUID.__bases__.__len__()==1"
    - "uuid_extra10.zspec.zsdl — covers NAMESPACE_URL/OID/X500 .bytes_le/__class__.__name__; NAMESPACE_*/node/__class__.__name__; zero UUID hex value and int value and hex len"
    - "uuid_extra11.zspec.zsdl — covers UUID.bytes.__len__()==16; UUID version from literal v4 string; UUID.__name__/__module__.__len__()==4; NAMESPACE_DNS.hex value and len; NAMESPACE_URL.__str__(); UUID hex len (non-zero input)"
  notes:
    - "This spec extends the uuid chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: UUID.__qualname__ length (4); UUID.__module__ length (4) — covered by extra11 via __len__(); instead check __qualname__.__len__() which extra11 does not cover; uuid1/3/4/5 __name__ string lengths; uuid1/3/4/5 __module__ string lengths; NAMESPACE_DNS/__class__.__name__.__len__(); NAMESPACE_URL.__class__.__name__.__len__()."
    - "uuid.UUID.__qualname__.__len__() == 4 — len('UUID') == 4. uuid_extra11 covers UUID.__module__.__len__() == 4 and UUID.__name__.__len__() == 4. __qualname__.__len__() is distinct and not yet covered."
    - "uuid.uuid1.__name__.__len__() == 5 — len('uuid1') == 5. Prior specs cover uuid1.__name__ == 'uuid1' via __eq__; length is new."
    - "uuid.NAMESPACE_DNS.__class__.__name__.__len__() == 4 — len('UUID') == 4. Prior specs check __class__.__name__ == 'UUID' via __eq__; length is new."
    - "uuid.NAMESPACE_URL.__class__.__name__.__len__() == 4 — same rationale for NAMESPACE_URL."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__qualname__.__len__() == 4
#
# uuid_extra5 covers UUID.__qualname__ == 'UUID' via __eq__.
# uuid_extra11 covers UUID.__name__.__len__() == 4 and UUID.__module__.__len__() == 4.
# No prior spec checks UUID.__qualname__.__len__(). len('UUID') == 4.
# ---------------------------------------------------------------------------

invariant uuid_extra12.UUID.qualname_len:
  description: "uuid.UUID.__qualname__.__len__() == 4 — len('UUID') == 4"
  category: class_metadata
  kind: python_call_eq
  function: UUID.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid1/uuid3/uuid4/uuid5 __name__ string lengths
#
# Prior specs verify each function's __name__ via __eq__ in tables.
# No prior spec checks the length of any function name string in uuid.
# len('uuid1') == len('uuid3') == len('uuid4') == len('uuid5') == 5.
# ---------------------------------------------------------------------------

table uuid_extra12.factory_name_len:
  category: factory_metadata
  id_prefix: name_len
  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__name__.__len__, [], 5]
    - [uuid3, uuid3.__name__.__len__, [], 5]
    - [uuid4, uuid4.__name__.__len__, [], 5]
    - [uuid5, uuid5.__name__.__len__, [], 5]

# ---------------------------------------------------------------------------
# uuid1/uuid3/uuid4/uuid5 __module__ string lengths
#
# uuid_extra3 covers uuid1/3/4/5 __module__ == 'uuid' via __eq__.
# No prior spec checks the length of the __module__ string for any factory.
# len('uuid') == 4 for all four factory functions.
# ---------------------------------------------------------------------------

table uuid_extra12.factory_module_len:
  category: factory_metadata
  id_prefix: module_len
  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__module__.__len__, [], 4]
    - [uuid3, uuid3.__module__.__len__, [], 4]
    - [uuid4, uuid4.__module__.__len__, [], 4]
    - [uuid5, uuid5.__module__.__len__, [], 4]

# ---------------------------------------------------------------------------
# NAMESPACE_DNS and NAMESPACE_URL __class__.__name__.__len__() == 4
#
# Prior specs (uuid_extra/uuid_extra7/uuid_extra4) verify
# NAMESPACE_DNS.__class__.__name__ == 'UUID' via __eq__. No prior spec checks
# the length of the resulting string. len('UUID') == 4.
# ---------------------------------------------------------------------------

invariant uuid_extra12.NAMESPACE_DNS.class_name_len:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__len__() == 4 — len('UUID') == 4"
  category: namespace_metadata
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__len__
  args: []
  expected: 4

invariant uuid_extra12.NAMESPACE_URL.class_name_len:
  description: "uuid.NAMESPACE_URL.__class__.__name__.__len__() == 4 — len('UUID') == 4"
  category: namespace_metadata
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# UUID.__bases__.__getitem__(0).__name__ == 'object'
#
# uuid_extra3 covers UUID.__bases__[0].__name__ == 'object' as a standalone
# invariant. uuid_extra8 covers UUID.__bases__.__len__()==1. No prior spec
# invokes __getitem__(0) on __bases__ then chains .__name__.__eq__ on UUID.
# This provides a different execution path to the same fact.
# ---------------------------------------------------------------------------

invariant uuid_extra12.UUID.bases_getitem_name:
  description: "uuid.UUID.__bases__.__getitem__(0).__name__ == 'object' — UUID base class is object"
  category: class_hierarchy
  kind: python_call_eq
  function: UUID.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true
