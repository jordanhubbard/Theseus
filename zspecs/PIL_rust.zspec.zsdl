spec: PIL_rust
version: ">=3.9"
backend: rust_module(PIL_rust)

docs: https://pillow.readthedocs.io/en/stable/reference/

provenance:
  derived_from:
    - "https://pillow.readthedocs.io/en/stable/reference/ — Pillow documentation"
  not_derived_from:
    - "Pillow source: PIL/Image.py"
  notes:
    - "Pillow (PIL fork) provides image processing for Python."
    - "Image.new('RGB', (100, 200)).size == (100, 200)."
    - "Image.new('RGB', (100, 200)).width == 100."
    - "Image.new('RGB', (100, 200)).height == 200."
    - "Image.new('RGB', (10, 10)).mode == 'RGB'."
    - "Image.new('L', (10, 10)).mode == 'L' — grayscale."
    - "Expose pil_width(w, h, mode) -> int: Image.new(mode, (w,h)).width."
    - "Expose pil_height(w, h, mode) -> int: Image.new(mode, (w,h)).height."
    - "Expose pil_mode(w, h, mode) -> str: Image.new(mode, (w,h)).mode."
    - "All test vectors verified against Pillow 11.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pil_width — image width
table PIL_rust.image.width:
  kind: python_call_eq
  category: width
  id_prefix: pil_w
  function: pil_width

  columns: [id, args, expected]
  rows:
    - [hundred,    [100, 200, "RGB"],  100]
    - [ten,        [10, 20, "RGB"],     10]
    - [one,        [1, 1, "L"],          1]

# pil_height — image height
table PIL_rust.image.height:
  kind: python_call_eq
  category: height
  id_prefix: pil_h
  function: pil_height

  columns: [id, args, expected]
  rows:
    - [two_hundred, [100, 200, "RGB"], 200]
    - [twenty,      [10, 20, "RGB"],    20]

# pil_mode — image mode string
table PIL_rust.image.mode:
  kind: python_call_eq
  category: mode
  id_prefix: pil_m
  function: pil_mode

  columns: [id, args, expected]
  rows:
    - [rgb,  [10, 10, "RGB"], "RGB"]
    - [gray, [10, 10, "L"],   "L"]
    - [rgba, [10, 10, "RGBA"], "RGBA"]

