spec: sprintf_js
version: ">=1.1.0"
backend: node(sprintf-js)

docs: https://www.npmjs.com/package/sprintf-js

provenance:
  derived_from:
    - "sprintf-js README — https://www.npmjs.com/package/sprintf-js"
    - "Test vectors verified with sprintf-js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "sprintf-js source"
  notes:
    - "sprintf-js is an npm package. Install: npm install sprintf-js"
    - "sprintf(fmt, ...args) formats a string using C-style format specifiers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns formatted string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sprintf_js.sprintf:
  kind: node_module_call_eq
  function: sprintf
  category: format
  id_prefix: sprintf

  columns: [id, args, expected]
  rows:
    - [string_int, ["Hello %s, you are %d years old", "Alice", 30],
       "Hello Alice, you are 30 years old"]
    - [float,      ["%.2f", 3.14159],  "3.14"]
    - [pad,        ["%05d", 42],       "00042"]
