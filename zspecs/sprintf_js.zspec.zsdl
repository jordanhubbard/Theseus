spec: sprintf_js
version: ">=1.0.0"
backend: node(sprintf-js)

docs: https://github.com/alexei/sprintf.js#readme

provenance:
  derived_from:
    - "sprintf-js README — https://github.com/alexei/sprintf.js#readme"
    - "Test vectors verified with sprintf-js@1.1.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "sprintf-js source"
  notes:
    - "sprintf-js exports { sprintf, vsprintf }."
    - "sprintf(fmt, ...args) returns a formatted string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string. No errors for valid format strings and matching args."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sprintf_js.sprintf:
  kind: node_module_call_eq
  function: sprintf
  category: sprintf
  id_prefix: sprintf

  columns: [id, args, expected]
  rows:
    - [int_expr,   ["%d + %d = %d", 1, 2, 3],   "1 + 2 = 3"]
    - [string_s,   ["Hello, %s!", "world"],       "Hello, world!"]
    - [float_f,    ["%.2f", 3.14159],             "3.14"]
