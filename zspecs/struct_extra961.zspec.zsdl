spec: struct_extra961
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct and struct.error class dicts, bases, builtin function names, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra961.class_dict_types:
  description: "struct class __dict__ type identity"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: st961dt
  columns: [id, function, args, expected]
  rows:
    - [st961dt001, struct.Struct.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [st961dt002, struct.error.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [st961dt003, struct.Struct.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st961dt004, struct.error.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st961dt005, struct.Struct.__dict__.__class__.__module__.__eq__, ["builtins"], true]
    - [st961dt006, struct.error.__dict__.__class__.__module__.__eq__, ["builtins"], true]

table struct_extra961.class_bases_types:
  description: "struct class __bases__ type and module identity"
  kind: python_call_eq
  category: class_bases_types
  id_prefix: st961bt
  columns: [id, function, args, expected]
  rows:
    - [st961bt001, struct.error.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [st961bt002, struct.Struct.__class__.__name__.__eq__,          ["type"],  true]
    - [st961bt003, struct.error.__class__.__name__.__eq__,           ["type"],  true]
    - [st961bt004, struct.__name__.__eq__,                           ["struct"], true]
    - [st961bt005, struct.__spec__.name.__eq__,                      ["struct"], true]
    - [st961bt006, struct.__name__.__class__.__name__.__eq__,        ["str"],   true]

table struct_extra961.builtin_function_class_names:
  description: "struct builtin function __class__.__name__ identity"
  kind: python_call_eq
  category: builtin_function_class_names
  id_prefix: st961fn
  columns: [id, function, args, expected]
  rows:
    - [st961fn001, struct.pack.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [st961fn002, struct.unpack.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [st961fn003, struct.calcsize.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [st961fn004, struct.pack.__module__.__eq__,               ["struct"], true]
    - [st961fn005, struct.unpack.__module__.__eq__,             ["struct"], true]
    - [st961fn006, struct.calcsize.__module__.__eq__,           ["struct"], true]
    - [st961fn007, struct.__spec__.__class__.__name__.__eq__,   ["ModuleSpec"], true]
