spec: inspect_extra1876
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "inspect module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party inspect extensions"
  notes:
    - "inspect.Parameter uses __setattr__ to enforce immutability of its fields"
    - "Parameter and Signature both use __slots__ for memory efficiency"
    - "getlocals is not part of inspect; use the built-in locals() instead"
  created_at: "2026-04-12"

table inspect_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["in1876-aa-001", "inspect.Parameter.__dict__.__contains__", ["__getattr__"], false]
    - ["in1876-aa-002", "inspect.Parameter.__dict__.__contains__", ["__setattr__"], true]
    - ["in1876-aa-003", "inspect.Parameter.__dict__.__contains__", ["__delattr__"], false]
    - ["in1876-aa-004", "inspect.Parameter.__dict__.__contains__", ["__getattribute__"], false]
    - ["in1876-aa-005", "inspect.Signature.__dict__.__contains__", ["__getattr__"], false]
    - ["in1876-aa-006", "inspect.Signature.__dict__.__contains__", ["__setattr__"], false]
    - ["in1876-aa-007", "inspect.BoundArguments.__dict__.__contains__", ["__getattr__"], false]
    - ["in1876-aa-008", "inspect.BoundArguments.__dict__.__contains__", ["__setattr__"], false]

table inspect_extra1876.introspection_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["in1876-ip-001", "inspect.Parameter.__dict__.__contains__", ["__dir__"], false]
    - ["in1876-ip-002", "inspect.Parameter.__dict__.__contains__", ["__sizeof__"], false]
    - ["in1876-ip-003", "inspect.Signature.__dict__.__contains__", ["__dir__"], false]
    - ["in1876-ip-004", "inspect.Signature.__dict__.__contains__", ["__sizeof__"], false]
    - ["in1876-ip-005", "inspect.BoundArguments.__dict__.__contains__", ["__dir__"], false]
    - ["in1876-ip-006", "inspect.BoundArguments.__dict__.__contains__", ["__sizeof__"], false]
    - ["in1876-ip-007", "inspect.Parameter.__dict__.__contains__", ["__slots__"], true]
    - ["in1876-ip-008", "inspect.Signature.__dict__.__contains__", ["__slots__"], true]

table inspect_extra1876.inspect_stack_attrs:
