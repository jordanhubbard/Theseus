  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.SALT_SIZE==16 / MAX_DIGEST_SIZE==64 / MAX_KEY_SIZE==64 / PERSON_SIZE==16
# hashlib.blake2s.SALT_SIZE==8 / MAX_DIGEST_SIZE==32 / MAX_KEY_SIZE==32 / PERSON_SIZE==8
#
# Wave 281 theme: blake2b and blake2s class constants.
#
# blake2b and blake2s expose four int class constants from the _blake2 C extension:
# SALT_SIZE, MAX_DIGEST_SIZE, MAX_KEY_SIZE, and PERSON_SIZE. blake2b supports wider
# outputs (up to 64 bytes) and larger salts/personalization strings (16 bytes) than
# blake2s (32 bytes max output, 8 bytes for salt/person). No prior hashlib spec
# anchors these constants under blakeconst142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra142.blake2b_class_constants:
  description: "hashlib.blake2b.SALT_SIZE==16 / MAX_DIGEST_SIZE==64 / MAX_KEY_SIZE==64 / PERSON_SIZE==16 — blake2b C-level int constants from _blake2 extension; SALT_SIZE and PERSON_SIZE are both 16 bytes; MAX_DIGEST_SIZE and MAX_KEY_SIZE are both 64 bytes; no prior hashlib spec anchors these constants; first blakeconst142 anchor"
  kind: python_call_eq
  category: class_constants
  id_prefix: blakeconst142

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_salt_size,        blake2b.SALT_SIZE.__eq__,        [16], true, "hashlib.blake2b.SALT_SIZE == 16 (maximum salt length in bytes for BLAKE2b)"]
    - [blake2b_max_digest_size,  blake2b.MAX_DIGEST_SIZE.__eq__,  [64], true, "hashlib.blake2b.MAX_DIGEST_SIZE == 64 (maximum digest length in bytes for BLAKE2b)"]
    - [blake2b_max_key_size,     blake2b.MAX_KEY_SIZE.__eq__,     [64], true, "hashlib.blake2b.MAX_KEY_SIZE == 64 (maximum key length in bytes for BLAKE2b)"]
    - [blake2b_person_size,      blake2b.PERSON_SIZE.__eq__,      [16], true, "hashlib.blake2b.PERSON_SIZE == 16 (maximum personalization string length in bytes for BLAKE2b)"]

table hashlib_extra142.blake2s_class_constants:
  description: "hashlib.blake2s.SALT_SIZE==8 / MAX_DIGEST_SIZE==32 / MAX_KEY_SIZE==32 / PERSON_SIZE==8 — blake2s C-level int constants from _blake2 extension; SALT_SIZE and PERSON_SIZE are both 8 bytes; MAX_DIGEST_SIZE and MAX_KEY_SIZE are both 32 bytes; no prior hashlib spec anchors blake2s constants; first blakeconst142 anchor"
  kind: python_call_eq
  category: class_constants
  id_prefix: blakeconst142

  columns: [id, function, args, expected, description]
  rows:
    - [blake2s_salt_size,        blake2s.SALT_SIZE.__eq__,        [8],  true, "hashlib.blake2s.SALT_SIZE == 8 (maximum salt length in bytes for BLAKE2s, half of BLAKE2b)"]
    - [blake2s_max_digest_size,  blake2s.MAX_DIGEST_SIZE.__eq__,  [32], true, "hashlib.blake2s.MAX_DIGEST_SIZE == 32 (maximum digest length in bytes for BLAKE2s, half of BLAKE2b)"]
    - [blake2s_max_key_size,     blake2s.MAX_KEY_SIZE.__eq__,     [32], true, "hashlib.blake2s.MAX_KEY_SIZE == 32 (maximum key length in bytes for BLAKE2s, half of BLAKE2b)"]
    - [blake2s_person_size,      blake2s.PERSON_SIZE.__eq__,      [8],  true, "hashlib.blake2s.PERSON_SIZE == 8 (maximum personalization string length in bytes for BLAKE2s)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__doc__.__eq__('Return a new BLAKE2b hash object.')
# hashlib.blake2b.__doc__.__len__()==33
# hashlib.blake2s.__doc__.__eq__('Return a new BLAKE2s hash object.')
# hashlib.blake2s.__doc__.__len__()==33
# hashlib.blake2b.__module__.__eq__('_blake2')
# hashlib.blake2s.__module__.__eq__('_blake2')
#
# Wave 281 theme: blake2b and blake2s doc and module identity.
#
# blake2b and blake2s each have a 33-char docstring following the pattern
# 'Return a new BLAKE2x hash object.' The __module__ for both is '_blake2'
# (the C extension), not 'hashlib'. No prior hashlib spec anchors these
# __doc__ equality values or __module__ for blake2b/blake2s under blakeconst142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra142.blake2_doc_and_module:
  description: "hashlib.blake2b/__doc__.__eq__('Return a new BLAKE2b hash object.')==True / blake2b/__doc__/__len__()==33 / blake2s/__doc__.__eq__('Return a new BLAKE2s hash object.')==True / blake2s/__doc__/__len__()==33 / blake2b/__module__.__eq__('_blake2')==True / blake2s/__module__.__eq__('_blake2')==True — both blake2 types have 33-char docstrings; __module__ is '_blake2' (C ext), not 'hashlib'; no prior hashlib spec anchors these; first blakeconst142 anchor"
  kind: python_call_eq
  category: doc_identity
  id_prefix: blakeconst142

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_doc_eq,     blake2b.__doc__.__eq__,     ["Return a new BLAKE2b hash object."], true, "hashlib.blake2b.__doc__ is 'Return a new BLAKE2b hash object.' (33 chars)"]
    - [blake2b_doc_len,    blake2b.__doc__.__len__,     [],                                   33,   "hashlib.blake2b.__doc__.__len__() is 33"]
    - [blake2s_doc_eq,     blake2s.__doc__.__eq__,     ["Return a new BLAKE2s hash object."], true, "hashlib.blake2s.__doc__ is 'Return a new BLAKE2s hash object.' (33 chars)"]
    - [blake2s_doc_len,    blake2s.__doc__.__len__,     [],                                   33,   "hashlib.blake2s.__doc__.__len__() is 33"]
    - [blake2b_module_eq,  blake2b.__module__.__eq__,   ["_blake2"],                          true, "hashlib.blake2b.__module__ is '_blake2' (from the _blake2 C extension, not hashlib)"]
    - [blake2s_module_eq,  blake2s.__module__.__eq__,   ["_blake2"],                          true, "hashlib.blake2s.__module__ is '_blake2' (from the _blake2 C extension, not hashlib)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__doc__.__len__()==68
# hashlib.sha3_512.__doc__.__len__()==68
# hashlib.sha3_224.__doc__.__len__()==68
# hashlib.sha3_384.__doc__.__len__()==68
# hashlib.shake_128.__doc__.__len__()==78
# hashlib.shake_256.__doc__.__len__()==78
#
# Wave 281 theme: SHA-3 and SHAKE constructor docstring lengths.
#
# sha3_256/sha3_512/sha3_224/sha3_384 all have 68-char docstrings. The 'sha3_'
# prefix (5 chars) plus a 3-digit size suffix gives consistent template length.
# shake_128 and shake_256 each have 78-char docstrings — longer than sha3 variants
# because the template describes the variable-length digest. No prior hashlib spec
# anchors sha3/shake __doc__ lengths under blakeconst142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra142.sha3_shake_doc_lengths:
  description: "hashlib.sha3_256/__doc__/__len__()==68 / sha3_512/__doc__/__len__()==68 / sha3_224/__doc__/__len__()==68 / sha3_384/__doc__/__len__()==68 / shake_128/__doc__/__len__()==78 / shake_256/__doc__/__len__()==78 — sha3 variants share a 68-char docstring template; shake variants share a 78-char template (10 chars longer to describe variable-length output); no prior hashlib spec anchors these lengths; first blakeconst142 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: blakeconst142

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_doc_len,  sha3_256.__doc__.__len__,  [], 68, "hashlib.sha3_256.__doc__ is 68 chars (sha3_ prefix + 3-digit size in docstring template)"]
    - [sha3_512_doc_len,  sha3_512.__doc__.__len__,  [], 68, "hashlib.sha3_512.__doc__ is 68 chars (same template as sha3_256)"]
    - [sha3_224_doc_len,  sha3_224.__doc__.__len__,  [], 68, "hashlib.sha3_224.__doc__ is 68 chars (same template as sha3_256/sha3_512)"]
    - [sha3_384_doc_len,  sha3_384.__doc__.__len__,  [], 68, "hashlib.sha3_384.__doc__ is 68 chars (same template as other sha3 variants)"]
    - [shake_128_doc_len, shake_128.__doc__.__len__, [], 78, "hashlib.shake_128.__doc__ is 78 chars (shake template is 10 chars longer than sha3 template)"]
    - [shake_256_doc_len, shake_256.__doc__.__len__, [], 78, "hashlib.shake_256.__doc__ is 78 chars (same template as shake_128)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.SALT_SIZE.__eq__(16) — standalone
#
# hashlib.blake2b.SALT_SIZE is 16. The BLAKE2b algorithm supports salts up to
# 16 bytes in length, compared to BLAKE2s which supports only 8. The SALT_SIZE
# class constant is defined at C level in _blake2/blake2module.c and exposed
# as an int attribute on the blake2b type object. No prior hashlib spec anchors
# blake2b.SALT_SIZE as a standalone under blakeconst142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra142.blake2b_SALT_SIZE_16:
  description: "hashlib.blake2b.SALT_SIZE.__eq__(16) == True — BLAKE2b supports salts up to 16 bytes (vs BLAKE2s 8 bytes); C-level int constant from _blake2 extension; no prior hashlib spec anchors blake2b.SALT_SIZE as a standalone; first standalone under blakeconst142"
  category: class_constants
  kind: python_call_eq
  function: blake2b.SALT_SIZE.__eq__
  args: [16]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.SALT_SIZE.__eq__(8) — standalone
#
# hashlib.blake2s.SALT_SIZE is 8. BLAKE2s is the 32-bit variant of BLAKE2,
# designed for smaller architectures. Its SALT_SIZE (8) is exactly half that
# of BLAKE2b (16), reflecting the narrower word size. No prior hashlib spec
# anchors blake2s.SALT_SIZE as a standalone under blakeconst142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra142.blake2s_SALT_SIZE_8:
  description: "hashlib.blake2s.SALT_SIZE.__eq__(8) == True — BLAKE2s supports salts up to 8 bytes (half of BLAKE2b's 16); BLAKE2s is the 32-bit variant designed for smaller architectures; no prior hashlib spec anchors blake2s.SALT_SIZE as a standalone; first standalone under blakeconst142"
  category: class_constants
  kind: python_call_eq
  function: blake2s.SALT_SIZE.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) — standalone
#
# hashlib.blake2b.MAX_DIGEST_SIZE is 64. BLAKE2b produces variable-length
# digests up to 64 bytes (512 bits), making it suitable as a drop-in for
# SHA-512. The constant is defined in _blake2/blake2b-ref.c (BLAKE2B_OUTBYTES).
# No prior hashlib spec anchors blake2b.MAX_DIGEST_SIZE as a standalone under
# blakeconst142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra142.blake2b_MAX_DIGEST_SIZE_64:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) == True — BLAKE2b supports variable-length digests up to 64 bytes (512 bits), matching SHA-512 size; C-level constant from _blake2 extension; no prior hashlib spec anchors this as a standalone; first standalone under blakeconst142"
  category: class_constants
  kind: python_call_eq
  function: blake2b.MAX_DIGEST_SIZE.__eq__
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) — standalone
#
# hashlib.blake2s.MAX_DIGEST_SIZE is 32. BLAKE2s produces variable-length
# digests up to 32 bytes (256 bits), making it suitable as a drop-in for
# SHA-256. The maximum digest size for BLAKE2s is exactly half that of
# BLAKE2b (64 bytes). No prior hashlib spec anchors blake2s.MAX_DIGEST_SIZE
# as a standalone under blakeconst142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra142.blake2s_MAX_DIGEST_SIZE_32:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) == True — BLAKE2s supports variable-length digests up to 32 bytes (256 bits), matching SHA-256 size; half of BLAKE2b's 64-byte maximum; no prior hashlib spec anchors this as a standalone; first standalone under blakeconst142"
  category: class_constants
  kind: python_call_eq
  function: blake2s.MAX_DIGEST_SIZE.__eq__
  args: [32]
  expected: true

