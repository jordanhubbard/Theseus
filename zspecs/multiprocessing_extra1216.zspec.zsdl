spec: multiprocessing_extra1216
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.Process/__mro__/__len__, multiprocessing.pool.Pool/__mro__/__len__, multiprocessing.queues.Queue/__mro__/__len__, multiprocessing.synchronize.Lock/__mro__/__len__, multiprocessing.managers.BaseManager/__mro__/__len__, multiprocessing.managers.SyncManager/__mro__/__len__, multiprocessing.AuthenticationError/__mro__/__len__"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing class __mro__.__len__() for Process (3), pool.Pool (2), queues.Queue (2), synchronize.Lock (3), managers.BaseManager (2), managers.SyncManager (3), and AuthenticationError (5) — behaviors not covered by extra1186 (__doc__/__weakref__ identity) or extra1201 (__bases__.__len__)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1216.process_mro_len:
