  rows:
    - [mp1216pm001, multiprocessing.Process.__mro__.__len__,                        [], 3]
    - [mp1216pm002, multiprocessing.AuthenticationError.__mro__.__len__,            [], 5]
    - [mp1216pm003, multiprocessing.Process.__mro__.__class__.__name__.__eq__,      ["tuple"], true]
    - [mp1216pm004, multiprocessing.AuthenticationError.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [mp1216pm005, multiprocessing.Process.__name__.__len__.__eq__,                [7],       true]
    - [mp1216pm006, multiprocessing.AuthenticationError.__name__.__len__.__eq__,    [19],      true]
    - [mp1216pm007, multiprocessing.Process.__name__.__eq__,                        ["Process"],             true]
