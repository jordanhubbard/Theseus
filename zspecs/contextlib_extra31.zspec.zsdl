spec: contextlib_extra31
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib_extra30.zspec.zsdl."
    - "Prior specs covered: __module__/__name__/__qualname__ for all major contextlib symbols; __module__.__len__() and __name__.__len__() for all symbols; MRO lengths for ExitStack(5)/suppress(4)/nullcontext(5)/closing/ContextDecorator(2)/AsyncExitStack(5); AbstractContextManager.__abstractmethods__.__len__()==1; ExitStack.enter_context/__qualname__ (eq) and ExitStack.callback/__qualname__ (eq)."
    - "This spec covers: __qualname__.__len__() for suppress.__enter__/__exit__/__init__; nullcontext.__enter__/__exit__/__init__; ExitStack.close/__enter__/__exit__; closing.__enter__/__exit__/__init__."
    - "suppress.__enter__.__qualname__ == 'suppress.__enter__' (len=18)."
    - "suppress.__exit__.__qualname__ == 'suppress.__exit__' (len=17); suppress.__init__.__qualname__ == 'suppress.__init__' (len=17)."
    - "nullcontext.__enter__.__qualname__ == 'nullcontext.__enter__' (len=21) — longest nullcontext method qualname."
    - "nullcontext.__exit__.__qualname__ == 'nullcontext.__exit__' (len=20); nullcontext.__init__.__qualname__ == 'nullcontext.__init__' (len=20)."
    - "ExitStack.close.__qualname__ == 'ExitStack.close' (len=15) — defined directly on ExitStack."
    - "ExitStack.__enter__.__qualname__ == 'ExitStack.__enter__' (len=19)."
    - "ExitStack.__exit__.__qualname__ == 'ExitStack.__exit__' (len=18)."
    - "closing.__enter__.__qualname__ == 'closing.__enter__' (len=17); closing.__exit__.__qualname__ == 'closing.__exit__' (len=16)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# suppress method __qualname__.__len__() table (extra31 namespace)
#
# suppress is a fully concrete context manager that silences specified
# exceptions. Its three core methods have qualnames of the form
# 'suppress.<method>':
#   __enter__ -> 18, __exit__ -> 17, __init__ -> 17.
# __enter__ is one character longer than __exit__ and __init__ (which share 17)
# because '__enter__' has 9 characters vs '__exit__'/'__init__' with 8 each,
# plus the 'suppress.' prefix (9 chars). No prior contextlib spec records these
# qualname lengths in the extra31 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra31.suppress_method_qualname_lens:
  description: "__qualname__.__len__() for suppress.__enter__, __exit__, and __init__"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: suppress_method_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [enter, suppress.__enter__.__qualname__.__len__, [], 18]
    - [exit,  suppress.__exit__.__qualname__.__len__,  [], 17]
    - [init,  suppress.__init__.__qualname__.__len__,  [], 17]

# ---------------------------------------------------------------------------
# nullcontext and ExitStack method __qualname__.__len__() table
# (extra31 namespace)
#
# nullcontext qualnames ('nullcontext.<method>'):
#   __enter__ -> 21, __exit__ -> 20, __init__ -> 20.
# ExitStack qualnames defined directly on ExitStack:
#   close -> 15, __enter__ -> 19, __exit__ -> 18.
# nullcontext.__enter__ (21) is the longest method qualname among the four
# concrete context manager classes covered in this spec. ExitStack.close (15)
# is the shortest because 'close' (5 chars) is much shorter than dunder names.
# Note: ExitStack.enter_context and ExitStack.push have qualnames on the
# internal _BaseExitStack class and were covered in contextlib_extra26.
# No prior contextlib spec records these qualname lengths in the extra31
# namespace.
# ---------------------------------------------------------------------------

table contextlib_extra31.nullcontext_exitstack_method_qualname_lens:
  description: "__qualname__.__len__() for nullcontext and ExitStack (directly-defined) methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: method_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [nullcontext_enter,  nullcontext.__enter__.__qualname__.__len__, [], 21]
    - [nullcontext_exit,   nullcontext.__exit__.__qualname__.__len__,  [], 20]
    - [nullcontext_init,   nullcontext.__init__.__qualname__.__len__,  [], 20]
    - [ExitStack_close,    ExitStack.close.__qualname__.__len__,       [], 15]
    - [ExitStack_enter,    ExitStack.__enter__.__qualname__.__len__,   [], 19]
    - [ExitStack_exit,     ExitStack.__exit__.__qualname__.__len__,    [], 18]

# ---------------------------------------------------------------------------
# nullcontext.__enter__.__qualname__.__len__() == 21 — standalone
# (extra31 namespace)
#
# 'nullcontext.__enter__' has 21 characters, making it the longest method
# qualname among the four concrete context managers inspected in this spec.
# nullcontext is a no-op context manager that returns a supplied value (or
# None) on __enter__. No prior contextlib spec records this standalone in the
# extra31 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra31.nullcontext.enter.qualname_len:
  description: "len(contextlib.nullcontext.__enter__.__qualname__) == 21 — longest among concrete CM method qualnames"
  category: method_qualname_lengths
  kind: python_call_eq
  function: nullcontext.__enter__.__qualname__.__len__
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# suppress.__enter__.__qualname__.__len__() == 18 — standalone
# (extra31 namespace)
#
# 'suppress.__enter__' has 18 characters. Among suppress's three methods,
# __enter__ is one character longer than __exit__ and __init__ (both 17)
# because '__enter__' is one character longer than '__exit__'. No prior
# contextlib spec records this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra31.suppress.enter.qualname_len:
  description: "len(contextlib.suppress.__enter__.__qualname__) == 18 — suppress.__enter__ is 1 longer than suppress.__exit__/__init__"
  category: method_qualname_lengths
  kind: python_call_eq
  function: suppress.__enter__.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# closing method __qualname__.__len__() — standalone table (extra31 namespace)
#
# closing wraps an object with a close() method as a context manager. Its
# three core methods have qualnames:
#   __enter__ -> 17, __exit__ -> 16, __init__ -> 16.
# This matches suppress's __exit__/__init__ length (17/17 for suppress vs
# 17/16/16 for closing — note closing.__enter__ == 17 too). No prior
# contextlib spec records closing method qualname lengths in the extra31
# namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra31.closing.enter.qualname_len:
  description: "len(contextlib.closing.__enter__.__qualname__) == 17 — 'closing.__enter__' has 17 characters"
  category: method_qualname_lengths
  kind: python_call_eq
  function: closing.__enter__.__qualname__.__len__
  args: []
  expected: 17
