spec: pathlib_extra202
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib.Path special method (dunder) qualnames not covered by prior pathlib_extra specs."
    - "All listed dunder methods resolve to qualnames on PurePath, not Path — Path inherits them from PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' (len=20); the / operator for path joining; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (len=21); the reflected / operator (str / Path); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__str__.__qualname__ == 'PurePath.__str__' (len=16); string representation of the path; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__repr__.__qualname__ == 'PurePath.__repr__' (len=17); developer representation of the path; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__hash__.__qualname__ == 'PurePath.__hash__' (len=17); hash value for use in sets/dicts; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__eq__.__qualname__ == 'PurePath.__eq__' (len=15); equality comparison; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__lt__.__qualname__ == 'PurePath.__lt__' (len=15); less-than ordering; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__bytes__.__qualname__ == 'PurePath.__bytes__' (len=18); bytes representation; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path division and string dunder qualnames
# __truediv__=='PurePath.__truediv__'(20), __rtruediv__=='PurePath.__rtruediv__'(21),
# __str__=='PurePath.__str__'(16)
# ---------------------------------------------------------------------------

table pathlib_extra202.path_division_and_str_qualnames:
  description: "pathlib.Path division and str dunders: __truediv__='PurePath.__truediv__'(20), __rtruediv__='PurePath.__rtruediv__'(21), __str__='PurePath.__str__'(16)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdunders202

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_qualname_eq,   pathlib.Path.__truediv__.__qualname__.__eq__,  ["PurePath.__truediv__"],  true, "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' (len=20); the / operator is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [rtruediv_qualname_eq,  pathlib.Path.__rtruediv__.__qualname__.__eq__, ["PurePath.__rtruediv__"], true, "pathlib.Path.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (len=21); the reflected / is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [str_qualname_eq,       pathlib.Path.__str__.__qualname__.__eq__,      ["PurePath.__str__"],      true, "pathlib.Path.__str__.__qualname__ == 'PurePath.__str__' (len=16); __str__ is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [truediv_qualname_len,  pathlib.Path.__truediv__.__qualname__.__len__, [],                        20,   "pathlib.Path.__truediv__.__qualname__.__len__() == 20; PurePath.__truediv__ has 20 characters; confirmed Python 3.14.3 macOS"]
    - [rtruediv_qualname_len, pathlib.Path.__rtruediv__.__qualname__.__len__,[], 21, "pathlib.Path.__rtruediv__.__qualname__.__len__() == 21; PurePath.__rtruediv__ has 21 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path repr, hash, and eq dunder qualnames
# __repr__=='PurePath.__repr__'(17), __hash__=='PurePath.__hash__'(17), __eq__=='PurePath.__eq__'(15)
# ---------------------------------------------------------------------------

table pathlib_extra202.path_repr_hash_eq_qualnames:
  description: "pathlib.Path repr/hash/eq dunders: __repr__='PurePath.__repr__'(17), __hash__='PurePath.__hash__'(17), __eq__='PurePath.__eq__'(15)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdunders202

  columns: [id, function, args, expected, description]
  rows:
    - [repr_qualname_eq,   pathlib.Path.__repr__.__qualname__.__eq__, ["PurePath.__repr__"], true, "pathlib.Path.__repr__.__qualname__ == 'PurePath.__repr__' (len=17); __repr__ is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [hash_qualname_eq,   pathlib.Path.__hash__.__qualname__.__eq__, ["PurePath.__hash__"], true, "pathlib.Path.__hash__.__qualname__ == 'PurePath.__hash__' (len=17); __hash__ is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [eq_qualname_eq,     pathlib.Path.__eq__.__qualname__.__eq__,   ["PurePath.__eq__"],   true, "pathlib.Path.__eq__.__qualname__ == 'PurePath.__eq__' (len=15); __eq__ is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [repr_qualname_len,  pathlib.Path.__repr__.__qualname__.__len__,[],                    17,   "pathlib.Path.__repr__.__qualname__.__len__() == 17; PurePath.__repr__ has 17 characters; confirmed Python 3.14.3 macOS"]
    - [hash_qualname_len,  pathlib.Path.__hash__.__qualname__.__len__,[],                    17,   "pathlib.Path.__hash__.__qualname__.__len__() == 17; PurePath.__hash__ has 17 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path lt and bytes dunder qualnames
# __lt__=='PurePath.__lt__'(15), __bytes__=='PurePath.__bytes__'(18)
# ---------------------------------------------------------------------------

table pathlib_extra202.path_lt_and_bytes_qualnames:
  description: "pathlib.Path lt and bytes dunders: __lt__='PurePath.__lt__'(15), __bytes__='PurePath.__bytes__'(18)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdunders202

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname_eq,      pathlib.Path.__lt__.__qualname__.__eq__,     ["PurePath.__lt__"],     true, "pathlib.Path.__lt__.__qualname__ == 'PurePath.__lt__' (len=15); __lt__ is defined on PurePath for ordering; confirmed Python 3.14.3 macOS"]
    - [bytes_qualname_eq,   pathlib.Path.__bytes__.__qualname__.__eq__,  ["PurePath.__bytes__"],  true, "pathlib.Path.__bytes__.__qualname__ == 'PurePath.__bytes__' (len=18); __bytes__ is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [lt_qualname_len,     pathlib.Path.__lt__.__qualname__.__len__,    [],                      15,   "pathlib.Path.__lt__.__qualname__.__len__() == 15; PurePath.__lt__ has 15 characters; confirmed Python 3.14.3 macOS"]
    - [bytes_qualname_len,  pathlib.Path.__bytes__.__qualname__.__len__, [],                      18,   "pathlib.Path.__bytes__.__qualname__.__len__() == 18; PurePath.__bytes__ has 18 characters; confirmed Python 3.14.3 macOS"]
    - [eq_qualname_len,     pathlib.Path.__eq__.__qualname__.__len__,    [],                      15,   "pathlib.Path.__eq__.__qualname__.__len__() == 15; PurePath.__eq__ has 15 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra202.truediv_qualname_eq:
  description: "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' — the / path-joining operator (len=20) is defined on PurePath and inherited by Path; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__truediv__.__qualname__.__eq__
  args: ["PurePath.__truediv__"]
  expected: true

invariant pathlib_extra202.rtruediv_qualname_eq:
  description: "pathlib.Path.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' — the reflected / operator (len=21) enables 'str / Path' syntax; defined on PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__rtruediv__.__qualname__.__eq__
  args: ["PurePath.__rtruediv__"]
  expected: true

invariant pathlib_extra202.str_qualname_eq:
  description: "pathlib.Path.__str__.__qualname__ == 'PurePath.__str__' — string representation of the path (len=16); defined on PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__str__.__qualname__.__eq__
  args: ["PurePath.__str__"]
  expected: true

invariant pathlib_extra202.repr_qualname_eq:
  description: "pathlib.Path.__repr__.__qualname__ == 'PurePath.__repr__' — developer representation of the path (len=17); defined on PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__repr__.__qualname__.__eq__
  args: ["PurePath.__repr__"]
  expected: true

invariant pathlib_extra202.hash_qualname_eq:
  description: "pathlib.Path.__hash__.__qualname__ == 'PurePath.__hash__' — hash for use in sets/dicts (len=17); defined on PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__hash__.__qualname__.__eq__
  args: ["PurePath.__hash__"]
  expected: true

invariant pathlib_extra202.eq_qualname_eq:
  description: "pathlib.Path.__eq__.__qualname__ == 'PurePath.__eq__' — equality comparison (len=15); defined on PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__eq__.__qualname__.__eq__
  args: ["PurePath.__eq__"]
  expected: true

invariant pathlib_extra202.lt_qualname_eq:
  description: "pathlib.Path.__lt__.__qualname__ == 'PurePath.__lt__' — less-than ordering operator (len=15); defined on PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__lt__.__qualname__.__eq__
  args: ["PurePath.__lt__"]
  expected: true

invariant pathlib_extra202.bytes_qualname_eq:
  description: "pathlib.Path.__bytes__.__qualname__ == 'PurePath.__bytes__' — bytes representation of the path (len=18); defined on PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__bytes__.__qualname__.__eq__
  args: ["PurePath.__bytes__"]
  expected: true

