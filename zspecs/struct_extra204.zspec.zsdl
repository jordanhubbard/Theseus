spec: struct_extra204
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified by running Python 3.14.3 struct module on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct_extra.zspec.zsdl covers: Struct.format/size attrs; calcsize for f/d/B/4s/BHI; pack_into/__name__; unpack_from with offset; iter_unpack; error.__name__ and error.__bases__[0].__name__."
    - "struct.error.__dict__ contains '__doc__' and '__module__' (verified True on Python 3.14.3); 'args' is NOT in struct.error.__dict__ (it is an instance attribute set at raise time, not a class attribute)."
    - "struct.__doc__ contains 'Functions', 'convert', 'C structs', 'byte order', 'big-endian', 'little-endian', 'float', 'pad byte', 'struct.error', and 'format strings' (verified on Python 3.14.3)."
    - "struct.__doc__ does NOT contain the word 'pack' or 'unpack' as standalone words — the doc describes format chars and byte order, not the function names (verified False on Python 3.14.3)."
    - "struct.Struct.__dict__ contains '__repr__', '__sizeof__', '__new__', 'size', 'format', 'pack', 'unpack' (all verified True on Python 3.14.3)."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error is a direct subclass of Exception (verified on Python 3.14.3)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# struct.error.__dict__ — class-level attribute membership
# 'args' is an instance attribute set at raise time, NOT a class attribute.
# '__doc__' and '__module__' are class-level attributes present in __dict__.
# ---------------------------------------------------------------------------

table structannotations204.error_dict.known_true:
  description: "struct.error.__dict__ contains class-level dunder attributes"
  kind: python_call_eq
  category: class_metadata
  id_prefix: structannotations204_error_dict_true

  columns: [id, function, args, expected, description]
  rows:
    - [doc,        "error.__dict__.__contains__", ["__doc__"],      true,  "struct.error.__dict__ contains '__doc__'"]
    - [module,     "error.__dict__.__contains__", ["__module__"],   true,  "struct.error.__dict__ contains '__module__'"]
    - [weakref,    "error.__dict__.__contains__", ["__weakref__"],  true,  "struct.error.__dict__ contains '__weakref__'"]
    - [not_args,   "error.__dict__.__contains__", ["args"],         false, "'args' is NOT in struct.error.__dict__ — it is set at raise time, not a class attr"]

# ---------------------------------------------------------------------------
# struct.__doc__ — content checks
# struct.__doc__ describes format chars, byte order options, and the struct.error exception.
# The words 'pack' and 'unpack' do NOT appear in struct.__doc__ (they describe the
# format string language, not the function API).
# ---------------------------------------------------------------------------

table structannotations204.doc.content:
  description: "struct.__doc__ contains expected substrings describing the module's format string language"
  kind: python_call_eq
  category: module_doc
  id_prefix: structannotations204_doc

  columns: [id, function, args, expected, description]
  rows:
    - [has_functions,  "__doc__.__contains__", ["Functions"],     true,  "struct.__doc__ starts with 'Functions to convert...'"]
    - [has_c_structs,  "__doc__.__contains__", ["C structs"],     true,  "struct.__doc__ mentions 'C structs'"]
    - [has_byte_order, "__doc__.__contains__", ["byte order"],    true,  "struct.__doc__ documents byte order options"]
    - [has_big_endian, "__doc__.__contains__", ["big-endian"],    true,  "struct.__doc__ documents big-endian format prefix '>'"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ — class-level method and slot membership
# Struct is a C-implemented type; its __dict__ contains built-in method descriptors.
# ---------------------------------------------------------------------------

table structannotations204.Struct_dict.methods:
  description: "struct.Struct.__dict__ contains expected built-in method and slot descriptors"
  kind: python_call_eq
  category: class_metadata
  id_prefix: structannotations204_Struct_dict

  columns: [id, function, args, expected, description]
  rows:
    - [repr,    "Struct.__dict__.__contains__", ["__repr__"],   true, "Struct.__dict__ contains '__repr__' slot"]
    - [sizeof,  "Struct.__dict__.__contains__", ["__sizeof__"], true, "Struct.__dict__ contains '__sizeof__' slot"]
    - [new,     "Struct.__dict__.__contains__", ["__new__"],    true, "Struct.__dict__ contains '__new__' slot"]
    - [pack,    "Struct.__dict__.__contains__", ["pack"],       true, "Struct.__dict__ contains 'pack' method descriptor"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structannotations204.error_dict.has_doc:
  description: "struct.error.__dict__.__contains__('__doc__') == True — struct.error has a class-level __doc__"
  category: class_metadata
  kind: python_call_eq
  function: "error.__dict__.__contains__"
  args: ["__doc__"]
  expected: true

invariant structannotations204.error_dict.has_module:
  description: "struct.error.__dict__.__contains__('__module__') == True — struct.error has a class-level __module__"
  category: class_metadata
  kind: python_call_eq
  function: "error.__dict__.__contains__"
  args: ["__module__"]
  expected: true

invariant structannotations204.doc.has_float:
  description: "struct.__doc__.__contains__('float') == True — struct.__doc__ documents the 'f' float format char"
  category: module_doc
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["float"]
  expected: true

invariant structannotations204.doc.has_struct_error:
  description: "struct.__doc__.__contains__('struct.error') == True — struct.__doc__ mentions the struct.error exception"
  category: module_doc
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["struct.error"]
  expected: true

invariant structannotations204.Struct_dict.has_repr:
  description: "struct.Struct.__dict__.__contains__('__repr__') == True — Struct defines __repr__"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__repr__"]
  expected: true

invariant structannotations204.Struct_dict.has_sizeof:
  description: "struct.Struct.__dict__.__contains__('__sizeof__') == True — Struct defines __sizeof__"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__sizeof__"]
  expected: true

invariant structannotations204.error.base_name:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error is a direct subclass of Exception"
  category: class_metadata
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant structannotations204.doc.has_little_endian:
  description: "struct.__doc__.__contains__('little-endian') == True — struct.__doc__ documents the '<' little-endian format prefix"
  category: module_doc
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["little-endian"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: partial
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-17T21:54:43Z
  iterations: 3
  pass_count: 19
  fail_count: 1
  total_invariants: 20
  notes: "Partial synthesis after 3 iteration(s): 19 passing, 1 failing."
  infeasible_reason: null
  invariant_annotations:
    structannotations204.error.base_name:
      status: failed
      reason: "Result <class 'Exception'> has no attribute '__name__.__eq__'"
