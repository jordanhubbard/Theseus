spec: configparser_extra6
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
  notes:
    - "This spec extends configparser.zspec.zsdl and prior extras."
    - "configparser (base) covers: __name__ for all public classes and exceptions, DEFAULTSECT, initial state, MRO checks."
    - "configparser_extra covers: ConfigParser/__name__/__module__, RawConfigParser/__name__, Error/__name__, NoSectionError/__name__/__base__, NoOptionError/__name__/__base__, DuplicateSectionError/__name__, InterpolationError/__name__, ConfigParser().sections()==[], DEFAULTSECT=='DEFAULT'."
    - "configparser_extra2 covers: __module__ for RawConfigParser/BasicInterpolation/ExtendedInterpolation/Error/NoSectionError/NoOptionError/DuplicateSectionError/ParsingError/MissingSectionHeaderError, exception hierarchy bases, ConfigParser method names, is_type checks, DEFAULTSECT class name."
    - "configparser_extra3 covers: __name__ tables for ConfigParser/RawConfigParser and all exceptions, DEFAULTSECT/MAX_INTERPOLATION_DEPTH values, Error base, NoSectionError base, ConfigParser instance class, ConfigParser __module__, RawConfigParser base."
    - "configparser_extra4 covers: __qualname__ for all major classes and exceptions."
    - "configparser_extra5 covers: configparser.__name__ == 'configparser', ConfigParser.__bases__[0].__name__ == 'RawConfigParser', Error/NoSectionError/NoOptionError __module__ table, RawConfigParser.__module__, NoOptionError.__bases__[0].__name__ == 'Error'."
    - "This spec adds: Interpolation base class metadata (__name__/__module__/__bases__[0].__name__ — not in any prior configparser spec), BasicInterpolation.__bases__[0].__name__ == 'Interpolation' and ExtendedInterpolation.__bases__[0].__name__ == 'Interpolation' (not in any prior spec), __module__ for InterpolationSyntaxError/InterpolationDepthError/InterpolationMissingOptionError/DuplicateOptionError (not covered in extra2 or extra5), MissingSectionHeaderError.__bases__[0].__name__ == 'ParsingError' (not in any prior spec — extra3 covers NoSectionError base only), and ConfigParser.__bases__[0].__qualname__ == 'RawConfigParser' (extra5 covers __name__; this checks __qualname__ — new vector)."
    - "configparser.Interpolation is the abstract base class for all interpolation strategies."
    - "configparser.Interpolation.__bases__[0].__name__ == 'object' — Interpolation directly extends object."
    - "configparser.BasicInterpolation.__bases__[0].__name__ == 'Interpolation'."
    - "configparser.ExtendedInterpolation.__bases__[0].__name__ == 'Interpolation'."
    - "configparser.MissingSectionHeaderError.__bases__[0].__name__ == 'ParsingError' — inherits from ParsingError, not directly from Error."
    - "InterpolationSyntaxError/InterpolationDepthError/InterpolationMissingOptionError all have __module__ == 'configparser'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Interpolation base class metadata — not in any prior configparser spec.
# Interpolation is the abstract base for BasicInterpolation and ExtendedInterpolation.
# ---------------------------------------------------------------------------

invariant configparser_extra6.Interpolation.class_name:
  description: "configparser.Interpolation.__name__ == 'Interpolation'"
  category: class_metadata
  kind: python_call_eq
  function: Interpolation.__name__.__eq__
  args: ["Interpolation"]
  expected: true

invariant configparser_extra6.Interpolation.module:
  description: "configparser.Interpolation.__module__ == 'configparser'"
  category: module_affiliation
  kind: python_call_eq
  function: Interpolation.__module__.__eq__
  args: ["configparser"]
  expected: true

invariant configparser_extra6.Interpolation.base_name:
  description: "configparser.Interpolation.__bases__[0].__name__ == 'object' — Interpolation directly extends object"
  category: hierarchy
  kind: python_call_eq
  function: Interpolation.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# BasicInterpolation and ExtendedInterpolation inherit from Interpolation.
# Not covered in any prior configparser spec (extra2 covers __module__ only).
# ---------------------------------------------------------------------------

invariant configparser_extra6.BasicInterpolation.base_name:
  description: "configparser.BasicInterpolation.__bases__[0].__name__ == 'Interpolation'"
  category: hierarchy
  kind: python_call_eq
  function: BasicInterpolation.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Interpolation"

invariant configparser_extra6.ExtendedInterpolation.base_name:
  description: "configparser.ExtendedInterpolation.__bases__[0].__name__ == 'Interpolation'"
  category: hierarchy
  kind: python_call_eq
  function: ExtendedInterpolation.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Interpolation"

# ---------------------------------------------------------------------------
# MissingSectionHeaderError inherits from ParsingError, not directly from Error.
# Not covered in any prior configparser spec. This is a deeper exception hierarchy check.
# ---------------------------------------------------------------------------

invariant configparser_extra6.MissingSectionHeaderError.base_name:
  description: "configparser.MissingSectionHeaderError.__bases__[0].__name__ == 'ParsingError'"
  category: hierarchy
  kind: python_call_eq
  function: MissingSectionHeaderError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ParsingError"

# ---------------------------------------------------------------------------
# __module__ for interpolation sub-exceptions not covered by extra2 or extra5.
# InterpolationSyntaxError, InterpolationDepthError, InterpolationMissingOptionError,
# DuplicateOptionError — extra2 notes do not include these in a table.
# ---------------------------------------------------------------------------

table configparser_extra6.interpolation_exception_modules:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: iexcmod6

  columns: [id, function, args, expected]
  rows:
    - [InterpolationSyntaxError,        InterpolationSyntaxError.__module__.__eq__,        ["configparser"], true]
    - [InterpolationDepthError,         InterpolationDepthError.__module__.__eq__,         ["configparser"], true]
    - [InterpolationMissingOptionError, InterpolationMissingOptionError.__module__.__eq__, ["configparser"], true]
    - [DuplicateOptionError,            DuplicateOptionError.__module__.__eq__,            ["configparser"], true]

# ---------------------------------------------------------------------------
# ConfigParser.__bases__[0].__qualname__ == 'RawConfigParser'
# extra5 covers __bases__[0].__name__; this checks __qualname__ (new vector).
# For a top-level class, qualname == name, so both equal 'RawConfigParser'.
# ---------------------------------------------------------------------------

invariant configparser_extra6.ConfigParser.base_qualname:
  description: "configparser.ConfigParser.__bases__[0].__qualname__ == 'RawConfigParser'"
  category: hierarchy
  kind: python_call_eq
  function: ConfigParser.__bases__.__getitem__
  args: [0]
  method: __qualname__
  expected: "RawConfigParser"

# ---------------------------------------------------------------------------
# MAX_INTERPOLATION_DEPTH type check — value (10) covered by extra3;
# the __class__.__name__ == 'int' type check is new.
# ---------------------------------------------------------------------------

invariant configparser_extra6.MAX_INTERPOLATION_DEPTH.type:
  description: "configparser.MAX_INTERPOLATION_DEPTH.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAX_INTERPOLATION_DEPTH.__class__.__name__.__eq__
  args: ["int"]
  expected: true
