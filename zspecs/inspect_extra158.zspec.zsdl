spec: inspect_extra158
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter.__init__.__qualname__ 'Parameter.__init__'; inspect.Parameter.replace.__qualname__ 'Parameter.replace'; inspect.BoundArguments.__init__.__qualname__ 'BoundArguments.__init__'; inspect.BoundArguments.apply_defaults.__qualname__ 'BoundArguments.apply_defaults'; inspect.Signature.__init__.__qualname__ 'Signature.__init__'; inspect.Signature.bind.__qualname__ 'Signature.bind'; inspect.Signature.replace.__qualname__ 'Signature.replace' (Wave 287)."
    - "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' — Parameter is a Python class in Lib/inspect.py; its __init__ method's __qualname__ is 'Parameter.__init__'. Verified with Python 3.14.3."
    - "inspect.Parameter.replace.__qualname__ == 'Parameter.replace' — Parameter.replace creates a copy with modified fields; its __qualname__ is 'Parameter.replace'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__' — BoundArguments is a Python class in Lib/inspect.py; its __init__ __qualname__ is 'BoundArguments.__init__'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' — apply_defaults sets default values for missing arguments; its __qualname__ is 'BoundArguments.apply_defaults'. Verified with Python 3.14.3."
    - "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' — Signature is a Python class in Lib/inspect.py; its __init__ __qualname__ is 'Signature.__init__'. Verified with Python 3.14.3."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' — Signature.bind binds arguments to parameters and returns BoundArguments; its __qualname__ is 'Signature.bind'. Verified with Python 3.14.3."
    - "inspect.Signature.replace.__qualname__ == 'Signature.replace' — Signature.replace creates a copy with modified parameters; its __qualname__ is 'Signature.replace'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter and inspect.BoundArguments method qualnames
#
# Wave 287 theme: inspect.Parameter and inspect.BoundArguments method
# __qualname__ attributes.
#
# inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__'
# inspect.Parameter.replace.__qualname__ == 'Parameter.replace'
# inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__'
# inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults'
#
# Parameter and BoundArguments are Python classes defined in Lib/inspect.py.
# Parameter represents a single parameter in a function signature, with
# attributes like name, default, annotation, and kind. BoundArguments holds
# the result of binding arguments to a Signature. All method __qualnames__
# follow the 'ClassName.method_name' pattern. New to extra158.
# ---------------------------------------------------------------------------

table inspect_extra158.parameter_and_boundarguments_qualnames:
  description: "inspect.Parameter: __init__ qualname 'Parameter.__init__', replace qualname 'Parameter.replace'; inspect.BoundArguments: __init__ qualname 'BoundArguments.__init__', apply_defaults qualname 'BoundArguments.apply_defaults'; wave 287; new to extra158"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpabaq158

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_init_qualname_eq,
       "Parameter.__init__.__qualname__.__eq__",
       ["Parameter.__init__"],
       true,
       "inspect.Parameter.__init__.__qualname__.__eq__('Parameter.__init__') == True — Parameter is a Python class in Lib/inspect.py representing a single function parameter with name, default, annotation, and kind attributes; its __init__ __qualname__ is 'Parameter.__init__'; str.__eq__('Parameter.__init__') returns True; new to extra158"]
    - [parameter_replace_qualname_eq,
       "Parameter.replace.__qualname__.__eq__",
       ["Parameter.replace"],
       true,
       "inspect.Parameter.replace.__qualname__.__eq__('Parameter.replace') == True — Parameter.replace creates a copy of the Parameter object with selected fields modified; its __qualname__ is 'Parameter.replace'; str.__eq__('Parameter.replace') returns True; new to extra158"]
    - [boundarguments_init_qualname_eq,
       "BoundArguments.__init__.__qualname__.__eq__",
       ["BoundArguments.__init__"],
       true,
       "inspect.BoundArguments.__init__.__qualname__.__eq__('BoundArguments.__init__') == True — BoundArguments is a Python class in Lib/inspect.py that holds the result of binding arguments to a Signature; its __init__ __qualname__ is 'BoundArguments.__init__'; str.__eq__('BoundArguments.__init__') returns True; new to extra158"]
    - [boundarguments_apply_defaults_qualname_eq,
       "BoundArguments.apply_defaults.__qualname__.__eq__",
       ["BoundArguments.apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__qualname__.__eq__('BoundArguments.apply_defaults') == True — apply_defaults sets default values for missing optional arguments in the BoundArguments object; its __qualname__ is 'BoundArguments.apply_defaults'; str.__eq__('BoundArguments.apply_defaults') returns True; new to extra158"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature method qualnames
#
# Wave 287 theme: inspect.Signature method __qualname__ attributes.
#
# inspect.Signature.__init__.__qualname__ == 'Signature.__init__'
# inspect.Signature.bind.__qualname__ == 'Signature.bind'
# inspect.Signature.replace.__qualname__ == 'Signature.replace'
#
# Signature is the main class in Lib/inspect.py representing the signature
# of a callable. __init__ constructs a Signature from an ordered list of
# Parameter objects. bind(*args, **kwargs) creates a BoundArguments mapping
# arguments to parameters. replace() creates a modified copy. All three
# methods are defined as Python functions within the Signature class body,
# so their __qualnames__ follow the 'Signature.<method_name>' pattern.
# New to extra158.
# ---------------------------------------------------------------------------

table inspect_extra158.signature_method_qualnames:
  description: "inspect.Signature: __init__ qualname 'Signature.__init__', bind qualname 'Signature.bind', replace qualname 'Signature.replace'; wave 287; new to extra158"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsmq158

  columns: [id, function, args, expected, description]
  rows:
    - [signature_init_qualname_eq,
       "Signature.__init__.__qualname__.__eq__",
       ["Signature.__init__"],
       true,
       "inspect.Signature.__init__.__qualname__.__eq__('Signature.__init__') == True — Signature is the main class in Lib/inspect.py representing the signature of a callable; it is constructed from an ordered sequence of Parameter objects; its __init__ __qualname__ is 'Signature.__init__'; str.__eq__('Signature.__init__') returns True; new to extra158"]
    - [signature_bind_qualname_eq,
       "Signature.bind.__qualname__.__eq__",
       ["Signature.bind"],
       true,
       "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — Signature.bind(*args, **kwargs) maps positional and keyword arguments to the Signature's parameters and returns a BoundArguments object; its __qualname__ is 'Signature.bind'; str.__eq__('Signature.bind') returns True; new to extra158"]
    - [signature_replace_qualname_eq,
       "Signature.replace.__qualname__.__eq__",
       ["Signature.replace"],
       true,
       "inspect.Signature.replace.__qualname__.__eq__('Signature.replace') == True — Signature.replace creates a modified copy of the Signature with selected attributes changed; its __qualname__ is 'Signature.replace'; str.__eq__('Signature.replace') returns True; new to extra158"]
    - [signature_init_qualname_class_eq_str,
       "Signature.__init__.__qualname__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.Signature.__init__.__qualname__.__class__.__name__.__eq__('str') == True — the __qualname__ of a Python function is always a str; Signature.__init__.__qualname__ is a str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra158"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra158
# ---------------------------------------------------------------------------

invariant inspect_extra158.parameter_init_qualname_eq:
  description: "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' — Parameter init method qualname; wave 287; new to extra158"
  kind: python_call_eq
  function: Parameter.__init__.__qualname__.__eq__
  args: ["Parameter.__init__"]
  expected: true

invariant inspect_extra158.parameter_replace_qualname_eq:
  description: "inspect.Parameter.replace.__qualname__ == 'Parameter.replace' — Parameter replace method creates modified copies; wave 287; new to extra158"
  kind: python_call_eq
  function: Parameter.replace.__qualname__.__eq__
  args: ["Parameter.replace"]
  expected: true

invariant inspect_extra158.boundarguments_init_qualname_eq:
  description: "inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__' — BoundArguments init method qualname; wave 287; new to extra158"
  kind: python_call_eq
  function: BoundArguments.__init__.__qualname__.__eq__
  args: ["BoundArguments.__init__"]
  expected: true

invariant inspect_extra158.boundarguments_apply_defaults_qualname_eq:
  description: "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' — apply_defaults sets missing default values; wave 287; new to extra158"
  kind: python_call_eq
  function: BoundArguments.apply_defaults.__qualname__.__eq__
  args: ["BoundArguments.apply_defaults"]
  expected: true

invariant inspect_extra158.signature_init_qualname_eq:
  description: "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' — Signature init constructs from Parameter list; wave 287; new to extra158"
  kind: python_call_eq
  function: Signature.__init__.__qualname__.__eq__
  args: ["Signature.__init__"]
  expected: true

invariant inspect_extra158.signature_bind_qualname_eq:
  description: "inspect.Signature.bind.__qualname__ == 'Signature.bind' — bind maps args to parameters returning BoundArguments; wave 287; new to extra158"
  kind: python_call_eq
  function: Signature.bind.__qualname__.__eq__
  args: ["Signature.bind"]
  expected: true

invariant inspect_extra158.signature_replace_qualname_eq:
  description: "inspect.Signature.replace.__qualname__ == 'Signature.replace' — replace creates modified copy of Signature; wave 287; new to extra158"
  kind: python_call_eq
  function: Signature.replace.__qualname__.__eq__
  args: ["Signature.replace"]
  expected: true

