spec: threading_extra571
version: ">=3.9"
backend: python_module(threading)
docs: "Behavioral spec for threading.RLock and Thread/synchronization primitive method identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers RLock factory function identity, Thread method qualnames, and __init__ qualnames for synchronization primitives"
  created_at: "2026-04-12T00:00:00Z"

table threading_extra571.rlock_identity:
  description: "Verify RLock factory class name and __name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: THEX571
  columns: [id, function, args, expected]
  rows:
    - [THEX571001, threading.RLock.__class__.__name__.__eq__, ["function"], true]
    - [THEX571002, threading.RLock.__name__.__eq__, ["RLock"], true]
table threading_extra571.thread_method_names:
  description: "Verify __name__ of Thread methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: THEX571
  columns: [id, function, args, expected]
  rows:
    - [THEX571003, threading.Thread.__init__.__name__.__eq__, ["__init__"], true]
    - [THEX571004, threading.Thread.__repr__.__name__.__eq__, ["__repr__"], true]
table threading_extra571.thread_method_qualnames:
  description: "Verify __qualname__ of Thread methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: THEX571
  columns: [id, function, args, expected]
  rows:
    - [THEX571005, threading.Thread.__init__.__qualname__.__eq__, ["Thread.__init__"], true]
    - [THEX571006, threading.Thread.__repr__.__qualname__.__eq__, ["Thread.__repr__"], true]
table threading_extra571.primitive_init_qualnames:
  description: "Verify __init__.__qualname__ of synchronization primitive classes"
  kind: python_call_eq
  category: method_identity
  id_prefix: THEX571
  columns: [id, function, args, expected]
  rows:
    - [THEX571007, threading.Condition.__init__.__qualname__.__eq__, ["Condition.__init__"], true]
    - [THEX571008, threading.Semaphore.__init__.__qualname__.__eq__, ["Semaphore.__init__"], true]
    - [THEX571009, threading.Event.__init__.__qualname__.__eq__, ["Event.__init__"], true]
    - [THEX571010, threading.Barrier.__init__.__qualname__.__eq__, ["Barrier.__init__"], true]
    - [THEX571011, threading.Timer.__init__.__qualname__.__eq__, ["Timer.__init__"], true]