spec: lodash_isnumber
version: ">=4.0.0"
backend: node(lodash.isnumber)

docs: https://lodash.com/docs/#isNumber

provenance:
  derived_from:
    - "lodash.isnumber README — https://www.npmjs.com/package/lodash.isnumber"
    - "Test vectors verified with lodash.isnumber@3.0.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isnumber exports the _.isNumber function directly as module.exports."
    - "isNumber checks if value is classified as a Number primitive or object."
    - "Returns true for integers and floats. Returns false for numeric strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isnumber.isnumber:
  kind: node_module_call_eq
  function: ~
  category: isnumber
  id_prefix: lisnum

  columns: [id, args, expected]
  rows:
    - [integer,   [42],       true]
    - [float,     [3.14],     true]
    - [zero,      [0],        true]
    - [negative,  [-1],       true]
    - [str_num,   ["42"],     false]
    - [null_val,  [null],     false]
    - [bool_val,  [true],     false]

