spec: split_on_first
version: ">=4.0.0"
backend: node(split-on-first)

docs: https://www.npmjs.com/package/split-on-first

provenance:
  derived_from:
    - "split-on-first README — https://www.npmjs.com/package/split-on-first"
    - "Test vectors verified with split-on-first via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "split-on-first source"
  notes:
    - "split-on-first is an npm package. Install: npm install split-on-first"
    - "Splits a string on the first occurrence of a separator, returning a two-element array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of two strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table split_on_first.splitOnFirst:
  kind: node_module_call_eq
  function: "default"
  category: string
  id_prefix: sof

  columns: [id, args, expected]
  rows:
    - [colon,   ["a:b:c", ":"],   ["a", "b:c"]]
    - [equals,  ["foo=bar=baz", "="], ["foo", "bar=baz"]]
    - [slash,   ["one/two/three", "/"], ["one", "two/three"]]
