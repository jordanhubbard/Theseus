spec: pathlib_extra1831
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 569 (_extra1831): descriptor protocol (__get__/__set__/__delete__/__set_name__); __call__ callable protocol; Path mutation method attribute presence."
    - "PurePath uses __new__ for construction rather than __init__; Path does likewise."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra1831.descriptor_protocol:
  description: "pathlib types descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1831

  columns: [id, function, args, expected]
  rows:
    - ["pl1831001", "pathlib.PurePath.__dict__.__contains__", ["__get__"], false]
    - ["pl1831002", "pathlib.Path.__dict__.__contains__", ["__get__"], false]
    - ["pl1831003", "pathlib.PurePosixPath.__dict__.__contains__", ["__get__"], false]
    - ["pl1831004", "pathlib.PureWindowsPath.__dict__.__contains__", ["__get__"], false]
    - ["pl1831005", "pathlib.PurePath.__dict__.__contains__", ["__set__"], false]
    - ["pl1831006", "pathlib.PurePath.__dict__.__contains__", ["__delete__"], false]
    - ["pl1831007", "pathlib.PurePath.__dict__.__contains__", ["__set_name__"], false]
    - ["pl1831008", "pathlib.Path.__dict__.__contains__", ["__set_name__"], false]

table pathlib_extra1831.callable_protocol:
  description: "pathlib types __call__ and construction protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1831

  columns: [id, function, args, expected]
  rows:
    - ["pl1831101", "pathlib.PurePath.__dict__.__contains__", ["__call__"], false]
    - ["pl1831102", "pathlib.Path.__dict__.__contains__", ["__call__"], false]
    - ["pl1831103", "pathlib.PurePosixPath.__dict__.__contains__", ["__call__"], false]
    - ["pl1831104", "pathlib.PureWindowsPath.__dict__.__contains__", ["__call__"], false]
    - ["pl1831105", "pathlib.PurePath.__dict__.__contains__", ["__new__"], true]
    - ["pl1831106", "pathlib.Path.__dict__.__contains__", ["__new__"], true]
    - ["pl1831107", "pathlib.PurePath.__dict__.__contains__", ["__init__"], false]
    - ["pl1831108", "pathlib.Path.__dict__.__contains__", ["__init__"], false]

table pathlib_extra1831.path_mkdir_chmod_attrs:
  description: "pathlib.Path mutation method dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1831

  columns: [id, function, args, expected]
  rows:
    - ["pl1831201", "pathlib.Path.__dict__.__contains__", ["mkdir"], true]
    - ["pl1831202", "pathlib.Path.__dict__.__contains__", ["chmod"], true]
    - ["pl1831203", "pathlib.Path.__dict__.__contains__", ["rename"], true]
    - ["pl1831204", "pathlib.Path.__dict__.__contains__", ["replace"], true]
    - ["pl1831205", "pathlib.Path.__dict__.__contains__", ["unlink"], true]
    - ["pl1831206", "pathlib.Path.__dict__.__contains__", ["rmdir"], true]
    - ["pl1831207", "pathlib.Path.__dict__.__contains__", ["symlink_to"], true]
    - ["pl1831208", "pathlib.Path.__dict__.__contains__", ["hardlink_to"], true]
    - ["pl1831209", "pathlib.Path.__dict__.__contains__", ["touch"], true]
    - ["pl1831210", "pathlib.Path.__dict__.__contains__", ["iterdir"], true]
