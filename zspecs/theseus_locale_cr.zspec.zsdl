spec: theseus_locale_cr
version: ">=3.8"
backend: python_cleanroom(theseus_locale_cr)
blocks: locale

docs: https://docs.python.org/3/library/locale.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/locale.html"
  not_derived_from:
    - "CPython source: Lib/locale.py (internal implementation)"
  notes:
    - "Clean-room locale subset. Do NOT import locale."
    - "setlocale(category, locale=None): set or query locale settings."
    - "getlocale(category): return (lang, encoding) tuple."
    - "format_string(fmt, val, grouping=False): format number according to locale."
    - "currency(val, symbol=True, grouping=False, international=False): format as currency."
    - "atof(string): convert string to float using locale decimal point."
    - "atoi(string): convert string to int, ignoring thousands separator."

error_model: python_exceptions

invariant theseus_locale_cr.locale2_atof:
  description: "atof('3.14') == 3.14"
  category: atof
  kind: python_call_eq
  function: locale2_atof
  args: []
  expected: true

invariant theseus_locale_cr.locale2_atoi:
  description: "atoi('42') == 42"
  category: atoi
  kind: python_call_eq
  function: locale2_atoi
  args: []
  expected: 42

invariant theseus_locale_cr.locale2_format_string:
  description: "format_string('%d', 42) == '42'"
  category: format_string
  kind: python_call_eq
  function: locale2_format_string
  args: []
  expected: "42"
