spec: struct_extra223
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack('<B', 255) == b'\\xff' — little-endian unsigned byte 255 packs to 0xff."
    - "struct.pack('<H', 256) == b'\\x00\\x01' — little-endian unsigned short 256; LSB first: 0x00 then 0x01."
    - "struct.pack('<I', 1) == b'\\x01\\x00\\x00\\x00' — little-endian unsigned int 1; LSB first."
    - "struct.unpack('<H', b'\\x00\\x01')[0] == 256 — inverse of pack('<H', 256); little-endian decoding."
    - "struct.unpack('<I', b'\\x01\\x00\\x00\\x00')[0] == 1 — inverse of pack('<I', 1); little-endian decoding."
    - "struct.pack('<h', -1) == b'\\xff\\xff' — little-endian signed short -1 in two's complement."
    - "struct.unpack('<h', b'\\xff\\xff')[0] == -1 — inverse of pack('<h', -1); two's complement signed short."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack('<B', ...) and struct.pack('<H', ...) — little-endian unsigned
#
# struct.pack('<B', 255)  == b'\xff'
# struct.pack('<H', 256)  == b'\x00\x01'
#
# '<' prefix selects little-endian byte order. 'B' is unsigned char (1 byte),
# 'H' is unsigned short (2 bytes). In little-endian order, the LSB comes
# first. 256 = 0x0100 → LSB=0x00, MSB=0x01 → b'\x00\x01'.
# ---------------------------------------------------------------------------

table struct_extra223.pack_little_endian_unsigned:
  description: "pack('<B',255)==b'\\xff'; pack('<H',256)==b'\\x00\\x01'; little-endian unsigned byte and short; new to extra223"
  kind: python_call_eq
  category: pack_values
  id_prefix: struct223

  columns: [id, function, args, expected, description]
  rows:
    - [pack_leB_255,  pack, ["<B", 255], !hex ff,   "struct.pack('<B', 255) == b'\\xff' — little-endian unsigned byte 255; single byte 0xff; for 1-byte values endianness is irrelevant; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [pack_leH_256,  pack, ["<H", 256], "!hex 0001", "struct.pack('<H', 256) == b'\\x00\\x01' — little-endian unsigned short 256 = 0x0100; LSB=0x00 first, MSB=0x01 second; contrasts with big-endian b'\\x01\\x00'; new anchor in extra223 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack('<I', 1) — little-endian unsigned int
#
# struct.pack('<I', 1) == b'\x01\x00\x00\x00'
#
# 'I' is unsigned int (4 bytes). In little-endian order, value 1 has
# LSB first: b'\x01\x00\x00\x00'. New to extra223.
# ---------------------------------------------------------------------------

table struct_extra223.pack_little_endian_I_1:
  description: "pack('<I',1)==b'\\x01\\x00\\x00\\x00'; little-endian unsigned int 1; LSB first; new to extra223"
  kind: python_call_eq
  category: pack_values
  id_prefix: struct223a

  columns: [id, function, args, expected, description]
  rows:
    - [pack_leI_1, pack, ["<I", 1], "!hex 01000000", "struct.pack('<I', 1) == b'\\x01\\x00\\x00\\x00' — little-endian unsigned int 1; value 1 has LSB=0x01 first then three 0x00 bytes; contrasts with big-endian b'\\x00\\x00\\x00\\x01'; new anchor in extra223 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.unpack('<H', ...) and struct.unpack('<I', ...) — little-endian unpack
#
# struct.unpack('<H', b'\x00\x01')[0] == 256
# struct.unpack('<I', b'\x01\x00\x00\x00')[0] == 1
#
# Inverse of the pack operations above. unpack always returns a tuple;
# index [0] extracts the first element. New to extra223.
# ---------------------------------------------------------------------------

table struct_extra223.unpack_little_endian_unsigned:
  description: "unpack('<H',b'\\x00\\x01')[0]==256; unpack('<I',b'\\x01\\x00\\x00\\x00')[0]==1; little-endian round-trip; new to extra223"
  kind: python_call_eq
  category: unpack_values
  id_prefix: struct223b

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_leH_256,   unpack, ["<H", "!hex 0001"],     [256], "struct.unpack('<H', b'\\x00\\x01')[0] == 256 — inverse of pack('<H', 256); little-endian unsigned short; LSB=0x00, MSB=0x01 → 256; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [unpack_leI_1,     unpack, ["<I", "!hex 01000000"], [1],   "struct.unpack('<I', b'\\x01\\x00\\x00\\x00')[0] == 1 — inverse of pack('<I', 1); little-endian unsigned int; LSB=0x01 first → value 1; new anchor in extra223 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack('<h', -1) and struct.unpack('<h', ...) — little-endian signed short
#
# struct.pack('<h', -1)           == b'\xff\xff'
# struct.unpack('<h', b'\xff\xff')[0] == -1
#
# 'h' is signed short (2 bytes). In two's complement, -1 is all bits set.
# Little-endian: both bytes are 0xff. New to extra223.
# ---------------------------------------------------------------------------

table struct_extra223.pack_unpack_little_endian_signed_short:
  description: "pack('<h',-1)==b'\\xff\\xff'; unpack('<h',b'\\xff\\xff')==(-1,); little-endian signed short -1; new to extra223"
  kind: python_call_eq
  category: pack_values
  id_prefix: struct223c

  columns: [id, function, args, expected, description]
  rows:
    - [pack_leh_neg1,   pack,   ["<h", -1],       "!hex ffff", "struct.pack('<h', -1) == b'\\xff\\xff' — little-endian signed short -1; two's complement -1 is all bits set = 0xffff; both bytes are 0xff; contrasts with unsigned short 65535 having same bytes; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [unpack_leh_ffff, unpack, ["<h", "!hex ffff"], [-1],     "struct.unpack('<h', b'\\xff\\xff')[0] == -1 — inverse of pack('<h', -1); 0xffff as little-endian signed short is -1 in two's complement; contrasts with unpack('<H', b'\\xff\\xff')==65535; new anchor in extra223 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra223.pack_leH_256:
  description: "struct.pack('<H', 256) == b'\\x00\\x01' — little-endian unsigned short 256; '<' is little-endian byte order; 'H' is unsigned short (2 bytes, range 0-65535); 256 = 0x0100 in big-endian notation; in little-endian the LSB (0x00) comes first and MSB (0x01) comes second, producing b'\\x00\\x01'; contrasts with big-endian/network-byte-order pack('!H', 256) == b'\\x01\\x00'; first extra223 namespace anchor for pack('<H', 256); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["<H", 256]
  expected: "!hex 0001"

invariant struct_extra223.pack_leI_1:
  description: "struct.pack('<I', 1) == b'\\x01\\x00\\x00\\x00' — little-endian unsigned int 1; 'I' is unsigned int (4 bytes, range 0-4294967295); value 1 in little-endian places LSB first: 0x01 followed by three zero bytes; contrasts with big-endian pack('>I', 1) == b'\\x00\\x00\\x00\\x01'; first extra223 namespace anchor for pack('<I', 1); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["<I", 1]
  expected: "!hex 01000000"

invariant struct_extra223.unpack_leh_neg1:
  description: "struct.unpack('<h', b'\\xff\\xff')[0] == -1 — little-endian signed short 0xffff decodes to -1; '<h' is little-endian signed short (2 bytes, range -32768 to 32767); 0xffff is all bits set; in two's complement signed representation this is -1; the result tuple contains (-1,) and index [0] extracts -1; contrasts with unpack('<H', b'\\xff\\xff') == (65535,) — same bytes, unsigned interpretation; first extra223 standalone for unpack('<h'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: ["<h", !hex ffff]
  expected: [-1]
