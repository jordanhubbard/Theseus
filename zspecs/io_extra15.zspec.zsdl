spec: io_extra15
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra14.zspec.zsdl."
    - "io_extra14 covers __module__ for IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedReader/BufferedWriter/BufferedRandom/TextIOWrapper/IncrementalNewlineDecoder/UnsupportedOperation."
    - "io_extra4 covers __name__ for BytesIO/StringIO/FileIO/BufferedReader; io.zspec.zsdl covers __name__ for BytesIO/StringIO."
    - "No prior io spec covers __qualname__ for BytesIO, StringIO, FileIO, or BufferedReader."
    - "io.BytesIO.__qualname__ == 'BytesIO' — C-implemented class; qualname equals name."
    - "io.StringIO.__qualname__ == 'StringIO' — C-implemented class; qualname equals name."
    - "io.FileIO.__qualname__ == 'FileIO' — C-implemented class; qualname equals name."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — C-implemented class; qualname equals name."
    - "For top-level classes (not nested), __qualname__ == __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Concrete class __qualname__ — BytesIO, StringIO, FileIO, BufferedReader
#
# io_extra4 covers __name__ for all four of these classes. No prior io spec
# covers __qualname__ for any of them. For top-level (non-nested) C-implemented
# classes, __qualname__ equals __name__. These invariants assert that equality
# via the __qualname__.__eq__ method chain pattern.
# ---------------------------------------------------------------------------

invariant io_extra15.BytesIO.qualname:
  description: "io.BytesIO.__qualname__ == 'BytesIO' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra15.StringIO.qualname:
  description: "io.StringIO.__qualname__ == 'StringIO' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra15.FileIO.qualname:
  description: "io.FileIO.__qualname__ == 'FileIO' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: FileIO.__qualname__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra15.BufferedReader.qualname:
  description: "io.BufferedReader.__qualname__ == 'BufferedReader' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true
