spec: io_extra86
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra85."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership; UnsupportedOperation identity, bases, MRO; DEFAULT_BUFFER_SIZE and SEEK_* constants class and value; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO."
    - "This spec covers: RawIOBase/__name__/__module__/__bases__[0].__name__/__mro__.__len__(); BufferedIOBase/__name__/__module__/__bases__[0].__name__/__mro__.__len__(); TextIOBase/__name__/__module__/__bases__[0].__name__/__mro__.__len__(); IOBase/__name__/__module__/__bases__[0].__name__/__mro__.__len__(); RawIOBase/__bases__.__len__(); BufferedIOBase/__bases__.__len__(); TextIOBase/__bases__.__len__(); IOBase/__bases__.__len__()."
    - "io.RawIOBase.__name__ == 'RawIOBase' — the Python-level ABC name."
    - "io.RawIOBase.__module__ == 'io' — RawIOBase is the pure-Python ABC defined in the io module (not _io)."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — first base is the C-level _RawIOBase from _io."
    - "io.RawIOBase.__mro__.__len__() == 5 — MRO is [RawIOBase, _RawIOBase, IOBase, _IOBase, object]."
    - "io.RawIOBase.__bases__.__len__() == 2 — RawIOBase has two bases: _RawIOBase and IOBase."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' — the Python-level ABC name."
    - "io.BufferedIOBase.__module__ == 'io' — BufferedIOBase is defined in the io module."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — first base is _BufferedIOBase from _io."
    - "io.BufferedIOBase.__mro__.__len__() == 5 — MRO is [BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]."
    - "io.TextIOBase.__name__ == 'TextIOBase' — the Python-level ABC name."
    - "io.TextIOBase.__module__ == 'io' — TextIOBase is defined in the io module."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — first base is _TextIOBase from _io."
    - "io.TextIOBase.__mro__.__len__() == 5 — MRO is [TextIOBase, _TextIOBase, IOBase, _IOBase, object]."
    - "io.IOBase.__name__ == 'IOBase' — the Python-level ABC name."
    - "io.IOBase.__module__ == 'io' — IOBase is defined in the io module."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — single base is the C-level _IOBase from _io."
    - "io.IOBase.__mro__.__len__() == 3 — MRO is [IOBase, _IOBase, object]."
    - "io.IOBase.__bases__.__len__() == 1 — IOBase has a single base: _IOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# RawIOBase class identity: __name__ and __module__
# io.RawIOBase is the Python-level ABC defined in the io module.
# __module__ == 'io' (not '_io') because RawIOBase is the Python wrapper,
# not the underlying C type _RawIOBase.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra86.RawIOBase_identity:
  description: "RawIOBase __name__ and __module__"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra86

  columns: [id, function, args, expected]
  rows:
    - [raw_name,   RawIOBase.__name__.__eq__,   ["RawIOBase"], true]
    - [raw_module, RawIOBase.__module__.__eq__, ["io"],        true]

# ---------------------------------------------------------------------------
# RawIOBase __bases__ and __mro__
# RawIOBase has two bases: _RawIOBase and IOBase.
# __bases__[0].__name__ == '_RawIOBase' (C-level base).
# MRO: [RawIOBase, _RawIOBase, IOBase, _IOBase, object] — length 5.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra86.RawIOBase_hierarchy:
  description: "RawIOBase __bases__ len, __bases__[0].__name__, and __mro__.__len__()"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ioextra86

  columns: [id, function, args, expected]
  rows:
    - [raw_bases_len,  RawIOBase.__bases__.__len__,                [],              2]
    - [raw_base0_name, "RawIOBase.__bases__[0].__name__.__eq__",  ["_RawIOBase"],  true]
    - [raw_mro_len,    RawIOBase.__mro__.__len__,                 [],              5]

# ---------------------------------------------------------------------------
# BufferedIOBase and TextIOBase identity and hierarchy
# Both have __module__ == 'io' (Python-level ABCs).
# BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase'.
# TextIOBase.__bases__[0].__name__ == '_TextIOBase'.
# Both have MRO length 5.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra86.BufferedIOBase_TextIOBase_identity_hierarchy:
  description: "BufferedIOBase and TextIOBase __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra86

  columns: [id, function, args, expected]
  rows:
    - [buf_name,       BufferedIOBase.__name__.__eq__,                    ["BufferedIOBase"],  true]
    - [buf_module,     BufferedIOBase.__module__.__eq__,                  ["io"],              true]
    - [buf_base0,      "BufferedIOBase.__bases__[0].__name__.__eq__",     ["_BufferedIOBase"], true]
    - [buf_mro_len,    BufferedIOBase.__mro__.__len__,                    [],                  5]
    - [txt_name,       TextIOBase.__name__.__eq__,                        ["TextIOBase"],      true]
    - [txt_module,     TextIOBase.__module__.__eq__,                      ["io"],              true]
    - [txt_base0,      "TextIOBase.__bases__[0].__name__.__eq__",         ["_TextIOBase"],     true]
    - [txt_mro_len,    TextIOBase.__mro__.__len__,                        [],                  5]

# ---------------------------------------------------------------------------
# IOBase class identity and hierarchy
# IOBase has a single base: _IOBase (the C-level type).
# IOBase.__module__ == 'io' (Python-level ABC).
# MRO: [IOBase, _IOBase, object] — length 3.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra86.IOBase_identity_hierarchy:
  description: "IOBase __name__, __module__, __bases__ len, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra86

  columns: [id, function, args, expected]
  rows:
    - [iob_name,       IOBase.__name__.__eq__,                   ["IOBase"], true]
    - [iob_module,     IOBase.__module__.__eq__,                 ["io"],     true]
    - [iob_bases_len,  IOBase.__bases__.__len__,                 [],         1]
    - [iob_base0,      "IOBase.__bases__[0].__name__.__eq__",    ["_IOBase"], true]
    - [iob_mro_len,    IOBase.__mro__.__len__,                   [],          3]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra86.RawIOBase.name:
  description: "io.RawIOBase.__name__ == 'RawIOBase' (Python-level ABC name)"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra86.RawIOBase.module:
  description: "io.RawIOBase.__module__ == 'io' (Python-level wrapper, not _io)"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra86.RawIOBase.mro_len:
  description: "io.RawIOBase.__mro__.__len__() == 5 ([RawIOBase, _RawIOBase, IOBase, _IOBase, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: RawIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra86.IOBase.mro_len:
  description: "io.IOBase.__mro__.__len__() == 3 ([IOBase, _IOBase, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: IOBase.__mro__.__len__
  args: []
  expected: 3

invariant io_extra86.BufferedIOBase.module:
  description: "io.BufferedIOBase.__module__ == 'io' (Python-level ABC wrapper)"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["io"]
  expected: true
