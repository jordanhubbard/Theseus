spec: pad_right
version: ">=0.2.2"
backend: node(pad-right)

docs: https://www.npmjs.com/package/pad-right

provenance:
  derived_from:
    - "pad-right README — https://www.npmjs.com/package/pad-right"
    - "Test vectors verified with pad-right via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "pad-right source"
  notes:
    - "pad-right is an npm package. Install: npm install pad-right"
    - "padRight(str, len, ch) pads str on the right. Default pad character is '0' (not space)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the padded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pad_right.padRight:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: padright

  columns: [id, args, expected]
  rows:
    - [default_pad, ["hi", 5],        "hi000"]
    - [space_pad,   ["hi", 5, " "],   "hi   "]
    - [star_pad,    ["hi", 5, "*"],   "hi***"]
