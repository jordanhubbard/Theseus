spec: re_extra1606
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 554 (_extra1606): __slots__ protocol dict-presence checks for re classes."
    - "re.Pattern and re.Match are C extension types; C types do not use Python __slots__."
    - "re.Pattern exposes C-level attributes: pattern, flags, groups (member_descriptor), groupindex (getset_descriptor)."
    - "re.Match exposes C-level attributes: re, string, pos, endpos (member_descriptor), lastindex, lastgroup, regs (getset_descriptor)."
    - "re.error is a Python exception class with __weakref__ but no __slots__."
    - "re.RegexFlag is an IntFlag enum; it does not define __slots__ in its own class dict."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra1606.pattern_no_slots:
  description: "re.Pattern is a C extension type — no __slots__, __dict__, or __weakref__ in its class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1606pt

  columns: [id, function, args, expected]
  rows:
    - ["re1606pt001", "re.Pattern.__dict__.__contains__", ["__slots__"],      false]
    - ["re1606pt002", "re.Pattern.__dict__.__contains__", ["__dict__"],       false]
    - ["re1606pt003", "re.Pattern.__dict__.__contains__", ["__weakref__"],    false]
    - ["re1606pt004", "re.Pattern.__dict__.__contains__", ["pattern"],        true]
    - ["re1606pt005", "re.Pattern.__dict__.__contains__", ["flags"],          true]
    - ["re1606pt006", "re.Pattern.__dict__.__contains__", ["groups"],         true]
    - ["re1606pt007", "re.Pattern.__dict__.__contains__", ["groupindex"],     true]
    - ["re1606pt008", "re.Pattern.__dict__.__contains__", ["match"],          true]
    - ["re1606pt009", "re.Pattern.__dict__.__contains__", ["search"],         true]
    - ["re1606pt010", "re.Pattern.__dict__.__contains__", ["findall"],        true]
    - ["re1606pt011", "re.Pattern.__dict__.__contains__", ["finditer"],       true]
    - ["re1606pt012", "re.Pattern.__dict__.__contains__", ["sub"],            true]
    - ["re1606pt013", "re.Pattern.__dict__.__contains__", ["subn"],           true]
    - ["re1606pt014", "re.Pattern.__dict__.__contains__", ["split"],          true]
    - ["re1606pt015", "re.Pattern.__dict__.__contains__", ["fullmatch"],      true]
    - ["re1606pt016", "re.Pattern.__dict__.__contains__", ["scanner"],        true]
    - ["re1606pt017", "re.Pattern.__dict__.__contains__", ["__repr__"],       true]
    - ["re1606pt018", "re.Pattern.__dict__.__contains__", ["__hash__"],       true]
    - ["re1606pt019", "re.Pattern.__dict__.__contains__", ["__eq__"],         true]
    - ["re1606pt020", "re.Pattern.__dict__.__contains__", ["__copy__"],       true]
    - ["re1606pt021", "re.Pattern.__dict__.__contains__", ["__deepcopy__"],   true]
    - ["re1606pt022", "re.Pattern.__dict__.__contains__", ["__class_getitem__"], true]
    - ["re1606pt023", "re.Pattern.__dict__.__contains__", ["__lt__"],         false]
    - ["re1606pt024", "re.Pattern.__dict__.__contains__", ["__le__"],         false]
    - ["re1606pt025", "re.error.__dict__.__contains__",   ["__slots__"],      false]
    - ["re1606pt026", "re.error.__dict__.__contains__",   ["__weakref__"],    true]
    - ["re1606pt027", "re.error.__dict__.__contains__",   ["__dict__"],       false]
    - ["re1606pt028", "re.RegexFlag.__dict__.__contains__", ["__slots__"],    false]
    - ["re1606pt029", "re.RegexFlag.__dict__.__contains__", ["__doc__"],      true]
    - ["re1606pt030", "re.Pattern.__dict__.__contains__", ["__doc__"],        true]

