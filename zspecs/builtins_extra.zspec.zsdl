spec: builtins_extra
version: ">=3.0"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/builtins.html

provenance:
  derived_from:
    - "Python 3 builtins documentation — https://docs.python.org/3/library/builtins.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins.zspec.zsdl — covers exception/type/function __name__ checks and basic function calls"
  notes:
    - "abs(-5) == 5; abs(3.14) returns a float."
    - "all([]) == True — vacuously true; any([]) == False — vacuously false."
    - "bin(10) == '0b1010', hex(255) == '0xff', oct(8) == '0o10'."
    - "divmod(10, 3) returns (3, 1) — quotient 3, remainder 1; elements extracted via __getitem__."
    - "pow(2, 10) == 1024; round(3.14159, 2) == 3.14."
    - "sorted([3,1,2]) returns a new list [1, 2, 3]."
    - "isinstance(1, int) == True; issubclass(bool, int) == True — bool is a subtype of int."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abs() — absolute value
# ---------------------------------------------------------------------------

invariant builtins_extra.abs.negative_int:
  description: "builtins.abs(-5) == 5"
  category: function_calls
  kind: python_call_eq
  function: abs
  args: [-5]
  expected: 5

invariant builtins_extra.abs.float_return_type:
  description: "builtins.abs(3.14).__class__.__name__ == 'float'"
  category: function_calls
  kind: python_call_eq
  function: abs
  args: [3.14]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# all() — returns True iff every element is truthy
# ---------------------------------------------------------------------------

invariant builtins_extra.all.all_true:
  description: "builtins.all([True, True, True]) == True"
  category: function_calls
  kind: python_call_eq
  function: all
  args: [[true, true, true]]
  expected: true

invariant builtins_extra.all.has_false:
  description: "builtins.all([True, False]) == False"
  category: function_calls
  kind: python_call_eq
  function: all
  args: [[true, false]]
  expected: false

# ---------------------------------------------------------------------------
# any() — returns True iff at least one element is truthy
# ---------------------------------------------------------------------------

invariant builtins_extra.any.one_true:
  description: "builtins.any([False, False, True]) == True"
  category: function_calls
  kind: python_call_eq
  function: any
  args: [[false, false, true]]
  expected: true

invariant builtins_extra.any.all_false:
  description: "builtins.any([False, False]) == False"
  category: function_calls
  kind: python_call_eq
  function: any
  args: [[false, false]]
  expected: false

# ---------------------------------------------------------------------------
# bin() — integer to binary string
# ---------------------------------------------------------------------------

invariant builtins_extra.bin.ten:
  description: "builtins.bin(10) == '0b1010'"
  category: function_calls
  kind: python_call_eq
  function: bin
  args: [10]
  expected: "0b1010"

# ---------------------------------------------------------------------------
# chr() and ord() — character/codepoint conversion
# ---------------------------------------------------------------------------

invariant builtins_extra.chr.65:
  description: "builtins.chr(65) == 'A'"
  category: function_calls
  kind: python_call_eq
  function: chr
  args: [65]
  expected: "A"

invariant builtins_extra.ord.A:
  description: "builtins.ord('A') == 65"
  category: function_calls
  kind: python_call_eq
  function: ord
  args: ["A"]
  expected: 65

# ---------------------------------------------------------------------------
# divmod() — quotient and remainder extracted via __getitem__
# ---------------------------------------------------------------------------

invariant builtins_extra.divmod.quotient:
  description: "builtins.divmod(10, 3)[0] == 3 — quotient"
  category: function_calls
  kind: python_call_eq
  function: divmod
  args: [10, 3]
  method: __getitem__
  method_args: [0]
  expected: 3

invariant builtins_extra.divmod.remainder:
  description: "builtins.divmod(10, 3)[1] == 1 — remainder"
  category: function_calls
  kind: python_call_eq
  function: divmod
  args: [10, 3]
  method: __getitem__
  method_args: [1]
  expected: 1

# ---------------------------------------------------------------------------
# hex() and oct() — integer base-conversion strings
# ---------------------------------------------------------------------------

invariant builtins_extra.hex.255:
  description: "builtins.hex(255) == '0xff'"
  category: function_calls
  kind: python_call_eq
  function: hex
  args: [255]
  expected: "0xff"

invariant builtins_extra.oct.eight:
  description: "builtins.oct(8) == '0o10'"
  category: function_calls
  kind: python_call_eq
  function: oct
  args: [8]
  expected: "0o10"

# ---------------------------------------------------------------------------
# pow() — exponentiation
# ---------------------------------------------------------------------------

invariant builtins_extra.pow.2_10:
  description: "builtins.pow(2, 10) == 1024"
  category: function_calls
  kind: python_call_eq
  function: pow
  args: [2, 10]
  expected: 1024

# ---------------------------------------------------------------------------
# round() — round to given number of decimal places
# ---------------------------------------------------------------------------

invariant builtins_extra.round.two_decimal:
  description: "builtins.round(3.14159, 2) == 3.14"
  category: function_calls
  kind: python_call_eq
  function: round
  args: [3.14159, 2]
  expected: 3.14

# ---------------------------------------------------------------------------
# sorted() — returns a new sorted list
# ---------------------------------------------------------------------------

invariant builtins_extra.sorted.basic:
  description: "builtins.sorted([3, 1, 2]) == [1, 2, 3]"
  category: function_calls
  kind: python_call_eq
  function: sorted
  args: [[3, 1, 2]]
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# sum() — sum of elements
# ---------------------------------------------------------------------------

invariant builtins_extra.sum.four_elements:
  description: "builtins.sum([1, 2, 3, 4]) == 10"
  category: function_calls
  kind: python_call_eq
  function: sum
  args: [[1, 2, 3, 4]]
  expected: 10

# ---------------------------------------------------------------------------
# max() and min()
# ---------------------------------------------------------------------------

invariant builtins_extra.max.basic:
  description: "builtins.max([1, 2, 3]) == 3"
  category: function_calls
  kind: python_call_eq
  function: max
  args: [[1, 2, 3]]
  expected: 3

invariant builtins_extra.min.basic:
  description: "builtins.min([1, 2, 3]) == 1"
  category: function_calls
  kind: python_call_eq
  function: min
  args: [[1, 2, 3]]
  expected: 1

# ---------------------------------------------------------------------------
# len()
# ---------------------------------------------------------------------------

invariant builtins_extra.len.three:
  description: "builtins.len([1, 2, 3]) == 3"
  category: function_calls
  kind: python_call_eq
  function: len
  args: [[1, 2, 3]]
  expected: 3

# ---------------------------------------------------------------------------
# isinstance() and issubclass()
# ---------------------------------------------------------------------------

invariant builtins_extra.isinstance.int_true:
  description: "builtins.isinstance(1, int) == True"
  category: function_calls
  kind: python_call_eq
  function: isinstance
  args: [1, int]
  expected: true

invariant builtins_extra.issubclass.bool_int:
  description: "builtins.issubclass(bool, int) == True — bool is a subtype of int"
  category: function_calls
  kind: python_call_eq
  function: issubclass
  args: [bool, int]
  expected: true
