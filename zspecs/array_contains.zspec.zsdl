spec: array_contains
version: ">=0.0.1"
backend: node(array-contains)

docs: https://www.npmjs.com/package/array-contains

provenance:
  derived_from:
    - "array-contains README — https://www.npmjs.com/package/array-contains"
    - "Test vectors verified with array-contains via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "array-contains source"
  notes:
    - "array-contains is an npm package. Install: npm install array-contains"
    - "Returns true if the array contains the given element."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_contains.check:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: arrcon

  columns: [id, args, expected]
  rows:
    - [found,     [[1, 2, 3], 2],   true]
    - [not_found, [[1, 2, 3], 4],   false]
    - [string,    [["a", "b"], "a"],  true]

