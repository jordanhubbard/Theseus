  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1156.package_loader_all_identity:
  description: "concurrent.futures.__package__/__loader__/__all__ class name identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf1156pl
  columns: [id, function, args, expected]
  rows:
    - [cf1156pl001, concurrent.futures.__package__.__class__.__name__.__eq__,      ["str"],              true]
    - [cf1156pl002, concurrent.futures.__package__.__eq__,                          ["concurrent.futures"], true]
    - [cf1156pl003, concurrent.futures.__loader__.__class__.__name__.__eq__,        ["SourceFileLoader"], true]
