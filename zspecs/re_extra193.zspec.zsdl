spec: re_extra193
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re.Match and re.Pattern class identity."
    - "re.Match.__name__ == 'Match' (len=5); confirmed Python 3.14.3 macOS."
    - "re.Match.__module__ == 're' (len=2); confirmed Python 3.14.3 macOS."
    - "re.Match.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS."
    - "re.Pattern.__name__ == 'Pattern' (len=7); confirmed Python 3.14.3 macOS."
    - "re.Pattern.__module__ == 're' (len=2); confirmed Python 3.14.3 macOS."
    - "re.Pattern.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS."
    - "re.Match.__name__.__len__() == 5 — M(1)a(2)t(3)c(4)h(5); shorter than Pattern (7); confirmed Python 3.14.3 macOS."
    - "re.Pattern.__name__.__len__() == 7 — P(1)a(2)t(3)t(4)e(5)r(6)n(7); longer than Match (5); confirmed Python 3.14.3 macOS."
    - "Name length ordering: Match(5) < Pattern(7); Pattern is 2 chars longer than Match; confirmed Python 3.14.3 macOS."
    - "Both re.Match and re.Pattern are C-level types exposed via the re module namespace; they are implemented in the _sre C extension but their __module__ reports 're'; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Match and re.Pattern __name__ equality
# Match(5), Pattern(7)
# ---------------------------------------------------------------------------

table re_extra193.match_pattern_class_names:
  description: "re.Match and re.Pattern __name__ values: Match='Match'(5), Pattern='Pattern'(7); Pattern is 2 chars longer than Match"
  kind: python_call_eq
  category: identity
  id_prefix: rematch193

  columns: [id, function, args, expected, description]
  rows:
    - [match_name_eq,   re.Match.__name__.__eq__,   ["Match"],   true, "re.Match.__name__ == 'Match' (len=5); confirmed Python 3.14.3 macOS"]
    - [pattern_name_eq, re.Pattern.__name__.__eq__, ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (len=7, longer than Match); confirmed Python 3.14.3 macOS"]
    - [match_name_len,  re.Match.__name__.__len__,  [],          5,    "re.Match.__name__.__len__() == 5 — M(1)a(2)t(3)c(4)h(5); confirmed Python 3.14.3 macOS"]
    - [pattern_name_len, re.Pattern.__name__.__len__, [],        7,    "re.Pattern.__name__.__len__() == 7 — P(1)a(2)t(3)t(4)e(5)r(6)n(7); confirmed Python 3.14.3 macOS"]
    - [module_len,      re.Match.__module__.__len__, [],         2,    "re.Match.__module__.__len__() == 2 — r(1)e(2); same module string length as Pattern; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Match and re.Pattern __module__ equality
# Both report 're' (len=2)
# ---------------------------------------------------------------------------

table re_extra193.match_pattern_class_modules:
  description: "re.Match and re.Pattern __module__ values: both report 're' (len=2)"
  kind: python_call_eq
  category: identity
  id_prefix: rematch193

  columns: [id, function, args, expected, description]
  rows:
    - [match_module_eq,   re.Match.__module__.__eq__,   ["re"], true, "re.Match.__module__ == 're' (len=2); confirmed Python 3.14.3 macOS"]
    - [pattern_module_eq, re.Pattern.__module__.__eq__, ["re"], true, "re.Pattern.__module__ == 're' (len=2); confirmed Python 3.14.3 macOS"]
    - [match_module_len,  re.Match.__module__.__len__,  [],     2,    "re.Match.__module__.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]
    - [pattern_module_len, re.Pattern.__module__.__len__, [],   2,    "re.Pattern.__module__.__len__() == 2 — same 're' string; confirmed Python 3.14.3 macOS"]
    - [match_name_not_re_match, re.Match.__name__.__eq__, ["re.Match"], false, "re.Match.__name__ != 're.Match' — __name__ is just 'Match', not the fully-qualified 're.Match'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Match and re.Pattern class identity (__class__.__name__)
# Both report 'type'
# ---------------------------------------------------------------------------

table re_extra193.match_pattern_metatype:
  description: "re.Match and re.Pattern class-level identity: both use plain type metaclass (__class__.__name__=='type'), name lengths Match=5 < Pattern=7"
  kind: python_call_eq
  category: identity
  id_prefix: rematch193

  columns: [id, function, args, expected, description]
  rows:
    - [match_class_eq,   re.Match.__class__.__name__.__eq__,   ["type"], true, "re.Match.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [pattern_class_eq, re.Pattern.__class__.__name__.__eq__, ["type"], true, "re.Pattern.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [match_class_len,  re.Match.__class__.__name__.__len__,  [],       4,    "re.Match.__class__.__name__.__len__() == 4 — t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [pattern_class_len, re.Pattern.__class__.__name__.__len__, [],     4,    "re.Pattern.__class__.__name__.__len__() == 4 — same 'type' string; confirmed Python 3.14.3 macOS"]
    - [match_name_len2,  re.Match.__name__.__len__,            [],       5,    "re.Match.__name__.__len__() == 5 (shorter than Pattern=7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra193.match_name_eq:
  description: "re.Match.__name__ == 'Match' — class name string length 5 ('Match'); re.Match is the type of match objects returned by re.match(), re.search(), and re.fullmatch(); its __name__ is just 'Match', not 're.Match'; __name__ does not include the module prefix; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra193.pattern_name_eq:
  description: "re.Pattern.__name__ == 'Pattern' — class name string length 7 ('Pattern'); re.Pattern is the type of compiled regular expression objects returned by re.compile(); __name__ is 'Pattern' (7 chars), 2 chars longer than 'Match' (5 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra193.match_module_eq:
  description: "re.Match.__module__ == 're' — Match objects report their module as 're' (len=2), the public module name; although the implementation is in the _sre C extension, the module attribute is set to 're' so the public API is correctly attributed; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra193.pattern_module_eq:
  description: "re.Pattern.__module__ == 're' — Pattern objects report their module as 're' (len=2); both re.Match and re.Pattern share the same __module__ value 're'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra193.match_class_name_type:
  description: "re.Match.__class__.__name__ == 'type' — Match's metaclass is the plain 'type'; re.Match is a C-level type implemented in _sre but its metaclass is the standard 'type', not a custom metaclass; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra193.pattern_class_name_type:
  description: "re.Pattern.__class__.__name__ == 'type' — Pattern's metaclass is the plain 'type'; both re.Match and re.Pattern use the standard type metaclass; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra193.match_name_len_5:
  description: "re.Match.__name__.__len__() == 5 — 'Match' has 5 characters: M(1)a(2)t(3)c(4)h(5); Match is shorter than Pattern (7); the difference in name length is 2 (Pattern has 'tern' appended relative to 'tch'); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__name__.__len__
  args: []
  expected: 5

invariant re_extra193.pattern_name_len_7:
  description: "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters: P(1)a(2)t(3)t(4)e(5)r(6)n(7); Pattern is longer than Match (5) by 2 characters; name length ordering in spec: Match=5 < Pattern=7; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__len__
  args: []
  expected: 7
