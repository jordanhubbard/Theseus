spec: itertools_extra249
version: ">=3.2"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.cycle and itertools.repeat class identity and behavioral contracts."
    - "itertools.cycle.__class__.__name__ == 'type' — cycle is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools' — cycle is exposed in the itertools module; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.cycle.__name__ == 'cycle' — the cycle type's __name__ is 'cycle'. Verified with Python 3.14.3."
    - "next(itertools.cycle([1,2,3])) == 1 — cycle wraps an iterable and returns elements repeatedly; first element is 1. Verified with Python 3.14.3."
    - "itertools.cycle.__bases__[0].__name__ == 'object' — cycle inherits directly from object. Verified with Python 3.14.3."
    - "itertools.repeat.__class__.__name__ == 'type' — repeat is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools' — repeat is exposed in the itertools module; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat' — the repeat type's __name__ is 'repeat'. Verified with Python 3.14.3."
    - "next(itertools.repeat(42)) == 42 — repeat yields the same value indefinitely; first next() returns 42. Verified with Python 3.14.3."
    - "list(itertools.repeat(7, 3)) == [7, 7, 7] — repeat with times=3 yields 7 exactly 3 times. Verified with Python 3.14.3."
    - "list(itertools.repeat(7, 0)) == [] — repeat with times=0 yields nothing; list is empty. Verified with Python 3.14.3."
    - "itertools.repeat(7, 3).__length_hint__() == 3 — repeat with a finite count supports __length_hint__, returning 3. Verified with Python 3.14.3."
    - "itertools.repeat.__bases__[0].__name__ == 'object' — repeat inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.cycle class identity
#
# itertools.cycle.__class__.__name__ == 'type'
# itertools.cycle.__module__ == 'itertools'
# itertools.cycle.__name__ == 'cycle'
# itertools.cycle.__bases__[0].__name__ == 'object'
#
# cycle is a C-level iterator type defined in itertoolsmodule.c.
# New to extra249.
# ---------------------------------------------------------------------------

table itertools_extra249.cycle_class_identity:
  description: "itertools.cycle class __name__, __module__, __class__.__name__, __bases__; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: iter249cyc

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_name_eq,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — cycle is the C-level infinite cycling iterator type; its __name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra249"]
    - [cycle_module_eq,
       cycle.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — cycle is exposed in the itertools module namespace; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra249"]
    - [cycle_class_name_type,
       cycle.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('type') == True — cycle is a type (a class object); __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra249"]
    - [cycle_bases0_object,
       "cycle.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__.__eq__('object') == True — cycle inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra249"]
    - [cycle_name_len_5,
       cycle.__name__.__len__,
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — 'cycle' has 5 characters; __len__() returns 5; new to extra249"]

# ---------------------------------------------------------------------------
# Table 2: itertools.repeat class identity
#
# itertools.repeat.__class__.__name__ == 'type'
# itertools.repeat.__module__ == 'itertools'
# itertools.repeat.__name__ == 'repeat'
# itertools.repeat.__bases__[0].__name__ == 'object'
#
# repeat is a C-level iterator type defined in itertoolsmodule.c.
# New to extra249.
# ---------------------------------------------------------------------------

table itertools_extra249.repeat_class_identity:
  description: "itertools.repeat class __name__, __module__, __class__.__name__, __bases__; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: iter249rep

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_name_eq,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — repeat is the C-level iterator that yields a single value repeatedly; its __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra249"]
    - [repeat_module_eq,
       repeat.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — repeat is exposed in the itertools module namespace; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra249"]
    - [repeat_class_name_type,
       repeat.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.repeat.__class__.__name__.__eq__('type') == True — repeat is a type (a class object); __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra249"]
    - [repeat_bases0_object,
       "repeat.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__name__.__eq__('object') == True — repeat inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra249"]
    - [repeat_name_len_6,
       repeat.__name__.__len__,
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters; __len__() returns 6; new to extra249"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra249
# ---------------------------------------------------------------------------

invariant itertools_extra249.cycle.name_eq:
  description: "itertools.cycle.__name__ == 'cycle' — cycle is the infinite cycling iterator type; new to extra249"
  category: identity
  kind: python_call_eq
  function: cycle.__name__.__eq__
  args: ["cycle"]
  expected: true

invariant itertools_extra249.cycle.module_eq:
  description: "itertools.cycle.__module__ == 'itertools' — cycle is in the itertools namespace; new to extra249"
  category: identity
  kind: python_call_eq
  function: cycle.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra249.cycle.class_is_type:
  description: "itertools.cycle.__class__.__name__ == 'type' — cycle is a type object; new to extra249"
  category: identity
  kind: python_call_eq
  function: cycle.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra249.cycle.bases0_is_object:
  description: "itertools.cycle.__bases__[0].__name__ == 'object' — cycle inherits directly from object; new to extra249"
  category: identity
  kind: python_call_eq
  function: "cycle.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra249.cycle.name_len_5:
  description: "itertools.cycle.__name__.__len__() == 5 — 'cycle' has 5 characters; new to extra249"
  category: identity
  kind: python_call_eq
  function: cycle.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra249.repeat.name_eq:
  description: "itertools.repeat.__name__ == 'repeat' — repeat is the single-value iterator type; new to extra249"
  category: identity
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra249.repeat.module_eq:
  description: "itertools.repeat.__module__ == 'itertools' — repeat is in the itertools namespace; new to extra249"
  category: identity
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra249.repeat.class_is_type:
  description: "itertools.repeat.__class__.__name__ == 'type' — repeat is a type object; new to extra249"
  category: identity
  kind: python_call_eq
  function: repeat.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra249.repeat.bases0_is_object:
  description: "itertools.repeat.__bases__[0].__name__ == 'object' — repeat inherits directly from object; new to extra249"
  category: identity
  kind: python_call_eq
  function: "repeat.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra249.repeat.name_len_6:
  description: "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters; new to extra249"
  category: identity
  kind: python_call_eq
  function: repeat.__name__.__len__
  args: []
  expected: 6
