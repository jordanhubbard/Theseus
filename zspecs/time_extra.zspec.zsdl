spec: time_extra
version: ">=3.3"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "Python time documentation — https://docs.python.org/3/library/time.html"
    - "POSIX.1-2017 — The Open Group Base Specifications (time functions)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
  notes:
    - "This spec extends time.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "time.zspec.zsdl covers: gmtime(0) epoch attributes, gmtime(1704067200) 2024 attributes, strptime vectors, struct_time.__name__, and function __name__ checks for gmtime/strptime/strftime/mktime/sleep."
    - "struct_time.__module__ == 'time' — the class is defined in the time C extension module."
    - "time(), monotonic(), perf_counter(), process_time() all return float; only return type is tested (values are non-deterministic)."
    - "gmtime() with no args returns the current time as struct_time; only the return type is tested."
    - "localtime() with no args returns local time as struct_time; only the return type is tested."
    - "time.timezone is a platform integer giving UTC offset in seconds west of UTC; its type is int."
    - "time.altzone is a platform integer giving the DST-adjusted UTC offset; its type is int."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct_time class metadata — module (name already in time.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant time_extra.struct_time.module:
  description: "time.struct_time.__module__ == 'time'"
  category: struct_time
  kind: python_call_eq
  function: struct_time.__module__.__eq__
  args: ["time"]
  expected: true

# ---------------------------------------------------------------------------
# Return type checks — non-deterministic time functions return float
# ---------------------------------------------------------------------------

invariant time_extra.time.return_type:
  description: "time.time().__class__.__name__ == 'float' — time() returns a float"
  category: return_types
  kind: python_call_eq
  function: time
  args: []
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

invariant time_extra.monotonic.return_type:
  description: "time.monotonic().__class__.__name__ == 'float' — monotonic() returns a float"
  category: return_types
  kind: python_call_eq
  function: monotonic
  args: []
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

invariant time_extra.perf_counter.return_type:
  description: "time.perf_counter().__class__.__name__ == 'float' — perf_counter() returns a float"
  category: return_types
  kind: python_call_eq
  function: perf_counter
  args: []
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

invariant time_extra.process_time.return_type:
  description: "time.process_time().__class__.__name__ == 'float' — process_time() returns a float"
  category: return_types
  kind: python_call_eq
  function: process_time
  args: []
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# gmtime() and localtime() with no args — return type only (values non-deterministic)
# ---------------------------------------------------------------------------

invariant time_extra.gmtime.return_type:
  description: "time.gmtime().__class__.__name__ == 'struct_time'"
  category: return_types
  kind: python_call_eq
  function: gmtime
  args: []
  method: __class__.__name__.__eq__
  method_args: ["struct_time"]
  expected: true

invariant time_extra.localtime.return_type:
  description: "time.localtime().__class__.__name__ == 'struct_time'"
  category: return_types
  kind: python_call_eq
  function: localtime
  args: []
  method: __class__.__name__.__eq__
  method_args: ["struct_time"]
  expected: true

# ---------------------------------------------------------------------------
# gmtime(0) — epoch attribute spot-checks
# (time.zspec.zsdl covers tm_year/tm_mon/tm_mday/tm_hour/tm_min/tm_sec/tm_wday/tm_yday/tm_isdst
#  in its table; these invariants are here as standalone anchors only if not already present.)
# These duplicate nothing not already in time.zspec.zsdl; they are intentionally omitted here.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# time.timezone and time.altzone — type checks
# ---------------------------------------------------------------------------

invariant time_extra.timezone.class_name:
  description: "time.timezone.__class__.__name__ == 'int' — UTC offset is an integer"
  category: module_constants
  kind: python_call_eq
  function: timezone.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant time_extra.altzone.class_name:
  description: "time.altzone.__class__.__name__ == 'int' — DST offset is an integer"
  category: module_constants
  kind: python_call_eq
  function: altzone.__class__.__name__.__eq__
  args: ["int"]
  expected: true
