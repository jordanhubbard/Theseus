spec: concurrent_futures_extra264
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "All Future methods are plain Python functions; __class__.__name__ == 'function'."
    - "All Future method __module__ values are 'concurrent.futures._base' (private submodule)."
    - "All Future method __qualname__ values carry the 'Future.' prefix (e.g. 'Future.cancel')."
    - "Methods covered: cancel, cancelled, running, done, result, exception, add_done_callback, set_result, set_exception."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future method __name__ — table
#
# Nine methods of concurrent.futures.Future: cancel, cancelled, running,
# done, result, exception, add_done_callback, set_result, set_exception.
# ---------------------------------------------------------------------------

table concurrent_futures_extra264.future_method_names:
  description: "concurrent.futures.Future methods report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mname

  columns: [id, function, args, expected, description]
  rows:
    - [cancel,            Future.cancel.__name__.__eq__,            ["cancel"],            true, "Future.cancel.__name__ == 'cancel'"]
    - [cancelled,         Future.cancelled.__name__.__eq__,         ["cancelled"],         true, "Future.cancelled.__name__ == 'cancelled'"]
    - [running,           Future.running.__name__.__eq__,           ["running"],           true, "Future.running.__name__ == 'running'"]
    - [done,              Future.done.__name__.__eq__,              ["done"],              true, "Future.done.__name__ == 'done'"]
    - [result,            Future.result.__name__.__eq__,            ["result"],            true, "Future.result.__name__ == 'result'"]
    - [exception,         Future.exception.__name__.__eq__,         ["exception"],         true, "Future.exception.__name__ == 'exception'"]
    - [add_done_callback, Future.add_done_callback.__name__.__eq__, ["add_done_callback"], true, "Future.add_done_callback.__name__ == 'add_done_callback'"]
    - [set_result,        Future.set_result.__name__.__eq__,        ["set_result"],        true, "Future.set_result.__name__ == 'set_result'"]
    - [set_exception,     Future.set_exception.__name__.__eq__,     ["set_exception"],     true, "Future.set_exception.__name__ == 'set_exception'"]

# ---------------------------------------------------------------------------
# Future method __qualname__ — table
#
# All Future method __qualname__ values carry the 'Future.' prefix.
# ---------------------------------------------------------------------------

table concurrent_futures_extra264.future_method_qualnames:
  description: "concurrent.futures.Future methods report 'Future.'-prefixed __qualname__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: mqualname

  columns: [id, function, args, expected, description]
  rows:
    - [cancel,            Future.cancel.__qualname__.__eq__,            ["Future.cancel"],            true, "Future.cancel.__qualname__ == 'Future.cancel'"]
    - [cancelled,         Future.cancelled.__qualname__.__eq__,         ["Future.cancelled"],         true, "Future.cancelled.__qualname__ == 'Future.cancelled'"]
    - [running,           Future.running.__qualname__.__eq__,           ["Future.running"],           true, "Future.running.__qualname__ == 'Future.running'"]
    - [done,              Future.done.__qualname__.__eq__,              ["Future.done"],              true, "Future.done.__qualname__ == 'Future.done'"]
    - [result,            Future.result.__qualname__.__eq__,            ["Future.result"],            true, "Future.result.__qualname__ == 'Future.result'"]
    - [exception,         Future.exception.__qualname__.__eq__,         ["Future.exception"],         true, "Future.exception.__qualname__ == 'Future.exception'"]
    - [add_done_callback, Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true, "Future.add_done_callback.__qualname__ == 'Future.add_done_callback'"]
    - [set_result,        Future.set_result.__qualname__.__eq__,        ["Future.set_result"],        true, "Future.set_result.__qualname__ == 'Future.set_result'"]
    - [set_exception,     Future.set_exception.__qualname__.__eq__,     ["Future.set_exception"],     true, "Future.set_exception.__qualname__ == 'Future.set_exception'"]

# ---------------------------------------------------------------------------
# Future method __class__.__name__ and __module__ — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra264.cancel.class_name:
  description: "concurrent.futures.Future.cancel.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: Future.cancel.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra264.cancel.module:
  description: "concurrent.futures.Future.cancel.__module__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: Future.cancel.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
