spec: just_unique
version: ">=4.2.0"
backend: node(just-unique)

docs: https://www.npmjs.com/package/just-unique

provenance:
  derived_from:
    - "just-unique README — https://www.npmjs.com/package/just-unique"
    - "Test vectors verified with just-unique via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-unique source"
  notes:
    - "just-unique is an npm package. Install: npm install just-unique"
    - "The module exports a single function that removes duplicate values from an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array with duplicate values removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_unique.unique:
  kind: node_module_call_eq
  function: ~
  category: filter
  id_prefix: juniq

  columns: [id, args, expected]
  rows:
    - [duplicates, [[1, 2, 1, 3, 2]], [1, 2, 3]]
    - [no_dups,    [[1, 2, 3]],       [1, 2, 3]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:11:05Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
