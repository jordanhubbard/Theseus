spec: wave_extra
version: ">=3.0"
backend: python_module(wave)

docs: https://docs.python.org/3/library/wave.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/wave.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "wave.zspec.zsdl — covers Wave_read/Wave_write/Error class names, module checks, open __name__, Error base, type checks, and method name checks"
  notes:
    - "This spec adds __name__-equality checks not in wave.zspec.zsdl."
    - "wave.Wave_read.__name__ == 'Wave_read' — the public class name."
    - "wave.Wave_write.__name__ == 'Wave_write' — the public class name."
    - "wave.Error.__name__ == 'Error' — the exception class name."
    - "wave.Error.__bases__[0].__name__ == 'Exception' — Error is a direct Exception subclass."
    - "wave.open.__name__ == 'open' — the entry-point function name attribute."
    - "wave.Wave_read.__module__ == 'wave' — the class is defined in the wave module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — __name__ equality for public classes
# ---------------------------------------------------------------------------

table wave_extra.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Wave_read,  Wave_read.__name__.__eq__,  ["Wave_read"],  true]
    - [Wave_write, Wave_write.__name__.__eq__, ["Wave_write"], true]
    - [Error,      Error.__name__.__eq__,      ["Error"],      true]

# ---------------------------------------------------------------------------
# Function name check — wave.open
# ---------------------------------------------------------------------------

invariant wave_extra.open.name:
  description: "wave.open.__name__ == 'open'"
  category: function_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership — Wave_read is defined in the wave module
# ---------------------------------------------------------------------------

invariant wave_extra.Wave_read.module:
  description: "wave.Wave_read.__module__ == 'wave'"
  category: modules
  kind: python_call_eq
  function: Wave_read.__module__.__eq__
  args: ["wave"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — wave.Error base is Exception
# ---------------------------------------------------------------------------

invariant wave_extra.Error.base_is_Exception:
  description: "wave.Error.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"
