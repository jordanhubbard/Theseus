spec: socket_extra122
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra121.zspec.zsdl — covers socket.socket.getpeername/getsockname/shutdown __class__.__module__.__eq__('builtins') and __class__.__name__.__len__()==17 (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() values and SocketIO class identity (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function class names (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra121; it does NOT duplicate invariants present in those files."
    - "Wave 285 theme: socket module Python-level function __code__ attributes — getaddrinfo/create_connection/getfqdn/has_dualstack_ipv6/create_server __code__.co_name equality and co_argcount — all five are Python-level functions in Lib/socket.py with __code__ attributes; extra96 anchors their __class__.__name__=='function' (getaddrinfo, create_connection); extra94 anchors __qualname__.__eq__; NOT YET covered: co_name equality or co_argcount for any of these five functions."
    - "socket.getaddrinfo.__code__.co_name == 'getaddrinfo'. co_argcount == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__code__.co_name == 'create_connection'. co_argcount == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_name == 'getfqdn'. co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.has_dualstack_ipv6.__code__.co_name == 'has_dualstack_ipv6'. co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__code__.co_name == 'create_server'. co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All five functions are defined in Lib/socket.py and have __code__ attributes (Python-level functions). getaddrinfo is a wrapper for the C-level getaddrinfo; it has 6 args (host, port, family=0, type=0, proto=0, flags=0). create_connection has 3 args (address, timeout, source_address). getfqdn has 1 arg (name=''). has_dualstack_ipv6 has 0 positional args. create_server has 1 positional arg (address). co_name always equals the function's def name — matching the qualname for top-level functions. len(getaddrinfo)==11; len(create_connection)==17 (co_name and qualname are the same length for top-level functions). All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_name.__eq__('getaddrinfo')
# socket.getaddrinfo.__code__.co_argcount.__eq__(6)
# socket.create_connection.__code__.co_name.__eq__('create_connection')
# socket.create_connection.__code__.co_argcount.__eq__(3)
# socket.getfqdn.__code__.co_name.__eq__('getfqdn')
#
# Wave 285 theme: getaddrinfo, create_connection, getfqdn __code__ attributes.
#
# getaddrinfo.__code__.co_name is 'getaddrinfo' (matches the def statement name).
# co_argcount is 6 (host, port, family=0, type=0, proto=0, flags=0). create_connection
# co_name is 'create_connection', co_argcount is 3 (address, timeout, source_address).
# getfqdn co_name is 'getfqdn', co_argcount is 1. extra96 anchors their __class__.__name__
# =='function'; extra94 anchors __qualname__.__eq__; no prior socket spec anchors __code__
# attributes for any module-level Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra122.python_fn_code_attrs_group1:
  description: "getaddrinfo.__code__.co_name.__eq__('getaddrinfo')==True / getaddrinfo.__code__.co_argcount.__eq__(6)==True / create_connection.__code__.co_name.__eq__('create_connection')==True / create_connection.__code__.co_argcount.__eq__(3)==True / getfqdn.__code__.co_name.__eq__('getfqdn')==True — all three are Python-level functions in Lib/socket.py; getaddrinfo has 6 args including defaults; create_connection has 3; getfqdn has 1; extra96 anchors class names; no prior spec anchors __code__ attrs for any socket module function; first sockcode122 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode122

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_co_name,   "getaddrinfo.__code__.co_name.__eq__",        ["getaddrinfo"],        true, "getaddrinfo.__code__.co_name is 'getaddrinfo' (matches def statement name; co_name always equals the def name; extra96 anchors class=='function'; no prior spec anchors co_name)"]
    - [getaddrinfo_co_argc,   "getaddrinfo.__code__.co_argcount.__eq__",     [6],                   true, "getaddrinfo.__code__.co_argcount is 6 (host, port, family=0, type=0, proto=0, flags=0 — 2 required + 4 default args; no prior spec anchors getaddrinfo co_argcount)"]
    - [create_conn_co_name,   "create_connection.__code__.co_name.__eq__",  ["create_connection"],  true, "create_connection.__code__.co_name is 'create_connection' (matches def statement name; extra96 anchors __class__.__name__=='function'; no prior spec anchors co_name)"]
    - [create_conn_co_argc,   "create_connection.__code__.co_argcount.__eq__",[3],                  true, "create_connection.__code__.co_argcount is 3 (address, timeout=GLOBAL_DEFAULT_TIMEOUT, source_address=None — 1 required + 2 default args; no prior spec anchors co_argcount)"]
    - [getfqdn_co_name,       "getfqdn.__code__.co_name.__eq__",            ["getfqdn"],            true, "getfqdn.__code__.co_name is 'getfqdn' (fully qualified domain name function; co_name matches def name; no prior spec anchors getfqdn __code__ attrs)"]

# ---------------------------------------------------------------------------
# socket.getfqdn.__code__.co_argcount.__eq__(1)
# socket.has_dualstack_ipv6.__code__.co_name.__eq__('has_dualstack_ipv6')
# socket.has_dualstack_ipv6.__code__.co_argcount.__eq__(0)
# socket.create_server.__code__.co_name.__eq__('create_server')
# socket.create_server.__code__.co_argcount.__eq__(1)
#
# Wave 285 theme: getfqdn, has_dualstack_ipv6, create_server __code__ attributes.
#
# getfqdn.__code__.co_argcount is 1 (name='' — optional hostname argument).
# has_dualstack_ipv6.__code__.co_name is 'has_dualstack_ipv6', co_argcount is 0
# (no positional args — it takes no arguments). create_server.__code__.co_name is
# 'create_server', co_argcount is 1 (address). has_dualstack_ipv6 is unusual in
# having co_argcount==0 among this group. No prior socket spec anchors __code__
# attributes for any of these three functions under sockcode122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra122.python_fn_code_attrs_group2:
  description: "getfqdn.__code__.co_argcount.__eq__(1)==True / has_dualstack_ipv6.__code__.co_name.__eq__('has_dualstack_ipv6')==True / has_dualstack_ipv6.__code__.co_argcount.__eq__(0)==True / create_server.__code__.co_name.__eq__('create_server')==True / create_server.__code__.co_argcount.__eq__(1)==True — getfqdn has 1 positional arg (name=''); has_dualstack_ipv6 has 0 args (tests if OS supports dual-stack sockets); create_server has 1 positional arg (address); no prior spec anchors __code__ attrs for any of these; first sockcode122 group2 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode122

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_co_argc,        "getfqdn.__code__.co_argcount.__eq__",            [1],                    true, "getfqdn.__code__.co_argcount is 1 (name='' — single optional hostname arg; getfqdn returns the fully qualified domain name; no prior spec anchors getfqdn co_argcount)"]
    - [dualstack_co_name,      "has_dualstack_ipv6.__code__.co_name.__eq__",     ["has_dualstack_ipv6"], true, "has_dualstack_ipv6.__code__.co_name is 'has_dualstack_ipv6' (tests OS dual-stack IPv6+IPv4 socket support; co_name matches def name; no prior spec anchors has_dualstack_ipv6 __code__ attrs)"]
    - [dualstack_co_argc,      "has_dualstack_ipv6.__code__.co_argcount.__eq__", [0],                    true, "has_dualstack_ipv6.__code__.co_argcount is 0 (takes no positional arguments; unique among this group in having co_argcount==0; no prior spec anchors this)"]
    - [create_server_co_name,  "create_server.__code__.co_name.__eq__",          ["create_server"],      true, "create_server.__code__.co_name is 'create_server' (creates a listening server socket; co_name matches def name; no prior spec anchors create_server __code__ attrs)"]
    - [create_server_co_argc,  "create_server.__code__.co_argcount.__eq__",      [1],                    true, "create_server.__code__.co_argcount is 1 (address — single positional arg; same co_argcount as getfqdn; no prior spec anchors create_server co_argcount)"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_name.__eq__('getaddrinfo')
# socket.getaddrinfo.__code__.co_argcount.__eq__(6)
# socket.create_connection.__code__.co_name.__eq__('create_connection')
# socket.has_dualstack_ipv6.__code__.co_name.__eq__('has_dualstack_ipv6')
# socket.has_dualstack_ipv6.__code__.co_argcount.__eq__(0)
#
# Wave 285 theme: unified cross-check for socket Python function co_name facts.
#
# This table provides a unified cross-check grouping key code attribute assertions
# across the five Python-level socket functions. It confirms that co_name consistently
# matches the function's def name (and hence its __qualname__ for top-level functions).
# has_dualstack_ipv6 is notable for co_argcount==0 (no positional args). getaddrinfo
# is notable for co_argcount==6 (the most args in this group). Together these span
# the range of argcounts: 0, 1, 1, 3, 6.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra122.python_fn_code_attrs_unified:
  description: "getaddrinfo.__code__.co_name.__eq__('getaddrinfo')==True / getaddrinfo.__code__.co_argcount.__eq__(6)==True / create_connection.__code__.co_name.__eq__('create_connection')==True / has_dualstack_ipv6.__code__.co_name.__eq__('has_dualstack_ipv6')==True / has_dualstack_ipv6.__code__.co_argcount.__eq__(0)==True — unified cross-check: co_name always equals def name; argcounts range from 0 (has_dualstack_ipv6) to 6 (getaddrinfo); no prior socket spec anchors __code__ attrs for any module Python function; first sockcode122 unified anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: sockcode122

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_co_name2,   "getaddrinfo.__code__.co_name.__eq__",         ["getaddrinfo"],        true, "getaddrinfo.__code__.co_name is 'getaddrinfo' (unified cross-check; co_name matches def name for top-level Python function)"]
    - [getaddrinfo_co_argc2,   "getaddrinfo.__code__.co_argcount.__eq__",      [6],                   true, "getaddrinfo.__code__.co_argcount is 6 (unified cross-check; most args in this group; 2 required + 4 optional)"]
    - [create_conn_co_name2,   "create_connection.__code__.co_name.__eq__",   ["create_connection"],  true, "create_connection.__code__.co_name is 'create_connection' (unified cross-check; co_name matches def name)"]
    - [dualstack_co_name2,     "has_dualstack_ipv6.__code__.co_name.__eq__",  ["has_dualstack_ipv6"], true, "has_dualstack_ipv6.__code__.co_name is 'has_dualstack_ipv6' (unified cross-check; co_name matches def name)"]
    - [dualstack_co_argc2,     "has_dualstack_ipv6.__code__.co_argcount.__eq__",[0],                  true, "has_dualstack_ipv6.__code__.co_argcount is 0 (unified cross-check; only function in this group with no positional args)"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_name.__eq__('getaddrinfo') — standalone
#
# socket.getaddrinfo.__code__.co_name is 'getaddrinfo'. getaddrinfo is a Python-level
# wrapper function in Lib/socket.py that calls the C-level socket.getaddrinfo and
# applies default argument handling. Its code object's co_name is 'getaddrinfo' —
# the name as written in the def statement. For top-level functions, co_name equals
# the function's __qualname__ (both 'getaddrinfo', 11 chars). extra96 anchors
# __class__.__name__=='function'; extra94 anchors __qualname__.__eq__; extra99 anchors
# __qualname__.__len__()==11. No prior socket spec anchors getaddrinfo.__code__.co_name
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra122.getaddrinfo_co_name_eq:
  description: "socket.getaddrinfo.__code__.co_name.__eq__('getaddrinfo') == True — getaddrinfo is a Python-level wrapper in Lib/socket.py; co_name reflects the def statement name; for top-level functions co_name equals __qualname__ ('getaddrinfo', 11 chars); extra96 anchors __class__.__name__=='function'; extra94 anchors __qualname__.__eq__; extra99 anchors __qualname__.__len__()==11; no prior spec anchors co_name as standalone; first standalone under sockcode122"
  category: code_attributes
  kind: python_call_eq
  function: "getaddrinfo.__code__.co_name.__eq__"
  args: ["getaddrinfo"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__code__.co_argcount.__eq__(6) — standalone
#
# socket.getaddrinfo.__code__.co_argcount is 6. getaddrinfo accepts:
# host, port, family=0, type=0, proto=0, flags=0 — that is 2 required positional
# arguments plus 4 optional keyword arguments = 6 total positional-or-keyword
# parameters as counted by co_argcount. The 6-arg count reflects the full parameter
# list of getaddrinfo as specified in POSIX and RFC 2133. No prior socket spec
# anchors getaddrinfo.__code__.co_argcount as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra122.getaddrinfo_co_argcount_6:
  description: "socket.getaddrinfo.__code__.co_argcount.__eq__(6) == True — getaddrinfo has 6 positional-or-keyword args: host, port, family=0, type=0, proto=0, flags=0 (2 required + 4 optional); co_argcount counts non-kw-only non-variadic args; 6 is the largest co_argcount in this spec; POSIX getaddrinfo has exactly this parameter list; no prior spec anchors getaddrinfo co_argcount as standalone; first standalone under sockcode122"
  category: code_attributes
  kind: python_call_eq
  function: "getaddrinfo.__code__.co_argcount.__eq__"
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# socket.has_dualstack_ipv6.__code__.co_name.__eq__('has_dualstack_ipv6') — standalone
#
# socket.has_dualstack_ipv6.__code__.co_name is 'has_dualstack_ipv6'. This is a
# Python-level function in Lib/socket.py that tests whether the operating system
# supports dual-stack (IPv6 with IPv4-mapped addresses) socket connections. Its
# co_argcount is 0 — it takes no positional arguments. The co_name 'has_dualstack_ipv6'
# has 18 chars — the longest co_name in this spec. No prior socket spec anchors
# has_dualstack_ipv6.__code__.co_name as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra122.has_dualstack_ipv6_co_name_eq:
  description: "socket.has_dualstack_ipv6.__code__.co_name.__eq__('has_dualstack_ipv6') == True — has_dualstack_ipv6 tests OS dual-stack IPv6+IPv4 socket support; Python-level function in Lib/socket.py; co_name is 'has_dualstack_ipv6' (18 chars; longest co_name in this spec; co_argcount==0 — takes no positional args); no prior socket spec anchors has_dualstack_ipv6 __code__ attrs in any form; first standalone under sockcode122"
  category: code_attributes
  kind: python_call_eq
  function: "has_dualstack_ipv6.__code__.co_name.__eq__"
  args: ["has_dualstack_ipv6"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__code__.co_name.__eq__('create_connection') — standalone
#
# socket.create_connection.__code__.co_name is 'create_connection'. create_connection
# is a convenience function in Lib/socket.py that creates a TCP socket connected to
# a given (host, port) address. Its co_argcount is 3 (address, timeout, source_address).
# The co_name 'create_connection' has 17 chars — coincidentally the same as the
# __qualname__ length (17 chars, since co_name==__qualname__ for top-level functions).
# extra96 anchors __class__.__name__=='function'; no prior socket spec anchors
# create_connection.__code__.co_name as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra122.create_connection_co_name_eq:
  description: "socket.create_connection.__code__.co_name.__eq__('create_connection') == True — create_connection is a convenience TCP socket connector in Lib/socket.py; co_name is 'create_connection' (17 chars; co_argcount==3: address, timeout, source_address; co_name equals __qualname__ for top-level functions — both 17 chars; extra96 anchors __class__.__name__=='function'; no prior spec anchors co_name as standalone; first standalone under sockcode122)"
  category: code_attributes
  kind: python_call_eq
  function: "create_connection.__code__.co_name.__eq__"
  args: ["create_connection"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_server.__code__.co_name.__eq__('create_server') — standalone
#
# socket.create_server.__code__.co_name is 'create_server'. create_server is a
# Python-level function in Lib/socket.py that creates a TCP socket bound and listening
# on the given address. Its co_argcount is 1 (address). The co_name 'create_server'
# has 13 chars. No prior socket spec anchors create_server.__code__.co_name in any
# form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra122.create_server_co_name_eq:
  description: "socket.create_server.__code__.co_name.__eq__('create_server') == True — create_server creates a TCP listening server socket in Lib/socket.py; co_name is 'create_server' (13 chars; co_argcount==1: address; co_name equals __qualname__ for top-level functions — both 13 chars; no prior socket spec anchors create_server __code__ attrs in any form; first standalone under sockcode122)"
  category: code_attributes
  kind: python_call_eq
  function: "create_server.__code__.co_name.__eq__"
  args: ["create_server"]
  expected: true
