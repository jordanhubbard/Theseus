spec: glob_extra
version: ">=3.4"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/glob.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "glob source: internal implementation details"
  notes:
    - "This spec covers glob behaviors not present in glob.zspec.zsdl."
    - "glob.glob.__module__ == 'glob' confirms the function is defined directly in the glob module."
    - "glob.escape() uses bracket-escaping, not backslash-escaping: '*' becomes '[*]', '?' becomes '[?]', '[' becomes '[[]'."
    - "escape('[abc]') == '[[]abc]' — the opening '[' is bracket-escaped to '[[]', leaving 'abc]' as a literal suffix."
    - "escape('a?b') == 'a[?]b' — the '?' wildcard is bracket-escaped to '[?]'."
    - "escape('a*b') == 'a[*]b' — the '*' wildcard is bracket-escaped to '[*]'."
    - "All expected values verified by running Python 3.14.3 glob module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant glob_extra.module.glob_module:
  description: "glob.glob.__module__ == 'glob'"
  category: module
  kind: python_call_eq
  function: glob.__module__.__eq__
  args: ["glob"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant glob_extra.function_names.glob:
  description: "glob.glob.__name__ == 'glob'"
  category: function_names
  kind: python_call_eq
  function: glob.__name__.__eq__
  args: ["glob"]
  expected: true

invariant glob_extra.function_names.iglob:
  description: "glob.iglob.__name__ == 'iglob'"
  category: function_names
  kind: python_call_eq
  function: iglob.__name__.__eq__
  args: ["iglob"]
  expected: true

invariant glob_extra.function_names.escape:
  description: "glob.escape.__name__ == 'escape'"
  category: function_names
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true

# ---------------------------------------------------------------------------
# escape() — bracket-encoding of wildcard characters
#
# Python's glob.escape() uses bracket notation to neutralize special chars:
#   * -> [*]   ? -> [?]   [ -> [[]
# This differs from backslash-escaping used in some other shell contexts.
# ---------------------------------------------------------------------------

invariant glob_extra.escape.bracket:
  description: "glob.escape('[abc]') == '[[]abc]' — opening '[' is bracket-escaped to '[[]'"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["[abc]"]
  expected: "[[]abc]"

invariant glob_extra.escape.question:
  description: "glob.escape('a?b') == 'a[?]b' — '?' wildcard is bracket-escaped"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["a?b"]
  expected: "a[?]b"

invariant glob_extra.escape.star:
  description: "glob.escape('a*b') == 'a[*]b' — '*' wildcard is bracket-escaped"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["a*b"]
  expected: "a[*]b"
