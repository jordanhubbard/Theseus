invariant multiprocessing_extra230.Array.name_len:
  description: "multiprocessing.Array.__name__.__len__() == 5 — 'Array' has 5 characters; new to extra230"
  category: array_identity
  kind: python_call_eq
  function: Array.__name__.__len__
  args: []
