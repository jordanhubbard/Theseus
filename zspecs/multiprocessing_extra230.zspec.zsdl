spec: multiprocessing_extra230
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers multiprocessing.Value and multiprocessing.Array function identity."
    - "Both Value and Array are bound methods of the default multiprocessing context (BaseContext)."
    - "multiprocessing.Value.__name__ == 'Value' — 5 characters."
    - "multiprocessing.Value.__module__ == 'multiprocessing.context' — the context submodule (23 chars)."
    - "multiprocessing.Value.__class__.__name__ == 'method' — bound method at the top-level namespace."
    - "multiprocessing.Value.__qualname__ == 'BaseContext.Value' — 17 characters."
    - "multiprocessing.Array.__name__ == 'Array' — 5 characters."
    - "multiprocessing.Array.__module__ == 'multiprocessing.context' — the context submodule (23 chars)."
    - "multiprocessing.Array.__class__.__name__ == 'method' — bound method at the top-level namespace."
    - "multiprocessing.Array.__qualname__ == 'BaseContext.Array' — 17 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Value function identity contracts
#
# Verifies __name__, __module__, __qualname__, and __class__.__name__ for
# Value (a bound method of the default BaseContext).
# ---------------------------------------------------------------------------

table multiprocessing_extra230.value_identity:
  description: "multiprocessing.Value function identity: name, module, qualname, class; new to extra230"
  kind: python_call_eq
  category: value_identity
  id_prefix: mpval230

  columns: [id, function, args, expected, description]
  rows:
    - [val_name_eq,
       Value.__name__.__eq__,
       ["Value"],
       true,
       "multiprocessing.Value.__name__.__eq__('Value') == True — bound method carries its simple name; new to extra230"]
    - [val_module_eq,
       Value.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.Value.__module__.__eq__('multiprocessing.context') == True — defined in context submodule; new to extra230"]
    - [val_class_name_eq,
       Value.__class__.__name__.__eq__,
       ["method"],
       true,
       "multiprocessing.Value.__class__.__name__ == 'method' — bound method at the top-level namespace; new to extra230"]
    - [val_name_len_5,
       Value.__name__.__len__,
       [],
       5,
       "multiprocessing.Value.__name__.__len__() == 5 — 'Value' has exactly 5 characters; new to extra230"]
    - [val_module_len_23,
       Value.__module__.__len__,
       [],
       23,
       "multiprocessing.Value.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra230"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.Array function identity contracts
#
# Verifies __name__, __module__, __qualname__, and __class__.__name__ for
# Array (a bound method of the default BaseContext).
# ---------------------------------------------------------------------------

table multiprocessing_extra230.array_identity:
  description: "multiprocessing.Array function identity: name, module, qualname, class; new to extra230"
  kind: python_call_eq
  category: array_identity
  id_prefix: mparr230

  columns: [id, function, args, expected, description]
  rows:
    - [arr_name_eq,
       Array.__name__.__eq__,
       ["Array"],
       true,
       "multiprocessing.Array.__name__.__eq__('Array') == True — bound method carries its simple name; new to extra230"]
    - [arr_module_eq,
       Array.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.Array.__module__.__eq__('multiprocessing.context') == True — defined in context submodule; new to extra230"]
    - [arr_class_name_eq,
       Array.__class__.__name__.__eq__,
       ["method"],
       true,
       "multiprocessing.Array.__class__.__name__ == 'method' — bound method at the top-level namespace; new to extra230"]
    - [arr_name_len_5,
       Array.__name__.__len__,
       [],
       5,
       "multiprocessing.Array.__name__.__len__() == 5 — 'Array' has exactly 5 characters; new to extra230"]
    - [arr_module_len_23,
       Array.__module__.__len__,
       [],
       23,
       "multiprocessing.Array.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra230"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra230
# ---------------------------------------------------------------------------

invariant multiprocessing_extra230.Value.name:
  description: "multiprocessing.Value.__name__ == 'Value'; new to extra230"
  category: value_identity
  kind: python_call_eq
  function: Value.__name__.__eq__
  args: ["Value"]
  expected: true

invariant multiprocessing_extra230.Value.module:
  description: "multiprocessing.Value.__module__ == 'multiprocessing.context'; new to extra230"
  category: value_identity
  kind: python_call_eq
  function: Value.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra230.Value.class_name:
  description: "multiprocessing.Value.__class__.__name__ == 'method' — bound method; new to extra230"
  category: value_identity
  kind: python_call_eq
  function: Value.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra230.Value.qualname:
  description: "multiprocessing.Value.__qualname__ == 'BaseContext.Value'; new to extra230"
  category: value_identity
  kind: python_call_eq
  function: Value.__qualname__.__eq__
  args: ["BaseContext.Value"]
  expected: true

invariant multiprocessing_extra230.Value.name_len:
  description: "multiprocessing.Value.__name__.__len__() == 5 — 'Value' has 5 characters; new to extra230"
  category: value_identity
  kind: python_call_eq
  function: Value.__name__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra230.Value.module_len:
  description: "multiprocessing.Value.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra230"
  category: value_identity
  kind: python_call_eq
  function: Value.__module__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra230.Value.qualname_len:
  description: "multiprocessing.Value.__qualname__.__len__() == 17 — 'BaseContext.Value' has 17 characters; new to extra230"
  category: value_identity
  kind: python_call_eq
  function: Value.__qualname__.__len__
  args: []
  expected: 17

invariant multiprocessing_extra230.Array.name:
  description: "multiprocessing.Array.__name__ == 'Array'; new to extra230"
  category: array_identity
  kind: python_call_eq
  function: Array.__name__.__eq__
  args: ["Array"]
  expected: true

invariant multiprocessing_extra230.Array.module:
  description: "multiprocessing.Array.__module__ == 'multiprocessing.context'; new to extra230"
  category: array_identity
  kind: python_call_eq
  function: Array.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra230.Array.class_name:
  description: "multiprocessing.Array.__class__.__name__ == 'method' — bound method; new to extra230"
  category: array_identity
  kind: python_call_eq
  function: Array.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra230.Array.qualname:
