spec: chunk
version: ">=3.9,<3.13"
backend: python_module(chunk)

docs: https://docs.python.org/3.11/library/chunk.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3.11/library/chunk.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/chunk.py"
  notes:
    - "The chunk module was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13."
    - "This spec targets Python 3.9 through 3.12 inclusive."
    - "chunk.Chunk is the sole public class; it wraps an IFF (Interchange File Format) chunk."
    - "Chunk instances are created from a file-like object positioned at the start of an IFF chunk header."
    - "Chunk.getname() returns the 4-byte chunk-type identifier as bytes."
    - "Chunk.getsize() returns the size of the chunk data (excluding the 8-byte header) as an integer."
    - "Chunk.read([size]) reads up to size bytes of chunk data; read() with no arg reads to end."
    - "Chunk.seek(pos[, whence]) seeks within chunk data."
    - "Chunk.tell() returns the current position within the chunk data."
    - "Chunk.skip() advances past the rest of the chunk data."
    - "Chunk.close() marks the chunk as closed; further reads raise ValueError."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "chunk.Chunk raises EOFError if the underlying file is truncated. Reading a closed Chunk raises ValueError."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Class name — chunk.Chunk
# ---------------------------------------------------------------------------

invariant chunk.Chunk.class_name:
  description: "chunk.Chunk.__name__ == 'Chunk'"
  category: classnames
  kind: python_call_eq
  function: Chunk.__name__.__eq__
  args: ["Chunk"]
  expected: true

# ---------------------------------------------------------------------------
# Module identity — chunk.Chunk is defined in chunk
# ---------------------------------------------------------------------------

invariant chunk.Chunk.module:
  description: "chunk.Chunk.__module__ == 'chunk' — Chunk is defined in the chunk module"
  category: module
  kind: python_call_eq
  function: Chunk.__module__.__eq__
  args: ["chunk"]
  expected: true

# ---------------------------------------------------------------------------
# Method name attributes on the Chunk class
# ---------------------------------------------------------------------------

table chunk.Chunk.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: method_name

  columns: [id, function, args, expected]
  rows:
    - [getname, Chunk.getname.__name__.__eq__, ["getname"], true]
    - [getsize, Chunk.getsize.__name__.__eq__, ["getsize"], true]
    - [read,    Chunk.read.__name__.__eq__,    ["read"],    true]
    - [seek,    Chunk.seek.__name__.__eq__,    ["seek"],    true]
    - [tell,    Chunk.tell.__name__.__eq__,    ["tell"],    true]
    - [skip,    Chunk.skip.__name__.__eq__,    ["skip"],    true]
    - [close,   Chunk.close.__name__.__eq__,   ["close"],   true]

# ---------------------------------------------------------------------------
# Chunk is a class (type)
# ---------------------------------------------------------------------------

invariant chunk.Chunk.is_class:
  description: "Chunk.__class__.__name__ == 'type' — chunk.Chunk is a class object"
  category: classnames
  kind: python_call_eq
  function: Chunk.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Chunk base class is object
# ---------------------------------------------------------------------------

invariant chunk.Chunk.base_class:
  description: "chunk.Chunk.__bases__[0].__name__ == 'object' — Chunk inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Chunk.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

