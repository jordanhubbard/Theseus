spec: lzma_extra11
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
  notes:
    - "This spec extends lzma_extra10.zspec.zsdl."
    - "Prior specs covered: lzma.__name__/__package__, LZMAFile.__name__/__module__/__qualname__, LZMAError.__name__/__module__, LZMACompressor.__name__/__module__, LZMADecompressor.__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, LZMAFile.__bases__[0].__name__, LZMAError.__bases__[0].__name__, various __qualname__ checks, FORMAT_*/CHECK_*/PRESET_* constant class names."
    - "This spec covers: lzma.LZMAFile.__init__.__name__, lzma.LZMAError.__init__.__name__, lzma.open.__qualname__, lzma.compress.__qualname__, lzma.decompress.__qualname__, lzma.open.__module__.__len__(), lzma.compress.__module__.__len__(), lzma.decompress.__module__.__len__(), lzma.LZMAFile.__module__.__len__(), lzma.LZMAError.__module__.__len__()."
    - "lzma.LZMAFile.__init__.__name__ == '__init__': the constructor method name. Verified 2026-04-09."
    - "lzma.LZMAError.__init__.__name__ == '__init__': the constructor method name. Verified 2026-04-09."
    - "lzma.open.__qualname__ == 'open': module-level function qualname. Verified 2026-04-09."
    - "lzma.compress.__qualname__ == 'compress': function qualname equals function name. Verified 2026-04-09."
    - "lzma.decompress.__qualname__ == 'decompress': function qualname equals function name. Verified 2026-04-09."
    - "lzma.open.__module__ == 'lzma' (len 4): open lives in the lzma module. Verified 2026-04-09."
    - "lzma.compress.__module__ == 'lzma' (len 4): compress lives in lzma. Verified 2026-04-09."
    - "lzma.decompress.__module__ == 'lzma' (len 4): decompress lives in lzma. Verified 2026-04-09."
    - "lzma.LZMAFile.__module__ == 'lzma' (len 4): LZMAFile is defined in lzma. Verified 2026-04-09."
    - "lzma.LZMAError.__module__ == '_lzma' (len 5): LZMAError is a C extension type defined in _lzma. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LZMAFile.__init__.__name__ == '__init__' — novel, extra11 anchor
#
# No prior lzma spec checks LZMAFile.__init__.__name__. The constructor method
# name is '__init__'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.LZMAFile.init_name:
  description: "lzma.LZMAFile.__init__.__name__ == '__init__' — constructor method name (extra11)"
  category: method_names
  kind: python_call_eq
  function: LZMAFile.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAError.__init__.__name__ == '__init__' — novel, extra11 anchor
#
# No prior lzma spec checks LZMAError.__init__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.LZMAError.init_name:
  description: "lzma.LZMAError.__init__.__name__ == '__init__' — constructor method name (extra11)"
  category: method_names
  kind: python_call_eq
  function: LZMAError.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# open.__qualname__ == 'open' — novel, extra11 anchor
#
# No prior lzma spec checks open.__qualname__ from the extra11 namespace.
# lzma.open is a module-level function; its __qualname__ equals its __name__.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.open.qualname:
  description: "lzma.open.__qualname__ == 'open' — module-level function qualname (extra11)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# compress.__qualname__ == 'compress' — novel, extra11 anchor
#
# No prior lzma spec checks compress.__qualname__ from the extra11 namespace.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.compress.qualname:
  description: "lzma.compress.__qualname__ == 'compress' — module-level function qualname (extra11)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__qualname__ == 'decompress' — novel, extra11 anchor
#
# No prior lzma spec checks decompress.__qualname__ from the extra11 namespace.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.decompress.qualname:
  description: "lzma.decompress.__qualname__ == 'decompress' — module-level function qualname (extra11)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# open.__module__.__len__() == 4 — novel, extra11 anchor
#
# lzma.open.__module__ == 'lzma' which has length 4. No prior lzma spec checks
# __module__.__len__() for the open function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.open.module_len:
  description: "lzma.open.__module__.__len__() == 4 — 'lzma' module name has four characters (extra11)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 4 — novel, extra11 anchor
#
# lzma.compress.__module__ == 'lzma' (len 4). No prior lzma spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.compress.module_len:
  description: "lzma.compress.__module__.__len__() == 4 — 'lzma' module name has four characters (extra11)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 4 — novel, extra11 anchor
#
# lzma.decompress.__module__ == 'lzma' (len 4). No prior lzma spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.decompress.module_len:
  description: "lzma.decompress.__module__.__len__() == 4 — 'lzma' module name has four characters (extra11)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# LZMAFile.__module__.__len__() == 4 — novel, extra11 anchor
#
# lzma.LZMAFile.__module__ == 'lzma' (len 4). No prior lzma spec checks
# __module__.__len__() for LZMAFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.LZMAFile.module_len:
  description: "lzma.LZMAFile.__module__.__len__() == 4 — 'lzma' module name has four characters (extra11)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMAFile.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# LZMAError.__module__.__len__() == 5 — novel, extra11 anchor
#
# lzma.LZMAError.__module__ == '_lzma' which has length 5. LZMAError is a C
# extension type from the _lzma module. No prior lzma spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra11.LZMAError.module_len:
  description: "lzma.LZMAError.__module__.__len__() == 5 — '_lzma' module name has five characters (extra11)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMAError.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __init__.__name__ table — LZMAFile and LZMAError (extra11)
#
# No prior lzma spec presents __init__.__name__ checks in a table.
# This table anchors both from the extra11 namespace.
# ---------------------------------------------------------------------------

table lzma_extra11.init_names:
  kind: python_call_eq
  category: method_names
  id_prefix: init11

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,  LZMAFile.__init__.__name__.__eq__,  ["__init__"], true]
    - [LZMAError, LZMAError.__init__.__name__.__eq__, ["__init__"], true]

# ---------------------------------------------------------------------------
# __module__.__len__() table — open, compress, decompress, LZMAFile, LZMAError
#                              (extra11)
#
# No prior lzma spec presents __module__.__len__() checks in a table.
# open/compress/decompress/LZMAFile have module 'lzma' (len 4);
# LZMAError has module '_lzma' (len 5). This table anchors all five from
# the extra11 namespace.
# ---------------------------------------------------------------------------

table lzma_extra11.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen11

  columns: [id, function, args, expected]
  rows:
    - [open,        open.__module__.__len__,        [], 4]
    - [compress,    compress.__module__.__len__,    [], 4]
    - [decompress,  decompress.__module__.__len__,  [], 4]
    - [LZMAFile,    LZMAFile.__module__.__len__,    [], 4]
    - [LZMAError,   LZMAError.__module__.__len__,   [], 5]
