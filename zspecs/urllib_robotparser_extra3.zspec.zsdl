spec: urllib_robotparser_extra3
version: ">=3.0"
backend: python_module(urllib.robotparser)

docs: https://docs.python.org/3/library/urllib.robotparser.html

provenance:
  derived_from:
    - "Python urllib.robotparser documentation — https://docs.python.org/3/library/urllib.robotparser.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/robotparser.py"
  notes:
    - "This spec extends urllib_robotparser.zspec.zsdl and urllib_robotparser_extra2.zspec.zsdl."
    - "urllib_robotparser.zspec.zsdl covers: RobotFileParser.__name__/__module__; method __name__ for set_url/read/parse/can_fetch/crawl_delay/request_rate; initial url/disallow_all/allow_all/entries/default_entry; set_url returns None; crawl_delay/request_rate return None."
    - "urllib_robotparser_extra2.zspec.zsdl covers: RobotFileParser.__qualname__/__class__.__name__/__bases__[0].__name__; method __qualname__ for all 8 methods; mtime() == 0; modified() returns None."
    - "No prior spec covers: RobotFileParser.__mro__[0].__name__ == 'RobotFileParser' (MRO self-check)."
    - "No prior spec covers: RobotFileParser.__mro__[1].__name__ == 'object' (MRO terminus)."
    - "No prior spec covers: RobotFileParser.__name__.__len__() == 15 (name length check)."
    - "No prior spec covers: RobotFileParser.set_url.__module__ == 'urllib.robotparser'."
    - "No prior spec covers: RobotFileParser.can_fetch.__module__ == 'urllib.robotparser'."
    - "No prior spec covers: RobotFileParser.parse.__module__ == 'urllib.robotparser'."
    - "No prior spec covers: RobotFileParser.mtime.__module__ == 'urllib.robotparser'."
    - "No prior spec covers: RobotFileParser.modified.__module__ == 'urllib.robotparser'."
    - "No prior spec covers: can_fetch returns True for an empty parser and any URL (no disallow rules)."
    - "RobotFileParser.__mro__: [RobotFileParser, object] — only two entries as it has no base class."
    - "Method __module__ attributes reflect the defining module for all RobotFileParser methods."
    - "can_fetch('*', 'http://example.com/') returns True on an empty parser because no rules are loaded."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# RobotFileParser MRO — two-entry MRO: [RobotFileParser, object]
#
# urllib_robotparser_extra2 covers __bases__[0].__name__ == 'object'.
# No prior spec checks __mro__ at any index for RobotFileParser.
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra3.mro_index0:
  description: "RobotFileParser.__mro__[0].__name__ == 'RobotFileParser' — MRO self-check"
  category: class_hierarchy
  kind: python_call_eq
  function: RobotFileParser.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "RobotFileParser"

invariant urllib_robotparser_extra3.mro_index1:
  description: "RobotFileParser.__mro__[1].__name__ == 'object' — MRO terminus is object"
  category: class_hierarchy
  kind: python_call_eq
  function: RobotFileParser.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# RobotFileParser.__name__ length check
#
# urllib_robotparser.zspec.zsdl checks __name__ == 'RobotFileParser' via __eq__.
# No prior spec checks __name__.__len__() for this class.
# 'RobotFileParser' has 15 characters.
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra3.name_len:
  description: "RobotFileParser.__name__.__len__() == 15 — 'RobotFileParser' has 15 characters"
  category: identity
  kind: python_call_eq
  function: RobotFileParser.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# Method __module__ checks — all public methods belong to urllib.robotparser
#
# urllib_robotparser_extra2 covers method __qualname__ for all 8 methods.
# No prior spec covers method __module__ for any RobotFileParser method.
# ---------------------------------------------------------------------------

table urllib_robotparser_extra3.method_modules:
  description: "All RobotFileParser methods have __module__ == 'urllib.robotparser'"
  kind: python_call_eq
  category: modules
  id_prefix: mmod

  columns: [id, function, args, expected]
  rows:
    - [set_url,      RobotFileParser.set_url.__module__.__eq__,      ["urllib.robotparser"], true]
    - [read,         RobotFileParser.read.__module__.__eq__,         ["urllib.robotparser"], true]
    - [parse,        RobotFileParser.parse.__module__.__eq__,        ["urllib.robotparser"], true]
    - [can_fetch,    RobotFileParser.can_fetch.__module__.__eq__,    ["urllib.robotparser"], true]
    - [crawl_delay,  RobotFileParser.crawl_delay.__module__.__eq__,  ["urllib.robotparser"], true]
    - [request_rate, RobotFileParser.request_rate.__module__.__eq__, ["urllib.robotparser"], true]
    - [mtime,        RobotFileParser.mtime.__module__.__eq__,        ["urllib.robotparser"], true]
    - [modified,     RobotFileParser.modified.__module__.__eq__,     ["urllib.robotparser"], true]

# ---------------------------------------------------------------------------
# can_fetch() on empty parser — returns True when no rules are loaded
#
# urllib_robotparser.zspec.zsdl covers crawl_delay and request_rate returning None.
# No prior spec covers can_fetch behavior on an empty (unparsed) parser.
# An empty parser has no disallow rules, so can_fetch always returns True.
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra3.can_fetch_empty_star:
  description: "RobotFileParser().can_fetch('*', 'http://example.com/') == True — no rules loaded, all allowed"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: can_fetch
  method_args: ["*", "http://example.com/"]
  expected: true

invariant urllib_robotparser_extra3.can_fetch_empty_useragent:
  description: "RobotFileParser().can_fetch('Googlebot', 'http://example.com/page') == True — no rules loaded"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: can_fetch
  method_args: ["Googlebot", "http://example.com/page"]
  expected: true
