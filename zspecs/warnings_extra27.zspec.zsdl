spec: warnings_extra27
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "warnings_extra26.zspec.zsdl — covers __all__.__len__()==9; __all__.__class__.__name__.__len__()==4; filters/defaultaction/onceregistry class name lengths; WarningMessage/catch_warnings __dict__.__class__.__name__.__len__()==12; warn(4)/filterwarnings(14)/simplefilter(12) __qualname__.__len__()."
    - "warnings_extra25.zspec.zsdl — covers WarningMessage/catch_warnings/UserWarning/DeprecationWarning __mro__.__len__() and __bases__[0].__name__.__len__(); WarningMessage/__str__/__init__ __qualname__.__len__(); catch_warnings method __qualname__.__len__()."
    - "warnings_extra24.zspec.zsdl — covers warn/warn_explicit/simplefilter/filterwarnings/resetwarnings __module__.__len__() and __name__.__len__(); catch_warnings method __qualname__.__len__() (__init__=23, __enter__=24, __exit__=23, __repr__=23)."
  notes:
    - "This spec extends warnings_extra26.zspec.zsdl."
    - "Prior specs covered: WarningMessage/catch_warnings/UserWarning/DeprecationWarning __mro__/__bases__/__dict__, class method __qualname__.__len__(), module-level function __name__/__module__/__qualname__ lengths for warn/filterwarnings/simplefilter/resetwarnings."
    - "This spec covers NEW angles: class __qualname__.__len__() for WarningMessage(14)/catch_warnings(14); module-level function __qualname__.__len__() for resetwarnings(13)/warn_explicit(13)/formatwarning(13)/showwarning(11)/deprecated(10); warnings.__name__.__len__()==8."
    - "warnings.WarningMessage.__qualname__ == 'WarningMessage' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__qualname__ == 'catch_warnings' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.resetwarnings.__qualname__ == 'resetwarnings' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.warn_explicit.__qualname__ == 'warn_explicit' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.formatwarning.__qualname__ == 'formatwarning' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.showwarning.__qualname__ == 'showwarning' (len 11). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.deprecated.__qualname__ == 'deprecated' (len 10). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.__name__ == 'warnings' (len 8). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings class __qualname__.__len__() for WarningMessage and catch_warnings
#
# No prior spec checks __qualname__.__len__() for WarningMessage or
# catch_warnings. Both have qualname equal to their name: 'WarningMessage'
# (len 14) and 'catch_warnings' (len 14).
# ---------------------------------------------------------------------------

invariant warnings_extra27.WarningMessage.qualname.len:
  description: "warnings.WarningMessage.__qualname__.__len__() == 14 — 'WarningMessage' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: WarningMessage.__qualname__.__len__
  args: []
  expected: 14

invariant warnings_extra27.catch_warnings.qualname.len:
  description: "warnings.catch_warnings.__qualname__.__len__() == 14 — 'catch_warnings' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: catch_warnings.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# warnings.__name__.__len__()
#
# No prior spec checks warnings.__name__.__len__(). The module name is
# 'warnings' (len 8).
# ---------------------------------------------------------------------------

invariant warnings_extra27.module.name.len:
  description: "warnings.__name__.__len__() == 8 — module name 'warnings' has 8 characters"
  category: module_membership
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# warnings.warn_explicit.__qualname__.__len__()
#
# warn_explicit.__qualname__ == 'warn_explicit' (len 13). Not covered in any
# prior warnings spec. warn_explicit is the lower-level warning dispatch
# function used by warn internally.
# ---------------------------------------------------------------------------

invariant warnings_extra27.warn_explicit.qualname.len:
  description: "warnings.warn_explicit.__qualname__.__len__() == 13 — 'warn_explicit' has 13 characters"
  category: string_length
  kind: python_call_eq
  function: warn_explicit.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() — resetwarnings,
# formatwarning, showwarning, deprecated
#
# No prior spec checks __qualname__.__len__() for resetwarnings, formatwarning,
# showwarning, or deprecated.
# resetwarnings=13, formatwarning=13, showwarning=11, deprecated=10.
# ---------------------------------------------------------------------------

table warnings_extra27.function_qualname_lens:
  description: "warnings module-level function __qualname__.__len__() — resetwarnings (13), formatwarning (13), showwarning (11), deprecated (10)"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [resetwarnings_qualname_len,
       resetwarnings.__qualname__.__len__,
       [],
       13,
       "len('resetwarnings') == 13"]
    - [formatwarning_qualname_len,
       formatwarning.__qualname__.__len__,
       [],
       13,
       "len('formatwarning') == 13"]
    - [showwarning_qualname_len,
       showwarning.__qualname__.__len__,
       [],
       11,
       "len('showwarning') == 11"]
    - [deprecated_qualname_len,
       deprecated.__qualname__.__len__,
       [],
       10,
       "len('deprecated') == 10"]
    - [warn_explicit_qualname_len,
       warn_explicit.__qualname__.__len__,
       [],
       13,
       "len('warn_explicit') == 13"]

# ---------------------------------------------------------------------------
# Table: warnings class __qualname__.__len__() and module __name__.__len__()
#
# Groups class qualname lengths for WarningMessage and catch_warnings, plus
# the module __name__ length. No prior spec covers any of these.
# ---------------------------------------------------------------------------

table warnings_extra27.class_qualname_and_module_name:
  description: "warnings class __qualname__.__len__() for WarningMessage (14) and catch_warnings (14), plus module __name__.__len__() (8)"
  kind: python_call_eq
  category: class_identity

  columns: [id, function, args, expected, description]
  rows:
    - [WarningMessage_qualname_len,
       WarningMessage.__qualname__.__len__,
       [],
       14,
       "len('WarningMessage') == 14"]
    - [catch_warnings_qualname_len,
       catch_warnings.__qualname__.__len__,
       [],
       14,
       "len('catch_warnings') == 14"]
    - [module_name_len,
       __name__.__len__,
       [],
       8,
       "len('warnings') == 8 — module __name__"]
