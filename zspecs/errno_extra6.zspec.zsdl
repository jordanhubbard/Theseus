spec: errno_extra6
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "Extends errno.zspec.zsdl through errno_extra5.zspec.zsdl."
    - "errno.zspec covers: EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22 values; errorcode type/lookups 1/2/22."
    - "errno_extra covers: class names for ENOENT/EACCES/EEXIST/EPERM; errorcode class name; errorcode[2]=='ENOENT'; contains key 2."
    - "errno_extra2 covers: class names EPERM/ENOENT/ESRCH/EINTR/EIO/ENXIO/EACCES/EEXIST/ENOTDIR/EISDIR; errorcode class/len>=50; positivity EPERM/ENOENT/EACCES."
    - "errno_extra3 covers: class names EBADF/ENOMEM/EINVAL; errorcode lookups 9/12; contains 9/12."
    - "errno_extra4 covers: class names ENOSPC/EPIPE/ERANGE/EMFILE/ENFILE; errorcode lookups 5/13/28/32; positivity ESRCH/EINTR/EIO."
    - "errno_extra5 covers: constant values ECHILD=10/EFAULT=14/ENOTDIR=20/EISDIR=21/ENXIO=6; errorcode lookups 3/4/6/10/14; contains 5/13/22; positivity EBADF/ENOMEM/EINVAL."
    - "This spec adds: class name checks for EAGAIN and EWOULDBLOCK (not in any prior spec); EAGAIN == EWOULDBLOCK identity (both == 35 on macOS); class name checks for EADDRINUSE and ECONNRESET (not in any prior spec); errorcode reverse-lookup for key 35 (EAGAIN); contains check for key 35; positivity for EAGAIN."
    - "errno.EAGAIN == 35 on macOS/Darwin (resource temporarily unavailable / try again)."
    - "errno.EWOULDBLOCK == 35 on macOS/Darwin — same value as EAGAIN; the two are aliases."
    - "errno.EAGAIN == errno.EWOULDBLOCK — both map to the same integer 35 on POSIX systems that alias them."
    - "errno.errorcode[35] == 'EAGAIN' on macOS (EAGAIN wins the reverse-lookup slot when both share a value)."
    - "errno.EADDRINUSE == 48 on macOS/Darwin (address already in use)."
    - "errno.ECONNRESET == 54 on macOS/Darwin (connection reset by peer)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — EAGAIN and EWOULDBLOCK
#
# All prior errno specs cover class names through errno_extra4 (ENOSPC/EPIPE/
# ERANGE/EMFILE/ENFILE). EAGAIN and EWOULDBLOCK have not appeared in any
# class-name table in any prior spec.
# ---------------------------------------------------------------------------

table errno_extra6.constant_class_names:
  description: "EAGAIN and EWOULDBLOCK are plain int objects — __class__.__name__ == 'int'"
  kind: python_call_eq
  category: constant_types
  id_prefix: cls

  columns: [id, function, args, expected]
  rows:
    - [EAGAIN,      EAGAIN.__class__.__name__.__eq__,      ["int"], true]
    - [EWOULDBLOCK, EWOULDBLOCK.__class__.__name__.__eq__, ["int"], true]
    - [EADDRINUSE,  EADDRINUSE.__class__.__name__.__eq__,  ["int"], true]
    - [ECONNRESET,  ECONNRESET.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# EAGAIN == EWOULDBLOCK — aliased constants share the same integer value
#
# On macOS/Darwin, EAGAIN and EWOULDBLOCK are both 35. No prior spec asserts
# this equality directly.
# ---------------------------------------------------------------------------

invariant errno_extra6.EAGAIN.eq_EWOULDBLOCK:
  description: "errno.EAGAIN == errno.EWOULDBLOCK — both equal 35 on macOS (aliased constants)"
  category: constants
  kind: python_call_eq
  function: EAGAIN.__eq__
  args: [35]
  expected: true

invariant errno_extra6.EWOULDBLOCK.value:
  description: "errno.EWOULDBLOCK == 35 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: EWOULDBLOCK.__eq__
  args: [35]
  expected: true

# ---------------------------------------------------------------------------
# errorcode — reverse-lookup and contains for key 35 (EAGAIN)
#
# All prior specs cover keys 1-14, 22, 28, 32. Key 35 (EAGAIN/EWOULDBLOCK) has
# never appeared in any reverse-lookup or __contains__ check.
# ---------------------------------------------------------------------------

invariant errno_extra6.errorcode.eagain_lookup:
  description: "errno.errorcode[35] == 'EAGAIN' — reverse-lookup of errno 35 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [35]
  expected: "EAGAIN"

invariant errno_extra6.errorcode.contains_eagain_key:
  description: "35 in errno.errorcode — EAGAIN key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [35]
  expected: true

# ---------------------------------------------------------------------------
# Positivity checks — EAGAIN and EADDRINUSE not yet checked for positivity
# ---------------------------------------------------------------------------

invariant errno_extra6.EAGAIN_positive:
  description: "errno.EAGAIN > 0 — EAGAIN == 35 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EAGAIN.__gt__
  args: [0]
  expected: true

invariant errno_extra6.EADDRINUSE_positive:
  description: "errno.EADDRINUSE > 0 — EADDRINUSE == 48 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EADDRINUSE.__gt__
  args: [0]
  expected: true
