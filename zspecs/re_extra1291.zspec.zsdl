spec: re_extra1291
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 533 _extra1291: checks __init__.__qualname__, __init__.__class__.__name__, and __dict__.__contains__('__init__') for re.error, re.Pattern, re.Match."
    - "In Python 3.13+, re.error is an alias for re.PatternError; re.error.__name__ == 'PatternError'."
    - "re.error.__init__.__qualname__ == 'PatternError.__init__' — the qualname reflects the canonical class name."
    - "re.error.__init__.__class__.__name__ == 'function' — pure-Python __init__."
    - "re.error defines __init__ directly in its __dict__; re.Pattern and re.Match do NOT."
    - "re.Pattern.__init__ and re.Match.__init__ resolve via MRO to object.__init__ (qualname 'object.__init__')."
    - "re.Pattern and re.Match are C-level types; neither defines __new__ or __init__ in their own __dict__."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1291.error_init:
  description: "re.error (PatternError) __init__ qualname, type, and __dict__.__contains__ checks"
  kind: python_call_eq
  category: error_init
  id_prefix: re1291er
  columns: [id, function, args, expected]
  rows:
    - [re1291er001, re.error.__init__.__qualname__.__eq__,       ["PatternError.__init__"], true]
    - [re1291er002, re.error.__init__.__class__.__name__.__eq__, ["function"],               true]
    - [re1291er003, re.error.__dict__.__contains__,             ["__init__"],               true]
    - [re1291er004, re.error.__dict__.__contains__,             ["__new__"],                false]
    - [re1291er005, re.error.__class__.__name__.__eq__,         ["type"],                   true]
    - [re1291er006, re.error.__name__.__eq__,                   ["PatternError"],           true]

table re_extra1291.pattern_init:
  description: "re.Pattern __init__ qualname and __dict__.__contains__ checks"
  kind: python_call_eq
  category: pattern_init
  id_prefix: re1291pt
  columns: [id, function, args, expected]
  rows:
    - [re1291pt001, re.Pattern.__dict__.__contains__,             ["__init__"],         false]
    - [re1291pt002, re.Pattern.__dict__.__contains__,             ["__new__"],          false]
    - [re1291pt003, re.Pattern.__init__.__qualname__.__eq__,      ["object.__init__"],  true]
    - [re1291pt004, re.Pattern.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [re1291pt005, re.Pattern.__class__.__name__.__eq__,         ["type"],             true]
    - [re1291pt006, re.Pattern.__name__.__eq__,                   ["Pattern"],          true]

table re_extra1291.match_init:
  description: "re.Match __init__ qualname and __dict__.__contains__ checks"
  kind: python_call_eq
  category: match_init
  id_prefix: re1291mt
  columns: [id, function, args, expected]
  rows:
    - [re1291mt001, re.Match.__dict__.__contains__,             ["__init__"],         false]
    - [re1291mt002, re.Match.__dict__.__contains__,             ["__new__"],          false]
    - [re1291mt003, re.Match.__init__.__qualname__.__eq__,      ["object.__init__"],  true]
    - [re1291mt004, re.Match.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [re1291mt005, re.Match.__class__.__name__.__eq__,         ["type"],             true]
    - [re1291mt006, re.Match.__name__.__eq__,                   ["Match"],            true]
