spec: p_defer
version: ">=4.0.0"
backend: node(p-defer)
esm: true

docs: https://github.com/sindresorhus/p-defer#readme

provenance:
  derived_from:
    - "p-defer README — https://github.com/sindresorhus/p-defer#readme"
    - "Test vectors verified with p-defer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-defer source"
  notes:
    - "Create a deferred promise — returns {promise, resolve, reject} so the resolver can be exposed externally."
    - "Install: npm install p-defer"
    - "v4 ESM only; default export IS the factory. Mostly an antipattern (raw new Promise is preferred), but useful in tricky control-flow."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "null"
  stickiness: "Each call returns a fresh deferred; promises are independent."
  codes: {}

invariant p_defer.default_export_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant p_defer.default_arity_zero:
  description: "Factory takes no arguments (length 0)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 0

invariant p_defer.returns_promise:
  description: "Returned object's .promise is a Promise"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: []}
    - {get: "promise.constructor.name"}
  expected: "Promise"

invariant p_defer.returns_resolve_fn:
  description: "Returned object's .resolve is a function"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: []}
    - {get: "resolve.constructor.name"}
  expected: "Function"

invariant p_defer.returns_reject_fn:
  description: "Returned object's .reject is a function"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: []}
    - {get: "reject.constructor.name"}
  expected: "Function"

invariant p_defer.has_promise_key:
  description: "Returned object has 'promise' own key"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: []}
    - {method: hasOwnProperty, args: ["promise"]}
  expected: true

invariant p_defer.has_resolve_key:
  description: "Returned object has 'resolve' own key"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: []}
    - {method: hasOwnProperty, args: ["resolve"]}
  expected: true

invariant p_defer.has_reject_key:
  description: "Returned object has 'reject' own key"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: []}
    - {method: hasOwnProperty, args: ["reject"]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:19:15Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
