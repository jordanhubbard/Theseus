spec: io_extra97
version: ">=3.9"
backend: python_module(io)
extends: io_extra96

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra96."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__/__class__.__name__ and membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; __mro__.__len__() for all classes; __name__ and __module__ string equality for all io classes; BytesIO/StringIO __dict__ membership for read/write/readable/writable/seekable/truncate/readline; io_extra93 covered __bases__[0].__name__ for IOBase, RawIOBase, FileIO, BufferedReader; io_extra96 covered __bases__[0].__name__ for BufferedIOBase, TextIOBase, BufferedWriter, BytesIO, StringIO, TextIOWrapper."
    - "This spec covers: io abstract base class __dict__ membership. IOBase, RawIOBase, BufferedIOBase, and TextIOBase are thin Python ABC wrappers over C-level _io types. Their __dict__ only contains: __abstractmethods__, __doc__, __firstlineno__, __module__, __static_attributes__, _abc_impl. Methods like close/readable/seekable/writable/read/write are NOT in these ABCs' __dict__ because they come from the C-level base types (_IOBase, _RawIOBase, _BufferedIOBase, _TextIOBase)."
    - "io.IOBase.__dict__.__contains__('close') == False — close is defined on the C-level _IOBase, not on the Python ABC wrapper."
    - "io.IOBase.__dict__.__contains__('readable') == False — readable is defined on the C-level _IOBase."
    - "io.IOBase.__dict__.__contains__('seekable') == False — seekable is defined on the C-level _IOBase."
    - "io.IOBase.__dict__.__contains__('writable') == False — writable is defined on the C-level _IOBase."
    - "io.IOBase.__dict__.__contains__('__doc__') == True — __doc__ is defined on the Python wrapper IOBase."
    - "io.IOBase.__dict__.__contains__('__abstractmethods__') == True — ABC machinery adds __abstractmethods__ to the Python wrapper."
    - "io.RawIOBase.__dict__.__contains__('read') == False — read is defined on the C-level _RawIOBase, not the Python ABC."
    - "io.RawIOBase.__dict__.__contains__('readall') == False — readall is defined on the C-level _RawIOBase."
    - "io.BufferedIOBase.__dict__.__contains__('read') == False — read is defined on the C-level _BufferedIOBase."
    - "io.BufferedIOBase.__dict__.__contains__('write') == False — write is defined on the C-level _BufferedIOBase."
    - "io.TextIOBase.__dict__.__contains__('read') == False — read is defined on the C-level _TextIOBase."
    - "io.TextIOBase.__dict__.__contains__('write') == False — write is defined on the C-level _TextIOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase __dict__ membership
# IOBase is a Python ABC wrapper over the C-level _IOBase type.
# Its __dict__ only contains ABC infrastructure: __abstractmethods__, __doc__,
# __firstlineno__, __module__, __static_attributes__, _abc_impl.
# Methods like close, readable, seekable, writable come from C-level _IOBase
# and are NOT in IOBase.__dict__.
# ---------------------------------------------------------------------------

table io_extra97.IOBase_dict_membership:
  description: "io.IOBase.__dict__.__contains__ for abstract methods (all False) and ABC fields (True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioabcdictmem97

  columns: [id, function, args, expected]
  rows:
    - [iobase_no_close,    IOBase.__dict__.__contains__, ["close"],              false]
    - [iobase_no_readable, IOBase.__dict__.__contains__, ["readable"],           false]
    - [iobase_no_seekable, IOBase.__dict__.__contains__, ["seekable"],           false]
    - [iobase_no_writable, IOBase.__dict__.__contains__, ["writable"],           false]
    - [iobase_has_doc,     IOBase.__dict__.__contains__, ["__doc__"],            true]
    - [iobase_has_absmeth, IOBase.__dict__.__contains__, ["__abstractmethods__"], true]

# ---------------------------------------------------------------------------
# io.RawIOBase __dict__ membership
# RawIOBase is a Python ABC wrapper over the C-level _RawIOBase type.
# Its __dict__ has the same ABC infrastructure only; read/readall/readinto/write
# are NOT in its __dict__ — they come from the C-level _RawIOBase.
# ---------------------------------------------------------------------------

table io_extra97.RawIOBase_dict_membership:
  description: "io.RawIOBase.__dict__.__contains__ for abstract methods (all False) and ABC fields (True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioabcdictmem97

  columns: [id, function, args, expected]
  rows:
    - [rawio_no_read,      RawIOBase.__dict__.__contains__, ["read"],             false]
    - [rawio_no_readall,   RawIOBase.__dict__.__contains__, ["readall"],          false]
    - [rawio_no_readinto,  RawIOBase.__dict__.__contains__, ["readinto"],         false]
    - [rawio_no_write,     RawIOBase.__dict__.__contains__, ["write"],            false]
    - [rawio_has_doc,      RawIOBase.__dict__.__contains__, ["__doc__"],          true]
    - [rawio_has_absmeth,  RawIOBase.__dict__.__contains__, ["__abstractmethods__"], true]

# ---------------------------------------------------------------------------
# io.BufferedIOBase __dict__ membership
# BufferedIOBase is a Python ABC wrapper over C-level _BufferedIOBase.
# read/write/read1/readinto are all defined on the C-level type, not here.
# ---------------------------------------------------------------------------

table io_extra97.BufferedIOBase_dict_membership:
  description: "io.BufferedIOBase.__dict__.__contains__ for abstract methods (all False) and ABC fields (True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioabcdictmem97

  columns: [id, function, args, expected]
  rows:
    - [bufio_no_read,     BufferedIOBase.__dict__.__contains__, ["read"],             false]
    - [bufio_no_write,    BufferedIOBase.__dict__.__contains__, ["write"],            false]
    - [bufio_no_read1,    BufferedIOBase.__dict__.__contains__, ["read1"],            false]
    - [bufio_no_readinto, BufferedIOBase.__dict__.__contains__, ["readinto"],         false]
    - [bufio_has_doc,     BufferedIOBase.__dict__.__contains__, ["__doc__"],          true]
    - [bufio_has_absmeth, BufferedIOBase.__dict__.__contains__, ["__abstractmethods__"], true]

# ---------------------------------------------------------------------------
# io.TextIOBase __dict__ membership + cross-checks
# TextIOBase is a Python ABC wrapper over C-level _TextIOBase.
# read/write/readline/seek are all in the C-level type, not this wrapper.
# Cross-checks: all four io ABCs share the same __dict__ structure pattern.
# ---------------------------------------------------------------------------

table io_extra97.TextIOBase_dict_membership_cross_checks:
  description: "io.TextIOBase.__dict__.__contains__ for abstract methods (all False); ABC fields (True); cross-checks"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioabcdictmem97

  columns: [id, function, args, expected]
  rows:
    - [textio_no_read,     TextIOBase.__dict__.__contains__, ["read"],             false]
    - [textio_no_write,    TextIOBase.__dict__.__contains__, ["write"],            false]
    - [textio_no_readline, TextIOBase.__dict__.__contains__, ["readline"],         false]
    - [textio_no_seek,     TextIOBase.__dict__.__contains__, ["seek"],             false]
    - [textio_has_doc,     TextIOBase.__dict__.__contains__, ["__doc__"],          true]
    - [textio_has_module,  TextIOBase.__dict__.__contains__, ["__module__"],       true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra97.IOBase.no_close_in_dict:
  description: "io.IOBase.__dict__.__contains__('close') == False (close is defined on C-level _IOBase, not the Python ABC wrapper)"
  category: dict_membership
  kind: python_call_eq
  function: IOBase.__dict__.__contains__
  args: ["close"]
  expected: false

invariant io_extra97.IOBase.no_readable_in_dict:
  description: "io.IOBase.__dict__.__contains__('readable') == False (readable is defined on C-level _IOBase, not the Python ABC wrapper)"
  category: dict_membership
  kind: python_call_eq
  function: IOBase.__dict__.__contains__
  args: ["readable"]
  expected: false

invariant io_extra97.RawIOBase.no_read_in_dict:
  description: "io.RawIOBase.__dict__.__contains__('read') == False (read is defined on C-level _RawIOBase, not the Python ABC wrapper)"
  category: dict_membership
  kind: python_call_eq
  function: RawIOBase.__dict__.__contains__
  args: ["read"]
  expected: false

invariant io_extra97.BufferedIOBase.no_write_in_dict:
  description: "io.BufferedIOBase.__dict__.__contains__('write') == False (write is defined on C-level _BufferedIOBase, not the Python ABC wrapper)"
  category: dict_membership
  kind: python_call_eq
  function: BufferedIOBase.__dict__.__contains__
  args: ["write"]
  expected: false

invariant io_extra97.TextIOBase.no_read_in_dict:
  description: "io.TextIOBase.__dict__.__contains__('read') == False (read is defined on C-level _TextIOBase, not the Python ABC wrapper)"
  category: dict_membership
  kind: python_call_eq
  function: TextIOBase.__dict__.__contains__
  args: ["read"]
  expected: false
