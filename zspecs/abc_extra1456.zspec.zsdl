spec: abc_extra1456
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc: Abstract Base Classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
    - "abc_extra1441.zspec.zsdl — covers __subclasshook__, __instancecheck__, and __subclasscheck__ for abc classes"
  notes:
    - "Wave 544 (_extra1456): focuses on __contains__, __iter__, and __next__ method presence and type checks for abc module classes."
    - "abc.ABCMeta does NOT define __contains__, __iter__, or __next__ in its own __dict__."
    - "abc.ABC does NOT define __contains__, __iter__, or __next__ in its own __dict__."
    - "abc.abstractmethod does NOT define __contains__, __iter__, or __next__ in its own __dict__."
    - "ABCMeta is a metaclass (subclass of type); ABC is a plain class whose metaclass is ABCMeta; abstractmethod is a plain class."
    - "None of these abc constructs are containers or iterators, so absence of __contains__/__iter__/__next__ is expected."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1456.contains_not_in_dict:
  description: "abc.__dict__ membership for __contains__ — ABCMeta, ABC, and abstractmethod do not define __contains__ in their own __dict__; all return False; none of these types are containers; verified with Python 3.14.3"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: ab1456cd
  columns: [id, function, args, expected]
  rows:
    - [ab1456cd001, abc.ABCMeta.__dict__.__contains__,      ["__contains__"], false]
    - [ab1456cd002, abc.ABC.__dict__.__contains__,          ["__contains__"], false]
    - [ab1456cd003, abc.abstractmethod.__dict__.__contains__, ["__contains__"], false]
    - [ab1456cd004, abc.ABCMeta.__dict__.__contains__,      ["__contains__"], false]
    - [ab1456cd005, abc.ABC.__dict__.__contains__,          ["__contains__"], false]
    - [ab1456cd006, abc.abstractmethod.__dict__.__contains__, ["__contains__"], false]

