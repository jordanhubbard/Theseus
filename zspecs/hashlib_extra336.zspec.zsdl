spec: hashlib_extra336
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "RFC 2898 — PKCS #5: Password-Based Cryptography Specification Version 2.0"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec focuses on hashlib.pbkdf2_hmac with non-empty password and salt inputs and the function's own introspective attributes."
    - "hashlib_extra.zspec.zsdl covers pbkdf2_hmac.__name__ and return lengths for empty password/salt; this spec uses b'password'/b'salt' test vectors and adds __module__ and __class__.__name__."
    - "pbkdf2_hmac('sha256', b'password', b'salt', 100000).__len__() == 32 — SHA-256 always produces 32 bytes regardless of iteration count."
    - "pbkdf2_hmac('md5', b'password', b'salt', 1).__len__() == 16 — MD5 produces 16 bytes."
    - "pbkdf2_hmac('sha512', b'password', b'salt', 1).__len__() == 64 — SHA-512 produces 64 bytes."
    - "pbkdf2_hmac.__module__ == '_hashlib' — it is implemented in the C extension _hashlib."
    - "pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — it is a C-level builtin."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "hashlib.pbkdf2_hmac raises ValueError for unknown hash names and iterations < 1."
  stderr: "null"
  stickiness: "N/A — pbkdf2_hmac is a pure function; each call is independent."
  codes: {}

# ---------------------------------------------------------------------------
# pbkdf2_hmac return length — non-empty password and salt inputs
# These complement hashlib_extra.zspec.zsdl which uses empty password/salt.
# ---------------------------------------------------------------------------

invariant hashlib_extra336.pbkdf2_hmac.sha256_100k_len:
  description: "len(pbkdf2_hmac('sha256', b'password', b'salt', 100000)) == 32 — output length equals SHA-256 digest size"
  category: functions
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["sha256", !ascii "password", !ascii "salt", 100000]
  method: __len__
  method_args: []
  expected: 32

invariant hashlib_extra336.pbkdf2_hmac.sha256_1iter_len:
  description: "len(pbkdf2_hmac('sha256', b'password', b'salt', 1)) == 32 — iteration count does not affect output length"
  category: functions
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["sha256", !ascii "password", !ascii "salt", 1]
  method: __len__
  method_args: []
  expected: 32

invariant hashlib_extra336.pbkdf2_hmac.md5_len:
  description: "len(pbkdf2_hmac('md5', b'password', b'salt', 1)) == 16 — output length equals MD5 digest size"
  category: functions
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["md5", !ascii "password", !ascii "salt", 1]
  method: __len__
  method_args: []
  expected: 16

invariant hashlib_extra336.pbkdf2_hmac.sha512_len:
  description: "len(pbkdf2_hmac('sha512', b'password', b'salt', 1)) == 64 — output length equals SHA-512 digest size"
  category: functions
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["sha512", !ascii "password", !ascii "salt", 1]
  method: __len__
  method_args: []
  expected: 64

# ---------------------------------------------------------------------------
# pbkdf2_hmac introspective attributes
# __name__ is covered in hashlib_extra.zspec.zsdl; this spec adds __module__
# and __class__.__name__ which are not yet covered.
# ---------------------------------------------------------------------------

invariant hashlib_extra336.pbkdf2_hmac.name:
  description: "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'"
  category: function_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra336.pbkdf2_hmac.module:
  description: "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — implemented in the C extension"
  category: function_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra336.pbkdf2_hmac.class_name:
  description: "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
