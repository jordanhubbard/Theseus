spec: threading_extra193
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Condition.__name__ == 'Condition' (len=9); Condition is a regular Python class defined in the threading module; verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading' (len=9); Condition is defined in Lib/threading.py; verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object'; Condition inherits directly from object with no intermediary base; verified with Python 3.14.3."
    - "threading.Condition.__init__.__qualname__ == 'Condition.__init__' (len=18); the qualified name encodes the containing class; verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' (len=14); wait blocks until notified or a timeout occurs; verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' (len=16); notify wakes one or more waiting threads; verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20); notify_all wakes all waiting threads; verified with Python 3.14.3."
    - "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18); wait_for blocks until a predicate becomes true; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

