spec: decimal_extra1576
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "Decimal has no __bytes__ method; bytes(Decimal(...)) raises TypeError."
    - "str(Decimal('3.14')) preserves the exact decimal string representation."
    - "repr(Decimal('3.14')) wraps in Decimal('...'): \"Decimal('3.14')\"."
    - "Decimal preserves trailing zeros: str(Decimal('0.00')) == '0.00'."
    - "Decimal supports special values: NaN, Infinity, -Infinity."
    - "format(Decimal('3.14159'), '.2f') rounds to 2 decimal places."
    - "format(Decimal('1234567'), ',') produces thousands-separated output."
    - "str(Decimal('1E+10')) preserves engineering notation."
    - "Decimal('3.14') == Decimal('3.14') is True; equality is value-based."
    - "All expected values verified by running Python 3.12 decimal on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Decimal.__str__ — basic numeric values
# ---------------------------------------------------------------------------

table decimal_extra1576.str_basic:
  kind: python_call_eq
  category: str_repr
  id_prefix: dc1576

  columns: [id, function, args, expected]
  rows:
    - ["dc1576_001", "Decimal.__str__", ["3.14"],     "3.14"]
    - ["dc1576_002", "Decimal.__str__", ["0"],        "0"]
    - ["dc1576_003", "Decimal.__str__", ["0.00"],     "0.00"]
    - ["dc1576_004", "Decimal.__str__", ["-3.14"],    "-3.14"]
    - ["dc1576_005", "Decimal.__str__", ["100"],      "100"]
    - ["dc1576_006", "Decimal.__str__", ["0.001"],    "0.001"]
    - ["dc1576_007", "Decimal.__str__", ["1E+10"],    "1E+10"]
    - ["dc1576_008", "Decimal.__str__", ["1.0E+10"],  "1.0E+10"]

# ---------------------------------------------------------------------------
# Decimal.__str__ — special values
# ---------------------------------------------------------------------------

table decimal_extra1576.str_special:
  kind: python_call_eq
  category: str_repr
  id_prefix: dc1576

  columns: [id, function, args, expected]
  rows:
    - ["dc1576_010", "Decimal.__str__", ["NaN"],       "NaN"]
    - ["dc1576_011", "Decimal.__str__", ["Infinity"],  "Infinity"]
    - ["dc1576_012", "Decimal.__str__", ["-Infinity"], "-Infinity"]
    - ["dc1576_013", "Decimal.__str__", ["-0"],        "-0"]

# ---------------------------------------------------------------------------
# Decimal.__repr__ — wraps in Decimal('...')
# ---------------------------------------------------------------------------

table decimal_extra1576.repr_values:
  kind: python_call_eq
  category: str_repr
  id_prefix: dc1576

  columns: [id, function, args, expected]
  rows:
    - ["dc1576_020", "Decimal.__repr__", ["3.14"],      "Decimal('3.14')"]
    - ["dc1576_021", "Decimal.__repr__", ["NaN"],       "Decimal('NaN')"]
    - ["dc1576_022", "Decimal.__repr__", ["Infinity"],  "Decimal('Infinity')"]
    - ["dc1576_023", "Decimal.__repr__", ["-Infinity"], "Decimal('-Infinity')"]
    - ["dc1576_024", "Decimal.__repr__", ["-0"],        "Decimal('-0')"]
    - ["dc1576_025", "Decimal.__repr__", ["0.00"],      "Decimal('0.00')"]
    - ["dc1576_026", "Decimal.__repr__", ["-3.14"],     "Decimal('-3.14')"]

# ---------------------------------------------------------------------------
# Decimal.__format__ — format specifiers
# ---------------------------------------------------------------------------

table decimal_extra1576.format_values:
  kind: python_call_eq
  category: str_repr
  id_prefix: dc1576

  columns: [id, function, args, expected]
  rows:
    - ["dc1576_030", "Decimal.__format__", ["3.14159",  ".2f"],  "3.14"]
    - ["dc1576_031", "Decimal.__format__", ["3.14159",  ".4f"],  "3.1416"]
    - ["dc1576_032", "Decimal.__format__", ["1234567",  ","],    "1,234,567"]
    - ["dc1576_033", "Decimal.__format__", ["1234.56",  ",.2f"], "1,234.56"]
    - ["dc1576_034", "Decimal.__format__", ["3.14159",  ".0f"],  "3"]
    - ["dc1576_035", "Decimal.__format__", ["100",      "d"],    "100"]

# ---------------------------------------------------------------------------
# Decimal equality — __eq__ returns bool
# ---------------------------------------------------------------------------

table decimal_extra1576.equality:
  kind: python_call_eq
  category: str_repr
  id_prefix: dc1576

  columns: [id, function, args, expected]
  rows:
    - ["dc1576_040", "Decimal.__eq__", ["3.14",  "3.14"],   true]
    - ["dc1576_041", "Decimal.__eq__", ["0",     "0.0"],    false]
    - ["dc1576_042", "Decimal.__eq__", ["1E+2",  "100"],    true]
    - ["dc1576_043", "Decimal.__eq__", ["-3.14", "3.14"],   false]

invariant decimal_extra1576.eq_str_true:
  description: "str(Decimal('3.14') == Decimal('3.14')) == 'True'"
  category: str_repr
  kind: python_call_eq
  function: bool.__str__
  args: [true]
  expected: "True"

invariant decimal_extra1576.eq_str_false:
  description: "str(Decimal('0') == Decimal('0.0')) == 'False' — different precision"
  category: str_repr
  kind: python_call_eq
  function: bool.__str__
  args: [false]
  expected: "False"

# ---------------------------------------------------------------------------
# Decimal class name attributes
# ---------------------------------------------------------------------------

invariant decimal_extra1576.class_name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: class_names
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra1576.class_module:
  description: "decimal.Decimal.__module__ contains 'decimal'"
  category: class_names
  kind: python_call_eq
  function: Decimal.__module__.__contains__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# bytes conversion raises TypeError
# ---------------------------------------------------------------------------

invariant decimal_extra1576.no_bytes_protocol:
  description: "bytes(Decimal('3.14')) raises TypeError — Decimal has no __bytes__"
  category: bytes_repr
  kind: python_call_raises
  function: bytes
  args: ["3.14"]
  raises: TypeError

# ---------------------------------------------------------------------------
# Decimal precision preservation — str() round-trip
# ---------------------------------------------------------------------------

table decimal_extra1576.precision_preservation:
  kind: python_call_eq
  category: str_repr
  id_prefix: dc1576

  columns: [id, function, args, expected]
  rows:
    - ["dc1576_050", "Decimal.__str__", ["1.0"],    "1.0"]
    - ["dc1576_051", "Decimal.__str__", ["1.00"],   "1.00"]
    - ["dc1576_052", "Decimal.__str__", ["1.000"],  "1.000"]
    - ["dc1576_053", "Decimal.__str__", ["0.1"],    "0.1"]
    - ["dc1576_054", "Decimal.__str__", ["0.10"],   "0.10"]
