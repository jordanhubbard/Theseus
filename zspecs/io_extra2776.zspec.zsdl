spec: io_extra2776
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "io_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "io_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "io_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 632 (io_extra2776) theme: __isub__, __imul__, and __itruediv__ dict-presence checks."
    - "None of the io classes define __isub__, __imul__, or __itruediv__ in their own __dict__."
    - "__isub__ supports the -= operator; io stream classes do not implement in-place subtraction semantics."
    - "__imul__ supports the *= operator; io stream classes do not implement in-place multiplication semantics."
    - "__itruediv__ supports the /= operator; io stream classes do not implement in-place true-division semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __isub__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2776.no_isub_in_io_classes:
  description: "__isub__ is absent from all io class __dict__s — io stream classes do not implement the -= in-place subtraction protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2776

  columns: [id, function, args, expected]
  rows:
    - ["io2776001", "io.IOBase.__dict__.__contains__",         ["__isub__"], false]
    - ["io2776002", "io.RawIOBase.__dict__.__contains__",      ["__isub__"], false]
    - ["io2776003", "io.BufferedIOBase.__dict__.__contains__", ["__isub__"], false]
    - ["io2776004", "io.TextIOBase.__dict__.__contains__",     ["__isub__"], false]
    - ["io2776005", "io.BytesIO.__dict__.__contains__",        ["__isub__"], false]
    - ["io2776006", "io.StringIO.__dict__.__contains__",       ["__isub__"], false]

# ---------------------------------------------------------------------------
# __imul__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2776.no_imul_in_io_classes:
  description: "__imul__ is absent from all io class __dict__s — io stream classes do not implement the *= in-place multiplication protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2776

  columns: [id, function, args, expected]
  rows:
    - ["io2776007", "io.IOBase.__dict__.__contains__",          ["__imul__"], false]
    - ["io2776008", "io.FileIO.__dict__.__contains__",          ["__imul__"], false]
    - ["io2776009", "io.BufferedReader.__dict__.__contains__",  ["__imul__"], false]
    - ["io2776010", "io.BufferedWriter.__dict__.__contains__",  ["__imul__"], false]
    - ["io2776011", "io.BufferedRandom.__dict__.__contains__",  ["__imul__"], false]
    - ["io2776012", "io.TextIOWrapper.__dict__.__contains__",   ["__imul__"], false]

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2776.no_itruediv_in_io_classes:
  description: "__itruediv__ is absent from all io class __dict__s — io stream classes do not implement the /= in-place true-division protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2776

  columns: [id, function, args, expected]
  rows:
    - ["io2776013", "io.IOBase.__dict__.__contains__",         ["__itruediv__"], false]
    - ["io2776014", "io.BytesIO.__dict__.__contains__",        ["__itruediv__"], false]
    - ["io2776015", "io.StringIO.__dict__.__contains__",       ["__itruediv__"], false]
    - ["io2776016", "io.FileIO.__dict__.__contains__",         ["__itruediv__"], false]
    - ["io2776017", "io.BufferedReader.__dict__.__contains__", ["__itruediv__"], false]
    - ["io2776018", "io.BufferedWriter.__dict__.__contains__", ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not in-place arithmetic operator hooks
# Confirms that io classes are sequential I/O objects, not numeric types
# ---------------------------------------------------------------------------

table io_extra2776.io_has_stream_methods_not_inplace_arithmetic_operator_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __isub__/__imul__/__itruediv__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2776

  columns: [id, function, args, expected]
  rows:
    - ["io2776019", "io.BytesIO.__dict__.__contains__",  ["read"],         true]
    - ["io2776020", "io.BytesIO.__dict__.__contains__",  ["write"],        true]
    - ["io2776021", "io.BytesIO.__dict__.__contains__",  ["seek"],         true]
    - ["io2776022", "io.BytesIO.__dict__.__contains__",  ["tell"],         true]
    - ["io2776023", "io.BytesIO.__dict__.__contains__",  ["__isub__"],     false]
    - ["io2776024", "io.BytesIO.__dict__.__contains__",  ["__imul__"],     false]
    - ["io2776025", "io.BytesIO.__dict__.__contains__",  ["__itruediv__"], false]
    - ["io2776026", "io.StringIO.__dict__.__contains__", ["read"],         true]
    - ["io2776027", "io.StringIO.__dict__.__contains__", ["write"],        true]
    - ["io2776028", "io.StringIO.__dict__.__contains__", ["seek"],         true]
    - ["io2776029", "io.StringIO.__dict__.__contains__", ["tell"],         true]
    - ["io2776030", "io.StringIO.__dict__.__contains__", ["__isub__"],     false]
    - ["io2776031", "io.StringIO.__dict__.__contains__", ["__imul__"],     false]
    - ["io2776032", "io.StringIO.__dict__.__contains__", ["__itruediv__"], false]
