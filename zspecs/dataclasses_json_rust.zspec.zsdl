spec: dataclasses_json_rust
version: ">=3.9"
backend: rust_module(dataclasses_json_rust)

docs: https://github.com/lidatong/dataclasses-json

provenance:
  derived_from:
    - "https://github.com/lidatong/dataclasses-json — dataclasses-json documentation"
  not_derived_from:
    - "dataclasses-json source: dataclasses_json/__init__.py"
  notes:
    - "dataclasses-json adds JSON serialization to Python dataclasses."
    - "@dataclass_json @dataclass class Point: x: int; y: int."
    - "Point(1, 2).to_json() == '{\"x\": 1, \"y\": 2}'."
    - "Point.from_json('{\"x\": 1, \"y\": 2}') == Point(1, 2)."
    - "Point(3, 4).to_dict() == {'x': 3, 'y': 4}."
    - "Expose dcj_to_dict_x(x, y) -> int: Point(x=x, y=y).to_dict()['x']."
    - "Expose dcj_from_json_y(json_str) -> int: Point.from_json(json_str).y."
    - "All test vectors verified against dataclasses-json 0.6.7."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dcj_to_dict_x — to_dict x field
table dataclasses_json_rust.serialize.to_dict_x:
  kind: python_call_eq
  category: to_dict
  id_prefix: dcj_x
  function: dcj_to_dict_x

  columns: [id, args, expected]
  rows:
    - [one,   [1, 2], 1]
    - [three, [3, 4], 3]

# dcj_from_json_y — from_json y field
table dataclasses_json_rust.deserialize.from_json_y:
  kind: python_call_eq
  category: from_json
  id_prefix: dcj_y
  function: dcj_from_json_y

  columns: [id, args, expected]
  rows:
    - [two,  ["{\"x\": 1, \"y\": 2}"], 2]
    - [four, ["{\"x\": 3, \"y\": 4}"], 4]

