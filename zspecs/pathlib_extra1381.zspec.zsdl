spec: pathlib_extra1381
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks for pathlib module classes."
    - "None of the pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) are abstract in the ABCMeta sense; they do not have '__abstractmethods__' in their own __dict__."
    - "pathlib.PurePath.__dict__.__contains__('__abstractmethods__') == False; same for Path, PurePosixPath, PureWindowsPath, and PosixPath; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "This contrasts with io abstract base classes (IOBase, RawIOBase, etc.) which DO have '__abstractmethods__' in their __dict__."
    - "The absence of '__abstractmethods__' in a class's own __dict__ means the class does not directly register itself as abstract via the ABCMeta frozenset mechanism."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1381.purepath_classes_no_abstractmethods:
  description: "pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath __dict__ lacks __abstractmethods__ — wave 539 theme: the three pure-path classes are not abstract in the ABCMeta sense; none have '__abstractmethods__' in their own __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: pl1381pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1381pp001, pathlib.PurePath.__dict__.__contains__,           ["__abstractmethods__"], false, "pathlib.PurePath.__dict__.__contains__('__abstractmethods__') == False (PurePath is not abstract via ABCMeta); verified with Python 3.12"]
    - [pl1381pp002, pathlib.PurePosixPath.__dict__.__contains__,      ["__abstractmethods__"], false, "pathlib.PurePosixPath.__dict__.__contains__('__abstractmethods__') == False (PurePosixPath is not abstract via ABCMeta); verified with Python 3.12"]
    - [pl1381pp003, pathlib.PureWindowsPath.__dict__.__contains__,    ["__abstractmethods__"], false, "pathlib.PureWindowsPath.__dict__.__contains__('__abstractmethods__') == False (PureWindowsPath is not abstract via ABCMeta); verified with Python 3.12"]
    - [pl1381pp004, pathlib.PurePath.__dict__.__contains__,           ["__abstractmethods__"], false, "pathlib.PurePath.__dict__.__contains__('__abstractmethods__') == False (cross-check anchor: PurePath, the base of all path classes, is not abstract); verified with Python 3.12"]
    - [pl1381pp005, pathlib.PurePosixPath.__dict__.__contains__,      ["__abstractmethods__"], false, "pathlib.PurePosixPath.__dict__.__contains__('__abstractmethods__') == False (cross-check: PurePosixPath, a concrete POSIX path class, is not abstract); verified with Python 3.12"]
    - [pl1381pp006, pathlib.PureWindowsPath.__dict__.__contains__,    ["__abstractmethods__"], false, "pathlib.PureWindowsPath.__dict__.__contains__('__abstractmethods__') == False (cross-check: PureWindowsPath, a concrete Windows path class, is not abstract); verified with Python 3.12"]
    - [pl1381pp007, pathlib.PurePath.__dict__.__contains__,           ["__doc__"],              true,  "pathlib.PurePath.__dict__.__contains__('__doc__') == True (sanity check: PurePath does have __doc__ in own __dict__); verified with Python 3.12"]
    - [pl1381pp008, pathlib.PurePosixPath.__dict__.__contains__,      ["__doc__"],              true,  "pathlib.PurePosixPath.__dict__.__contains__('__doc__') == True (sanity check: PurePosixPath does have __doc__ in own __dict__); verified with Python 3.12"]

table pathlib_extra1381.path_posixpath_no_abstractmethods:
  description: "pathlib.Path and pathlib.PosixPath __dict__ lacks __abstractmethods__ — wave 539 theme: the concrete Path and PosixPath classes are not abstract in the ABCMeta sense; neither has '__abstractmethods__' in its own __dict__; consistent with PurePath family; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: pl1381ph
  columns: [id, function, args, expected, description]
  rows:
    - [pl1381ph001, pathlib.Path.__dict__.__contains__,       ["__abstractmethods__"], false, "pathlib.Path.__dict__.__contains__('__abstractmethods__') == False (Path is a concrete class, not abstract); verified with Python 3.12"]
    - [pl1381ph002, pathlib.PosixPath.__dict__.__contains__,  ["__abstractmethods__"], false, "pathlib.PosixPath.__dict__.__contains__('__abstractmethods__') == False (PosixPath is a concrete class, not abstract); verified with Python 3.12"]
    - [pl1381ph003, pathlib.Path.__dict__.__contains__,       ["__abstractmethods__"], false, "pathlib.Path.__dict__.__contains__('__abstractmethods__') == False (cross-check: Path is the main concrete path class, absent abstractmethods); verified with Python 3.12"]
    - [pl1381ph004, pathlib.PosixPath.__dict__.__contains__,  ["__abstractmethods__"], false, "pathlib.PosixPath.__dict__.__contains__('__abstractmethods__') == False (cross-check: PosixPath is the POSIX-specific concrete path class, absent abstractmethods); verified with Python 3.12"]
    - [pl1381ph005, pathlib.Path.__dict__.__contains__,       ["__doc__"],              true,  "pathlib.Path.__dict__.__contains__('__doc__') == True (sanity check: Path does have __doc__ in own __dict__); verified with Python 3.12"]
    - [pl1381ph006, pathlib.PosixPath.__dict__.__contains__,  ["__doc__"],              true,  "pathlib.PosixPath.__dict__.__contains__('__doc__') == True (sanity check: PosixPath does have __doc__ in own __dict__); verified with Python 3.12"]
    - [pl1381ph007, pathlib.Path.__dict__.__contains__,       ["__abstractmethods__"], false, "pathlib.Path.__dict__.__contains__('__abstractmethods__') == False (final cross-check: all pathlib path classes are non-abstract); verified with Python 3.12"]

table pathlib_extra1381.all_path_classes_abstractmethods_absent:
  description: "All pathlib path classes __dict__ cross-check for absent __abstractmethods__ — wave 539 theme: confirms that all five pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) uniformly lack '__abstractmethods__' in their own __dict__; this distinguishes pathlib from io module abstract base classes; verified with Python 3.12"
