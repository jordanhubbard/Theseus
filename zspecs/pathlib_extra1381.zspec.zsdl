  id_prefix: pl1381ca
  columns: [id, function, args, expected, description]
  rows:
    - [pl1381ca001, pathlib.PurePath.__dict__.__contains__,        ["__abstractmethods__"], false, "pathlib.PurePath.__dict__.__contains__('__abstractmethods__') == False (all five pathlib classes absent check 1/5); verified with Python 3.12"]
    - [pl1381ca002, pathlib.PurePosixPath.__dict__.__contains__,   ["__abstractmethods__"], false, "pathlib.PurePosixPath.__dict__.__contains__('__abstractmethods__') == False (all five pathlib classes absent check 2/5); verified with Python 3.12"]
    - [pl1381ca003, pathlib.PureWindowsPath.__dict__.__contains__,  ["__abstractmethods__"], false, "pathlib.PureWindowsPath.__dict__.__contains__('__abstractmethods__') == False (all five pathlib classes absent check 3/5); verified with Python 3.12"]
    - [pl1381ca004, pathlib.Path.__dict__.__contains__,            ["__abstractmethods__"], false, "pathlib.Path.__dict__.__contains__('__abstractmethods__') == False (all five pathlib classes absent check 4/5); verified with Python 3.12"]
    - [pl1381ca005, pathlib.PosixPath.__dict__.__contains__,       ["__abstractmethods__"], false, "pathlib.PosixPath.__dict__.__contains__('__abstractmethods__') == False (all five pathlib classes absent check 5/5); verified with Python 3.12"]
    - [pl1381ca006, pathlib.PurePath.__dict__.__contains__,        ["__abstractmethods__"], false, "pathlib.PurePath.__dict__.__contains__('__abstractmethods__') == False (final cross-check: pathlib has no abstract path classes in the ABCMeta sense); verified with Python 3.12"]
    - [pl1381ca007, pathlib.Path.__dict__.__contains__,            ["__abstractmethods__"], false, "pathlib.Path.__dict__.__contains__('__abstractmethods__') == False (final cross-check: concrete path class absent); verified with Python 3.12"]
    - [pl1381ca008, pathlib.PosixPath.__dict__.__contains__,       ["__abstractmethods__"], false, "pathlib.PosixPath.__dict__.__contains__('__abstractmethods__') == False (final cross-check: POSIX-specific path class absent); verified with Python 3.12"]
