spec: autopep8_rust
version: ">=3.9"
backend: rust_module(autopep8_rust)

docs: https://github.com/hhatto/autopep8

provenance:
  derived_from:
    - "https://github.com/hhatto/autopep8 — autopep8 documentation"
  not_derived_from:
    - "autopep8 source: autopep8.py"
  notes:
    - "autopep8 automatically formats Python code to conform to PEP 8."
    - "autopep8.fix_code('x=1') == 'x = 1'."
    - "autopep8.fix_code('y=1+2') == 'y = 1+2'."
    - "autopep8.__version__ is a non-empty string."
    - "Expose autopep8_fix(code) -> str: autopep8.fix_code(code)."
    - "Expose autopep8_version_nonempty() -> bool: len(autopep8.__version__) > 0."
    - "All test vectors verified against autopep8 2.3.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# autopep8_fix — fix PEP 8 violations
table autopep8_rust.fix.code:
  kind: python_call_eq
  category: fix
  id_prefix: ap8_f
  function: autopep8_fix

  columns: [id, args, expected]
  rows:
    - [assign, ["x=1"], "x = 1"]
    - [noop,   ["x = 1"], "x = 1"]

# autopep8_version_nonempty — version non-empty
invariant autopep8_rust.version.nonempty:
  description: "autopep8.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: autopep8_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:06:14Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
