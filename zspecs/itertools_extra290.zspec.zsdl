spec: itertools_extra290
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools class base class identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools classes directly extend object at the C level"
    - "pairwise added in Python 3.10, batched added in Python 3.12"
    - "__bases__[0] subscript requires double-quoting the function field in table rows"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra290.bases_group1:
  description: "__bases__[0].__name__ for chain, count, cycle, repeat, product, combinations, permutations, accumulate, islice, starmap (all 'object')"
  kind: python_call_eq
  category: identity
  id_prefix: itex290a

  columns: [id, function, args, expected, description]
  rows:
    - [itex290a01, "itertools.chain.__bases__[0].__name__.__eq__", ["object"], true, "chain base class is object"]
    - [itex290a02, "itertools.count.__bases__[0].__name__.__eq__", ["object"], true, "count base class is object"]
    - [itex290a03, "itertools.cycle.__bases__[0].__name__.__eq__", ["object"], true, "cycle base class is object"]
    - [itex290a04, "itertools.repeat.__bases__[0].__name__.__eq__", ["object"], true, "repeat base class is object"]
    - [itex290a05, "itertools.product.__bases__[0].__name__.__eq__", ["object"], true, "product base class is object"]
    - [itex290a06, "itertools.combinations.__bases__[0].__name__.__eq__", ["object"], true, "combinations base class is object"]
    - [itex290a07, "itertools.permutations.__bases__[0].__name__.__eq__", ["object"], true, "permutations base class is object"]
    - [itex290a08, "itertools.accumulate.__bases__[0].__name__.__eq__", ["object"], true, "accumulate base class is object"]
    - [itex290a09, "itertools.islice.__bases__[0].__name__.__eq__", ["object"], true, "islice base class is object"]
    - [itex290a10, "itertools.starmap.__bases__[0].__name__.__eq__", ["object"], true, "starmap base class is object"]

table itertools_extra290.bases_group2:
  description: "__bases__[0].__name__ for filterfalse, dropwhile, takewhile, groupby, zip_longest, compress, combinations_with_replacement (all 'object')"
  kind: python_call_eq
  category: identity
  id_prefix: itex290b

  columns: [id, function, args, expected, description]
  rows:
    - [itex290b01, "itertools.filterfalse.__bases__[0].__name__.__eq__", ["object"], true, "filterfalse base class is object"]
    - [itex290b02, "itertools.dropwhile.__bases__[0].__name__.__eq__", ["object"], true, "dropwhile base class is object"]
    - [itex290b03, "itertools.takewhile.__bases__[0].__name__.__eq__", ["object"], true, "takewhile base class is object"]
    - [itex290b04, "itertools.groupby.__bases__[0].__name__.__eq__", ["object"], true, "groupby base class is object"]
    - [itex290b05, "itertools.zip_longest.__bases__[0].__name__.__eq__", ["object"], true, "zip_longest base class is object"]
    - [itex290b06, "itertools.compress.__bases__[0].__name__.__eq__", ["object"], true, "compress base class is object"]
    - [itex290b07, "itertools.combinations_with_replacement.__bases__[0].__name__.__eq__", ["object"], true, "combinations_with_replacement base class is object"]

invariant itertools_extra290.inv_pairwise_base:
  description: "pairwise base class is object (Python 3.10+)"
  category: identity
  kind: python_call_eq
  function: "itertools.pairwise.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra290.inv_batched_base:
  description: "batched base class is object (Python 3.12+)"
  category: identity
  kind: python_call_eq
  function: "itertools.batched.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
