spec: mp3541
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 683 (mp3541): __format__, __sizeof__, __dir__ dict-presence checks for multiprocessing types."
    - "All values false — multiprocessing types do not define __format__, __sizeof__, or __dir__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __format__ dict-presence — operator.contains(Cls.__dict__, '__format__')
# ---------------------------------------------------------------------------

table mp3541.format:
  description: "multiprocessing types __format__ dict-presence checks; wave 683"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3541
  columns: [id, function, args, expected]
  rows:
    - ["mp3541001", operator.contains, [multiprocessing.Process.__dict__,                 "__format__"], false]
    - ["mp3541002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__format__"], false]
    - ["mp3541003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__format__"], false]
    - ["mp3541004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__format__"], false]
    - ["mp3541005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__format__"], false]

