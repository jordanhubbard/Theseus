spec: re_extra89
version: ">=3.9"
backend: python_module(re)
extends: re_extra88

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra88."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern/Match method __doc__.__class__.__name__; re module function __code__ attributes; Pattern/Match identity; Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError attributes; re flag constants; re.RegexFlag hierarchy; re.NOFLAG value; Pattern/Match method __doc__.__len__(); re.Pattern/__dict__.__contains__ for match/search/findall/finditer/sub/subn/split/fullmatch/flags/pattern; re.Match/__dict__.__contains__ for group/groups/start/end."
    - "This spec covers: re module-level function __qualname__ string equality for compile, match, search, fullmatch, findall, finditer, sub, subn, split, escape, purge."
    - "re.compile.__qualname__ == 'compile' — top-level module function."
    - "re.match.__qualname__ == 'match' — top-level module function."
    - "re.search.__qualname__ == 'search' — top-level module function."
    - "re.fullmatch.__qualname__ == 'fullmatch' — top-level module function."
    - "re.findall.__qualname__ == 'findall' — top-level module function."
    - "re.finditer.__qualname__ == 'finditer' — top-level module function."
    - "re.sub.__qualname__ == 'sub' — top-level module function."
    - "re.subn.__qualname__ == 'subn' — top-level module function."
    - "re.split.__qualname__ == 'split' — top-level module function."
    - "re.escape.__qualname__ == 'escape' — top-level module function."
    - "re.purge.__qualname__ == 'purge' — top-level module function."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.match/search/fullmatch __qualname__ string equality
# These are top-level module functions; __qualname__ equals the bare function name.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra89.match_search_fullmatch_qualnames:
  description: "re.match/search/fullmatch __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: requalstr89

  columns: [id, function, args, expected]
  rows:
    - [match_qualname,     match.__qualname__.__eq__,     ["match"],     true]
    - [search_qualname,    search.__qualname__.__eq__,    ["search"],    true]
    - [fullmatch_qualname, fullmatch.__qualname__.__eq__, ["fullmatch"], true]

# ---------------------------------------------------------------------------
# re.findall/finditer/split __qualname__ string equality
# Top-level module functions; __qualname__ equals the bare function name.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra89.findall_finditer_split_qualnames:
  description: "re.findall/finditer/split __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: requalstr89

  columns: [id, function, args, expected]
  rows:
    - [findall_qualname,  findall.__qualname__.__eq__,  ["findall"],  true]
    - [finditer_qualname, finditer.__qualname__.__eq__, ["finditer"], true]
    - [split_qualname,    split.__qualname__.__eq__,    ["split"],    true]

# ---------------------------------------------------------------------------
# re.sub/subn/escape/purge __qualname__ string equality
# Top-level module functions; __qualname__ equals the bare function name.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra89.sub_subn_escape_purge_qualnames:
  description: "re.sub/subn/escape/purge __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: requalstr89

  columns: [id, function, args, expected]
  rows:
    - [sub_qualname,    sub.__qualname__.__eq__,    ["sub"],    true]
    - [subn_qualname,   subn.__qualname__.__eq__,   ["subn"],   true]
    - [escape_qualname, escape.__qualname__.__eq__, ["escape"], true]
    - [purge_qualname,  purge.__qualname__.__eq__,  ["purge"],  true]

# ---------------------------------------------------------------------------
# re function __qualname__ cross-check: compile and match equality to each other
# Both are top-level functions; compile.__qualname__ != match.__qualname__ (different names).
# Confirm compile.__qualname__.__eq__('compile') and match.__qualname__.__eq__('match').
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra89.compile_qualname_and_crosscheck:
  description: "re.compile __qualname__ equality; cross-check compile != match qualname"
  kind: python_call_eq
  category: qualname
  id_prefix: requalstr89

  columns: [id, function, args, expected]
  rows:
    - [compile_qualname,       compile.__qualname__.__eq__,      ["compile"], true]
    - [compile_not_match,      compile.__qualname__.__eq__,      ["match"],   false]
    - [match_not_compile,      match.__qualname__.__eq__,        ["compile"], false]
    - [escape_not_purge,       escape.__qualname__.__eq__,       ["purge"],   false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra89.compile.qualname:
  description: "re.compile.__qualname__ == 'compile' (top-level module function; qualname is bare name)"
  category: qualname
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra89.match.qualname:
  description: "re.match.__qualname__ == 'match' (top-level module function; qualname is bare name)"
  category: qualname
  kind: python_call_eq
  function: match.__qualname__.__eq__
  args: ["match"]
  expected: true

invariant re_extra89.sub.qualname:
  description: "re.sub.__qualname__ == 'sub' (top-level module function; qualname is bare name)"
  category: qualname
  kind: python_call_eq
  function: sub.__qualname__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra89.escape.qualname:
  description: "re.escape.__qualname__ == 'escape' (top-level module function; qualname is bare name)"
  category: qualname
  kind: python_call_eq
  function: escape.__qualname__.__eq__
  args: ["escape"]
  expected: true

invariant re_extra89.split.qualname:
  description: "re.split.__qualname__ == 'split' (top-level module function; qualname is bare name)"
  category: qualname
  kind: python_call_eq
  function: split.__qualname__.__eq__
  args: ["split"]
  expected: true
