spec: struct_extra148
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra147.zspec.zsdl — covers struct.calcsize('B'/'H'/'I'/'Q'/'f'/'d'/'?') / calcsize('BB'/'HH'/'II'/'QQ') (table + invariants)."
    - "struct_extra146.zspec.zsdl — covers _struct.__dict__.__len__()==15 / _struct.__dict__.__class__.__name__.__eq__('dict') / _struct.__dict__.__contains__('Struct'/'pack'/'error'/'calcsize'/'unpack'/'pack_into'/'iter_unpack'/'_clearcache') / struct.__dict__.__len__()==18 (table + invariants)."
    - "struct_extra145.zspec.zsdl — covers struct.__dict__.__len__()==18 / struct.Struct.__dict__.__len__()==16 / struct.error.__dict__.__len__()==3 / struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') (table + invariants)."
    - "struct_extra143.zspec.zsdl — covers struct.Struct.__dict__.__contains__('pack'/'unpack'/'pack_into'/'format'/'size') / Struct.__dict__.__len__()==16 / struct.pack.__module__.__eq__('_struct') (table + invariants)."
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') / Struct.__bases__[0].__name__.__eq__('object') / Struct.__mro__.__len__()==2 (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra147."
    - "Wave 334 theme: struct.Struct class identity and method qualnames — Struct.__name__.__eq__('Struct') (6 chars) / Struct.__module__.__eq__('_struct') (7 chars) / Struct.__bases__[0].__name__.__eq__('object') / Struct.pack.__qualname__.__eq__('Struct.pack') / Struct.unpack.__qualname__.__eq__('Struct.unpack') / struct.error.__name__.__eq__('error') / struct.error.__module__.__eq__('struct') / struct.error.__bases__[0].__name__.__eq__('Exception')."
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__module__ == '_struct' (7 chars). The Struct class is implemented in the _struct C extension, so its __module__ is '_struct' not 'struct'. This is anchored by extra141 (Struct.__module__.__eq__('_struct')); this spec anchors the __name__ and __bases__ identity separately and the method qualnames."
    - "Note: struct.Struct.pack.__qualname__ == 'Struct.pack'. Despite Struct being a C extension type, its method_descriptor objects carry the 'Struct.' (7 chars) prefix in their __qualname__. Struct.calcsize does NOT exist as an attribute on the Struct class — calcsize is a module-level function, not an instance method. So Struct.pack and Struct.unpack are valid but Struct.calcsize would raise AttributeError."
    - "Note: struct.error.__name__ == 'error' (5 chars, lowercase). Unlike most exception classes (which use CapWords like 'Exception', 'OSError', 'ValueError'), struct.error uses a lowercase name. This is a historical convention. struct.error.__module__ == 'struct' (not '_struct'), because struct.error is defined in the _struct C extension but its __module__ attribute reports 'struct' (6 chars, without underscore prefix). struct.error.__bases__[0] is Exception (not OSError)."
    - "Note: struct.Struct.__name__ == 'Struct' (6 chars). struct.Struct.__module__ == '_struct' (7 chars with underscore). The Struct class inherits directly from object (__bases__[0].__name__ == 'object'), confirmed by Struct.__mro__.__len__()==2 (extra141). The Struct class is the main interface for efficient repeated packing/unpacking with the same format string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct')
# struct.Struct.__module__.__eq__('_struct')
# struct.Struct.__bases__[0].__name__.__eq__('object')
#
# Wave 334 theme: Struct class identity — name, module, and base class.
#
# Struct.__name__ == 'Struct' (6 chars). Struct.__module__ == '_struct' (7 chars,
# C extension). Struct.__bases__[0].__name__ == 'object' (single inheritance from object).
# extra141 anchors all three as standalones; no prior struct spec anchors them together
# as a table under structid148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra148.Struct_class_identity:
  description: "struct.Struct.__name__.__eq__('Struct')==True / Struct.__module__.__eq__('_struct')==True / Struct.__bases__[0].__name__.__eq__('object')==True / Struct.__name__.__len__()==6 — Struct class name is 'Struct' (6 chars); comes from '_struct' C extension (7 chars, underscore prefix); inherits directly from 'object' (MRO length 2, extra141); extra141 anchors all three; first structid148 anchor for these three as a combined table"
  kind: python_call_eq
  category: identity
  id_prefix: structid148

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_name_Struct,        "Struct.__name__.__eq__",                 ["Struct"],   true, "struct.Struct.__name__ == 'Struct' (6 chars; CapWords class name; C extension type from _struct)"]
    - [Struct_module_struct,      "Struct.__module__.__eq__",               ["_struct"],  true, "struct.Struct.__module__ == '_struct' (7 chars; C extension module; underscore prefix distinguishes from public struct)"]
    - [Struct_bases_object,       "Struct.__bases__[0].__name__.__eq__",    ["object"],   true, "struct.Struct.__bases__[0].__name__ == 'object' (Struct inherits directly from object; MRO length 2)"]
    - [Struct_name_len_6,         "Struct.__name__.__len__",                [],           6,    "struct.Struct.__name__.__len__() is 6 ('Struct' = 6 chars; same length as 'socket' and 'object')"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack')
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack')
#
# Wave 334 theme: Struct method qualnames use 'Struct.' prefix.
#
# Despite Struct being a C extension type, its method descriptors carry the 'Struct.'
# (7-char) prefix in their __qualname__. 'Struct.pack' is 11 chars; 'Struct.unpack'
# is 13 chars. No prior struct spec anchors Struct.pack or Struct.unpack __qualname__
# as a table under structid148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra148.Struct_method_qualnames:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack')==True / Struct.unpack.__qualname__.__eq__('Struct.unpack')==True / Struct.pack.__qualname__.__len__()==11 / Struct.unpack.__qualname__.__len__()==13 — C extension method descriptors carry 'Struct.' prefix (7 chars); 'Struct.pack'=11 chars ('Struct.'=7+'pack'=4); 'Struct.unpack'=13 chars ('Struct.'=7+'unpack'=6); no prior struct spec anchors Struct method qualnames as a table; first structid148 anchor"
  kind: python_call_eq
  category: identity
  id_prefix: structid148

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_pack_qualname,       "Struct.pack.__qualname__.__eq__",    ["Struct.pack"],   true, "struct.Struct.pack.__qualname__ == 'Struct.pack' (11 chars; 'Struct.'=7 + 'pack'=4; C extension method_descriptor)"]
    - [Struct_unpack_qualname,     "Struct.unpack.__qualname__.__eq__",  ["Struct.unpack"], true, "struct.Struct.unpack.__qualname__ == 'Struct.unpack' (13 chars; 'Struct.'=7 + 'unpack'=6; C extension method_descriptor)"]
    - [Struct_pack_qualname_len,   "Struct.pack.__qualname__.__len__",   [],                11,   "struct.Struct.pack.__qualname__.__len__() is 11 ('Struct.pack' = 7+4 = 11 chars)"]
    - [Struct_unpack_qualname_len, "Struct.unpack.__qualname__.__len__", [],                13,   "struct.Struct.unpack.__qualname__.__len__() is 13 ('Struct.unpack' = 7+6 = 13 chars)"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__bases__[0].__name__.__eq__('Exception')
#
# Wave 334 theme: struct.error exception class identity.
#
# struct.error.__name__ == 'error' (lowercase, 5 chars). struct.error.__module__ ==
# 'struct' (not '_struct', 6 chars). struct.error.__bases__[0].__name__ == 'Exception'.
# extra141 anchors error.__qualname__.__eq__('error'); no prior struct spec anchors
# error.__name__/__module__/__bases__ as a combined table under structid148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra148.struct_error_identity:
  description: "struct.error.__name__.__eq__('error')==True / struct.error.__module__.__eq__('struct')==True / struct.error.__bases__[0].__name__.__eq__('Exception')==True / struct.error.__name__.__len__()==5 — 'error' (5 chars, lowercase; historical non-CapWords naming); __module__ is 'struct' (6 chars, no underscore) not '_struct' (7 chars); inherits from 'Exception' not 'OSError' (contrast with socket.error which is OSError); first structid148 anchor for error.__name__/__module__/__bases__ as combined table"
  kind: python_call_eq
  category: identity
  id_prefix: structid148

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_error,        "error.__name__.__eq__",              ["error"],     true, "struct.error.__name__ == 'error' (5 chars; lowercase; historical naming unlike CapWords 'Exception'/'OSError')"]
    - [error_module_struct,     "error.__module__.__eq__",            ["struct"],    true, "struct.error.__module__ == 'struct' (6 chars; no underscore prefix; reports public module, not '_struct' C extension)"]
    - [error_bases_Exception,   "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception' (inherits from Exception, not OSError; pure struct-specific error)"]
    - [error_name_len_5,        "error.__name__.__len__",             [],            5,    "struct.error.__name__.__len__() is 5 ('error' = 5 chars; lowercase 5-char exception name)"]

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct') — standalone
#
# struct.Struct.__name__ is 'Struct' (6 chars). The Struct class name uses CapWords
# convention, unlike struct.error which uses lowercase. 'Struct' (6 chars) is the same
# length as 'socket' (6 chars) and 'object' (6 chars). The __name__ attribute of a type
# contains just the class name without any module prefix — it is the unqualified name.
# struct.Struct.__qualname__ is also 'Struct' (confirmed by extra141 anchoring
# Struct.__qualname__.__eq__('Struct')). This spec anchors __name__ specifically.
# No prior struct spec anchors Struct.__name__.__eq__('Struct') as a standalone under
# structid148. First standalone under structid148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra148.Struct_name_eq_Struct:
  description: "struct.Struct.__name__.__eq__('Struct') == True — 'Struct' (6 chars); CapWords naming; same length as 'socket' and 'object'; __name__ is unqualified class name (no module prefix); extra141 anchors Struct.__qualname__.__eq__('Struct'); this spec anchors __name__ specifically; no prior struct spec anchors this as a standalone; first standalone under structid148"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack' (11 chars). Despite Struct being a
# C extension type (_struct.Struct), its method_descriptor objects for pack and unpack
# carry proper 'Struct.pack' and 'Struct.unpack' qualnames. The 'Struct.' prefix (7 chars)
# in the qualname reflects the class ownership. Note: struct.Struct does NOT have a
# 'calcsize' instance method — calcsize is only a module-level function (struct.calcsize).
# So Struct.pack (11 chars) is the primary method to anchor for qualname. No prior struct
# spec anchors Struct.pack.__qualname__ as a standalone under structid148.
# First standalone under structid148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra148.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — 11 chars; 'Struct.'=7 + 'pack'=4; C extension method_descriptor carries proper qualname; struct.Struct.calcsize does NOT exist (calcsize is module-level only); extra143 anchors Struct.__dict__.__contains__('pack'); no prior struct spec anchors Struct.pack qualname as a standalone; first standalone under structid148"
  category: identity
  kind: python_call_eq
  function: Struct.pack.__qualname__.__eq__
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct' (6 chars, no underscore). Although struct.error
# is implemented in the _struct C extension, its __module__ attribute reports 'struct'
# — the public module name. This is because C extension types can specify their
# tp_name as 'struct.error', which causes Python to set __module__ to 'struct' and
# __qualname__ to 'error'. This is distinct from struct.Struct.__module__ which is
# '_struct' (7 chars with underscore). The difference: Struct.__module__='_struct'
# (the C extension), error.__module__='struct' (the public wrapper). No prior struct
# spec anchors error.__module__.__eq__('struct') as a standalone under structid148.
# First standalone under structid148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra148.struct_error_module_eq_struct:
  description: "struct.error.__module__.__eq__('struct') == True — 6 chars (no underscore); error.__module__ is 'struct' not '_struct' (7 chars); C extension types can report public module via tp_name; contrast with Struct.__module__='_struct' (the C extension); extra97 anchors error.__module__.__len__()==6; no prior struct spec anchors this as a standalone; first standalone under structid148"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception'. struct.error inherits directly
# from Exception (the built-in base class for all non-system-exiting exceptions), not
# from a more specific exception class like OSError or ValueError. This means struct.error
# is a pure struct-specific exception with no overlapping semantics with I/O, OS, or
# value errors. This is in contrast to socket.error, which is an alias for OSError.
# struct.error signals malformed format strings, incorrect buffer sizes, or data that
# cannot be packed into the specified format. No prior struct spec anchors
# error.__bases__[0].__name__.__eq__('Exception') as a standalone under structid148.
# First standalone under structid148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra148.struct_error_bases_Exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — inherits from 'Exception' directly (not OSError/ValueError); pure struct-specific exception for bad format strings, buffer mismatches, or unpackable data; contrast with socket.error which aliases OSError; extra145 anchors struct.error.__dict__.__class__.__name__=='mappingproxy'; no prior struct spec anchors this as a standalone; first standalone under structid148"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
