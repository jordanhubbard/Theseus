spec: swap_array
version: ">=1.0.0"
backend: node(swap-array)

docs: https://www.npmjs.com/package/swap-array

provenance:
  derived_from:
    - "swap-array README — https://www.npmjs.com/package/swap-array"
    - "Test vectors verified with swap-array via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "swap-array source"
  notes:
    - "swap-array is an npm package. Install: npm install swap-array"
    - "Returns a new array with the elements at the two given indices swapped."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table swap_array.swap:
  kind: node_module_call_eq
  function: "default"
  category: arrays
  id_prefix: swaparr

  columns: [id, args, expected]
  rows:
    - [first_last, [[1, 2, 3, 4, 5], 0, 4], [5, 2, 3, 4, 1]]
    - [middle,     [[1, 2, 3, 4, 5], 1, 3], [1, 4, 3, 2, 5]]
    - [strings,    [["a", "b", "c"], 0, 2], ["c", "b", "a"]]
