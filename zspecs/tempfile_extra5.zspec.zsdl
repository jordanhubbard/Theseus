spec: tempfile_extra5
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "This spec extends tempfile.zspec.zsdl and prior extras."
    - "tempfile_extra.zspec.zsdl — covers SpooledTemporaryFile/TemporaryDirectory __bases__[0].__name__; mkstemp/mkdtemp/gettempdir/SpooledTemporaryFile/TemporaryDirectory __module__; gettempprefixb; template; gettempdir_starts_slash; SpooledTemporaryFile_is_type."
    - "tempfile_extra2.zspec.zsdl — covers NamedTemporaryFile/TemporaryFile/gettempprefix __module__; gettempprefix/gettempdir return type; TemporaryDirectory is_type; SpooledTemporaryFile/mkstemp/mkdtemp/NamedTemporaryFile/TemporaryFile __name__ standalones; tempdir NoneType."
    - "tempfile_extra3.zspec.zsdl — covers class_names table (NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory/TemporaryFile __name__); function_names table (mkstemp/mkdtemp/gettempdir/gettempprefix/mktemp); class_modules table (NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory); gettempdir returns_str; gettempprefix value; TemporaryDirectory/SpooledTemporaryFile instance class names."
    - "tempfile_extra4.zspec.zsdl — covers __qualname__ for NamedTemporaryFile/TemporaryFile/TemporaryDirectory/SpooledTemporaryFile/mkstemp/mkdtemp/gettempdir/gettempprefix; __module__ for TemporaryFile/gettempdir/gettempprefix/mkstemp/mkdtemp; gettempprefix().__class__.__name__=='str'."
    - "This spec adds: mktemp.__qualname__, mktemp.__module__, gettempprefixb.__qualname__, gettempprefixb.__module__, NamedTemporaryFile.__bases__[0].__name__=='object', NamedTemporaryFile.__class__.__name__=='function' (NamedTemporaryFile is a wrapper function in CPython), mkdtemp.__class__.__name__=='function', mkstemp.__class__.__name__=='function'."
    - "tempfile.NamedTemporaryFile is implemented as a plain function in CPython that returns a file-like object; its __class__.__name__ is 'function', not 'type'."
    - "tempfile.mktemp.__qualname__ == 'mktemp' — module-level function, qualname equals name."
    - "tempfile.mktemp.__module__ == 'tempfile' — function defined in the tempfile module."
    - "tempfile.gettempprefixb.__qualname__ == 'gettempprefixb' — module-level function, qualname equals name."
    - "tempfile.gettempprefixb.__module__ == 'tempfile' — function defined in the tempfile module."
    - "tempfile.NamedTemporaryFile.__bases__ raises AttributeError because NamedTemporaryFile is a function, not a class; use __class__.__name__ == 'function' instead."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mktemp — __qualname__ and __module__
# tempfile_extra3 covers mktemp.__name__; extra4 does NOT cover mktemp.__qualname__
# or mktemp.__module__. Both are new.
# ---------------------------------------------------------------------------

invariant tempfile_extra5.mktemp.qualname:
  description: "tempfile.mktemp.__qualname__ == 'mktemp' — module-level function, qualname equals name"
  category: qualname_attrs
  kind: python_call_eq
  function: mktemp.__qualname__.__eq__
  args: ["mktemp"]
  expected: true

invariant tempfile_extra5.mktemp.module:
  description: "tempfile.mktemp.__module__ == 'tempfile'"
  category: module_attrs
  kind: python_call_eq
  function: mktemp.__module__.__eq__
  args: ["tempfile"]
  expected: true

# ---------------------------------------------------------------------------
# gettempprefixb — __qualname__ and __module__
# Not covered by any prior tempfile spec.
# ---------------------------------------------------------------------------

invariant tempfile_extra5.gettempprefixb.qualname:
  description: "tempfile.gettempprefixb.__qualname__ == 'gettempprefixb' — module-level function"
  category: qualname_attrs
  kind: python_call_eq
  function: gettempprefixb.__qualname__.__eq__
  args: ["gettempprefixb"]
  expected: true

invariant tempfile_extra5.gettempprefixb.module:
  description: "tempfile.gettempprefixb.__module__ == 'tempfile'"
  category: module_attrs
  kind: python_call_eq
  function: gettempprefixb.__module__.__eq__
  args: ["tempfile"]
  expected: true

# ---------------------------------------------------------------------------
# NamedTemporaryFile.__class__.__name__ == 'function'
# tempfile.NamedTemporaryFile is implemented as a plain Python function in CPython
# (it returns a _TemporaryFileWrapper or similar). Unlike TemporaryDirectory and
# SpooledTemporaryFile (which are classes), NamedTemporaryFile is a function.
# tempfile_extra covers SpooledTemporaryFile_is_type (__class__.__name__=='type').
# tempfile_extra2 covers TemporaryDirectory.is_type (__class__.__name__=='type').
# This spec adds the complementary check for NamedTemporaryFile.
# ---------------------------------------------------------------------------

invariant tempfile_extra5.NamedTemporaryFile.class_is_function:
  description: "tempfile.NamedTemporaryFile.__class__.__name__ == 'function' — NamedTemporaryFile is a wrapper function"
  category: class_identity
  kind: python_call_eq
  function: NamedTemporaryFile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# mkdtemp and mkstemp __class__.__name__ == 'function'
# All module-level callables that are not classes should report 'function'.
# tempfile_extra2 and tempfile_extra4 cover __name__ and __module__ for these;
# __class__.__name__ is not covered for mkdtemp or mkstemp in any prior spec.
# ---------------------------------------------------------------------------

table tempfile_extra5.function_class_names:
  description: "tempfile module-level functions report __class__.__name__ == 'function'"
  kind: python_call_eq
  category: class_identity
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [mkdtemp,       mkdtemp.__class__.__name__.__eq__,       ["function"], true]
    - [mkstemp,       mkstemp.__class__.__name__.__eq__,       ["function"], true]
    - [gettempdir,    gettempdir.__class__.__name__.__eq__,    ["function"], true]
    - [gettempprefix, gettempprefix.__class__.__name__.__eq__, ["function"], true]
    - [mktemp,        mktemp.__class__.__name__.__eq__,        ["function"], true]
