spec: csv_extra10
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra9."
    - "csv_extra2 covers: Dialect/__name__; QUOTE_ALL/QUOTE_NONE values and types; Error/__name__."
    - "csv_extra3 covers: Dialect/__name__; QUOTE_ALL/__class__/__name__; QUOTE_MINIMAL/__class__/__name__."
    - "csv_extra6 covers: Dialect/__bases__[0]/__name__; QUOTE_NONNUMERIC/__class__/__name__; QUOTE_NONE/__class__/__name__."
    - "csv_extra8 covers: Sniffer/__name__; Dialect/__name__; Error/__name__; Error/__bases__[0]/__name__; register_dialect/__name__; Sniffer/__module__; Error/__module__; Dialect/__module__; Sniffer/__bases__[0]/__name__."
    - "csv_extra9 covers: DictReader/DictWriter __bases__[0]; reader/writer/DictReader/DictWriter __class__/__name__; list_dialects return type; unregister_dialect/__module__."
    - "This spec adds four new axes: Dialect/__class__/__name__; Error/__class__/__name__; Sniffer/__class__/__name__; get_dialect/__name__."
    - "csv.Dialect.__class__.__name__ — Dialect is a C-extension type object in _csv; its metaclass is 'type'. Prior specs only checked __name__, __module__, __bases__[0].__name__, and __qualname__ for Dialect."
    - "csv.Error.__class__.__name__ — Error is a Python exception class; its metaclass is 'type'. Prior specs only checked __name__, __module__, __bases__[0].__name__, and __qualname__ for Error."
    - "csv.Sniffer.__class__.__name__ — Sniffer is a pure-Python class; its metaclass is 'type'. Prior specs only checked __name__, __module__, __bases__[0].__name__, and __qualname__."
    - "csv.get_dialect.__name__ == 'get_dialect' — only __qualname__ was checked before; __name__ is a new axis."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Metaclass checks for Dialect, Error, and Sniffer
#
# Prior specs check __name__, __module__, __qualname__, and __bases__[0].__name__
# for Dialect, Error, and Sniffer.
# csv_extra9 adds metaclass checks for reader, writer, DictReader, DictWriter.
# No prior csv spec checks __class__.__name__ for Dialect, Error, or Sniffer.
# All three are class objects whose metaclass is 'type'.
# ---------------------------------------------------------------------------

table csv_extra10.class_metaclasses:
  kind: python_call_eq
  category: metaclasses
  id_prefix: meta10

  columns: [id, function, args, expected]
  rows:
    - [Dialect, Dialect.__class__.__name__.__eq__, ["type"], true]
    - [Error,   Error.__class__.__name__.__eq__,   ["type"], true]
    - [Sniffer, Sniffer.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# csv.get_dialect.__name__
#
# csv_extra5 checks get_dialect.__qualname__ == 'get_dialect'.
# No prior csv spec checks get_dialect.__name__.
# For a module-level function, __name__ == __qualname__ == 'get_dialect'.
# This is a new axis (the __name__ attribute, distinct from __qualname__).
# ---------------------------------------------------------------------------

invariant csv_extra10.get_dialect.name:
  description: "csv.get_dialect.__name__ == 'get_dialect' — unqualified function name"
  category: function_names
  kind: python_call_eq
  function: get_dialect.__name__.__eq__
  args: ["get_dialect"]
  expected: true
