spec: io_extra232
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io module __dict__ membership for all public names."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module __dict__ membership
# Verifies that the expected public names are present in io's __dict__.
# ---------------------------------------------------------------------------

table io_extra232.dict_membership:
  description: "io.__dict__ contains the expected public names"
  kind: python_call_eq
  category: module_membership
  id_prefix: iodictmember232

  columns: [id, function, args, expected]
  rows:
    - [bytesio_present,        "__dict__.__contains__", ["BytesIO"],           true]
    - [stringio_present,       "__dict__.__contains__", ["StringIO"],          true]
    - [fileio_present,         "__dict__.__contains__", ["FileIO"],            true]
    - [bufferedreader_present, "__dict__.__contains__", ["BufferedReader"],    true]
    - [bufferedwriter_present, "__dict__.__contains__", ["BufferedWriter"],    true]
    - [bufferedrandom_present, "__dict__.__contains__", ["BufferedRandom"],    true]
    - [textiowrapper_present,  "__dict__.__contains__", ["TextIOWrapper"],     true]
    - [iobase_present,         "__dict__.__contains__", ["IOBase"],            true]
    - [rawiobase_present,      "__dict__.__contains__", ["RawIOBase"],         true]
    - [bufferediobase_present, "__dict__.__contains__", ["BufferedIOBase"],    true]
    - [textiobase_present,     "__dict__.__contains__", ["TextIOBase"],        true]
    - [open_present,           "__dict__.__contains__", ["open"],              true]
    - [default_buffer_size_present, "__dict__.__contains__", ["DEFAULT_BUFFER_SIZE"], true]
    - [seek_set_present,       "__dict__.__contains__", ["SEEK_SET"],          true]
    - [seek_cur_present,       "__dict__.__contains__", ["SEEK_CUR"],          true]
    - [seek_end_present,       "__dict__.__contains__", ["SEEK_END"],          true]
    - [unsupported_op_present, "__dict__.__contains__", ["UnsupportedOperation"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra232.dict_contains_BytesIO:
  description: "io.__dict__.__contains__('BytesIO') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["BytesIO"]
  expected: true

invariant io_extra232.dict_contains_open:
  description: "io.__dict__.__contains__('open') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["open"]
  expected: true

invariant io_extra232.dict_contains_DEFAULT_BUFFER_SIZE:
  description: "io.__dict__.__contains__('DEFAULT_BUFFER_SIZE') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["DEFAULT_BUFFER_SIZE"]
  expected: true

invariant io_extra232.dict_contains_UnsupportedOperation:
  description: "io.__dict__.__contains__('UnsupportedOperation') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["UnsupportedOperation"]
  expected: true
