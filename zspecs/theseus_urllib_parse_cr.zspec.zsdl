spec: theseus_urllib_parse_cr
version: ">=3.8"
backend: python_cleanroom(theseus_urllib_parse_cr)
blocks: urllib.parse

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.parse.html"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py (internal implementation)"
  notes:
    - "Clean-room urllib.parse module. Do NOT import urllib.parse."
    - "urlparse(urlstring): parse URL into components."
    - "urlunparse(components): reconstruct URL from components."
    - "urlencode(query): encode dict as URL query string."
    - "urljoin(base, url): join base URL with relative URL."
    - "quote(string): percent-encode a string."
    - "unquote(string): decode percent-encoded string."

error_model: python_exceptions

invariant theseus_urllib_parse_cr.urllib_parse2_urlparse:
  description: "urlparse extracts scheme, netloc, path from URL"
  category: urlparse
  kind: python_call_eq
  function: urllib_parse2_urlparse
  args: []
  expected: true

invariant theseus_urllib_parse_cr.urllib_parse2_urlencode:
  description: "urlencode({'a': 1, 'b': 2}) produces query string"
  category: urlencode
  kind: python_call_eq
  function: urllib_parse2_urlencode
  args: []
  expected: true

invariant theseus_urllib_parse_cr.urllib_parse2_quote:
  description: "quote('hello world') returns 'hello%20world'"
  category: quote
  kind: python_call_eq
  function: urllib_parse2_quote
  args: []
  expected: "hello%20world"
