spec: lodash_sorteduniqby
version: ">=4.0.0"
backend: node(lodash.sorteduniqby)

docs: https://lodash.com/docs/#sortedUniqBy

provenance:
  derived_from:
    - "lodash.sorteduniqby README — https://www.npmjs.com/package/lodash.sorteduniqby"
    - "Test vectors verified with lodash.sorteduniqby@4.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sorteduniqby exports the _.sortedUniqBy function directly as module.exports."
    - "sortedUniqBy(array, iteratee) removes consecutive duplicates using iteratee for comparison."
    - "String iteratee plucks a property. Array must be sorted by the iteratee value."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array with consecutive duplicates removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sorteduniqby.sorteduniqby:
  kind: node_module_call_eq
  function: ~
  category: sorteduniqby
  id_prefix: lsuby

  columns: [id, args, expected]
  rows:
    - [by_x,  [[{"x": 1, "y": "a"}, {"x": 1, "y": "b"}, {"x": 2, "y": "c"}], "x"],
       [{"x": 1, "y": "a"}, {"x": 2, "y": "c"}]]
