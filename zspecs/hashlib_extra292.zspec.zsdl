spec: hashlib_extra292
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html — HMAC keyed-hashing for message authentication"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hmac.py, Modules/_hashopenssl.c"
  notes:
    - "hmac.compare_digest is implemented in _hashlib (C extension), not _operator as sometimes assumed"
    - "hmac.digest is a pure-Python wrapper in hmac module, not from _hashlib"
    - "hmac.HMAC inherits directly from object"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra292.module_identity:
  description: "hmac module identity attributes: __name__, __package__, __spec__ class, __loader__ class"
  kind: python_call_eq
  category: identity
  id_prefix: hx292m

  columns: [id, function, args, expected, description]
  rows:
    - [hx292m001, hmac.__name__.__class__.__name__, [], str, "__name__ is a str"]
    - [hx292m002, hmac.__name__.__eq__, ["hmac"], true, "__name__ == 'hmac'"]
    - [hx292m003, hmac.__package__.__eq__, [""], true, "__package__ == ''"]
    - [hx292m004, hmac.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "__spec__ class is ModuleSpec"]
    - [hx292m005, hmac.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "__loader__ class is SourceFileLoader"]
    - [hx292m006, hmac.new.__name__.__eq__, ["new"], true, "hmac.new.__name__ == 'new'"]
    - [hx292m007, hmac.new.__module__.__eq__, ["hmac"], true, "hmac.new.__module__ == 'hmac'"]

table hashlib_extra292.hmac_class_identity:
  description: "HMAC class identity and method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: hx292c

  columns: [id, function, args, expected, description]
  rows:
    - [hx292c001, hmac.HMAC.__name__.__eq__, ["HMAC"], true, "HMAC.__name__ == 'HMAC'"]
    - [hx292c002, hmac.HMAC.__module__.__eq__, ["hmac"], true, "HMAC.__module__ == 'hmac'"]
    - [hx292c003, hmac.HMAC.__bases__.__len__, [], 1, "HMAC has exactly one base class"]
    - [hx292c004, hmac.HMAC.__bases__.__getitem__(0).__name__.__eq__, ["object"], true, "HMAC base class is object"]
    - [hx292c005, hmac.HMAC.update.__qualname__.__eq__, ["HMAC.update"], true, "HMAC.update qualname"]
    - [hx292c006, hmac.HMAC.digest.__qualname__.__eq__, ["HMAC.digest"], true, "HMAC.digest qualname"]
    - [hx292c007, hmac.HMAC.hexdigest.__qualname__.__eq__, ["HMAC.hexdigest"], true, "HMAC.hexdigest qualname"]
    - [hx292c008, hmac.HMAC.copy.__qualname__.__eq__, ["HMAC.copy"], true, "HMAC.copy qualname"]

invariant hashlib_extra292.compare_digest_module:
  description: "hmac.compare_digest is implemented in _hashlib C extension"
  category: identity
  kind: python_call_eq
  function: hmac.compare_digest.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra292.digest_module:
  description: "hmac.digest lives in the hmac module (pure-Python wrapper)"
  category: identity
  kind: python_call_eq
  function: hmac.digest.__module__.__eq__
  args: ["hmac"]
  expected: true

invariant hashlib_extra292.digest_name:
  description: "hmac.digest.__name__ == 'digest'"
  category: identity
  kind: python_call_eq
  function: hmac.digest.__name__.__eq__
  args: ["digest"]
  expected: true

invariant hashlib_extra292.compare_digest_name:
  description: "hmac.compare_digest.__name__ == 'compare_digest'"
  category: identity
  kind: python_call_eq
  function: hmac.compare_digest.__name__.__eq__
  args: ["compare_digest"]
  expected: true
