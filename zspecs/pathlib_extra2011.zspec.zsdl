spec: pathlib_extra2011
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2011 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "pathlib path classes use __truediv__ (the / operator) for path joining — not __add__."
    - "None of pathlib.Path, PurePath, PurePosixPath, PureWindowsPath define arithmetic operators in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2011.add_protocol:
  description: "pathlib path classes __add__/__radd__/__iadd__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2011

  columns: [id, function, args, expected]
  rows:
    - ["pl2011001", "pathlib.Path.__dict__.__contains__",             ["__add__"],  false]
    - ["pl2011002", "pathlib.Path.__dict__.__contains__",             ["__radd__"], false]
    - ["pl2011003", "pathlib.Path.__dict__.__contains__",             ["__iadd__"], false]
    - ["pl2011004", "pathlib.PurePath.__dict__.__contains__",         ["__add__"],  false]
    - ["pl2011005", "pathlib.PurePath.__dict__.__contains__",         ["__radd__"], false]
    - ["pl2011006", "pathlib.PurePath.__dict__.__contains__",         ["__iadd__"], false]
    - ["pl2011007", "pathlib.PurePosixPath.__dict__.__contains__",    ["__add__"],  false]
    - ["pl2011008", "pathlib.PurePosixPath.__dict__.__contains__",    ["__radd__"], false]
    - ["pl2011009", "pathlib.PurePosixPath.__dict__.__contains__",    ["__iadd__"], false]
    - ["pl2011010", "pathlib.PureWindowsPath.__dict__.__contains__",  ["__add__"],  false]
    - ["pl2011011", "pathlib.PureWindowsPath.__dict__.__contains__",  ["__radd__"], false]
    - ["pl2011012", "pathlib.PureWindowsPath.__dict__.__contains__",  ["__iadd__"], false]

