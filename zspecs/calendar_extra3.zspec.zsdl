spec: calendar_extra3
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "Extends calendar.zspec.zsdl, calendar_extra.zspec.zsdl, and calendar_extra2.zspec.zsdl."
    - "calendar.zspec.zsdl covers: isleap table (2000/2024/1900/2100/2023/2026), weekday vectors, leapdays, month_name/abbr/day_name/day_abbr, MONDAY/WEDNESDAY/SUNDAY/JANUARY/DECEMBER constants."
    - "calendar_extra.zspec.zsdl covers: Calendar/__name__/__module__, TextCalendar/__name__/__bases__, HTMLCalendar/__name__/__bases__, isleap/__name__ and 2000/1900/2024 values, leapdays(2000,2024)==6, month_name class, weekheader, MONDAY/SUNDAY constants."
    - "calendar_extra2.zspec.zsdl covers: Calendar/__name__, TextCalendar/__name__, HTMLCalendar/__name__, MONDAY/SUNDAY values, month_name class, isleap(2000)/isleap(1900), leapdays(2000,2001)."
    - "This spec adds: __qualname__ for Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/isleap/monthrange/weekday, MONDAY/__class__/__name__=='int', SUNDAY/__class__/__name__=='int', __module__ for isleap and Calendar, and behavioral isleap(2024)/isleap(2023)/monthrange(2024,1)[0]."
    - "calendar.MONDAY is a Day enum value; Day is an IntEnum subclass so MONDAY.__class__.__name__ == 'Day', but its int base means __class__.__mro__ includes int. The task specifies __class__.__name__ == 'int' — however Day enum members report __class__.__name__ as 'Day'. We verify the integer-like nature via __int__.__class__.__name__ comparison instead: MONDAY.__class__.__bases__[0].__name__ == 'int' confirms IntEnum inherits from int."
    - "NOTE on MONDAY.__class__.__name__: calendar.MONDAY is a Day enum member; Day(IntEnum). Day.__class__.__name__ == 'EnumType', MONDAY.__class__.__name__ == 'Day'. The task vector states 'MONDAY.__class__.__name__ == int' meaning the class name is 'int', which is not accurate for enum members. We implement this as MONDAY.__class__.__bases__[0].__name__ == 'int' (Day's first base is int via IntEnum)."
    - "calendar.monthrange(2024, 1) returns (0, 31); index 0 is the weekday of the first day (0=Monday). January 1, 2024 was a Monday."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table — Calendar, TextCalendar, HTMLCalendar, LocaleTextCalendar
#
# These are module-level classes; their __qualname__ equals their __name__.
# No existing calendar spec covers __qualname__ for any of these names.
# ---------------------------------------------------------------------------

table calendar_extra3.qualnames.classes:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Calendar,            Calendar.__qualname__.__eq__,            ["Calendar"],            true]
    - [TextCalendar,        TextCalendar.__qualname__.__eq__,        ["TextCalendar"],        true]
    - [HTMLCalendar,        HTMLCalendar.__qualname__.__eq__,        ["HTMLCalendar"],        true]
    - [LocaleTextCalendar,  LocaleTextCalendar.__qualname__.__eq__,  ["LocaleTextCalendar"],  true]

# ---------------------------------------------------------------------------
# __qualname__ table — isleap, monthrange, weekday
#
# Module-level functions; __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table calendar_extra3.qualnames.functions:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [isleap,     isleap.__qualname__.__eq__,     ["isleap"],     true]
    - [monthrange, monthrange.__qualname__.__eq__,  ["monthrange"], true]
    - [weekday,    weekday.__qualname__.__eq__,     ["weekday"],    true]

# ---------------------------------------------------------------------------
# MONDAY and SUNDAY — integer base class check
#
# calendar.MONDAY and SUNDAY are Day enum members. Day is defined as
# class Day(IntEnum), so Day.__bases__[0].__name__ == 'int'.
# We confirm that the Day class (i.e., MONDAY.__class__) has 'int' as its
# first base, establishing the integer nature of these constants.
# ---------------------------------------------------------------------------

invariant calendar_extra3.MONDAY.class_base_is_int:
  description: "calendar.MONDAY.__class__.__bases__[0].__name__ == 'int' — Day enum inherits from int via IntEnum"
  category: constants
  kind: python_call_eq
  function: MONDAY.__class__.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

invariant calendar_extra3.SUNDAY.class_base_is_int:
  description: "calendar.SUNDAY.__class__.__bases__[0].__name__ == 'int' — Day enum inherits from int via IntEnum"
  category: constants
  kind: python_call_eq
  function: SUNDAY.__class__.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# __module__ — isleap and Calendar
#
# isleap and Calendar are both defined in the calendar module.
# calendar_extra covers Calendar.__module__ but not isleap.__module__.
# ---------------------------------------------------------------------------

invariant calendar_extra3.isleap.module:
  description: "calendar.isleap.__module__ == 'calendar'"
  category: modules
  kind: python_call_eq
  function: isleap.__module__.__eq__
  args: ["calendar"]
  expected: true

invariant calendar_extra3.Calendar.module:
  description: "calendar.Calendar.__module__ == 'calendar'"
  category: modules
  kind: python_call_eq
  function: Calendar.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: isleap
#
# calendar.zspec.zsdl and calendar_extra cover 2024/2023/2000/1900.
# We add 2024==True and 2023==False here as this spec's own vectors.
# ---------------------------------------------------------------------------

invariant calendar_extra3.isleap.2024_true:
  description: "calendar.isleap(2024) == True — 2024 is divisible by 4 and not by 100"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2024]
  expected: true

invariant calendar_extra3.isleap.2023_false:
  description: "calendar.isleap(2023) == False — 2023 is not divisible by 4"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2023]
  expected: false

# ---------------------------------------------------------------------------
# Behavioral: monthrange(2024, 1)[0] == 0
#
# monthrange(year, month) returns (weekday_of_first_day, number_of_days).
# January 1, 2024 was a Monday, so weekday_of_first_day == 0.
# ---------------------------------------------------------------------------

invariant calendar_extra3.monthrange.jan_2024_first_weekday:
  description: "calendar.monthrange(2024, 1)[0] == 0 — January 2024 starts on Monday (weekday 0)"
  category: monthrange
  kind: python_call_eq
  function: monthrange
  args: [2024, 1]
  method: __getitem__
  method_args: [0]
  expected: 0
