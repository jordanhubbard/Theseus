spec: calendar_extra3
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl, calendar_extra.zspec.zsdl, and calendar_extra2.zspec.zsdl."
    - "Focus: Calendar, TextCalendar, HTMLCalendar class identity, and isleap/leapdays function results."
    - "calendar.TextCalendar.__bases__[0].__name__ == 'Calendar' — TextCalendar inherits from Calendar."
    - "calendar.HTMLCalendar.__bases__[0].__name__ == 'Calendar' — HTMLCalendar inherits from Calendar."
    - "Leap year rules: divisible by 4 AND (not by 100 OR by 400). 2024: leap. 2023: not. 1900: not (div by 100 not 400). 2000: leap (div by 400)."
    - "calendar.leapdays(2000, 2024) counts leap years in [2000, 2024): 2000, 2004, 2008, 2012, 2016, 2020 = 6."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — Calendar, TextCalendar, HTMLCalendar
# ---------------------------------------------------------------------------

invariant calendar_extra3.Calendar.class_name:
  description: "calendar.Calendar.__name__ == 'Calendar'"
  category: class_names
  kind: python_call_eq
  function: Calendar.__name__.__eq__
  args: ["Calendar"]
  expected: true

invariant calendar_extra3.TextCalendar.class_name:
  description: "calendar.TextCalendar.__name__ == 'TextCalendar'"
  category: class_names
  kind: python_call_eq
  function: TextCalendar.__name__.__eq__
  args: ["TextCalendar"]
  expected: true

invariant calendar_extra3.HTMLCalendar.class_name:
  description: "calendar.HTMLCalendar.__name__ == 'HTMLCalendar'"
  category: class_names
  kind: python_call_eq
  function: HTMLCalendar.__name__.__eq__
  args: ["HTMLCalendar"]
  expected: true

invariant calendar_extra3.Calendar.module:
  description: "calendar.Calendar.__module__ == 'calendar'"
  category: class_names
  kind: python_call_eq
  function: Calendar.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance hierarchy
# ---------------------------------------------------------------------------

invariant calendar_extra3.TextCalendar.base:
  description: "calendar.TextCalendar.__bases__[0].__name__ == 'Calendar'"
  category: hierarchy
  kind: python_call_eq
  function: TextCalendar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Calendar"

invariant calendar_extra3.HTMLCalendar.base:
  description: "calendar.HTMLCalendar.__bases__[0].__name__ == 'Calendar'"
  category: hierarchy
  kind: python_call_eq
  function: HTMLCalendar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Calendar"

# ---------------------------------------------------------------------------
# isleap — leap year predicate
# ---------------------------------------------------------------------------

invariant calendar_extra3.isleap.2024_true:
  description: "calendar.isleap(2024) == True — 2024 is divisible by 4 and not by 100"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2024]
  expected: true

invariant calendar_extra3.isleap.2023_false:
  description: "calendar.isleap(2023) == False — 2023 is not divisible by 4"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2023]
  expected: false

invariant calendar_extra3.isleap.1900_false:
  description: "calendar.isleap(1900) == False — 1900 divisible by 100 but not by 400"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [1900]
  expected: false

invariant calendar_extra3.isleap.2000_true:
  description: "calendar.isleap(2000) == True — 2000 is divisible by 400"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2000]
  expected: true

# ---------------------------------------------------------------------------
# leapdays — count leap years in a range [y1, y2)
# ---------------------------------------------------------------------------

invariant calendar_extra3.leapdays.2000_2024:
  description: "calendar.leapdays(2000, 2024) == 6 — leap years: 2000, 2004, 2008, 2012, 2016, 2020"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [2000, 2024]
  expected: 6

# ---------------------------------------------------------------------------
# class_names table — Calendar, TextCalendar, HTMLCalendar
# ---------------------------------------------------------------------------

table calendar_extra3.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [Calendar,     Calendar.__name__.__eq__,     ["Calendar"],     true]
    - [TextCalendar, TextCalendar.__name__.__eq__, ["TextCalendar"], true]
    - [HTMLCalendar, HTMLCalendar.__name__.__eq__, ["HTMLCalendar"], true]
