spec: threading_extra293
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Lock, RLock identity; TIMEOUT_MAX comparisons"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py, Modules/_threadmodule.c"
  notes:
    - "threading.Lock is a type (class), __class__.__name__ == 'type', __name__ == 'lock'"
    - "threading.RLock is a function, __class__.__name__ == 'function', __name__ == 'RLock'"
    - "threading.TIMEOUT_MAX == 9223372036.0 on macOS/Darwin 25.4.0 (platform-specific)"
    - "threading.TIMEOUT_MAX is a float > 1e8 on all tested platforms"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra293.lock_identity:
  description: "Identity checks for threading.Lock and threading.RLock"
  kind: python_call_eq
  category: identity
  id_prefix: the293a

  columns: [id, function, args, expected, description]
  rows:
    - [the293a001, threading.Lock.__class__.__name__.__eq__, ["type"], true, "threading.Lock is a type/class"]
    - [the293a002, threading.Lock.__name__.__eq__, ["lock"], true, "threading.Lock.__name__ is 'lock'"]
    - [the293a003, threading.RLock.__class__.__name__.__eq__, ["function"], true, "threading.RLock is a function"]
    - [the293a004, threading.RLock.__name__.__eq__, ["RLock"], true, "threading.RLock.__name__ is 'RLock'"]

table threading_extra293.timeout_max:
  description: "threading.TIMEOUT_MAX type and comparison checks"
  kind: python_call_eq
  category: identity
  id_prefix: the293b

  columns: [id, function, args, expected, description]
  rows:
    - [the293b001, threading.TIMEOUT_MAX.__class__.__name__.__eq__, ["float"], true, "TIMEOUT_MAX is a float"]
    - [the293b002, threading.TIMEOUT_MAX.__gt__, [0], true, "TIMEOUT_MAX > 0"]
    - [the293b003, threading.TIMEOUT_MAX.__gt__, [100000000.0], true, "TIMEOUT_MAX > 1e8"]
    - [the293b004, threading.TIMEOUT_MAX.__gt__, [10000000000.0], false, "TIMEOUT_MAX is not > 1e10"]

invariant threading_extra293.lock_is_type:
  description: "threading.Lock.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: threading.Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra293.lock_name_is_lock:
  description: "threading.Lock.__name__ == 'lock'"
  category: identity
  kind: python_call_eq
  function: threading.Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra293.rlock_is_function:
  description: "threading.RLock.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: threading.RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra293.timeout_max_gt_zero:
  description: "threading.TIMEOUT_MAX > 0"
  category: identity
  kind: python_call_eq
  function: threading.TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra293.timeout_max_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float'"
  category: identity
  kind: python_call_eq
  function: threading.TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true
