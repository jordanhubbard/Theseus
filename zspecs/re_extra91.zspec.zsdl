spec: re_extra91
version: ">=3.9"
backend: python_module(re)
extends: re_extra90

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra90."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; method qualnames; re.error/__name__; module-level function qualnames; re.RegexFlag hierarchy; re module constants; Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError attributes; re.NOFLAG value; Pattern/Match method __doc__.__len__(); re.Pattern/__dict__.__contains__; re module-level function __qualname__ for all functions; Pattern/Match __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); RegexFlag class identity."
    - "This spec covers: re.Pattern and re.Match method __qualname__ string equality. Pattern and Match are C types from the _sre module; their methods are method_descriptor objects with __qualname__ attributes."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' — method_descriptor with class-prefixed qualname."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' — method_descriptor with class-prefixed qualname."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' — method_descriptor with class-prefixed qualname."
    - "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' — method_descriptor with class-prefixed qualname."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' — method_descriptor with class-prefixed qualname."
    - "re.Pattern.subn.__qualname__ == 'Pattern.subn' — method_descriptor with class-prefixed qualname."
    - "re.Pattern.split.__qualname__ == 'Pattern.split' — method_descriptor with class-prefixed qualname."
    - "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' — method_descriptor with class-prefixed qualname."
    - "re.Match.group.__qualname__ == 'Match.group' — method_descriptor with class-prefixed qualname."
    - "re.Match.groups.__qualname__ == 'Match.groups' — method_descriptor with class-prefixed qualname."
    - "re.Match.start.__qualname__ == 'Match.start' — method_descriptor with class-prefixed qualname."
    - "re.Match.end.__qualname__ == 'Match.end' — method_descriptor with class-prefixed qualname."
    - "re.Match.span.__qualname__ == 'Match.span' — method_descriptor with class-prefixed qualname."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern match/search/findall/finditer method __qualname__ string equality
# Pattern is a C type from _sre; its methods are method_descriptor objects.
# In modern Python these have __qualname__ with 'Pattern.' class prefix.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra91.Pattern_match_search_qualnames:
  description: "re.Pattern.match/search/findall/finditer __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: repathmethodqual91

  columns: [id, function, args, expected]
  rows:
    - [pattern_match_qualname,    Pattern.match.__qualname__.__eq__,    ["Pattern.match"],    true]
    - [pattern_search_qualname,   Pattern.search.__qualname__.__eq__,   ["Pattern.search"],   true]
    - [pattern_findall_qualname,  Pattern.findall.__qualname__.__eq__,  ["Pattern.findall"],  true]
    - [pattern_finditer_qualname, Pattern.finditer.__qualname__.__eq__, ["Pattern.finditer"], true]

# ---------------------------------------------------------------------------
# re.Pattern sub/subn/split/fullmatch method __qualname__ string equality
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra91.Pattern_sub_split_qualnames:
  description: "re.Pattern.sub/subn/split/fullmatch __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: repathmethodqual91

  columns: [id, function, args, expected]
  rows:
    - [pattern_sub_qualname,       Pattern.sub.__qualname__.__eq__,       ["Pattern.sub"],       true]
    - [pattern_subn_qualname,      Pattern.subn.__qualname__.__eq__,      ["Pattern.subn"],      true]
    - [pattern_split_qualname,     Pattern.split.__qualname__.__eq__,     ["Pattern.split"],     true]
    - [pattern_fullmatch_qualname, Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true]

# ---------------------------------------------------------------------------
# re.Match group/groups/start/end method __qualname__ string equality
# Match is a C type from _sre; its methods are method_descriptor objects.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra91.Match_group_start_qualnames:
  description: "re.Match.group/groups/start/end __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: repathmethodqual91

  columns: [id, function, args, expected]
  rows:
    - [match_group_qualname,  Match.group.__qualname__.__eq__,  ["Match.group"],  true]
    - [match_groups_qualname, Match.groups.__qualname__.__eq__, ["Match.groups"], true]
    - [match_start_qualname,  Match.start.__qualname__.__eq__,  ["Match.start"],  true]
    - [match_end_qualname,    Match.end.__qualname__.__eq__,    ["Match.end"],    true]

# ---------------------------------------------------------------------------
# re.Match span + cross-checks
# span qualname; cross-check: Pattern and Match methods have different prefixes.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra91.Match_span_cross_checks:
  description: "re.Match.span __qualname__; cross-checks between Pattern and Match method qualname prefixes"
  kind: python_call_eq
  category: qualname
  id_prefix: repathmethodqual91

  columns: [id, function, args, expected]
  rows:
    - [match_span_qualname,         Match.span.__qualname__.__eq__,        ["Match.span"],    true]
    - [pattern_match_not_match,     Pattern.match.__qualname__.__eq__,     ["Match.match"],   false]
    - [match_group_not_pattern,     Match.group.__qualname__.__eq__,       ["Pattern.group"], false]
    - [pattern_sub_not_match_sub,   Pattern.sub.__qualname__.__eq__,       ["Match.sub"],     false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra91.Pattern.match_qualname:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' (method_descriptor with class-prefixed qualname)"
  category: qualname
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra91.Pattern.fullmatch_qualname:
  description: "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (method_descriptor with class-prefixed qualname)"
  category: qualname
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__eq__
  args: ["Pattern.fullmatch"]
  expected: true

invariant re_extra91.Pattern.sub_qualname:
  description: "re.Pattern.sub.__qualname__ == 'Pattern.sub' (method_descriptor with class-prefixed qualname)"
  category: qualname
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__eq__
  args: ["Pattern.sub"]
  expected: true

invariant re_extra91.Match.group_qualname:
  description: "re.Match.group.__qualname__ == 'Match.group' (method_descriptor with class-prefixed qualname)"
  category: qualname
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra91.Match.span_qualname:
  description: "re.Match.span.__qualname__ == 'Match.span' (method_descriptor with class-prefixed qualname)"
  category: qualname
  kind: python_call_eq
  function: Match.span.__qualname__.__eq__
  args: ["Match.span"]
  expected: true
