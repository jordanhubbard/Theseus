spec: decimal_extra386
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.MAX_EMAX == 999999999999999999 — maximum value for exponent Emax in a context"
    - "decimal.MIN_EMIN == -999999999999999999 — minimum value for exponent Emin in a context"
    - "decimal.MAX_PREC == 999999999999999999 — maximum value for precision in a context"
    - "decimal.MIN_ETINY == -1999999999999999997 — equals MIN_EMIN - MAX_PREC + 1; the most negative subnormal exponent"
    - "decimal.HAVE_THREADS == True — always True in CPython; indicates thread-safe decimal operations"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal context limit constants — MAX_EMAX, MIN_EMIN, MAX_PREC
# ---------------------------------------------------------------------------

table decimal_extra386.context_limit_constants:
  description: "decimal context limit constants — MAX_EMAX==999999999999999999, MIN_EMIN==-999999999999999999, MAX_PREC==999999999999999999; these are the platform limits for exponent and precision in a decimal Context; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: deccxlim386

  columns: [id, function, args, expected]
  rows:
    - [max_emax, decimal.MAX_EMAX.__eq__, [999999999999999999],  true]
    - [min_emin, decimal.MIN_EMIN.__eq__, [-999999999999999999], true]
    - [max_prec, decimal.MAX_PREC.__eq__, [999999999999999999],  true]

# ---------------------------------------------------------------------------
# decimal.MIN_ETINY — most negative subnormal exponent
# ---------------------------------------------------------------------------

table decimal_extra386.min_etiny_constant:
  description: "decimal.MIN_ETINY == -1999999999999999997; equals MIN_EMIN - MAX_PREC + 1; this is the most negative possible exponent for subnormal numbers in a decimal Context at maximum precision; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decetiny386

  columns: [id, function, args, expected]
  rows:
    - [min_etiny, decimal.MIN_ETINY.__eq__, [-1999999999999999997], true]

# ---------------------------------------------------------------------------
# decimal.HAVE_THREADS — thread-safety indicator
# ---------------------------------------------------------------------------

table decimal_extra386.have_threads_constant:
  description: "decimal.HAVE_THREADS == True; always True in CPython; indicates that decimal operations are thread-safe; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decthreads386

  columns: [id, function, args, expected]
  rows:
    - [have_threads, decimal.HAVE_THREADS.__eq__, [true], true]
