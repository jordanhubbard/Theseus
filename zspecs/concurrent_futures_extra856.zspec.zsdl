spec: concurrent_futures_extra856
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - concurrent.futures standard library module
    - CPython source: Lib/concurrent/futures/_base.py
  not_derived_from:
    - any third-party executor implementation
    - asyncio.Future or threading.Future variants
  notes:
    - Covers Executor base class qualnames and context-manager protocol methods
    - Covers Future lifecycle method qualnames
    - Covers BrokenExecutor exception module and as_completed doc presence
  created_at: "2026-04-12"

table concurrent_futures_extra856.executor_base:
  description: concurrent.futures Executor base class qualnames and doc identity
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: cf856ex
  columns: [id, function, args, expected]
  rows:
    - [cf856ex001, concurrent.futures.Executor.__qualname__.__eq__, ["Executor"], true]
    - [cf856ex002, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf856ex003, concurrent.futures.Executor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf856ex004, concurrent.futures.Executor.submit.__qualname__.__eq__, ["Executor.submit"], true]
    - [cf856ex005, concurrent.futures.Executor.map.__qualname__.__eq__, ["Executor.map"], true]
    - [cf856ex006, concurrent.futures.Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"], true]
    - [cf856ex007, concurrent.futures.Executor.__enter__.__qualname__.__eq__, ["Executor.__enter__"], true]
    - [cf856ex008, concurrent.futures.Executor.__exit__.__qualname__.__eq__, ["Executor.__exit__"], true]

table concurrent_futures_extra856.future_and_exceptions:
  description: concurrent.futures Future lifecycle methods and exception/utility identity
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: cf856fu
  columns: [id, function, args, expected]
  rows:
    - [cf856fu001, concurrent.futures.Future.__init__.__qualname__.__eq__, ["Future.__init__"], true]
    - [cf856fu002, concurrent.futures.Future.__repr__.__qualname__.__eq__, ["Future.__repr__"], true]
    - [cf856fu003, concurrent.futures.BrokenExecutor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf856fu004, concurrent.futures.as_completed.__doc__.__class__.__name__.__eq__, ["str"], true]
