spec: h11_rust
version: ">=3.9"
backend: rust_module(h11_rust)

docs: https://h11.readthedocs.io/

provenance:
  derived_from:
    - "https://h11.readthedocs.io/ — h11 library"
  notes:
    - "h11 provides a pure-Python HTTP/1.1 protocol library."
    - "h11.Connection is a class."
    - "h11.Request is a class."
    - "h11.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant h11_rust.has_connection:
  description: "h11.Connection is a class"
  category: presence
  kind: python_call_eq
  function: h11_has_connection
  args: []
  expected: true

invariant h11_rust.has_request:
  description: "h11.Request is a class"
  category: presence
  kind: python_call_eq
  function: h11_has_request
  args: []
  expected: true

invariant h11_rust.version_nonempty:
  description: "h11.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: h11_version_nonempty
  args: []
  expected: true

