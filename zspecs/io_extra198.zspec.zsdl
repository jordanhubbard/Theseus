spec: io_extra198
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec extends io_extra197.zspec.zsdl."
    - "This spec covers: io.BufferedWriter class identity — __name__, __module__, __bases__[0].__name__, __init__.__qualname__, write.__qualname__, flush.__qualname__, __class__.__name__, and length ordering vs BufferedReader."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' (len=14); confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__module__ == '_io' (len=3); BufferedWriter is implemented in the _io C extension, not in the pure-Python io wrapper; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' (len=15); the direct base is the C-level _BufferedIOBase, not the pure-Python BufferedIOBase; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__init__.__qualname__ == 'BufferedWriter.__init__' (len=23: 'BufferedWriter.'=15+'__init__'=8=23); confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (len=20: 'BufferedWriter.'=15+'write'=5=20); confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (len=20: 'BufferedWriter.'=15+'flush'=5=20); same length as write.__qualname__; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__class__.__name__ == 'type' — BufferedWriter uses the plain type metaclass (not ABCMeta); confirmed Python 3.14.3 macOS."
    - "Length ordering: write.__qualname__=20 == flush.__qualname__=20 < __init__.__qualname__=23; confirmed Python 3.14.3 macOS."
    - "BufferedReader.__name__ len == BufferedWriter.__name__ len == 14; both class names are the same length; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.BufferedWriter method __qualname__ equality
# write(20), flush(20), __init__(23)
# ---------------------------------------------------------------------------

table io_extra198.bufferedwriter_method_qualnames:
  description: "io.BufferedWriter method __qualname__ values: write='BufferedWriter.write'(20), flush='BufferedWriter.flush'(20), __init__='BufferedWriter.__init__'(23)"
  kind: python_call_eq
  category: identity
  id_prefix: iobufferedwriter198

  columns: [id, function, args, expected, description]
  rows:
    - [write_qn_eq, io.BufferedWriter.write.__qualname__.__eq__,   ["BufferedWriter.write"],   true, "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (len=20); confirmed Python 3.14.3 macOS"]
    - [flush_qn_eq, io.BufferedWriter.flush.__qualname__.__eq__,   ["BufferedWriter.flush"],   true, "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (len=20, same as write); confirmed Python 3.14.3 macOS"]
    - [init_qn_eq,  io.BufferedWriter.__init__.__qualname__.__eq__, ["BufferedWriter.__init__"], true, "io.BufferedWriter.__init__.__qualname__ == 'BufferedWriter.__init__' (len=23, longest in spec); confirmed Python 3.14.3 macOS"]
    - [write_qn_len, io.BufferedWriter.write.__qualname__.__len__, [], 20, "io.BufferedWriter.write.__qualname__.__len__() == 20 ('BufferedWriter.'=15+'write'=5); confirmed Python 3.14.3 macOS"]
    - [init_qn_len,  io.BufferedWriter.__init__.__qualname__.__len__, [], 23, "io.BufferedWriter.__init__.__qualname__.__len__() == 23 ('BufferedWriter.'=15+'__init__'=8); longest in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.BufferedWriter method __qualname__ lengths
# write(20) == flush(20) < __init__(23)
# ---------------------------------------------------------------------------

table io_extra198.bufferedwriter_method_qualname_lengths:
  description: "io.BufferedWriter method __qualname__ lengths: write=20, flush=20, __init__=23; length ordering write==flush < __init__"
  kind: python_call_eq
  category: identity
  id_prefix: iobufferedwriter198

  columns: [id, function, args, expected, description]
  rows:
    - [write_qn_len, io.BufferedWriter.write.__qualname__.__len__,    [], 20, "io.BufferedWriter.write.__qualname__.__len__() == 20 ('BufferedWriter.'=15+'write'=5); confirmed Python 3.14.3 macOS"]
    - [flush_qn_len, io.BufferedWriter.flush.__qualname__.__len__,    [], 20, "io.BufferedWriter.flush.__qualname__.__len__() == 20 ('BufferedWriter.'=15+'flush'=5); same length as write; confirmed Python 3.14.3 macOS"]
    - [init_qn_len,  io.BufferedWriter.__init__.__qualname__.__len__, [], 23, "io.BufferedWriter.__init__.__qualname__.__len__() == 23 ('BufferedWriter.'=15+'__init__'=8); longest in spec; confirmed Python 3.14.3 macOS"]
    - [module_len,   io.BufferedWriter.__module__.__len__,            [], 3,  "io.BufferedWriter.__module__.__len__() == 3 — _io (underscore+i+o); confirmed Python 3.14.3 macOS"]
    - [name_len,     io.BufferedWriter.__name__.__len__,              [], 14, "io.BufferedWriter.__name__.__len__() == 14 — same length as BufferedReader.__name__ (14); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.BufferedWriter class-level identity attributes
# __name__(BufferedWriter,14), __module__(_io,3), __bases__[0].__name__(_BufferedIOBase,15), __class__(type)
# ---------------------------------------------------------------------------

table io_extra198.bufferedwriter_class_identity:
  description: "io.BufferedWriter class-level identity: __name__='BufferedWriter'(14), __module__='_io'(3), __bases__[0].__name__='_BufferedIOBase'(15), __class__.__name__='type'"
  kind: python_call_eq
  category: identity
  id_prefix: iobufferedwriter198

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       io.BufferedWriter.__name__.__eq__,                          ["BufferedWriter"],  true, "io.BufferedWriter.__name__ == 'BufferedWriter' (len=14); confirmed Python 3.14.3 macOS"]
    - [module_eq,     io.BufferedWriter.__module__.__eq__,                        ["_io"],             true, "io.BufferedWriter.__module__ == '_io' (C extension, len=3); confirmed Python 3.14.3 macOS"]
    - [base_eq,       "io.BufferedWriter.__bases__[0].__name__.__eq__",           ["_BufferedIOBase"], true, "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' (len=15); confirmed Python 3.14.3 macOS"]
    - [class_name_eq, io.BufferedWriter.__class__.__name__.__eq__,                ["type"],            true, "io.BufferedWriter.__class__.__name__ == 'type' (plain type metaclass, not ABCMeta); confirmed Python 3.14.3 macOS"]
    - [name_len,      io.BufferedWriter.__name__.__len__,                         [],                  14,   "io.BufferedWriter.__name__.__len__() == 14 — B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)W(9)r(10)i(11)t(12)e(13)r(14); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra198.bufferedwriter_name_eq:
  description: "io.BufferedWriter.__name__ == 'BufferedWriter' — class name string length 14 ('BufferedWriter'); io.BufferedWriter is the public buffered I/O writer class; its __name__ attribute returns the plain class name as a string; length 14 equals io.BufferedReader.__name__ length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__name__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra198.bufferedwriter_module_eq:
  description: "io.BufferedWriter.__module__ == '_io' — BufferedWriter is implemented in the _io C extension (len=3); although accessed as io.BufferedWriter, the class itself lives in the C extension module _io; this parallels io.BufferedReader which also reports __module__=='_io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra198.bufferedwriter_base_name_eq:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — the direct base class of BufferedWriter is _BufferedIOBase (len=15), which is the internal C-level base class; both BufferedReader and BufferedWriter share _BufferedIOBase as their direct C-level base; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.BufferedWriter.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra198.bufferedwriter_init_qualname_eq:
  description: "io.BufferedWriter.__init__.__qualname__ == 'BufferedWriter.__init__' — the qualified name of the __init__ method is 'BufferedWriter.__init__' (len=23: 'BufferedWriter.'=15 + '__init__'=8 = 23); this is the longest qualname among the methods examined in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__init__.__qualname__.__eq__
  args: ["BufferedWriter.__init__"]
  expected: true

invariant io_extra198.bufferedwriter_write_qualname_eq:
  description: "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' — the qualified name of the write method is 'BufferedWriter.write' (len=20: 'BufferedWriter.'=15 + 'write'=5 = 20); write writes bytes to the buffer and returns the number of bytes written; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.write.__qualname__.__eq__
  args: ["BufferedWriter.write"]
  expected: true

invariant io_extra198.bufferedwriter_flush_qualname_eq:
  description: "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' — the qualified name of the flush method is 'BufferedWriter.flush' (len=20: 'BufferedWriter.'=15 + 'flush'=5 = 20); flush forces buffered data to be written to the raw stream; flush.__qualname__ and write.__qualname__ are both length 20; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.flush.__qualname__.__eq__
  args: ["BufferedWriter.flush"]
  expected: true

invariant io_extra198.bufferedwriter_class_name_type:
  description: "io.BufferedWriter.__class__.__name__ == 'type' — BufferedWriter's metaclass is the plain 'type' (not ABCMeta); this parallels BufferedReader which also uses the plain type metaclass; both are concrete classes and do not use ABCMeta; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra198.bufferedwriter_name_len_eq_reader:
  description: "io.BufferedWriter.__name__.__len__() == 14 — 'BufferedWriter' has 14 characters: B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)W(9)r(10)i(11)t(12)e(13)r(14); this equals the length of io.BufferedReader.__name__ ('BufferedReader'=14); the symmetry arises because 'Reader' and 'Writer' are both 6-character words; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__name__.__len__
  args: []
  expected: 14

