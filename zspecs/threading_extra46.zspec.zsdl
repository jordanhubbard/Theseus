spec: threading_extra46
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra45.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__/__module__; Thread/__qualname__.__len__()==6; Thread/__mro__.__len__()==2; Thread/__bases__[0].__name__=='object'; Event/__qualname__=='Event'; Event/__qualname__.__len__()==5; Event/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Semaphore/__name__/__qualname__/__module__; Semaphore/__qualname__.__len__()==9; Semaphore/__mro__.__len__()==2; BoundedSemaphore/__name__/__qualname__/__module__; BoundedSemaphore/__qualname__.__len__()==16; BoundedSemaphore/__mro__.__len__()==3; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; Condition/__name__/__module__; Condition/__mro__.__len__()==2; Condition/__bases__[0].__name__=='object'; Barrier/__name__/__qualname__/__module__; Barrier/__mro__.__len__()==2; Barrier/__bases__[0].__name__=='object'; Timer/__name__/__qualname__/__module__; Timer/__mro__.__len__()==3; Timer/__bases__[0].__name__=='Thread'; Lock/__name__=='lock'; Lock/__qualname__=='lock'; Lock/__qualname__.__len__()==4; local/__name__=='_local'; TIMEOUT_MAX; threading.__all__.__len__()==28; current_thread/__name__/__module__; main_thread/__name__/__module__; active_count/__name__/__module__; enumerate/__name__/__module__; settrace/__name__; setprofile/__name__; stack_size/__name__."
    - "This spec covers: threading.Thread.__bases__[0].__qualname__ == 'object'; threading.Event.__bases__[0].__qualname__ == 'object'; threading.Semaphore.__bases__[0].__qualname__ == 'object'; threading.BoundedSemaphore.__bases__[0].__qualname__ == 'Semaphore'; threading.Condition.__bases__[0].__qualname__ == 'object'; threading.Barrier.__bases__[0].__qualname__ == 'object'; threading.Timer.__bases__[0].__qualname__ == 'Thread'."
    - "Key findings: Thread, Event, Semaphore, Condition, and Barrier all have __bases__[0].__qualname__ == 'object' — each is a pure-Python class defined at module level in Lib/threading.py that inherits directly from object. BoundedSemaphore.__bases__[0].__qualname__ == 'Semaphore' — BoundedSemaphore extends Semaphore; __qualname__ == __name__ == 'Semaphore' for that class. Timer.__bases__[0].__qualname__ == 'Thread' — Timer extends Thread; __qualname__ == __name__ == 'Thread'. For built-in object and for pure-Python module-level classes, __qualname__ equals __name__. Prior specs recorded __bases__[0].__name__ for all these classes (string equality) but no prior spec recorded __bases__[0].__qualname__ for any threading class. All seven invariants are new to extra46."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading classes that inherit directly from object — __bases__[0].__qualname__
# — extra46 namespace
#
# Thread, Event, Semaphore, Condition, and Barrier are pure-Python classes
# defined at module level in Lib/threading.py. All five inherit directly from
# object as their sole base class. For the built-in object type,
# __qualname__ == __name__ == 'object'. Prior specs recorded
# __bases__[0].__name__ == 'object' for all five (string equality), but no
# prior spec recorded __bases__[0].__qualname__ for any threading class.
# All five invariants are new to extra46.
# ---------------------------------------------------------------------------

table threading_extra46.object_bases_qualname:
  description: "threading Thread/Event/Semaphore/Condition/Barrier __bases__[0].__qualname__ == 'object' — pure-Python classes inheriting directly from object; __qualname__ == __name__ for built-in object type"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: tobq46

  columns: [id, function, args, expected, description]
  rows:
    - [thread_bases_qualname,
       "Thread.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/threading.py; inherits directly from object; represents a thread of execution; MRO is [Thread, object]"]
    - [event_bases_qualname,
       "Event.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/threading.py; inherits directly from object; synchronization flag-based primitive; MRO is [Event, object]"]
    - [semaphore_bases_qualname,
       "Semaphore.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/threading.py; inherits directly from object; counting semaphore synchronization primitive; MRO is [Semaphore, object]"]
    - [condition_bases_qualname,
       "Condition.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/threading.py; inherits directly from object; wait/notify-based synchronization primitive; MRO is [Condition, object]"]
    - [barrier_bases_qualname,
       "Barrier.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/threading.py; inherits directly from object; reusable synchronization barrier for n threads; MRO is [Barrier, object]"]

# ---------------------------------------------------------------------------
# threading.BoundedSemaphore __bases__[0].__qualname__ — extra46 namespace
#
# threading.BoundedSemaphore.__bases__[0].__qualname__ is 'Semaphore' (9 chars).
# BoundedSemaphore is a pure-Python class defined at module level in
# Lib/threading.py that extends Semaphore to prevent release() calls that would
# push the count above the initial value. Its MRO is
# [BoundedSemaphore, Semaphore, object] (length 3, confirmed in a prior spec).
# Semaphore is defined at module level so __qualname__ == __name__ == 'Semaphore'.
# Prior specs recorded BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# (string equality) but no prior spec recorded __bases__[0].__qualname__. New.
# ---------------------------------------------------------------------------

invariant threading_extra46.BoundedSemaphore_bases_qualname:
  description: "threading.BoundedSemaphore.__bases__[0].__qualname__ == 'Semaphore' — extends Semaphore; Semaphore is a module-level class so __qualname__ == __name__ == 'Semaphore'; MRO is [BoundedSemaphore, Semaphore, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__qualname__.__eq__"
  args: ["Semaphore"]
  expected: true

# ---------------------------------------------------------------------------
# threading.Timer __bases__[0].__qualname__ — extra46 namespace
#
# threading.Timer.__bases__[0].__qualname__ is 'Thread' (6 chars). Timer is a
# pure-Python class defined at module level in Lib/threading.py that extends
# Thread to run a function after a specified delay. Its MRO is
# [Timer, Thread, object] (length 3, confirmed in a prior spec). Thread is
# defined at module level so __qualname__ == __name__ == 'Thread'. Prior specs
# recorded Timer.__bases__[0].__name__ == 'Thread' (string equality) via the
# __bases__[0].__name__ invariant, but no prior spec recorded
# Timer.__bases__[0].__qualname__. New to extra46.
# ---------------------------------------------------------------------------

invariant threading_extra46.Timer_bases_qualname:
  description: "threading.Timer.__bases__[0].__qualname__ == 'Thread' — Timer extends Thread; Thread is a module-level class so __qualname__ == __name__ == 'Thread'; MRO is [Timer, Thread, object]; Timer runs a callable after a delay in a separate thread"
  category: class_hierarchy
  kind: python_call_eq
  function: "Timer.__bases__[0].__qualname__.__eq__"
  args: ["Thread"]
  expected: true
