spec: hashlib_extra287
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib algorithms_guaranteed and algorithms_available sets"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py, Modules/_hashopenssl.c"
  notes:
    - "algorithms_guaranteed is a frozenset of hash names guaranteed to be available on all Python platforms"
    - "algorithms_available is a superset of algorithms_guaranteed reflecting what the current OpenSSL supports"
    - "hashlib.new.__name__ returns '__hash_new' on CPython 3.14 macOS (internal implementation detail)"
    - "All 12 algorithms checked in guaranteed set were confirmed present on CPython 3.14 macOS"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra287.algorithms_guaranteed_membership:
  description: "Core algorithms are present in hashlib.algorithms_guaranteed"
  kind: python_call_eq
  category: identity
  id_prefix: hlg

  columns: [id, function, args, expected, description]
  rows:
    - [hlg001, hashlib.algorithms_guaranteed.__contains__, ["sha256"],  true, "sha256 in algorithms_guaranteed"]
    - [hlg002, hashlib.algorithms_guaranteed.__contains__, ["sha512"],  true, "sha512 in algorithms_guaranteed"]
    - [hlg003, hashlib.algorithms_guaranteed.__contains__, ["sha1"],    true, "sha1 in algorithms_guaranteed"]
    - [hlg004, hashlib.algorithms_guaranteed.__contains__, ["md5"],     true, "md5 in algorithms_guaranteed"]
    - [hlg005, hashlib.algorithms_guaranteed.__contains__, ["sha3_256"], true, "sha3_256 in algorithms_guaranteed"]
    - [hlg006, hashlib.algorithms_guaranteed.__contains__, ["blake2b"], true, "blake2b in algorithms_guaranteed"]
    - [hlg007, hashlib.algorithms_guaranteed.__contains__, ["blake2s"], true, "blake2s in algorithms_guaranteed"]
    - [hlg008, hashlib.algorithms_guaranteed.__contains__, ["sha224"],  true, "sha224 in algorithms_guaranteed"]
    - [hlg009, hashlib.algorithms_guaranteed.__contains__, ["sha384"],  true, "sha384 in algorithms_guaranteed"]
    - [hlg010, hashlib.algorithms_guaranteed.__contains__, ["sha3_512"], true, "sha3_512 in algorithms_guaranteed"]
    - [hlg011, hashlib.algorithms_guaranteed.__contains__, ["sha3_224"], true, "sha3_224 in algorithms_guaranteed"]
    - [hlg012, hashlib.algorithms_guaranteed.__contains__, ["sha3_384"], true, "sha3_384 in algorithms_guaranteed"]

table hashlib_extra287.algorithms_available_superset:
  description: "algorithms_available contains all guaranteed algorithms"
  kind: python_call_eq
  category: identity
  id_prefix: hla

  columns: [id, function, args, expected, description]
  rows:
    - [hla001, hashlib.algorithms_available.__contains__, ["sha256"],  true, "sha256 in algorithms_available"]
    - [hla002, hashlib.algorithms_available.__contains__, ["sha512"],  true, "sha512 in algorithms_available"]
    - [hla003, hashlib.algorithms_available.__contains__, ["sha1"],    true, "sha1 in algorithms_available"]
    - [hla004, hashlib.algorithms_available.__contains__, ["md5"],     true, "md5 in algorithms_available"]
    - [hla005, hashlib.algorithms_available.__contains__, ["sha3_256"], true, "sha3_256 in algorithms_available"]
    - [hla006, hashlib.algorithms_available.__contains__, ["blake2b"], true, "blake2b in algorithms_available"]
    - [hla007, hashlib.algorithms_available.__contains__, ["blake2s"], true, "blake2s in algorithms_available"]
    - [hla008, hashlib.algorithms_available.__contains__, ["sha224"],  true, "sha224 in algorithms_available"]
    - [hla009, hashlib.algorithms_available.__contains__, ["sha384"],  true, "sha384 in algorithms_available"]
    - [hla010, hashlib.algorithms_available.__contains__, ["sha3_512"], true, "sha3_512 in algorithms_available"]
    - [hla011, hashlib.algorithms_available.__contains__, ["sha3_224"], true, "sha3_224 in algorithms_available"]
    - [hla012, hashlib.algorithms_available.__contains__, ["sha3_384"], true, "sha3_384 in algorithms_available"]

invariant hashlib_extra287.new_module:
  description: "hashlib.new is defined in the hashlib module"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__module__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra287.algorithms_guaranteed_is_set:
  description: "hashlib.algorithms_guaranteed is a set"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra287.algorithms_available_is_set:
  description: "hashlib.algorithms_available is a set"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true
