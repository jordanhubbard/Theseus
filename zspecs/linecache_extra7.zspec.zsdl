spec: linecache_extra7
version: ">=3.9"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/linecache.html — Python linecache module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py"
    - "linecache.zspec.zsdl — covers function_names table; getline for /nonexistent_path_xyz/file.py; getlines nonexistent; clearcache/checkcache return None."
    - "linecache_extra.zspec.zsdl — covers getline/__name__/__module__; getlines/__name__; clearcache/__name__; checkcache/__name__; cache.__class__.__name__=='dict'; getline('',1)==''."
    - "linecache_extra2.zspec.zsdl — covers all six functions by __name__ and __module__; cache.__class__.__name__=='dict'."
    - "linecache_extra3.zspec.zsdl — covers function_names table; getline.__module__ standalone; updatecache.__name__ standalone; checkcache.__class__.__name__=='function'; getlines('/dev/null',{}).__class__.__name__=='list'; getline('nonexistent_file_xyz.py',1)==''."
    - "linecache_extra4.zspec.zsdl — covers __qualname__ for getline/getlines/clearcache/checkcache/updatecache; getline('/dev/null',1)==''; getlines('/dev/null')==[]."
    - "linecache_extra5.zspec.zsdl — covers lazycache.__qualname__; __class__.__name__=='function' for getline/getlines/clearcache/updatecache/lazycache; getline('',0)==''."
    - "linecache_extra6.zspec.zsdl — covers getline('/dev/null',2)/('/dev/null',-1)/('',2)/('/nonexistent_path_xyz/file.py',100); getlines('')==[]; getlines('nonexistent_file_xyz.txt')==[]; getlines('nonexistent_file_xyz.txt',{}).__class__.__name__=='list'; checkcache(None)==None."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior linecache spec."
    - "Focus: __module__ attributes for all six public functions as a consolidated table in the extra7 namespace; cache.__class__.__name__ == 'dict' re-anchor; getline return type; getlines return type."
    - "linecache.getline.__module__ == 'linecache' — extra1/extra2 cover this; the extra7 table re-anchors it under the new namespace."
    - "linecache.getlines.__module__ == 'linecache' — same rationale."
    - "linecache.clearcache.__module__ == 'linecache' — same rationale."
    - "linecache.checkcache.__module__ == 'linecache' — same rationale."
    - "linecache.lazycache.__module__ == 'linecache' — same rationale."
    - "linecache.updatecache.__module__ == 'linecache' — same rationale."
    - "linecache.cache.__class__.__name__ == 'dict' — extra1/extra2/extra3 cover this; re-anchored here as a standalone invariant under extra7."
    - "linecache.getline.__name__ == 'getline' — base spec and extras cover this; re-anchored as standalone invariants in extra7 for the four most-used functions."
    - "linecache.getlines.__name__ == 'getlines' — same rationale."
    - "linecache.clearcache.__name__ == 'clearcache' — same rationale."
    - "linecache.checkcache.__name__ == 'checkcache' — same rationale."
    - "linecache.getline('', 0).__class__.__name__ == 'str' — getline always returns str; extra5 covers getline('',0)=='' (value); this checks the return type independently."
    - "linecache.getlines('').__class__.__name__ == 'list' — getlines always returns list; extra6 covers getlines('')==[] (value); this checks the return type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — all six public linecache functions
#
# linecache_extra and linecache_extra2 cover __module__ for these functions.
# This table re-anchors all six under the extra7 namespace as a consolidated
# regression fixture.
# ---------------------------------------------------------------------------

table linecache_extra7.function_modules:
  kind: python_call_eq
  category: function_identity
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [getline,    getline.__module__.__eq__,    ["linecache"], true]
    - [getlines,   getlines.__module__.__eq__,   ["linecache"], true]
    - [clearcache, clearcache.__module__.__eq__, ["linecache"], true]
    - [checkcache, checkcache.__module__.__eq__, ["linecache"], true]
    - [lazycache,  lazycache.__module__.__eq__,  ["linecache"], true]
    - [updatecache, updatecache.__module__.__eq__, ["linecache"], true]

# ---------------------------------------------------------------------------
# __name__ checks — four primary public functions
#
# Base spec and prior extras cover __name__ for all public functions.
# These standalone extra7 invariants re-anchor the four most-used functions.
# ---------------------------------------------------------------------------

invariant linecache_extra7.getline.name:
  description: "linecache.getline.__name__ == 'getline'"
  category: function_identity
  kind: python_call_eq
  function: getline.__name__.__eq__
  args: ["getline"]
  expected: true

invariant linecache_extra7.getlines.name:
  description: "linecache.getlines.__name__ == 'getlines'"
  category: function_identity
  kind: python_call_eq
  function: getlines.__name__.__eq__
  args: ["getlines"]
  expected: true

invariant linecache_extra7.clearcache.name:
  description: "linecache.clearcache.__name__ == 'clearcache'"
  category: function_identity
  kind: python_call_eq
  function: clearcache.__name__.__eq__
  args: ["clearcache"]
  expected: true

invariant linecache_extra7.checkcache.name:
  description: "linecache.checkcache.__name__ == 'checkcache'"
  category: function_identity
  kind: python_call_eq
  function: checkcache.__name__.__eq__
  args: ["checkcache"]
  expected: true

# ---------------------------------------------------------------------------
# cache.__class__.__name__ == 'dict'
#
# linecache.cache is the module-level dict used to store cached file contents.
# extra1/extra2/extra3 all cover this. This extra7 invariant re-anchors it
# under the new namespace.
# ---------------------------------------------------------------------------

invariant linecache_extra7.cache.class_name:
  description: "linecache.cache.__class__.__name__ == 'dict' — linecache.cache is a dict"
  category: module_attributes
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# Return type checks — getline and getlines
#
# Prior specs verify specific return values ('' or []).
# These invariants verify that the return types are always str and list
# respectively, using empty-filename calls that are stable across all platforms.
# extra5 covers getline('',0)=='' (value); extra6 covers getlines('')==[] (value).
# The type checks here are a distinct dimension not previously covered.
# ---------------------------------------------------------------------------

invariant linecache_extra7.getline.return_type:
  description: "linecache.getline('', 0).__class__.__name__ == 'str' — getline always returns str"
  category: return_types
  kind: python_call_eq
  function: getline
  args: ["", 0]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant linecache_extra7.getlines.return_type:
  description: "linecache.getlines('').__class__.__name__ == 'list' — getlines always returns list"
  category: return_types
  kind: python_call_eq
  function: getlines
  args: [""]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true
