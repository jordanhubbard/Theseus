spec: pygments_rust
version: ">=3.9"
backend: rust_module(pygments_rust)

docs: https://pygments.org/docs/api/#pygments.lexers.get_lexer_by_name

provenance:
  derived_from:
    - "https://pygments.org/docs/api/ — Pygments API documentation"
  not_derived_from:
    - "Pygments source: pygments/lexers/__init__.py"
  notes:
    - "Clean-room Rust reimplementation of Pygments lexer lookup, exposed via PyO3."
    - "get_lexer_by_name is imported from pygments.lexers."
    - "get_lexer_by_name('python').name == 'Python'."
    - "get_lexer_by_name('json').name == 'JSON'."
    - "get_lexer_by_name('javascript').name == 'JavaScript'."
    - "get_lexer_by_name('rust').name == 'Rust'."
    - "get_lexer_by_name('sql').name == 'SQL'."
    - "get_lexer_by_name('html').name == 'HTML'."
    - "get_lexer_by_name('yaml').name == 'YAML'."
    - "All test vectors verified against Pygments 2.19.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# get_lexer_by_name — lexer name lookup
table pygments_rust.get_lexer_by_name.name:
  kind: python_call_eq
  category: lexer_name
  id_prefix: pyg_lex
  function: get_lexer_by_name
  method: name

  columns: [id, args, expected]
  rows:
    - [python,     ["python"],     "Python"]
    - [json,       ["json"],       "JSON"]
    - [javascript, ["javascript"], "JavaScript"]
    - [rust,       ["rust"],       "Rust"]
    - [sql,        ["sql"],        "SQL"]
    - [html,       ["html"],       "HTML"]
    - [yaml,       ["yaml"],       "YAML"]
    - [bash,       ["bash"],       "Bash"]

# get_lexer_by_name — aliases (case-insensitive)
invariant pygments_rust.get_lexer_by_name.alias_py:
  description: "get_lexer_by_name('py').name == 'Python'"
  category: lexer_alias
  kind: python_call_eq
  function: get_lexer_by_name
  args: ["py"]
  method: name
  expected: "Python"

invariant pygments_rust.get_lexer_by_name.alias_js:
  description: "get_lexer_by_name('js').name == 'JavaScript'"
  category: lexer_alias
  kind: python_call_eq
  function: get_lexer_by_name
  args: ["js"]
  method: name
  expected: "JavaScript"

