spec: concurrent_futures_extra177
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.Future instance method names — concurrent.futures.Future.__init__.__name__=='__init__' (len=8); concurrent.futures.Future.__repr__.__name__=='__repr__' (len=8; same); concurrent.futures.Future._Future__get_result.__name__=='__get_result' (len=12; name-mangled private method); concurrent.futures.Future.exception.__name__=='exception' (len=9); concurrent.futures.Future.exception.__qualname__=='Future.exception' (len=16); concurrent.futures.Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24)."
    - "concurrent.futures.Future.__init__.__name__ == '__init__' (len=8: __init__). concurrent.futures.Future.__repr__.__name__ == '__repr__' (len=8: __repr__). Both __init__ and __repr__ share the same name length of 8. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future._Future__get_result.__name__ == '__get_result' (len=12). The private method __get_result is name-mangled by Python to _Future__get_result on the class, but retains its original __name__ attribute of '__get_result'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.exception.__name__ == 'exception' (len=9). concurrent.futures.Future.exception.__qualname__ == 'Future.exception' (len=16: F-u-t-u-r-e-.-e-x-c-e-p-t-i-o-n = 16). The __qualname__ includes the class name and a dot. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24: Future=6+'.'=1+add_done_callback=17=24). This is the longest qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future.__init__ and __repr__ method __name__ identity
#
# Future.__init__.__name__ == '__init__' (len=8)
# Future.__repr__.__name__ == '__repr__' (len=8; same as __init__)
#
# Both dunder methods share the same name length of 8.
# New to extra177.
# ---------------------------------------------------------------------------

table concurrent_futures_extra177.future_dunder_init_repr:
  description: "Future.__init__.__name__ '__init__' len 8; Future.__repr__.__name__ '__repr__' len 8 (same); new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: cffutmethods177

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,
       Future.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "concurrent.futures.Future.__init__.__name__.__eq__('__init__') == True — Future.__init__ is the constructor that sets up internal state (condition, state, result, callbacks); its __name__ is '__init__' (8 chars: _-_-i-n-i-t-_-_); str.__eq__('__init__') returns True; new to extra177"]
    - [init_name_len_8,
       Future.__init__.__name__.__len__,
       [],
       8,
       "concurrent.futures.Future.__init__.__name__.__len__() == 8 — '__init__' has 8 characters: __init__=8 (two underscores each side of 'init'=4); same length as '__repr__'=8; str.__len__() returns 8; new to extra177"]
    - [repr_name_eq,
       Future.__repr__.__name__.__eq__,
       ["__repr__"],
       true,
       "concurrent.futures.Future.__repr__.__name__.__eq__('__repr__') == True — Future.__repr__ produces a human-readable string representation including the future's state; its __name__ is '__repr__' (8 chars: _-_-r-e-p-r-_-_); str.__eq__('__repr__') returns True; new to extra177"]
    - [repr_name_len_8,
       Future.__repr__.__name__.__len__,
       [],
       8,
       "concurrent.futures.Future.__repr__.__name__.__len__() == 8 — '__repr__' has 8 characters: __repr__=8 (two underscores each side of 'repr'=4); same length as '__init__'=8; str.__len__() returns 8; new to extra177"]
    - [init_repr_same_len,
       Future.__init__.__name__.__len__,
       [],
       8,
       "concurrent.futures.Future.__init__.__name__.__len__() == 8 confirming __init__ and __repr__ share name length 8; both dunder methods have the same 8-char name; new to extra177"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.Future._Future__get_result (private __get_result)
#
# Future._Future__get_result.__name__ == '__get_result' (len=12)
#
# Python name-mangles Future.__get_result to _Future__get_result on the class,
# but the function's own __name__ attribute retains the original '__get_result'.
# New to extra177.
# ---------------------------------------------------------------------------

table concurrent_futures_extra177.future_get_result:
  description: "Future._Future__get_result.__name__ '__get_result' len 12 (name-mangled private method); new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: cffutmethods177

  columns: [id, function, args, expected, description]
  rows:
    - [get_result_name_eq,
       _Future__get_result.__name__.__eq__,
       ["__get_result"],
       true,
       "concurrent.futures.Future._Future__get_result.__name__.__eq__('__get_result') == True — __get_result is a private method name-mangled by Python to _Future__get_result; despite the mangled class attribute name, the function's __name__ retains '__get_result' (12 chars: _-_-g-e-t-_-r-e-s-u-l-t); str.__eq__('__get_result') returns True; new to extra177"]
    - [get_result_name_len_12,
       _Future__get_result.__name__.__len__,
       [],
       12,
       "concurrent.futures.Future._Future__get_result.__name__.__len__() == 12 — '__get_result' has 12 characters: __=2+get=3+_=1+result=6=12; longest method __name__ in this spec; NAME LENGTHS: __init__=__repr__=8 < exception=9 < __get_result=12; str.__len__() returns 12; new to extra177"]
    - [get_result_name_class_eq,
       _Future__get_result.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "concurrent.futures.Future._Future__get_result.__name__.__class__.__name__.__eq__('str') == True — __name__ is a str object; its class name is 'str'; str.__eq__('str') returns True; new to extra177"]
    - [get_result_longer_than_init,
       _Future__get_result.__name__.__len__,
       [],
       12,
       "concurrent.futures.Future._Future__get_result.__name__.__len__() == 12 confirming __get_result (12) > __init__=__repr__ (8) > exception (9) — wait, 12 > 9 > 8; NAME LENGTHS: __init__=__repr__=8 < exception=9 < __get_result=12; new to extra177"]
    - [get_result_qualname_eq,
       _Future__get_result.__qualname__.__eq__,
       ["Future.__get_result"],
       true,
       "concurrent.futures.Future._Future__get_result.__qualname__.__eq__('Future.__get_result') == True — the __qualname__ of the private method includes the class name 'Future' and the unmangled method name '__get_result'; str.__eq__('Future.__get_result') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.Future.exception and add_done_callback qualnames
#
# Future.exception.__name__ == 'exception' (len=9)
# Future.exception.__qualname__ == 'Future.exception' (len=16)
# Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24)
#
# __qualname__ includes the enclosing class name and a dot separator.
# New to extra177.
# ---------------------------------------------------------------------------

table concurrent_futures_extra177.future_qualnames:
  description: "Future.exception.__name__ 'exception' len 9; exception.__qualname__ 'Future.exception' len 16; add_done_callback.__qualname__ 'Future.add_done_callback' len 24; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: cffutmethods177

  columns: [id, function, args, expected, description]
  rows:
    - [exception_name_eq,
       Future.exception.__name__.__eq__,
       ["exception"],
       true,
       "concurrent.futures.Future.exception.__name__.__eq__('exception') == True — Future.exception returns the exception raised by the call (or None if the call hasn't been completed or was cancelled); its __name__ is 'exception' (9 chars: e-x-c-e-p-t-i-o-n); str.__eq__('exception') returns True; new to extra177"]
    - [exception_name_len_9,
       Future.exception.__name__.__len__,
       [],
       9,
       "concurrent.futures.Future.exception.__name__.__len__() == 9 — 'exception' has 9 characters: e-x-c-e-p-t-i-o-n; NAME LENGTHS: __init__=__repr__=8 < exception=9 < __get_result=12; str.__len__() returns 9; new to extra177"]
    - [exception_qualname_eq,
       Future.exception.__qualname__.__eq__,
       ["Future.exception"],
       true,
       "concurrent.futures.Future.exception.__qualname__.__eq__('Future.exception') == True — the __qualname__ of a method defined in a class is 'ClassName.method_name'; for Future.exception it is 'Future.exception' (16 chars: Future=6+'.'=1+exception=9=16); str.__eq__('Future.exception') returns True; new to extra177"]
    - [exception_qualname_len_16,
       Future.exception.__qualname__.__len__,
       [],
       16,
       "concurrent.futures.Future.exception.__qualname__.__len__() == 16 — 'Future.exception' has 16 characters: Future=6+'.'=1+exception=9=16; str.__len__() returns 16; new to extra177"]
    - [add_done_callback_qualname_eq,
       Future.add_done_callback.__qualname__.__eq__,
       ["Future.add_done_callback"],
       true,
       "concurrent.futures.Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback') == True — add_done_callback registers a callback to be called when the future completes; its __qualname__ is 'Future.add_done_callback' (24 chars: Future=6+'.'=1+add_done_callback=17=24); str.__eq__('Future.add_done_callback') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra177
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra177.future_init_name_eq:
  description: "concurrent.futures.Future.__init__.__name__ == '__init__' — constructor method; name len=8; same as __repr__; new to extra177"
  category: identity
  kind: python_call_eq
  function: Future.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant concurrent_futures_extra177.future_repr_name_len_8:
  description: "concurrent.futures.Future.__repr__.__name__.__len__() == 8 — '__repr__' has 8 chars; same length as '__init__'=8; new to extra177"
  category: identity
  kind: python_call_eq
  function: Future.__repr__.__name__.__len__
  args: []
  expected: 8

invariant concurrent_futures_extra177.future_get_result_name_eq:
  description: "concurrent.futures.Future._Future__get_result.__name__ == '__get_result' — name-mangled private method; original __name__ retained; len=12; new to extra177"
  category: identity
  kind: python_call_eq
  function: _Future__get_result.__name__.__eq__
  args: ["__get_result"]
  expected: true

invariant concurrent_futures_extra177.future_exception_name_len_9:
  description: "concurrent.futures.Future.exception.__name__.__len__() == 9 — 'exception' has 9 chars; NAME LENGTHS: __init__=__repr__=8 < exception=9 < __get_result=12; new to extra177"
  category: identity
  kind: python_call_eq
  function: Future.exception.__name__.__len__
  args: []
  expected: 9

invariant concurrent_futures_extra177.future_exception_qualname_eq:
  description: "concurrent.futures.Future.exception.__qualname__ == 'Future.exception' — qualname includes class name; len=16 (Future=6+.=1+exception=9=16); new to extra177"
  category: identity
  kind: python_call_eq
  function: Future.exception.__qualname__.__eq__
  args: ["Future.exception"]
  expected: true

invariant concurrent_futures_extra177.future_add_done_callback_qualname_len_24:
  description: "concurrent.futures.Future.add_done_callback.__qualname__.__len__() == 24 — 'Future.add_done_callback' has 24 chars (Future=6+.=1+add_done_callback=17=24); longest qualname in this spec; new to extra177"
  category: identity
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__len__
  args: []
  expected: 24
