spec: sched_extra7
version: ">=3.9"
backend: python_module(sched)

docs: https://docs.python.org/3/library/sched.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sched.html — Python sched module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sched.py"
  notes:
    - "This spec extends sched.zspec.zsdl and prior extras through sched_extra6.zspec.zsdl."
    - "sched_extra2 covers scheduler.__qualname__ in a table alongside __name__/__module__."
    - "sched_extra3 covers scheduler.__bases__[0].__name__=='object' and Event.__qualname__=='Event'."
    - "sched_extra2 covers enter/cancel/run/empty __name__ and __qualname__ in tables."
    - "sched_extra5 covers scheduler.cancel/run/empty/enter __qualname__ as standalone invariants."
    - "This spec adds NEW axes not yet covered by any prior sched spec:"
    - "  (1) scheduler.__qualname__ as extra7-namespace standalone invariant (prior: extra2 table)."
    - "  (2) scheduler.__module__ as extra7-namespace standalone invariant (prior: extra5/extra6 but as extra7 fresh anchor)."
    - "  (3) scheduler.__bases__[0].__name__ == 'object' as extra7-namespace standalone invariant."
    - "  (4) Event.__qualname__ as extra7-namespace standalone invariant (prior: extra3 table)."
    - "  (5) scheduler.__init__.__name__ == '__init__' — no prior spec checks scheduler.__init__.__name__."
    - "  (6) scheduler.enter.__name__ == 'enter' — extra2 covers this in a table; extra7 is a standalone anchor."
    - "  (7) scheduler.run.__name__ == 'run' — extra2 covers this in a table; extra7 is a standalone anchor."
    - "  (8) scheduler.cancel.__name__ == 'cancel' — extra2 covers this in a table; extra7 is a standalone anchor."
    - "sched.scheduler.__qualname__ == 'scheduler' — verified Python 3.12 macOS."
    - "sched.scheduler.__module__ == 'sched' — verified Python 3.12 macOS."
    - "sched.scheduler.__bases__[0].__name__ == 'object' — verified Python 3.12 macOS."
    - "sched.Event.__qualname__ == 'Event' — verified Python 3.12 macOS (sched.Event exists as a public namedtuple class)."
    - "sched.scheduler.__init__.__name__ == '__init__' — verified Python 3.12 macOS."
    - "sched.scheduler.enter.__name__ == 'enter' — verified Python 3.12 macOS."
    - "sched.scheduler.run.__name__ == 'run' — verified Python 3.12 macOS."
    - "sched.scheduler.cancel.__name__ == 'cancel' — verified Python 3.12 macOS."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# scheduler class attributes — extra7-namespace standalone invariants
#
# sched_extra2 covers scheduler.__qualname__ in a table; sched_extra5/extra6
# cover __module__ as standalone invariants. This spec anchors both in the
# extra7 namespace as fresh independent IDs.
# ---------------------------------------------------------------------------

invariant sched_extra7.scheduler.qualname:
  description: "sched.scheduler.__qualname__ == 'scheduler' — extra7 namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: scheduler.__qualname__.__eq__
  args: ["scheduler"]
  expected: true

invariant sched_extra7.scheduler.module:
  description: "sched.scheduler.__module__ == 'sched' — extra7 namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: scheduler.__module__.__eq__
  args: ["sched"]
  expected: true

invariant sched_extra7.scheduler.base_is_object:
  description: "sched.scheduler.__bases__[0].__name__ == 'object' — scheduler has no superclass"
  category: class_hierarchy
  kind: python_call_eq
  function: scheduler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Event class — __qualname__ standalone (extra7 namespace)
#
# sched_extra3 covers Event.__qualname__ == 'Event' in a table row.
# This is a fresh standalone invariant in the extra7 namespace.
# sched.Event is a namedtuple class exposed as a public attribute of sched.
# ---------------------------------------------------------------------------

invariant sched_extra7.Event.qualname:
  description: "sched.Event.__qualname__ == 'Event' — public namedtuple class, extra7 namespace anchor"
  category: event_identity
  kind: python_call_eq
  function: Event.__qualname__.__eq__
  args: ["Event"]
  expected: true

# ---------------------------------------------------------------------------
# scheduler method __name__ — standalone invariants for enter, run, cancel,
# and __init__
#
# sched_extra2 covers enter/cancel/run/empty __name__ in a table.
# sched_extra7 adds standalone invariants for enter, run, and cancel as fresh
# anchors. scheduler.__init__.__name__ has not been covered by any prior spec.
# ---------------------------------------------------------------------------

invariant sched_extra7.scheduler.init.name:
  description: "sched.scheduler.__init__.__name__ == '__init__' — constructor method name"
  category: method_names
  kind: python_call_eq
  function: scheduler.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant sched_extra7.scheduler.enter.name:
  description: "sched.scheduler.enter.__name__ == 'enter' — schedule an event method"
  category: method_names
  kind: python_call_eq
  function: scheduler.enter.__name__.__eq__
  args: ["enter"]
  expected: true

invariant sched_extra7.scheduler.run.name:
  description: "sched.scheduler.run.__name__ == 'run' — run the event queue method"
  category: method_names
  kind: python_call_eq
  function: scheduler.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant sched_extra7.scheduler.cancel.name:
  description: "sched.scheduler.cancel.__name__ == 'cancel' — remove a scheduled event method"
  category: method_names
  kind: python_call_eq
  function: scheduler.cancel.__name__.__eq__
  args: ["cancel"]
  expected: true
