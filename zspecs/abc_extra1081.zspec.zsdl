spec: abc_extra1081
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta.register, ABC.__doc__, abstractmethod descriptor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks ABCMeta.register return-value class, ABC.__doc__.__class__.__name__, abstractmethod.__isabstractmethod__.__class__.__name__, ABCMeta.__abstractmethods__ descriptor identity — behaviors not covered by extra1051 or extra1066"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1081.abcmeta_register_identity:
  description: "abc.ABCMeta.register method qualname and class identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab1081rg
  columns: [id, function, args, expected]
  rows:
    - [ab1081rg001, abc.ABCMeta.register.__qualname__.__eq__,        ["ABCMeta.register"],        true]
    - [ab1081rg002, abc.ABCMeta.register.__name__.__eq__,            ["register"],                true]
    - [ab1081rg003, abc.ABCMeta.register.__module__.__eq__,          ["abc"],                     true]
    - [ab1081rg004, abc.ABCMeta.register.__class__.__name__.__eq__,  ["function"],                true]
    - [ab1081rg005, abc.ABCMeta.__prepare__.__qualname__.__eq__,     ["ABCMeta.__prepare__"],     true]
    - [ab1081rg006, abc.ABCMeta.__prepare__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1081rg007, abc.ABCMeta.__qualname__.__eq__,                 ["ABCMeta"],                 true]

table abc_extra1081.abstractmethod_descriptor_identity:
  description: "abc.abstractmethod __isabstractmethod__ class name and descriptor identity"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: ab1081ad
  columns: [id, function, args, expected]
  rows:
    - [ab1081ad001, abc.abstractmethod.__isabstractmethod__.__class__.__name__.__eq__, ["bool"],        true]
    - [ab1081ad002, abc.abstractmethod.__dict__.__class__.__name__.__eq__,             ["mappingproxy"], true]
    - [ab1081ad003, abc.abstractmethod.__weakref__.__class__.__name__.__eq__,          ["getset_descriptor"], true]
    - [ab1081ad004, abc.abstractmethod.__new__.__qualname__.__eq__,                    ["object.__new__"], true]
    - [ab1081ad005, abc.abstractmethod.__repr__.__qualname__.__eq__,                   ["object.__repr__"], true]
    - [ab1081ad006, abc.abstractmethod.__call__.__qualname__.__eq__,                   ["abstractmethod.__call__"], true]
    - [ab1081ad007, abc.abstractmethod.__call__.__class__.__name__.__eq__,             ["slot_wrapper"], true]

table abc_extra1081.abcmeta_abstractmethods_descriptor:
  description: "abc.ABCMeta instancecheck/subclasscheck qualnames and ABCMeta name identity"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: ab1081am
  columns: [id, function, args, expected]
  rows:
    - [ab1081am001, abc.ABCMeta.__instancecheck__.__qualname__.__eq__,         ["ABCMeta.__instancecheck__"],  true]
    - [ab1081am002, abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,   ["function"],                   true]
    - [ab1081am003, abc.ABCMeta.__instancecheck__.__module__.__eq__,           ["abc"],                        true]
    - [ab1081am004, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,         ["ABCMeta.__subclasscheck__"],  true]
    - [ab1081am005, abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,   ["function"],                   true]
    - [ab1081am006, abc.ABCMeta.__subclasscheck__.__module__.__eq__,           ["abc"],                        true]
    - [ab1081am007, abc.ABCMeta.__name__.__eq__,                               ["ABCMeta"],                    true]
