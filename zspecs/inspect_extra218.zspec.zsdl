spec: inspect_extra218
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect module-level predicate function results for False and True cases (wave 384)."
    - "inspect.isfunction(42) == False; isfunction(int) == False; isfunction(len) == False. Verified with Python 3.14.3."
    - "inspect.isfunction(lambda: None) == True. Verified with Python 3.14.3."
    - "inspect.isclass(42) == False; isclass(lambda: None) == False. Verified with Python 3.14.3."
    - "inspect.isclass(int) == True; isclass(type) == True. Verified with Python 3.14.3."
    - "inspect.ismodule(42) == False; ismodule(int) == False. Verified with Python 3.14.3."
    - "inspect.ismodule(inspect) == True. Verified with Python 3.14.3."
    - "inspect.isbuiltin(42) == False; isbuiltin(lambda: None) == False. Verified with Python 3.14.3."
    - "inspect.isbuiltin(len) == True; isbuiltin(print) == True. Verified with Python 3.14.3."
    - "inspect.isroutine(len) == True; isroutine(lambda: None) == True; isroutine(42) == False. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isfunction — False cases
#
# isfunction returns True only for Python functions created by def/lambda.
# It returns False for integers, built-in functions, and classes.
#
# Verified with Python 3.14.3:
#   isfunction(42) == False
#   isfunction(int) == False   (int is a class, not a function)
#   isfunction(len) == False   (len is a built-in, not a Python function)
# ---------------------------------------------------------------------------

table inspect_extra218.isfunction_false_cases:
  description: "inspect.isfunction returns False for int, class, and builtin inputs; wave 384; new to extra218"
  kind: python_call_eq
  category: behavior
  id_prefix: inspectextra218isfuncfalse

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_42_is_false,
       isfunction,
       [42],
       false,
       "inspect.isfunction(42) == False — 42 is a plain integer, not a Python function; isfunction checks for CPython function objects (type.__name__ == 'function'); returns False; new to extra218"]
    - [isfunction_int_is_false,
       isfunction,
       [int],
       false,
       "inspect.isfunction(int) == False — int is a built-in class/type, not a Python-defined function; isfunction returns False for class objects; new to extra218"]
    - [isfunction_len_is_false,
       isfunction,
       [len],
       false,
       "inspect.isfunction(len) == False — len is a C-level built-in function; isfunction only returns True for Python-defined functions (types.FunctionType); returns False for built-ins; new to extra218"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isfunction — True cases
#
# lambda creates a Python function object (types.FunctionType).
# def-defined functions also return True.
#
# Verified with Python 3.14.3:
#   isfunction(lambda: None) == True
# ---------------------------------------------------------------------------

table inspect_extra218.isfunction_true_cases:
  description: "inspect.isfunction returns True for Python-defined functions; wave 384; new to extra218"
  kind: python_call_eq
  category: behavior
  id_prefix: inspectextra218isfunctrue

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_lambda_is_true,
       isfunction,
       [lambda: None],
       true,
       "inspect.isfunction(lambda: None) == True — a lambda expression creates a Python function object (types.FunctionType); isfunction returns True for Python-defined functions; new to extra218"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isclass — False and True cases
#
# isclass returns True for class objects (instances of type or subclasses).
# It returns False for integers, lambda functions, and instances.
#
# Verified with Python 3.14.3:
#   isclass(42) == False
#   isclass(lambda: None) == False
#   isclass(int) == True
#   isclass(type) == True
# ---------------------------------------------------------------------------

table inspect_extra218.isclass_cases:
  description: "inspect.isclass returns False for non-class inputs, True for class objects; wave 384; new to extra218"
  kind: python_call_eq
  category: behavior
  id_prefix: inspectextra218isclass

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_42_is_false,
       isclass,
       [42],
       false,
       "inspect.isclass(42) == False — 42 is an integer instance, not a class; isclass checks isinstance(obj, type); returns False; new to extra218"]
    - [isclass_lambda_is_false,
       isclass,
       [lambda: None],
       false,
       "inspect.isclass(lambda: None) == False — a lambda is a function object (types.FunctionType), not a class; isclass returns False; new to extra218"]
    - [isclass_int_is_true,
       isclass,
       [int],
       true,
       "inspect.isclass(int) == True — int is a built-in type (a class object); isinstance(int, type) == True; isclass returns True; new to extra218"]
    - [isclass_type_is_true,
       isclass,
       [type],
       true,
       "inspect.isclass(type) == True — type is the metaclass and is itself a class; isinstance(type, type) == True; isclass returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 4: inspect.ismodule — False and True cases
#
# ismodule returns True only for module objects.
#
# Verified with Python 3.14.3:
#   ismodule(42) == False
#   ismodule(int) == False
#   ismodule(inspect) == True
# ---------------------------------------------------------------------------

table inspect_extra218.ismodule_cases:
  description: "inspect.ismodule returns False for non-module inputs, True for module objects; wave 384; new to extra218"
  kind: python_call_eq
  category: behavior
  id_prefix: inspectextra218ismodule

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_42_is_false,
       ismodule,
       [42],
       false,
       "inspect.ismodule(42) == False — 42 is an integer; ismodule checks isinstance(obj, types.ModuleType); returns False; new to extra218"]
    - [ismodule_int_is_false,
       ismodule,
       [int],
       false,
       "inspect.ismodule(int) == False — int is a built-in type, not a module; ismodule returns False; new to extra218"]
    - [ismodule_inspect_is_true,
       ismodule,
       [inspect],
       true,
       "inspect.ismodule(inspect) == True — inspect is a module object; isinstance(inspect, types.ModuleType) == True; ismodule returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 5: inspect.isbuiltin — False and True cases
#
# isbuiltin returns True for C-level built-in function objects.
#
# Verified with Python 3.14.3:
#   isbuiltin(42) == False
#   isbuiltin(lambda: None) == False
#   isbuiltin(len) == True
#   isbuiltin(print) == True
# ---------------------------------------------------------------------------

table inspect_extra218.isbuiltin_cases:
  description: "inspect.isbuiltin returns False for non-builtin inputs, True for C-level builtins; wave 384; new to extra218"
  kind: python_call_eq
  category: behavior
  id_prefix: inspectextra218isbuiltin

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_42_is_false,
       isbuiltin,
       [42],
       false,
       "inspect.isbuiltin(42) == False — 42 is an integer; isbuiltin checks isinstance(obj, types.BuiltinFunctionType); returns False; new to extra218"]
    - [isbuiltin_lambda_is_false,
       isbuiltin,
       [lambda: None],
       false,
       "inspect.isbuiltin(lambda: None) == False — a lambda is a Python function object, not a C-level built-in; isbuiltin returns False; new to extra218"]
    - [isbuiltin_len_is_true,
       isbuiltin,
       [len],
       true,
       "inspect.isbuiltin(len) == True — len is a C-level built-in function (types.BuiltinFunctionType); isbuiltin returns True; new to extra218"]
    - [isbuiltin_print_is_true,
       isbuiltin,
       [print],
       true,
       "inspect.isbuiltin(print) == True — print is a C-level built-in function; isbuiltin returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 6: inspect.isroutine — False and True cases
#
# isroutine is a broader check that returns True for any callable that is
# a function, method, built-in, or generator function.
#
# Verified with Python 3.14.3:
#   isroutine(len) == True
#   isroutine(lambda: None) == True
#   isroutine(42) == False
# ---------------------------------------------------------------------------

table inspect_extra218.isroutine_cases:
  description: "inspect.isroutine returns True for callables (builtins, functions), False for non-callables; wave 384; new to extra218"
  kind: python_call_eq
  category: behavior
  id_prefix: inspectextra218isroutine

  columns: [id, function, args, expected, description]
  rows:
    - [isroutine_len_is_true,
       isroutine,
       [len],
       true,
       "inspect.isroutine(len) == True — isroutine returns True if the object is a function, method, built-in, or generator function; len is a built-in so isbuiltin(len) is True which satisfies isroutine; new to extra218"]
    - [isroutine_lambda_is_true,
       isroutine,
       [lambda: None],
       true,
       "inspect.isroutine(lambda: None) == True — a lambda is a Python function (isfunction returns True); isroutine includes isfunction in its check; returns True; new to extra218"]
    - [isroutine_42_is_false,
       isroutine,
       [42],
       false,
       "inspect.isroutine(42) == False — 42 is an integer; it is not a function, method, built-in, or generator; isroutine returns False; new to extra218"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra218
# ---------------------------------------------------------------------------

invariant inspect_extra218.isfunction_42_false:
  description: "inspect.isfunction(42) == False — integer is not a Python function; wave 384; new to extra218"
  kind: python_call_eq
  function: isfunction
  args: [42]
  expected: false

invariant inspect_extra218.isfunction_int_false:
  description: "inspect.isfunction(int) == False — int is a class, not a Python function; wave 384; new to extra218"
  kind: python_call_eq
  function: isfunction
  args: [int]
  expected: false

invariant inspect_extra218.isfunction_len_false:
  description: "inspect.isfunction(len) == False — len is a built-in, not a Python function; wave 384; new to extra218"
  kind: python_call_eq
  function: isfunction
  args: [len]
  expected: false

invariant inspect_extra218.isfunction_lambda_true:
  description: "inspect.isfunction(lambda: None) == True — lambda creates a Python function object; wave 384; new to extra218"
  kind: python_call_eq
  function: isfunction
  args: [lambda: None]
  expected: true

invariant inspect_extra218.isclass_42_false:
  description: "inspect.isclass(42) == False — integer is not a class; wave 384; new to extra218"
  kind: python_call_eq
  function: isclass
  args: [42]
  expected: false

invariant inspect_extra218.isclass_int_true:
  description: "inspect.isclass(int) == True — int is a built-in class; wave 384; new to extra218"
  kind: python_call_eq
  function: isclass
  args: [int]
  expected: true

invariant inspect_extra218.isclass_type_true:
  description: "inspect.isclass(type) == True — type is the metaclass and is itself a class; wave 384; new to extra218"
  kind: python_call_eq
  function: isclass
  args: [type]
  expected: true

invariant inspect_extra218.ismodule_42_false:
  description: "inspect.ismodule(42) == False — integer is not a module; wave 384; new to extra218"
  kind: python_call_eq
  function: ismodule
  args: [42]
  expected: false

invariant inspect_extra218.ismodule_inspect_true:
  description: "inspect.ismodule(inspect) == True — inspect is a module object; wave 384; new to extra218"
  kind: python_call_eq
  function: ismodule
  args: [inspect]
  expected: true

invariant inspect_extra218.isbuiltin_42_false:
  description: "inspect.isbuiltin(42) == False — integer is not a built-in function; wave 384; new to extra218"
  kind: python_call_eq
  function: isbuiltin
  args: [42]
  expected: false

invariant inspect_extra218.isbuiltin_len_true:
  description: "inspect.isbuiltin(len) == True — len is a C-level built-in function; wave 384; new to extra218"
  kind: python_call_eq
  function: isbuiltin
  args: [len]
  expected: true

invariant inspect_extra218.isbuiltin_print_true:
  description: "inspect.isbuiltin(print) == True — print is a C-level built-in function; wave 384; new to extra218"
  kind: python_call_eq
  function: isbuiltin
  args: [print]
  expected: true

invariant inspect_extra218.isroutine_len_true:
  description: "inspect.isroutine(len) == True — len satisfies isbuiltin so isroutine returns True; wave 384; new to extra218"
  kind: python_call_eq
  function: isroutine
  args: [len]
  expected: true

invariant inspect_extra218.isroutine_lambda_true:
  description: "inspect.isroutine(lambda: None) == True — lambda satisfies isfunction so isroutine returns True; wave 384; new to extra218"
  kind: python_call_eq
  function: isroutine
  args: [lambda: None]
  expected: true

invariant inspect_extra218.isroutine_42_false:
  description: "inspect.isroutine(42) == False — integer satisfies none of the isroutine sub-checks; wave 384; new to extra218"
  kind: python_call_eq
  function: isroutine
  args: [42]
  expected: false
