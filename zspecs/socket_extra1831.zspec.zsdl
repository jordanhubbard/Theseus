spec: socket_extra1831
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "socket stdlib documentation"
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  not_derived_from:
    - "third-party networking libraries"
  notes:
    - "socket.socket defines __init__ in its __dict__ (pure-Python class wrapping a C socket)"
    - "socket.socket does not define __new__ in its __dict__ (uses inherited object.__new__)"
    - "socket.socket instances are not callable — no __call__ in socket.__dict__"
    - "socket.error is an alias for OSError; it does not define __init__ or __new__ in its own __dict__"
    - "socket.timeout is an alias for TimeoutError; similar to socket.error"
    - "socket module-level networking functions (gethostname, getaddrinfo, etc.) are present in socket.__dict__"
    - "create_server and has_dualstack_ipv6 were added in Python 3.8"
    - "socket.socket does not define __iter__ or __contains__"
  created_at: "2026-04-12"

table socket_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["sk1831-dp-001", "socket.socket.__dict__.__contains__", ["__get__"], false]
    - ["sk1831-dp-002", "socket.socket.__dict__.__contains__", ["__set__"], false]
    - ["sk1831-dp-003", "socket.socket.__dict__.__contains__", ["__delete__"], false]
    - ["sk1831-dp-004", "socket.socket.__dict__.__contains__", ["__set_name__"], false]
    - ["sk1831-dp-005", "socket.error.__dict__.__contains__", ["__get__"], false]
    - ["sk1831-dp-006", "socket.error.__dict__.__contains__", ["__set__"], false]
    - ["sk1831-dp-007", "socket.timeout.__dict__.__contains__", ["__get__"], false]
    - ["sk1831-dp-008", "socket.timeout.__dict__.__contains__", ["__set__"], false]

