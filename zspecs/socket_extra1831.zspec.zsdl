    - ["sk1831-cp-002", "socket.error.__dict__.__contains__", ["__call__"], false]
    - ["sk1831-cp-003", "socket.socket.__dict__.__contains__", ["__init__"], true]
    - ["sk1831-cp-004", "socket.socket.__dict__.__contains__", ["__new__"], false]
    - ["sk1831-cp-005", "socket.socket.__dict__.__contains__", ["__iter__"], false]
    - ["sk1831-cp-006", "socket.socket.__dict__.__contains__", ["__contains__"], false]
    - ["sk1831-cp-007", "socket.error.__dict__.__contains__", ["__init__"], false]
    - ["sk1831-cp-008", "socket.error.__dict__.__contains__", ["__new__"], false]

