spec: re_extra2086
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl"
    - "re_extra1771.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "re.RegexFlag defines __format__ in its own __dict__ (True) — it is an IntFlag enum subclass with custom format support."
    - "re.Pattern, re.Match, and re.error do NOT define __format__ in their own __dict__."
    - "None of the re classes define __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "re.RegexFlag is an enum.IntFlag subclass; IntFlag overrides __format__ to control flag display."
    - "All expected values verified by running Python 3.12 re module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table re_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re2086001", "re.Pattern.__dict__.__contains__", ["__format__"], false]
    - ["re2086002", "re.Match.__dict__.__contains__", ["__format__"], false]
    - ["re2086003", "re.RegexFlag.__dict__.__contains__", ["__format__"], true]
    - ["re2086004", "re.error.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# __bytes__ bytes conversion protocol dict-presence
# ---------------------------------------------------------------------------

table re_extra2086.bytes_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re2086005", "re.Pattern.__dict__.__contains__", ["__bytes__"], false]
    - ["re2086006", "re.Match.__dict__.__contains__", ["__bytes__"], false]
    - ["re2086007", "re.RegexFlag.__dict__.__contains__", ["__bytes__"], false]
    - ["re2086008", "re.error.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# __fspath__ filesystem path protocol dict-presence
# ---------------------------------------------------------------------------

table re_extra2086.fspath_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re2086009", "re.Pattern.__dict__.__contains__", ["__fspath__"], false]
    - ["re2086010", "re.Match.__dict__.__contains__", ["__fspath__"], false]
    - ["re2086011", "re.RegexFlag.__dict__.__contains__", ["__fspath__"], false]
    - ["re2086012", "re.error.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# __buffer__ / __release_buffer__ buffer protocol dict-presence
# ---------------------------------------------------------------------------

table re_extra2086.buffer_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re2086013", "re.Pattern.__dict__.__contains__", ["__buffer__"], false]
    - ["re2086014", "re.Pattern.__dict__.__contains__", ["__release_buffer__"], false]
    - ["re2086015", "re.Match.__dict__.__contains__", ["__buffer__"], false]
    - ["re2086016", "re.Match.__dict__.__contains__", ["__release_buffer__"], false]
    - ["re2086017", "re.RegexFlag.__dict__.__contains__", ["__buffer__"], false]
    - ["re2086018", "re.RegexFlag.__dict__.__contains__", ["__release_buffer__"], false]
    - ["re2086019", "re.error.__dict__.__contains__", ["__buffer__"], false]
    - ["re2086020", "re.error.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# Cross-protocol summary — RegexFlag own-dict membership
# ---------------------------------------------------------------------------

table re_extra2086.regexflag_dict_summary:
  columns: [id, function, args, expected]
  rows:
    - ["re2086021", "re.RegexFlag.__dict__.__contains__", ["__format__"], true]
    - ["re2086022", "re.RegexFlag.__dict__.__contains__", ["__bytes__"], false]
    - ["re2086023", "re.RegexFlag.__dict__.__contains__", ["__fspath__"], false]
    - ["re2086024", "re.RegexFlag.__dict__.__contains__", ["__buffer__"], false]
    - ["re2086025", "re.RegexFlag.__dict__.__contains__", ["__release_buffer__"], false]
    - ["re2086026", "re.Pattern.__dict__.__contains__", ["__format__"], false]
    - ["re2086027", "re.Match.__dict__.__contains__", ["__format__"], false]
    - ["re2086028", "re.error.__dict__.__contains__", ["__format__"], false]
