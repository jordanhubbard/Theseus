spec: secrets_extra
version: ">=3.6"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/secrets.html"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified by running Python 3.12 secrets module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
  notes:
    - "Covers function __name__ and __module__ checks, and return type class checks not in secrets.zspec.zsdl."
    - "token_bytes, token_hex, token_urlsafe are defined directly in the secrets module."
    - "choice, randbelow, randbits are delegated to the module-level SystemRandom instance."
    - "SystemRandom is imported from random; its __name__ reflects the random module class name."
    - "token_bytes(n) always returns a bytes object of exactly n bytes."
    - "token_hex(n) always returns a str of hex digits."
    - "token_urlsafe(n) always returns a URL-safe base64 str."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

invariant secrets_extra.functions.token_bytes_name:
  description: "secrets.token_bytes.__name__ == 'token_bytes'"
  category: functions
  kind: python_call_eq
  function: token_bytes.__name__.__eq__
  args: ["token_bytes"]
  expected: true

invariant secrets_extra.functions.token_hex_name:
  description: "secrets.token_hex.__name__ == 'token_hex'"
  category: functions
  kind: python_call_eq
  function: token_hex.__name__.__eq__
  args: ["token_hex"]
  expected: true

invariant secrets_extra.functions.token_urlsafe_name:
  description: "secrets.token_urlsafe.__name__ == 'token_urlsafe'"
  category: functions
  kind: python_call_eq
  function: token_urlsafe.__name__.__eq__
  args: ["token_urlsafe"]
  expected: true

invariant secrets_extra.functions.choice_name:
  description: "secrets.choice.__name__ == 'choice'"
  category: functions
  kind: python_call_eq
  function: choice.__name__.__eq__
  args: ["choice"]
  expected: true

invariant secrets_extra.functions.randbelow_name:
  description: "secrets.randbelow.__name__ == 'randbelow'"
  category: functions
  kind: python_call_eq
  function: randbelow.__name__.__eq__
  args: ["randbelow"]
  expected: true

invariant secrets_extra.functions.randbits_name:
  description: "secrets.randbits.__name__ == 'randbits'"
  category: functions
  kind: python_call_eq
  function: randbits.__name__.__eq__
  args: ["randbits"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ check
# ---------------------------------------------------------------------------

invariant secrets_extra.modules.token_bytes_module:
  description: "secrets.token_bytes.__module__ == 'secrets'"
  category: modules
  kind: python_call_eq
  function: token_bytes.__module__.__eq__
  args: ["secrets"]
  expected: true

# ---------------------------------------------------------------------------
# Class name check — SystemRandom
# ---------------------------------------------------------------------------

invariant secrets_extra.classes.SystemRandom_name:
  description: "secrets.SystemRandom.__name__ == 'SystemRandom'"
  category: classes
  kind: python_call_eq
  function: SystemRandom.__name__.__eq__
  args: ["SystemRandom"]
  expected: true

# ---------------------------------------------------------------------------
# Return type checks — token_bytes returns bytes, token_hex/token_urlsafe return str
# ---------------------------------------------------------------------------

invariant secrets_extra.return_types.token_bytes_class:
  description: "token_bytes(16).__class__.__name__ == 'bytes'"
  category: return_types
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant secrets_extra.return_types.token_bytes_len:
  description: "token_bytes(16).__len__() == 16 — result is exactly 16 bytes"
  category: return_types
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __len__
  method_chain: __eq__
  method_chain_args: [16]
  expected: true

invariant secrets_extra.return_types.token_hex_class:
  description: "token_hex(8).__class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant secrets_extra.return_types.token_urlsafe_class:
  description: "token_urlsafe(8).__class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: token_urlsafe
  args: [8]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
