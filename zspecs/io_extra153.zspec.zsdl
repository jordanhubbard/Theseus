spec: io_extra153
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.__all__ module-level public API list — its class (__name__=='list'), length (24), and membership tests for key names. Also covers io.__spec__.name, io.__doc__ class and length, and io.__name__."
    - "io.__all__ is a list of 24 strings: the public API exported by the io module, ranging from 'BlockingIOError' (len=15) to 'IncrementalNewlineDecoder' (len=25 — the longest name in __all__)."
    - "io.__all__.__contains__('IOBase') == True; __contains__('BytesIO') == True; __contains__('BlockingIOError') == True; __contains__('text_encoding') == True; __contains__('open_code') == True."
    - "io.__all__.__contains__('IncrementalNewlineDecoder') == True; this is the longest name in io.__all__ at 25 characters."
    - "io.__spec__.name == 'io' (len=2); io.__doc__.__class__.__name__ == 'str'; io.__doc__.__len__() == 1473."
    - "io.__name__ == 'io' (len=2); io.__all__.__class__.__name__ == 'list'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__all__ list identity
# io.__all__.__class__.__name__ == 'list'; io.__all__.__len__() == 24.
# io.__all__ contains all public API names exported by the io module.
# ---------------------------------------------------------------------------

table io_extra153.all_list_identity:
  description: "io.__all__ list identity: __class__.__name__=='list', __len__()==24"
  kind: python_call_eq
  category: identity
  id_prefix: ioall153

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls_eq,  __all__.__class__.__name__.__eq__, ["list"], true, "io.__all__.__class__.__name__ == 'list' (io.__all__ is a plain Python list, not a tuple or set)"]
    - [all_len_eq,  __all__.__len__,                   [],       24,   "io.__all__.__len__() == 24 (the io module exports 24 public names, covering the full hierarchy of IO classes plus constants and utilities)"]

# ---------------------------------------------------------------------------
# io.__all__ membership tests — core IO classes
# IOBase, RawIOBase, BufferedIOBase, TextIOBase are the four abstract base classes.
# BytesIO, StringIO, FileIO are the three main concrete in-memory/file classes.
# BlockingIOError, open, open_code are also in __all__.
# ---------------------------------------------------------------------------

table io_extra153.all_membership_core:
  description: "io.__all__ membership: IOBase, BytesIO, StringIO, FileIO, RawIOBase, BufferedIOBase, TextIOBase, BlockingIOError, open, open_code all present"
  kind: python_call_eq
  category: identity
  id_prefix: ioall153

  columns: [id, function, args, expected, description]
  rows:
    - [has_iobase,     __all__.__contains__, ["IOBase"],           true, "io.__all__ contains 'IOBase' (the abstract base for all IO objects; root of the io class hierarchy)"]
    - [has_bytesio,    __all__.__contains__, ["BytesIO"],          true, "io.__all__ contains 'BytesIO' (in-memory bytes stream; commonly used for binary data manipulation without a real file)"]
    - [has_stringio,   __all__.__contains__, ["StringIO"],         true, "io.__all__ contains 'StringIO' (in-memory text stream; commonly used for string manipulation)"]
    - [has_fileio,     __all__.__contains__, ["FileIO"],           true, "io.__all__ contains 'FileIO' (raw file I/O class; lowest-level file access without buffering)"]
    - [has_rawiobase,  __all__.__contains__, ["RawIOBase"],        true, "io.__all__ contains 'RawIOBase' (abstract base for raw binary I/O)"]
    - [has_bufiobase,  __all__.__contains__, ["BufferedIOBase"],   true, "io.__all__ contains 'BufferedIOBase' (abstract base for buffered binary I/O)"]
    - [has_textiobase, __all__.__contains__, ["TextIOBase"],       true, "io.__all__ contains 'TextIOBase' (abstract base for text I/O with encoding/decoding)"]
    - [has_blockerr,   __all__.__contains__, ["BlockingIOError"],  true, "io.__all__ contains 'BlockingIOError' (exception raised on non-blocking I/O; first item in io.__all__)"]
    - [has_open,       __all__.__contains__, ["open"],             true, "io.__all__ contains 'open' (the built-in open function re-exported via io; same object as the built-in open)"]
    - [has_open_code,  __all__.__contains__, ["open_code"],        true, "io.__all__ contains 'open_code' (opens a file for reading source code; uses the importlib.util.source_from_cache logic)"]

# ---------------------------------------------------------------------------
# io.__all__ membership tests — buffered classes and utilities
# BufferedReader, BufferedWriter, BufferedRWPair, BufferedRandom,
# TextIOWrapper, UnsupportedOperation, SEEK_SET/CUR/END,
# DEFAULT_BUFFER_SIZE, text_encoding, IncrementalNewlineDecoder, Reader, Writer.
# ---------------------------------------------------------------------------

table io_extra153.all_membership_buffered_and_utils:
  description: "io.__all__ membership: BufferedReader, BufferedWriter, TextIOWrapper, UnsupportedOperation, seek constants, DEFAULT_BUFFER_SIZE, text_encoding, IncrementalNewlineDecoder, Reader, Writer"
  kind: python_call_eq
  category: identity
  id_prefix: ioall153

  columns: [id, function, args, expected, description]
  rows:
    - [has_bufreader,   __all__.__contains__, ["BufferedReader"],          true, "io.__all__ contains 'BufferedReader' (buffered binary reading; wraps a RawIOBase)"]
    - [has_bufwriter,   __all__.__contains__, ["BufferedWriter"],          true, "io.__all__ contains 'BufferedWriter' (buffered binary writing; wraps a RawIOBase)"]
    - [has_bufrwpair,   __all__.__contains__, ["BufferedRWPair"],          true, "io.__all__ contains 'BufferedRWPair' (combines buffered reader and writer for bidirectional I/O)"]
    - [has_bufrandom,   __all__.__contains__, ["BufferedRandom"],          true, "io.__all__ contains 'BufferedRandom' (buffered random-access binary I/O for read+write on the same file)"]
    - [has_textiowrap,  __all__.__contains__, ["TextIOWrapper"],           true, "io.__all__ contains 'TextIOWrapper' (buffered text I/O over a buffered binary stream; the type returned by open() in text mode)"]
    - [has_unsupop,     __all__.__contains__, ["UnsupportedOperation"],    true, "io.__all__ contains 'UnsupportedOperation' (exception raised for unsupported IO operations)"]
    - [has_seekset,     __all__.__contains__, ["SEEK_SET"],                true, "io.__all__ contains 'SEEK_SET' (integer constant 0: seek from beginning of stream)"]
    - [has_text_enc,    __all__.__contains__, ["text_encoding"],           true, "io.__all__ contains 'text_encoding' (helper function that coerces encoding='locale' or None to actual encoding string)"]
    - [has_incnldec,    __all__.__contains__, ["IncrementalNewlineDecoder"],true, "io.__all__ contains 'IncrementalNewlineDecoder' (len=25; the longest name in io.__all__; a codec for universal newline mode)"]
    - [has_reader,      __all__.__contains__, ["Reader"],                  true, "io.__all__ contains 'Reader' (abstract reader mixin for codec-based reading)"]
    - [has_writer,      __all__.__contains__, ["Writer"],                  true, "io.__all__ contains 'Writer' (abstract writer mixin for codec-based writing)"]

# ---------------------------------------------------------------------------
# io module-level attributes: __spec__.name, __doc__, __name__
# io.__spec__.name == 'io' (len=2); io.__doc__ is a str of length 1473.
# io.__name__ == 'io' (len=2).
# ---------------------------------------------------------------------------

table io_extra153.module_level_attrs:
  description: "io module-level attributes: __spec__.name=='io' (2), __doc__ is str (len=1473), __name__=='io' (2)"
  kind: python_call_eq
  category: identity
  id_prefix: ioall153

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,   __spec__.name.__eq__,                ["io"],  true, "io.__spec__.name == 'io' (the module spec name is the bare module name 'io', len=2)"]
    - [spec_name_len,  __spec__.name.__len__,               [],      2,    "io.__spec__.name.__len__() == 2 ('io' has 2 characters; the shortest module name in the stdlib io family)"]
    - [doc_cls_eq,     __doc__.__class__.__name__.__eq__,   ["str"], true, "io.__doc__.__class__.__name__ == 'str' (the io module has a non-None docstring of type str)"]
    - [doc_len_eq,     __doc__.__len__,                     [],      1473, "io.__doc__.__len__() == 1473 (the io module docstring is 1473 characters long; it describes the hierarchy of abstract base classes and concrete implementations)"]
    - [name_eq,        __name__.__eq__,                     ["io"],  true, "io.__name__ == 'io' (the module name attribute; same value as io.__spec__.name)"]
    - [name_len,       __name__.__len__,                    [],      2,    "io.__name__.__len__() == 2 ('io' has 2 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra153.all.class_is_list:
  description: "io.__all__.__class__.__name__ == 'list' — the public API list of the io module is a plain Python list; this is consistent across all Python stdlib modules where __all__ is defined as a list literal in the module source"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant io_extra153.all.len_24:
  description: "io.__all__.__len__() == 24 — the io module exports exactly 24 public names; this includes 4 abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase), 3 in-memory classes (BytesIO, StringIO, FileIO), 4 buffered classes, TextIOWrapper, UnsupportedOperation, 3 SEEK constants, DEFAULT_BUFFER_SIZE, open, open_code, text_encoding, IncrementalNewlineDecoder, Reader, Writer, and BlockingIOError"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 24

invariant io_extra153.all.contains_IOBase:
  description: "io.__all__.__contains__('IOBase') == True — IOBase is the root abstract base class of the io module hierarchy; all concrete IO classes (BytesIO, StringIO, FileIO, BufferedReader, etc.) are ultimately derived from IOBase"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["IOBase"]
  expected: true

invariant io_extra153.all.contains_IncrementalNewlineDecoder:
  description: "io.__all__.__contains__('IncrementalNewlineDecoder') == True — IncrementalNewlineDecoder is the longest name in io.__all__ at 25 characters; it is a codec for translating universal newlines ('\\r', '\\r\\n', '\\n') incrementally; it implements the IncrementalDecoder interface"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["IncrementalNewlineDecoder"]
  expected: true

invariant io_extra153.all.contains_text_encoding:
  description: "io.__all__.__contains__('text_encoding') == True — text_encoding() is a helper function added in Python 3.10 that returns 'locale' if encoding is None and 'utf-8' or another encoding otherwise; it helps stdlib code emit DeprecationWarnings for callers that rely on the locale encoding"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["text_encoding"]
  expected: true

invariant io_extra153.spec_name_eq_io:
  description: "io.__spec__.name == 'io' (len=2) — the io module's ModuleSpec name is the bare 'io'; __spec__.name is used by the import system to identify the module; the io module is a hybrid of pure Python (Lib/io.py) and C extension (_io)"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["io"]
  expected: true

invariant io_extra153.doc.len_1473:
  description: "io.__doc__.__len__() == 1473 — the io module's module-level docstring is 1473 characters long; it summarizes the three-layer I/O hierarchy (raw, buffered, text) and the abstract base classes; this is distinct from io.open.__doc__ (5959 chars, covered in io_extra151) which documents the open() function parameters"
  category: identity
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1473

invariant io_extra153.all.contains_BlockingIOError:
  description: "io.__all__.__contains__('BlockingIOError') == True — BlockingIOError is the first item in io.__all__ (index 0); it is a built-in exception re-exported through the io module; it is raised when an I/O operation would block on a non-blocking stream"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["BlockingIOError"]
  expected: true
