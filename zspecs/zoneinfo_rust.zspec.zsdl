spec: zoneinfo_rust
version: ">=3.9"
backend: rust_module(zoneinfo_rust)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo documentation"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_zoneinfo.py"
  notes:
    - "Clean-room Rust reimplementation of Python zoneinfo.ZoneInfo, exposed via PyO3."
    - "ZoneInfo('UTC').key == 'UTC' — the IANA timezone key."
    - "ZoneInfo('UTC') is a valid timezone recognized by the system."
    - "ZoneInfo('America/New_York').key == 'America/New_York'."
    - "ZoneInfo('Europe/London').key == 'Europe/London'."
    - "ZoneInfo('Asia/Tokyo').key == 'Asia/Tokyo'."
    - "ZoneInfo.no_cache('UTC').key == 'UTC' — bypasses cache."
    - "All test vectors verified against Python 3.14.3 zoneinfo module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# ZoneInfo — key attribute (IANA timezone identifier)
table zoneinfo_rust.key.vectors:
  kind: python_call_eq
  category: key
  id_prefix: zi_key
  function: ZoneInfo
  method: key

  columns: [id, args, expected]
  rows:
    - [utc,         ["UTC"],                "UTC"]
    - [new_york,    ["America/New_York"],   "America/New_York"]
    - [london,      ["Europe/London"],      "Europe/London"]
    - [tokyo,       ["Asia/Tokyo"],         "Asia/Tokyo"]
    - [paris,       ["Europe/Paris"],       "Europe/Paris"]

# ZoneInfo.no_cache — bypass the cache
invariant zoneinfo_rust.no_cache.utc:
  description: "ZoneInfo.no_cache('UTC').key == 'UTC'"
  category: no_cache
  kind: python_call_eq
  function: ZoneInfo.no_cache
  args: ["UTC"]
  method: key
  expected: "UTC"

