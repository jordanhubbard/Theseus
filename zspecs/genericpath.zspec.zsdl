spec: genericpath
version: ">=3.0"
backend: python_module(genericpath)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.path.html"
    - "CPython source: Lib/genericpath.py (PSF; name and behavioural checks only)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/genericpath.py implementation internals"
  notes:
    - "genericpath is an internal CPython module providing shared helpers for os.path implementations."
    - "It is importable directly on all platforms and contains stable public functions."
    - "commonprefix(list) returns the longest common leading substring of all items in list."
    - "commonprefix([]) returns '' (empty list has no common prefix)."
    - "commonprefix(['abc', 'abcd', 'abcde']) returns 'abc'."
    - "commonprefix(['abc', 'xyz']) returns '' (no common characters at position 0)."
    - "commonprefix(['/usr/lib', '/usr/local/lib']) returns '/usr/l'."
    - "exists, isfile, isdir, islink, getatime, getmtime, getctime, getsize are filesystem helpers."
    - "All expected values verified by running Python 3.12 genericpath module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "commonprefix raises no exceptions for a list of strings. Filesystem functions raise OSError for inaccessible paths."
  stderr: "null"
  stickiness: "N/A — functions are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table genericpath.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [commonprefix,  commonprefix.__name__.__eq__,  ["commonprefix"],  true]
    - [exists,        exists.__name__.__eq__,        ["exists"],        true]
    - [isfile,        isfile.__name__.__eq__,        ["isfile"],        true]
    - [isdir,         isdir.__name__.__eq__,         ["isdir"],         true]
    - [islink,        islink.__name__.__eq__,        ["islink"],        true]
    - [getatime,      getatime.__name__.__eq__,      ["getatime"],      true]
    - [getmtime,      getmtime.__name__.__eq__,      ["getmtime"],      true]
    - [getsize,       getsize.__name__.__eq__,       ["getsize"],       true]

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant genericpath.module.commonprefix:
  description: "commonprefix.__module__ == 'genericpath'"
  category: module
  kind: python_call_eq
  function: commonprefix.__module__.__eq__
  args: ["genericpath"]
  expected: true

# ---------------------------------------------------------------------------
# commonprefix — behavioural invariants
# ---------------------------------------------------------------------------

invariant genericpath.commonprefix.empty_list:
  description: "commonprefix([]) == '' — empty list yields empty string"
  category: behavior
  kind: python_call_eq
  function: commonprefix
  args: [[]]
  method: __eq__
  method_args: [""]
  expected: true

invariant genericpath.commonprefix.identical:
  description: "commonprefix(['abc', 'abc']) == 'abc' — identical strings share full prefix"
  category: behavior
  kind: python_call_eq
  function: commonprefix
  args: [["abc", "abc"]]
  method: __eq__
  method_args: ["abc"]
  expected: true

invariant genericpath.commonprefix.partial:
  description: "commonprefix(['abc', 'abcd', 'abcde']) == 'abc'"
  category: behavior
  kind: python_call_eq
  function: commonprefix
  args: [["abc", "abcd", "abcde"]]
  method: __eq__
  method_args: ["abc"]
  expected: true

invariant genericpath.commonprefix.no_common:
  description: "commonprefix(['abc', 'xyz']) == '' — no common prefix"
  category: behavior
  kind: python_call_eq
  function: commonprefix
  args: [["abc", "xyz"]]
  method: __eq__
  method_args: [""]
  expected: true

invariant genericpath.commonprefix.paths:
  description: "commonprefix(['/usr/lib', '/usr/local/lib']) == '/usr/l'"
  category: behavior
  kind: python_call_eq
  function: commonprefix
  args: [["/usr/lib", "/usr/local/lib"]]
  method: __eq__
  method_args: ["/usr/l"]
  expected: true

invariant genericpath.commonprefix.single_element:
  description: "commonprefix(['hello']) == 'hello' — single element is its own prefix"
  category: behavior
  kind: python_call_eq
  function: commonprefix
  args: [["hello"]]
  method: __eq__
  method_args: ["hello"]
  expected: true
