spec: datetime_extra
version: ">=3.7"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html
rfcs:
  - "RFC 3339 — Date and Time on the Internet: Timestamps"
  - "ISO 8601 — Date and time — Representations for information interchange"

provenance:
  derived_from:
    - "Python 3 datetime documentation — https://docs.python.org/3/library/datetime.html"
    - "ISO 8601 date/time format specification"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec covers datetime behaviors not in datetime.zspec.zsdl, _datetime.zspec.zsdl, or datetime_timedelta.zspec.zsdl."
    - "date.today() and datetime.now() return live values; we verify their __class__.__name__ rather than exact values."
    - "time here refers to datetime.time (the class), not the time module."
    - "timezone.utc is a module-level singleton; its __class__.__name__ is 'timezone'."
    - "MINYEAR == 1 and MAXYEAR == 9999 are documented module-level integer constants."
    - "date.min, date.max, datetime.min are class-level attributes returning instances of their respective types."
    - "date.resolution is a timedelta instance representing the smallest difference between date values (1 day)."
    - "timedelta.__name__ == 'timedelta' is confirmed here against the datetime module (not _datetime)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module constants — MINYEAR and MAXYEAR
# ---------------------------------------------------------------------------

invariant datetime_extra.MINYEAR.value:
  description: "datetime.MINYEAR == 1 — smallest year representable by date"
  category: constants
  kind: python_call_eq
  function: MINYEAR.__eq__
  args: [1]
  expected: true

invariant datetime_extra.MAXYEAR.value:
  description: "datetime.MAXYEAR == 9999 — largest year representable by date"
  category: constants
  kind: python_call_eq
  function: MAXYEAR.__eq__
  args: [9999]
  expected: true

# ---------------------------------------------------------------------------
# Class name checks — the four main datetime classes
#
# These confirm that the module exports the expected type objects with the
# correct __name__ attributes.
# ---------------------------------------------------------------------------

invariant datetime_extra.time.class_name:
  description: "datetime.time.__name__ == 'time' — the time class, not the time module"
  category: class_names
  kind: python_call_eq
  function: time.__name__.__eq__
  args: ["time"]
  expected: true

invariant datetime_extra.timezone.class_name:
  description: "datetime.timezone.__name__ == 'timezone'"
  category: class_names
  kind: python_call_eq
  function: timezone.__name__.__eq__
  args: ["timezone"]
  expected: true

invariant datetime_extra.timedelta.class_name:
  description: "datetime.timedelta.__name__ == 'timedelta'"
  category: class_names
  kind: python_call_eq
  function: timedelta.__name__.__eq__
  args: ["timedelta"]
  expected: true

# ---------------------------------------------------------------------------
# date.today() — runtime value; verify the return type
#
# date.today() returns a date instance. We cannot test the exact date, so
# we verify the class name of the returned object.
# ---------------------------------------------------------------------------

invariant datetime_extra.date.today_class_name:
  description: "date.today().__class__.__name__ == 'date'"
  category: live_constructors
  kind: python_call_eq
  function: date.today
  args: []
  method: __class__.__name__.__eq__
  method_args: ["date"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.now() — runtime value; verify the return type
#
# datetime.now() returns a datetime instance. We verify the class name.
# ---------------------------------------------------------------------------

invariant datetime_extra.datetime.now_class_name:
  description: "datetime.now().__class__.__name__ == 'datetime'"
  category: live_constructors
  kind: python_call_eq
  function: datetime.now
  args: []
  method: __class__.__name__.__eq__
  method_args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# timezone.utc — class-level singleton type check
#
# timezone.utc is a fixed sentinel; its __class__.__name__ must be 'timezone'.
# ---------------------------------------------------------------------------

invariant datetime_extra.timezone.utc_class_name:
  description: "timezone.utc.__class__.__name__ == 'timezone'"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.__class__.__name__.__eq__
  args: ["timezone"]
  expected: true

# ---------------------------------------------------------------------------
# date class-level bound attributes — min and max
#
# date.min and date.max are date instances representing the smallest and
# largest representable dates.
# ---------------------------------------------------------------------------

invariant datetime_extra.date.min_class_name:
  description: "date.min.__class__.__name__ == 'date'"
  category: date_bounds
  kind: python_call_eq
  function: date.min.__class__.__name__.__eq__
  args: ["date"]
  expected: true

invariant datetime_extra.date.max_class_name:
  description: "date.max.__class__.__name__ == 'date'"
  category: date_bounds
  kind: python_call_eq
  function: date.max.__class__.__name__.__eq__
  args: ["date"]
  expected: true

# ---------------------------------------------------------------------------
# datetime class-level bound attribute — min
#
# datetime.min is a datetime instance representing the earliest datetime.
# ---------------------------------------------------------------------------

invariant datetime_extra.datetime.min_class_name:
  description: "datetime.min.__class__.__name__ == 'datetime'"
  category: datetime_bounds
  kind: python_call_eq
  function: datetime.min.__class__.__name__.__eq__
  args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# date.resolution — timedelta of one day
#
# date.resolution is the smallest difference between two date values (1 day).
# Its type must be timedelta.
# ---------------------------------------------------------------------------

invariant datetime_extra.date.resolution_class_name:
  description: "date.resolution.__class__.__name__ == 'timedelta'"
  category: date_bounds
  kind: python_call_eq
  function: date.resolution.__class__.__name__.__eq__
  args: ["timedelta"]
  expected: true
