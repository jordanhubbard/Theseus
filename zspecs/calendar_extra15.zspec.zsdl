spec: calendar_extra15
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra3.zspec.zsdl — covers __qualname__ for Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/isleap/monthrange/weekday; MONDAY/SUNDAY class base; isleap/__module__ and Calendar/__module__"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; isleap; leapdays; monthrange; firstweekday/__module__; timegm/__module__"
    - "calendar_extra9.zspec.zsdl — covers TextCalendar/__module__/__qualname__; HTMLCalendar/__module__/__qualname__; setfirstweekday/__name__; firstweekday/__name__"
    - "calendar_extra13.zspec.zsdl — covers LocaleTextCalendar/__qualname__; LocaleHTMLCalendar/__qualname__; isleap/__qualname__; month/__qualname__; calendar/__qualname__"
    - "calendar_extra14.zspec.zsdl — covers leapdays/__qualname__; timegm/__qualname__; setfirstweekday/__qualname__; firstweekday/__qualname__; monthcalendar/__qualname__; prmonth/__qualname__; prcal/__qualname__"
  notes:
    - "This spec extends calendar.zspec.zsdl and prior extras through calendar_extra14.zspec.zsdl."
    - "NEW in extra15 — Axis 1: __qualname__ for TextCalendar instance methods (formatmonth, formatyear, formatweekheader) — dotted qualnames such as 'TextCalendar.formatmonth'."
    - "NEW in extra15 — Axis 2: __qualname__ for HTMLCalendar instance methods (formatmonth, formatyear, formatyearpage) — dotted qualnames such as 'HTMLCalendar.formatmonth'."
    - "NEW in extra15 — Axis 3: __qualname__ for Calendar base class methods (iterweekdays, itermonthdates) — dotted qualnames such as 'Calendar.iterweekdays'."
    - "calendar.TextCalendar.formatmonth.__qualname__ == 'TextCalendar.formatmonth' — verified Python 3.12."
    - "calendar.TextCalendar.formatyear.__qualname__ == 'TextCalendar.formatyear' — verified Python 3.12."
    - "calendar.TextCalendar.formatweekheader.__qualname__ == 'TextCalendar.formatweekheader' — verified Python 3.12."
    - "calendar.HTMLCalendar.formatmonth.__qualname__ == 'HTMLCalendar.formatmonth' — verified Python 3.12."
    - "calendar.HTMLCalendar.formatyear.__qualname__ == 'HTMLCalendar.formatyear' — verified Python 3.12."
    - "calendar.HTMLCalendar.formatyearpage.__qualname__ == 'HTMLCalendar.formatyearpage' — verified Python 3.12."
    - "calendar.Calendar.iterweekdays.__qualname__ == 'Calendar.iterweekdays' — verified Python 3.12."
    - "calendar.Calendar.itermonthdates.__qualname__ == 'Calendar.itermonthdates' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextCalendar instance method __qualname__ values
#
# Prior specs cover the __qualname__ of the TextCalendar *class* itself
# ('TextCalendar'). No prior spec checks the __qualname__ of methods defined
# on TextCalendar, which are dotted strings such as 'TextCalendar.formatmonth'.
# ---------------------------------------------------------------------------

table calendar_extra15.TextCalendar_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [formatmonth,     "TextCalendar.formatmonth.__qualname__.__eq__",     ["TextCalendar.formatmonth"],     true]
    - [formatyear,      "TextCalendar.formatyear.__qualname__.__eq__",      ["TextCalendar.formatyear"],      true]
    - [formatweekheader, "TextCalendar.formatweekheader.__qualname__.__eq__", ["TextCalendar.formatweekheader"], true]

# ---------------------------------------------------------------------------
# HTMLCalendar instance method __qualname__ values
#
# No prior spec checks the __qualname__ of methods defined on HTMLCalendar.
# The dotted qualnames parallel those for TextCalendar above.
# ---------------------------------------------------------------------------

table calendar_extra15.HTMLCalendar_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [formatmonth,    "HTMLCalendar.formatmonth.__qualname__.__eq__",    ["HTMLCalendar.formatmonth"],    true]
    - [formatyear,     "HTMLCalendar.formatyear.__qualname__.__eq__",     ["HTMLCalendar.formatyear"],     true]
    - [formatyearpage, "HTMLCalendar.formatyearpage.__qualname__.__eq__", ["HTMLCalendar.formatyearpage"], true]

# ---------------------------------------------------------------------------
# Calendar base class method __qualname__ values
#
# No prior spec checks the __qualname__ of Calendar base class methods such as
# iterweekdays and itermonthdates. These return iterators over weekday indices
# and month dates respectively, and their qualnames are dotted.
# ---------------------------------------------------------------------------

invariant calendar_extra15.Calendar.iterweekdays.qualname:
  description: "calendar.Calendar.iterweekdays.__qualname__ == 'Calendar.iterweekdays' — dotted method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: "Calendar.iterweekdays.__qualname__.__eq__"
  args: ["Calendar.iterweekdays"]
  expected: true

invariant calendar_extra15.Calendar.itermonthdates.qualname:
  description: "calendar.Calendar.itermonthdates.__qualname__ == 'Calendar.itermonthdates' — dotted method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: "Calendar.itermonthdates.__qualname__.__eq__"
  args: ["Calendar.itermonthdates"]
  expected: true
