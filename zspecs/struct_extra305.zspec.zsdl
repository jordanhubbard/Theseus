spec: struct_extra305
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.unpack always returns a tuple, even when unpacking a single value."
    - "struct.unpack('>I', b'\\x00\\x00\\x01\\x00') returns (256,) — big-endian uint32 from hex 00000100."
    - "struct.unpack('>HH', b'\\x00\\x01\\x00\\x02') returns (1, 2) — two big-endian uint16 values."
    - "struct.unpack('>b', b'\\x7f') returns (127,) — maximum signed int8 value."
    - "struct.unpack('>B', b'\\xff') returns (255,) — maximum unsigned uint8 value."
    - "struct.unpack_from accepts an optional offset parameter; offset=0 is explicit here."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.unpack — big-endian uint32 ('>I') from known byte sequences
# ---------------------------------------------------------------------------

table struct_extra305.unpack.uint32:
  kind: python_call_eq
  category: unpack_vector
  id_prefix: unpack_uint32
  function: unpack

  columns: [id, args, expected]
  rows:
    - [big_endian_uint32_256,  [">I", !hex 00000100], [256]]
    - [big_endian_uint32_zero, [">I", !hex 00000000], [0]  ]
    - [big_endian_uint32_max,  [">I", !hex ffffffff], [4294967295]]

# ---------------------------------------------------------------------------
# struct.unpack — two big-endian uint16 ('>HH') from known byte sequence
# struct.unpack('>HH', b'\x00\x01\x00\x02') == (1, 2)
# ---------------------------------------------------------------------------

invariant struct_extra305.unpack.two_uint16.tuple:
  description: "struct.unpack('>HH', b'\\x00\\x01\\x00\\x02') == (1, 2)"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">HH", !hex 00010002]
  expected: [1, 2]

invariant struct_extra305.unpack.two_uint16.first:
  description: "struct.unpack('>HH', b'\\x00\\x01\\x00\\x02')[0] == 1"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">HH", !hex 00010002]
  method: __getitem__
  method_args: [0]
  expected: 1

invariant struct_extra305.unpack.two_uint16.second:
  description: "struct.unpack('>HH', b'\\x00\\x01\\x00\\x02')[1] == 2"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">HH", !hex 00010002]
  method: __getitem__
  method_args: [1]
  expected: 2

# ---------------------------------------------------------------------------
# struct.unpack — signed int8 ('>b') and unsigned uint8 ('>B')
# ---------------------------------------------------------------------------

invariant struct_extra305.unpack.int8_max:
  description: "struct.unpack('>b', b'\\x7f')[0] == 127 — maximum signed int8"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">b", !hex 7f]
  method: __getitem__
  method_args: [0]
  expected: 127

invariant struct_extra305.unpack.uint8_max:
  description: "struct.unpack('>B', b'\\xff')[0] == 255 — maximum unsigned uint8"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">B", !hex ff]
  method: __getitem__
  method_args: [0]
  expected: 255

# ---------------------------------------------------------------------------
# struct.unpack_from — read uint32 from a 5-byte buffer at offset 0
# struct.unpack_from('>I', b'\x00\x00\x01\x00\x00', 0)[0] == 256
# ---------------------------------------------------------------------------

invariant struct_extra305.unpack_from.uint32_offset0:
  description: "struct.unpack_from('>I', b'\\x00\\x00\\x01\\x00\\x00', 0)[0] == 256 — reads 4 bytes from offset 0"
  category: unpack_from_vector
  kind: python_call_eq
  function: unpack_from
  args: [">I", !hex 0000010000, 0]
  method: __getitem__
  method_args: [0]
  expected: 256
