spec: hashlib_extra171
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra170.zspec.zsdl — covers hashlib.sha1/__sha224/__sha384/__blake2b/__blake2s/__sha3_256 .__name__ (openssl_ prefix or bare) and .__module__ ('_hashlib' or '_blake2') and name lengths (table + invariants)."
    - "hashlib_extra169.zspec.zsdl — covers hashlib.algorithms_guaranteed.__contains__ for sha256/sha512/md5/sha1/sha3_256/blake2b/sha224/shake_256/sha3_512 and algorithms_guaranteed/__available __len__()==14/19 (table + invariants)."
    - "hashlib_extra168.zspec.zsdl — covers hashlib.sha256/__md5/__sha512 .__name__ (openssl_ prefix) and .__module__ ('_hashlib'); algorithms_available/__guaranteed .__class__.__name__=='set' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra170."
    - "Wave 350 theme: hashlib function identity for hashlib.new, hashlib.pbkdf2_hmac, hashlib.scrypt, and hashlib.file_digest. hashlib.new.__name__=='__hash_new' (not 'new' — it is actually the private __hash_new wrapper function), hashlib.new.__module__=='hashlib', hashlib.new.__class__.__name__=='function'. hashlib.pbkdf2_hmac.__name__=='pbkdf2_hmac', hashlib.pbkdf2_hmac.__module__=='_hashlib' (C extension), hashlib.pbkdf2_hmac.__class__.__name__=='builtin_function_or_method'. hashlib.scrypt.__name__=='scrypt', hashlib.scrypt.__module__=='_hashlib'. hashlib.file_digest.__name__=='file_digest', hashlib.file_digest.__module__=='hashlib', hashlib.file_digest.__class__.__name__=='function' (pure Python, added in 3.11)."
    - "hashlib.new.__name__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0. NOTE: hashlib.new is actually the internal __hash_new function, not a function named 'new'. Its __name__ attribute is '__hash_new' (10 chars = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3), not 'new'."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__name__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__name__ == 'file_digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.new.__name__ == '__hash_new' (10 chars = '__'=2 + 'hash_new'=8). The hashlib.new API is documented as the generic constructor, but the actual function object is an internal __hash_new wrapper. '__hash_new'(10) >> 'new'(3) by 7 chars. It is a pure Python 'function' (defined in Lib/hashlib.py), not a C builtin. __module__=='hashlib'(7 chars) confirming pure Python origin."
    - "Note: hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (11 chars = 'pbkdf2'=6 + '_hmac'=5). PBKDF2-HMAC is a password-based key derivation function from PKCS#5 / RFC 8018. It applies a pseudorandom function (HMAC) iteratively to produce a derived key. pbkdf2_hmac.__module__=='_hashlib'(8 chars; C extension) and __class__.__name__=='builtin_function_or_method' (25 chars) — it is a C builtin, not a pure Python function."
    - "Note: hashlib.scrypt.__name__ == 'scrypt' (6 chars). scrypt is a memory-hard password-based key derivation function (RFC 7914). It is available on macOS/Darwin with OpenSSL backing. scrypt.__module__=='_hashlib'(8 chars; same C extension as pbkdf2_hmac). 'scrypt'(6 chars) == 'sha256'(6) in length — coincidental same length."
    - "Note: hashlib.file_digest.__name__ == 'file_digest' (11 chars = 'file'=4 + '_digest'=7). file_digest was added in Python 3.11. It computes a hash digest for a file object efficiently. file_digest.__module__=='hashlib'(7 chars; pure Python in Lib/hashlib.py) and __class__.__name__=='function'(8 chars) — pure Python, not a C extension. 'file_digest'(11) == 'pbkdf2_hmac'(11) in length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new')
# hashlib.new.__module__.__eq__('hashlib')
# hashlib.new.__class__.__name__.__eq__('function')
# hashlib.new.__name__.__len__()==10
#
# Wave 350 theme: hashlib.new function identity — actual __name__ is '__hash_new'.
#
# new.__name__ == '__hash_new' (10 chars; private wrapper; not 'new').
# new.__module__ == 'hashlib' (7 chars; pure Python in Lib/hashlib.py).
# new.__class__.__name__ == 'function' (8 chars; pure Python function, not C builtin).
# new.__name__.__len__() == 10 (__hash_new = 10 chars).
# No prior hashlib spec anchors new.__name__ as a table under hashlibfn171.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra171.new_function_identity:
  description: "hashlib.new.__name__.__eq__('__hash_new')==True / new.__module__.__eq__('hashlib')==True / new.__class__.__name__.__eq__('function')==True / new.__name__.__len__()==10 — new.__name__ is '__hash_new' (10 chars = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3; hashlib.new is actually the __hash_new internal wrapper function; its __name__ is '__hash_new', not 'new'; '__hash_new'(10) >> 'new'(3) by 7 chars — the name is much longer than the attribute name used to access it; the leading double-underscore prefix signals a private/internal function in Lib/hashlib.py); new.__module__ is 'hashlib' (7 chars; hashlib.new is defined in Lib/hashlib.py — pure Python; __module__=='hashlib'(7) confirms public module; 'hashlib'(7) == 'hashlib'.__len__()==7); new.__class__.__name__ is 'function' (8 chars; pure Python function defined with def in Lib/hashlib.py; contrasts with pbkdf2_hmac.__class__.__name__=='builtin_function_or_method'(25 chars) which is a C extension function; 'function'(8) > 'hashlib'(7) by 1 char); new.__name__.__len__() is 10 ('__hash_new' = 10 chars; 'hashlib'(7) < 'new.__name__'(10): module name is shorter than the function's actual __name__; first hashlibfn171 anchor for new function identity)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibfn171

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_hash_new,    "new.__name__.__eq__",            ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' (10 chars; internal wrapper; NOT 'new'; '__hash_new'(10) >> 'new'(3) by 7 chars)"]
    - [new_module_hashlib,   "new.__module__.__eq__",          ["hashlib"],    true, "hashlib.new.__module__ == 'hashlib' (7 chars; pure Python in Lib/hashlib.py; public module name)"]
    - [new_class_function,   "new.__class__.__name__.__eq__",  ["function"],   true, "hashlib.new.__class__.__name__ == 'function' (8 chars; pure Python function; contrasts with pbkdf2_hmac which is 'builtin_function_or_method'(25 chars))"]
    - [new_name_len_10,      "new.__name__.__len__",           [],             10,   "hashlib.new.__name__.__len__() is 10 ('__hash_new' = 10 chars; '__'=2 + 'hash_new'=8; 'hashlib'(7) < '__hash_new'(10) by 3)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.pbkdf2_hmac.__name__.__len__()==11
#
# Wave 350 theme: hashlib.pbkdf2_hmac function identity.
#
# pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (11 chars; PBKDF2 key derivation).
# pbkdf2_hmac.__module__ == '_hashlib' (8 chars; C extension).
# pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' (25 chars).
# pbkdf2_hmac.__name__.__len__() == 11 ('pbkdf2_hmac' = 11 chars).
# No prior hashlib spec anchors pbkdf2_hmac.__name__ as a table under hashlibfn171.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra171.pbkdf2_hmac_function_identity:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')==True / pbkdf2_hmac.__module__.__eq__('_hashlib')==True / pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')==True / pbkdf2_hmac.__name__.__len__()==11 — pbkdf2_hmac.__name__ is 'pbkdf2_hmac' (11 chars = 'pbkdf2'=6 + '_hmac'=5; PBKDF2 stands for Password-Based Key Derivation Function 2; HMAC = Hash-based Message Authentication Code; defined in PKCS#5 / RFC 8018; hashlib.pbkdf2_hmac(hash_name, password, salt, iterations) derives a cryptographic key from a password using HMAC-based iteration; 'pbkdf2_hmac'(11) == 'file_digest'(11) in length — coincidental equal length); pbkdf2_hmac.__module__ is '_hashlib' (8 chars = '_'=1 + 'hashlib'=7; private C extension from Modules/_hashlib.c; contrasts with new.__module__=='hashlib'(7 chars; public pure Python) — the leading underscore marks private C extension; '_hashlib'(8) > 'hashlib'(7) by 1 char due to the underscore prefix); pbkdf2_hmac.__class__.__name__ is 'builtin_function_or_method' (25 chars; pbkdf2_hmac is a C extension function; contrasts with new.__class__.__name__=='function'(8 chars; pure Python)); pbkdf2_hmac.__name__.__len__() is 11 ('pbkdf2_hmac' = 11 chars; 'pbkdf2_hmac'(11) > '_hashlib'(8) > 'hashlib'(7) in length; first hashlibfn171 anchor for pbkdf2_hmac identity)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibfn171

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_name,          "pbkdf2_hmac.__name__.__eq__",           ["pbkdf2_hmac"], true, "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (11 chars = 'pbkdf2'=6 + '_hmac'=5; PBKDF2-HMAC key derivation; RFC 8018)"]
    - [pbkdf2_module,        "pbkdf2_hmac.__module__.__eq__",         ["_hashlib"],    true, "hashlib.pbkdf2_hmac.__module__ == '_hashlib' (8 chars; private C extension; '_hashlib'(8) > 'hashlib'(7) by 1 char)"]
    - [pbkdf2_class_builtin, "pbkdf2_hmac.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' (25 chars; C extension function; contrasts with new.__class__.__name__=='function'(8))"]
    - [pbkdf2_name_len_11,   "pbkdf2_hmac.__name__.__len__",          [],              11,   "hashlib.pbkdf2_hmac.__name__.__len__() is 11 ('pbkdf2_hmac' = 'pbkdf2'=6 + '_hmac'=5 = 11; 'pbkdf2_hmac'(11) == 'file_digest'(11) in length)"]

# ---------------------------------------------------------------------------
# hashlib.scrypt.__name__ and __module__ and __class__.__name__
#
# Wave 350 theme: hashlib.scrypt function identity.
#
# scrypt.__name__ == 'scrypt' (6 chars; memory-hard KDF from RFC 7914).
# scrypt.__module__ == '_hashlib' (8 chars; C extension; same as pbkdf2_hmac).
# scrypt.__class__.__name__ == 'builtin_function_or_method' (25 chars; C builtin).
# scrypt.__name__.__len__() == 6 ('scrypt' = 6 chars; same length as 'sha256').
# No prior hashlib spec anchors scrypt.__name__ as a table under hashlibfn171.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra171.scrypt_function_identity:
  description: "hashlib.scrypt.__name__.__eq__('scrypt')==True / scrypt.__module__.__eq__('_hashlib')==True / scrypt.__class__.__name__.__eq__('builtin_function_or_method')==True / scrypt.__name__.__len__()==6 — scrypt.__name__ is 'scrypt' (6 chars; scrypt is a memory-hard password-based key derivation function designed to be computationally expensive and require large amounts of memory, making brute-force attacks costly; standardized in RFC 7914 (2016); scrypt(password, salt, n, r, p) where n=CPU/memory cost, r=block size, p=parallelization; 'scrypt'(6) == 'sha256'(6) == 'sha512'(6) in length — coincidental equal length; 'scrypt'(6) > 'new'(3) > 'scrypt.__name__'(6): scrypt name is 6 chars); scrypt.__module__ is '_hashlib' (8 chars; private C extension; scrypt is backed by OpenSSL on macOS/Darwin; '_hashlib'(8) == pbkdf2_hmac.__module__(8) — both KDFs share the same C extension; 'scrypt' requires OpenSSL with scrypt support; available on macOS/Darwin 25.4.0 with OpenSSL); scrypt.__class__.__name__ is 'builtin_function_or_method' (25 chars; C extension builtin; same class as pbkdf2_hmac; both scrypt and pbkdf2_hmac are C builtins in _hashlib); scrypt.__name__.__len__() is 6 ('scrypt' = 6 chars; 'scrypt'(6) < '_hashlib'(8) by 2; same 6-char length as SHA algorithm names 'sha256'/'sha512'/'sha224'; first hashlibfn171 anchor for scrypt identity)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibfn171

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_name,          "scrypt.__name__.__eq__",           ["scrypt"],   true, "hashlib.scrypt.__name__ == 'scrypt' (6 chars; memory-hard KDF; RFC 7914; 'scrypt'(6)==sha256'(6) in length)"]
    - [scrypt_module,        "scrypt.__module__.__eq__",         ["_hashlib"], true, "hashlib.scrypt.__module__ == '_hashlib' (8 chars; private C extension; OpenSSL-backed; same as pbkdf2_hmac.__module__)"]
    - [scrypt_class_builtin, "scrypt.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method' (25 chars; C extension; same type as pbkdf2_hmac)"]
    - [scrypt_name_len_6,    "scrypt.__name__.__len__",          [],           6,    "hashlib.scrypt.__name__.__len__() is 6 ('scrypt' = 6 chars; same length as 'sha256'/'sha512'/'sha224'=6 — coincidental)"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__name__ and __module__ and __class__.__name__
#
# Wave 350 theme: hashlib.file_digest identity (Python 3.11+).
#
# file_digest.__name__ == 'file_digest' (11 chars; added in Python 3.11).
# file_digest.__module__ == 'hashlib' (7 chars; pure Python in Lib/hashlib.py).
# file_digest.__class__.__name__ == 'function' (8 chars; pure Python, not C builtin).
# file_digest.__name__.__len__() == 11 ('file_digest' = 11 chars).
# No prior hashlib spec anchors file_digest.__name__ as a table under hashlibfn171.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra171.file_digest_function_identity:
  description: "hashlib.file_digest.__name__.__eq__('file_digest')==True / file_digest.__module__.__eq__('hashlib')==True / file_digest.__class__.__name__.__eq__('function')==True / file_digest.__name__.__len__()==11 — file_digest.__name__ is 'file_digest' (11 chars = 'file'=4 + '_digest'=7; hashlib.file_digest(fileobj, digest) was added in Python 3.11 (bpo-47928); computes a hash digest for an entire file object efficiently using read() in chunks; fileobj must be a file opened in binary mode; digest can be a constructor name string or a callable; 'file_digest'(11) == 'pbkdf2_hmac'(11) in length — coincidental equal length; both are 11-char function names in hashlib); file_digest.__module__ is 'hashlib' (7 chars; pure Python defined in Lib/hashlib.py — file_digest is NOT a C extension function; __module__=='hashlib'(7 chars; public module) contrasts with pbkdf2_hmac.__module__=='_hashlib'(8 chars; private C extension); file_digest.__module__(7) == new.__module__(7) — both are pure Python functions in hashlib); file_digest.__class__.__name__ is 'function' (8 chars; pure Python function; file_digest is the only KDF-adjacent function in this spec that is a pure Python 'function' rather than a C 'builtin_function_or_method'; file_digest.__class__.__name__(8) == new.__class__.__name__(8) — both are 'function'; contrasts with pbkdf2_hmac and scrypt which are 'builtin_function_or_method'(25 chars)); file_digest.__name__.__len__() is 11 ('file_digest' = 11 chars; 'file'=4 + '_digest'=7; 'file_digest'(11) > 'hashlib'(7) > 'scrypt'(6) in length; first hashlibfn171 anchor for file_digest identity)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibfn171

  columns: [id, function, args, expected, description]
  rows:
    - [fd_name,            "file_digest.__name__.__eq__",           ["file_digest"], true, "hashlib.file_digest.__name__ == 'file_digest' (11 chars = 'file'=4 + '_digest'=7; added Python 3.11; computes hash of file object; 'file_digest'(11)=='pbkdf2_hmac'(11))"]
    - [fd_module,          "file_digest.__module__.__eq__",         ["hashlib"],     true, "hashlib.file_digest.__module__ == 'hashlib' (7 chars; pure Python in Lib/hashlib.py; __module__=='hashlib'(7)==new.__module__; not '_hashlib')"]
    - [fd_class_function,  "file_digest.__class__.__name__.__eq__", ["function"],    true, "hashlib.file_digest.__class__.__name__ == 'function' (8 chars; pure Python; same as new.__class__.__name__; contrasts with pbkdf2_hmac/scrypt which are 'builtin_function_or_method')"]
    - [fd_name_len_11,     "file_digest.__name__.__len__",          [],              11,   "hashlib.file_digest.__name__.__len__() is 11 ('file_digest' = 'file'=4 + '_digest'=7 = 11; same 11-char length as 'pbkdf2_hmac'=11)"]

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new') — standalone
#
# hashlib.new.__name__ is '__hash_new' (10 chars). The publicly documented hashlib.new()
# constructor is actually the __hash_new wrapper function defined in Lib/hashlib.py. Its
# __name__ attribute is '__hash_new' (10 chars), not 'new'. The double-underscore prefix
# signals that it is a private/internal function even though it is accessible as hashlib.new.
# '__hash_new'(10) = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3 = 10 chars.
# hashlib.new.__module__ == 'hashlib' (7 chars; pure Python).
# No prior hashlib spec anchors new.__name__ as a standalone under hashlibfn171.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra171.new_name_eq_hash_new:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — '__hash_new' (10 chars = '__'=2 + 'hash'=4 + '_new'=4; hashlib.new is actually the __hash_new wrapper; its __name__ is '__hash_new' not 'new'; '__hash_new'(10) >> 'new'(3) by 7 chars); new.__module__=='hashlib'(7 chars; pure Python); new.__class__.__name__=='function'(8 chars; pure Python function); new.__name__.__len__()==10; first hashlibfn171 standalone for new.__name__"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__module__.__eq__('hashlib') — standalone
#
# hashlib.new.__module__ is 'hashlib' (7 chars). The new/__hash_new function is defined
# in Lib/hashlib.py (pure Python), so its __module__ is the public 'hashlib' module.
# This contrasts with pbkdf2_hmac and scrypt which have __module__ == '_hashlib' (the private
# C extension). 'hashlib' (7 chars) vs '_hashlib' (8 chars): the private C extension name
# is 1 char longer due to the leading underscore.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra171.new_module_eq_hashlib:
  description: "hashlib.new.__module__.__eq__('hashlib') == True — 'hashlib' (7 chars; pure Python defined in Lib/hashlib.py; public module); contrasts with pbkdf2_hmac.__module__=='_hashlib'(8 chars; private C extension — 1 char longer due to '_' prefix); new.__module__(7)==file_digest.__module__(7)=='hashlib' — both pure Python hashlib functions share same module; new.__name__=='__hash_new'(10); first hashlibfn171 standalone for new.__module__"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') — standalone
#
# hashlib.pbkdf2_hmac.__name__ is 'pbkdf2_hmac' (11 chars). PBKDF2 (Password-Based Key
# Derivation Function 2) is a key stretching algorithm that applies a pseudorandom function
# (here HMAC) iteratively to derive a cryptographic key from a password. Defined in PKCS#5
# / RFC 8018. 'pbkdf2_hmac' (11 chars) = 'pbkdf2'=6 + '_hmac'=5. pbkdf2_hmac is a C builtin
# from the _hashlib extension (not a pure Python function like new).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra171.pbkdf2_hmac_name_eq:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True — 'pbkdf2_hmac' (11 chars = 'pbkdf2'=6 + '_hmac'=5; PBKDF2-HMAC key stretching; PKCS#5 / RFC 8018; applies HMAC iteratively to derive cryptographic key from password; pbkdf2_hmac.__module__=='_hashlib'(8 chars; C extension); pbkdf2_hmac.__class__.__name__=='builtin_function_or_method'(25 chars); 'pbkdf2_hmac'(11)==file_digest.__name__.__len__()==11; first hashlibfn171 standalone for pbkdf2_hmac.__name__"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib' (8 chars). pbkdf2_hmac is implemented in
# the _hashlib C extension (Modules/_hashlib.c), which is the same extension that backs
# the OpenSSL-based hash constructors (sha256, sha512, etc.). '_hashlib' (8 chars) = '_'=1 +
# 'hashlib'=7. The leading underscore marks this as a private C extension module.
# '_hashlib'(8) > 'hashlib'(7) by 1 char (the underscore prefix).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra171.pbkdf2_hmac_module_eq:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — '_hashlib' (8 chars = '_'=1 + 'hashlib'=7; private C extension module; Modules/_hashlib.c; same extension as OpenSSL hash constructors sha256/sha512/scrypt); '_hashlib'(8) > 'hashlib'(7) by 1 char (underscore prefix); pbkdf2_hmac.__name__=='pbkdf2_hmac'(11); scrypt.__module__=='_hashlib'(8) too — both KDFs are in the same C extension; first hashlibfn171 standalone for pbkdf2_hmac.__module__"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__name__.__eq__('scrypt') — standalone
#
# hashlib.scrypt.__name__ is 'scrypt' (6 chars). scrypt is a memory-hard key derivation
# function from RFC 7914. It is backed by OpenSSL on macOS/Darwin and may not be available
# on all platforms. 'scrypt' (6 chars) is equal in length to 'sha256' and 'sha512' (both
# 6 chars) — coincidental same length. scrypt.__module__ == '_hashlib' (C extension).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra171.scrypt_name_eq:
