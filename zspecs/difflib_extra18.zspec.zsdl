# difflib.SequenceMatcher.set_seq1 — __qualname__
#
# No prior spec verifies SequenceMatcher.set_seq1.__qualname__ as a standalone
# invariant. For a method defined in class SequenceMatcher, __qualname__ takes
# the form 'SequenceMatcher.set_seq1'.
# Verified at runtime: 'SequenceMatcher.set_seq1'.
# ---------------------------------------------------------------------------

invariant difflib_extra18.SequenceMatcher.set_seq1_qualname:
  description: "difflib.SequenceMatcher.set_seq1.__qualname__ == 'SequenceMatcher.set_seq1' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.set_seq1.__qualname__.__eq__
  args: ["SequenceMatcher.set_seq1"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher.set_seq2 — __qualname__
#
# No prior spec verifies SequenceMatcher.set_seq2.__qualname__ as a standalone
# invariant. For a method defined in class SequenceMatcher, __qualname__ takes
# the form 'SequenceMatcher.set_seq2'.
# Verified at runtime: 'SequenceMatcher.set_seq2'.
# ---------------------------------------------------------------------------

invariant difflib_extra18.SequenceMatcher.set_seq2_qualname:
  description: "difflib.SequenceMatcher.set_seq2.__qualname__ == 'SequenceMatcher.set_seq2' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.set_seq2.__qualname__.__eq__
