spec: difflib_extra18
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra17.zspec.zsdl."
    - "difflib_extra17 covers: SequenceMatcher.ratio/__qualname__; SequenceMatcher.get_matching_blocks/__qualname__; Differ.compare/__qualname__; HtmlDiff.make_file/__qualname__."
    - "difflib_extra3 covers: unified_diff/__qualname__; context_diff/__qualname__; ndiff/__qualname__; SequenceMatcher/__qualname__; Differ/__qualname__; HtmlDiff/__qualname__."
    - "No prior spec covers SequenceMatcher.find_longest_match/__qualname__, SequenceMatcher.get_opcodes/__qualname__, or SequenceMatcher.get_grouped_opcodes/__qualname__ as standalone invariants."
    - "No prior spec covers SequenceMatcher.set_seq1/__qualname__ or SequenceMatcher.set_seq2/__qualname__ as standalone invariants."
    - "No prior spec covers Differ._dump/__qualname__ or HtmlDiff.make_table/__qualname__ as standalone invariants."
    - "Note: difflib.Differ has no public 'dump' method; the private method is '_dump'."
    - "difflib.SequenceMatcher.find_longest_match.__qualname__ == 'SequenceMatcher.find_longest_match' — method qualname includes owning class. Verified at runtime."
    - "difflib.SequenceMatcher.get_opcodes.__qualname__ == 'SequenceMatcher.get_opcodes' — method qualname includes owning class. Verified at runtime."
    - "difflib.SequenceMatcher.get_grouped_opcodes.__qualname__ == 'SequenceMatcher.get_grouped_opcodes' — method qualname includes owning class. Verified at runtime."
    - "difflib.SequenceMatcher.set_seq1.__qualname__ == 'SequenceMatcher.set_seq1' — method qualname includes owning class. Verified at runtime."
    - "difflib.SequenceMatcher.set_seq2.__qualname__ == 'SequenceMatcher.set_seq2' — method qualname includes owning class. Verified at runtime."
    - "difflib.Differ._dump.__qualname__ == 'Differ._dump' — private method qualname includes owning class. Verified at runtime."
    - "difflib.HtmlDiff.make_table.__qualname__ == 'HtmlDiff.make_table' — method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher.find_longest_match — __qualname__
#
# No prior spec verifies SequenceMatcher.find_longest_match.__qualname__ as a
# standalone invariant. For a method defined in class SequenceMatcher,
# __qualname__ takes the form 'SequenceMatcher.find_longest_match'.
# Verified at runtime: 'SequenceMatcher.find_longest_match'.
# ---------------------------------------------------------------------------

invariant difflib_extra18.SequenceMatcher.find_longest_match_qualname:
  description: "difflib.SequenceMatcher.find_longest_match.__qualname__ == 'SequenceMatcher.find_longest_match' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.find_longest_match.__qualname__.__eq__
  args: ["SequenceMatcher.find_longest_match"]
  expected: true

# ---------------------------------------------------------------------------
