# ---------------------------------------------------------------------------
# difflib.Differ._dump — __qualname__
#
# No prior spec verifies Differ._dump.__qualname__ as a standalone invariant.
# Note: difflib.Differ has no public 'dump' method; the private helper is
# '_dump'. For a method defined in class Differ, __qualname__ takes the form
# 'Differ._dump'. Verified at runtime: 'Differ._dump'.
# ---------------------------------------------------------------------------

invariant difflib_extra18.Differ.dump_qualname:
  description: "difflib.Differ._dump.__qualname__ == 'Differ._dump' — private method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: "Differ._dump.__qualname__.__eq__"
  args: ["Differ._dump"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.HtmlDiff.make_table — __qualname__
#
# No prior spec verifies HtmlDiff.make_table.__qualname__ as a standalone
# invariant. For a method defined in class HtmlDiff, __qualname__ takes the
# form 'HtmlDiff.make_table'. Verified at runtime: 'HtmlDiff.make_table'.
# ---------------------------------------------------------------------------

invariant difflib_extra18.HtmlDiff.make_table_qualname:
  description: "difflib.HtmlDiff.make_table.__qualname__ == 'HtmlDiff.make_table' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: HtmlDiff.make_table.__qualname__.__eq__
  args: ["HtmlDiff.make_table"]
  expected: true

# ---------------------------------------------------------------------------
# Table: consolidated difflib method __qualname__ values
#
# Groups all seven method __qualname__ checks from this spec into a single
# table: five SequenceMatcher methods (find_longest_match, get_opcodes,
# get_grouped_opcodes, set_seq1, set_seq2), one Differ private method (_dump),
# and one HtmlDiff method (make_table).
# All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra18.method_qualnames:
  description: "difflib SequenceMatcher, Differ, and HtmlDiff method __qualname__ values — seven methods consolidated"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [SequenceMatcher_find_longest_match,
       SequenceMatcher.find_longest_match.__qualname__.__eq__,
       ["SequenceMatcher.find_longest_match"],
       true,
       "SequenceMatcher.find_longest_match.__qualname__ == 'SequenceMatcher.find_longest_match'"]
    - [SequenceMatcher_get_opcodes,
       SequenceMatcher.get_opcodes.__qualname__.__eq__,
       ["SequenceMatcher.get_opcodes"],
       true,
       "SequenceMatcher.get_opcodes.__qualname__ == 'SequenceMatcher.get_opcodes'"]
    - [SequenceMatcher_get_grouped_opcodes,
       SequenceMatcher.get_grouped_opcodes.__qualname__.__eq__,
       ["SequenceMatcher.get_grouped_opcodes"],
       true,
       "SequenceMatcher.get_grouped_opcodes.__qualname__ == 'SequenceMatcher.get_grouped_opcodes'"]
    - [SequenceMatcher_set_seq1,
       SequenceMatcher.set_seq1.__qualname__.__eq__,
       ["SequenceMatcher.set_seq1"],
       true,
       "SequenceMatcher.set_seq1.__qualname__ == 'SequenceMatcher.set_seq1'"]
    - [SequenceMatcher_set_seq2,
       SequenceMatcher.set_seq2.__qualname__.__eq__,
       ["SequenceMatcher.set_seq2"],
       true,
       "SequenceMatcher.set_seq2.__qualname__ == 'SequenceMatcher.set_seq2'"]
    - [Differ_dump,
       "Differ._dump.__qualname__.__eq__",
       ["Differ._dump"],
       true,
       "Differ._dump.__qualname__ == 'Differ._dump'"]
    - [HtmlDiff_make_table,
       HtmlDiff.make_table.__qualname__.__eq__,
       ["HtmlDiff.make_table"],
       true,
       "HtmlDiff.make_table.__qualname__ == 'HtmlDiff.make_table'"]
