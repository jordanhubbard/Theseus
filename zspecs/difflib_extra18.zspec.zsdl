#
# No prior spec verifies SequenceMatcher.get_grouped_opcodes.__qualname__ as a
# standalone invariant. For a method defined in class SequenceMatcher,
# __qualname__ takes the form 'SequenceMatcher.get_grouped_opcodes'.
# Verified at runtime: 'SequenceMatcher.get_grouped_opcodes'.
# ---------------------------------------------------------------------------

invariant difflib_extra18.SequenceMatcher.get_grouped_opcodes_qualname:
  description: "difflib.SequenceMatcher.get_grouped_opcodes.__qualname__ == 'SequenceMatcher.get_grouped_opcodes' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.get_grouped_opcodes.__qualname__.__eq__
  args: ["SequenceMatcher.get_grouped_opcodes"]
  expected: true

