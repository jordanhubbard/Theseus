spec: itertools_extra46
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra45.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all types; __name__/__qualname__ string equality for all major types; __bases__[0].__name__=='object' string equality for chain/count/product/permutations/combinations/combinations_with_replacement/groupby/islice/zip_longest/accumulate/compress/dropwhile/takewhile/filterfalse/starmap/pairwise/batched/repeat/cycle; __bases__[0].__qualname__=='object' for groupby/chain/compress/islice/zip_longest/permutations/combinations/product/accumulate (extra45)."
    - "This spec covers: itertools.starmap.__bases__[0].__qualname__ == 'object'; itertools.dropwhile.__bases__[0].__qualname__ == 'object'; itertools.takewhile.__bases__[0].__qualname__ == 'object'; itertools.filterfalse.__bases__[0].__qualname__ == 'object'; itertools.pairwise.__bases__[0].__qualname__ == 'object'; itertools.batched.__bases__[0].__qualname__ == 'object'; itertools.repeat.__bases__[0].__qualname__ == 'object'; itertools.cycle.__bases__[0].__qualname__ == 'object'; itertools.combinations_with_replacement.__bases__[0].__qualname__ == 'object'."
    - "Key findings: All nine remaining itertools C-extension types have __bases__[0].__qualname__ == 'object'. Every itertools type defined in Modules/itertoolsmodule.c inherits directly from PyBaseObject_Type (object) with no intermediate class; for the built-in object type __qualname__ equals __name__ (both are 'object'). Prior spec extra45 covered __bases__[0].__qualname__ for the first nine types (groupby, chain, compress, islice, zip_longest, permutations, combinations, product, accumulate). This spec completes the __bases__[0].__qualname__ coverage for the remaining nine itertools types: the filtering/mapping types (starmap, dropwhile, takewhile, filterfalse), the newer additions (pairwise added 3.10, batched added 3.12), the infinite iterators (repeat, cycle), and the remaining combinatoric type (combinations_with_replacement). The __qualname__ attribute provides the same value as __name__ for the built-in object type but is a distinct attribute lookup."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools filtering/mapping types __bases__[0].__qualname__ — extra46 namespace
#
# itertools.starmap, dropwhile, takewhile, and filterfalse all have
# __bases__[0].__qualname__ == 'object'. These four are C-extension types
# defined in Modules/itertoolsmodule.c that filter or map over iterables.
# Prior spec extra44 recorded __bases__[0].__name__ == 'object' (string equality)
# for all four. Prior spec extra45 recorded __bases__[0].__qualname__ for
# groupby, chain, compress, islice, zip_longest, permutations, combinations,
# product, and accumulate — but not for these four. All four are new to extra46.
# ---------------------------------------------------------------------------

table itertools_extra46.filtering_mapping_bases_qualname:
  description: "itertools starmap/dropwhile/takewhile/filterfalse __bases__[0].__qualname__ == 'object' — C-extension filtering/mapping types inheriting directly from object; __qualname__ == __name__ for built-in object type"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: fmbq46

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_bases_qualname,
       "starmap.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__qualname__ == 'object' — C-extension type in itertoolsmodule.c; inherits directly from object; maps a function using arguments unpacked from each tuple in an iterable"]
    - [dropwhile_bases_qualname,
       "dropwhile.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.dropwhile.__bases__[0].__qualname__ == 'object' — C-extension type in itertoolsmodule.c; inherits directly from object; drops elements while a predicate is true then yields the remainder"]
    - [takewhile_bases_qualname,
       "takewhile.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.takewhile.__bases__[0].__qualname__ == 'object' — C-extension type in itertoolsmodule.c; inherits directly from object; yields elements while a predicate is true then stops"]
    - [filterfalse_bases_qualname,
       "filterfalse.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.filterfalse.__bases__[0].__qualname__ == 'object' — C-extension type in itertoolsmodule.c; inherits directly from object; yields elements for which the predicate is false (complement of the built-in filter)"]

# ---------------------------------------------------------------------------
# itertools newer and infinite types __bases__[0].__qualname__ — extra46 namespace
#
# itertools.pairwise (added Python 3.10), itertools.batched (added Python 3.12),
# itertools.repeat, and itertools.cycle all have __bases__[0].__qualname__ == 'object'.
# All four are C-extension types in itertoolsmodule.c inheriting directly from
# PyBaseObject_Type. Prior spec extra44 recorded __bases__[0].__name__ == 'object'
# (string equality) for all four. Extra45 covered __bases__[0].__qualname__ only
# for the first nine types — not for these four. All four are new to extra46.
# ---------------------------------------------------------------------------

table itertools_extra46.newer_infinite_bases_qualname:
  description: "itertools pairwise/batched/repeat/cycle __bases__[0].__qualname__ == 'object' — C-extension types including Python 3.10/3.12 additions and infinite iterators; all inherit directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: nibq46

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_bases_qualname,
       "pairwise.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.pairwise.__bases__[0].__qualname__ == 'object' — C-extension type added in Python 3.10; inherits directly from object; yields consecutive overlapping pairs (a, b), (b, c), ... from an iterable"]
    - [batched_bases_qualname,
       "batched.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.batched.__bases__[0].__qualname__ == 'object' — C-extension type added in Python 3.12; inherits directly from object; batches an iterable into non-overlapping tuples of at most length n"]
    - [repeat_bases_qualname,
       "repeat.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__qualname__ == 'object' — C-extension type in itertoolsmodule.c; inherits directly from object; infinite (or bounded) iterator that yields the same object repeatedly"]
    - [cycle_bases_qualname,
       "cycle.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__qualname__ == 'object' — C-extension type in itertoolsmodule.c; inherits directly from object; cycles through an iterable indefinitely, saving a copy internally"]

# ---------------------------------------------------------------------------
# itertools.combinations_with_replacement __bases__[0].__qualname__ — extra46
#
# itertools.combinations_with_replacement is a C-extension type in
# itertoolsmodule.c that yields r-length subsequences with possible repeated
# elements. Its __bases__[0].__qualname__ is 'object' — the type inherits
# directly from PyBaseObject_Type. Prior spec extra43 recorded
# __bases__[0].__name__ == 'object' (string equality) and prior specs recorded
# __qualname__ == 'combinations_with_replacement'. Extra45 covered
# __bases__[0].__qualname__ for combinations (without replacement) and product,
# but not for combinations_with_replacement. This invariant is new to extra46.
# ---------------------------------------------------------------------------

invariant itertools_extra46.combinations_with_replacement_bases_qualname:
  description: "itertools.combinations_with_replacement.__bases__[0].__qualname__ == 'object' — C-extension type; inherits directly from object; yields r-length subsequences with repeated elements; __qualname__ == __name__ == 'object' for built-in object type"
  category: class_hierarchy
  kind: python_call_eq
  function: "combinations_with_replacement.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true
