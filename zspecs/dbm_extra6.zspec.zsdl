spec: dbm_extra6
version: ">=3.9"
backend: python_module(dbm)

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dbm.html — Python dbm module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dbm/__init__.py"
    - "CPython source: Lib/dbm/dumb.py"
  notes:
    - "This spec extends dbm.zspec.zsdl through dbm_extra5.zspec.zsdl with new, non-duplicate invariants."
    - "dbm_extra5 covers: dumb._Database.__bases__[0].__name__; dumb.__package__; _names.__len__ >= 1; dumb.open.__qualname__."
    - "dbm_extra4 covers: open/__module__; open/__doc__ type; dumb.error/__module__; _names[0] type; error/__mro__ length."
    - "dbm_extra3 covers: __qualname__ for open, whichdb, error; _names.__class__.__name__."
    - "dbm_extra2 covers: dbm.__name__; dbm.__package__; dumb.open/__module__; dumb._Database/__name__/__module__; attr_names table."
    - "dbm_extra covers: open/__name__/__module__/is_function; whichdb/__name__/__module__/is_function; error bases; dumb attrs."
    - "No prior spec covers: dbm.open.__class__.__name__ == 'function' — function metatype; only __module__/__qualname__ checked before."
    - "No prior spec covers: dbm.whichdb.__class__.__name__ == 'function' — whichdb function metatype; only name/module/qualname checked."
    - "No prior spec covers: dbm.dumb.open.__class__.__name__ == 'function' — dumb.open metatype."
    - "No prior spec covers: dbm.error[0].__name__ == 'error' — first element of the error tuple by name."
    - "No prior spec covers: dbm.error[1].__name__ == 'OSError' — second element of the error tuple is OSError."
    - "No prior spec covers: dbm.error[0].__module__ == 'dbm' — the dbm.error exception class lives in dbm."
    - "No prior spec covers: dbm.dumb._Database.__qualname__ == '_Database' — qualname for the dumb backend class."
    - "dbm.error is a tuple of (dbm.error class, OSError); error[0].__name__ == 'error', error[1].__name__ == 'OSError'."
    - "dbm.open.__class__.__name__ == 'function' — consistent with whichdb which is also a plain function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dbm.error tuple element names
#
# dbm.error is a tuple of two types: (dbm.error, OSError).
# dbm_extra checks that error is a tuple and has __len__ 2.
# No prior spec checks the __name__ of either element.
# error[0] is the custom dbm.error exception class (name 'error').
# error[1] is the built-in OSError (name 'OSError').
# ---------------------------------------------------------------------------

invariant dbm_extra6.error_0_name:
  description: "dbm.error[0].__name__ == 'error' — first element is the dbm-specific exception class"
  category: exception_attrs
  kind: python_call_eq
  function: "error[0].__name__.__eq__"
  args: ["error"]
  expected: true

invariant dbm_extra6.error_1_name:
  description: "dbm.error[1].__name__ == 'OSError' — second element of the error tuple is OSError"
  category: exception_attrs
  kind: python_call_eq
  function: "error[1].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.error[0].__module__
#
# dbm_extra4 checks dumb.error.__module__ == 'dbm'. No prior spec checks
# the __module__ of dbm.error[0] (the primary dbm exception class).
# The dbm.error class is defined in the dbm package itself.
# ---------------------------------------------------------------------------

invariant dbm_extra6.error_0_module:
  description: "dbm.error[0].__module__ == 'dbm' — the dbm exception class is defined in the dbm package"
  category: exception_attrs
  kind: python_call_eq
  function: "error[0].__module__.__eq__"
  args: ["dbm"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.dumb._Database.__qualname__
#
# dbm_extra2 checks _Database.__name__ == '_Database' and __module__.
# dbm_extra5 checks _Database.__bases__[0].__name__ == 'object'.
# No prior spec checks _Database.__qualname__.
# For a top-level class, __qualname__ == __name__ == '_Database'.
# ---------------------------------------------------------------------------

invariant dbm_extra6.dumb._Database.qualname:
  description: "dbm.dumb._Database.__qualname__ == '_Database' — top-level class qualname matches name"
  category: class_attrs
  kind: python_call_eq
  function: dumb._Database.__qualname__.__eq__
  args: ["_Database"]
  expected: true

# ---------------------------------------------------------------------------
# Function metatype table — open, whichdb, dumb.open
#
# dbm_extra covers that open is a function (is_function), but uses a
# different axis. No prior spec checks __class__.__name__ == 'function'
# for any of these three callables directly. This provides the class-name
# angle on the same fact.
# ---------------------------------------------------------------------------

table dbm_extra6.function_metatypes:
  description: "dbm callables — __class__.__name__ == 'function'"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fmeta6

  columns: [id, function, args, expected]
  rows:
    - [open_class,      open.__class__.__name__.__eq__,      ["function"], true]
    - [whichdb_class,   whichdb.__class__.__name__.__eq__,   ["function"], true]
    - [dumb_open_class, dumb.open.__class__.__name__.__eq__, ["function"], true]
