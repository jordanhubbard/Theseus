spec: sk2911
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 641 (sk2911): __ilshift__, __irshift__, __ipow__ dict-presence checks for socket types."
    - "Wave 638 showed socket.AddressInfo and socket.MsgFlag have reflected bitwise ops (__ror__, __rand__, __rxor__) True; wave 639 showed in-place bitwise (__ior__, __iand__, __ixor__) are also present."
    - "Despite the IntFlag inheritance of AddressInfo and MsgFlag, in-place shift and power ops (ilshift/irshift/ipow) are NOT defined — these are bitwise-flag types, not shift or power types."
    - "socket.AddressFamily and socket.SocketKind are also IntFlag subclasses and likewise do not define __ilshift__, __irshift__, or __ipow__ in their own __dict__."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2911.ilshift:
  description: "socket types __ilshift__ dict-presence checks; wave 641"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2911
  columns: [id, function, args, expected]
  rows:
    - ["sk2911001", operator.contains, [socket.socket.__dict__,        "__ilshift__"], false]
    - ["sk2911002", operator.contains, [socket.AddressFamily.__dict__, "__ilshift__"], false]
    - ["sk2911003", operator.contains, [socket.SocketKind.__dict__,    "__ilshift__"], false]
    - ["sk2911004", operator.contains, [socket.AddressInfo.__dict__,   "__ilshift__"], false]
    - ["sk2911005", operator.contains, [socket.MsgFlag.__dict__,       "__ilshift__"], false]
    - ["sk2911006", operator.contains, [socket.error.__dict__,         "__ilshift__"], false]
    - ["sk2911007", operator.contains, [socket.herror.__dict__,        "__ilshift__"], false]
    - ["sk2911008", operator.contains, [socket.gaierror.__dict__,      "__ilshift__"], false]

