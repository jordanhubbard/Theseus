spec: theseus_random_cr
version: ">=3.9"
backend: python_cleanroom(theseus_random_cr)
blocks: random

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://en.wikipedia.org/wiki/Linear_congruential_generator"
  notes:
    - "Clean-room pseudo-random number generator. Do NOT import random or secrets."
    - "May use os.urandom for seeding only."
    - "Implement an LCG (Linear Congruential Generator): next = (a*x + c) % m."
    - "randint(a, b): uniform integer in [a, b] inclusive."
    - "choice(seq): uniformly random element from non-empty sequence."
    - "shuffle(seq): in-place shuffle using Fisher-Yates algorithm."
    - "random_randint_range(): randint(1, 10) returns int in [1, 10]."
    - "random_choice_valid(): choice([1,2,3,4,5]) returns one of those values."
    - "random_shuffle_len(): shuffle([1,2,3]) preserves length."
    - "Export: randint(a, b) -> int, choice(seq), shuffle(seq), random() -> float."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_random_cr.randint_range:
  description: "randint(1, 10) returns int in [1, 10]"
  category: randint
  kind: python_call_eq
  function: random_randint_range
  args: []
  expected: true

invariant theseus_random_cr.choice_valid:
  description: "choice([1,2,3,4,5]) returns one of those values"
  category: choice
  kind: python_call_eq
  function: random_choice_valid
  args: []
  expected: true

invariant theseus_random_cr.shuffle_len:
  description: "shuffle preserves list length and same elements"
  category: shuffle
  kind: python_call_eq
  function: random_shuffle_preserves_elements
  args: []
  expected: true
