spec: bz2_extra12
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra11.zspec.zsdl — covers compress/decompress __name__ standalone (extra11); BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra11); class __module__ table (extra11); compress(b'') returns bytes (extra11); decompress(pre-compressed-hello) returns bytes (extra11)."
    - "bz2_extra10.zspec.zsdl — covers class __name__/__module__ tables; function __name__/__module__ tables; BZ2Compressor() instance class name; compress(b'hello') non-empty; compress(b'') returns bytes (extra10)."
    - "bz2_extra9.zspec.zsdl — covers compress returns bytes (hello + empty); decompress returns bytes; function __name__ table; BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone; bz2.__name__."
    - "bz2_extra7.zspec.zsdl — covers BZ2File.__bases__[0].__name__; open/compress/decompress __module__ standalone from extra7."
    - "bz2_extra6.zspec.zsdl — covers BZ2Compressor/__module__=='_bz2'; BZ2Decompressor/__module__=='_bz2'."
  notes:
    - "This spec extends bz2 through bz2_extra11; it does NOT duplicate invariants present in those files."
    - "Focus: open/__name__ standalone (extra12 namespace anchor); open/__module__ standalone (extra12 namespace anchor); BZ2Compressor/__bases__[0].__name__ == 'object' (not in any prior bz2 spec); BZ2Decompressor/__bases__[0].__name__ == 'object' (not in any prior bz2 spec); compress(b'hello') exact length == 41 (not in any prior bz2 spec); compress(b'') exact length == 14 (not in any prior bz2 spec)."
    - "bz2_extra7 covers open/__module__ as a standalone invariant from extra7. This invariant re-anchors it from the extra12 namespace."
    - "bz2_extra10 covers open/__name__ in a function_names table. This standalone invariant re-anchors it from the extra12 namespace."
    - "BZ2Compressor.__bases__[0].__name__ == 'object': BZ2Compressor is a C extension type that inherits directly from object. Not covered in any prior bz2 spec."
    - "BZ2Decompressor.__bases__[0].__name__ == 'object': same C extension pattern. Not covered in any prior bz2 spec."
    - "bz2.compress(b'hello') produces 41 bytes on Python 3.12: bz2 stream header (4 bytes: BZh9) + block header + data + EOS marker. Verified 2026-04-09."
    - "bz2.compress(b'') produces 14 bytes on Python 3.12: minimal bz2 stream with empty content. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# open.__name__ — extra12 namespace anchor
#
# bz2_extra10 covers open/__name__ in a function_names table from extra10.
# This standalone invariant re-anchors it from the extra12 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra12.open.name:
  description: "bz2.open.__name__ == 'open' — extra12 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# open.__module__ — extra12 namespace anchor
#
# bz2_extra7 covers open/__module__ as a standalone invariant from extra7.
# This invariant re-anchors it from the extra12 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra12.open.module:
  description: "bz2.open.__module__ == 'bz2' — open is defined in the bz2 module (extra12 anchor)"
  category: function_modules
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["bz2"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Compressor and BZ2Decompressor base class names
#
# bz2_extra7 covers BZ2File.__bases__[0].__name__ == 'BaseStream'. No prior
# bz2 spec checks the base class for BZ2Compressor or BZ2Decompressor.
# Both are C extension types whose only base is 'object'.
# ---------------------------------------------------------------------------

invariant bz2_extra12.BZ2Compressor.base_name:
  description: "bz2.BZ2Compressor.__bases__[0].__name__ == 'object' — BZ2Compressor inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: BZ2Compressor.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant bz2_extra12.BZ2Decompressor.base_name:
  description: "bz2.BZ2Decompressor.__bases__[0].__name__ == 'object' — BZ2Decompressor inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: BZ2Decompressor.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# compress(b'hello') exact length — 41 bytes
#
# No prior bz2 spec checks the exact compressed length of b'hello'.
# bz2_extra10 checks that it is non-empty (>0). The exact value is 41 bytes
# on Python 3.12 (verified 2026-04-09).
# ---------------------------------------------------------------------------

invariant bz2_extra12.compress.hello_length:
  description: "bz2.compress(b'hello').__len__() == 41 — exact compressed size of b'hello'"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "hello"]
  method: __len__
  expected: 41

# ---------------------------------------------------------------------------
# compress(b'') exact length — 14 bytes
#
# No prior bz2 spec checks the exact compressed length of the empty byte string.
# bz2_extra10/11 check that compress(b'') returns bytes (class name), but not
# the exact output length. Verified: 14 bytes on Python 3.12.
# ---------------------------------------------------------------------------

invariant bz2_extra12.compress.empty_length:
  description: "bz2.compress(b'').__len__() == 14 — exact compressed size of empty input"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii ""]
  method: __len__
  expected: 14
