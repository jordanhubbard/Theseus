spec: struct_extra61
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra60.zspec.zsdl — covers struct.error.__bases__[0].__name__=='Exception' / error.__mro__.__len__()==4 / error.__qualname__=='error' / unpack.__doc__.__class__.__name__=='str' / calcsize.__doc__.__class__.__name__=='str' / pack.__doc__.__contains__('struct') (table + invariants)."
    - "struct_extra59.zspec.zsdl — covers unpack.__doc__.__contains__('unpack') / unpack.__doc__.__contains__('tuple') / calcsize.__doc__.__contains__('size') / calcsize.__doc__.__contains__('format') / Struct.__doc__.__contains__('compiled') / Struct.__doc__.__contains__('object') / pack.__doc__.__len__()==176 (table + invariants)."
    - "struct_extra58.zspec.zsdl — covers struct.__doc__.__contains__('struct') / error.__doc__.__class__.__name__.__eq__('NoneType') / pack.__doc__.__class__.__name__.__eq__('str') / unpack.__doc__.__contains__('format') (table + invariants)."
    - "struct_extra57.zspec.zsdl — covers struct.__doc__.__class__.__name__.__eq__('str') / Struct.__doc__.__contains__('Struct') / Struct.__doc__.__contains__('fmt') / pack.__doc__.__contains__('format') (table + invariants)."
    - "struct_extra11.zspec.zsdl — covers struct.error.__module__.__eq__('struct') and Struct.__module__.__eq__('_struct') as standalone invariants."
    - "struct_extra8.zspec.zsdl — covers function __module__ (all '_struct' except error 'struct')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra60; it does NOT duplicate invariants present in those files."
    - "Wave 232 theme: struct.Struct class hierarchy + identity checks, and pack_into/unpack_from/iter_unpack docstring content."
    - "struct.Struct is a C extension type (from _struct.c) that subclasses object directly. struct_extra11 checks Struct.__module__.__eq__('_struct'). No prior struct spec checks Struct.__bases__[0].__name__, Struct.__mro__.__len__(), Struct.__name__, Struct.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct is a C extension type subclassing object directly; __bases__ has one entry. The [0] subscript requires double-quoting in table rows. No prior struct spec checks Struct.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__.__len__() == 2 — MRO is [Struct, object] with 2 entries. No prior struct spec checks Struct.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct' — the C extension type's __name__ is 'Struct'. No prior struct spec checks Struct.__name__.__eq__('Struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct' — Struct is a top-level type so __qualname__ == 'Struct'. No prior struct spec checks Struct.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__doc__.__contains__('buffer') == True — pack_into(fmt, buffer, offset, v1, v2, ...) has 'buffer' in its docstring; all prior struct specs on pack_into check __qualname__ or __module__ but not docstring content. No prior struct spec checks pack_into.__doc__.__contains__ for any word. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__doc__.__contains__('offset') == True — 'offset' is the third parameter of pack_into and appears in its docstring. No prior struct spec checks pack_into.__doc__.__contains__('offset'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__doc__.__contains__('buffer') == True — unpack_from(fmt, /, buffer, offset=0) has 'buffer' in its docstring. No prior struct spec checks unpack_from.__doc__.__contains__ for any word. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__doc__.__contains__('offset') == True — 'offset' appears in the unpack_from docstring as a parameter. No prior struct spec checks unpack_from.__doc__.__contains__('offset'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__doc__.__contains__('buffer') == True — iter_unpack(fmt, buffer) has 'buffer' as its second parameter appearing in the docstring. No prior struct spec checks iter_unpack.__doc__.__contains__ for any word. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct class identity checks — name, module, qualname, bases
#
# Wave 232 theme: Struct class identity beyond the module axis.
#
# struct.Struct is a C extension type from _struct. struct_extra11 checks
# Struct.__module__.__eq__('_struct') (module axis). No prior struct spec
# checks Struct.__name__, Struct.__qualname__, or Struct.__bases__[0].__name__.
# The [0] subscript in Struct.__bases__[0].__name__ requires double-quoting.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra61.Struct_identity:
  description: "struct.Struct.__name__=='Struct' / Struct.__module__=='_struct' / Struct.__qualname__=='Struct' / Struct.__bases__[0].__name__=='object' — Struct is a C extension type from _struct subclassing object directly; struct_extra11 checks Struct.__module__.__eq__('_struct') (module axis); no prior struct spec checks Struct.__name__, Struct.__qualname__, or Struct.__bases__[0].__name__; first name/qualname/bases identity anchor for struct.Struct"
  kind: python_call_eq
  category: class_identity
  id_prefix: structid3_61

  columns: [id, function, args, expected]
  rows:
    - [Struct_name_Struct,      Struct.__name__.__eq__,                  ["Struct"],  true]
    - [Struct_module__struct,   Struct.__module__.__eq__,                ["_struct"], true]
    - [Struct_qualname_Struct,  Struct.__qualname__.__eq__,              ["Struct"],  true]
    - [Struct_bases_0_object,   "Struct.__bases__[0].__name__.__eq__",   ["object"],  true]

# ---------------------------------------------------------------------------
# struct.Struct class hierarchy — MRO length
#
# Wave 232 theme: Struct MRO depth check.
#
# struct.Struct is a C extension type that subclasses object directly. Its MRO
# is [Struct, object] with exactly 2 entries. No prior struct spec checks
# Struct.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra61.Struct_hierarchy:
  description: "struct.Struct.__mro__.__len__()==2 — MRO is [Struct, object] with 2 entries; Struct subclasses object directly with no intermediate classes; no prior struct spec checks Struct.__mro__.__len__(); first MRO length anchor for struct.Struct"
  kind: python_call_eq
  category: class_identity
  id_prefix: structid3_61

  columns: [id, function, args, expected]
  rows:
    - [Struct_mro_len_2, Struct.__mro__.__len__, [], 2]

# ---------------------------------------------------------------------------
# struct.pack_into __doc__ content checks
#
# Wave 232 theme: docstring content for C builtin pack_into.
#
# struct.pack_into(fmt, buffer, offset, v1, v2, ...) writes packed bytes into
# a buffer at a given offset. 'buffer' and 'offset' are key parameters that
# appear in the docstring. No prior struct spec checks pack_into docstring
# content for any word. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra61.pack_into_doc_contains:
  description: "struct.pack_into.__doc__.__contains__('buffer') and pack_into.__doc__.__contains__('offset') — pack_into(fmt, buffer, offset, v1, ...) writes packed bytes into a writable buffer at a given offset; both 'buffer' and 'offset' appear in the docstring as key parameter names; no prior struct spec checks pack_into.__doc__.__contains__ for any word; first docstring content anchor for pack_into"
  kind: python_call_eq
  category: docstrings
  id_prefix: structid3_61

  columns: [id, function, args, expected]
  rows:
    - [pack_into_doc_contains_buffer, pack_into.__doc__.__contains__, ["buffer"], true]
    - [pack_into_doc_contains_offset, pack_into.__doc__.__contains__, ["offset"], true]

# ---------------------------------------------------------------------------
# struct.unpack_from and iter_unpack __doc__ content checks
#
# Wave 232 theme: docstring content for C builtins unpack_from and iter_unpack.
#
# struct.unpack_from(fmt, /, buffer, offset=0) reads from a buffer at an offset.
# struct.iter_unpack(fmt, buffer) yields successive unpack results from buffer.
# 'buffer' and 'offset' appear in unpack_from's docstring; 'buffer' appears in
# iter_unpack's docstring. No prior struct spec checks unpack_from or iter_unpack
# docstring content for any word. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra61.unpack_from_iter_unpack_doc_contains:
  description: "struct.unpack_from.__doc__.__contains__('buffer'/'offset') and iter_unpack.__doc__.__contains__('buffer') — unpack_from(fmt, /, buffer, offset=0) reads packed bytes from buffer at offset; iter_unpack(fmt, buffer) yields successive results; 'buffer' and 'offset' appear in unpack_from's docstring; 'buffer' appears in iter_unpack's docstring; no prior struct spec checks unpack_from or iter_unpack docstring content; first content anchor for unpack_from and iter_unpack"
  kind: python_call_eq
  category: docstrings
  id_prefix: structid3_61

  columns: [id, function, args, expected]
  rows:
    - [unpack_from_doc_contains_buffer,  unpack_from.__doc__.__contains__,  ["buffer"], true]
    - [unpack_from_doc_contains_offset,  unpack_from.__doc__.__contains__,  ["offset"], true]
    - [iter_unpack_doc_contains_buffer,  iter_unpack.__doc__.__contains__,  ["buffer"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct') — standalone
#
# struct.Struct is the compiled struct object class. Its __name__ is 'Struct'.
# struct_extra11 covers Struct.__module__.__eq__('_struct') (module axis).
# No prior struct spec checks Struct.__name__.__eq__. First __name__ identity
# anchor for struct.Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra61.Struct_name_Struct:
  description: "struct.Struct.__name__.__eq__('Struct') == True — Struct is the compiled struct object C extension type; its __name__ is 'Struct'; struct_extra11 covers Struct.__module__.__eq__('_struct') (module axis); no prior struct spec checks Struct.__name__.__eq__; first __name__ identity anchor for struct.Struct"
  category: class_identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct is defined in the C extension _struct (compiled as _struct.so).
# Its __module__ attribute is '_struct'. struct_extra11 checks this as a
# standalone invariant — this spec uses it as a standalone anchor complementing
# the Struct_identity table above. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra61.Struct_module_struct:
  description: "struct.Struct.__module__.__eq__('_struct') == True — Struct is a C extension type defined in _struct; its __module__ is '_struct'; struct_extra11 also checks this (module axis anchor); this standalone confirms the identity chain for struct_extra61 readers; complementary module identity anchor for struct.Struct"
  category: class_identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__bases__[0].__name__.__eq__('object') — standalone
#
# struct.Struct is a C extension type that subclasses object directly. Its
# __bases__ tuple has exactly one element: object. No prior struct spec checks
# Struct.__bases__[0].__name__. First base class identity anchor for Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra61.Struct_bases_object:
  description: "struct.Struct.__bases__[0].__name__.__eq__('object') == True — Struct is a C extension type subclassing object directly; __bases__ has one entry: object; no prior struct spec checks Struct.__bases__[0].__name__; first base class identity anchor for struct.Struct"
  category: class_identity
  kind: python_call_eq
  function: Struct.__bases__
  method_chain: ["__getitem__", "__getattribute__", "__eq__"]
  method_chain_args: [[0], ["__name__"], ["object"]]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__mro__.__len__() == 2 — standalone
#
# The MRO of struct.Struct is [Struct, object] — exactly 2 entries. Struct
# subclasses object with no intermediate classes. No prior struct spec checks
# Struct.__mro__.__len__(). First MRO length anchor for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra61.Struct_mro_2:
  description: "struct.Struct.__mro__.__len__() == 2 — MRO is [Struct, object] with 2 entries; Struct subclasses object directly; no prior struct spec checks Struct.__mro__.__len__(); first MRO length anchor for struct.Struct"
  category: class_identity
  kind: python_call_eq
  function: Struct.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# struct.pack_into.__doc__.__contains__('buffer') — standalone
#
# struct.pack_into writes packed bytes into a writable buffer. The word 'buffer'
# appears in the docstring as a key parameter name. No prior struct spec checks
# pack_into.__doc__.__contains__ for any word. First docstring content anchor
# for pack_into. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra61.pack_into_doc_buffer:
  description: "struct.pack_into.__doc__.__contains__('buffer') == True — pack_into(fmt, buffer, offset, v1, ...) writes into a writable buffer; 'buffer' is a key parameter name appearing in the docstring; no prior struct spec checks pack_into.__doc__.__contains__ for any word; first docstring content anchor for pack_into"
  category: docstrings
  kind: python_call_eq
  function: pack_into.__doc__.__contains__
  args: ["buffer"]
  expected: true
