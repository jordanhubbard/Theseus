spec: lodash_startswith
version: ">=4.0.0"
backend: node(lodash.startswith)

docs: https://lodash.com/docs/#startsWith

provenance:
  derived_from:
    - "lodash.startswith README — https://www.npmjs.com/package/lodash.startswith"
    - "Test vectors verified with lodash.startswith@4.2.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.startswith exports the _.startsWith function directly as module.exports."
    - "startsWith(string, target, position) checks if string starts with target."
    - "Optional position offsets where the check begins."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_startswith.startswith:
  kind: node_module_call_eq
  function: ~
  category: startswith
  id_prefix: lsw

  columns: [id, args, expected]
  rows:
    - [match,       ["hello world", "hello"],    true]
    - [no_match,    ["hello world", "world"],    false]
    - [empty_tgt,   ["hello", ""],               true]
    - [full_match,  ["abc", "abc"],              true]
    - [with_pos,    ["hello", "llo", 2],         true]

