spec: uuid_extra2236
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
  notes:
    - "Theme: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__ presence in class __dict__."
    - "uuid.UUID defines __slots__ = ('int', 'is_safe', '__weakref__') — so __slots__ IS in UUID.__dict__."
    - "__weakref__ is in UUID.__dict__ because it appears as a slot name in __slots__, creating a weakref descriptor."
    - "__dict__ is NOT in UUID.__dict__ because __slots__ suppresses the instance __dict__ slot."
    - "__abstractmethods__ is NOT in UUID.__dict__ — UUID is a concrete class."
    - "__init__ IS in UUID.__dict__ — UUID defines its own __init__ in pure Python."
    - "__new__ is NOT in UUID.__dict__ — UUID does not override __new__."
    - "uuid.SafeUUID is an IntEnum subclass; it inherits __new__ from Enum machinery."
    - "SafeUUID does NOT define __slots__, __weakref__, __dict__, __abstractmethods__, or __init__ in its own __dict__."
    - "SafeUUID.__new__ IS in SafeUUID.__dict__ — Enum metaclass injects __new__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table uuid_extra2236.UUID_slots:
  description: "uuid.UUID pure-Python class — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: uu2236
  columns: [id, function, args, expected]
  rows:
    - ["uu2236001", uuid.UUID.__dict__.__contains__, ["__slots__"], true]
    - ["uu2236002", uuid.UUID.__dict__.__contains__, ["__weakref__"], true]
    - ["uu2236003", uuid.UUID.__dict__.__contains__, ["__dict__"], false]
    - ["uu2236004", uuid.UUID.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["uu2236005", uuid.UUID.__dict__.__contains__, ["__init__"], true]
    - ["uu2236006", uuid.UUID.__dict__.__contains__, ["__new__"], false]
    - ["uu2236007", uuid.UUID.__dict__.__contains__, ["__subclasshook__"], false]

table uuid_extra2236.SafeUUID_slots:
  description: "uuid.SafeUUID IntEnum class — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: uu2236
  columns: [id, function, args, expected]
  rows:
    - ["uu2236008", uuid.SafeUUID.__dict__.__contains__, ["__slots__"], false]
    - ["uu2236009", uuid.SafeUUID.__dict__.__contains__, ["__weakref__"], false]
    - ["uu2236010", uuid.SafeUUID.__dict__.__contains__, ["__dict__"], false]
    - ["uu2236011", uuid.SafeUUID.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["uu2236012", uuid.SafeUUID.__dict__.__contains__, ["__init__"], false]
    - ["uu2236013", uuid.SafeUUID.__dict__.__contains__, ["__new__"], true]
    - ["uu2236014", uuid.SafeUUID.__dict__.__contains__, ["__subclasshook__"], false]

table uuid_extra2236.UUID_classname:
  description: "uuid.UUID class identity attributes"
  kind: python_call_eq
  category: classnames
  id_prefix: uu2236
  columns: [id, function, args, expected]
  rows:
    - ["uu2236015", uuid.UUID.__name__.__eq__, ["UUID"], true]
    - ["uu2236016", uuid.UUID.__module__.__eq__, ["uuid"], true]
    - ["uu2236017", uuid.UUID.__class__.__name__.__eq__, ["type"], true]
    - ["uu2236018", uuid.UUID.__qualname__.__eq__, ["UUID"], true]
    - ["uu2236019", uuid.UUID.__dict__.__contains__, ["__doc__"], true]

table uuid_extra2236.SafeUUID_classname:
  description: "uuid.SafeUUID class identity attributes"
  kind: python_call_eq
  category: classnames
  id_prefix: uu2236
  columns: [id, function, args, expected]
  rows:
    - ["uu2236020", uuid.SafeUUID.__name__.__eq__, ["SafeUUID"], true]
    - ["uu2236021", uuid.SafeUUID.__module__.__eq__, ["uuid"], true]
    - ["uu2236022", uuid.SafeUUID.__qualname__.__eq__, ["SafeUUID"], true]
    - ["uu2236023", uuid.SafeUUID.__bases__.__len__, [], 1]
    - ["uu2236024", uuid.SafeUUID.__doc__.__class__.__name__.__eq__, ["str"], true]
    - ["uu2236025", uuid.SafeUUID.__dict__.__contains__, ["__doc__"], true]
