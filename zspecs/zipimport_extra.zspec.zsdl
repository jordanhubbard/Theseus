spec: zipimport_extra
version: ">=3.1"
backend: python_module(zipimport)

docs: https://docs.python.org/3/library/zipimport.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipimport.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "zipimport source: Modules/zipimport.c (C extension internals)"
    - "zipimport.zspec.zsdl — covers zipimporter method names, type checks, MRO, and ZipImportError hierarchy"
  notes:
    - "This spec extends zipimport.zspec.zsdl with focused class name and module membership checks."
    - "zipimporter.__name__ == 'zipimporter' — the class is named with a lowercase 'z'."
    - "zipimporter.__module__ == 'zipimport' — it lives in the zipimport module."
    - "ZipImportError.__name__ == 'ZipImportError'."
    - "ZipImportError.__bases__[0].__name__ == 'ImportError' — ZipImportError subclasses ImportError."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "zipimport.ZipImportError is raised when a ZIP archive cannot be found, is invalid, or a requested module is not present in the archive."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — zipimporter and ZipImportError
# ---------------------------------------------------------------------------

invariant zipimport_extra.zipimporter.class_name:
  description: "zipimport.zipimporter.__name__ == 'zipimporter'"
  category: class_names
  kind: python_call_eq
  function: zipimporter.__name__.__eq__
  args: ["zipimporter"]
  expected: true

invariant zipimport_extra.ZipImportError.class_name:
  description: "zipimport.ZipImportError.__name__ == 'ZipImportError'"
  category: class_names
  kind: python_call_eq
  function: ZipImportError.__name__.__eq__
  args: ["ZipImportError"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership checks
# ---------------------------------------------------------------------------

invariant zipimport_extra.zipimporter.module:
  description: "zipimport.zipimporter.__module__ == 'zipimport'"
  category: modules
  kind: python_call_eq
  function: zipimporter.__module__.__eq__
  args: ["zipimport"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — ZipImportError is a subclass of ImportError
# ---------------------------------------------------------------------------

invariant zipimport_extra.ZipImportError.base_is_ImportError:
  description: "zipimport.ZipImportError.__bases__[0].__name__ == 'ImportError'"
  category: exceptions
  kind: python_call_eq
  function: ZipImportError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "ImportError"
