spec: socket_extra258
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "socket.getfqdn is a pure-Python function; __module__ == 'socket' and __class__.__name__ == 'function'."
    - "socket.gethostname is a builtin_function_or_method from _socket; __module__ == '_socket'."
    - "socket.gethostbyaddr, socket.getservbyname, socket.getservbyport are builtin_function_or_method from _socket."
    - "builtin_function_or_method objects from _socket do not expose __qualname__ separately from __name__."
    - "socket.getfqdn.__qualname__ == 'getfqdn' (same as __name__ for module-level functions)."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.getfqdn function identity (pure Python)
# ---------------------------------------------------------------------------

invariant socket_extra258.getfqdn.name:
  description: "socket.getfqdn.__name__ == 'getfqdn'"
  category: identity
  kind: python_call_eq
  function: getfqdn.__name__.__eq__
  args: ["getfqdn"]
  expected: true

invariant socket_extra258.getfqdn.qualname:
  description: "socket.getfqdn.__qualname__ == 'getfqdn'"
  category: identity
  kind: python_call_eq
  function: getfqdn.__qualname__.__eq__
  args: ["getfqdn"]
  expected: true

invariant socket_extra258.getfqdn.module:
  description: "socket.getfqdn.__module__ == 'socket'"
  category: identity
  kind: python_call_eq
  function: getfqdn.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra258.getfqdn.class_name:
  description: "socket.getfqdn.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: getfqdn.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname function identity (builtin from _socket)
# ---------------------------------------------------------------------------

invariant socket_extra258.gethostname.name:
  description: "socket.gethostname.__name__ == 'gethostname'"
  category: identity
  kind: python_call_eq
  function: gethostname.__name__.__eq__
  args: ["gethostname"]
  expected: true

invariant socket_extra258.gethostname.qualname:
  description: "socket.gethostname.__qualname__ == 'gethostname'"
  category: identity
  kind: python_call_eq
  function: gethostname.__qualname__.__eq__
  args: ["gethostname"]
  expected: true

invariant socket_extra258.gethostname.module:
  description: "socket.gethostname.__module__ == '_socket'"
  category: identity
  kind: python_call_eq
  function: gethostname.__module__.__eq__
  args: ["_socket"]
  expected: true

invariant socket_extra258.gethostname.class_name:
  description: "socket.gethostname.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: gethostname.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

