spec: abc_extra235
version: ">=3.10"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc.get_cache_token and abc.update_abstractmethods function identity."
    - "abc.get_cache_token is a builtin function implemented in Modules/_abc.c; its __module__ is '_abc'."
    - "abc.get_cache_token.__name__ == 'get_cache_token' — 15 characters."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' — top-level function."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C extension builtin."
    - "abc.update_abstractmethods was added in Python 3.10. It is a pure Python function in abc module."
    - "abc.update_abstractmethods.__name__ == 'update_abstractmethods' — 22 characters."
    - "abc.update_abstractmethods.__module__ == 'abc' — defined in the abc module itself."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' — top-level function."
    - "abc.update_abstractmethods.__class__.__name__ == 'function' — pure Python function."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.get_cache_token function identity contracts
#
# Verifies __name__, __module__, __qualname__, and __class__.__name__ for
# get_cache_token (a C builtin re-exported from the abc module).
# ---------------------------------------------------------------------------

table abc_extra235.get_cache_token_identity:
  description: "abc.get_cache_token function identity: name, module, qualname, class; new to extra235"
  kind: python_call_eq
  category: get_cache_token
  id_prefix: abc235gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name_eq,
       get_cache_token.__name__.__eq__,
       ["get_cache_token"],
       true,
       "abc.get_cache_token.__name__.__eq__('get_cache_token') == True — builtin carries its simple name; new to extra235"]
    - [gct_module_eq,
       get_cache_token.__module__.__eq__,
       ["_abc"],
       true,
       "abc.get_cache_token.__module__.__eq__('_abc') == True — implemented in the _abc C extension; new to extra235"]
    - [gct_qualname_eq,
       get_cache_token.__qualname__.__eq__,
       ["get_cache_token"],
       true,
       "abc.get_cache_token.__qualname__.__eq__('get_cache_token') == True — top-level function; qualname equals __name__; new to extra235"]
    - [gct_class_name_eq,
       get_cache_token.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C extension builtin; new to extra235"]
    - [gct_name_len_15,
       get_cache_token.__name__.__len__,
       [],
       15,
       "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 characters; new to extra235"]

# ---------------------------------------------------------------------------
# Table 2: abc.update_abstractmethods function identity contracts
#
# Verifies __name__, __module__, __qualname__, __class__.__name__ for
# update_abstractmethods (a pure Python function, Python >= 3.10).
# ---------------------------------------------------------------------------

table abc_extra235.update_abstractmethods_identity:
  description: "abc.update_abstractmethods function identity: name, module, qualname, class; new to extra235"
  kind: python_call_eq
  category: update_abstractmethods
  id_prefix: abc235uam

  columns: [id, function, args, expected, description]
  rows:
    - [uam_name_eq,
       update_abstractmethods.__name__.__eq__,
       ["update_abstractmethods"],
       true,
       "abc.update_abstractmethods.__name__.__eq__('update_abstractmethods') == True — function carries its simple name; new to extra235"]
    - [uam_module_eq,
       update_abstractmethods.__module__.__eq__,
       ["abc"],
       true,
       "abc.update_abstractmethods.__module__.__eq__('abc') == True — pure Python function defined in the abc module; new to extra235"]
    - [uam_qualname_eq,
       update_abstractmethods.__qualname__.__eq__,
       ["update_abstractmethods"],
       true,
       "abc.update_abstractmethods.__qualname__.__eq__('update_abstractmethods') == True — top-level function; qualname equals __name__; new to extra235"]
    - [uam_class_name_eq,
       update_abstractmethods.__class__.__name__.__eq__,
       ["function"],
       true,
       "abc.update_abstractmethods.__class__.__name__ == 'function' — pure Python function; new to extra235"]
    - [uam_name_len_22,
       update_abstractmethods.__name__.__len__,
       [],
       22,
       "abc.update_abstractmethods.__name__.__len__() == 22 — 'update_abstractmethods' has 22 characters; new to extra235"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra235
# ---------------------------------------------------------------------------

invariant abc_extra235.get_cache_token.name:
  description: "abc.get_cache_token.__name__ == 'get_cache_token'; new to extra235"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra235.get_cache_token.module:
  description: "abc.get_cache_token.__module__ == '_abc' — implemented in _abc C extension; new to extra235"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra235.get_cache_token.qualname:
  description: "abc.get_cache_token.__qualname__ == 'get_cache_token'; new to extra235"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra235.get_cache_token.class_name:
  description: "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'; new to extra235"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra235.get_cache_token.name_len:
  description: "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 characters; new to extra235"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__name__.__len__
  args: []
  expected: 15

invariant abc_extra235.get_cache_token.module_len:
  description: "abc.get_cache_token.__module__.__len__() == 4 — '_abc' has 4 characters; new to extra235"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__module__.__len__
  args: []
  expected: 4

invariant abc_extra235.update_abstractmethods.name:
  description: "abc.update_abstractmethods.__name__ == 'update_abstractmethods'; new to extra235"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__name__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra235.update_abstractmethods.module:
  description: "abc.update_abstractmethods.__module__ == 'abc'; new to extra235"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra235.update_abstractmethods.qualname:
  description: "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'; new to extra235"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__qualname__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra235.update_abstractmethods.class_name:
  description: "abc.update_abstractmethods.__class__.__name__ == 'function'; new to extra235"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra235.update_abstractmethods.name_len:
  description: "abc.update_abstractmethods.__name__.__len__() == 22 — 'update_abstractmethods' has 22 characters; new to extra235"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__name__.__len__
  args: []
  expected: 22

invariant abc_extra235.update_abstractmethods.module_len:
  description: "abc.update_abstractmethods.__module__.__len__() == 3 — 'abc' has 3 characters; new to extra235"
  category: update_abstractmethods
  kind: python_call_eq
