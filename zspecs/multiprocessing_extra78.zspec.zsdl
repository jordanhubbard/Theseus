spec: multiprocessing_extra78
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra77.zspec.zsdl."
    - "This spec covers: wave 244 theme — multiprocessing BaseProcess code attributes. NEW in extra78: Process.start.__code__.co_name=='start'; Process.start.__code__.co_argcount==1 (self only; start is defined on BaseProcess); Process.run.__code__.co_name=='run'; Process.run.__code__.co_argcount==1 (self only); Process.terminate.__code__.co_name=='terminate'; Process.terminate.__code__.co_argcount==1 (self only); Process.kill.__code__.co_name=='kill'; Process.kill.__code__.co_argcount==1 (self only); Process.is_alive.__code__.co_name=='is_alive'; Process.is_alive.__code__.co_argcount==1 (self only); Process.join.__code__.co_name=='join'; Process.join.__code__.co_argcount==2 (self + timeout); Process.__repr__.__code__.co_name=='__repr__'; Process.__repr__.__code__.co_argcount==1 (self only). All methods are inherited from BaseProcess but accessible via Process. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__code__.co_name == 'start'. start is defined on BaseProcess in multiprocessing/process.py; accessible via Process. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__code__.co_argcount == 1. Only self is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.run.__code__.co_name == 'run'. run is defined on BaseProcess in multiprocessing/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.run.__code__.co_argcount == 1. Only self is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.terminate.__code__.co_name == 'terminate'. terminate is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.terminate.__code__.co_argcount == 1. Only self is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.kill.__code__.co_name == 'kill'. kill is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.kill.__code__.co_argcount == 1. Only self is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.is_alive.__code__.co_name == 'is_alive'. is_alive is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.is_alive.__code__.co_argcount == 1. Only self is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.join.__code__.co_name == 'join'. join is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.join.__code__.co_argcount == 2. self and timeout are positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__repr__.__code__.co_name == '__repr__'. __repr__ is defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__repr__.__code__.co_argcount == 1. Only self is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process.start and run code attributes — extra78
#
# Wave 244 theme: BaseProcess code attributes (accessed via Process).
#
# Process.start.__code__.co_name == 'start'
# Process.start.__code__.co_argcount == 1
# Process.run.__code__.co_name == 'run'
# Process.run.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table multiprocessing_extra78.Process_start_and_run_code_attrs:
  description: "multiprocessing Process.start and run code attribute checks in mpextra78 namespace — wave 244 theme: BaseProcess code attributes accessed via Process; Process.start.__code__.co_name=='start'; Process.start.__code__.co_argcount==1 (self only; start defined on BaseProcess); Process.run.__code__.co_name=='run'; Process.run.__code__.co_argcount==1 (self only); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpextra78

  columns: [id, function, args, expected, description]
  rows:
    - [start_co_name,     Process.start.__code__.co_name.__eq__,    ["start"], true, "Process.start.__code__.co_name == 'start' — start is defined on BaseProcess; accessed via Process; verified with Python 3.14.3"]
    - [start_co_argcount, Process.start.__code__.co_argcount.__eq__, [1],       true, "Process.start.__code__.co_argcount == 1 — only self is a positional parameter; verified with Python 3.14.3"]
    - [run_co_name,       Process.run.__code__.co_name.__eq__,      ["run"],   true, "Process.run.__code__.co_name == 'run' — run is defined on BaseProcess; verified with Python 3.14.3"]
    - [run_co_argcount,   Process.run.__code__.co_argcount.__eq__,  [1],       true, "Process.run.__code__.co_argcount == 1 — only self is a positional parameter; verified with Python 3.14.3"]

