invariant multiprocessing_extra78.Process_start_co_name:
  description: "multiprocessing.Process.start.__code__.co_name.__eq__('start') returns True — start is defined on BaseProcess in multiprocessing/process.py and accessible via Process; code object co_name matches the method name; NEW in extra78: first standalone co_name invariant for Process.start in mpextra78 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.start.__code__.co_name.__eq__
  args: ["start"]
  expected: true

invariant multiprocessing_extra78.Process_start_co_argcount:
  description: "multiprocessing.Process.start.__code__.co_argcount.__eq__(1) returns True — only self is a positional parameter; start defined on BaseProcess; NEW in extra78: first standalone co_argcount invariant for Process.start in mpextra78 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.start.__code__.co_argcount.__eq__
