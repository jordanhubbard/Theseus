spec: asyncio_extra65
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_varnames, co_filename, and co_flags documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra64.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ and Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ (extra56), class __weakref__.__class__.__name__ (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), class __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), class __subclasshook__.__class__.__name__ (extra57), asyncio.__all__.__contains__ membership checks (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra59), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra60), Queue/Lock __init__ and put/get/empty/full/qsize/acquire/release __qualname__.__eq__ (extra61), gather/sleep/wait __annotations__.__class__.__name__.__eq__('dict'), gather __globals__.__class__.__name__.__eq__('dict'), gather __globals__.__contains__('gather'), Queue.__doc__.__contains__('Queue') (extra62), gather/__code__/__defaults__/__class__.__name__ checks, sleep/__code__/__defaults__/__class__.__name__ checks, Queue.__init__/__defaults__/__class__.__name__ checks (extra63), gather/sleep/Queue.__init__/Lock.__init__ __code__.co_name equality and co_argcount values (extra64)."
    - "This spec covers (asynciocode3_65 namespace): wave 231 theme — __code__.co_varnames, co_filename, co_flags attribute chains. NEW in extra65: gather.__code__.co_varnames.__class__.__name__=='tuple' — co_varnames is always a tuple; sleep.__code__.co_varnames.__class__.__name__=='tuple'; Queue.__init__.__code__.co_varnames.__class__.__name__=='tuple'; sleep.__code__.co_varnames[0]=='delay' — sleep(delay, result=None) so first co_varnames entry is 'delay'; Queue.__init__.__code__.co_varnames[0]=='self' — Queue.__init__(self, maxsize=0) so first is 'self'; Lock.__init__.__code__.co_varnames[0]=='self' — Lock.__init__(self) so first is 'self'; gather.__code__.co_filename.__contains__('.py')==True — co_filename is the path to the .py source file; sleep/Queue.__init__ co_filename.__contains__('.py')==True; gather/sleep/Queue.__init__ co_flags.__class__.__name__=='int' — co_flags is always an int."
    - "asyncio.gather.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is a tuple of strings naming the local variables (including arguments) in definition order. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.co_varnames[0] == 'delay'. sleep is defined as 'async def sleep(delay, result=None)' — delay is the first positional-or-keyword parameter so co_varnames[0]=='delay'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__code__.co_varnames[0] == 'self'. Queue.__init__(self, maxsize=0) — self is the first parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__code__.co_varnames[0] == 'self'. Lock.__init__(self) — self is the first (only) parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.co_filename.__contains__('.py') == True. co_filename stores the absolute path to the source file that defines the function; all asyncio functions are defined in pure-Python .py files. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.co_flags.__class__.__name__ == 'int'. co_flags is a bitmask of flags describing the code object's properties (CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, etc.) stored as a plain Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio __code__.co_varnames.__class__.__name__ checks — extra65
#
# Wave 231 theme: co_varnames type identity.
#
# co_varnames is always a tuple of strings on every code object.
# tuple.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table asyncio_extra65.co_varnames_class_name:
  description: "asyncio __code__.co_varnames.__class__.__name__.__eq__('tuple') checks in asynciocode3_65 namespace — wave 231 theme: co_varnames type identity; co_varnames is always a tuple on all code objects; gather/sleep/Queue.__init__ all have co_varnames.__class__.__name__=='tuple'; NEW in extra65: no prior asyncio spec has checked __code__.co_varnames.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode3_65

  columns: [id, function, args, expected, description]
  rows:
    - [gather_co_varnames_class,     gather.__code__.co_varnames.__class__.__name__.__eq__,         ["tuple"], true, "gather.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of strings naming all local variables in the code object; gather.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra65: first co_varnames.__class__.__name__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_co_varnames_class,      sleep.__code__.co_varnames.__class__.__name__.__eq__,          ["tuple"], true, "sleep.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; sleep.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra65: first co_varnames.__class__.__name__ check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_co_varnames_class, Queue.__init__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true, "Queue.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; Queue.__init__.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra65: first co_varnames.__class__.__name__ check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio __code__.co_varnames[0] first-argument checks — extra65
#
# Wave 231 theme: first entry in co_varnames.
#
# co_varnames lists arguments first, in definition order:
#   sleep(delay, result=None) → co_varnames[0] == 'delay'
#   Queue.__init__(self, maxsize=0) → co_varnames[0] == 'self'
#   Lock.__init__(self) → co_varnames[0] == 'self'
#
# Table row function values containing '[' MUST be double-quoted in YAML.
# ---------------------------------------------------------------------------

table asyncio_extra65.co_varnames_first_arg:
  description: "asyncio __code__.co_varnames[0].__eq__ checks in asynciocode3_65 namespace — wave 231 theme: first co_varnames entry; sleep co_varnames[0]=='delay', Queue.__init__ co_varnames[0]=='self', Lock.__init__ co_varnames[0]=='self'; arguments appear in co_varnames in definition order, so co_varnames[0] is always the first parameter; NEW in extra65: no prior asyncio spec has checked co_varnames[0].__eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode3_65a

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_co_varnames_first,      "sleep.__code__.co_varnames[0].__eq__",         ["delay"],   true, "sleep.__code__.co_varnames[0] == 'delay' — sleep is defined as 'async def sleep(delay, result=None)'; delay is the first positional-or-keyword parameter; co_varnames lists arguments first in definition order; co_varnames[0] is 'delay'; __eq__('delay') returns True; NEW in extra65: first co_varnames[0] check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_co_varnames_first, "Queue.__init__.__code__.co_varnames[0].__eq__", ["self"],   true, "Queue.__init__.__code__.co_varnames[0] == 'self' — Queue.__init__(self, maxsize=0); self is the first parameter; co_varnames[0] is 'self'; __eq__('self') returns True; NEW in extra65: first co_varnames[0] check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]
    - [lock_init_co_varnames_first,  "Lock.__init__.__code__.co_varnames[0].__eq__",  ["self"],   true, "Lock.__init__.__code__.co_varnames[0] == 'self' — Lock.__init__(self); self is the only parameter; co_varnames[0] is 'self'; __eq__('self') returns True; NEW in extra65: first co_varnames[0] check for Lock.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio __code__.co_filename.__contains__('.py') checks — extra65
#
# Wave 231 theme: co_filename membership check.
#
# co_filename stores the absolute path to the .py source file. All asyncio
# functions are implemented in pure Python, so co_filename always ends with
# (or contains) '.py'.
# ---------------------------------------------------------------------------

table asyncio_extra65.co_filename_contains_py:
  description: "asyncio __code__.co_filename.__contains__('.py') checks in asynciocode3_65 namespace — wave 231 theme: co_filename membership; gather/sleep/Queue.__init__ all have co_filename containing '.py'; co_filename is the absolute path to the pure-Python source file implementing each function; NEW in extra65: no prior asyncio spec has checked __code__.co_filename.__contains__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode3_65b

  columns: [id, function, args, expected, description]
  rows:
    - [gather_co_filename_py,     gather.__code__.co_filename.__contains__,         [".py"], true, "gather.__code__.co_filename.__contains__('.py') == True — co_filename stores the absolute path to the source .py file; asyncio.gather is implemented in Lib/asyncio/tasks.py; the filename contains '.py'; __contains__('.py') returns True; NEW in extra65: first co_filename membership check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_co_filename_py,      sleep.__code__.co_filename.__contains__,          [".py"], true, "sleep.__code__.co_filename.__contains__('.py') == True — asyncio.sleep is implemented in a pure-Python .py file (Lib/asyncio/tasks.py); the filename contains '.py'; NEW in extra65: first co_filename membership check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_co_filename_py, Queue.__init__.__code__.co_filename.__contains__, [".py"], true, "Queue.__init__.__code__.co_filename.__contains__('.py') == True — asyncio.Queue is implemented in Lib/asyncio/queues.py; the filename contains '.py'; NEW in extra65: first co_filename membership check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio __code__.co_flags.__class__.__name__ checks — extra65
#
# Wave 231 theme: co_flags type identity.
#
# co_flags is a bitmask integer encoding properties of the code object
# (CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS, CO_COROUTINE, etc.).
# It is always a plain Python int. int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table asyncio_extra65.co_flags_class_name:
  description: "asyncio __code__.co_flags.__class__.__name__.__eq__('int') checks in asynciocode3_65 namespace — wave 231 theme: co_flags type identity; co_flags is a bitmask int encoding code-object properties; gather/sleep/Queue.__init__ all have co_flags.__class__.__name__=='int'; NEW in extra65: no prior asyncio spec has checked __code__.co_flags.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode3_65c

  columns: [id, function, args, expected, description]
  rows:
    - [gather_co_flags_class,     gather.__code__.co_flags.__class__.__name__.__eq__,         ["int"], true, "gather.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a bitmask integer encoding properties of the code object; gather.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra65: first co_flags.__class__.__name__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_co_flags_class,      sleep.__code__.co_flags.__class__.__name__.__eq__,          ["int"], true, "sleep.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int; sleep.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra65: first co_flags.__class__.__name__ check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_co_flags_class, Queue.__init__.__code__.co_flags.__class__.__name__.__eq__, ["int"], true, "Queue.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int; Queue.__init__.__code__.co_flags is an int; int.__class__.__name__ is 'int'; NEW in extra65: first co_flags.__class__.__name__ check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant asyncio_extra65.gather_co_varnames_tuple:
  description: "asyncio.gather.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is a tuple of strings naming all local variables in the code object; gather.__code__.co_varnames is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra65: no prior asyncio spec has checked gather.__code__.co_varnames.__class__.__name__ via __eq__; wave 231 first co_varnames type identity invariant for gather; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra65.sleep_co_varnames_first_delay:
  description: "asyncio.sleep.__code__.co_varnames[0].__eq__('delay') returns True — sleep is defined as 'async def sleep(delay, result=None)'; delay is the first positional-or-keyword parameter; co_varnames lists arguments first in definition order so co_varnames[0]=='delay'; NEW in extra65: no prior asyncio spec has checked sleep.__code__.co_varnames[0] via __eq__; wave 231 first co_varnames first-entry invariant for sleep; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: "sleep.__code__.co_varnames[0].__eq__"
  args: ["delay"]
  expected: true

invariant asyncio_extra65.queue_init_co_varnames_self:
  description: "asyncio.Queue.__init__.__code__.co_varnames[0].__eq__('self') returns True — Queue.__init__(self, maxsize=0); self is the first parameter; co_varnames[0]=='self'; __eq__('self') returns True; NEW in extra65: no prior asyncio spec has checked Queue.__init__.__code__.co_varnames[0] via __eq__; wave 231 first co_varnames first-entry invariant for Queue.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: "Queue.__init__.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant asyncio_extra65.gather_co_filename_contains_py:
  description: "asyncio.gather.__code__.co_filename.__contains__('.py') returns True — co_filename stores the absolute path to the source .py file; asyncio.gather is implemented in Lib/asyncio/tasks.py; the filename contains '.py'; __contains__('.py') returns True; NEW in extra65: no prior asyncio spec has checked gather.__code__.co_filename.__contains__ via invariant; wave 231 first co_filename membership invariant for gather; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

invariant asyncio_extra65.gather_co_flags_int:
  description: "asyncio.gather.__code__.co_flags.__class__.__name__.__eq__('int') returns True — co_flags is a bitmask integer encoding code-object properties (CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_COROUTINE, etc.); gather.__code__.co_flags is a plain Python int; int.__class__.__name__ is 'int'; NEW in extra65: no prior asyncio spec has checked gather.__code__.co_flags.__class__.__name__ via __eq__; wave 231 first co_flags type identity invariant for gather; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true
