spec: asyncio_extra46
version: ">=3.11"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra45.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths, Semaphore acquire/release __qualname__ string values and lengths, BoundedSemaphore/__name__/__module__/inherited acquire qualname, Condition/__name__/__module__/wait qualname, TaskGroup/__name__/__module__/__bases__[0].__name__, Runner/__name__/__module__, shield/ensure_future/create_task __name__/__module__, get_event_loop/__name__/__module__, get_running_loop/__name__/__module__, new_event_loop/__name__/__module__, run/__name__/__module__, iscoroutine/__name__/__module__, iscoroutinefunction/__name__/__module__, get_event_loop/__qualname__=='get_event_loop', get_running_loop/__qualname__=='get_running_loop', run/__qualname__=='run', sleep/__qualname__=='sleep', gather/__qualname__=='gather', wait/__qualname__=='wait', Queue/Lock/Event __qualname__ string equality, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/TaskGroup __qualname__.__len__(), CancelledError/__qualname__=='CancelledError', TimeoutError/__qualname__=='TimeoutError', TaskGroup/Runner/Task/Future __mro__.__len__(), Semaphore/BoundedSemaphore/Condition/TaskGroup/Runner __qualname__ string equality, Task/__qualname__.__len__()==4, Future/__qualname__.__len__()==6, Runner/__qualname__.__len__()==6 (extra45)."
    - "This spec covers: Task/__name__=='Task'; Task/__module__=='_asyncio'; Task/__qualname__=='Task'; Future/__name__=='Future'; Future/__module__=='_asyncio'; Future/__qualname__=='Future'; Task/__bases__[0].__name__=='Future'; Task/__module__.__len__()==8; Future/__module__.__len__()==8; Task/__name__.__len__()==4; Future/__name__.__len__()==6."
    - "asyncio.Task.__name__ == 'Task'. Task is a C-extension class in the _asyncio module exposed through the asyncio namespace. __name__ == 'Task'. len('Task') == 4. Verified with Python 3.14.3."
    - "asyncio.Task.__module__ == '_asyncio'. Task is implemented in C as part of _asyncio (the C accelerator module); its __module__ is '_asyncio', not 'asyncio'. len('_asyncio') == 8. Verified with Python 3.14.3."
    - "asyncio.Task.__qualname__ == 'Task'. Task is a top-level class in _asyncio; its __qualname__ equals its __name__. Both are 'Task'. Verified with Python 3.14.3."
    - "asyncio.Future.__name__ == 'Future'. Future is the C-extension base class in _asyncio exposed through asyncio. __name__ == 'Future'. len('Future') == 6. Verified with Python 3.14.3."
    - "asyncio.Future.__module__ == '_asyncio'. Future is implemented in C in _asyncio (the C accelerator module); its __module__ is '_asyncio', not 'asyncio'. len('_asyncio') == 8. Same __module__ as Task. Verified with Python 3.14.3."
    - "asyncio.Future.__qualname__ == 'Future'. Future is a top-level class in _asyncio; __qualname__ equals __name__ == 'Future'. len('Future') == 6. Verified with Python 3.14.3."
    - "asyncio.Task.__bases__[0].__name__ == 'Future'. Task inherits directly from Future; Task.__bases__ == (<class '_asyncio.Future'>,). The single base class name is 'Future'. len('Future') == 6. Verified with Python 3.14.3."
    - "asyncio.Task.__module__.__len__() == 8. Task.__module__ == '_asyncio'; len('_asyncio') == 8. Future shares the same module string and length. Verified with Python 3.14.3."
    - "asyncio.Future.__module__.__len__() == 8. Future.__module__ == '_asyncio'; len('_asyncio') == 8. Task and Future are both C-extension classes in _asyncio with identical __module__ values. Verified with Python 3.14.3."
    - "asyncio.Task.__name__.__len__() == 4. Task.__name__ == 'Task'; len('Task') == 4. This is the same as Task.__qualname__.__len__()==4 captured in extra45. Verified with Python 3.14.3."
    - "asyncio.Future.__name__.__len__() == 6. Future.__name__ == 'Future'; len('Future') == 6. This matches Future.__qualname__.__len__()==6 captured in extra45. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Task and Future class name/module/qualname string equality — extra46
#
# Task and Future are C-extension classes in _asyncio (exposed via asyncio):
#   Task.__name__     == 'Task'
#   Task.__module__   == '_asyncio'
#   Task.__qualname__ == 'Task'
#   Future.__name__     == 'Future'
#   Future.__module__   == '_asyncio'
#   Future.__qualname__ == 'Future'
# Prior specs captured __qualname__ string equality (extra45) and __qualname__
# lengths (extra45), MRO depths (extra45), and __module__ lengths (earlier).
# Extra46 captures the string equality for __name__ and __module__ directly.
# ---------------------------------------------------------------------------

table asyncio_extra46.task_future_name_module_qualname_eq:
  description: "asyncio Task and Future class __name__/__module__/__qualname__ string equality in extra46 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: asynctfnmqeq46

  columns: [id, function, args, expected, description]
  rows:
    - [Task_name,     Task.__name__.__eq__,     ["Task"],     true, "Task.__name__ == 'Task' — C-extension class in _asyncio (4 chars)"]
    - [Task_module,   Task.__module__.__eq__,   ["_asyncio"], true, "Task.__module__ == '_asyncio' — C accelerator module (8 chars)"]
    - [Task_qualname, Task.__qualname__.__eq__, ["Task"],     true, "Task.__qualname__ == 'Task' — top-level class; qualname equals name"]
    - [Future_name,     Future.__name__.__eq__,     ["Future"],   true, "Future.__name__ == 'Future' — C-extension base class in _asyncio (6 chars)"]
    - [Future_module,   Future.__module__.__eq__,   ["_asyncio"], true, "Future.__module__ == '_asyncio' — same C accelerator module as Task (8 chars)"]
    - [Future_qualname, Future.__qualname__.__eq__, ["Future"],   true, "Future.__qualname__ == 'Future' — top-level class; qualname equals name"]

# ---------------------------------------------------------------------------
# asyncio Task.__bases__[0].__name__ string equality — extra46
#
# Task inherits directly from Future:
#   Task.__bases__ == (<class '_asyncio.Future'>,)
#   Task.__bases__[0].__name__ == 'Future'
# This confirms the Task -> Future inheritance chain at the API level.
# Task.__mro__ == (Task, Future, object) with depth 3 (captured in extra45).
# extra46 captures the bases[0] name string equality directly.
# ---------------------------------------------------------------------------

table asyncio_extra46.task_bases_name:
  description: "asyncio Task.__bases__[0].__name__ string equality in extra46 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: asynctaskbasename46

  columns: [id, function, args, expected, description]
  rows:
    - [Task_bases0_name_eq,  "Task.__bases__[0].__name__.__eq__",  ["Future"], true, "Task.__bases__[0].__name__ == 'Future' — Task inherits from Future as its sole base class"]
    - [Task_bases0_name_len, "Task.__bases__[0].__name__.__len__", [],         6,    "Task.__bases__[0].__name__.__len__() == 6 — 'Future' has 6 characters"]

# ---------------------------------------------------------------------------
# asyncio Task and Future class __module__.__len__() — extra46
#
# Both Task and Future have __module__ == '_asyncio' (8 chars):
#   Task.__module__.__len__()   == 8
#   Future.__module__.__len__() == 8
# This shared module string demonstrates they are both C-extension classes
# from the _asyncio accelerator module. Prior extra specs captured __module__
# lengths for sync classes (Queue/Lock/Event/Semaphore etc) and __module__ length
# for Task/Future in earlier specs. Extra46 presents them as a paired table
# capturing the identical module lengths.
# ---------------------------------------------------------------------------

table asyncio_extra46.task_future_module_name_lengths:
  description: "asyncio Task and Future class __module__.__len__() and __name__.__len__() in extra46 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: asynctfmodnamelen46

  columns: [id, function, args, expected, description]
  rows:
    - [Task_module_len,   Task.__module__.__len__,   [], 8, "Task.__module__.__len__() == 8 — '_asyncio' has 8 characters"]
    - [Future_module_len, Future.__module__.__len__, [], 8, "Future.__module__.__len__() == 8 — '_asyncio' has 8 characters; same as Task"]
    - [Task_name_len,     Task.__name__.__len__,     [], 4, "Task.__name__.__len__() == 4 — 'Task' has 4 characters"]
    - [Future_name_len,   Future.__name__.__len__,   [], 6, "Future.__name__.__len__() == 6 — 'Future' has 6 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra46
# ---------------------------------------------------------------------------

invariant asyncio_extra46.Task_name_eq:
  description: "asyncio.Task.__name__ == 'Task' — C-extension class in _asyncio; name is 'Task' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra46.Task_module_eq:
  description: "asyncio.Task.__module__ == '_asyncio' — Task is implemented in the C accelerator _asyncio module"
  category: class_names
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra46.Task_qualname_eq:
  description: "asyncio.Task.__qualname__ == 'Task' — top-level C-extension class; qualname equals name"
  category: class_names
  kind: python_call_eq
  function: Task.__qualname__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra46.Future_name_eq:
  description: "asyncio.Future.__name__ == 'Future' — C-extension base class in _asyncio; name is 'Future' (6 chars)"
  category: class_names
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant asyncio_extra46.Future_module_eq:
  description: "asyncio.Future.__module__ == '_asyncio' — Future is implemented in the C accelerator _asyncio module; same module as Task"
  category: class_names
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra46.Future_qualname_eq:
  description: "asyncio.Future.__qualname__ == 'Future' — top-level C-extension class; qualname equals name"
  category: class_names
  kind: python_call_eq
  function: Future.__qualname__.__eq__
  args: ["Future"]
  expected: true

invariant asyncio_extra46.Task_bases0_name_eq:
  description: "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits from Future as its sole direct base class"
  category: class_names
  kind: python_call_eq
  function: "Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra46.Task_bases0_name_len:
  description: "asyncio.Task.__bases__[0].__name__.__len__() == 6 — 'Future' has 6 characters"
  category: class_names
  kind: python_call_eq
  function: "Task.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant asyncio_extra46.Task_module_len:
  description: "asyncio.Task.__module__.__len__() == 8 — '_asyncio' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: Task.__module__.__len__
  args: []
  expected: 8

invariant asyncio_extra46.Future_module_len:
  description: "asyncio.Future.__module__.__len__() == 8 — '_asyncio' has 8 characters; same length as Task.__module__"
  category: class_names
  kind: python_call_eq
  function: Future.__module__.__len__
  args: []
  expected: 8

invariant asyncio_extra46.Task_name_len:
  description: "asyncio.Task.__name__.__len__() == 4 — 'Task' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: Task.__name__.__len__
  args: []
  expected: 4

invariant asyncio_extra46.Future_name_len:
  description: "asyncio.Future.__name__.__len__() == 6 — 'Future' has 6 characters"
  category: class_names
  kind: python_call_eq
  function: Future.__name__.__len__
  args: []
  expected: 6
