spec: abc_extra1036
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta, ABC, and abstractmethod documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta descriptor types, abc.ABC inherited method qualnames, and module doc identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1036.abcmeta_descriptors:
  description: "abc.ABCMeta descriptor and cache attribute class identity"
  kind: python_call_eq
  category: abcmeta_descriptors
  id_prefix: ab1036ad
  columns: [id, function, args, expected]
  rows:
    - [ab1036ad001, abc.ABCMeta.__abstractmethods__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [ab1036ad002, abc.ABCMeta._abc_caches_version.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [ab1036ad003, abc.ABCMeta.__weakref__.__class__.__name__.__eq__,             ["getset_descriptor"], true]
    - [ab1036ad004, abc.ABCMeta.__class__.__name__.__eq__,                         ["type"],              true]
    - [ab1036ad005, abc.ABCMeta.__module__.__eq__,                                 ["abc"],               true]
    - [ab1036ad006, abc.ABCMeta.__doc__.__class__.__name__.__eq__,                 ["str"],               true]

table abc_extra1036.abc_class_method_qualnames:
  description: "abc.ABC inherited and class method __qualname__ identity"
  kind: python_call_eq
  category: abc_class_method_qualnames
  id_prefix: ab1036cm
  columns: [id, function, args, expected]
  rows:
    - [ab1036cm001, abc.ABC.__init_subclass__.__func__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [ab1036cm002, abc.ABC.__class__.__name__.__eq__,                      ["ABCMeta"],                  true]
    - [ab1036cm003, abc.ABC.__module__.__eq__,                              ["abc"],                      true]
    - [ab1036cm004, abc.ABC.__doc__.__class__.__name__.__eq__,              ["str"],                      true]
    - [ab1036cm005, abc.ABCMeta.register.__qualname__.__eq__,               ["ABCMeta.register"],         true]
    - [ab1036cm006, abc.ABCMeta.__instancecheck__.__qualname__.__eq__,      ["ABCMeta.__instancecheck__"], true]
    - [ab1036cm007, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,      ["ABCMeta.__subclasscheck__"], true]

table abc_extra1036.abstractmethod_and_module_identity:
  description: "abc.abstractmethod attribute identity and module doc class"
  kind: python_call_eq
  category: abstractmethod_and_module_identity
  id_prefix: ab1036mi
  columns: [id, function, args, expected]
  rows:
    - [ab1036mi001, abc.abstractmethod.__isabstractmethod__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ab1036mi002, abc.abstractmethod.__qualname__.__eq__,                            ["abstractmethod"],    true]
    - [ab1036mi003, abc.abstractmethod.__module__.__eq__,                              ["abc"],               true]
    - [ab1036mi004, abc.__doc__.__class__.__name__.__eq__,                             ["str"],               true]
    - [ab1036mi005, abc.__name__.__eq__,                                               ["abc"],               true]
