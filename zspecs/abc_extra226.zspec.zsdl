# ---------------------------------------------------------------------------
# abc.ABCMeta identity and method name contracts — extra226 namespace
#
# ABCMeta.__name__ == 'ABCMeta' (7 chars); module is 'abc'.
# ABCMeta.register, __subclasscheck__, __instancecheck__, __prepare__ are key methods.
# ---------------------------------------------------------------------------

table abc_extra226.abcmeta_identity:
  description: "abc.ABCMeta __name__, __module__ and method __name__ contracts in abc226meta namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc226meta

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,           ABCMeta.__name__.__eq__,                     ["ABCMeta"],                    true, "abc.ABCMeta.__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [abcmeta_name_len_7,        ABCMeta.__name__.__len__,                    [],                             7,    "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; verified with Python 3.14.3"]
    - [abcmeta_module_eq,         ABCMeta.__module__.__eq__,                   ["abc"],                        true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abcmeta_register_name_eq,  ABCMeta.register.__name__.__eq__,            ["register"],                   true, "abc.ABCMeta.register.__name__ == 'register'; verified with Python 3.14.3"]
    - [abcmeta_register_qn_eq,    ABCMeta.register.__qualname__.__eq__,        ["ABCMeta.register"],           true, "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'; verified with Python 3.14.3"]
    - [abcmeta_register_mod_eq,   ABCMeta.register.__module__.__eq__,          ["abc"],                        true, "abc.ABCMeta.register.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abcmeta_subclschk_name_eq, ABCMeta.__subclasscheck__.__name__.__eq__,   ["__subclasscheck__"],          true, "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'; verified with Python 3.14.3"]
    - [abcmeta_instchk_name_eq,   ABCMeta.__instancecheck__.__name__.__eq__,   ["__instancecheck__"],          true, "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'; verified with Python 3.14.3"]
    - [abcmeta_prepare_name_eq,   ABCMeta.__prepare__.__name__.__eq__,         ["__prepare__"],                true, "abc.ABCMeta.__prepare__.__name__ == '__prepare__'; verified with Python 3.14.3"]
    - [abcmeta_prepare_qn_eq,     ABCMeta.__prepare__.__qualname__.__eq__,     ["ABCMeta.__prepare__"],        true, "abc.ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__'; verified with Python 3.14.3"]

