spec: urllib_parse_extra5
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl, urllib_parse_extra.zspec.zsdl, urllib_parse_extra2.zspec.zsdl, urllib_parse_extra3.zspec.zsdl, urllib_parse_extra4.zspec.zsdl."
    - "Focus: __qualname__ attributes for functions not yet covered (quote_plus, unquote_plus, parse_qs, parse_qsl), urlparse.__module__, and urlencode behavioral vector with new input."
    - "urllib_parse_extra4.zspec.zsdl already covers ParseResult/SplitResult/DefragResult/urldefrag qualnames and quote/unquote/urlencode/urlparse/urlsplit/urljoin qualnames in its table."
    - "urllib_parse_extra3.zspec.zsdl covers urlencode({'a': 1}) == 'a=1' and quote/unquote basics."
    - "urllib_parse.zspec.zsdl (base) covers quote_plus/unquote_plus values via kwargs table rows."
    - "This spec adds: quote_plus/unquote_plus/parse_qs/parse_qsl qualnames (not in extra4 table), urlparse.__module__, and urlencode({'key': 'val'}) == 'key=val'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — functions not covered in urllib_parse_extra4 table
# (extra4 table covered: urlparse, urlsplit, urljoin, urlencode, quote, unquote)
# ---------------------------------------------------------------------------

table urllib_parse_extra5.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [quote_plus,   quote_plus.__qualname__.__eq__,   ["quote_plus"],   true]
    - [unquote_plus, unquote_plus.__qualname__.__eq__, ["unquote_plus"], true]
    - [parse_qs,     parse_qs.__qualname__.__eq__,     ["parse_qs"],     true]
    - [parse_qsl,    parse_qsl.__qualname__.__eq__,    ["parse_qsl"],    true]

# ---------------------------------------------------------------------------
# Module identity — urlparse.__module__ == 'urllib.parse'
# (Extra4 covers module equality for the named-tuple types via other means;
#  this is the first explicit __module__ check for urlparse as a function.)
# ---------------------------------------------------------------------------

invariant urllib_parse_extra5.urlparse.module:
  description: "urllib.parse.urlparse.__module__ == 'urllib.parse'"
  category: modules
  kind: python_call_eq
  function: urlparse.__module__.__eq__
  args: ["urllib.parse"]
  expected: true

# ---------------------------------------------------------------------------
# urlencode behavioral — {'key': 'val'} → 'key=val'
# (Extra3 covers {'a': 1} → 'a=1'; this is a distinct string-value vector.)
# ---------------------------------------------------------------------------

invariant urllib_parse_extra5.urlencode.key_val:
  description: "urllib.parse.urlencode({'key': 'val'}) == 'key=val'"
  category: urlencode
  kind: python_call_eq
  function: urlencode
  args: [{key: "val"}]
  expected: "key=val"
