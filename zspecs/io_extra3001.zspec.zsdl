spec: io3001
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (io3001): __getitem__, __setitem__, __delitem__ dict-presence checks for io types."
    - "IO stream classes implement read/write protocols, not item access/mutation protocols."
    - "None of IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, BufferedRandom, or TextIOWrapper define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "BytesIO and StringIO expose buffer contents via read/getvalue, not via subscript syntax."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# IO stream types do not support subscript access; none define __getitem__; all false.
# ---------------------------------------------------------------------------

table io3001.getitem:
  description: "io types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io3001
  columns: [id, function, args, expected]
  rows:
    - ["io3001001", operator.contains, [io.IOBase.__dict__,          "__getitem__"], false]
    - ["io3001002", operator.contains, [io.RawIOBase.__dict__,       "__getitem__"], false]
    - ["io3001003", operator.contains, [io.BufferedIOBase.__dict__,  "__getitem__"], false]
    - ["io3001004", operator.contains, [io.TextIOBase.__dict__,      "__getitem__"], false]
    - ["io3001005", operator.contains, [io.BytesIO.__dict__,         "__getitem__"], false]
    - ["io3001006", operator.contains, [io.StringIO.__dict__,        "__getitem__"], false]

