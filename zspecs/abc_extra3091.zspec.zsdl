spec: ab3091
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (ab3091): __hash__, __eq__, __bool__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "All 3 abc subjects return false for __hash__, __eq__, and __bool__ in their own __dict__."
    - "abc.ABC is a simple convenience base class; it defines no custom hash, equality, or bool."
    - "abc.ABCMeta is a metaclass for tracking abstract base classes; it defines no custom hash, equality, or bool in its own __dict__ (ABCMeta inherits __eq__ from type, not defined at ABCMeta level)."
    - "type(abc.abstractmethod(lambda: None)) is <class 'function'>; function objects do not define __hash__, __eq__, or __bool__ in their own __dict__ — they inherit identity-based hash and equality from object."
    - "The absence of __hash__ in function.__dict__ is consistent with functions being hashable by identity (object.__hash__), not by any custom hash."
    - "Wave 652 (ab3076) covered __get__/__set__/__delete__ for the same three subjects; this wave covers __hash__/__eq__/__bool__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# All 3 abc subjects return false for __hash__.
# abc.ABC and abc.ABCMeta are abstract base class infrastructure; they do not
# override hashing. type(abc.abstractmethod(lambda: None)) is <class 'function'>;
# function objects hash by identity via object.__hash__ without defining their
# own __hash__ in the function class __dict__.
# ---------------------------------------------------------------------------

table ab3091.hash:
  description: "abc types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3091

  columns: [id, function, args, expected]
  rows:
    - ["ab3091001", operator.contains, [abc.ABC.__dict__,                                 "__hash__"], false]
    - ["ab3091002", operator.contains, [abc.ABCMeta.__dict__,                             "__hash__"], false]
    - ["ab3091003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# All 3 abc subjects return false for __eq__.
# abc.ABC defines no custom equality. abc.ABCMeta inherits __eq__ from type
# (via the metaclass chain) but does not define it in ABCMeta's own __dict__.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>; function
# objects use identity-based equality from object and do not define __eq__
# in the function class __dict__.
# ---------------------------------------------------------------------------

table ab3091.eq:
  description: "abc types __eq__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3091

  columns: [id, function, args, expected]
  rows:
    - ["ab3091004", operator.contains, [abc.ABC.__dict__,                                 "__eq__"], false]
    - ["ab3091005", operator.contains, [abc.ABCMeta.__dict__,                             "__eq__"], false]
    - ["ab3091006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__eq__"], false]

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# All 3 abc subjects return false for __bool__.
# abc.ABC, abc.ABCMeta, and <class 'function'> all evaluate as truthy by
# inheriting the default from object; none define custom boolean coercion.
# ---------------------------------------------------------------------------

table ab3091.bool:
  description: "abc types __bool__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3091

  columns: [id, function, args, expected]
  rows:
    - ["ab3091007", operator.contains, [abc.ABC.__dict__,                                 "__bool__"], false]
    - ["ab3091008", operator.contains, [abc.ABCMeta.__dict__,                             "__bool__"], false]
    - ["ab3091009", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__bool__"], false]

# ---------------------------------------------------------------------------
# combined — __hash__, __eq__, __bool__ across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __hash__: false for all 3 — no custom hashing defined at the class level.
# __eq__:   false for all 3 — no custom equality defined at the class level.
# __bool__: false for all 3 — no custom boolean coercion defined.
# All three subjects rely entirely on object-inherited identity semantics.
# Contrast with wave 652 (ab3076) where type(abstractmethod(lambda: None))
# had __get__ = true (function is a non-data descriptor); here all are false.
# ---------------------------------------------------------------------------

table ab3091.combined:
  description: "abc types combined __hash__/__eq__/__bool__; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3091

  columns: [id, function, args, expected]
  rows:
    - ["ab3091010", operator.contains, [abc.ABC.__dict__,                                 "__hash__"], false]
    - ["ab3091011", operator.contains, [abc.ABC.__dict__,                                 "__eq__"],   false]
    - ["ab3091012", operator.contains, [abc.ABC.__dict__,                                 "__bool__"], false]
    - ["ab3091013", operator.contains, [abc.ABCMeta.__dict__,                             "__hash__"], false]
    - ["ab3091014", operator.contains, [abc.ABCMeta.__dict__,                             "__eq__"],   false]
    - ["ab3091015", operator.contains, [abc.ABCMeta.__dict__,                             "__bool__"], false]
    - ["ab3091016", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__hash__"], false]
    - ["ab3091017", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__eq__"],   false]
    - ["ab3091018", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__bool__"], false]
