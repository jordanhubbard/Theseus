spec: abc_extra28
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra27.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta(3)/ABC(2), ABC/ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasscheck__/__qualname__.__len__()==25, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, ABCMeta.register.__qualname__.__len__()==16, abstractmethod.__name__.__len__()==14, get_cache_token.__name__.__len__()==15, abc.__name__.__len__()==3, ABCMeta mro entry name lengths, ABC.__mro__[0].__name__.__len__()==3, ABC.__mro__[1].__name__.__len__()==6."
    - "This spec covers: ABCMeta.__subclasshook__.__qualname__.__len__()==24, ABCMeta.__subclasshook__.__name__.__len__()==16; abstractclassmethod/__name__.__len__()==19, abstractclassmethod/__qualname__.__len__()==19; abstractstaticmethod/__name__.__len__()==20, abstractstaticmethod/__qualname__.__len__()==20; get_cache_token/__qualname__.__len__()==15, get_cache_token/__module__.__len__()==4 ('_abc'); ABCMeta.register/__module__.__len__()==3 ('abc'); update_abstractmethods/__module__.__len__()==3 ('abc'); issubclass(bool, int)==True, isinstance(True, int)==True."
    - "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars) — qualname includes the class prefix 'ABCMeta.' (8 chars) plus the dunder name '__subclasshook__' (16 chars)."
    - "ABCMeta.__subclasshook__.__name__ == '__subclasshook__' (16 chars) — the raw method name without the class prefix."
    - "abstractclassmethod is deprecated since Python 3.3 but still present in Python 3.12 — __name__ == 'abstractclassmethod' (19 chars)."
    - "abstractstaticmethod is deprecated since Python 3.3 but still present in Python 3.12 — __name__ == 'abstractstaticmethod' (20 chars)."
    - "get_cache_token.__module__ == '_abc' (4 chars) — implemented in C (_abc extension), not Lib/abc.py."
    - "ABCMeta.register.__module__ == 'abc' (3 chars) — pure Python implementation in Lib/abc.py."
    - "update_abstractmethods.__module__ == 'abc' (3 chars) — pure Python function in Lib/abc.py."
    - "issubclass(bool, int) == True and isinstance(True, int) == True — bool is a subclass of int in Python; True is an instance of int."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__subclasshook__ name lengths — extra28 namespace
#
# ABCMeta defines __subclasshook__ as a classmethod. Its identity attributes:
#   ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars)
#   ABCMeta.__subclasshook__.__name__     == '__subclasshook__'         (16 chars)
# The __qualname__ is 8 characters longer than __name__ due to the 'ABCMeta.'
# prefix (8 chars). No prior abc spec has measured __name__.__len__() or
# __qualname__.__len__() for __subclasshook__ in an explicit table row.
# ---------------------------------------------------------------------------

table abc_extra28.subclasshook_name_lengths:
  description: "ABCMeta.__subclasshook__ __name__ and __qualname__ lengths in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: subclasshookname28

  columns: [id, function, args, expected]
  rows:
    - [name_len,     ABCMeta.__subclasshook__.__name__.__len__,     [], 16]
    - [qualname_len, ABCMeta.__subclasshook__.__qualname__.__len__,  [], 24]

# ---------------------------------------------------------------------------
# abstractclassmethod and abstractstaticmethod name lengths — extra28 namespace
#
# Both deprecated decorators remain in the abc module in Python 3.12.
# Their name lengths:
#   abstractclassmethod.__name__.__len__()     == 19 ('abstractclassmethod')
#   abstractclassmethod.__qualname__.__len__() == 19 (top-level class; qualname == name)
#   abstractstaticmethod.__name__.__len__()    == 20 ('abstractstaticmethod')
#   abstractstaticmethod.__qualname__.__len__() == 20 (top-level class; qualname == name)
# abstractstaticmethod is one character longer than abstractclassmethod —
# 'static' (6) vs 'class' (5).
# No prior abc spec has measured these deprecated decorator name lengths.
# ---------------------------------------------------------------------------

table abc_extra28.deprecated_decorator_name_lengths:
  description: "abc abstractclassmethod and abstractstaticmethod __name__ and __qualname__ lengths in extra28 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: deprdecname28

  columns: [id, function, args, expected]
  rows:
    - [abstractclassmethod_name,     abstractclassmethod.__name__.__len__,      [], 19]
    - [abstractclassmethod_qualname, abstractclassmethod.__qualname__.__len__,   [], 19]
    - [abstractstaticmethod_name,    abstractstaticmethod.__name__.__len__,     [], 20]
    - [abstractstaticmethod_qualname, abstractstaticmethod.__qualname__.__len__, [], 20]

# ---------------------------------------------------------------------------
# Module membership: __module__ lengths for get_cache_token vs register — extra28
#
# get_cache_token is a C-extension function — its __module__ is '_abc' (4 chars).
# ABCMeta.register is a pure-Python method — its __module__ is 'abc' (3 chars).
# update_abstractmethods is also pure Python — its __module__ is 'abc' (3 chars).
# This distinction (4 vs 3) reveals which abc public API is in C vs Python.
# No prior abc spec has measured get_cache_token.__module__.__len__() or
# update_abstractmethods.__module__.__len__() as table rows.
# ---------------------------------------------------------------------------

table abc_extra28.module_membership_lengths:
  description: "abc public API __module__.__len__() distinguishing C-extension (_abc=4) from pure-Python (abc=3) implementations in extra28 namespace"
  kind: python_call_eq
  category: module_structure
  id_prefix: modmemblen28

  columns: [id, function, args, expected]
  rows:
    - [get_cache_token,       get_cache_token.__module__.__len__,       [], 4]
    - [register,              ABCMeta.register.__module__.__len__,       [], 3]
    - [update_abstractmethods, update_abstractmethods.__module__.__len__, [], 3]

# ---------------------------------------------------------------------------
# issubclass and isinstance behavioral invariants — extra28 namespace
#
# These are behavioral facts about Python's type system as exposed through
# the abc module's subclass relationship machinery:
#   issubclass(bool, int) == True — bool is a subclass of int
#   isinstance(True, int) == True — True is an instance of int
# These hold because bool inherits from int in Python's type hierarchy.
# The abc module's ABCMeta uses __subclasshook__ to support virtual subclassing,
# but bool/int use ordinary C-level inheritance. These are stable, well-known
# invariants not tied to ABCMeta. No prior abc spec has captured them.
# ---------------------------------------------------------------------------

invariant abc_extra28.issubclass_bool_int:
  description: "issubclass(bool, int) == True — bool is a subclass of int via ordinary C-level inheritance"
  category: behavioral
  kind: python_call_eq
  function: issubclass
  args: [bool, int]
  expected: true

invariant abc_extra28.isinstance_True_int:
  description: "isinstance(True, int) == True — True is an instance of int because bool subclasses int"
  category: behavioral
  kind: python_call_eq
  function: isinstance
  args: [true, int]
  expected: true

invariant abc_extra28.get_cache_token_module_len:
  description: "abc.get_cache_token.__module__.__len__() == 4 — '_abc' (4 chars) reveals C-extension implementation"
  category: module_structure
  kind: python_call_eq
  function: get_cache_token.__module__.__len__
  args: []
  expected: 4

invariant abc_extra28.abstractstaticmethod_name_len:
  description: "abc.abstractstaticmethod.__name__.__len__() == 20 — 'abstractstaticmethod' is the longest deprecated decorator name in abc"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__name__.__len__
  args: []
  expected: 20
