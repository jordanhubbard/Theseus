spec: concurrent_futures_extra1606
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "concurrent.futures.Future is pure Python and does NOT use __slots__; its class dict contains __dict__ and __weakref__ descriptors so instances have a per-instance __dict__"
    - "concurrent.futures.Executor also has __dict__ and __weakref__ getset_descriptors in its own class dict — no __slots__"
    - "ThreadPoolExecutor and ProcessPoolExecutor inherit __dict__ from Executor; no __slots__ in their own class dicts"
    - "All concurrent.futures exception classes are pure Python with no __slots__"
    - "Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

table concurrent_futures_extra1606.executor_slots:
  description: "concurrent.futures executor and Future classes: no __slots__, instances have __dict__ via inherited or own __dict__ descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1606ex

  columns: [id, function, args, expected]
  rows:
    - ["cf1606ex001", "concurrent.futures.Future.__dict__.__contains__", ["__slots__"], false]
    - ["cf1606ex002", "concurrent.futures.Future.__dict__.__contains__", ["__dict__"], true]
    - ["cf1606ex003", "concurrent.futures.Future.__dict__.__contains__", ["__weakref__"], true]
    - ["cf1606ex004", "concurrent.futures.Future.__module__.__eq__", ["concurrent.futures._base"], true]
    - ["cf1606ex005", "type(concurrent.futures.Future.__dict__[\"__dict__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["cf1606ex006", "type(concurrent.futures.Future.__dict__[\"__weakref__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["cf1606ex007", "concurrent.futures.Future.__dict__.__contains__", ["cancel"], true]
    - ["cf1606ex008", "concurrent.futures.Future.__dict__.__contains__", ["result"], true]
    - ["cf1606ex009", "concurrent.futures.Future.__dict__.__contains__", ["done"], true]
    - ["cf1606ex010", "concurrent.futures.Future.__dict__.__contains__", ["cancelled"], true]
    - ["cf1606ex011", "concurrent.futures.Future.__dict__.__contains__", ["running"], true]
    - ["cf1606ex012", "concurrent.futures.Future.__dict__.__contains__", ["set_result"], true]
    - ["cf1606ex013", "concurrent.futures.Future.__dict__.__contains__", ["set_exception"], true]
    - ["cf1606ex014", "concurrent.futures.Executor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1606ex015", "concurrent.futures.Executor.__dict__.__contains__", ["__dict__"], true]
    - ["cf1606ex016", "concurrent.futures.Executor.__dict__.__contains__", ["__weakref__"], true]
    - ["cf1606ex017", "concurrent.futures.Executor.__module__.__eq__", ["concurrent.futures._base"], true]
    - ["cf1606ex018", "type(concurrent.futures.Executor.__dict__[\"__dict__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["cf1606ex019", "type(concurrent.futures.Executor.__dict__[\"__weakref__\"]).__name__.__eq__", ["getset_descriptor"], true]
    - ["cf1606ex020", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1606ex021", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__dict__"], false]
    - ["cf1606ex022", "concurrent.futures.ThreadPoolExecutor.__module__.__eq__", ["concurrent.futures.thread"], true]
    - ["cf1606ex023", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1606ex024", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__dict__"], false]
    - ["cf1606ex025", "concurrent.futures.ProcessPoolExecutor.__module__.__eq__", ["concurrent.futures.process"], true]
    - ["cf1606ex026", "issubclass(concurrent.futures.ThreadPoolExecutor, concurrent.futures.Executor).__bool__", [], true]
    - ["cf1606ex027", "issubclass(concurrent.futures.ProcessPoolExecutor, concurrent.futures.Executor).__bool__", [], true]
    - ["cf1606ex028", "concurrent.futures.Executor.__dict__.__contains__", ["submit"], true]
    - ["cf1606ex029", "concurrent.futures.Executor.__dict__.__contains__", ["map"], true]
    - ["cf1606ex030", "concurrent.futures.Executor.__dict__.__contains__", ["shutdown"], true]

table concurrent_futures_extra1606.exceptions_no_slots:
  description: "concurrent.futures exception classes are pure Python with no __slots__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1606xc

  columns: [id, function, args, expected]
  rows:
    - ["cf1606xc001", "concurrent.futures.CancelledError.__dict__.__contains__", ["__slots__"], false]
    - ["cf1606xc002", "concurrent.futures.CancelledError.__module__.__eq__", ["concurrent.futures._base"], true]
    - ["cf1606xc003", "concurrent.futures.CancelledError.__name__.__eq__", ["CancelledError"], true]
    - ["cf1606xc004", "concurrent.futures.TimeoutError.__dict__.__contains__", ["__slots__"], false]
    - ["cf1606xc005", "concurrent.futures.TimeoutError.__module__.__eq__", ["builtins"], true]
    - ["cf1606xc006", "concurrent.futures.TimeoutError.__name__.__eq__", ["TimeoutError"], true]
    - ["cf1606xc007", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1606xc008", "concurrent.futures.BrokenExecutor.__module__.__eq__", ["concurrent.futures._base"], true]
    - ["cf1606xc009", "concurrent.futures.BrokenExecutor.__name__.__eq__", ["BrokenExecutor"], true]
    - ["cf1606xc010", "issubclass(concurrent.futures.CancelledError, Exception).__bool__", [], true]
    - ["cf1606xc011", "issubclass(concurrent.futures.TimeoutError, OSError).__bool__", [], true]
    - ["cf1606xc012", "issubclass(concurrent.futures.BrokenExecutor, RuntimeError).__bool__", [], true]
    - ["cf1606xc013", "concurrent.futures.CancelledError.__bases__.__len__", [], 1]
    - ["cf1606xc014", "concurrent.futures.BrokenExecutor.__bases__.__len__", [], 1]
    - ["cf1606xc015", "concurrent.futures.CancelledError.__dict__.__contains__", ["__dict__"], false]
    - ["cf1606xc016", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__dict__"], false]
    - ["cf1606xc017", "concurrent.futures.CancelledError.__dict__.__contains__", ["__weakref__"], false]
    - ["cf1606xc018", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__weakref__"], false]
    - ["cf1606xc019", "concurrent.futures.CancelledError.__dict__.__contains__", ["__firstlineno__"], true]
    - ["cf1606xc020", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__firstlineno__"], true]
    - ["cf1606xc021", "concurrent.futures.CancelledError.__dict__.__contains__", ["__static_attributes__"], true]
    - ["cf1606xc022", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__static_attributes__"], true]
