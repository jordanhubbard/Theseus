spec: functools_extra272
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' — __init__ and __call__ are both wrapper_descriptor on the C-level partial type."
    - "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — __new__ differs from __init__/__call__."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' (len=5) — WRAPPER_ASSIGNMENTS is a plain tuple constant."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is also a tuple, length 1 vs WRAPPER_ASSIGNMENTS length 6."
    - "functools.WRAPPER_ASSIGNMENTS.__len__.__class__.__name__ == 'method-wrapper' — bound slot wrapper on the tuple instance."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is a C builtin from the _functools extension."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' (len=26) — longest class name in spec."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a pure Python decorator."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is defined in the pure Python functools module."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.partial class-level attribute identity
#
# partial.__init__ and partial.__call__ are both wrapper_descriptor (C slot).
# partial.__new__ is builtin_function_or_method (different from __init__/__call__).
# partial.__doc__.__class__.__name__ == 'str' — docstring present.
# WRAPPER_ASSIGNMENTS is a tuple of length 6; WRAPPER_UPDATES is a tuple of length 1.
# ---------------------------------------------------------------------------

table functools_extra272.partial_class_attrs_identity:
  description: "functools.partial class-level attribute identity — __init__ and __call__ are wrapper_descriptor(17); __new__ is builtin_function_or_method(26); __doc__ class is str; WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are both tuple; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex272pa

  columns: [id, function, args, expected, description]
  rows:
    - [doc_cls_eq,         partial.__doc__.__class__.__name__.__eq__,              ["str"],                        true, "functools.partial.__doc__.__class__.__name__ == 'str' — partial has a docstring; verified with Python 3.14.3"]
    - [init_name_eq,       partial.__init__.__name__.__eq__,                       ["__init__"],                   true, "functools.partial.__init__.__name__ == '__init__'; verified with Python 3.14.3"]
    - [init_cls_eq,        partial.__init__.__class__.__name__.__eq__,             ["wrapper_descriptor"],         true, "functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper; verified with Python 3.14.3"]
    - [init_cls_len,       partial.__init__.__class__.__name__.__len__,            [],                             17,   "functools.partial.__init__.__class__.__name__.__len__() == 17 — 'wrapper_descriptor' len=17; verified with Python 3.14.3"]
    - [call_name_eq,       partial.__call__.__name__.__eq__,                       ["__call__"],                   true, "functools.partial.__call__.__name__ == '__call__'; verified with Python 3.14.3"]
    - [call_cls_eq,        partial.__call__.__class__.__name__.__eq__,             ["wrapper_descriptor"],         true, "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — same as __init__; verified with Python 3.14.3"]
    - [new_name_eq,        partial.__new__.__name__.__eq__,                        ["__new__"],                    true, "functools.partial.__new__.__name__ == '__new__'; verified with Python 3.14.3"]
    - [new_cls_eq,         partial.__new__.__class__.__name__.__eq__,              ["builtin_function_or_method"], true, "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — differs from __init__/__call__; verified with Python 3.14.3"]
    - [new_cls_len,        partial.__new__.__class__.__name__.__len__,             [],                             26,   "functools.partial.__new__.__class__.__name__.__len__() == 26 — longest class name in spec; verified with Python 3.14.3"]
    - [wa_cls_eq,          WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,          ["tuple"],                      true, "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [wa_len,             WRAPPER_ASSIGNMENTS.__len__,                            [],                             6,    "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — six standard wrapper attributes; verified with Python 3.14.3"]
    - [wu_cls_eq,          WRAPPER_UPDATES.__class__.__name__.__eq__,              ["tuple"],                      true, "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [wu_len,             WRAPPER_UPDATES.__len__,                                [],                             1,    "functools.WRAPPER_UPDATES.__len__() == 1 — one update attribute; verified with Python 3.14.3"]
    - [wa_lencls_eq,       WRAPPER_ASSIGNMENTS.__len__.__class__.__name__.__eq__,  ["method-wrapper"],             true, "functools.WRAPPER_ASSIGNMENTS.__len__.__class__.__name__ == 'method-wrapper' — bound slot on tuple instance; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.cmp_to_key and functools.total_ordering identity
#
# cmp_to_key is a C builtin from _functools (__module__ == '_functools').
# cmp_to_key.__class__.__name__ == 'builtin_function_or_method' (len=26).
# total_ordering is a pure Python decorator (__class__.__name__ == 'function').
# total_ordering.__module__ == 'functools' (len=9).
# cmp_to_key.__name__ (len=10) < total_ordering.__name__ (len=13).
# ---------------------------------------------------------------------------

table functools_extra272.cmp_to_key_total_ordering_identity:
  description: "functools.cmp_to_key(10) and total_ordering(13) identity — cmp_to_key is a C builtin from _functools(10); total_ordering is a pure Python function in functools(9); cmp_to_key.__class__.__name__=='builtin_function_or_method'(26) longest class name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex272ct

  columns: [id, function, args, expected, description]
  rows:
    - [ck_name_eq,         cmp_to_key.__name__.__eq__,                 ["cmp_to_key"],                 true, "functools.cmp_to_key.__name__ == 'cmp_to_key'; verified with Python 3.14.3"]
    - [ck_name_len,        cmp_to_key.__name__.__len__,                [],                             10,   "functools.cmp_to_key.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ck_mod_eq,          cmp_to_key.__module__.__eq__,               ["_functools"],                 true, "functools.cmp_to_key.__module__ == '_functools' — C implementation; verified with Python 3.14.3"]
    - [ck_mod_len,         cmp_to_key.__module__.__len__,              [],                             10,   "functools.cmp_to_key.__module__.__len__() == 10 — '_functools' len=10; verified with Python 3.14.3"]
    - [ck_qn_eq,           cmp_to_key.__qualname__.__eq__,             ["cmp_to_key"],                 true, "functools.cmp_to_key.__qualname__ == 'cmp_to_key'; verified with Python 3.14.3"]
    - [ck_cls_eq,          cmp_to_key.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — C builtin; verified with Python 3.14.3"]
    - [to_name_eq,         total_ordering.__name__.__eq__,             ["total_ordering"],             true, "functools.total_ordering.__name__ == 'total_ordering'; verified with Python 3.14.3"]
    - [to_name_len,        total_ordering.__name__.__len__,            [],                             13,   "functools.total_ordering.__name__.__len__() == 13 — longest name in spec; verified with Python 3.14.3"]
    - [to_mod_eq,          total_ordering.__module__.__eq__,           ["functools"],                  true, "functools.total_ordering.__module__ == 'functools' — pure Python; verified with Python 3.14.3"]
    - [to_mod_len,         total_ordering.__module__.__len__,          [],                             9,    "functools.total_ordering.__module__.__len__() == 9; verified with Python 3.14.3"]
    - [to_qn_eq,           total_ordering.__qualname__.__eq__,         ["total_ordering"],             true, "functools.total_ordering.__qualname__ == 'total_ordering' — qualname equals name; verified with Python 3.14.3"]
    - [to_cls_eq,          total_ordering.__class__.__name__.__eq__,   ["function"],                   true, "functools.total_ordering.__class__.__name__ == 'function' — pure Python decorator; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra272
# ---------------------------------------------------------------------------

invariant functools_extra272.partial_init_is_wrapper_descriptor:
  description: "functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' — __init__ and __call__ on the C-level partial type are both wrapper_descriptor, distinguishing them from __new__ which is builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: partial.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra272.wrapper_assignments_len_is_six:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — the tuple of standard wrapper attributes has six members; WRAPPER_UPDATES has length 1; 6 > 1"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra272.cmp_to_key_module_is_cfunctools:
  description: "functools.cmp_to_key.__module__ == '_functools' (len=10) — cmp_to_key is a C builtin, same as reduce.__module__; both are in the _functools C extension"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra272.total_ordering_is_pure_python:
  description: "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function/decorator, unlike cmp_to_key which is a C builtin"
  category: identity
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra272.partial_doc_class_is_str:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — partial has a non-None docstring; the doc attribute class name is 'str'"
  category: identity
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
