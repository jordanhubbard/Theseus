spec: sqlite3_extra7
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra6.zspec.zsdl."
    - "sqlite3_extra4 covers __name__ for Connection/Cursor/Row/Error/DatabaseError/OperationalError/IntegrityError/InterfaceError/ProgrammingError/DataError/NotSupportedError."
    - "sqlite3_extra3 covers __module__ for Cursor/Row/Error/DatabaseError/OperationalError/IntegrityError/ProgrammingError/InterfaceError (all == 'sqlite3')."
    - "sqlite3_extra6 covers __bases__[0].__qualname__ for DatabaseError and OperationalError."
    - "This spec adds: __module__ for Connection/Row/Cursor as standalone invariants; __bases__[0].__name__ for IntegrityError/OperationalError/ProgrammingError/DataError/NotSupportedError/InterfaceError/Warning/Error; SQLITE_OK/SQLITE_ERROR/SQLITE_INTERNAL constants."
    - "sqlite3.Connection.__module__ == 'sqlite3' — top-level C extension type."
    - "sqlite3.Row.__module__ == 'sqlite3' — C extension type for row access."
    - "sqlite3.Cursor.__module__ == 'sqlite3' — C extension type for database cursor."
    - "sqlite3.IntegrityError.__bases__[0].__name__ == 'DatabaseError'."
    - "sqlite3.OperationalError.__bases__[0].__name__ == 'DatabaseError'."
    - "sqlite3.ProgrammingError.__bases__[0].__name__ == 'DatabaseError'."
    - "sqlite3.DataError.__bases__[0].__name__ == 'DatabaseError'."
    - "sqlite3.NotSupportedError.__bases__[0].__name__ == 'DatabaseError'."
    - "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error'."
    - "sqlite3.Warning.__bases__[0].__name__ == 'Exception'."
    - "sqlite3.Error.__bases__[0].__name__ == 'Exception'."
    - "sqlite3.SQLITE_OK == 0 — SQLITE result code for success."
    - "sqlite3.SQLITE_ERROR == 1 — SQLITE result code for generic error."
    - "sqlite3.SQLITE_INTERNAL == 2 — SQLITE result code for internal error."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for core C extension types — Connection, Row, Cursor
#
# sqlite3_extra3 covers __module__ for Cursor/Row/Error via a table.
# This spec adds Connection.__module__ as a standalone invariant (new axis),
# and re-covers Row and Cursor as independent named invariants for
# independent traceability.
# ---------------------------------------------------------------------------

invariant sqlite3_extra7.Connection.module:
  description: "sqlite3.Connection.__module__ == 'sqlite3' — C extension type at module scope"
  category: class_modules
  kind: python_call_eq
  function: Connection.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra7.Row.module:
  description: "sqlite3.Row.__module__ == 'sqlite3' — C extension type at module scope"
  category: class_modules
  kind: python_call_eq
  function: Row.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra7.Cursor.module:
  description: "sqlite3.Cursor.__module__ == 'sqlite3' — C extension type at module scope"
  category: class_modules
  kind: python_call_eq
  function: Cursor.__module__.__eq__
  args: ["sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# Exception base class hierarchy — __bases__[0].__name__ checks
#
# sqlite3_extra6 checks __bases__[0].__qualname__ for DatabaseError and
# OperationalError. This spec adds __bases__[0].__name__ for the complete
# exception hierarchy — IntegrityError/OperationalError/ProgrammingError/
# DataError/NotSupportedError (all subclass DatabaseError),
# InterfaceError (subclasses Error), Warning/Error (subclass Exception).
# ---------------------------------------------------------------------------

table sqlite3_extra7.exception_base_names:
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: base_name

  columns: [id, function, args, method, expected]
  rows:
    - [IntegrityError,   IntegrityError.__bases__.__getitem__,   [0], __name__, "DatabaseError"]
    - [OperationalError, OperationalError.__bases__.__getitem__,  [0], __name__, "DatabaseError"]
    - [ProgrammingError, ProgrammingError.__bases__.__getitem__,  [0], __name__, "DatabaseError"]
    - [DataError,        DataError.__bases__.__getitem__,         [0], __name__, "DatabaseError"]
    - [NotSupportedError, NotSupportedError.__bases__.__getitem__, [0], __name__, "DatabaseError"]
    - [InterfaceError,   InterfaceError.__bases__.__getitem__,   [0], __name__, "Error"]
    - [Warning,          Warning.__bases__.__getitem__,          [0], __name__, "Exception"]
    - [Error,            Error.__bases__.__getitem__,            [0], __name__, "Exception"]

# ---------------------------------------------------------------------------
# SQLITE result code constants — SQLITE_OK, SQLITE_ERROR, SQLITE_INTERNAL
#
# sqlite3_extra3 checks SQLITE_OK and threadsafety bounds.
# sqlite3_extra6 checks threadsafety.__class__.__name__. This spec adds
# SQLITE_ERROR and SQLITE_INTERNAL — new constants not checked in any prior
# spec — and re-checks SQLITE_OK with __eq__ for independent traceability.
# ---------------------------------------------------------------------------

invariant sqlite3_extra7.SQLITE_OK.value:
  description: "sqlite3.SQLITE_OK == 0 — SQLITE result code for success"
  category: sqlite_constants
  kind: python_call_eq
  function: SQLITE_OK.__eq__
  args: [0]
  expected: true

invariant sqlite3_extra7.SQLITE_ERROR.value:
  description: "sqlite3.SQLITE_ERROR == 1 — SQLITE result code for generic SQL error"
  category: sqlite_constants
  kind: python_call_eq
  function: SQLITE_ERROR.__eq__
  args: [1]
  expected: true

invariant sqlite3_extra7.SQLITE_INTERNAL.value:
  description: "sqlite3.SQLITE_INTERNAL == 2 — SQLITE result code for internal error"
  category: sqlite_constants
  kind: python_call_eq
  function: SQLITE_INTERNAL.__eq__
  args: [2]
  expected: true
