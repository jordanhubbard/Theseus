spec: inspect_extra38
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra37.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty.__class__.__name__.__len__()==4; Parameter.POSITIONAL_ONLY/__class__.__name__.__len__()==14; _ParameterKind.__qualname__.__len__()==14; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; various field lengths; cleandoc/__name__(8)/formatannotation/__name__(16)/getattr_static/__name__(14)/classify_class_attrs/__name__(20); CO_OPTIMIZED.__class__.__name__.__len__()==3; Signature method qualnames: __init__(18)/bind(14)/bind_partial(22)/replace(17); Parameter method qualnames: __init__(18)/replace(17); BoundArguments.apply_defaults qualname(29); BoundArguments.args.__class__.__name__(8)."
    - "This spec covers: getmembers.__module__.__len__() (7 — 'inspect'); signature.__module__.__len__() (7 — 'inspect'); isfunction.__module__.__len__() (7 — 'inspect'); Parameter.__module__.__len__() (7 — 'inspect'); Signature.__module__.__len__() (7 — 'inspect'); BoundArguments.__module__.__len__() (7 — 'inspect'); Parameter.empty.__name__.__len__() (6 — '_empty'); BoundArguments.__name__.__len__() (14 — 'BoundArguments'); FullArgSpec._fields.__len__() (7 — seven field names)."
    - "Key findings: Every inspect function and class recorded here has __module__ == 'inspect' (7 chars) — confirming all are defined in Lib/inspect.py with no C-extension split (unlike functools, which has '_functools'). inspect.Parameter.empty.__name__ is '_empty' (6 chars) — the private sentinel class has a leading underscore and a 5-char stem, giving 6 total. inspect.BoundArguments.__name__ is 'BoundArguments' (14 chars) — the longest __name__ of the three Signature-related classes (Signature=9, Parameter=9, BoundArguments=14). inspect.FullArgSpec._fields has 7 elements ('args', 'varargs', 'varkw', 'defaults', 'kwonlyargs', 'kwonlydefaults', 'annotations') — covering all categories of argument specification."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect function __module__.__len__() — extra38 namespace
#
# inspect.getmembers.__module__, inspect.signature.__module__, and inspect.
# isfunction.__module__ are all 'inspect' (7 chars). Unlike functools (which
# has a C-extension split giving '_functools' for some callables), the inspect
# module has no C-extension component — every function and class is pure Python,
# so every __module__ is 'inspect'. No prior inspect spec records __module__
# .__len__() for getmembers, signature, or isfunction. These three are recorded
# together for the first time in the extra38 namespace.
# ---------------------------------------------------------------------------

table inspect_extra38.function_module_name_lengths:
  description: "inspect module-level function __module__.__len__(): getmembers(7), signature(7), isfunction(7) — all 'inspect'"
  kind: python_call_eq
  category: module_metadata
  id_prefix: funcmodlen38

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers,
       getmembers.__module__.__len__,
       [],
       7,
       "len(inspect.getmembers.__module__) == 7 — 'inspect' (pure-Python; no C-extension split in inspect module)"]
    - [signature,
       signature.__module__.__len__,
       [],
       7,
       "len(inspect.signature.__module__) == 7 — 'inspect' (pure-Python; the primary public API for introspecting call signatures)"]
    - [isfunction,
       isfunction.__module__.__len__,
       [],
       7,
       "len(inspect.isfunction.__module__) == 7 — 'inspect' (pure-Python predicate; tests whether object is a Python function)"]

# ---------------------------------------------------------------------------
# inspect class __module__.__len__() — extra38 namespace
#
# inspect.Parameter.__module__, inspect.Signature.__module__, and inspect.
# BoundArguments.__module__ are all 'inspect' (7 chars). The inspect module is
# implemented entirely in pure Python (Lib/inspect.py), so all three core
# Signature-related classes share the same 7-char module name. No prior inspect
# spec records __module__.__len__() for Parameter, Signature, or BoundArguments.
# These three values are recorded together for the first time in the extra38
# namespace.
# ---------------------------------------------------------------------------

table inspect_extra38.class_module_name_lengths:
  description: "inspect Signature-related class __module__.__len__(): Parameter(7), Signature(7), BoundArguments(7) — all 'inspect'"
  kind: python_call_eq
  category: module_metadata
  id_prefix: classmodlen38

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter,
       Parameter.__module__.__len__,
       [],
       7,
       "len(inspect.Parameter.__module__) == 7 — 'inspect' (pure-Python class representing a single callable parameter)"]
    - [Signature,
       Signature.__module__.__len__,
       [],
       7,
       "len(inspect.Signature.__module__) == 7 — 'inspect' (pure-Python class representing a callable's signature)"]
    - [BoundArguments,
       BoundArguments.__module__.__len__,
       [],
       7,
       "len(inspect.BoundArguments.__module__) == 7 — 'inspect' (pure-Python class holding arguments bound to a Signature)"]

# ---------------------------------------------------------------------------
# Parameter.empty.__name__.__len__() — extra38 standalone invariant
#
# inspect.Parameter.empty.__name__ is '_empty' (6 chars). Parameter.empty is
# a sentinel class (not an instance) used to represent missing default values
# and missing annotations. Its __name__ starts with an underscore, marking it
# as a private implementation detail. Prior specs recorded Parameter.empty.
# __class__.__name__.__len__() == 4 ('type' — empty is a class, so its
# metatype is 'type'), but not the sentinel class's own __name__.__len__() == 6
# ('_empty'). Signature.empty is the same object as Parameter.empty. No prior
# inspect spec records Parameter.empty.__name__.__len__() in the extra38 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra38.Parameter_empty_name_len:
  description: "len(inspect.Parameter.empty.__name__) == 6 — '_empty' (private sentinel class; leading underscore + 5-char stem; Signature.empty is the same object)"
  category: string_properties
  kind: python_call_eq
  function: Parameter.empty.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# BoundArguments.__name__.__len__() and FullArgSpec._fields.__len__() — extra38
#
# inspect.BoundArguments.__name__ is 'BoundArguments' (14 chars) — the longest
# __name__ among the three Signature-related classes (Signature=9, Parameter=9,
# BoundArguments=14). inspect.FullArgSpec._fields has 7 elements — 'args',
# 'varargs', 'varkw', 'defaults', 'kwonlyargs', 'kwonlydefaults', 'annotations'
# — covering all categories of argument specification. Prior specs recorded
# BoundArguments.__mro__.__len__()==2 and BoundArguments.apply_defaults.__qualname__
# .__len__()==29, but not BoundArguments.__name__.__len__() == 14 or FullArgSpec.
# _fields.__len__() == 7. No prior inspect spec records these two values together
# in the extra38 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra38.BoundArguments_name_len:
  description: "len(inspect.BoundArguments.__name__) == 14 — 'BoundArguments' (longest __name__ among Signature/Parameter/BoundArguments; Signature=9, Parameter=9)"
  category: string_properties
  kind: python_call_eq
  function: BoundArguments.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra38.FullArgSpec_fields_len:
  description: "len(inspect.FullArgSpec._fields) == 7 — seven fields: 'args', 'varargs', 'varkw', 'defaults', 'kwonlyargs', 'kwonlydefaults', 'annotations'"
  category: module_metadata
  kind: python_call_eq
  function: FullArgSpec._fields.__len__
  args: []
  expected: 7
