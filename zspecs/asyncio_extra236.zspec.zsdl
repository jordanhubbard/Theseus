spec: asyncio_extra236
version: ">=3.9"
backend: python_module(asyncio.protocols)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio protocol class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py"
  notes:
    - "asyncio.BaseProtocol.__name__ == 'BaseProtocol' — 12 characters; module is 'asyncio.protocols'; verified with Python 3.14.3."
    - "asyncio.Protocol.__name__ == 'Protocol' — 8 characters; module is 'asyncio.protocols'; verified with Python 3.14.3."
    - "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol' — 16 characters; module is 'asyncio.protocols'; verified with Python 3.14.3."
    - "asyncio.BufferedProtocol.__name__ == 'BufferedProtocol' — 16 characters; module is 'asyncio.protocols'; verified with Python 3.14.3."
    - "asyncio.BaseProtocol.__bases__[0].__name__ == 'object' — BaseProtocol inherits directly from object; verified with Python 3.14.3."
    - "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol' — Protocol inherits directly from BaseProtocol; verified with Python 3.14.3."
    - "asyncio.DatagramProtocol.__bases__[0].__name__ == 'BaseProtocol' — DatagramProtocol inherits directly from BaseProtocol; verified with Python 3.14.3."
    - "asyncio.BufferedProtocol.__bases__[0].__name__ == 'BaseProtocol' — BufferedProtocol inherits directly from BaseProtocol; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio protocol class identity contracts — extra236 namespace
#
# BaseProtocol.__name__ == 'BaseProtocol' (12 chars); module 'asyncio.protocols'.
# Protocol.__name__ == 'Protocol' (8 chars); module 'asyncio.protocols'.
# DatagramProtocol.__name__ == 'DatagramProtocol' (16 chars); module 'asyncio.protocols'.
# BufferedProtocol.__name__ == 'BufferedProtocol' (16 chars); module 'asyncio.protocols'.
# ---------------------------------------------------------------------------

table asyncio_extra236.protocol_class_names:
  description: "asyncio protocol class __name__ and __module__ contracts in aio236pcn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio236pcn

  columns: [id, function, args, expected, description]
  rows:
    - [bp_name_eq,       BaseProtocol.__name__.__eq__,          ["BaseProtocol"],      true, "asyncio.BaseProtocol.__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [bp_name_len_12,   BaseProtocol.__name__.__len__,         [],                    12,   "asyncio.BaseProtocol.__name__.__len__() == 12 — 'BaseProtocol' has 12 characters; verified with Python 3.14.3"]
    - [bp_module_eq,     BaseProtocol.__module__.__eq__,        ["asyncio.protocols"], true, "asyncio.BaseProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [proto_name_eq,    Protocol.__name__.__eq__,              ["Protocol"],          true, "asyncio.Protocol.__name__ == 'Protocol'; verified with Python 3.14.3"]
    - [proto_name_len_8, Protocol.__name__.__len__,             [],                    8,    "asyncio.Protocol.__name__.__len__() == 8 — 'Protocol' has 8 characters; verified with Python 3.14.3"]
    - [proto_module_eq,  Protocol.__module__.__eq__,            ["asyncio.protocols"], true, "asyncio.Protocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [dgp_name_eq,      DatagramProtocol.__name__.__eq__,      ["DatagramProtocol"],  true, "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol'; verified with Python 3.14.3"]
    - [dgp_name_len_16,  DatagramProtocol.__name__.__len__,     [],                    16,   "asyncio.DatagramProtocol.__name__.__len__() == 16 — 'DatagramProtocol' has 16 characters; verified with Python 3.14.3"]
    - [dgp_module_eq,    DatagramProtocol.__module__.__eq__,    ["asyncio.protocols"], true, "asyncio.DatagramProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [bufp_name_eq,     BufferedProtocol.__name__.__eq__,      ["BufferedProtocol"],  true, "asyncio.BufferedProtocol.__name__ == 'BufferedProtocol'; verified with Python 3.14.3"]
    - [bufp_name_len_16, BufferedProtocol.__name__.__len__,     [],                    16,   "asyncio.BufferedProtocol.__name__.__len__() == 16 — 'BufferedProtocol' has 16 characters; verified with Python 3.14.3"]
    - [bufp_module_eq,   BufferedProtocol.__module__.__eq__,    ["asyncio.protocols"], true, "asyncio.BufferedProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio protocol class inheritance contracts — extra236 namespace
#
# BaseProtocol.__bases__[0].__name__ == 'object'.
# Protocol.__bases__[0].__name__ == 'BaseProtocol'.
# DatagramProtocol.__bases__[0].__name__ == 'BaseProtocol'.
