invariant asyncio_extra236.base_protocol_base_is_object:
  description: "asyncio.BaseProtocol.__bases__[0].__name__ == 'object' — BaseProtocol inherits directly from object"
  category: identity
  kind: python_call_eq
  function: BaseProtocol.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant asyncio_extra236.protocol_base_is_base_protocol:
  description: "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol' — Protocol inherits directly from BaseProtocol"
  category: identity
  kind: python_call_eq
  function: Protocol.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BaseProtocol"

invariant asyncio_extra236.datagram_protocol_base_is_base_protocol:
