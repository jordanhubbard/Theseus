# ---------------------------------------------------------------------------
# Standalone invariants — extra137
# ---------------------------------------------------------------------------

invariant itertools_extra137.tee_is_builtin:
  description: "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a C builtin function, not a type; wave 265; new to extra137"
  kind: python_call_eq
  function: tee.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra137.tee_qualname_len:
  description: "len(itertools.tee.__qualname__) == 3 — __qualname__ is 'tee'; wave 265; new to extra137"
  kind: python_call_eq
  function: tee.__qualname__.__len__
  args: []
  expected: 3

invariant itertools_extra137.chain_from_iterable_qualname_len:
  description: "len(itertools.chain.from_iterable.__qualname__) == 19 — __qualname__ is 'chain.from_iterable'; wave 265; new to extra137"
  kind: python_call_eq
  function: "chain.from_iterable.__qualname__.__len__"
  args: []
  expected: 19

invariant itertools_extra137.compress_iter_qualname_len:
  description: "len(itertools.compress.__iter__.__qualname__) == 17 — __qualname__ is 'compress.__iter__'; wave 265; new to extra137"
  kind: python_call_eq
  function: compress.__iter__.__qualname__.__len__
  args: []
  expected: 17

invariant itertools_extra137.dropwhile_next_qualname_len:
  description: "len(itertools.dropwhile.__next__.__qualname__) == 18 — __qualname__ is 'dropwhile.__next__'; wave 265; new to extra137"
  kind: python_call_eq
  function: dropwhile.__next__.__qualname__.__len__
  args: []
  expected: 18
