spec: itertools_extra137
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.tee (builtin_function_or_method identity), itertools.chain.from_iterable (classmethod_descriptor qualname/name), itertools.compress and itertools.dropwhile (C extension type slot qualnames) — Wave 265."
    - "itertools.tee.__class__.__name__ == 'builtin_function_or_method' (len 26) — tee is a C builtin function, not a type. Verified with Python 3.14.3."
    - "itertools.tee.__qualname__ == 'tee' (len 3) — tee is exposed as a C builtin. Verified with Python 3.14.3."
    - "itertools.tee.__module__ == 'itertools' (len 9). Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' (len 19) — from_iterable is a classmethod_descriptor on the chain type. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' (len 26). Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' (len 13). Verified with Python 3.14.3."
    - "itertools.compress.__class__.__name__ == 'type' (len 4) — compress is a C extension type. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools' (len 9). Verified with Python 3.14.3."
    - "itertools.compress.__name__ == 'compress' (len 8). Verified with Python 3.14.3."
    - "itertools.compress.__iter__.__qualname__ == 'compress.__iter__' (len 17). Verified with Python 3.14.3."
    - "itertools.compress.__next__.__qualname__ == 'compress.__next__' (len 17). Verified with Python 3.14.3."
    - "itertools.dropwhile.__class__.__name__ == 'type' (len 4) — dropwhile is a C extension type. Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' (len 9). Verified with Python 3.14.3."
    - "itertools.dropwhile.__iter__.__qualname__ == 'dropwhile.__iter__' (len 18). Verified with Python 3.14.3."
    - "itertools.dropwhile.__next__.__qualname__ == 'dropwhile.__next__' (len 18). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.tee — builtin_function_or_method identity
#
# Wave 265 theme: itertools.tee is a C builtin function (not a type).
#
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
# itertools.tee.__qualname__ == 'tee' (len 3)
# itertools.tee.__name__ == 'tee' (len 3)
# itertools.tee.__module__ == 'itertools' (len 9)
#
# tee returns a tuple of n independent iterators from a single iterable.
# It is a C builtin function, not a C extension type. New to extra137.
# ---------------------------------------------------------------------------

table itertools_extra137.tee_identity:
  description: "itertools.tee: builtin_function_or_method, qualname=='tee' len 3, __module__=='itertools' len 9; wave 265; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolstee137

  columns: [id, function, args, expected, description]
  rows:
    - [tee_class_name_eq,
       "tee.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — tee is a C builtin function in Modules/itertoolsmodule.c, not a type; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra137"]
    - [tee_class_name_len_eq_26,
       "tee.__class__.__name__.__len__",
       [],
       26,
       "itertools.tee.__class__.__name__.__len__() == 26 — __class__.__name__ is 'builtin_function_or_method' which has 26 characters; len('builtin_function_or_method') == 26; new to extra137"]
    - [tee_qualname_eq,
       "tee.__qualname__.__eq__",
       ["tee"],
       true,
       "itertools.tee.__qualname__.__eq__('tee') == True — tee is a C builtin function; its __qualname__ is 'tee'; str.__eq__('tee') returns True; new to extra137"]
    - [tee_qualname_len_eq_3,
       "tee.__qualname__.__len__",
       [],
       3,
       "itertools.tee.__qualname__.__len__() == 3 — __qualname__ is 'tee' which has 3 characters; len('tee') == 3; new to extra137"]
    - [tee_module_eq_itertools,
       "tee.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.tee.__module__.__eq__('itertools') == True — tee's __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra137"]
    - [tee_module_len_eq_9,
       "tee.__module__.__len__",
       [],
       9,
       "itertools.tee.__module__.__len__() == 9 — __module__ is 'itertools' which has 9 characters; len('itertools') == 9; new to extra137"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.from_iterable — classmethod_descriptor identity
#
# Wave 265 theme: itertools.chain.from_iterable qualname and __name__.
#
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' (len 19)
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' (len 26)
# itertools.chain.from_iterable.__name__ == 'from_iterable' (len 13)
# itertools.chain.from_iterable.__module__ is None
#
# chain.from_iterable is an alternate constructor classmethod on the chain type.
# As a C descriptor its __module__ is None. New to extra137.
# ---------------------------------------------------------------------------

table itertools_extra137.chain_from_iterable_identity:
  description: "itertools.chain.from_iterable: qualname=='chain.from_iterable' len 19, __name__ len 13, class len 26; wave 265; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolschainfrom137

  columns: [id, function, args, expected, description]
  rows:
    - ["chain.from_iterable.__qualname__.__eq__",
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — chain.from_iterable is an alternate constructor classmethod on the chain C type; its __qualname__ is 'chain.from_iterable'; str.__eq__('chain.from_iterable') returns True; new to extra137"]
    - ["chain.from_iterable.__qualname__.__len__",
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — __qualname__ is 'chain.from_iterable' which has 19 characters; len('chain.from_iterable') == 19; new to extra137"]
    - ["chain.from_iterable.__name__.__eq__",
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — the __name__ of the descriptor is 'from_iterable' (without the class prefix); str.__eq__('from_iterable') returns True; new to extra137"]
    - ["chain.from_iterable.__name__.__len__",
       "chain.from_iterable.__name__.__len__",
       [],
       13,
       "itertools.chain.from_iterable.__name__.__len__() == 13 — __name__ is 'from_iterable' which has 13 characters; len('from_iterable') == 13; new to extra137"]
    - ["chain.from_iterable.__class__.__name__.__eq__",
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.from_iterable is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra137"]

# ---------------------------------------------------------------------------
# Table 3: itertools.compress — C extension type slot qualnames
#
# Wave 265 theme: itertools.compress type identity and slot qualnames.
#
# itertools.compress.__class__.__name__ == 'type' (len 4)
# itertools.compress.__module__ == 'itertools' (len 9)
# itertools.compress.__name__ == 'compress' (len 8)
# len(itertools.compress.__mro__) == 2
# itertools.compress.__iter__.__qualname__ == 'compress.__iter__' (len 17)
# itertools.compress.__next__.__qualname__ == 'compress.__next__' (len 17)
#
# compress filters elements from data returning only those where the
# corresponding selector element is True. New to extra137.
# ---------------------------------------------------------------------------

table itertools_extra137.compress_identity:
  description: "itertools.compress: C type, __name__ len 8, MRO len 2, slot qualnames len 17; wave 265; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscompress137

  columns: [id, function, args, expected, description]
  rows:
    - [compress_class_name_eq_type,
       "compress.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.compress.__class__.__name__.__eq__('type') == True — compress is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra137"]
    - [compress_module_eq_itertools,
       "compress.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — compress's __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra137"]
    - [compress_name_eq,
       "compress.__name__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — the C extension type's __name__ is 'compress'; str.__eq__('compress') returns True; new to extra137"]
    - [compress_name_len_eq_8,
       "compress.__name__.__len__",
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — __name__ is 'compress' which has 8 characters; len('compress') == 8; new to extra137"]
    - [compress_mro_len_eq_2,
       "compress.__mro__.__len__",
       [],
       2,
       "itertools.compress.__mro__.__len__() == 2 — compress's MRO is [compress, object]; len(__mro__) is 2; new to extra137"]
    - [compress_iter_qualname_eq,
       "compress.__iter__.__qualname__.__eq__",
       ["compress.__iter__"],
       true,
       "itertools.compress.__iter__.__qualname__.__eq__('compress.__iter__') == True — compress.__iter__ is a slot method on the C type; its qualname is 'compress.__iter__'; str.__eq__('compress.__iter__') returns True; new to extra137"]
    - [compress_iter_qualname_len_eq_17,
       "compress.__iter__.__qualname__.__len__",
       [],
       17,
       "itertools.compress.__iter__.__qualname__.__len__() == 17 — __qualname__ is 'compress.__iter__' which has 17 characters; len('compress.__iter__') == 17; new to extra137"]
    - [compress_next_qualname_eq,
       "compress.__next__.__qualname__.__eq__",
       ["compress.__next__"],
       true,
       "itertools.compress.__next__.__qualname__.__eq__('compress.__next__') == True — compress.__next__ is a slot method on the C type; its qualname is 'compress.__next__'; str.__eq__('compress.__next__') returns True; new to extra137"]
    - [compress_next_qualname_len_eq_17,
       "compress.__next__.__qualname__.__len__",
       [],
       17,
       "itertools.compress.__next__.__qualname__.__len__() == 17 — __qualname__ is 'compress.__next__' which has 17 characters; len('compress.__next__') == 17; new to extra137"]

# ---------------------------------------------------------------------------
# Table 4: itertools.dropwhile — C extension type slot qualnames
#
# Wave 265 theme: itertools.dropwhile type identity and slot qualnames.
#
# itertools.dropwhile.__class__.__name__ == 'type'
# itertools.dropwhile.__module__ == 'itertools'
# itertools.dropwhile.__name__ == 'dropwhile' (len 9)
