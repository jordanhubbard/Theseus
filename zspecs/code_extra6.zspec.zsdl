spec: code_extra6
version: ">=3.9"
backend: python_module(code)

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/code.html — Python code module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/code.py"
    - "code.zspec.zsdl — covers function __name__ (interact/compile_command); class __name__ (InteractiveConsole/InteractiveInterpreter/CommandCompiler); InteractiveConsole.__module__/__bases__[0]; InteractiveInterpreter method names; compile_command behavioral tests"
    - "code_extra.zspec.zsdl — covers InteractiveConsole/__module__; InteractiveInterpreter/__module__; base hierarchy; CommandCompiler/__name__/__module__; function names; InteractiveInterpreter method names table"
    - "code_extra2.zspec.zsdl — covers InteractiveInterpreter.__bases__[0].__name__=='object'; compile_command/__module__=='codeop'; interact.__module__=='code'; class qualnames table"
    - "code_extra3.zspec.zsdl — covers InteractiveConsole/InteractiveInterpreter __bases__.__len__==1; CommandCompiler/interact/compile_command __qualname__; InteractiveConsole.__bases__[0].__qualname__"
    - "code_extra4.zspec.zsdl — covers InteractiveInterpreter method __qualname__ checks; InteractiveConsole push/resetbuffer/raw_input __name__; CommandCompiler.__bases__[0].__name__; CommandCompiler.__bases__.__len__"
    - "code_extra5.zspec.zsdl — covers interact/__code__.co_name; interact/__code__.__class__.__name__; compile_command/__code__.co_name; code.__name__; InteractiveConsole.raw_input.__qualname__"
  notes:
    - "This spec covers axes not tested in any prior code spec."
    - "code.InteractiveInterpreter.showsyntaxerror.__name__ == 'showsyntaxerror' — not covered in any prior code spec."
    - "code.InteractiveInterpreter.showtraceback.__name__ == 'showtraceback' — not covered in any prior code spec."
    - "code.InteractiveInterpreter.showsyntaxerror.__qualname__ == 'InteractiveInterpreter.showsyntaxerror' — not covered."
    - "code.InteractiveInterpreter.showtraceback.__qualname__ == 'InteractiveInterpreter.showtraceback' — not covered."
    - "code.InteractiveInterpreter.showsyntaxerror/__module__ == 'code' — method __module__ not covered in any prior code spec."
    - "code.InteractiveConsole.__mro__[1].__name__ == 'InteractiveInterpreter' — MRO entry not covered in any prior spec."
    - "code.InteractiveConsole.__mro__.__len__() == 3 — MRO length not covered in any prior spec."
    - "code.InteractiveInterpreter.__mro__.__len__() == 2 — MRO length not covered in any prior spec."
    - "code.CommandCompiler.__call__.__name__ == '__call__' — the callable interface method name not covered."
    - "code.CommandCompiler.__call__.__qualname__ == 'CommandCompiler.__call__' — not covered in any prior spec."
    - "code.InteractiveInterpreter.runsource/__code__.co_name == 'runsource' — bytecode name not covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# showsyntaxerror and showtraceback __name__ checks
# code/code_extra cover runsource/runcode/write/push/resetbuffer __name__.
# showsyntaxerror and showtraceback have never been checked.
# ---------------------------------------------------------------------------

invariant code_extra6.InteractiveInterpreter.showsyntaxerror_name:
  description: "code.InteractiveInterpreter.showsyntaxerror.__name__ == 'showsyntaxerror'"
  category: method_names
  kind: python_call_eq
  function: InteractiveInterpreter.showsyntaxerror.__name__.__eq__
  args: ["showsyntaxerror"]
  expected: true

invariant code_extra6.InteractiveInterpreter.showtraceback_name:
  description: "code.InteractiveInterpreter.showtraceback.__name__ == 'showtraceback'"
  category: method_names
  kind: python_call_eq
  function: InteractiveInterpreter.showtraceback.__name__.__eq__
  args: ["showtraceback"]
  expected: true

# ---------------------------------------------------------------------------
# showsyntaxerror and showtraceback __qualname__ checks
# code_extra4 covers runsource/runcode/write __qualname__.
# showsyntaxerror and showtraceback __qualname__ not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant code_extra6.InteractiveInterpreter.showsyntaxerror_qualname:
  description: "code.InteractiveInterpreter.showsyntaxerror.__qualname__ == 'InteractiveInterpreter.showsyntaxerror'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveInterpreter.showsyntaxerror.__qualname__.__eq__
  args: ["InteractiveInterpreter.showsyntaxerror"]
  expected: true

invariant code_extra6.InteractiveInterpreter.showtraceback_qualname:
  description: "code.InteractiveInterpreter.showtraceback.__qualname__ == 'InteractiveInterpreter.showtraceback'"
  category: method_qualnames
  kind: python_call_eq
  function: InteractiveInterpreter.showtraceback.__qualname__.__eq__
  args: ["InteractiveInterpreter.showtraceback"]
  expected: true

# ---------------------------------------------------------------------------
# InteractiveConsole MRO entries
# code_extra3 checks InteractiveConsole.__bases__[0].__qualname__.
# code covers InteractiveConsole.__bases__[0] (via __module__).
# MRO entries and MRO length have not been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant code_extra6.InteractiveConsole.mro1_name:
  description: "code.InteractiveConsole.__mro__[1].__name__ == 'InteractiveInterpreter' — second entry in MRO"
  category: mro
  kind: python_call_eq
  function: InteractiveConsole.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["InteractiveInterpreter"]
  expected: true

invariant code_extra6.InteractiveConsole.mro_len:
  description: "len(code.InteractiveConsole.__mro__) == 3 — Console, Interpreter, object"
  category: mro
  kind: python_call_eq
  function: InteractiveConsole.__mro__.__len__
  args: []
  expected: 3

invariant code_extra6.InteractiveInterpreter.mro_len:
  description: "len(code.InteractiveInterpreter.__mro__) == 2 — Interpreter and object only"
  category: mro
  kind: python_call_eq
  function: InteractiveInterpreter.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# CommandCompiler.__call__ — the callable interface
# code_extra4 checks CommandCompiler.__bases__[0].__name__ and __bases__.__len__.
# The __call__ method has not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant code_extra6.CommandCompiler.call_name:
  description: "code.CommandCompiler.__call__.__name__ == '__call__'"
  category: method_names
  kind: python_call_eq
  function: CommandCompiler.__call__.__name__.__eq__
  args: ["__call__"]
  expected: true

invariant code_extra6.CommandCompiler.call_qualname:
  description: "code.CommandCompiler.__call__.__qualname__ == 'CommandCompiler.__call__'"
  category: method_qualnames
  kind: python_call_eq
  function: CommandCompiler.__call__.__qualname__.__eq__
  args: ["CommandCompiler.__call__"]
  expected: true

# ---------------------------------------------------------------------------
# InteractiveInterpreter.runsource bytecode co_name cross-check
# code_extra5 checks interact/__code__.co_name and compile_command/__code__.co_name.
# Method code objects (runsource/runcode) have not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant code_extra6.InteractiveInterpreter.runsource_co_name:
  description: "code.InteractiveInterpreter.runsource.__code__.co_name == 'runsource'"
  category: code_objects
  kind: python_call_eq
  function: InteractiveInterpreter.runsource.__code__.co_name.__eq__
  args: ["runsource"]
  expected: true

invariant code_extra6.InteractiveInterpreter.runcode_co_name:
  description: "code.InteractiveInterpreter.runcode.__code__.co_name == 'runcode'"
  category: code_objects
  kind: python_call_eq
  function: InteractiveInterpreter.runcode.__code__.co_name.__eq__
  args: ["runcode"]
  expected: true
