spec: hashlib_extra1876
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "hashlib module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party hashlib extensions"
  notes:
    - "Tests attribute access protocol membership in hashlib types and module"
    - "hashlib hash types are implemented as C extension types; __getattr__/__setattr__/__delattr__ are not defined at the Python class level"
    - "Modern SHA-3, BLAKE2, and XOF (shake) algorithms verified present in module dict"
  created_at: "2026-04-12"

table hashlib_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl1876-aa-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__getattr__"], false]
    - ["hl1876-aa-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__setattr__"], false]
    - ["hl1876-aa-003", "hashlib.sha256.__class__.__dict__.__contains__", ["__delattr__"], false]
    - ["hl1876-aa-004", "hashlib.md5.__class__.__dict__.__contains__", ["__getattr__"], false]
    - ["hl1876-aa-005", "hashlib.__dict__.__contains__", ["__getattr__"], false]
    - ["hl1876-aa-006", "hashlib.__dict__.__contains__", ["__setattr__"], false]
    - ["hl1876-aa-007", "hashlib.__dict__.__contains__", ["__delattr__"], false]
    - ["hl1876-aa-008", "hashlib.__dict__.__contains__", ["__getattribute__"], false]

