  columns: [id, function, args, expected]
  rows:
    - ["hl1876-ip-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__dir__"], false]
    - ["hl1876-ip-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__sizeof__"], false]
    - ["hl1876-ip-003", "hashlib.md5.__class__.__dict__.__contains__", ["__dir__"], false]
    - ["hl1876-ip-004", "hashlib.__dict__.__contains__", ["__dir__"], false]
    - ["hl1876-ip-005", "hashlib.__dict__.__contains__", ["__sizeof__"], false]
    - ["hl1876-ip-006", "hashlib.sha256.__class__.__dict__.__contains__", ["__slots__"], false]
    - ["hl1876-ip-007", "hashlib.sha256.__class__.__dict__.__contains__", ["__dict__"], false]
    - ["hl1876-ip-008", "hashlib.__dict__.__contains__", ["__slots__"], false]

