spec: io_extra2371
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.open.__class__.__name__ == 'builtin_function_or_method' — open is a C builtin."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are ABCs; __class__.__name__ == 'ABCMeta', not 'type'."
    - "io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.TextIOWrapper, io.IncrementalNewlineDecoder are concrete classes; __class__.__name__ == 'type'."
    - "io.DEFAULT_BUFFER_SIZE, io.SEEK_SET, io.SEEK_CUR, io.SEEK_END are int constants; __class__.__name__ == 'int'."
    - "io.UnsupportedOperation is a concrete exception class; __class__.__name__ == 'type'."
  created_at: "2026-04-12"

