# ---------------------------------------------------------------------------
# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant abc_extra104.abstractproperty_init_is_wrapper_descriptor:
  description: "type(abc.abstractproperty.__init__).__name__.__eq__('wrapper_descriptor') returns True — abstractproperty inherits __init__ from property (C-level); abstractproperty.__init__.__qualname__=='property.__init__' (len=17, because it IS property's __init__); contrast: abstractclassmethod.__init__ and abstractstaticmethod.__init__ are both type 'function' (Python-defined, have __code__); abstractproperty has mro [abstractproperty, property, object] (length=3); abstractproperty.__bases__[0].__name__=='property'; abstractproperty is deprecated since Python 3.3 (use ABCMeta + property + @abstractmethod instead); because abstractproperty's __init__ is a wrapper_descriptor (C-level), it has no __code__ attribute; this contrasts with Python-defined functions which have __code__ with co_argcount; NEW in extra104: first standalone abstractproperty.__init__ type invariant in abcdeprecated104 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.abstractproperty.__init__).__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra104.abstractclassmethod_init_co_argcount_2:
  description: "abc.abstractclassmethod.__init__.__code__.co_argcount == 2 — abstractclassmethod.__init__ takes self and fn; abstractclassmethod.__init__.__qualname__=='abstractclassmethod.__init__' (len=28); type(abstractclassmethod.__init__).__name__=='function' (Python-defined, has __code__); abstractclassmethod is deprecated since Python 3.3; abstractclassmethod.__bases__[0].__name__=='classmethod'; abstractclassmethod.__mro__.__len__()==3 ([abstractclassmethod, classmethod, object]); compare co_argcount: abstractclassmethod.__init__=2 == abstractstaticmethod.__init__=2 (tied); ABCMeta.__new__=4 (most); abstractproperty.__init__ has no __code__ (C-level); abstractclassmethod.__init__ qualname len=28 vs abstractstaticmethod=29 (longer by 1); NEW in extra104: first standalone abstractclassmethod.__init__ argcount invariant in abcdeprecated104 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractclassmethod.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra104.abstractstaticmethod_init_qualname_len_29:
  description: "abc.abstractstaticmethod.__init__.__qualname__.__len__() == 29 — 'abstractstaticmethod.__init__' = 'abstractstaticmethod.'=21 + '__init__'=8 = 29; this is the longest qualname in this spec; compare qualname lengths: ABCMeta.__new__=15 (shortest) < abstractproperty.__init__=17 < abstractclassmethod.__init__=28 < abstractstaticmethod.__init__=29 (longest); 'abstractstaticmethod'=20 chars (longest class name: 'abstract'=8+'static'=6+'method'=6=20); abstractstaticmethod.__init__ is Python-defined (type=='function') with co_argcount==2 (self and fn); abstractstaticmethod is deprecated since Python 3.3 (use ABCMeta + staticmethod + @abstractmethod instead); abstractstaticmethod.__bases__[0].__name__=='staticmethod'; mro len=3; NEW in extra104: first standalone abstractstaticmethod.__init__ qualname length invariant in abcdeprecated104 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractstaticmethod.__init__.__qualname__.__len__
  args: []
  expected: 29

invariant abc_extra104.ABCMeta_new_co_argcount_4:
  description: "abc.ABCMeta.__new__.__code__.co_argcount == 4 — ABCMeta.__new__ takes cls, name, bases, and namespace; ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15, shortest qualname in spec); type(ABCMeta.__new__).__name__=='function' (Python-defined in Lib/abc.py); ABCMeta.__new__.__code__.co_name=='__new__'; compare co_argcount: abstractclassmethod.__init__=2 == abstractstaticmethod.__init__=2 (tied at 2) < ABCMeta.__new__=4 (most args in spec); co_argcount=4 reflects the metaclass __new__ signature: cls (the metaclass), name (class name), bases (base classes tuple), namespace (class body dict); ABCMeta.__new__ is responsible for setting up the abstract base class protocol (scanning the namespace for @abstractmethod-decorated methods); ABCMeta.__new__.__qualname__.__len__()==15 is the shortest qualname in spec; NEW in extra104: first standalone ABCMeta.__new__ argcount invariant in abcdeprecated104 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant abc_extra104.abstractstaticmethod_base_is_staticmethod:
  description: "abc.abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod') returns True — abstractstaticmethod inherits from staticmethod giving MRO [abstractstaticmethod, staticmethod, object] (length=3); compare: abstractclassmethod.__bases__[0].__name__=='classmethod' (inherits from classmethod); abstractproperty.__bases__[0].__name__=='property' (inherits from property); all three deprecated abstract decorator classes have mro len=3 and inherit from their respective non-abstract counterparts; abstractstaticmethod.__name__.__len__()==20 (longest class name in spec: 'abstract'=8+'static'=6+'method'=6=20); abstractstaticmethod.__init__.__code__.co_argcount==2 (self and fn); abstractstaticmethod is deprecated since Python 3.3; the mro pattern (deprecated_abstract_X, X, object) is consistent across all three deprecated abstract decorator classes; NEW in extra104: first standalone abstractstaticmethod base invariant in abcdeprecated104 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "abc.abstractstaticmethod.__bases__[0].__name__.__eq__"
  args: ["staticmethod"]
  expected: true

