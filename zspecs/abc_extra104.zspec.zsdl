spec: abc_extra104
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra103.zspec.zsdl."
    - "This spec covers: wave 254 theme — abstractproperty.__init__ qualname and type; abstractclassmethod.__init__ qualname and code attrs; abstractstaticmethod.__init__ qualname and code attrs; ABCMeta.__new__ qualname and code attrs. NEW in extra104: abc.abstractproperty.__init__.__qualname__=='property.__init__' (len=17; type is wrapper_descriptor — C-level, no __code__); abc.abstractclassmethod.__init__.__qualname__=='abstractclassmethod.__init__' (len=28, co_argcount=2: self and fn; type is function — Python-defined); abc.abstractstaticmethod.__init__.__qualname__=='abstractstaticmethod.__init__' (len=29, co_argcount=2: self and fn; type is function — Python-defined); abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15, co_argcount=4: cls, name, bases, namespace; type is function — Python-defined); abstractproperty inherits from property (base=property, mro len=3); abstractclassmethod inherits from classmethod (base=classmethod, mro len=3); abstractstaticmethod inherits from staticmethod (base=staticmethod, mro len=3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__init__.__qualname__ == 'property.__init__'. abstractproperty inherits __init__ from property (C-level wrapper_descriptor — no __code__). abstractproperty.__name__=='abstractproperty', __bases__[0].__name__=='property', __mro__.__len__()==3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__init__.__qualname__ == 'abstractclassmethod.__init__'. abstractclassmethod defines its own __init__ (Python function, co_argcount=2: self and fn). abstractclassmethod.__name__=='abstractclassmethod', __bases__[0].__name__=='classmethod', __mro__.__len__()==3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__init__.__qualname__ == 'abstractstaticmethod.__init__'. abstractstaticmethod defines its own __init__ (Python function, co_argcount=2: self and fn). abstractstaticmethod.__name__=='abstractstaticmethod', __bases__[0].__name__=='staticmethod', __mro__.__len__()==3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__'. ABCMeta.__new__ is a Python-defined function (type=='function') with co_argcount==4 (cls, name, bases, namespace). ABCMeta.__new__.__qualname__.__len__()==15 ('ABCMeta.__new__'=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abstractproperty.__init__ qualname and type — extra104
#
# Wave 254 theme: abstractproperty, abstractclassmethod, abstractstaticmethod __init__ attrs.
#
# abc.abstractproperty.__init__.__qualname__    == 'property.__init__'  (wrapper_descriptor, C-level)
# abc.abstractclassmethod.__init__.__qualname__ == 'abstractclassmethod.__init__' (function, co_argcount=2)
# ---------------------------------------------------------------------------

table abc_extra104.abc_deprecated_init_qualnames_a:
  description: "abc.abstractproperty, abstractclassmethod __init__ qualname and type checks in abcdeprecated104 namespace — wave 254 theme: abc.abstractproperty.__init__.__qualname__.__eq__('property.__init__')==True (len=17: 'property.__init__'=17; abstractproperty inherits __init__ from property — its parent class; type is wrapper_descriptor because property.__init__ is C-level with no __code__ attribute); type(abc.abstractproperty.__init__).__name__.__eq__('wrapper_descriptor')==True (C-level, no __code__); abc.abstractproperty.__name__.__eq__('abstractproperty')==True (len=16); abc.abstractproperty.__bases__[0].__name__.__eq__('property')==True; abc.abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]); abc.abstractclassmethod.__init__.__qualname__.__eq__('abstractclassmethod.__init__')==True (len=28: 'abstractclassmethod.'=20+'__init__'=8=28); type(abc.abstractclassmethod.__init__).__name__.__eq__('function')==True (Python-defined, has __code__); abc.abstractclassmethod.__init__.__code__.co_argcount==2 (self and fn); abc.abstractclassmethod.__name__.__eq__('abstractclassmethod')==True (len=19); abc.abstractclassmethod.__bases__[0].__name__.__eq__('classmethod')==True; abc.abstractclassmethod.__mro__.__len__()==3; compare: abstractproperty.__init__ is inherited from property (C-level), abstractclassmethod.__init__ is Python-defined; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdeprecated104

  columns: [id, function, args, expected, description]
  rows:
    - [ap_init_qn_eq,   abc.abstractproperty.__init__.__qualname__.__eq__,             ["property.__init__"],              true, "abstractproperty.__init__.__qualname__ == 'property.__init__' (len=17, inherited from property); verified with Python 3.14.3"]
    - [ap_init_qn_len,  abc.abstractproperty.__init__.__qualname__.__len__,            [],                                 17,   "abstractproperty.__init__.__qualname__.__len__() == 17 ('property.__init__'=17); verified with Python 3.14.3"]
