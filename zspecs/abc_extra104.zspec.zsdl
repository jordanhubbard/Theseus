    - [ap_name_eq,      abc.abstractproperty.__name__.__eq__,                          ["abstractproperty"],               true, "abstractproperty.__name__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [ap_base_eq,      "abc.abstractproperty.__bases__[0].__name__.__eq__",           ["property"],                      true, "abstractproperty.__bases__[0].__name__ == 'property'; verified with Python 3.14.3"]
    - [ap_mro_len,      abc.abstractproperty.__mro__.__len__,                          [],                                 3,    "abstractproperty.__mro__.__len__() == 3 ([abstractproperty, property, object]); verified with Python 3.14.3"]
    - [acm_init_qn_eq,  abc.abstractclassmethod.__init__.__qualname__.__eq__,          ["abstractclassmethod.__init__"],  true, "abstractclassmethod.__init__.__qualname__ == 'abstractclassmethod.__init__' (len=28); verified with Python 3.14.3"]
    - [acm_init_qn_len, abc.abstractclassmethod.__init__.__qualname__.__len__,         [],                                 28,   "abstractclassmethod.__init__.__qualname__.__len__() == 28 ('abstractclassmethod.__init__'=28); verified with Python 3.14.3"]
    - [acm_init_type_eq, type(abc.abstractclassmethod.__init__).__name__.__eq__,       ["function"],                      true, "type(abstractclassmethod.__init__).__name__ == 'function' (Python-defined, has __code__); verified with Python 3.14.3"]
    - [acm_init_argc,   abc.abstractclassmethod.__init__.__code__.co_argcount.__eq__,  [2],                               true, "abstractclassmethod.__init__.__code__.co_argcount == 2 (self and fn); verified with Python 3.14.3"]
