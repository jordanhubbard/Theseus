spec: decimal_extra259
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "libmpdec source"
  notes:
    - "Decimal.quantize, Decimal.sqrt, and Decimal.log10 are all method_descriptor objects."
    - "Decimal('4').sqrt() returns Decimal('2') — str() gives '2'."
    - "Decimal('9').sqrt() returns Decimal('3') — str() gives '3'."
    - "Decimal('100').log10() returns Decimal('2') — str() gives '2'."
    - "Decimal('1000').log10() returns Decimal('3') — str() gives '3'."
    - "Decimal('1.5').quantize(Decimal('0.1')) returns Decimal('1.5') — str() gives '1.5'."
    - "Decimal('1.55').quantize(Decimal('0.1')) returns Decimal('1.6') under ROUND_HALF_EVEN (banker's rounding)."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal method identity — quantize, sqrt, log10 are method_descriptors
# ---------------------------------------------------------------------------

invariant decimal_extra259.quantize.qualname:
  description: "Decimal.quantize.__qualname__ == 'Decimal.quantize'"
  category: identity
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

invariant decimal_extra259.quantize.class_name:
  description: "Decimal.quantize.__class__.__name__ == 'method_descriptor'"
  category: identity
  kind: python_call_eq
  function: Decimal.quantize.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra259.sqrt.qualname:
  description: "Decimal.sqrt.__qualname__ == 'Decimal.sqrt'"
  category: identity
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__eq__
  args: ["Decimal.sqrt"]
  expected: true

invariant decimal_extra259.sqrt.class_name:
  description: "Decimal.sqrt.__class__.__name__ == 'method_descriptor'"
  category: identity
  kind: python_call_eq
  function: Decimal.sqrt.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra259.log10.qualname:
  description: "Decimal.log10.__qualname__ == 'Decimal.log10'"
  category: identity
  kind: python_call_eq
  function: Decimal.log10.__qualname__.__eq__
  args: ["Decimal.log10"]
  expected: true

invariant decimal_extra259.log10.class_name:
  description: "Decimal.log10.__class__.__name__ == 'method_descriptor'"
  category: identity
  kind: python_call_eq
  function: Decimal.log10.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# Decimal.sqrt — perfect squares
# ---------------------------------------------------------------------------

table decimal_extra259.sqrt.perfect_squares:
  description: "Decimal.sqrt() for perfect squares returns integer-valued Decimal; str() gives bare integer string"
  kind: python_call_eq
  category: sqrt
  id_prefix: sqrt

  columns: [id, function, args, method, method_chain, expected]
  rows:
    - [sqrt_4,  Decimal, ["4"], sqrt, __str__, "2"]
    - [sqrt_9,  Decimal, ["9"], sqrt, __str__, "3"]

# ---------------------------------------------------------------------------
# Decimal.log10 — powers of 10
# ---------------------------------------------------------------------------

table decimal_extra259.log10.powers_of_ten:
  description: "Decimal.log10() for powers of 10 returns exact integer Decimal; str() gives bare integer string"
  kind: python_call_eq
  category: log10
  id_prefix: log10

  columns: [id, function, args, method, method_chain, expected]
  rows:
    - [log10_100,  Decimal, ["100"],  log10, __str__, "2"]
    - [log10_1000, Decimal, ["1000"], log10, __str__, "3"]

# ---------------------------------------------------------------------------
# Decimal.quantize — rounding to fixed precision
# ---------------------------------------------------------------------------

invariant decimal_extra259.quantize.one_decimal_place_exact:
  description: "Decimal('1.5').quantize(Decimal('0.1')) == '1.5' — already at correct precision"
  category: quantize
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: quantize
  method_args: ["0.1"]
  method_chain: __str__
  expected: "1.5"

invariant decimal_extra259.quantize.round_half_even:
  description: "Decimal('1.55').quantize(Decimal('0.1')) == '1.6' under ROUND_HALF_EVEN (banker's rounding)"
  category: quantize
  kind: python_call_eq
  function: Decimal
  args: ["1.55"]
  method: quantize
  method_args: ["0.1"]
  method_chain: __str__
  expected: "1.6"
