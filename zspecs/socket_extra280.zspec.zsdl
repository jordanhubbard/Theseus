spec: socket_extra280
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl through socket_extra279.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra279.zspec.zsdl covers: socket.getservbyname() and socket.getservbyport() — well-known port lookups (http/ftp/ssh/smtp/https); return types; error for unknown service; function identity."
    - "This spec focuses on: socket.socket class method identity via __qualname__ — setsockopt/getsockopt/fileno/settimeout/gettimeout/bind; socket.socket.__name__ and __module__; socket.socket method class names."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt' — qualname uses the C-level class name 'socket', not 'socket.socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.getsockopt.__qualname__ == 'socket.getsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.settimeout.__qualname__ == 'socket.settimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.gettimeout.__qualname__ == 'socket.gettimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.bind.__qualname__ == 'socket.bind'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor' — these are C-level method descriptors, not Python functions. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__name__ == 'socket' — the C-level class name is 'socket' (not 'socket.socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__module__ == 'socket' — the class is defined in the socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "Method descriptor lookups are pure attribute accesses; no exceptions expected."
  stderr: "null"
  stickiness: "N/A — these are class-level attribute lookups with no side effects."
  codes: {}

# ---------------------------------------------------------------------------
# socket.socket method __qualname__ values
# socket.socket is a C extension type; its methods are method_descriptor objects.
# The __qualname__ of each method uses the short C-level class name 'socket'
# (not 'socket.socket'), giving e.g. 'socket.setsockopt'.
# ---------------------------------------------------------------------------

table socket_extra280.socket_method_qualnames:
  description: "socket.socket.<method>.__qualname__ values — all use C-level class name 'socket' not 'socket.socket'; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: method_qualname
  id_prefix: smq280

  columns: [id, function, args, expected, description]
  rows:
    - [setsockopt_qualname, "socket.setsockopt.__qualname__.__eq__", ["socket.setsockopt"], true, "setsockopt qualname uses C-level class name 'socket'"]
    - [getsockopt_qualname, "socket.getsockopt.__qualname__.__eq__", ["socket.getsockopt"], true, "getsockopt qualname uses C-level class name 'socket'"]
    - [fileno_qualname,     "socket.fileno.__qualname__.__eq__",     ["socket.fileno"],     true, "fileno qualname uses C-level class name 'socket'"]
    - [settimeout_qualname, "socket.settimeout.__qualname__.__eq__", ["socket.settimeout"], true, "settimeout qualname uses C-level class name 'socket'"]
    - [gettimeout_qualname, "socket.gettimeout.__qualname__.__eq__", ["socket.gettimeout"], true, "gettimeout qualname uses C-level class name 'socket'"]
    - [bind_qualname,       "socket.bind.__qualname__.__eq__",       ["socket.bind"],       true, "bind qualname uses C-level class name 'socket'"]

# ---------------------------------------------------------------------------
# socket.socket method __class__.__name__ == 'method_descriptor'
# Methods on C extension types are method_descriptor objects (not functions,
# not bound methods). This holds for all socket.socket methods.
# ---------------------------------------------------------------------------

table socket_extra280.socket_method_class_names:
  description: "socket.socket.<method>.__class__.__name__ == 'method_descriptor' — C extension type methods are method descriptors; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: method_class
  id_prefix: smc280

  columns: [id, function, args, expected, description]
  rows:
    - [setsockopt_class, "socket.setsockopt.__class__.__name__.__eq__", ["method_descriptor"], true, "setsockopt is a method_descriptor"]
    - [getsockopt_class, "socket.getsockopt.__class__.__name__.__eq__", ["method_descriptor"], true, "getsockopt is a method_descriptor"]
    - [fileno_class,     "socket.fileno.__class__.__name__.__eq__",     ["method_descriptor"], true, "fileno is a method_descriptor"]
    - [settimeout_class, "socket.settimeout.__class__.__name__.__eq__", ["method_descriptor"], true, "settimeout is a method_descriptor"]

# ---------------------------------------------------------------------------
# socket.socket — class-level identity
# The C-level class name is 'socket' (not 'socket.socket').
# __module__ is 'socket' (the module, not '_socket').
# ---------------------------------------------------------------------------

invariant socket_extra280.socket_class.name:
  description: "socket.socket.__name__ == 'socket' — C-level class name is 'socket', not 'socket.socket'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra280.socket_class.module:
  description: "socket.socket.__module__ == 'socket' — socket class is exposed through the socket module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra280.socket_class.class_of_class:
  description: "socket.socket.__class__.__name__ == 'type' — socket.socket is a regular Python type object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: socket.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket — MRO length
# socket.socket has 3 entries in its MRO: socket.socket, its C base, and object.
# len(socket.socket.__mro__) == 3 confirms the single-inheritance chain.
# ---------------------------------------------------------------------------

invariant socket_extra280.socket_class.mro_length:
  description: "len(socket.socket.__mro__) == 3 — MRO has 3 entries: socket, its base socket, and object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: socket.__mro__.__len__
  args: []
  expected: 3
