# ---------------------------------------------------------------------------
# Table 1: functools.partialmethod class identity attributes
#
# Wave 286 theme: functools.partialmethod class identity — name, module, bases,
# and inherited __init__ qualname.
#
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__module__ == 'functools'
# functools.partialmethod.__bases__[0].__name__ == 'object'
# functools.partialmethod.__init__.__qualname__ == 'object.__init__'
#
# functools.partialmethod is a Python class in Lib/functools.py that creates
# partial-like objects suitable for use as method definitions in class bodies.
# Unlike functools.partial (a C extension type), partialmethod is a pure Python
# class that inherits directly from object. It does not define its own __init__
# slot, so __init__ is inherited from object and its __qualname__ is
# 'object.__init__'. New to extra162.
# ---------------------------------------------------------------------------

table functools_extra162.partialmethod_class_identity:
  description: "functools.partialmethod: __name__ 'partialmethod', __module__ 'functools', __bases__[0] 'object', __init__.__qualname__ 'object.__init__'; wave 286; new to extra162"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspmid162

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a Python class in Lib/functools.py that creates partial-like objects for method definitions in class bodies; its __name__ is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra162"]
    - [partialmethod_module_eq_functools,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra162"]
    - ["partialmethod_bases_0_name_eq_object",
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra162"]
    - [partialmethod_init_qualname_eq,
       "partialmethod.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "functools.partialmethod.__init__.__qualname__.__eq__('object.__init__') == True — partialmethod does not define its own __init__; the descriptor slot is inherited from object; the __qualname__ of this inherited descriptor is 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra162"]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod __get__ qualname and __name__ length
#
# Wave 286 theme: functools.partialmethod descriptor method __get__ qualname
# and __name__ string length.
#
# functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__'
# functools.partialmethod.__name__.__len__() == 13
#
# partialmethod defines a __get__ method in Python to act as a descriptor.
# When accessed on a class or instance, __get__ returns a bound partial object.
# Its __qualname__ is 'partialmethod.__get__' reflecting the class scope.
# The name 'partialmethod' has exactly 13 characters. New to extra162.
# ---------------------------------------------------------------------------

table functools_extra162.partialmethod_get_qualname_and_name_len:
