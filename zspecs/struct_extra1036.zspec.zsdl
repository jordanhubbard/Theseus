spec: struct_extra1036
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct function __reduce__.__qualname__ and module __doc__ class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1036.pack_unpack_reduce_qualnames:
  description: "struct pack/unpack function __reduce__.__qualname__ identity"
  kind: python_call_eq
  category: reduce_qualnames
  id_prefix: st1036p
  columns: [id, function, args, expected]
  rows:
    - [st1036p001, struct.pack.__reduce__.__qualname__.__eq__,        ["pack.__reduce__"],        true]
    - [st1036p002, struct.unpack.__reduce__.__qualname__.__eq__,      ["unpack.__reduce__"],      true]
    - [st1036p003, struct.calcsize.__reduce__.__qualname__.__eq__,    ["calcsize.__reduce__"],    true]
    - [st1036p004, struct.pack_into.__reduce__.__qualname__.__eq__,   ["pack_into.__reduce__"],   true]
    - [st1036p005, struct.unpack_from.__reduce__.__qualname__.__eq__, ["unpack_from.__reduce__"], true]
    - [st1036p006, struct.iter_unpack.__reduce__.__qualname__.__eq__, ["iter_unpack.__reduce__"], true]

table struct_extra1036.struct_class_reduce_qualnames:
  description: "struct.Struct class and method __reduce__.__qualname__ identity"
  kind: python_call_eq
  category: reduce_qualnames
  id_prefix: st1036c
  columns: [id, function, args, expected]
  rows:
    - [st1036c001, struct.Struct.__reduce__.__qualname__.__eq__,         ["Struct.__reduce__"],         true]
    - [st1036c002, struct.Struct.__init__.__qualname__.__eq__,           ["Struct.__init__"],           true]
    - [st1036c003, struct.Struct.pack.__qualname__.__eq__,               ["Struct.pack"],               true]
    - [st1036c004, struct.Struct.unpack.__qualname__.__eq__,             ["Struct.unpack"],             true]
    - [st1036c005, struct.Struct.pack_into.__qualname__.__eq__,          ["Struct.pack_into"],          true]
    - [st1036c006, struct.Struct.unpack_from.__qualname__.__eq__,        ["Struct.unpack_from"],        true]
    - [st1036c007, struct.Struct.iter_unpack.__qualname__.__eq__,        ["Struct.iter_unpack"],        true]

table struct_extra1036.module_doc_class_identity:
  description: "struct module __doc__ class identity and module-level attribute checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: st1036m
  columns: [id, function, args, expected]
  rows:
    - [st1036m001, struct.__doc__.__class__.__name__.__eq__,             ["str"],    true]
    - [st1036m002, struct.__name__.__eq__,                               ["struct"], true]
    - [st1036m003, struct.Struct.__class__.__name__.__eq__,              ["type"],   true]
    - [st1036m004, struct.Struct.__module__.__eq__,                      ["struct"], true]
    - [st1036m005, struct.Struct.__doc__.__class__.__name__.__eq__,      ["str"],    true]
