spec: difflib_extra8
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
    - "difflib.zspec.zsdl — covers SequenceMatcher ratio/find_longest/get_matching_blocks/get_opcodes; get_close_matches; IS_CHARACTER_JUNK/IS_LINE_JUNK tables; Differ/__name__; HtmlDiff/__name__; function names."
    - "difflib_extra.zspec.zsdl — covers SequenceMatcher/__name__/__module__; Differ/__name__; HtmlDiff/__name__; unified_diff/context_diff/ndiff/get_close_matches __name__; behavioral get_close_matches."
    - "difflib_extra2.zspec.zsdl — covers class name table; base class checks; function_modules table; unified_diff first line; ndiff prefix; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__; SequenceMatcher.ratio_identical."
    - "difflib_extra3.zspec.zsdl — covers __qualname__ for all major symbols; __module__ for SequenceMatcher/get_close_matches; get_close_matches('appel',...)."
    - "difflib_extra4.zspec.zsdl — covers SequenceMatcher/Differ/HtmlDiff __name__/__module__/__qualname__ extra4 anchors."
    - "difflib_extra5.zspec.zsdl — covers Differ/__module__; HtmlDiff/__module__; restore/__name__/__module__; IS_LINE_JUNK/__module__; IS_CHARACTER_JUNK/__module__; SequenceMatcher.quick_ratio disjoint; real_quick_ratio equal-length; get_close_matches('banana',...)."
    - "difflib_extra6.zspec.zsdl — covers Differ/HtmlDiff/SequenceMatcher __name__/__module__ extra6 anchors; function __name__ anchors; IS_LINE_JUNK/IS_CHARACTER_JUNK __name__ anchors."
    - "difflib_extra7.zspec.zsdl — covers name_attrs table; qualname_attrs table; HtmlDiff base class; SequenceMatcher ratio 5-char; get_close_matches('appel') extra7 anchor; ndiff equal-line prefix; unified_diff hunk header."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior difflib spec."
    - "difflib.IS_LINE_JUNK.__qualname__ == 'IS_LINE_JUNK' — no prior spec records this qualname."
    - "difflib.IS_CHARACTER_JUNK.__qualname__ == 'IS_CHARACTER_JUNK' — no prior spec records this qualname."
    - "difflib.IS_LINE_JUNK(' ') == True — space is junk whitespace; extra2/extra6 record __name__ but no prior standalone behavioral invariant for the space input."
    - "difflib.IS_LINE_JUNK('a') == False — 'a' is not a junk character."
    - "difflib.IS_CHARACTER_JUNK(' ') == True — space is character junk."
    - "difflib.IS_CHARACTER_JUNK('a') == False — 'a' is not character junk."
    - "difflib.Differ.__bases__[0].__name__ == 'object' — no prior spec checks the Differ base class."
    - "difflib.SequenceMatcher.mro().__len__() == 2 — [SequenceMatcher, object]; no prior spec checks SequenceMatcher MRO length."
    - "difflib.Differ.mro().__len__() == 2 — [Differ, object]; no prior spec checks Differ MRO length."
    - "difflib.context_diff.__qualname__ == 'context_diff' — covered in extra3; this is the extra8-namespace anchor."
    - "difflib.get_close_matches('wheat', ['wheel', 'whist', 'cat']) == ['whist', 'wheel'] — new word vector not in prior specs."
    - "difflib.get_close_matches('appel', ['ape', 'apple', 'peach'], n=1) == ['apple'] — n=1 limit, no prior spec uses n=1 keyword."
    - "difflib.SequenceMatcher(None, 'abc', 'xyz').ratio() == 0.0 — fully disjoint sequences; extra5 tests quick_ratio but not ratio for disjoint."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IS_LINE_JUNK and IS_CHARACTER_JUNK — __qualname__ attributes
#
# Prior specs cover __name__ and __module__ for these predicates.
# No prior spec checks __qualname__. For module-level functions, __qualname__
# equals __name__, so both values are 'IS_LINE_JUNK' and 'IS_CHARACTER_JUNK'.
# ---------------------------------------------------------------------------

invariant difflib_extra8.IS_LINE_JUNK.qualname:
  description: "difflib.IS_LINE_JUNK.__qualname__ == 'IS_LINE_JUNK' — module-level function qualname"
  category: junk_predicates
  kind: python_call_eq
  function: IS_LINE_JUNK.__qualname__.__eq__
  args: ["IS_LINE_JUNK"]
  expected: true

invariant difflib_extra8.IS_CHARACTER_JUNK.qualname:
  description: "difflib.IS_CHARACTER_JUNK.__qualname__ == 'IS_CHARACTER_JUNK' — module-level function qualname"
  category: junk_predicates
  kind: python_call_eq
  function: IS_CHARACTER_JUNK.__qualname__.__eq__
  args: ["IS_CHARACTER_JUNK"]
  expected: true

# ---------------------------------------------------------------------------
# IS_LINE_JUNK behavioral vectors — space and 'a'
#
# Prior specs record the __name__ of IS_LINE_JUNK but do not test its behavior
# as standalone invariants. IS_LINE_JUNK(' ') returns True (space is junk);
# IS_LINE_JUNK('a') returns False (alphanumeric is not junk).
# ---------------------------------------------------------------------------

invariant difflib_extra8.IS_LINE_JUNK.space_is_junk:
  description: "difflib.IS_LINE_JUNK(' ') == True — a space character is junk"
  category: junk_predicates
  kind: python_call_eq
  function: IS_LINE_JUNK
  args: [" "]
  expected: true

invariant difflib_extra8.IS_LINE_JUNK.alpha_not_junk:
  description: "difflib.IS_LINE_JUNK('a') == False — 'a' is not a junk character"
  category: junk_predicates
  kind: python_call_eq
  function: IS_LINE_JUNK
  args: ["a"]
  expected: false

# ---------------------------------------------------------------------------
# IS_CHARACTER_JUNK behavioral vectors — space and 'a'
#
# Same gap as IS_LINE_JUNK: prior specs record __name__/__module__ but no
# standalone behavioral invariant. IS_CHARACTER_JUNK(' ') == True;
# IS_CHARACTER_JUNK('a') == False.
# ---------------------------------------------------------------------------

invariant difflib_extra8.IS_CHARACTER_JUNK.space_is_junk:
  description: "difflib.IS_CHARACTER_JUNK(' ') == True — space is character junk"
  category: junk_predicates
  kind: python_call_eq
  function: IS_CHARACTER_JUNK
  args: [" "]
  expected: true

invariant difflib_extra8.IS_CHARACTER_JUNK.alpha_not_junk:
  description: "difflib.IS_CHARACTER_JUNK('a') == False — 'a' is not character junk"
  category: junk_predicates
  kind: python_call_eq
  function: IS_CHARACTER_JUNK
  args: ["a"]
  expected: false

# ---------------------------------------------------------------------------
# Differ base class
#
# difflib_extra2 checks SequenceMatcher.__bases__[0].__name__ == 'object' and
# difflib_extra7 checks HtmlDiff.__bases__[0].__name__ == 'object'.
# No prior spec checks Differ.__bases__[0].__name__. Differ is a plain Python
# class that inherits directly from object.
# ---------------------------------------------------------------------------

invariant difflib_extra8.Differ.base_class:
  description: "difflib.Differ.__bases__[0].__name__ == 'object' — Differ inherits from object"
  category: class_identity
  kind: python_call_eq
  function: Differ.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher and Differ MRO lengths
#
# No prior spec checks mro().__len__() for SequenceMatcher or Differ.
# Both inherit only from object, so their MRO has 2 entries.
# ---------------------------------------------------------------------------

invariant difflib_extra8.SequenceMatcher.mro_len:
  description: "difflib.SequenceMatcher.mro().__len__() == 2 — [SequenceMatcher, object]"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.mro
  args: []
  method: __len__
  expected: 2

invariant difflib_extra8.Differ.mro_len:
  description: "difflib.Differ.mro().__len__() == 2 — [Differ, object]"
  category: class_identity
  kind: python_call_eq
  function: Differ.mro
  args: []
  method: __len__
  expected: 2

# ---------------------------------------------------------------------------
# context_diff.__qualname__ — extra8-namespace anchor
#
# difflib_extra3 covers context_diff.__qualname__ == 'context_diff' in the
# extra3 namespace. This is the extra8-namespace standalone anchor.
# ---------------------------------------------------------------------------

invariant difflib_extra8.context_diff.qualname:
  description: "difflib.context_diff.__qualname__ == 'context_diff' — extra8-namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__qualname__.__eq__
  args: ["context_diff"]
  expected: true

# ---------------------------------------------------------------------------
# get_close_matches — new word and n=1 keyword argument
#
# difflib_extra3/extra5/extra7 cover get_close_matches with 'appel' and 'banana'.
# No prior spec covers 'wheat' as the word or the n=1 keyword argument.
# get_close_matches('wheat', ['wheel','whist','cat']) == ['whist', 'wheel']
# get_close_matches('appel', ['ape','apple','peach'], n=1) == ['apple']
# ---------------------------------------------------------------------------

invariant difflib_extra8.get_close_matches.wheat:
  description: "difflib.get_close_matches('wheat', ['wheel','whist','cat']) == ['whist', 'wheel']"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["wheat", ["wheel", "whist", "cat"]]
  expected: ["whist", "wheel"]

invariant difflib_extra8.get_close_matches.n_one:
  description: "difflib.get_close_matches('appel', ['ape','apple','peach'], n=1) == ['apple'] — n=1 limit"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["appel", ["ape", "apple", "peach"]]
  kwargs: {n: 1}
  expected: ["apple"]

# ---------------------------------------------------------------------------
# SequenceMatcher.ratio — fully disjoint sequences
#
# difflib_extra2/extra7 cover ratio for identical sequences (ratio == 1.0).
# difflib_extra5 covers quick_ratio for disjoint ('abc'/'xyz') but not ratio.
# SequenceMatcher(None, 'abc', 'xyz').ratio() == 0.0 because no characters match.
# ---------------------------------------------------------------------------

invariant difflib_extra8.SequenceMatcher.ratio_disjoint:
  description: "difflib.SequenceMatcher(None,'abc','xyz').ratio() == 0.0 — fully disjoint sequences"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abc", "xyz"]
  method: ratio.__eq__
  method_args: [0.0]
  expected: true
