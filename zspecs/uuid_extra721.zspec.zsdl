spec: uuid_extra721
version: ">=3.9"
backend: python_module(uuid)
docs: "Behavioral spec covering uuid.UUID property qualnames"
error_model: python_exceptions

provenance:
  derived_from: "uuid stdlib documentation and CPython source"
  not_derived_from: "any third-party uuid extension"
  notes: "UUID property descriptors are defined in pure Python; qualnames reflect class-scoped descriptor names"
  created_at: "2026-04-12"

table uuid_extra721.uuid_property_qualnames:
  description: "uuid.UUID property qualnames"
  kind: python_call_eq
  category: qualname
  id_prefix: uu721qn
  columns: [id, function, args, expected]
  rows:
    - [uu721qn001, uuid.UUID.bytes.__qualname__.__eq__, ["UUID.bytes"], true]
    - [uu721qn002, uuid.UUID.bytes_le.__qualname__.__eq__, ["UUID.bytes_le"], true]
    - [uu721qn003, uuid.UUID.fields.__qualname__.__eq__, ["UUID.fields"], true]
    - [uu721qn004, uuid.UUID.time_low.__qualname__.__eq__, ["UUID.time_low"], true]
    - [uu721qn005, uuid.UUID.time_mid.__qualname__.__eq__, ["UUID.time_mid"], true]
    - [uu721qn006, uuid.UUID.time_hi_version.__qualname__.__eq__, ["UUID.time_hi_version"], true]
    - [uu721qn007, uuid.UUID.clock_seq_hi_variant.__qualname__.__eq__, ["UUID.clock_seq_hi_variant"], true]
    - [uu721qn008, uuid.UUID.clock_seq_low.__qualname__.__eq__, ["UUID.clock_seq_low"], true]
    - [uu721qn009, uuid.UUID.node.__qualname__.__eq__, ["UUID.node"], true]
    - [uu721qn010, uuid.UUID.time.__qualname__.__eq__, ["UUID.time"], true]
    - [uu721qn011, uuid.UUID.clock_seq.__qualname__.__eq__, ["UUID.clock_seq"], true]
    - [uu721qn012, uuid.UUID.version.__qualname__.__eq__, ["UUID.version"], true]
