spec: struct_extra130
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra129.zspec.zsdl — covers struct module-level function __name__/__qualname__/__module__/__class__.__name__ for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra128.zspec.zsdl — covers Struct.__init__ wrapper_descriptor identity / Struct.pack/unpack/pack_into/unpack_from __qualname__ equality / Struct method __class__.__name__=='method_descriptor' / Struct method __name__ equality (table + invariants)."
    - "struct_extra127.zspec.zsdl — covers Struct.__reduce__/__reduce_ex__ identity / Struct.__sizeof__ class name and qualname / Struct.__doc__ equality and length / Struct.size and format __objclass__.__name__ and __module__ equality (table + invariants)."
    - "struct_extra126.zspec.zsdl — covers Struct.__init__/__repr__/__sizeof__/__reduce_ex__ qualname string equality / Struct.__new__.__qualname__ equality / Struct.__class__.__name__=='type' (table + invariants)."
    - "struct_extra125.zspec.zsdl — covers struct.__all__ list class name and length / Struct method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra124.zspec.zsdl — covers Struct.__dict__.__contains__ for dunder names (table + invariants)."
    - "struct_extra123.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __objclass__.__module__ and __objclass__.__qualname__ equality (table + invariants)."
    - "struct_extra122.zspec.zsdl — covers struct.error/__name__/__qualname__/__module__/__bases__[0].__name__/__mro__.__len__()==4/__class__.__name__ equality / Struct/__name__/__qualname__/__class__.__name__/Struct.size/format/__name__ equality (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.__module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 351 theme: struct.error MRO chain __name__ entries (indexed) / struct.Struct.__mro__[1].__name__ ('object') / struct.Struct.iter_unpack method identity (__qualname__/__name__/__class__.__name__/__objclass__) / struct.Struct.__new__ identity (__name__/__qualname__/__class__.__name__)."
    - "struct.error.__mro__[1].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[2].__name__ == 'BaseException'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[3].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__[1].__name__ == 'object'. Struct has a minimal 2-entry MRO: (Struct, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__new__.__name__ == '__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__new__.__qualname__ == 'Struct.__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__new__.__class__.__name__ == 'builtin_function_or_method'. Struct.__new__ is a C builtin, unlike Struct.__init__ which is a wrapper_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra128 covers Struct.pack/unpack/pack_into/unpack_from __qualname__ but NOT iter_unpack __qualname__. This spec is the first to anchor Struct.iter_unpack __qualname__ equality under structmro130."
    - "Note: extra122 anchors error.__mro__.__len__()==4 and error.__bases__[0].__name__=='Exception'. This spec is the first to anchor the individual MRO chain entries via indexed access (__mro__[1]/__mro__[2]/__mro__[3].__name__) under structmro130."
    - "Note: extra126 covers Struct.__new__.__qualname__ equality at table level. This spec cross-checks Struct.__new__ __name__/__class__.__name__ under structmro130."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__mro__[1].__name__.__eq__('Exception')
# struct.error.__mro__[2].__name__.__eq__('BaseException')
# struct.error.__mro__[3].__name__.__eq__('object')
# struct.Struct.__mro__[1].__name__.__eq__('object')
# struct.error.__mro__[0].__name__.__eq__('error')
#
# Wave 351 theme: struct.error and struct.Struct MRO chain entry names.
#
# struct.error.__mro__ is (struct.error, Exception, BaseException, object).
# Each entry's __name__ can be verified via indexed access: __mro__[1].__name__
# == 'Exception', __mro__[2].__name__ == 'BaseException', __mro__[3].__name__
# == 'object'. struct.Struct has a minimal MRO of just (Struct, object), so
# __mro__[1].__name__ == 'object'. struct_extra122 anchors error.__mro__.__len__()
# == 4 and error.__bases__[0].__name__ == 'Exception'; this spec is the first
# to anchor the individual indexed MRO entries under structmro130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra130.error_mro_chain_entries:
  description: "struct.error/__mro__[0]/__name__.__eq__('error')==True / __mro__[1]/__name__.__eq__('Exception')==True / __mro__[2]/__name__.__eq__('BaseException')==True / __mro__[3]/__name__.__eq__('object')==True / Struct/__mro__[1]/__name__.__eq__('object')==True — error MRO chain: (error, Exception, BaseException, object); Struct MRO: (Struct, object); extra122 anchors __mro__.__len__() and __bases__; first structmro130 anchor for indexed MRO entry names"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmro130

  columns: [id, function, args, expected, description]
  rows:
    - [error_mro0,  "error.__mro__[0].__name__.__eq__",   ["error"],         true, "error.__mro__[0].__name__ is 'error' (struct.error itself; first in MRO)"]
    - [error_mro1,  "error.__mro__[1].__name__.__eq__",   ["Exception"],     true, "error.__mro__[1].__name__ is 'Exception' (direct base class)"]
    - [error_mro2,  "error.__mro__[2].__name__.__eq__",   ["BaseException"], true, "error.__mro__[2].__name__ is 'BaseException' (grandparent; two levels above object)"]
    - [error_mro3,  "error.__mro__[3].__name__.__eq__",   ["object"],        true, "error.__mro__[3].__name__ is 'object' (root of Python class hierarchy)"]
    - [struct_mro1, "Struct.__mro__[1].__name__.__eq__",  ["object"],        true, "Struct.__mro__[1].__name__ is 'object' (Struct has minimal 2-entry MRO: Struct, object)"]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')
# struct.Struct.iter_unpack.__name__.__eq__('iter_unpack')
# struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.iter_unpack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.iter_unpack.__objclass__.__module__.__eq__('_struct')
#
# Wave 351 theme: struct.Struct.iter_unpack method descriptor identity.
#
# struct.Struct.iter_unpack is a method_descriptor that creates an iterator
# yielding successive fixed-size records from a buffer. Unlike the module-level
# struct.iter_unpack (a builtin_function_or_method with __qualname__=='iter_unpack'),
# the Struct instance method has __qualname__=='Struct.iter_unpack'. Its
# __objclass__ is the Struct C type from the _struct extension. struct_extra128
# covers Struct.pack/unpack/pack_into/unpack_from __qualname__ but not
# iter_unpack. struct_extra123 covers pack/unpack/etc. __objclass__.__module__
# but not iter_unpack. This spec is the first to anchor iter_unpack method
# identity under structmro130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra130.Struct_iter_unpack_identity:
  description: "struct.Struct.iter_unpack/__qualname__.__eq__('Struct.iter_unpack')==True / iter_unpack/__name__.__eq__('iter_unpack')==True / iter_unpack/__class__.__name__.__eq__('method_descriptor')==True / iter_unpack/__objclass__/__name__.__eq__('Struct')==True / iter_unpack/__objclass__/__module__.__eq__('_struct')==True — Struct.iter_unpack is a method_descriptor distinct from module-level iter_unpack (builtin_function_or_method); extra128 covers pack/unpack/etc. but not iter_unpack qualname; first structmro130 anchor for iter_unpack method identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmro130

  columns: [id, function, args, expected, description]
  rows:
    - [iu_qualname,   Struct.iter_unpack.__qualname__.__eq__,              ["Struct.iter_unpack"], true, "Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (has class prefix; distinct from module-level 'iter_unpack')"]
    - [iu_name,       Struct.iter_unpack.__name__.__eq__,                   ["iter_unpack"],        true, "Struct.iter_unpack.__name__ is 'iter_unpack' (short name without class prefix)"]
    - [iu_class,      Struct.iter_unpack.__class__.__name__.__eq__,         ["method_descriptor"],  true, "Struct.iter_unpack.__class__.__name__ is 'method_descriptor' (C method bound to Struct type)"]
    - [iu_objclass,   Struct.iter_unpack.__objclass__.__name__.__eq__,      ["Struct"],             true, "Struct.iter_unpack.__objclass__.__name__ is 'Struct' (the owning C extension type)"]
    - [iu_objmodule,  Struct.iter_unpack.__objclass__.__module__.__eq__,    ["_struct"],            true, "Struct.iter_unpack.__objclass__.__module__ is '_struct' (the C extension origin)"]

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__name__.__eq__('__new__')
# struct.Struct.__new__.__qualname__.__eq__('Struct.__new__')
# struct.Struct.__new__.__class__.__name__.__eq__('builtin_function_or_method')
# struct.error.__mro__[1].__name__.__eq__('Exception')
# struct.error.__mro__[2].__name__.__eq__('BaseException')
#
# Wave 351 theme: struct.Struct.__new__ identity cross-check.
#
# struct.Struct.__new__ is a C-level allocation function (builtin_function_or_method),
# unlike struct.Struct.__init__ which is a wrapper_descriptor. __new__ is
# responsible for allocating the Struct instance, while __init__ (via the
# wrapper_descriptor mechanism) initializes it with the format string. The
# __qualname__ of __new__ is 'Struct.__new__' (with class prefix), matching
# the pattern of other Struct methods. extra126 anchors __new__.__qualname__
# equality at table level; this spec cross-checks __new__.__name__ and
# __class__.__name__ under structmro130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra130.Struct_new_identity:
  description: "struct.Struct.__new__/__name__.__eq__('__new__')==True / __new__/__qualname__.__eq__('Struct.__new__')==True / __new__/__class__.__name__.__eq__('builtin_function_or_method')==True / error/__mro__[1]/__name__.__eq__('Exception')==True / error/__mro__[2]/__name__.__eq__('BaseException')==True — Struct.__new__ is a C builtin (unlike __init__ which is wrapper_descriptor); extra126 anchors __new__.__qualname__; extra128 anchors __init__ class name; first structmro130 anchor for __new__.__name__ and __class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmro130

  columns: [id, function, args, expected, description]
  rows:
    - [new_name,     Struct.__new__.__name__.__eq__,               ["__new__"],                   true, "Struct.__new__.__name__ is '__new__' (dunder name without class prefix)"]
    - [new_qualname, Struct.__new__.__qualname__.__eq__,            ["Struct.__new__"],             true, "Struct.__new__.__qualname__ is 'Struct.__new__' (with class prefix; cross-check extra126)"]
    - [new_class,    Struct.__new__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "Struct.__new__.__class__.__name__ is 'builtin_function_or_method' (C builtin, unlike __init__ wrapper_descriptor)"]
    - [err_mro1,     "error.__mro__[1].__name__.__eq__",            ["Exception"],                 true, "error.__mro__[1].__name__ is 'Exception' (cross-check; extra122 anchors __bases__[0].__name__)"]
    - [err_mro2,     "error.__mro__[2].__name__.__eq__",            ["BaseException"],             true, "error.__mro__[2].__name__ is 'BaseException' (grandparent class in MRO chain)"]

# ---------------------------------------------------------------------------
# struct.error.__mro__[1].__name__.__eq__('Exception') — standalone
#
# struct.error.__mro__[1].__name__ is 'Exception'. The MRO (Method Resolution
# Order) for struct.error is (struct.error, Exception, BaseException, object).
# Index 1 is the direct base class Exception. struct_extra122 anchors
# error.__bases__[0].__name__ == 'Exception' at table level and as a standalone;
# this spec provides an alternative access path via the indexed MRO rather than
# __bases__. The MRO and __bases__ agree here because struct.error has only one
# direct base. First standalone for error.__mro__[1].__name__.__eq__('Exception')
# under structmro130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra130.error_mro1_Exception:
  description: "struct.error.__mro__[1].__name__.__eq__('Exception') == True — error.__mro__[1] is Exception (the direct base; single-inheritance so MRO[1]==__bases__[0]); alternative access path vs extra122 __bases__[0].__name__ == 'Exception'; first standalone for error.__mro__[1].__name__.__eq__ under structmro130"
  category: type_identity
  kind: python_call_eq
  function: "error.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__mro__[1].__name__.__eq__('object') — standalone
#
# struct.Struct.__mro__[1].__name__ is 'object'. struct.Struct is a C extension
# type that directly subclasses object (no intermediate Python-level base). Its
# MRO is (Struct, object) — just 2 entries. struct_extra93 anchors
# Struct.__mro__.__len__()==2 and Struct.__bases__ at table level. This spec
# is the first to anchor the indexed access Struct.__mro__[1].__name__ == 'object'
# as a standalone under structmro130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra130.Struct_mro1_object:
  description: "struct.Struct.__mro__[1].__name__.__eq__('object') == True — Struct.__mro__[1] is object (Struct directly subclasses object with no intermediate base; 2-entry MRO); extra93 anchors Struct.__mro__.__len__()==2; first standalone for Struct.__mro__[1].__name__.__eq__ under structmro130"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') — standalone
#
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack'. The iter_unpack
# method creates an iterator that yields successive fixed-size records from a
# buffer by repeatedly applying the same format — useful for parsing binary
# data streams without creating a list of all results first. Its __qualname__
# has the 'Struct.' prefix because it is a method bound to the Struct class.
# struct_extra128 covers pack/unpack/pack_into/unpack_from __qualname__ but not
# iter_unpack. This is the first standalone for Struct.iter_unpack.__qualname__
# equality under structmro130. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra130.iter_unpack_method_qualname:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — Struct.iter_unpack.__qualname__ has class prefix 'Struct.'; yields fixed-size records as iterator; extra128 covers pack/unpack/etc. qualnames but not iter_unpack; first standalone for Struct.iter_unpack.__qualname__.__eq__ under structmro130"
  category: type_identity
  kind: python_call_eq
  function: Struct.iter_unpack.__qualname__.__eq__
  args: ["Struct.iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__name__.__eq__('__new__') — standalone
#
# struct.Struct.__new__.__name__ is '__new__'. Struct.__new__ is a C-level
# object allocator (builtin_function_or_method). The distinction between
# __new__ and __init__ in C extension types is significant: __new__ allocates
# the object memory (wrapped as a builtin_function_or_method), while __init__
# validates and sets the format string (wrapped as a wrapper_descriptor because
# Struct.__init__ wraps the C-level tp_init slot via PyMemberDef). struct_extra126
# anchors __new__.__qualname__=='Struct.__new__'; this is the first standalone
# for __new__.__name__.__eq__('__new__') under structmro130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra130.Struct_new_name:
  description: "struct.Struct.__new__.__name__.__eq__('__new__') == True — Struct.__new__ is a C-level allocator (builtin_function_or_method) distinct from __init__ (wrapper_descriptor); __name__ is '__new__' without class prefix; extra126 anchors __new__.__qualname__; first standalone for Struct.__new__.__name__.__eq__ under structmro130"
  category: type_identity
  kind: python_call_eq
  function: Struct.__new__.__name__.__eq__
  args: ["__new__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.iter_unpack.__class__.__name__ is 'method_descriptor'. All five
# Struct bound methods (pack, unpack, pack_into, unpack_from, iter_unpack) are
# method_descriptor objects — C methods bound to the Struct type via the
# PyMethodDescrObject mechanism. struct_extra128 anchors
# Struct.pack/unpack/pack_into/unpack_from __class__.__name__=='method_descriptor'
# at table level; this is the first standalone for iter_unpack.__class__.__name__
# == 'method_descriptor' under structmro130.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra130.iter_unpack_method_descriptor:
  description: "struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor') == True — all five Struct bound methods including iter_unpack are method_descriptor (PyMethodDescrObject); extra128 anchors pack/unpack/pack_into/unpack_from class names; first standalone for iter_unpack.__class__.__name__.__eq__ under structmro130"
  category: type_identity
  kind: python_call_eq
  function: Struct.iter_unpack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
