spec: uuid_extra95
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra94

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra94.zspec.zsdl — covers uuid.UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' / uuid3/uuid5/getnode __qualname__.__len__() / SafeUUID.__class__.__name__=='EnumType' / SafeUUID.__module__=='uuid' / SafeUUID.__mro__.__len__()==3 (table + invariants)."
    - "uuid_extra93.zspec.zsdl — covers uuid.__name__/__spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__ lengths / __spec__.has_location / UUID/__module__/__len__()==7 / uuid1/uuid4/__module__/__len__()==4 (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers uuid.UUID property fget.__code__.co_name equality / fget.__code__.co_argcount==1 / co_name.__len__() values (table + invariants)."
    - "uuid_extra91.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__/__int__ __qualname__.__len__() / uuid1/uuid4 __qualname__.__len__() (table + invariants)."
    - "uuid_extra90.zspec.zsdl — covers NAMESPACE_URL/OID/X500 class names / NAMESPACE_* version==1 / RFC_4122/RESERVED_* class names and __len__() / UUID.__class__.__name__=='type' (table + invariants)."
    - "uuid_extra89.zspec.zsdl — covers UUID method __module__.__eq__('uuid') / UUID.fields.fget class/qualname / getnode/__code__.co_name / uuid5.__module__ (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra94; it does NOT duplicate invariants present in those files."
    - "Wave 266 theme: uuid.SafeUUID member values / SafeUUID.__name__ equality and length / SafeUUID.__bases__[0].__name__ / UUID property fget __qualname__ lengths."
    - "uuid.SafeUUID.safe.value == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.value == -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unknown.value == None. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__.__eq__('SafeUUID') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' (len 10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: SafeUUID has three members: safe (value=0), unsafe (value=-1), unknown (value=None). 'safe' indicates multiprocessing-safe UUID generation; 'unsafe' indicates not safe; 'unknown' means safety is unknown."
    - "Note: SafeUUID.__bases__[0].__name__ is 'Enum' (not 'int'): SafeUUID inherits from Enum, not IntEnum. The MRO (SafeUUID, Enum, object) confirms depth 3."
    - "Note: UUID property fget qualnames include the 'UUID.' class prefix: hex=8, urn=8, bytes=10, fields=11, variant=12, version=12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.value == 0
# uuid.SafeUUID.unsafe.value == -1
# uuid.SafeUUID.__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__qualname__.__eq__('SafeUUID')
# uuid.SafeUUID.__name__.__len__()==8
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum')
#
# Wave 266 theme: SafeUUID member values and class identity attributes.
#
# SafeUUID is a Python enum indicating whether a UUID was generated in a way
# that is safe for concurrent use. It has three members: safe (value=0),
# unsafe (value=-1), and unknown (value=None). uuid_extra94 anchors
# SafeUUID.__class__.__name__=='EnumType', SafeUUID.__module__=='uuid', and
# SafeUUID.__mro__.__len__()==3. No prior uuid spec anchors SafeUUID member
# values, __name__/__qualname__ equality, __name__.__len__(), or
# __bases__[0].__name__ under uuidsafe95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra95.SafeUUID_members_and_identity:
  description: "uuid.SafeUUID/safe/value==0 / SafeUUID/unsafe/value==-1 / SafeUUID/__name__.__eq__('SafeUUID')==True / SafeUUID/__qualname__.__eq__('SafeUUID')==True / SafeUUID/__name__/__len__()==8 / SafeUUID/__bases__[0]/__name__.__eq__('Enum')==True — SafeUUID has three members: safe=0 (multiprocessing-safe), unsafe=-1 (not safe), unknown=None; inherits from Enum (not IntEnum); extra94 anchors metaclass/module/MRO depth; first uuidsafe95 anchor for SafeUUID member values and name identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidsafe95

  columns: [id, function, args, expected, description]
  rows:
    - [safe_value,       "SafeUUID.safe.value.__eq__",            [0],          true, "SafeUUID.safe.value is 0: indicates multiprocessing-safe UUID generation"]
    - [unsafe_value,     "SafeUUID.unsafe.value.__eq__",          [-1],         true, "SafeUUID.unsafe.value is -1: indicates not multiprocessing-safe"]
    - [name_eq,          "SafeUUID.__name__.__eq__",              ["SafeUUID"], true, "SafeUUID.__name__ is 'SafeUUID' (the enum class name)"]
    - [qualname_eq,      "SafeUUID.__qualname__.__eq__",          ["SafeUUID"], true, "SafeUUID.__qualname__ is 'SafeUUID' (no enclosing scope prefix)"]
    - [name_len,         SafeUUID.__name__.__len__,               [], 8,        "'SafeUUID' is 8 chars"]
    - [bases_enum,       "SafeUUID.__bases__[0].__name__.__eq__", ["Enum"],     true, "SafeUUID's direct base is Enum (not IntEnum or int); MRO is (SafeUUID, Enum, object)"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__len__()==8
# uuid.UUID.bytes.fget.__qualname__.__len__()==10
# uuid.UUID.urn.fget.__qualname__.__len__()==8
# uuid.UUID.fields.fget.__qualname__.__len__()==11
#
# Wave 266 theme: UUID property fget __qualname__ lengths (group A).
#
# UUID defines multiple properties using the @property decorator. Each property's
# fget function has a __qualname__ of the form 'UUID.<propname>'. hex.fget has
# __qualname__ 'UUID.hex' (8 chars = 'UUID.' 5 + 'hex' 3). bytes.fget has
# __qualname__ 'UUID.bytes' (10 chars = 'UUID.' 5 + 'bytes' 5). urn.fget has
# __qualname__ 'UUID.urn' (8 chars). fields.fget has __qualname__ 'UUID.fields'
# (11 chars). uuid_extra92 anchors fget __code__.co_name values; uuid_extra89
# anchors fget class name. No prior spec anchors fget __qualname__.__len__()
# under uuidsafe95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra95.UUID_property_fget_qualname_lengths_A:
  description: "uuid.UUID.hex/fget/__qualname__/__len__()==8 / UUID.bytes/fget/__qualname__/__len__()==10 / UUID.urn/fget/__qualname__/__len__()==8 / UUID.fields/fget/__qualname__/__len__()==11 — hex.fget qualname is 'UUID.hex' (8); bytes.fget is 'UUID.bytes' (10); urn.fget is 'UUID.urn' (8); fields.fget is 'UUID.fields' (11); extra92 anchors co_name; extra89 anchors fget class name; first uuidsafe95 anchor for property fget qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidsafe95

  columns: [id, function, args, expected, description]
  rows:
    - [hex_fget_qlen,    "UUID.hex.fget.__qualname__.__len__",    [], 8,  "'UUID.hex' is 8 chars ('UUID.' 5 + 'hex' 3)"]
    - [bytes_fget_qlen,  "UUID.bytes.fget.__qualname__.__len__",  [], 10, "'UUID.bytes' is 10 chars ('UUID.' 5 + 'bytes' 5)"]
    - [urn_fget_qlen,    "UUID.urn.fget.__qualname__.__len__",    [], 8,  "'UUID.urn' is 8 chars ('UUID.' 5 + 'urn' 3)"]
    - [fields_fget_qlen, "UUID.fields.fget.__qualname__.__len__", [], 11, "'UUID.fields' is 11 chars ('UUID.' 5 + 'fields' 6)"]

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__qualname__.__len__()==12
# uuid.UUID.version.fget.__qualname__.__len__()==12
#
# Wave 266 theme: UUID property fget __qualname__ lengths (group B).
#
# uuid.UUID.variant.fget has __qualname__ 'UUID.variant' (12 chars = 'UUID.' 5 +
# 'variant' 7). uuid.UUID.version.fget has __qualname__ 'UUID.version' (12 chars =
# 'UUID.' 5 + 'version' 7). Both are pure-Python fget functions (class 'function').
# variant identifies whether the UUID follows RFC 4122 or another variant;
# version gives the UUID version number (1-5) for RFC 4122 UUIDs. No prior uuid
# spec anchors variant.fget or version.fget __qualname__.__len__() under uuidsafe95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra95.UUID_property_fget_qualname_lengths_B:
  description: "uuid.UUID.variant/fget/__qualname__/__len__()==12 / UUID.version/fget/__qualname__/__len__()==12 — variant.fget is 'UUID.variant' (12 chars); version.fget is 'UUID.version' (12 chars); both property fget functions (class 'function') in Lib/uuid.py; extra89 anchors fget class name; first uuidsafe95 anchor for variant/version fget qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidsafe95

  columns: [id, function, args, expected, description]
  rows:
    - [variant_fget_qlen, "UUID.variant.fget.__qualname__.__len__", [], 12, "'UUID.variant' is 12 chars ('UUID.' 5 + 'variant' 7); identifies RFC 4122 vs other variants"]
    - [version_fget_qlen, "UUID.version.fget.__qualname__.__len__", [], 12, "'UUID.version' is 12 chars ('UUID.' 5 + 'version' 7); gives UUID version (1-5) for RFC 4122"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.value.__eq__(0) — standalone
#
# uuid.SafeUUID.safe.value is 0. SafeUUID.safe indicates that the UUID was
# generated using a method that is safe for concurrent use (e.g., via os.urandom
# or an equivalent that does not rely on shared state). The value 0 is the
# integer representation of the 'safe' member. SafeUUID inherits from Enum (not
# IntEnum), so SafeUUID.safe is an enum member, but its value attribute gives
# the raw Python int. No prior uuid spec anchors SafeUUID.safe.value as a
# standalone under uuidsafe95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra95.SafeUUID_safe_value_0:
  description: "uuid.SafeUUID.safe.value.__eq__(0) == True — SafeUUID.safe.value is 0; indicates UUID generation was multiprocessing-safe (via os.urandom or similar); SafeUUID inherits from Enum so .value gives the raw Python int; no prior uuid spec anchors SafeUUID.safe.value as a standalone; first standalone under uuidsafe95"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.safe.value.__eq__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.unsafe.value.__eq__(-1) — standalone
#
# uuid.SafeUUID.unsafe.value is -1. SafeUUID.unsafe indicates that the UUID was
# generated using a method that is NOT safe for concurrent use (e.g., using the
# MAC address combined with the current time without locking). The value -1
# is the integer representation of the 'unsafe' member. No prior uuid spec
# anchors SafeUUID.unsafe.value as a standalone under uuidsafe95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra95.SafeUUID_unsafe_value_neg1:
  description: "uuid.SafeUUID.unsafe.value.__eq__(-1) == True — SafeUUID.unsafe.value is -1; indicates UUID generation was NOT multiprocessing-safe (e.g., MAC+time without locking); SafeUUID inherits from Enum so .value gives the raw Python int; no prior uuid spec anchors SafeUUID.unsafe.value as a standalone; first standalone under uuidsafe95"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.unsafe.value.__eq__"
  args: [-1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') — standalone
#
# uuid.SafeUUID.__bases__[0].__name__ is 'Enum'. SafeUUID inherits directly from
# Enum (not from IntEnum, despite storing integer values). The choice of Enum
# over IntEnum means SafeUUID members are not automatically interchangeable with
# plain integers. The MRO is (SafeUUID, Enum, object), giving depth 3. uuid_extra94
# anchors SafeUUID.__mro__.__len__()==3 and SafeUUID.__class__.__name__=='EnumType';
# no prior spec anchors SafeUUID.__bases__[0].__name__ as a standalone under
# uuidsafe95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra95.SafeUUID_bases_Enum:
  description: "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID's direct base is Enum (not IntEnum); members are not auto-interchangeable with plain ints; MRO is (SafeUUID, Enum, object) depth 3; extra94 anchors MRO depth and metaclass; first standalone for SafeUUID.__bases__[0].__name__ under uuidsafe95"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__len__()==8 — standalone
#
# uuid.UUID.hex.fget.__qualname__.__len__() is 8. hex.fget.__qualname__ is
# 'UUID.hex' (8 chars = 'UUID.' 5 + 'hex' 3). The hex property returns a
# 32-character lowercase hexadecimal string representation of the UUID value
# (e.g., '12345678123412341234123456789abc'). The fget function is a pure-Python
# function defined in Lib/uuid.py. uuid_extra92 anchors hex.fget.__code__.co_name;
# uuid_extra89 anchors fget class name; no prior spec anchors hex.fget
# __qualname__.__len__() as a standalone under uuidsafe95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra95.UUID_hex_fget_qualname_len_8:
  description: "uuid.UUID.hex.fget.__qualname__.__len__() == 8 — hex.fget.__qualname__ is 'UUID.hex' (8 chars = 'UUID.' 5 + 'hex' 3); hex property returns 32-char lowercase hex string of UUID value; fget is a pure-Python function in Lib/uuid.py; extra92 anchors co_name; extra89 anchors fget class name; first standalone for UUID.hex.fget qualname length under uuidsafe95"
  category: qualname_lengths
  kind: python_call_eq
  function: "UUID.hex.fget.__qualname__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__qualname__.__len__()==12 — standalone
#
# uuid.UUID.variant.fget.__qualname__.__len__() is 12. variant.fget.__qualname__
# is 'UUID.variant' (12 chars = 'UUID.' 5 + 'variant' 7). The variant property
# identifies which UUID variant the UUID belongs to: RFC_4122, RESERVED_NCS,
# RESERVED_MICROSOFT, or RESERVED_FUTURE. It is the longest of the UUID property
# fget qualnames along with version (also 12 chars). No prior uuid spec anchors
# UUID.variant.fget.__qualname__.__len__() as a standalone under uuidsafe95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra95.UUID_variant_fget_qualname_len_12:
  description: "uuid.UUID.variant.fget.__qualname__.__len__() == 12 — variant.fget.__qualname__ is 'UUID.variant' (12 chars = 'UUID.' 5 + 'variant' 7); longest UUID property fget qualname (tied with version at 12); variant property identifies UUID variant (RFC_4122, RESERVED_NCS, etc.); no prior uuid spec anchors this length as a standalone; first standalone under uuidsafe95"
  category: qualname_lengths
  kind: python_call_eq
  function: "UUID.variant.fget.__qualname__.__len__"
  args: []
  expected: 12
