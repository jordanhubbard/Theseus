spec: inspect_extra167
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Signature.__name__ 'Signature'; inspect.Signature.__module__ 'inspect'; inspect.Signature.__bases__[0].__name__ 'object'; inspect.BoundArguments.__name__ 'BoundArguments'; inspect.BoundArguments.__module__ 'inspect'; inspect.BoundArguments.__bases__[0].__name__ 'object'; inspect.FullArgSpec.__name__ 'FullArgSpec'; inspect.FullArgSpec.__bases__[0].__name__ 'tuple' (Wave 296)."
    - "inspect.Signature.__name__ == 'Signature' — inspect.Signature is a Python class defined in Lib/inspect.py representing the call signature of a callable; its class __name__ is 'Signature'. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — Signature is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — inspect.Signature inherits directly from object (it is a regular Python class, not a subclass of any other class). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' — inspect.BoundArguments is a Python class defined in Lib/inspect.py representing arguments bound to a function signature; its class __name__ is 'BoundArguments'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — inspect.BoundArguments inherits directly from object. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec' — inspect.FullArgSpec is a namedtuple type created by collections.namedtuple in Lib/inspect.py; its type __name__ is 'FullArgSpec'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple, which means it is a subclass of tuple; its __bases__[0].__name__ is 'tuple' (not 'object'). This distinguishes it from Signature and BoundArguments. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature class identity — __name__, __module__, __bases__
#
# Wave 296 theme: inspect.Signature Python class identity — __name__,
# __module__, __bases__[0], and __class__.__name__.
#
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__bases__[0].__name__ == 'object'
# inspect.Signature.__class__.__name__ == 'type'
#
# inspect.Signature is a Python class defined in Lib/inspect.py. It represents
# the call signature of a callable object, including parameters (as an
# OrderedDict of Parameter objects) and an optional return annotation. It is
# returned by inspect.signature(). It inherits directly from object (not from
# any other inspect class). New to extra167.
# ---------------------------------------------------------------------------

table inspect_extra167.signature_class_identity:
  description: "inspect.Signature: __name__ 'Signature', __module__ 'inspect', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsci167

  columns: [id, function, args, expected, description]
  rows:
    - [sig_name_signature,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — inspect.Signature is a Python class defined in Lib/inspect.py representing the call signature of a callable (with parameters and return annotation); its class __name__ attribute is 'Signature'; str.__eq__('Signature') returns True; new to extra167"]
    - [sig_module_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — inspect.Signature is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra167"]
    - ["sig_bases_0_object",
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — inspect.Signature is a Python class that inherits directly from object (not from any other inspect class); its __bases__ tuple has one element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [sig_class_name_type,
       "Signature.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — inspect.Signature is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments class identity — __name__, __module__, __bases__
#
# Wave 296 theme: inspect.BoundArguments Python class identity — __name__,
# __module__, __bases__[0], and __class__.__name__.
#
# inspect.BoundArguments.__name__ == 'BoundArguments'
# inspect.BoundArguments.__module__ == 'inspect'
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
# inspect.BoundArguments.__class__.__name__ == 'type'
#
# inspect.BoundArguments is a Python class defined in Lib/inspect.py. It is
# returned by Signature.bind() and Signature.bind_partial() and represents
# arguments bound to the function's signature. It stores the mapping of
# parameter names to argument values and supports apply_defaults() to fill
# in default values. It inherits directly from object. New to extra167.
# ---------------------------------------------------------------------------

table inspect_extra167.bound_arguments_class_identity:
  description: "inspect.BoundArguments: __name__ 'BoundArguments', __module__ 'inspect', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: inspectbaci167

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_bound_arguments,
       "BoundArguments.__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — inspect.BoundArguments is a Python class defined in Lib/inspect.py representing arguments bound to a Signature (returned by Signature.bind()); its class __name__ attribute is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra167"]
    - [ba_module_inspect,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — inspect.BoundArguments is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra167"]
    - ["ba_bases_0_object",
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — inspect.BoundArguments is a Python class that inherits directly from object; its __bases__ tuple has one element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [ba_class_name_type,
       "BoundArguments.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — inspect.BoundArguments is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FullArgSpec namedtuple identity — __name__ and __bases__
#
# Wave 296 theme: inspect.FullArgSpec namedtuple identity — __name__,
# __bases__[0].__name__, __module__, and __class__.__name__.
#
# inspect.FullArgSpec.__name__ == 'FullArgSpec'
# inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'
# inspect.FullArgSpec.__module__ == 'inspect'
# inspect.FullArgSpec.__class__.__name__ == 'type'
#
# inspect.FullArgSpec is a namedtuple created by collections.namedtuple in
# Lib/inspect.py. As a namedtuple, its immediate base class is 'tuple' (not
# 'object'); this distinguishes it from inspect.Signature and BoundArguments
# which inherit directly from object. It is returned by inspect.getfullargspec()
# and has seven fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults,
# annotations. New to extra167.
# ---------------------------------------------------------------------------

table inspect_extra167.full_arg_spec_namedtuple_identity:
  description: "inspect.FullArgSpec: __name__ 'FullArgSpec', __bases__[0].__name__ 'tuple' (namedtuple), __module__ 'inspect', __class__.__name__ 'type'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: inspectfasni167

  columns: [id, function, args, expected, description]
  rows:
    - [fas_name_full_arg_spec,
       "FullArgSpec.__name__.__eq__",
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — inspect.FullArgSpec is a namedtuple type created by collections.namedtuple in Lib/inspect.py; it is returned by inspect.getfullargspec() and has fields args/varargs/varkw/defaults/kwonlyargs/kwonlydefaults/annotations; its type __name__ is 'FullArgSpec'; str.__eq__('FullArgSpec') returns True; new to extra167"]
    - ["fas_bases_0_tuple",
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — inspect.FullArgSpec is a namedtuple, which means it is created by collections.namedtuple and therefore inherits from tuple (not object); its __bases__[0].__name__ is 'tuple', distinguishing it from Signature and BoundArguments which have 'object' as base; str.__eq__('tuple') returns True; new to extra167"]
    - [fas_module_inspect,
       "FullArgSpec.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — inspect.FullArgSpec is defined (via namedtuple) in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra167"]
    - [fas_bases_0_not_object,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["object"],
       false,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('object') == False — unlike inspect.Signature and BoundArguments which inherit from object, FullArgSpec is a namedtuple and therefore inherits from tuple; its __bases__[0].__name__ is 'tuple', not 'object'; str.__eq__('object') returns False; new to extra167"]

# ---------------------------------------------------------------------------
# Table 4: Cross-checks — Signature vs BoundArguments vs FullArgSpec
#
# Wave 296 theme: cross-checks between the three inspect classes to confirm
# their distinct identities and the namedtuple distinction for FullArgSpec.
#
# inspect.Signature.__name__ != 'BoundArguments'
# inspect.BoundArguments.__name__ != 'FullArgSpec'
# inspect.FullArgSpec.__bases__[0].__name__ != inspect.Signature.__bases__[0].__name__
#   (FullArgSpec inherits from tuple; Signature from object)
# inspect.Signature.__module__ == inspect.BoundArguments.__module__ == 'inspect'
#
# All three are Python types defined in Lib/inspect.py with __module__ 'inspect'.
# Their __name__ values are distinct. The key structural difference is that
# FullArgSpec is a namedtuple (base: tuple) while Signature and BoundArguments
# are plain Python classes (base: object). New to extra167.
# ---------------------------------------------------------------------------

table inspect_extra167.signature_bound_fullargspec_cross_checks:
  description: "inspect: Signature.__name__ != 'BoundArguments', BoundArguments.__name__ != 'FullArgSpec', FullArgSpec base 'tuple' != Signature base 'object'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsbfcc167

  columns: [id, function, args, expected, description]
  rows:
    - [sig_name_ne_bound_arguments,
       "Signature.__name__.__eq__",
       ["BoundArguments"],
       false,
       "inspect.Signature.__name__.__eq__('BoundArguments') == False — Signature.__name__ is 'Signature', not 'BoundArguments'; these are two distinct Python classes defined in Lib/inspect.py; str.__eq__('BoundArguments') returns False; new to extra167"]
    - [ba_name_ne_full_arg_spec,
       "BoundArguments.__name__.__eq__",
       ["FullArgSpec"],
       false,
       "inspect.BoundArguments.__name__.__eq__('FullArgSpec') == False — BoundArguments.__name__ is 'BoundArguments', not 'FullArgSpec'; these are two distinct types in Lib/inspect.py; str.__eq__('FullArgSpec') returns False; new to extra167"]
    - ["fas_bases_ne_sig_bases",
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["object"],
       false,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('object') == False — FullArgSpec's base class is 'tuple' (it is a namedtuple), while Signature's and BoundArguments' base class is 'object'; this structural difference marks FullArgSpec as a namedtuple; str.__eq__('object') returns False; new to extra167"]
    - [sig_module_same_as_ba_module,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — both inspect.Signature and inspect.BoundArguments have __module__ 'inspect'; they are defined in the same module Lib/inspect.py; str.__eq__('inspect') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra167
# ---------------------------------------------------------------------------

invariant inspect_extra167.signature_name_signature:
  description: "inspect.Signature.__name__ == 'Signature' — Python class for function call signature (parameters + return annotation); wave 296; new to extra167"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra167.signature_module_inspect:
  description: "inspect.Signature.__module__ == 'inspect' — Signature is defined in Lib/inspect.py; wave 296; new to extra167"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra167.signature_bases_0_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature Python class inherits directly from object; wave 296; new to extra167"
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra167.bound_arguments_name_bound_arguments:
  description: "inspect.BoundArguments.__name__ == 'BoundArguments' — Python class for arguments bound to a Signature (returned by Signature.bind()); wave 296; new to extra167"
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra167.bound_arguments_module_inspect:
  description: "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in Lib/inspect.py; wave 296; new to extra167"
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra167.bound_arguments_bases_0_object:
  description: "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments Python class inherits directly from object; wave 296; new to extra167"
  kind: python_call_eq
  function: "BoundArguments.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra167.full_arg_spec_name_full_arg_spec:
  description: "inspect.FullArgSpec.__name__ == 'FullArgSpec' — namedtuple type for full argument spec (returned by getfullargspec()); wave 296; new to extra167"
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra167.full_arg_spec_bases_0_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple and therefore inherits from tuple, not object; wave 296; new to extra167"
  kind: python_call_eq
  function: "FullArgSpec.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

