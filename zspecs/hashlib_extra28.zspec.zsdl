spec: hashlib_extra28
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra27.zspec.zsdl — covers HASH instance method qualnames (update/digest/hexdigest/copy) via md5() and sha256(); sha256().block_size/digest_size __class__.__name__."
    - "hashlib_extra26.zspec.zsdl — covers sha224/sha384 __qualname__.__eq__; new.__qualname__.__eq__; algorithms_guaranteed/available __class__.__name__.__eq__."
    - "hashlib_extra25.zspec.zsdl — covers algorithms_guaranteed/__class__/__qualname__; algorithms_guaranteed/__len__()==14; algorithms_guaranteed contains sha3_256; isdisjoint(set())."
    - "hashlib_extra24.zspec.zsdl — covers md5/sha1/sha256/sha512 __qualname__.__eq__ standalone; __qualname__.__len__ for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__; algorithms_available/__class__/__name__.__eq__."
    - "hashlib_extra9.zspec.zsdl — covers algorithms_guaranteed len >= 8; blake2s/blake2b/sha3_512 membership."
    - "hashlib_extra.zspec.zsdl — covers algorithms_available/__class__/__name__.__eq__ == 'set'; algorithms_available.__contains__('sha256')."
  notes:
    - "This spec extends hashlib through hashlib_extra27; it does NOT duplicate invariants present in those files."
    - "Focus: sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__ — no prior spec covers these four constructors' qualnames as standalone __eq__ invariants or via __len__."
    - "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256': OpenSSL-backed SHA3-256 constructor on CPython 3.12. No prior spec covers sha3_256.__qualname__.__eq__ (extra25 covers membership; extra24 does not list sha3_256 in its qualname table). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__ == 'openssl_sha3_512': OpenSSL-backed SHA3-512 constructor. Not covered by any prior qualname __eq__ invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__ == 'blake2b': Pure-Python/C blake2b constructor. Not covered by any prior __qualname__.__eq__ invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__ == 'blake2s': Pure-Python/C blake2s constructor. Not covered by any prior __qualname__.__eq__ invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "__qualname__.__len__() for sha3_256 == 16 ('openssl_sha3_256'), sha3_512 == 16 ('openssl_sha3_512'), blake2b == 7 ('blake2b'), blake2s == 7 ('blake2s'). extra24 covers len for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac; none of the sha3_*/blake2* are covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha3_256 and sha3_512 __qualname__ — standalone __eq__ invariants
#
# hashlib_extra25 covers algorithms_guaranteed.__contains__('sha3_256') membership.
# hashlib_extra9 covers sha3_512 membership in algorithms_guaranteed.
# No prior spec covers __qualname__.__eq__ for sha3_256 or sha3_512 as
# standalone invariants. On CPython 3.12, both use the OpenSSL backend.
# ---------------------------------------------------------------------------

invariant hashlib_extra28.sha3_256.qualname:
  description: "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256' — OpenSSL-backed SHA3-256 constructor qualname"
  category: function_qualnames
  kind: python_call_eq
  function: sha3_256.__qualname__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

invariant hashlib_extra28.sha3_512.qualname:
  description: "hashlib.sha3_512.__qualname__ == 'openssl_sha3_512' — OpenSSL-backed SHA3-512 constructor qualname"
  category: function_qualnames
  kind: python_call_eq
  function: sha3_512.__qualname__.__eq__
  args: ["openssl_sha3_512"]
  expected: true

# ---------------------------------------------------------------------------
# blake2b and blake2s __qualname__ — standalone __eq__ invariants
#
# hashlib_extra9 covers blake2b and blake2s membership in algorithms_guaranteed.
# No prior spec covers blake2b.__qualname__.__eq__ or blake2s.__qualname__.__eq__
# as standalone invariants (extra24 does not include blake2b/blake2s in its table).
# On CPython 3.12, blake2b and blake2s qualnames match their function names.
# ---------------------------------------------------------------------------

invariant hashlib_extra28.blake2b.qualname:
  description: "hashlib.blake2b.__qualname__ == 'blake2b' — blake2b constructor qualname"
  category: function_qualnames
  kind: python_call_eq
  function: blake2b.__qualname__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra28.blake2s.qualname:
  description: "hashlib.blake2s.__qualname__ == 'blake2s' — blake2s constructor qualname"
  category: function_qualnames
  kind: python_call_eq
  function: blake2s.__qualname__.__eq__
  args: ["blake2s"]
  expected: true

# ---------------------------------------------------------------------------
# sha3_256, sha3_512, blake2b, blake2s __qualname__.__len__()
#
# hashlib_extra24 covers __qualname__.__len__() for md5/sha1/sha256/sha512/sha224/
# sha384/new/pbkdf2_hmac. No prior spec covers __len__ for sha3_256, sha3_512,
# blake2b, or blake2s.
# 'openssl_sha3_256' == 16, 'openssl_sha3_512' == 16, 'blake2b' == 7, 'blake2s' == 7.
# ---------------------------------------------------------------------------

table hashlib_extra28.sha3_blake2_qualname_lengths:
  description: "Length of __qualname__ strings for sha3_256/sha3_512/blake2b/blake2s constructors"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hlqlen28

  columns: [id, function, args, expected]
  rows:
    - [sha3_256, sha3_256.__qualname__.__len__, [], 16]
    - [sha3_512, sha3_512.__qualname__.__len__, [], 16]
    - [blake2b,  blake2b.__qualname__.__len__,  [],  7]
    - [blake2s,  blake2s.__qualname__.__len__,  [],  7]
