spec: theseus_weakref_extra_cr
version: ">=3.8"
backend: python_cleanroom(theseus_weakref_extra_cr)
blocks: weakref

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/weakref.html"
  not_derived_from:
    - "CPython source: Lib/weakref.py"
  notes:
    - "Clean-room weakref module. Do NOT import weakref."
    - "WeakValueDictionary, WeakKeyDictionary, WeakSet, finalize."

error_model: python_exceptions

invariant theseus_weakref_extra_cr.weakref2_ref:
  description: "ref() creates weak reference that returns object"
  category: behavior
  kind: python_call_eq
  function: weakref2_ref
  args: []
  expected: true

invariant theseus_weakref_extra_cr.weakref2_dead:
  description: "ref() returns None after object is deleted"
  category: behavior
  kind: python_call_eq
  function: weakref2_dead
  args: []
  expected: true

invariant theseus_weakref_extra_cr.weakref2_weakvalue_dict:
  description: "WeakValueDictionary removes entries when values are GC'd"
  category: behavior
  kind: python_call_eq
  function: weakref2_weakvalue_dict
  args: []
  expected: true
