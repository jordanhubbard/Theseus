spec: itertools_extra751
version: ">=3.9"
backend: python_module(itertools)
docs: "Behavioral specs for itertools module class type identity checks"
provenance:
  derived_from:
    - "Python 3.9+ standard library itertools module"
  not_derived_from:
    - "any third-party itertools extension"
  notes:
    - "Covers class name identity for core itertools types"
    - "All itertools iterator objects are implemented as C types"
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra751.class_names:
  description: "Verify __class__.__name__ for each itertools attribute resolves to 'type'"
  kind: python_call_eq
  category: identity
  id_prefix: it751xx
  columns: [id, function, args, expected]
  rows:
    - [it751xx001, itertools.chain.__class__.__name__.__eq__, ["type"], true]
    - [it751xx002, itertools.product.__class__.__name__.__eq__, ["type"], true]
    - [it751xx003, itertools.combinations.__class__.__name__.__eq__, ["type"], true]
    - [it751xx004, itertools.permutations.__class__.__name__.__eq__, ["type"], true]
    - [it751xx005, itertools.combinations_with_replacement.__class__.__name__.__eq__, ["type"], true]
    - [it751xx006, itertools.accumulate.__class__.__name__.__eq__, ["type"], true]
    - [it751xx007, itertools.groupby.__class__.__name__.__eq__, ["type"], true]
    - [it751xx008, itertools.islice.__class__.__name__.__eq__, ["type"], true]
    - [it751xx009, itertools.compress.__class__.__name__.__eq__, ["type"], true]
    - [it751xx010, itertools.filterfalse.__class__.__name__.__eq__, ["type"], true]
    - [it751xx011, itertools.starmap.__class__.__name__.__eq__, ["type"], true]
    - [it751xx012, itertools.dropwhile.__class__.__name__.__eq__, ["type"], true]
