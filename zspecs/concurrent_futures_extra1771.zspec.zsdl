spec: concurrent_futures_extra1771
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Wave 565, suffix _extra1771. Theme: async protocol — which stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "concurrent.futures is a synchronous library; none of its public types define any async protocol methods."
    - "concurrent.futures.Future is a sync future — no __await__, no __aenter__, no __aexit__, no __aiter__, no __anext__."
    - "ThreadPoolExecutor and ProcessPoolExecutor use synchronous context manager protocols (__enter__/__exit__), not async ones."
    - "Executor defines __enter__ and __exit__ for use as a sync context manager, not __aenter__/__aexit__."
    - "concurrent.futures.Future.__dict__ contains 'running' and 'exception' (sync methods), verified True."
    - "concurrent.futures.wait.__class__.__name__ == 'function' — wait() is a plain function."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: async protocol methods absent from concurrent.futures types
#
# All concurrent.futures types are synchronous; none define __aenter__,
# __aexit__, __aiter__, __anext__, or __await__ in their own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1771.async_protocol_absent:
  kind: python_call_eq
  category: async_protocol
  id_prefix: cf1771

  columns: [id, function, args, expected]
  rows:
    - ["cf1771001", concurrent.futures.Future.__dict__.__contains__,              ["__aenter__"], false]
    - ["cf1771002", concurrent.futures.Future.__dict__.__contains__,              ["__aexit__"],  false]
    - ["cf1771003", concurrent.futures.Future.__dict__.__contains__,              ["__await__"],  false]
    - ["cf1771004", concurrent.futures.Future.__dict__.__contains__,              ["__aiter__"],  false]
    - ["cf1771005", concurrent.futures.Future.__dict__.__contains__,              ["__anext__"],  false]
    - ["cf1771006", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__aenter__"], false]
    - ["cf1771007", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__aexit__"],  false]
    - ["cf1771008", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__await__"],  false]
    - ["cf1771009", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["__aenter__"], false]
    - ["cf1771010", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["__aexit__"],  false]
    - ["cf1771011", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["__await__"],  false]
    - ["cf1771012", concurrent.futures.Executor.__dict__.__contains__,            ["__aenter__"], false]
    - ["cf1771013", concurrent.futures.Executor.__dict__.__contains__,            ["__aexit__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary sync-protocol and identity checks
#
# concurrent.futures.Future has sync methods in its __dict__ (running, exception).
# Executor defines sync context manager methods (__enter__, __exit__).
# wait() is a plain function.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1771.sync_protocol_present:
  kind: python_call_eq
  category: sync_protocol
  id_prefix: cf1771

  columns: [id, function, args, expected]
  rows:
    - ["cf1771014", concurrent.futures.Future.__dict__.__contains__,    ["running"],    true]
    - ["cf1771015", concurrent.futures.Future.__dict__.__contains__,    ["exception"],  true]
    - ["cf1771016", concurrent.futures.Executor.__dict__.__contains__,  ["__enter__"],  true]
    - ["cf1771017", concurrent.futures.Executor.__dict__.__contains__,  ["__exit__"],   true]
    - ["cf1771018", concurrent.futures.Executor.__dict__.__contains__,  ["__aenter__"], false]
    - ["cf1771019", concurrent.futures.Executor.__dict__.__contains__,  ["__aexit__"],  false]
    - ["cf1771020", concurrent.futures.wait.__class__.__name__.__eq__,  ["function"],   true]
    - ["cf1771021", concurrent.futures.Future.__dict__.__contains__,    ["cancel"],     true]
    - ["cf1771022", concurrent.futures.Future.__dict__.__contains__,    ["result"],     true]
    - ["cf1771023", concurrent.futures.Future.__dict__.__contains__,    ["done"],       true]
