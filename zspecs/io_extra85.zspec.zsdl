spec: io_extra85
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra84."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership; UnsupportedOperation identity, bases, MRO; DEFAULT_BUFFER_SIZE and SEEK_* constants class and value; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity."
    - "This spec covers: TextIOWrapper/__name__/__module__; TextIOWrapper/__bases__.__len__() and __bases__[0].__name__; TextIOWrapper/__mro__.__len__(); StringIO/__name__/__module__; StringIO/__bases__.__len__() and __bases__[0].__name__; StringIO/__mro__.__len__(); FileIO/__name__/__module__; FileIO/__bases__[0].__name__; FileIO/__mro__.__len__(); BytesIO/__name__/__module__; BytesIO/__bases__.__len__() and __bases__[0].__name__; BytesIO/__mro__.__len__()."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the C type name matches Python-visible name."
    - "io.TextIOWrapper.__module__ == '_io' — implemented in the _io C extension module."
    - "io.TextIOWrapper.__bases__.__len__() == 1 — TextIOWrapper has a single base class."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — inherits from _TextIOBase."
    - "io.TextIOWrapper.__mro__.__len__() == 4 — MRO is [TextIOWrapper, _TextIOBase, _IOBase, object]."
    - "io.StringIO.__name__ == 'StringIO' — the C type name matches Python-visible name."
    - "io.StringIO.__module__ == '_io' — implemented in the _io C extension module."
    - "io.StringIO.__bases__.__len__() == 1 — StringIO has a single base class."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO also inherits from _TextIOBase."
    - "io.StringIO.__mro__.__len__() == 4 — MRO is [StringIO, _TextIOBase, _IOBase, object]."
    - "io.FileIO.__name__ == 'FileIO' — the C type name matches Python-visible name."
    - "io.FileIO.__module__ == '_io' — implemented in the _io C extension module."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO inherits from _RawIOBase."
    - "io.FileIO.__mro__.__len__() == 4 — MRO is [FileIO, _RawIOBase, _IOBase, object]."
    - "io.BytesIO.__name__ == 'BytesIO' — the C type name matches Python-visible name."
    - "io.BytesIO.__module__ == '_io' — implemented in the _io C extension module."
    - "io.BytesIO.__bases__.__len__() == 1 — BytesIO has a single base class."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO inherits from _BufferedIOBase."
    - "io.BytesIO.__mro__.__len__() == 4 — MRO is [BytesIO, _BufferedIOBase, _IOBase, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextIOWrapper class identity: __name__ and __module__
# TextIOWrapper is a C type defined in the _io extension.
# __module__ == '_io' (not 'io') because it is implemented in the C layer.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra85.TextIOWrapper_identity:
  description: "TextIOWrapper __name__ and __module__"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra85

  columns: [id, function, args, expected]
  rows:
    - [tiow_name,   TextIOWrapper.__name__.__eq__,   ["TextIOWrapper"], true]
    - [tiow_module, TextIOWrapper.__module__.__eq__, ["_io"],           true]

# ---------------------------------------------------------------------------
# TextIOWrapper __bases__ and __mro__
# TextIOWrapper has a single base class _TextIOBase.
# MRO: [TextIOWrapper, _TextIOBase, _IOBase, object] — length 4.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra85.TextIOWrapper_hierarchy:
  description: "TextIOWrapper __bases__ length, __bases__[0].__name__, and __mro__.__len__()"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ioextra85

  columns: [id, function, args, expected]
  rows:
    - [tiow_bases_len,  TextIOWrapper.__bases__.__len__,               [],              1]
    - [tiow_base0_name, "TextIOWrapper.__bases__[0].__name__.__eq__",  ["_TextIOBase"], true]
    - [tiow_mro_len,    TextIOWrapper.__mro__.__len__,                 [],              4]

# ---------------------------------------------------------------------------
# StringIO class identity, bases, and MRO
# StringIO is a C type in _io. It inherits from _TextIOBase just like TextIOWrapper.
# MRO: [StringIO, _TextIOBase, _IOBase, object] — length 4.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra85.StringIO_identity_hierarchy:
  description: "StringIO __name__, __module__, __bases__ len, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra85

  columns: [id, function, args, expected]
  rows:
    - [sio_name,      StringIO.__name__.__eq__,                  ["StringIO"],    true]
    - [sio_module,    StringIO.__module__.__eq__,                ["_io"],         true]
    - [sio_bases_len, StringIO.__bases__.__len__,                [],              1]
    - [sio_base0,     "StringIO.__bases__[0].__name__.__eq__",   ["_TextIOBase"], true]
    - [sio_mro_len,   StringIO.__mro__.__len__,                  [],              4]

# ---------------------------------------------------------------------------
# FileIO class identity, base, and MRO; BytesIO identity and hierarchy
# FileIO inherits from _RawIOBase; MRO length 4.
# BytesIO inherits from _BufferedIOBase; MRO length 4.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra85.FileIO_BytesIO_identity_hierarchy:
  description: "FileIO and BytesIO __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra85

  columns: [id, function, args, expected]
  rows:
    - [fio_name,       FileIO.__name__.__eq__,                   ["FileIO"],          true]
    - [fio_module,     FileIO.__module__.__eq__,                 ["_io"],             true]
    - [fio_base0,      "FileIO.__bases__[0].__name__.__eq__",    ["_RawIOBase"],      true]
    - [fio_mro_len,    FileIO.__mro__.__len__,                   [],                  4]
    - [bio_name,       BytesIO.__name__.__eq__,                  ["BytesIO"],         true]
    - [bio_module,     BytesIO.__module__.__eq__,                ["_io"],             true]
    - [bio_bases_len,  BytesIO.__bases__.__len__,                [],                  1]
    - [bio_base0,      "BytesIO.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"], true]
    - [bio_mro_len,    BytesIO.__mro__.__len__,                  [],                  4]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra85.TextIOWrapper.name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper'"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra85.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io'"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra85.TextIOWrapper.mro_len:
  description: "io.TextIOWrapper.__mro__.__len__() == 4 ([TextIOWrapper, _TextIOBase, _IOBase, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: TextIOWrapper.__mro__.__len__
  args: []
  expected: 4

invariant io_extra85.StringIO.module:
  description: "io.StringIO.__module__ == '_io'"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra85.BytesIO.bases_len:
  description: "io.BytesIO.__bases__.__len__() == 1 (single base: _BufferedIOBase)"
  category: class_hierarchy
  kind: python_call_eq
  function: BytesIO.__bases__.__len__
  args: []
  expected: 1
