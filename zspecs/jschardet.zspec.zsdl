spec: jschardet
version: ">=3.0.0"
backend: node(jschardet)

docs: https://github.com/aadsm/jschardet#readme

provenance:
  derived_from:
    - "jschardet README — https://github.com/aadsm/jschardet#readme"
    - "Mozilla universal charset detector"
    - "Test vectors verified with jschardet via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "jschardet source"
  notes:
    - "JS port of Mozilla's universal charset detector — guesses character encoding from raw bytes."
    - "Install: npm install jschardet"
    - "detect(input) returns {encoding: string|null, confidence: number}; ASCII text always reports 'ascii' with confidence 1.0."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws. Returns null encoding when no detection is confident."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# detect(string) — encoding field
table jschardet.detect_encoding:
  kind: node_chain_eq
  category: encoding
  entry: named
  function: detect
  id_prefix: enc

  columns: [id, entry_args, chain, expected]
  rows:
    - [pure_ascii_string,
       ["Hello World"],
       [{get: encoding}],
       "ascii"]

    - [empty_string,
       [""],
       [{get: encoding}],
       ~]

# detect on string carrying raw bytes — UTF-8 detection
invariant jschardet.detect_utf8_bytes:
  description: "Latin-1 string carrying UTF-8 bytes of '日本' (E6 97 A5 E6 9C AC) reports 'UTF-8'"
  category: encoding
  kind: node_chain_eq
  entry: named
  function: detect
  entry_args: ["\xe6\x97\xa5\xe6\x9c\xac"]
  chain:
    - {get: encoding}
  expected: "UTF-8"

# Confidence is 1.0 for pure ASCII
invariant jschardet.ascii_confidence_one:
  description: "Pure ASCII text yields confidence == 1.0"
  category: confidence
  kind: node_chain_eq
  entry: named
  function: detect
  entry_args: ["Hello World"]
  chain:
    - {get: confidence}
  expected: 1
