    - [cf1141wd010, concurrent.futures.Executor.__weakref__.__class__.__name__.__eq__,            ["getset_descriptor"],   true]
    - [cf1141wd011, concurrent.futures.Executor.__weakref__.__qualname__.__eq__,                  ["Executor.__weakref__"], true]
    - [cf1141wd012, concurrent.futures.Executor.__weakref__.__name__.__eq__,                      ["__weakref__"],          true]

