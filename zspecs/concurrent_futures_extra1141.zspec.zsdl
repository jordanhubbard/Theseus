    - [cf1141wd003, concurrent.futures.ThreadPoolExecutor.__weakref__.__name__.__eq__,             ["__weakref__"],          true]
    - [cf1141wd004, concurrent.futures.ProcessPoolExecutor.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"],   true]
    - [cf1141wd005, concurrent.futures.ProcessPoolExecutor.__weakref__.__qualname__.__eq__,        ["Executor.__weakref__"], true]
    - [cf1141wd006, concurrent.futures.ProcessPoolExecutor.__weakref__.__name__.__eq__,            ["__weakref__"],          true]
    - [cf1141wd007, concurrent.futures.Future.__weakref__.__class__.__name__.__eq__,              ["getset_descriptor"],   true]
    - [cf1141wd008, concurrent.futures.Future.__weakref__.__qualname__.__eq__,                    ["Future.__weakref__"],  true]
