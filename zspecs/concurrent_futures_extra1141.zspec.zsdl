spec: concurrent_futures_extra1141
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures.FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED constant class names, ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __weakref__ descriptor identity, Future.result/exception/cancel/cancelled/running/done qualnames"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED constant class names, ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __weakref__ descriptor class name and qualname, Future.result/exception/cancel/cancelled/running/done qualnames — behaviors not covered by extra1111 or extra1126"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1141.wait_constant_class_names:
  description: "concurrent.futures.FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED constant class name and value identity"
  kind: python_call_eq
  category: constant_identity
  id_prefix: cf1141wc
  columns: [id, function, args, expected]
  rows:
    - [cf1141wc001, concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__,  ["str"],              true]
    - [cf1141wc002, concurrent.futures.FIRST_COMPLETED.__eq__,                      ["FIRST_COMPLETED"],  true]
    - [cf1141wc003, concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__,  ["str"],              true]
    - [cf1141wc004, concurrent.futures.FIRST_EXCEPTION.__eq__,                      ["FIRST_EXCEPTION"],  true]
    - [cf1141wc005, concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__,    ["str"],              true]
    - [cf1141wc006, concurrent.futures.ALL_COMPLETED.__eq__,                        ["ALL_COMPLETED"],    true]

table concurrent_futures_extra1141.weakref_descriptor_identity:
