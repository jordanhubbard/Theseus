spec: multiprocessing_extra1096
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing cpu_count, current_process, active_children, AuthenticationError, ProcessError, and Process class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.cpu_count qualname/module/class, multiprocessing.current_process qualname/module, multiprocessing.active_children qualname/module, AuthenticationError/ProcessError module/qualname, Process.start/join/terminate qualnames — behaviors not covered by extra1066 or extra1081"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1096.cpu_count_current_process:
  description: "multiprocessing.cpu_count and current_process module, qualname, and class identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: mp1096cp
  columns: [id, function, args, expected]
  rows:
    - [mp1096cp001, multiprocessing.cpu_count.__module__.__eq__,             ["multiprocessing.context"],  true]
    - [mp1096cp002, multiprocessing.cpu_count.__qualname__.__eq__,           ["BaseContext.cpu_count"],    true]
    - [mp1096cp003, multiprocessing.cpu_count.__name__.__eq__,               ["cpu_count"],                true]
    - [mp1096cp004, multiprocessing.cpu_count.__class__.__name__.__eq__,     ["method"],                   true]
    - [mp1096cp005, multiprocessing.current_process.__module__.__eq__,       ["multiprocessing.process"],  true]
    - [mp1096cp006, multiprocessing.current_process.__qualname__.__eq__,     ["current_process"],          true]
    - [mp1096cp007, multiprocessing.current_process.__name__.__eq__,         ["current_process"],          true]
    - [mp1096cp008, multiprocessing.current_process.__class__.__name__.__eq__, ["function"],               true]

table multiprocessing_extra1096.active_children_and_errors:
  description: "multiprocessing.active_children module/qualname and AuthenticationError/ProcessError identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: mp1096ae
  columns: [id, function, args, expected]
  rows:
    - [mp1096ae001, multiprocessing.active_children.__module__.__eq__,            ["multiprocessing.process"],  true]
    - [mp1096ae002, multiprocessing.active_children.__qualname__.__eq__,          ["active_children"],          true]
    - [mp1096ae003, multiprocessing.active_children.__name__.__eq__,              ["active_children"],          true]
    - [mp1096ae004, multiprocessing.active_children.__class__.__name__.__eq__,    ["function"],                 true]
    - [mp1096ae005, multiprocessing.AuthenticationError.__module__.__eq__,        ["multiprocessing.context"],  true]
    - [mp1096ae006, multiprocessing.AuthenticationError.__qualname__.__eq__,      ["AuthenticationError"],      true]
    - [mp1096ae007, multiprocessing.AuthenticationError.__name__.__eq__,          ["AuthenticationError"],      true]
    - [mp1096ae008, multiprocessing.ProcessError.__module__.__eq__,               ["multiprocessing.context"],  true]
    - [mp1096ae009, multiprocessing.ProcessError.__qualname__.__eq__,             ["ProcessError"],             true]

table multiprocessing_extra1096.process_class_method_qualnames:
  description: "multiprocessing.Process class module and start/join/terminate method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mp1096pm
  columns: [id, function, args, expected]
  rows:
    - [mp1096pm001, multiprocessing.Process.__module__.__eq__,            ["multiprocessing.context"],  true]
    - [mp1096pm002, multiprocessing.Process.__qualname__.__eq__,          ["Process"],                  true]
    - [mp1096pm003, multiprocessing.Process.__name__.__eq__,              ["Process"],                  true]
    - [mp1096pm004, multiprocessing.Process.__class__.__name__.__eq__,    ["type"],                     true]
    - [mp1096pm005, multiprocessing.Process.start.__qualname__.__eq__,    ["BaseProcess.start"],        true]
    - [mp1096pm006, multiprocessing.Process.join.__qualname__.__eq__,     ["BaseProcess.join"],         true]
    - [mp1096pm007, multiprocessing.Process.terminate.__qualname__.__eq__, ["BaseProcess.terminate"],   true]
