spec: pathlib_extra237
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __name__ contracts for common filesystem methods."
    - "pathlib.Path.stat.__name__ == 'stat' — Path.stat method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.exists.__name__ == 'exists' — Path.exists method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.is_file.__name__ == 'is_file' — Path.is_file method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.is_dir.__name__ == 'is_dir' — Path.is_dir method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.mkdir.__name__ == 'mkdir' — Path.mkdir method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.open.__name__ == 'open' — Path.open method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.read_text.__name__ == 'read_text' — Path.read_text method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.write_text.__name__ == 'write_text' — Path.write_text method name; verified Python 3.14.3 macOS."
    - "pathlib.Path.unlink.__name__ == 'unlink' — Path.unlink method name; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __name__ contracts
# All standard Path filesystem methods carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra237.Path_method_names:
  description: "pathlib.Path method __name__ contracts — stat, exists, is_file, is_dir, mkdir, open, read_text, write_text, unlink; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: pathlibpathmnames237

  columns: [id, function, args, expected]
  rows:
    - [path_stat_name,        Path.stat.__name__.__eq__,        ["stat"],       true]
    - [path_exists_name,      Path.exists.__name__.__eq__,      ["exists"],     true]
    - [path_is_file_name,     Path.is_file.__name__.__eq__,     ["is_file"],    true]
    - [path_is_dir_name,      Path.is_dir.__name__.__eq__,      ["is_dir"],     true]
    - [path_mkdir_name,       Path.mkdir.__name__.__eq__,       ["mkdir"],      true]
    - [path_open_name,        Path.open.__name__.__eq__,        ["open"],       true]
    - [path_read_text_name,   Path.read_text.__name__.__eq__,   ["read_text"],  true]
    - [path_write_text_name,  Path.write_text.__name__.__eq__,  ["write_text"], true]
    - [path_unlink_name,      Path.unlink.__name__.__eq__,      ["unlink"],     true]

# ---------------------------------------------------------------------------
# pathlib.Path method name length contracts
# Spot-check selected method name lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra237.Path.stat.name_length:
  description: "pathlib.Path.stat.__name__.__len__() == 4 — 'stat' has 4 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Path.stat.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra237.Path.exists.name_length:
  description: "pathlib.Path.exists.__name__.__len__() == 6 — 'exists' has 6 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Path.exists.__name__.__len__
  args: []
  expected: 6

invariant pathlib_extra237.Path.is_file.name_length:
  description: "pathlib.Path.is_file.__name__.__len__() == 7 — 'is_file' has 7 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Path.is_file.__name__.__len__
  args: []
  expected: 7

invariant pathlib_extra237.Path.read_text.name_length:
  description: "pathlib.Path.read_text.__name__.__len__() == 9 — 'read_text' has 9 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Path.read_text.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra237.Path.write_text.name_length:
  description: "pathlib.Path.write_text.__name__.__len__() == 10 — 'write_text' has 10 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Path.write_text.__name__.__len__
  args: []
  expected: 10
