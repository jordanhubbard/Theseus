spec: io_extra21
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
    - "io_extra19.zspec.zsdl — covers StringIO('hello').read(), StringIO('hello').getvalue(), BytesIO().getvalue()==b''; __qualname__ for major io classes; UnsupportedOperation base classes"
    - "io_extra20.zspec.zsdl — covers __name__ for all major io classes; DEFAULT_BUFFER_SIZE==8192; BytesIO/__bases__[0].__name__ and StringIO/__bases__[0].__name__"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra20.zspec.zsdl."
    - "io_extra19 covers StringIO('hello').read() and StringIO('hello').getvalue() and BytesIO().getvalue()==b''."
    - "No prior io spec covers io.StringIO().getvalue() == '' — empty StringIO buffer."
    - "No prior io spec covers io.StringIO().readable() == True."
    - "No prior io spec covers io.StringIO().writable() == True."
    - "No prior io spec covers io.StringIO().seekable() == True."
    - "No prior io spec covers io.BytesIO(b'hello').getvalue() == b'hello' with !ascii tag."
    - "No prior io spec covers io.BytesIO(b'hello').read() == b'hello' — read full contents."
    - "No prior io spec covers io.BytesIO().readable() == True."
    - "No prior io spec covers io.BytesIO().writable() == True."
    - "io.StringIO() with no argument initialises to an empty string buffer; getvalue() returns ''."
    - "io.StringIO is readable, writable, and seekable — it is a full in-memory text stream."
    - "io.BytesIO(b'hello').getvalue() returns b'hello' — the full buffer regardless of position."
    - "io.BytesIO(b'hello').read() returns b'hello' — position starts at 0 so the full content is read."
    - "io.BytesIO is readable, writable, and seekable — it is a full in-memory binary stream."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO() instance — empty getvalue()
#
# io_extra19 covers StringIO('hello').getvalue() == 'hello'.
# No prior io spec covers StringIO() with no argument and getvalue() == ''.
# An empty StringIO initialises its buffer to the empty string.
# ---------------------------------------------------------------------------

invariant io_extra21.StringIO.empty_getvalue:
  description: "io.StringIO().getvalue() == '' — empty StringIO has an empty buffer"
  category: stringio_instance
  kind: python_call_eq
  function: StringIO
  args: []
  method: getvalue
  method_args: []
  expected: ""

# ---------------------------------------------------------------------------
# io.StringIO instance — readable, writable, seekable
#
# No prior io spec covers the readable(), writable(), or seekable() methods
# on a StringIO instance. All three must return True — StringIO is a full
# in-memory text stream supporting all three I/O capabilities.
# ---------------------------------------------------------------------------

invariant io_extra21.StringIO.readable:
  description: "io.StringIO().readable() == True — StringIO supports read operations"
  category: stringio_instance
  kind: python_call_eq
  function: StringIO
  args: []
  method: readable
  method_args: []
  expected: true

invariant io_extra21.StringIO.writable:
  description: "io.StringIO().writable() == True — StringIO supports write operations"
  category: stringio_instance
  kind: python_call_eq
  function: StringIO
  args: []
  method: writable
  method_args: []
  expected: true

invariant io_extra21.StringIO.seekable:
  description: "io.StringIO().seekable() == True — StringIO supports seek operations"
  category: stringio_instance
  kind: python_call_eq
  function: StringIO
  args: []
  method: seekable
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# io.BytesIO(b'hello') — getvalue and read
#
# io_extra19 covers BytesIO().getvalue() == b'' (empty, encoded as !b64 "").
# No prior io spec covers BytesIO(b'hello').getvalue() or .read() with !ascii tag.
# BytesIO(b'hello').getvalue() returns b'hello' — the full buffer at any position.
# BytesIO(b'hello').read() returns b'hello' — position starts at 0.
# ---------------------------------------------------------------------------

invariant io_extra21.BytesIO.hello_getvalue:
  description: "io.BytesIO(b'hello').getvalue() == b'hello' — returns full buffer"
  category: bytesio_instance
  kind: python_call_eq
  function: BytesIO
  args: [!ascii hello]
  method: getvalue
  method_args: []
  expected: !ascii hello

invariant io_extra21.BytesIO.hello_read:
  description: "io.BytesIO(b'hello').read() == b'hello' — reads full content from position 0"
  category: bytesio_instance
  kind: python_call_eq
  function: BytesIO
  args: [!ascii hello]
  method: read
  method_args: []
  expected: !ascii hello

# ---------------------------------------------------------------------------
# io.BytesIO instance — readable, writable, seekable
#
# No prior io spec covers the readable(), writable(), or seekable() methods
# on a BytesIO instance. All three must return True — BytesIO is a full
# in-memory binary stream supporting all three I/O capabilities.
# ---------------------------------------------------------------------------

invariant io_extra21.BytesIO.readable:
  description: "io.BytesIO().readable() == True — BytesIO supports read operations"
  category: bytesio_instance
  kind: python_call_eq
  function: BytesIO
  args: []
  method: readable
  method_args: []
  expected: true

invariant io_extra21.BytesIO.writable:
  description: "io.BytesIO().writable() == True — BytesIO supports write operations"
  category: bytesio_instance
  kind: python_call_eq
  function: BytesIO
  args: []
  method: writable
  method_args: []
  expected: true

invariant io_extra21.BytesIO.seekable:
  description: "io.BytesIO().seekable() == True — BytesIO supports seek operations"
  category: bytesio_instance
  kind: python_call_eq
  function: BytesIO
  args: []
  method: seekable
  method_args: []
  expected: true
