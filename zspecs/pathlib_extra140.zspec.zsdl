spec: pathlib_extra140
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path traversal and existence-test methods — __qualname__ string equality and length checks for iterdir, glob, rglob, exists, is_file, is_dir. Also co_argcount and co_varnames.__len__() for each method's code object. All methods are pure Python functions (not C descriptors), so __class__.__name__ == 'function'."
    - "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' (length 12), co_argcount == 1."
    - "pathlib.Path.glob.__qualname__ == 'Path.glob' (length 9), co_argcount == 2."
    - "pathlib.Path.rglob.__qualname__ == 'Path.rglob' (length 10), co_argcount == 2."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists' (length 11), co_argcount == 1."
    - "pathlib.Path.is_file.__qualname__ == 'Path.is_file' (length 12), co_argcount == 1."
    - "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir' (length 11), co_argcount == 1."
    - "pathlib.Path.iterdir.__code__.co_varnames.__len__() == 4: ('self', 'root_dir', 'scandir_it', 'entries')."
    - "pathlib.Path.glob.__code__.co_varnames.__len__() == 11."
    - "pathlib.Path.rglob.__code__.co_varnames.__len__() == 4: ('self', 'pattern', 'case_sensitive', 'recurse_symlinks')."
    - "pathlib.Path.exists.__code__.co_varnames.__len__() == 2: ('self', 'follow_symlinks')."
    - "pathlib.Path.is_file.__code__.co_varnames.__len__() == 2: ('self', 'follow_symlinks')."
    - "pathlib.Path.is_dir.__code__.co_varnames.__len__() == 2: ('self', 'follow_symlinks')."
    - "All methods' __module__ == 'pathlib' since Path is a pure Python class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path traversal method __qualname__ equality and lengths
# iterdir: 'Path.iterdir' (12), glob: 'Path.glob' (9), rglob: 'Path.rglob' (10).
# ---------------------------------------------------------------------------

table pathlib_extra140.path_traversal_method_qualnames:
  description: "pathlib.Path traversal method __qualname__ string equality and lengths: iterdir=12, glob=9, rglob=10"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibtr140

  columns: [id, function, args, expected]
  rows:
    - [iterdir_qn_eq,   Path.iterdir.__qualname__.__eq__,  ["Path.iterdir"],  true]
    - [iterdir_qn_len,  Path.iterdir.__qualname__.__len__, [],                12]
    - [glob_qn_eq,      Path.glob.__qualname__.__eq__,     ["Path.glob"],     true]
    - [glob_qn_len,     Path.glob.__qualname__.__len__,    [],                9]
    - [rglob_qn_eq,     Path.rglob.__qualname__.__eq__,    ["Path.rglob"],    true]
    - [rglob_qn_len,    Path.rglob.__qualname__.__len__,   [],                10]
    - [iterdir_cls_eq,  Path.iterdir.__class__.__name__.__eq__, ["function"],  true]
    - [glob_cls_eq,     Path.glob.__class__.__name__.__eq__,    ["function"],  true]
    - [rglob_cls_eq,    Path.rglob.__class__.__name__.__eq__,   ["function"],  true]
    - [iterdir_mod_eq,  Path.iterdir.__module__.__eq__,    ["pathlib"],       true]

# ---------------------------------------------------------------------------
# pathlib.Path existence-test method __qualname__ equality and lengths
# exists: 'Path.exists' (11), is_file: 'Path.is_file' (12), is_dir: 'Path.is_dir' (11).
# ---------------------------------------------------------------------------

table pathlib_extra140.path_existence_method_qualnames:
  description: "pathlib.Path existence-test method __qualname__ string equality and lengths: exists=11, is_file=12, is_dir=11"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibex140

  columns: [id, function, args, expected]
  rows:
    - [exists_qn_eq,    Path.exists.__qualname__.__eq__,   ["Path.exists"],   true]
    - [exists_qn_len,   Path.exists.__qualname__.__len__,  [],                11]
    - [isfile_qn_eq,    Path.is_file.__qualname__.__eq__,  ["Path.is_file"],  true]
    - [isfile_qn_len,   Path.is_file.__qualname__.__len__, [],                12]
    - [isdir_qn_eq,     Path.is_dir.__qualname__.__eq__,   ["Path.is_dir"],   true]
    - [isdir_qn_len,    Path.is_dir.__qualname__.__len__,  [],                11]
    - [exists_cls_eq,   Path.exists.__class__.__name__.__eq__,  ["function"],  true]
    - [isfile_cls_eq,   Path.is_file.__class__.__name__.__eq__, ["function"],  true]
    - [isdir_cls_eq,    Path.is_dir.__class__.__name__.__eq__,  ["function"],  true]
    - [exists_mod_eq,   Path.exists.__module__.__eq__,     ["pathlib"],       true]
    - [isfile_mod_eq,   Path.is_file.__module__.__eq__,    ["pathlib"],       true]
    - [isdir_mod_eq,    Path.is_dir.__module__.__eq__,     ["pathlib"],       true]

# ---------------------------------------------------------------------------
# pathlib.Path method co_argcount checks
# iterdir: co_argcount == 1 (just self, follow_* args keyword-only or absent).
# glob/rglob: co_argcount == 2 (self, pattern).
# exists/is_file/is_dir: co_argcount == 1 (self; follow_symlinks is keyword-only).
# ---------------------------------------------------------------------------

table pathlib_extra140.path_method_co_argcount:
  description: "pathlib.Path traversal and existence-test method __code__.co_argcount values: iterdir=1, glob=2, rglob=2, exists=1, is_file=1, is_dir=1"
  kind: python_call_eq
  category: method_code
  id_prefix: pathlibca140

  columns: [id, function, args, expected]
  rows:
    - [iterdir_argc,  Path.iterdir.__code__.co_argcount.__eq__,  [1], true]
    - [glob_argc,     Path.glob.__code__.co_argcount.__eq__,     [2], true]
    - [rglob_argc,    Path.rglob.__code__.co_argcount.__eq__,    [2], true]
    - [exists_argc,   Path.exists.__code__.co_argcount.__eq__,   [1], true]
    - [isfile_argc,   Path.is_file.__code__.co_argcount.__eq__,  [1], true]
    - [isdir_argc,    Path.is_dir.__code__.co_argcount.__eq__,   [1], true]

# ---------------------------------------------------------------------------
# pathlib.Path method co_varnames length checks
# iterdir: 4, glob: 11, rglob: 4, exists: 2, is_file: 2, is_dir: 2.
# ---------------------------------------------------------------------------

table pathlib_extra140.path_method_co_varnames_len:
  description: "pathlib.Path method __code__.co_varnames length: iterdir=4, glob=11, rglob=4, exists=2, is_file=2, is_dir=2"
  kind: python_call_eq
  category: method_code
  id_prefix: pathlibvn140

  columns: [id, function, args, expected]
  rows:
    - [iterdir_vnlen,  Path.iterdir.__code__.co_varnames.__len__,  [], 4]
    - [glob_vnlen,     Path.glob.__code__.co_varnames.__len__,     [], 11]
    - [rglob_vnlen,    Path.rglob.__code__.co_varnames.__len__,    [], 4]
    - [exists_vnlen,   Path.exists.__code__.co_varnames.__len__,   [], 2]
    - [isfile_vnlen,   Path.is_file.__code__.co_varnames.__len__,  [], 2]
    - [isdir_vnlen,    Path.is_dir.__code__.co_varnames.__len__,   [], 2]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra140.Path.iterdir_qualname_eq:
  description: "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' (length 12; iterdir is a pure Python function defined directly on Path)"
  category: method_identity
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__eq__
  args: ["Path.iterdir"]
  expected: true

invariant pathlib_extra140.Path.glob_qualname_len_9:
  description: "pathlib.Path.glob.__qualname__.__len__() == 9 ('Path.glob' is 9 chars: 'Path' (4) + '.' (1) + 'glob' (4))"
  category: method_identity
  kind: python_call_eq
  function: Path.glob.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra140.Path.iterdir_is_function:
  description: "pathlib.Path.iterdir.__class__.__name__ == 'function' (Path is a pure Python class, so its methods are plain Python functions, not C method_descriptors)"
  category: method_identity
  kind: python_call_eq
  function: Path.iterdir.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra140.Path.glob_co_argcount_2:
  description: "pathlib.Path.glob.__code__.co_argcount == 2 (positional args are 'self' and 'pattern'; case_sensitive and recurse_symlinks are keyword-only)"
  category: method_code
  kind: python_call_eq
  function: Path.glob.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra140.Path.glob_co_varnames_len_11:
  description: "pathlib.Path.glob.__code__.co_varnames.__len__() == 11 (11 local variable slots including self, pattern, and internal locals)"
  category: method_code
  kind: python_call_eq
  function: Path.glob.__code__.co_varnames.__len__
  args: []
  expected: 11
