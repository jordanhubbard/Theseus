spec: re_extra108
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra107.zspec.zsdl."
    - "This spec covers: re.Pattern and re.Match class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and re.PatternError (formerly re.error) identity."
    - "re.Pattern.__name__ == 'Pattern'; re.Pattern.__module__ == 're'; re.Pattern.__qualname__ == 'Pattern'."
    - "re.Pattern.__bases__[0].__name__ == 'object'; re.Pattern.__mro__.__len__() == 2."
    - "re.Match.__name__ == 'Match'; re.Match.__module__ == 're'; re.Match.__qualname__ == 'Match'."
    - "re.Match.__bases__[0].__name__ == 'object'; re.Match.__mro__.__len__() == 2."
    - "type(re.Pattern).__name__ == 'type'; re.Pattern.__class__.__name__ == 'type' (Pattern is a C extension type, not a metaclass like ABCMeta)."
    - "re.PatternError.__name__ == 'PatternError' (renamed from 'error' in Python 3.13; re.error is an alias for re.PatternError)."
    - "re.PatternError.__bases__[0].__name__ == 'Exception'; re.PatternError.__mro__.__len__() == 4."
    - "len('Pattern') == 7; len('Match') == 5; len('PatternError') == 12."
    - "type(re.compile('')).__name__ == 'Pattern'; type(re.compile('')).__module__ == 're'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__
# Pattern is a C extension type (from _sre module), exposed in the re namespace.
# It directly inherits from object, giving MRO length 2.
# type(Pattern).__name__ == 'type' (plain metaclass, not ABCMeta).
# ---------------------------------------------------------------------------

table re_extra108.Pattern_identity:
  description: "re.Pattern class identity: __name__='Pattern', __module__='re', __qualname__='Pattern', __bases__[0]='object', __mro__ len=2, __class__='type'"
  kind: python_call_eq
  category: class_names
  id_prefix: reclsid108a

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,      Pattern.__name__.__eq__,          ["Pattern"], true,  "re.Pattern.__name__ == 'Pattern'"]
    - [pat_module_eq,    Pattern.__module__.__eq__,         ["re"],      true,  "re.Pattern.__module__ == 're' (exposed in the re namespace, not '_sre')"]
    - [pat_qualname_eq,  Pattern.__qualname__.__eq__,       ["Pattern"], true,  "re.Pattern.__qualname__ == 'Pattern' (qualname equals name for top-level C extension type)"]
    - [pat_base_eq,      "Pattern.__bases__[0].__name__.__eq__", ["object"], true, "re.Pattern.__bases__[0].__name__ == 'object' (Pattern inherits directly from object)"]
    - [pat_mro_len,      "Pattern.__mro__.__len__",         [],          2,    "re.Pattern.__mro__.__len__() == 2 (Pattern, object)"]
    - [pat_class_name,   Pattern.__class__.__name__.__eq__, ["type"],    true,  "re.Pattern.__class__.__name__ == 'type' (plain metaclass, not ABCMeta)"]
    - [pat_name_len,     Pattern.__name__.__len__,          [],          7,    "re.Pattern.__name__.__len__() == 7 ('Pattern' has 7 characters)"]
    - [pat_mod_not_sre,  Pattern.__module__.__eq__,         ["_sre"],    false, "re.Pattern.__module__ != '_sre' (Pattern is exposed in the 're' namespace, not the internal '_sre' C extension)"]

# ---------------------------------------------------------------------------
# re.Match class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__
# Match is a C extension type parallel to Pattern.
# It also inherits directly from object, MRO length 2.
# type(Match).__name__ == 'type'.
# ---------------------------------------------------------------------------

table re_extra108.Match_identity:
  description: "re.Match class identity: __name__='Match', __module__='re', __qualname__='Match', __bases__[0]='object', __mro__ len=2, __class__='type'"
  kind: python_call_eq
  category: class_names
  id_prefix: reclsid108b

  columns: [id, function, args, expected, description]
  rows:
    - [match_name_eq,     Match.__name__.__eq__,          ["Match"],   true,  "re.Match.__name__ == 'Match'"]
    - [match_module_eq,   Match.__module__.__eq__,         ["re"],      true,  "re.Match.__module__ == 're'"]
    - [match_qualname_eq, Match.__qualname__.__eq__,       ["Match"],   true,  "re.Match.__qualname__ == 'Match' (qualname equals name for top-level C extension type)"]
    - [match_base_eq,     "Match.__bases__[0].__name__.__eq__", ["object"], true, "re.Match.__bases__[0].__name__ == 'object'"]
    - [match_mro_len,     "Match.__mro__.__len__",         [],          2,    "re.Match.__mro__.__len__() == 2 (Match, object)"]
    - [match_class_name,  Match.__class__.__name__.__eq__, ["type"],    true,  "re.Match.__class__.__name__ == 'type'"]
    - [match_name_len,    Match.__name__.__len__,          [],          5,    "re.Match.__name__.__len__() == 5 ('Match' has 5 characters)"]
    - [match_name_ne_pat, Match.__name__.__eq__,           ["Pattern"], false, "re.Match.__name__ != 'Pattern' (Match and Pattern are distinct C extension types)"]

# ---------------------------------------------------------------------------
# re.PatternError (re.error alias) class identity
# In Python 3.13+, re.error was renamed to re.PatternError; re.error remains
# as an alias. PatternError.__name__ == 'PatternError' (not 'error').
# Inherits from Exception; MRO: PatternError, Exception, BaseException, object (len=4).
# ---------------------------------------------------------------------------

table re_extra108.PatternError_identity:
  description: "re.PatternError class identity: __name__='PatternError', __module__='re', __bases__[0]='Exception', __mro__ len=4; re.error is the same object"
  kind: python_call_eq
  category: class_names
  id_prefix: reclsid108c

  columns: [id, function, args, expected, description]
  rows:
    - [paterr_name_eq,    PatternError.__name__.__eq__,          ["PatternError"], true,  "re.PatternError.__name__ == 'PatternError' (renamed from 'error' in Python 3.13)"]
    - [paterr_module_eq,  PatternError.__module__.__eq__,         ["re"],           true,  "re.PatternError.__module__ == 're'"]
    - [paterr_qualname_eq, PatternError.__qualname__.__eq__,      ["PatternError"], true,  "re.PatternError.__qualname__ == 'PatternError'"]
    - [paterr_base_eq,    "PatternError.__bases__[0].__name__.__eq__", ["Exception"], true, "re.PatternError.__bases__[0].__name__ == 'Exception'"]
    - [paterr_mro_len,    "PatternError.__mro__.__len__",         [],               4,     "re.PatternError.__mro__.__len__() == 4 (PatternError, Exception, BaseException, object)"]
    - [paterr_name_len,   PatternError.__name__.__len__,          [],               12,    "re.PatternError.__name__.__len__() == 12 ('PatternError' has 12 characters)"]
    - [paterr_not_error,  PatternError.__name__.__eq__,           ["error"],        false, "re.PatternError.__name__ != 'error' (renamed in Python 3.13; 'error' is an alias but the class __name__ is 'PatternError')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra108.Pattern.module_is_re:
  description: "re.Pattern.__module__ == 're' (though Pattern is implemented in the C extension _sre, it is exposed in the 're' namespace; its __module__ attribute reflects this public namespace, not the internal _sre)"
  category: class_names
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra108.Pattern.mro_len_2:
  description: "re.Pattern.__mro__.__len__() == 2 (Pattern's MRO is (Pattern, object); as a C extension type with no intermediate base classes, it has the minimal MRO of length 2, same as re.Match)"
  category: class_names
  kind: python_call_eq
  function: "Pattern.__mro__.__len__"
  args: []
  expected: 2

invariant re_extra108.Match.name_is_Match:
  description: "re.Match.__name__ == 'Match' (the C extension type representing a match object returned by Pattern.match/search/etc.; __name__ is the bare class name 'Match', length 5)"
  category: class_names
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra108.PatternError.mro_len_4:
  description: "re.PatternError.__mro__.__len__() == 4 (PatternError's MRO is (PatternError, Exception, BaseException, object); it is a plain exception class with no additional intermediate bases)"
  category: class_names
  kind: python_call_eq
  function: "PatternError.__mro__.__len__"
  args: []
  expected: 4

invariant re_extra108.PatternError.bases_is_Exception:
  description: "re.PatternError.__bases__[0].__name__ == 'Exception' (PatternError — formerly re.error — directly subclasses Exception; it carries a 'pattern' and 'pos' attribute for diagnostics but has no additional base class between itself and Exception)"
  category: class_names
  kind: python_call_eq
  function: "PatternError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

