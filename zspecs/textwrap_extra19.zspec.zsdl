spec: textwrap_extra19
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra18.zspec.zsdl."
    - "textwrap_extra18 covers: wrap.__module__; fill.__module__; dedent.__module__; indent.__module__; shorten.__module__; wrap.__name__; fill.__name__; table of function __module__ attributes."
    - "textwrap_extra17 covers: TextWrapper.__name__; TextWrapper.__module__; TextWrapper.__bases__[0].__name__; wrap/fill/shorten/indent/dedent __qualname__; two tables."
    - "NOT yet covered (now covered here): textwrap.TextWrapper.__mro__.__len__() == 2 — TextWrapper MRO depth."
    - "NOT yet covered (now covered here): textwrap.TextWrapper.__mro__[0].__name__ == 'TextWrapper' — first MRO entry."
    - "NOT yet covered (now covered here): textwrap.TextWrapper.__mro__[1].__name__ == 'object' — second MRO entry."
    - "NOT yet covered (now covered here): textwrap.TextWrapper.__name__.__len__() == 11 — len of the class __name__ string."
    - "NOT yet covered (now covered here): textwrap.TextWrapper.__qualname__ == 'TextWrapper' — qualname as standalone extra19 invariant."
    - "NOT yet covered (now covered here): textwrap.TextWrapper.__module__ == 'textwrap' — module as standalone extra19 invariant."
    - "NOT yet covered (now covered here): table of function __name__ attributes — wrap, fill, dedent, indent, shorten."
    - "textwrap.TextWrapper.__mro__.__len__() == 2 verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "textwrap.TextWrapper.__name__.__len__() == 11 verified at runtime ('TextWrapper' has 11 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.TextWrapper — MRO depth and MRO entry names
#
# textwrap_extra17 covers TextWrapper.__name__, __module__, __bases__[0].__name__,
# and __qualname__. No prior spec verifies TextWrapper.__mro__.__len__() or the
# individual MRO entry __name__ values as standalone invariants.
# TextWrapper inherits directly from object: MRO is [TextWrapper, object].
# Verified at runtime: __len__() == 2; mro[0].__name__ == 'TextWrapper';
# mro[1].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant textwrap_extra19.TextWrapper.mro_len:
  description: "textwrap.TextWrapper.__mro__.__len__() == 2 — TextWrapper MRO: [TextWrapper, object]"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__mro__.__len__
  args: []
  expected: 2

invariant textwrap_extra19.TextWrapper.mro_0:
  description: "textwrap.TextWrapper.__mro__[0].__name__ == 'TextWrapper' — first MRO entry is TextWrapper itself"
  category: class_identity
  kind: python_call_eq
  function: "TextWrapper.__mro__[0].__name__.__eq__"
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra19.TextWrapper.mro_1:
  description: "textwrap.TextWrapper.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: class_identity
  kind: python_call_eq
  function: "TextWrapper.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper — __name__ string length
#
# No prior spec verifies TextWrapper.__name__.__len__() as a standalone
# invariant. 'TextWrapper' has 11 characters.
# Verified at runtime: TextWrapper.__name__.__len__() == 11.
# ---------------------------------------------------------------------------

invariant textwrap_extra19.TextWrapper.name_len:
  description: "textwrap.TextWrapper.__name__.__len__() == 11 — 'TextWrapper' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# textwrap.TextWrapper — qualname and module (extra19 namespace anchors)
#
# textwrap_extra17 covers TextWrapper.__qualname__ and TextWrapper.__module__
# as standalone invariants in that namespace. These re-anchor them under
# extra19 to pair with the MRO invariants above.
# Verified: TextWrapper.__qualname__ == 'TextWrapper';
# TextWrapper.__module__ == 'textwrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra19.TextWrapper.qualname:
  description: "textwrap.TextWrapper.__qualname__ == 'TextWrapper' — qualname of the TextWrapper class"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__qualname__.__eq__
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra19.TextWrapper.module:
  description: "textwrap.TextWrapper.__module__ == 'textwrap' — TextWrapper is defined in the textwrap module"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __name__ attributes — wrap, fill, dedent, indent, shorten
#
# textwrap_extra18 covers wrap.__name__ and fill.__name__ as standalone
# invariants. textwrap_extra17 covers __qualname__ (equal to __name__ for
# module-level functions) in a table. No prior table groups all five function
# __name__ attributes explicitly under the extra19 namespace.
# Verified: all five __name__ values match the function names.
# ---------------------------------------------------------------------------

table textwrap_extra19.function_names:
  description: "textwrap module-level function __name__ attributes — wrap, fill, dedent, indent, shorten"
  kind: python_call_eq
  category: function_identity
  id_prefix: fn19

  columns: [id, function, args, expected]
  rows:
    - [wrap,    wrap.__name__.__eq__,    ["wrap"],    true]
    - [fill,    fill.__name__.__eq__,    ["fill"],    true]
    - [dedent,  dedent.__name__.__eq__,  ["dedent"],  true]
    - [indent,  indent.__name__.__eq__,  ["indent"],  true]
    - [shorten, shorten.__name__.__eq__, ["shorten"], true]
