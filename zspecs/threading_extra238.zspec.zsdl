spec: threading_extra238
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Event is_set/set/clear behavioral contracts."
    - "threading.Event.__name__ == 'Event' (len=5) — the class name. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' (len=9) — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Event.__qualname__ == 'Event' (len=5). Verified with Python 3.14.3."
    - "threading.Event.__class__.__name__ == 'type' — Event is a Python class. Verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Event.is_set.__name__ == 'is_set' (len=6). Verified with Python 3.14.3."
    - "threading.Event.set.__name__ == 'set' (len=3). Verified with Python 3.14.3."
    - "threading.Event.clear.__name__ == 'clear' (len=5). Verified with Python 3.14.3."
    - "threading.Event.is_set.__qualname__ == 'Event.is_set' (len=12). Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__ == 'Event.set' (len=9). Verified with Python 3.14.3."
    - "threading.Event.clear.__qualname__ == 'Event.clear' (len=11). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Event class identity contracts
#
# threading.Event.__name__ == 'Event' (len=5)
# threading.Event.__module__ == 'threading' (len=9)
# threading.Event.__qualname__ == 'Event' (len=5)
# threading.Event.__class__.__name__ == 'type'
# threading.Event.__bases__[0].__name__ == 'object'
#
# Event is a Python class in Lib/threading.py. New to extra238.
# ---------------------------------------------------------------------------

table threading_extra238.event_class_identity:
  description: "threading.Event class identity: name, module, qualname, metaclass type, base object; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra238eventclassid

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a Python class in Lib/threading.py implementing a thread synchronization flag; __name__ is 'Event' (len=5); new to extra238"]
    - [event_name_len_5,
       Event.__name__.__len__,
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — 'Event' has exactly 5 characters (E-v-e-n-t); str.__len__() returns 5; new to extra238"]
    - [event_module_eq,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra238"]
    - [event_qualname_eq,
       Event.__qualname__.__eq__,
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — Event is a top-level class with unqualified qualname 'Event'; new to extra238"]
    - [event_class_is_type,
       Event.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Event.__class__.__name__.__eq__('type') == True — Event is a Python class; its metaclass is the built-in type; new to extra238"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event base, MRO, and doc contracts
#
# threading.Event.__bases__[0].__name__ == 'object'
# threading.Event.__mro__[0].__name__ == 'Event'
# threading.Event.__mro__[1].__name__ == 'object'
# threading.Event.__doc__.__contains__('flag') == True
# threading.Event.__doc__.__contains__('set') == True
#
# Event has a two-element MRO and a docstring describing the flag semantics. New to extra238.
# ---------------------------------------------------------------------------

table threading_extra238.event_mro_and_doc:
  description: "threading.Event base is object; MRO slots; doc contains 'flag' and 'set'; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra238eventmrodoc

  columns: [id, function, args, expected, description]
  rows:
    - [event_base_is_object,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event inherits directly from object; __bases__[0].__name__ is 'object'; new to extra238"]
    - [event_mro0_eq,
       "Event.__mro__[0].__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__mro__[0].__name__.__eq__('Event') == True — MRO slot 0 is the class itself; __mro__[0].__name__ is 'Event'; new to extra238"]
    - [event_mro1_eq,
       "Event.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__mro__[1].__name__.__eq__('object') == True — MRO slot 1 is object; Event has a two-element MRO; new to extra238"]
    - [event_doc_contains_flag,
       Event.__doc__.__contains__,
       ["flag"],
       true,
       "threading.Event.__doc__.__contains__('flag') == True — docstring describes a flag that can be set to true or reset to false; str.__contains__('flag') returns True; new to extra238"]
    - [event_doc_contains_set,
       Event.__doc__.__contains__,
       ["set"],
       true,
       "threading.Event.__doc__.__contains__('set') == True — docstring mentions the set() method used to set the flag to true; str.__contains__('set') returns True; new to extra238"]

# ---------------------------------------------------------------------------
# Table 3: threading.Event.is_set, .set, .clear method identity contracts
#
# threading.Event.is_set.__name__ == 'is_set' (len=6)
# threading.Event.set.__name__ == 'set' (len=3)
# threading.Event.clear.__name__ == 'clear' (len=5)
# threading.Event.is_set.__qualname__ == 'Event.is_set' (len=12)
# threading.Event.set.__qualname__ == 'Event.set' (len=9)
#
# is_set, set, and clear are Python methods on Event. New to extra238.
# ---------------------------------------------------------------------------

table threading_extra238.event_method_identity:
  description: "threading.Event.is_set, set, and clear method identity: name, qualname; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra238eventmethid

  columns: [id, function, args, expected, description]
  rows:
    - [is_set_name_eq,
       Event.is_set.__name__.__eq__,
       ["is_set"],
       true,
       "threading.Event.is_set.__name__.__eq__('is_set') == True — is_set is a method on Event that returns True when the flag is set; __name__ is 'is_set' (len=6); new to extra238"]
    - [set_name_eq,
       Event.set.__name__.__eq__,
       ["set"],
       true,
       "threading.Event.set.__name__.__eq__('set') == True — set is a method on Event that sets the internal flag to True; __name__ is 'set' (len=3); new to extra238"]
    - [clear_name_eq,
       Event.clear.__name__.__eq__,
       ["clear"],
       true,
       "threading.Event.clear.__name__.__eq__('clear') == True — clear is a method on Event that resets the internal flag to False; __name__ is 'clear' (len=5); new to extra238"]
    - [is_set_qualname_eq,
       Event.is_set.__qualname__.__eq__,
       ["Event.is_set"],
       true,
       "threading.Event.is_set.__qualname__.__eq__('Event.is_set') == True — is_set qualname is 'Event.is_set' (len=12) indicating it is a method of Event; new to extra238"]
    - [set_qualname_eq,
       Event.set.__qualname__.__eq__,
       ["Event.set"],
       true,
       "threading.Event.set.__qualname__.__eq__('Event.set') == True — set qualname is 'Event.set' (len=9) indicating it is a method of Event; new to extra238"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra238
# ---------------------------------------------------------------------------

invariant threading_extra238.event_name_eq:
  description: "threading.Event.__name__ == 'Event' (len=5); new to extra238"
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra238.event_name_len_5:
  description: "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters; new to extra238"
  kind: python_call_eq
  function: Event.__name__.__len__
  args: []
  expected: 5

invariant threading_extra238.event_module_eq:
  description: "threading.Event.__module__ == 'threading'; new to extra238"
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra238.event_module_len_9:
  description: "threading.Event.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra238"
  kind: python_call_eq
  function: Event.__module__.__len__
  args: []
  expected: 9

invariant threading_extra238.event_qualname_eq:
  description: "threading.Event.__qualname__ == 'Event'; new to extra238"
  kind: python_call_eq
  function: Event.__qualname__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra238.event_class_is_type:
  description: "threading.Event.__class__.__name__ == 'type'; new to extra238"
  kind: python_call_eq
  function: Event.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra238.event_base_is_object:
  description: "threading.Event.__bases__[0].__name__ == 'object'; new to extra238"
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra238.event_mro0_eq:
  description: "threading.Event.__mro__[0].__name__ == 'Event'; new to extra238"
  kind: python_call_eq
  function: "Event.__mro__[0].__name__.__eq__"
  args: ["Event"]
  expected: true

invariant threading_extra238.event_mro1_eq:
  description: "threading.Event.__mro__[1].__name__ == 'object'; new to extra238"
  kind: python_call_eq
  function: "Event.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra238.event_doc_contains_flag:
  description: "threading.Event.__doc__.__contains__('flag') == True; new to extra238"
  kind: python_call_eq
  function: Event.__doc__.__contains__
  args: ["flag"]
  expected: true

invariant threading_extra238.event_doc_contains_set:
  description: "threading.Event.__doc__.__contains__('set') == True; new to extra238"
  kind: python_call_eq
  function: Event.__doc__.__contains__
  args: ["set"]
  expected: true

invariant threading_extra238.is_set_name_eq:
  description: "threading.Event.is_set.__name__ == 'is_set' (len=6); new to extra238"
  kind: python_call_eq
  function: Event.is_set.__name__.__eq__
  args: ["is_set"]
  expected: true

invariant threading_extra238.set_name_eq:
  description: "threading.Event.set.__name__ == 'set' (len=3); new to extra238"
  kind: python_call_eq
  function: Event.set.__name__.__eq__
  args: ["set"]
  expected: true

invariant threading_extra238.clear_name_eq:
  description: "threading.Event.clear.__name__ == 'clear' (len=5); new to extra238"
  kind: python_call_eq
  function: Event.clear.__name__.__eq__
  args: ["clear"]
  expected: true

invariant threading_extra238.is_set_qualname_eq:
  description: "threading.Event.is_set.__qualname__ == 'Event.is_set' (len=12); new to extra238"
  kind: python_call_eq
  function: Event.is_set.__qualname__.__eq__
  args: ["Event.is_set"]
  expected: true

invariant threading_extra238.set_qualname_eq:
  description: "threading.Event.set.__qualname__ == 'Event.set' (len=9); new to extra238"
  kind: python_call_eq
  function: Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

invariant threading_extra238.clear_qualname_eq:
  description: "threading.Event.clear.__qualname__ == 'Event.clear' (len=11); new to extra238"
