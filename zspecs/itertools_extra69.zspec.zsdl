# New to extra69.
# ---------------------------------------------------------------------------

table itertools_extra69.itertools_qualnames_4:
  description: "itertools C type __qualname__ identity set 4: count __qualname__=='count'; wave 235 __qualname__ identity; new to extra69"
  kind: python_call_eq
  category: type_qualnames
  id_prefix: itertqualnames69

  columns: [id, function, args, expected, description]
  rows:
    - [count_qualname_eq_count,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C extension type defined at module level in Modules/itertoolsmodule.c; it generates an infinite arithmetic sequence starting from a given value with a given step; __qualname__ equals __name__ for module-level C types; count.__qualname__ == 'count' (5 chars); str.__eq__('count') returns True; no prior itertools spec checks count.__qualname__; new to extra69"]

