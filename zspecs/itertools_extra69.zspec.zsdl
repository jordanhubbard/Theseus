spec: itertools_extra69
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra68.zspec.zsdl."
    - "Wave 235 theme: itertools C type __qualname__ identity — for module-level C types __qualname__ equals __name__."
    - "chain.__qualname__ == 'chain' — module-level C type, qualname equals name. Verified with Python 3.14.3."
    - "islice.__qualname__ == 'islice' — module-level C type. Verified with Python 3.14.3."
    - "product.__qualname__ == 'product' — module-level C type. Verified with Python 3.14.3."
    - "combinations.__qualname__ == 'combinations' — module-level C type. Verified with Python 3.14.3."
    - "permutations.__qualname__ == 'permutations' — module-level C type. Verified with Python 3.14.3."
    - "accumulate.__qualname__ == 'accumulate' — module-level C type. Verified with Python 3.14.3."
    - "cycle.__qualname__ == 'cycle' — module-level C type. Verified with Python 3.14.3."
    - "repeat.__qualname__ == 'repeat' — module-level C type. Verified with Python 3.14.3."
    - "groupby.__qualname__ == 'groupby' — module-level C type. Verified with Python 3.14.3."
    - "starmap.__qualname__ == 'starmap' — module-level C type. Verified with Python 3.14.3."
    - "compress.__qualname__ == 'compress' — module-level C type. Verified with Python 3.14.3."
    - "dropwhile.__qualname__ == 'dropwhile' — module-level C type. Verified with Python 3.14.3."
    - "takewhile.__qualname__ == 'takewhile' — module-level C type. Verified with Python 3.14.3."
    - "zip_longest.__qualname__ == 'zip_longest' — module-level C type. Verified with Python 3.14.3."
    - "filterfalse.__qualname__ == 'filterfalse' — module-level C type. Verified with Python 3.14.3."
    - "count.__qualname__ == 'count' — module-level C type. Verified with Python 3.14.3."
    - "For all itertools C types defined at module level (not nested), __qualname__ == __name__. This is because there is no enclosing class or function scope in the qualified name path. Prior itertools_extra68 covered __name__ and __module__ for all major types. This spec covers __qualname__ for all 16 types, which is new to extra69."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools type __qualname__ — set 1 — extra69
#
# Wave 235 theme: __qualname__ identity for 5 itertools C types.
#
# All itertools types are defined at module level in Modules/itertoolsmodule.c.
# For module-level C types (not nested within another class), the __qualname__
# attribute equals the __name__ attribute — there is no enclosing class or
# function scope to prefix the qualified name.
#
# chain.__qualname__        == 'chain'
# islice.__qualname__       == 'islice'
# product.__qualname__      == 'product'
# combinations.__qualname__ == 'combinations'
# permutations.__qualname__ == 'permutations'
#
# No prior itertools spec checks __qualname__ for any itertools C type.
# New to extra69.
# ---------------------------------------------------------------------------

table itertools_extra69.itertools_qualnames_1:
  description: "itertools C types __qualname__ identity set 1: chain/islice/product/combinations/permutations __qualname__==__name__; wave 235 __qualname__ identity; new to extra69"
  kind: python_call_eq
  category: type_qualnames
  id_prefix: itertqualnames69

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_eq_chain,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C extension type defined at module level in Modules/itertoolsmodule.c; for C types that are not nested within another class or function, __qualname__ equals __name__; chain.__qualname__ == 'chain' (5 chars); str.__eq__('chain') returns True; no prior itertools spec checks chain.__qualname__; new to extra69"]
    - [islice_qualname_eq_islice,
       islice.__qualname__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — islice is a C extension type defined at module level in Modules/itertoolsmodule.c; __qualname__ equals __name__ for module-level C types; islice.__qualname__ == 'islice' (6 chars); str.__eq__('islice') returns True; no prior itertools spec checks islice.__qualname__; new to extra69"]
    - [product_qualname_eq_product,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is a C extension type defined at module level in Modules/itertoolsmodule.c; __qualname__ equals __name__ for module-level C types; product.__qualname__ == 'product' (7 chars); str.__eq__('product') returns True; no prior itertools spec checks product.__qualname__; new to extra69"]
    - [combinations_qualname_eq_combinations,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a C extension type defined at module level in Modules/itertoolsmodule.c; __qualname__ equals __name__ for module-level C types; combinations.__qualname__ == 'combinations' (12 chars); str.__eq__('combinations') returns True; no prior itertools spec checks combinations.__qualname__; new to extra69"]
    - [permutations_qualname_eq_permutations,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a C extension type defined at module level in Modules/itertoolsmodule.c; __qualname__ equals __name__ for module-level C types; permutations.__qualname__ == 'permutations' (12 chars); str.__eq__('permutations') returns True; no prior itertools spec checks permutations.__qualname__; new to extra69"]

# ---------------------------------------------------------------------------
# itertools type __qualname__ — set 2 — extra69
#
# Wave 235 theme: __qualname__ identity for 5 more itertools C types.
#
# accumulate, cycle, repeat, groupby, starmap are C extension types at module
# level. Each __qualname__ equals the type's __name__.
#
# accumulate.__qualname__ == 'accumulate'
# cycle.__qualname__      == 'cycle'
# repeat.__qualname__     == 'repeat'
# groupby.__qualname__    == 'groupby'
# starmap.__qualname__    == 'starmap'
#
# New to extra69.
# ---------------------------------------------------------------------------

table itertools_extra69.itertools_qualnames_2:
  description: "itertools C types __qualname__ identity set 2: accumulate/cycle/repeat/groupby/starmap __qualname__==__name__; wave 235 __qualname__ identity; new to extra69"
  kind: python_call_eq
  category: type_qualnames
  id_prefix: itertqualnames69

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_qualname_eq_accumulate,
       accumulate.__qualname__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__.__eq__('accumulate') == True — accumulate is a C extension type defined at module level in Modules/itertoolsmodule.c; it returns running totals or cumulative results of a binary function; __qualname__ equals __name__ for module-level C types; accumulate.__qualname__ == 'accumulate' (10 chars); str.__eq__('accumulate') returns True; no prior itertools spec checks accumulate.__qualname__; new to extra69"]
    - [cycle_qualname_eq_cycle,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — cycle is a C extension type defined at module level in Modules/itertoolsmodule.c; it cycles through an iterable indefinitely; __qualname__ equals __name__ for module-level C types; cycle.__qualname__ == 'cycle' (5 chars); str.__eq__('cycle') returns True; no prior itertools spec checks cycle.__qualname__; new to extra69"]
    - [repeat_qualname_eq_repeat,
       repeat.__qualname__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__qualname__.__eq__('repeat') == True — repeat is a C extension type defined at module level in Modules/itertoolsmodule.c; it returns a value repeatedly; __qualname__ equals __name__ for module-level C types; repeat.__qualname__ == 'repeat' (6 chars); str.__eq__('repeat') returns True; no prior itertools spec checks repeat.__qualname__; new to extra69"]
    - [groupby_qualname_eq_groupby,
       groupby.__qualname__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — groupby is a C extension type defined at module level in Modules/itertoolsmodule.c; it groups consecutive elements of an iterable by a key function; __qualname__ equals __name__ for module-level C types; groupby.__qualname__ == 'groupby' (7 chars); str.__eq__('groupby') returns True; no prior itertools spec checks groupby.__qualname__; new to extra69"]
    - [starmap_qualname_eq_starmap,
       starmap.__qualname__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__qualname__.__eq__('starmap') == True — starmap is a C extension type defined at module level in Modules/itertoolsmodule.c; it applies a function to argument tuples obtained by unpacking each element of the iterable; __qualname__ equals __name__ for module-level C types; starmap.__qualname__ == 'starmap' (7 chars); str.__eq__('starmap') returns True; no prior itertools spec checks starmap.__qualname__; new to extra69"]

# ---------------------------------------------------------------------------
# itertools type __qualname__ — set 3 — extra69
#
# Wave 235 theme: __qualname__ identity for 5 more itertools C types.
#
# compress, dropwhile, takewhile, zip_longest, filterfalse are C extension
# types at module level. Each __qualname__ equals the type's __name__.
#
# compress.__qualname__    == 'compress'
# dropwhile.__qualname__   == 'dropwhile'
# takewhile.__qualname__   == 'takewhile'
# zip_longest.__qualname__ == 'zip_longest'
# filterfalse.__qualname__ == 'filterfalse'
#
# New to extra69.
# ---------------------------------------------------------------------------

table itertools_extra69.itertools_qualnames_3:
  description: "itertools C types __qualname__ identity set 3: compress/dropwhile/takewhile/zip_longest/filterfalse __qualname__==__name__; wave 235 __qualname__ identity; new to extra69"
  kind: python_call_eq
  category: type_qualnames
  id_prefix: itertqualnames69

  columns: [id, function, args, expected, description]
  rows:
    - [compress_qualname_eq_compress,
       compress.__qualname__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — compress is a C extension type defined at module level in Modules/itertoolsmodule.c; it filters elements using a boolean selector iterable; __qualname__ equals __name__ for module-level C types; compress.__qualname__ == 'compress' (8 chars); str.__eq__('compress') returns True; no prior itertools spec checks compress.__qualname__; new to extra69"]
    - [dropwhile_qualname_eq_dropwhile,
       dropwhile.__qualname__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__.__eq__('dropwhile') == True — dropwhile is a C extension type defined at module level in Modules/itertoolsmodule.c; it drops elements while a predicate is true then yields the rest; __qualname__ equals __name__ for module-level C types; dropwhile.__qualname__ == 'dropwhile' (9 chars); str.__eq__('dropwhile') returns True; no prior itertools spec checks dropwhile.__qualname__; new to extra69"]
    - [takewhile_qualname_eq_takewhile,
       takewhile.__qualname__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__qualname__.__eq__('takewhile') == True — takewhile is a C extension type defined at module level in Modules/itertoolsmodule.c; it yields elements while a predicate is true then stops; __qualname__ equals __name__ for module-level C types; takewhile.__qualname__ == 'takewhile' (9 chars); str.__eq__('takewhile') returns True; no prior itertools spec checks takewhile.__qualname__; new to extra69"]
    - [zip_longest_qualname_eq_zip_longest,
       zip_longest.__qualname__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — zip_longest is a C extension type defined at module level in Modules/itertoolsmodule.c; it zips iterables of different lengths using a fillvalue for shorter ones; __qualname__ equals __name__ for module-level C types; zip_longest.__qualname__ == 'zip_longest' (11 chars); str.__eq__('zip_longest') returns True; no prior itertools spec checks zip_longest.__qualname__; new to extra69"]
    - [filterfalse_qualname_eq_filterfalse,
       filterfalse.__qualname__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__.__eq__('filterfalse') == True — filterfalse is a C extension type defined at module level in Modules/itertoolsmodule.c; it yields elements for which a predicate is False; __qualname__ equals __name__ for module-level C types; filterfalse.__qualname__ == 'filterfalse' (11 chars); str.__eq__('filterfalse') returns True; no prior itertools spec checks filterfalse.__qualname__; new to extra69"]

# ---------------------------------------------------------------------------
# itertools type __qualname__ — set 4 — extra69
#
# Wave 235 theme: __qualname__ identity for count.
#
