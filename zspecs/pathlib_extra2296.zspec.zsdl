spec: pathlib_extra2296
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "All pathlib classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath) are pure-Python with __module__ == 'pathlib'."
    - "PosixPath is only instantiable on POSIX systems; WindowsPath is only instantiable on Windows. Both classes exist on all platforms."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2296.pure_path_module:
  description: "Pure path classes all have __module__ == 'pathlib'"
  kind: python_call_eq
  category: module_identity
  id_prefix: pp2296

  columns: [id, function, args, expected]
  rows:
    - ["pp2296001", "pathlib.PurePath.__module__", [], "pathlib"]
    - ["pp2296002", "pathlib.PurePosixPath.__module__", [], "pathlib"]
    - ["pp2296003", "pathlib.PureWindowsPath.__module__", [], "pathlib"]

table pathlib_extra2296.pure_path_qualname:
  description: "Pure path classes have simple __qualname__ matching class name"
  kind: python_call_eq
  category: module_identity
  id_prefix: pp2296

  columns: [id, function, args, expected]
  rows:
    - ["pp2296004", "pathlib.PurePath.__qualname__", [], "PurePath"]
    - ["pp2296005", "pathlib.PurePosixPath.__qualname__", [], "PurePosixPath"]
    - ["pp2296006", "pathlib.PureWindowsPath.__qualname__", [], "PureWindowsPath"]

table pathlib_extra2296.concrete_path_module:
  description: "Concrete path classes all have __module__ == 'pathlib'"
  kind: python_call_eq
  category: module_identity
  id_prefix: pp2296

  columns: [id, function, args, expected]
  rows:
    - ["pp2296007", "pathlib.Path.__module__", [], "pathlib"]
    - ["pp2296008", "pathlib.PosixPath.__module__", [], "pathlib"]
    - ["pp2296009", "pathlib.WindowsPath.__module__", [], "pathlib"]

table pathlib_extra2296.concrete_path_qualname:
  description: "Concrete path classes have simple __qualname__ matching class name"
  kind: python_call_eq
  category: module_identity
  id_prefix: pp2296

  columns: [id, function, args, expected]
  rows:
    - ["pp2296010", "pathlib.Path.__qualname__", [], "Path"]
    - ["pp2296011", "pathlib.PosixPath.__qualname__", [], "PosixPath"]
    - ["pp2296012", "pathlib.WindowsPath.__qualname__", [], "WindowsPath"]

table pathlib_extra2296.path_name:
  description: "pathlib classes __name__ matches class name (no aliasing)"
  kind: python_call_eq
  category: module_identity
  id_prefix: pp2296

  columns: [id, function, args, expected]
  rows:
    - ["pp2296013", "pathlib.PurePath.__name__", [], "PurePath"]
    - ["pp2296014", "pathlib.PurePosixPath.__name__", [], "PurePosixPath"]
    - ["pp2296015", "pathlib.PureWindowsPath.__name__", [], "PureWindowsPath"]
    - ["pp2296016", "pathlib.Path.__name__", [], "Path"]
    - ["pp2296017", "pathlib.PosixPath.__name__", [], "PosixPath"]
    - ["pp2296018", "pathlib.WindowsPath.__name__", [], "WindowsPath"]

table pathlib_extra2296.module_consistency:
  description: "All six pathlib classes consistently report __module__ == 'pathlib'"
  kind: python_call_eq
  category: module_identity
  id_prefix: pp2296

  columns: [id, function, args, expected]
  rows:
    - ["pp2296019", "pathlib.PurePath.__module__", [], "pathlib"]
    - ["pp2296020", "pathlib.Path.__module__", [], "pathlib"]
    - ["pp2296021", "pathlib.PosixPath.__module__", [], "pathlib"]
    - ["pp2296022", "pathlib.WindowsPath.__module__", [], "pathlib"]
