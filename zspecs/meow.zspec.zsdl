spec: meow
version: ">=12.0.0"
backend: node(meow)
esm: true

docs: https://github.com/sindresorhus/meow#readme

provenance:
  derived_from:
    - "meow README — https://github.com/sindresorhus/meow#readme"
    - "Test vectors verified with meow via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "meow source"
  notes:
    - "meow is an ESM-only npm package. Install: npm install meow"
    - "Usage: import meow from 'meow'; const cli = meow({importMeta: import.meta, argv, flags})"
    - "importMeta is required so meow can locate package.json for help/version output."
    - "For offline tests we pass a synthetic importMeta {url: 'file:///dev/null/package.json'} — meow does not read the file unless --help/--version is invoked."
    - "cli.flags returns the parsed flag object; cli.input returns the positional-arg array."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Returns a CLI object with .flags, .input, .pkg, .help, etc.; we only test .flags and .input."
  stderr: "null"
  stickiness: "N/A — each meow() call is independent."
  codes: {}

# ── flags parsing ────────────────────────────────────────────────────────────

table meow.flags:
  kind: node_property_eq
  category: flags
  entry: named
  function: default
  property: flags
  id_prefix: flags

  columns: [id, entry_args, expected]
  rows:
    - [string_flag,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: ["--name", "Alice"],
         flags: {name: {type: "string"}}}],
       {name: "Alice"}]

    - [number_coercion,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: ["--age", "30"],
         flags: {age: {type: "number"}}}],
       {age: 30}]

    - [boolean_short_flag,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: ["-v"],
         flags: {verbose: {type: "boolean", shortFlag: "v"}}}],
       {verbose: true}]

    - [default_value,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: [],
         flags: {color: {type: "string", default: "red"}}}],
       {color: "red"}]

    - [equals_syntax,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: ["--port=8080"],
         flags: {port: {type: "number"}}}],
       {port: 8080}]

# ── positional input ─────────────────────────────────────────────────────────

table meow.input:
  kind: node_property_eq
  category: input
  entry: named
  function: default
  property: input
  id_prefix: input

  columns: [id, entry_args, expected]
  rows:
    - [single_positional,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: ["foo"],
         flags: {}}],
       ["foo"]]

    - [multiple_positionals,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: ["a", "b", "c"],
         flags: {}}],
       ["a", "b", "c"]]

    - [positionals_with_flag,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: ["pos1", "pos2", "-v"],
         flags: {verbose: {type: "boolean", shortFlag: "v"}}}],
       ["pos1", "pos2"]]

    - [empty_input,
       [{importMeta: {url: "file:///dev/null/package.json"},
         argv: [],
         flags: {}}],
       []]
