spec: dc2986
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (dc2986): __len__, __length_hint__, __contains__ dict-presence checks for decimal types."
    - "decimal.Decimal is an arbitrary-precision numeric type — not a container; no container protocol slots."
    - "decimal.Context holds rounding/precision configuration; it is not a sequence or container."
    - "decimal.DecimalException and its subclasses are exception types; they do not define container slots."
    - "Verified types: Decimal, Context, DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, Clamped."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# Decimal numeric and exception types do not define __len__; all false.
# ---------------------------------------------------------------------------

table dc2986.len:
  description: "decimal types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2986
  columns: [id, function, args, expected]
  rows:
    - ["dc2986001", operator.contains, [decimal.Decimal.__dict__,          "__len__"], false]
    - ["dc2986002", operator.contains, [decimal.Context.__dict__,          "__len__"], false]
    - ["dc2986003", operator.contains, [decimal.DecimalException.__dict__, "__len__"], false]
    - ["dc2986004", operator.contains, [decimal.InvalidOperation.__dict__, "__len__"], false]
    - ["dc2986005", operator.contains, [decimal.DivisionByZero.__dict__,   "__len__"], false]
    - ["dc2986006", operator.contains, [decimal.Overflow.__dict__,         "__len__"], false]

