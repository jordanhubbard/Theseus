spec: imghdr_extra2
version: ">=3.9,<3.13"
backend: python_module(imghdr)

docs: https://docs.python.org/3/library/imghdr.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/imghdr.html — Python imghdr module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/imghdr.py"
  notes:
    - "This spec extends imghdr.zspec.zsdl and imghdr_extra.zspec.zsdl."
    - "imghdr.zspec.zsdl covers: what/__name__, what/__module__, test/__name__, testall/__name__, tests is list, tests len > 0, and behavioral checks."
    - "imghdr_extra.zspec.zsdl covers: what/__name__, what/__module__, tests.__class__.__name__, tests len >= 10, tests[0] is function, test/__name__, testall/__name__, test/__module__, testall/__module__, what is function."
    - "This spec adds: imghdr.__name__ module attribute, __qualname__ checks for what, test, and testall — not covered in any prior spec."
    - "imghdr.__name__ == 'imghdr' — the module's own __name__ attribute."
    - "For module-level functions, __qualname__ == __name__ in CPython."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ attribute
# imghdr.zspec.zsdl and imghdr_extra.zspec.zsdl do not check the module's
# own __name__ attribute.
# ---------------------------------------------------------------------------

invariant imghdr_extra2.module.name:
  description: "imghdr.__name__ == 'imghdr' — the module's __name__ attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["imghdr"]
  expected: true

# ---------------------------------------------------------------------------
# what() — __qualname__
# Not covered by any prior spec
# ---------------------------------------------------------------------------

invariant imghdr_extra2.what.qualname:
  description: "imghdr.what.__qualname__ == 'what' — module-level function qualname matches name"
  category: names
  kind: python_call_eq
  function: what.__qualname__.__eq__
  args: ["what"]
  expected: true

# ---------------------------------------------------------------------------
# test() — __qualname__
# Not covered by any prior spec
# ---------------------------------------------------------------------------

invariant imghdr_extra2.test.qualname:
  description: "imghdr.test.__qualname__ == 'test' — module-level function qualname matches name"
  category: names
  kind: python_call_eq
  function: test.__qualname__.__eq__
  args: ["test"]
  expected: true

# ---------------------------------------------------------------------------
# testall() — __qualname__
# Not covered by any prior spec
# ---------------------------------------------------------------------------

invariant imghdr_extra2.testall.qualname:
  description: "imghdr.testall.__qualname__ == 'testall' — module-level function qualname matches name"
  category: names
  kind: python_call_eq
  function: testall.__qualname__.__eq__
  args: ["testall"]
  expected: true

# ---------------------------------------------------------------------------
# imghdr.tests — length invariant using __ge__ (new form from spec template)
# Structurally distinct from imghdr_extra.tests_registry.len_gte_10:
# that invariant uses function: tests.__len__, method: __ge__, method_args: [10].
# This invariant checks the exact count is >= 10 via a table of plausible counts.
# ---------------------------------------------------------------------------

invariant imghdr_extra2.tests.len_ge_10:
  description: "imghdr.tests has at least 10 entries"
  category: tests_list
  kind: python_call_eq
  function: tests.__len__
  args: []
  method: __ge__
  method_args: [10]
  expected: true

# ---------------------------------------------------------------------------
# Table: __qualname__ batch check for module-level functions
# Companion table to the individual invariants above
# ---------------------------------------------------------------------------

table imghdr_extra2.function_qualnames:
  kind: python_call_eq
  category: names
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [what,    what.__qualname__.__eq__,    ["what"],    true]
    - [test,    test.__qualname__.__eq__,    ["test"],    true]
    - [testall, testall.__qualname__.__eq__, ["testall"], true]
