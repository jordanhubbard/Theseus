spec: multiprocessing_extra1171
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.__all__.__class__.__name__ identity, multiprocessing.queues.__name__ identity, multiprocessing.pool.__name__ identity, multiprocessing.synchronize.__name__ identity, multiprocessing.process.__name__ identity, multiprocessing.managers.__name__ identity, multiprocessing.sharedctypes.__name__ identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.__all__.__class__.__name__ identity, multiprocessing.queues/pool/synchronize/process/managers/sharedctypes submodule __name__ identity, multiprocessing.managers.SyncManager/BaseManager class module identity — behaviors not covered by extra1141 or extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1171.all_and_package_class_identity:
  description: "multiprocessing.__all__.__class__.__name__ and top-level module attribute class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp1171ac
  columns: [id, function, args, expected]
  rows:
    - [mp1171ac001, multiprocessing.__all__.__class__.__name__.__eq__,           ["list"],             true]
    - [mp1171ac002, multiprocessing.__all__.__contains__,                         ["Process"],          true]
    - [mp1171ac003, multiprocessing.__all__.__contains__,                         ["Queue"],            true]
    - [mp1171ac004, multiprocessing.__all__.__contains__,                         ["Pool"],             true]
    - [mp1171ac005, multiprocessing.__all__.__contains__,                         ["Lock"],             true]
    - [mp1171ac006, multiprocessing.__all__.__contains__,                         ["Manager"],          true]
    - [mp1171ac007, multiprocessing.__spec__.__class__.__name__.__eq__,           ["ModuleSpec"],       true]
    - [mp1171ac008, multiprocessing.__spec__.name.__eq__,                         ["multiprocessing"],  true]
    - [mp1171ac009, multiprocessing.__spec__.name.__class__.__name__.__eq__,      ["str"],              true]

table multiprocessing_extra1171.submodule_name_identity:
