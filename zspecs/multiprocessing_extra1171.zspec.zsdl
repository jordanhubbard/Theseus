    - [mp1171sn007, multiprocessing.process.__name__.__eq__,          ["multiprocessing.process"],      true]
    - [mp1171sn008, multiprocessing.process.__name__.__class__.__name__.__eq__, ["str"],                true]
    - [mp1171sn009, multiprocessing.managers.__name__.__eq__,         ["multiprocessing.managers"],     true]
