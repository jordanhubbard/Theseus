spec: struct_extra1246
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct __doc__ class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that struct module, Struct class, and pack/unpack/calcsize functions have str __doc__; struct.error.__doc__ is NoneType; verifies __doc__.__class__.__name__ comparisons"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1246.module_doc_class:
  description: "struct module, Struct, and pack/unpack family __doc__ is a str"
  kind: python_call_eq
  category: doc_class
  id_prefix: st1246md
  columns: [id, function, args, expected]
  rows:
    - [st1246md001, struct.__doc__.__class__.__name__.__eq__,             ["str"], true]
    - [st1246md002, struct.Struct.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [st1246md003, struct.pack.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [st1246md004, struct.unpack.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [st1246md005, struct.pack_into.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [st1246md006, struct.unpack_from.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st1246md007, struct.iter_unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st1246md008, struct.calcsize.__doc__.__class__.__name__.__eq__,    ["str"], true]

table struct_extra1246.module_doc_not_nonetype:
  description: "struct module and functions that have str __doc__ are not NoneType"
  kind: python_call_eq
  category: doc_not_nonetype
  id_prefix: st1246mn
  columns: [id, function, args, expected]
  rows:
    - [st1246mn001, struct.__doc__.__class__.__name__.__eq__,             ["NoneType"], false]
    - [st1246mn002, struct.Struct.__doc__.__class__.__name__.__eq__,      ["NoneType"], false]
    - [st1246mn003, struct.pack.__doc__.__class__.__name__.__eq__,        ["NoneType"], false]
    - [st1246mn004, struct.unpack.__doc__.__class__.__name__.__eq__,      ["NoneType"], false]
    - [st1246mn005, struct.pack_into.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [st1246mn006, struct.unpack_from.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [st1246mn007, struct.iter_unpack.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [st1246mn008, struct.calcsize.__doc__.__class__.__name__.__eq__,    ["NoneType"], false]

table struct_extra1246.error_doc_is_nonetype:
  description: "struct.error.__doc__ is NoneType; meta-level doc class name is str"
  kind: python_call_eq
  category: error_doc_nonetype
  id_prefix: st1246en
  columns: [id, function, args, expected]
  rows:
    - [st1246en001, struct.error.__doc__.__class__.__name__.__eq__,                           ["NoneType"], true]
    - [st1246en002, struct.error.__doc__.__class__.__name__.__eq__,                           ["str"],      false]
    - [st1246en003, struct.error.__doc__.__class__.__name__.__class__.__name__.__eq__,        ["str"],      true]
    - [st1246en004, struct.__doc__.__class__.__name__.__class__.__name__.__eq__,              ["str"],      true]
    - [st1246en005, struct.Struct.__doc__.__class__.__name__.__class__.__name__.__eq__,       ["str"],      true]
    - [st1246en006, struct.pack.__doc__.__class__.__name__.__class__.__name__.__eq__,         ["str"],      true]
    - [st1246en007, struct.unpack.__doc__.__class__.__name__.__class__.__name__.__eq__,       ["str"],      true]
    - [st1246en008, struct.calcsize.__doc__.__class__.__name__.__class__.__name__.__eq__,     ["str"],      true]
