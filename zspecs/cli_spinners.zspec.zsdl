spec: cli_spinners
version: ">=3.0.0"
backend: node(cli-spinners)

docs: https://github.com/sindresorhus/cli-spinners#readme

provenance:
  derived_from:
    - "cli-spinners README — https://github.com/sindresorhus/cli-spinners#readme"
    - "Test vectors verified with cli-spinners via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "cli-spinners source"
  notes:
    - "Static data: 80+ named spinner animations, each with {interval, frames}."
    - "Install: npm install cli-spinners"
    - "v3 ESM with CJS shim; the spinner table is exposed under .default."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure static data; lookup of unknown names returns undefined."
  stderr: "null"
  stickiness: "N/A — pure data."
  codes: {}

# Dots — the canonical default spinner for ora et al.
invariant cli_spinners.dots_interval:
  description: "dots.interval is 80ms"
  category: dots
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: dots}
    - {get: interval}
  expected: 80

invariant cli_spinners.dots_frames_count:
  description: "dots has 10 frames (Braille animation cycle)"
  category: dots
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: dots}
    - {get: frames}
    - {get: length}
  expected: 10

invariant cli_spinners.dots_first_frame:
  description: "dots.frames[0] is the Braille pattern ⠋"
  category: dots
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: dots}
    - {get: frames}
    - {method: at, args: [0]}
  expected: "⠋"

# Line spinner
invariant cli_spinners.line_interval:
  description: "line.interval is 130ms (per cli-spinners catalog)"
  category: line
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: line}
    - {get: interval}
  expected: 130

invariant cli_spinners.line_frames_count:
  description: "line spinner has 4 frames"
  category: line
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: line}
    - {get: frames}
    - {get: length}
  expected: 4

# Distinct spinner — clock has more frames
invariant cli_spinners.clock_has_frames:
  description: "clock has 12 frames (one per hour position)"
  category: clock
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: clock}
    - {get: frames}
    - {get: length}
  expected: 12

# Unknown spinner returns undefined
invariant cli_spinners.unknown_spinner_undefined:
  description: "Looking up an unregistered spinner name returns undefined"
  category: registry
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: not_a_real_spinner}
  expected: ~
