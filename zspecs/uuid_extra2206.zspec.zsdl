  description: "uuid.UUID.__dict__ positive presence — known UUID attributes including ordering dunders are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2206

  columns: [id, function, args, expected]
  rows:
    - ["uu2206013", "uuid.UUID.__dict__.__contains__", ["__init__"], true]
    - ["uu2206014", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu2206015", "uuid.UUID.__dict__.__contains__", ["__int__"], true]
    - ["uu2206016", "uuid.UUID.__dict__.__contains__", ["__str__"], true]
    - ["uu2206017", "uuid.UUID.__dict__.__contains__", ["__repr__"], true]
    - ["uu2206018", "uuid.UUID.__dict__.__contains__", ["__setattr__"], true]
    - ["uu2206019", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
    - ["uu2206020", "uuid.UUID.__dict__.__contains__", ["bytes"], true]
    - ["uu2206021", "uuid.UUID.__dict__.__contains__", ["hex"], true]
    - ["uu2206022", "uuid.UUID.__dict__.__contains__", ["urn"], true]
    - ["uu2206023", "uuid.UUID.__dict__.__contains__", ["variant"], true]
    - ["uu2206024", "uuid.UUID.__dict__.__contains__", ["version"], true]
    - ["uu2206025", "uuid.UUID.__dict__.__contains__", ["node"], true]
