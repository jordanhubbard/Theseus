table uuid_extra2206.SafeUUID_dict_keys_positive:
  description: "uuid.SafeUUID.__dict__ positive presence — enum members safe, unsafe, unknown are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2206

  columns: [id, function, args, expected]
  rows:
    - ["uu2206027", "uuid.SafeUUID.__dict__.__contains__", ["safe"], true]
    - ["uu2206028", "uuid.SafeUUID.__dict__.__contains__", ["unsafe"], true]
