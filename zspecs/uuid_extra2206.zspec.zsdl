spec: uuid_extra2206
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/uuid.html"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2206: rich comparison operator protocol dict-presence — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "uuid.UUID explicitly defines __lt__, __le__, __gt__, __ge__, __eq__ in its own __dict__ for total ordering by integer value. It does NOT define __ne__ (inherits from object)."
    - "uuid.SafeUUID is a plain Enum (not IntEnum). It defines none of the rich comparison operators in its own __dict__."
    - "uuid.UUID.__dict__ contains: __slots__, __init__, _from_int, __getstate__, __setstate__, __eq__, __lt__, __gt__, __le__, __ge__, __hash__, __int__, __repr__, __setattr__, __str__, bytes, bytes_le, fields, hex, urn, variant, version, int, is_safe, and other UUID properties."
    - "uuid.SafeUUID.__dict__ contains IntEnum machinery keys plus members: safe, unsafe, unknown."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2206.UUID_rich_comparison_protocol:
  description: "uuid.UUID rich comparison operator protocol dict-presence — UUID defines __lt__, __le__, __gt__, __ge__, __eq__ but NOT __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2206

  columns: [id, function, args, expected]
  rows:
    - ["uu2206001", "uuid.UUID.__dict__.__contains__", ["__lt__"], true]
    - ["uu2206002", "uuid.UUID.__dict__.__contains__", ["__le__"], true]
    - ["uu2206003", "uuid.UUID.__dict__.__contains__", ["__gt__"], true]
    - ["uu2206004", "uuid.UUID.__dict__.__contains__", ["__ge__"], true]
    - ["uu2206005", "uuid.UUID.__dict__.__contains__", ["__eq__"], true]
    - ["uu2206006", "uuid.UUID.__dict__.__contains__", ["__ne__"], false]

table uuid_extra2206.SafeUUID_rich_comparison_protocol:
  description: "uuid.SafeUUID rich comparison operator protocol dict-presence — SafeUUID is a plain Enum and defines none of the rich comparison operators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2206

  columns: [id, function, args, expected]
  rows:
    - ["uu2206007", "uuid.SafeUUID.__dict__.__contains__", ["__lt__"], false]
    - ["uu2206008", "uuid.SafeUUID.__dict__.__contains__", ["__le__"], false]
    - ["uu2206009", "uuid.SafeUUID.__dict__.__contains__", ["__gt__"], false]
    - ["uu2206010", "uuid.SafeUUID.__dict__.__contains__", ["__ge__"], false]
    - ["uu2206011", "uuid.SafeUUID.__dict__.__contains__", ["__eq__"], false]
    - ["uu2206012", "uuid.SafeUUID.__dict__.__contains__", ["__ne__"], false]

