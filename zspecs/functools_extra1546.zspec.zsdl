spec: functools_extra1546
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 550 theme: bitwise operator dict-presence checks via __dict__.__contains__ for functools classes."
    - "functools.partial.__dict__.__contains__ returns False for all bitwise dunder methods. partial is a C extension type; it defines no bitwise operators. Verified with Python 3.14."
    - "functools.cached_property.__dict__.__contains__ returns False for all bitwise dunder methods. cached_property is a Python descriptor class; bitwise operations are not applicable. Verified with Python 3.14."
    - "functools.partialmethod.__dict__.__contains__ returns False for all bitwise dunder methods. partialmethod is a Python descriptor class; bitwise operations are not applicable. Verified with Python 3.14."
    - "Bitwise dunders checked: __and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__, __rlshift__, __rrshift__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — bitwise operator dict-presence checks
#
# Wave 550 theme: partial is a C extension type. Its own __dict__ does not
# contain any bitwise dunder methods. These are not value types and have no
# meaningful bitwise semantics; dict.__contains__ returns False for all.
# ---------------------------------------------------------------------------

table functools_extra1546.partial_bitwise_dict_contains:
  description: "functools.partial.__dict__.__contains__ returns False for all bitwise dunder methods; wave 550; new to extra1546"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1546pa

  columns: [id, function, args, expected, description]
  rows:
    - ["fu1546pa001",
       "partial.__dict__.__contains__",
       ["__and__"],
       false,
       "functools.partial.__dict__.__contains__('__and__') == False — partial is a C extension type; its __dict__ does not define __and__; wave 550; new to extra1546"]
    - ["fu1546pa002",
       "partial.__dict__.__contains__",
       ["__or__"],
       false,
       "functools.partial.__dict__.__contains__('__or__') == False — partial does not define __or__ in its own class __dict__; wave 550; new to extra1546"]
    - ["fu1546pa003",
