spec: http_client_extra19
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra18.zspec.zsdl — covers HTTPConnection/__mro__.__len__()==2; HTTPException/__mro__.__len__()==4; HTTPSConnection/__mro__.__len__()==3; HTTPResponse/__mro__.__len__()==6; HTTPException/__bases__[0].__name__=='Exception'; NotConnected/__bases__[0].__name__=='HTTPException'; HTTPSConnection/__bases__[0].__name__=='HTTPConnection'; HTTPResponse.read/__qualname__/__qualname__.__len__()==17; HTTPResponse.readline/readinto __qualname__.__len__()==21/__name__.__len__()==8."
    - "http_client_extra17.zspec.zsdl — covers HTTPSConnection/HTTPResponse/HTTPException __qualname__.__len__(); HTTPConnection.request/connect/close/send __qualname__/__name__ __len__(); HTTPResponse.read/close/geturl/info __name__.__len__(); parse_headers.__module__.__len__()."
    - "http_client_extra16.zspec.zsdl — covers __module__.__len__()==11 for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException; __name__.__len__() for all four; HTTPConnection.__qualname__.__len__()==14; parse_headers/__name__/__qualname__/__name__.__len__."
    - "http_client_extra15.zspec.zsdl — covers HTTPConnection.__init__.__name__, HTTPResponse/__bases__[0].__name__, NotConnected/InvalidURL exception names and bases, UnknownProtocol/__name__, RemoteDisconnected names and bases, IncompleteRead/__name__."
    - "http_client_extra14.zspec.zsdl — covers HTTPConnection/__qualname__/__module__, HTTPSConnection/__qualname__/__module__, HTTP_PORT/HTTPS_PORT constants, BadStatusLine/CannotSendRequest exception attributes."
  notes:
    - "This spec extends http_client_extra18.zspec.zsdl."
    - "Prior specs covered: HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException all __name__/__module__/__qualname__/__bases__/__mro__.__len__(); HTTP_PORT/HTTPS_PORT; status codes; parse_headers; exception class names and bases; all __len__() for __module__/__name__/__qualname__ of four main classes; HTTPConnection.request/connect/close/send __qualname__/__name__ __len__(); HTTPResponse.read/readline/readinto __qualname__/__name__ __len__()."
    - "This spec covers: http.client.__all__.__len__()==19 and __all__.__class__.__name__=='list'; http.client.HTTP_PORT.__class__.__name__=='int' and value==80; http.client.HTTPS_PORT.__class__.__name__=='int' and value==443; http.client.responses.__class__.__name__=='dict' and __len__()==62; http.client.HTTPConnection.__dict__.__class__.__name__=='mappingproxy' and __len__()==12; http.client.HTTPResponse.__dict__.__class__.__name__=='mappingproxy' and __len__()==12; http.client.HTTPException.__dict__.__class__.__name__=='mappingproxy' and __len__()==12; http.client.HTTPConnection.getresponse/__qualname__/__qualname__.__len__()==26/__name__.__len__()==11; http.client.HTTPConnection.set_debuglevel/__qualname__.__len__()==29/__name__.__len__()==14; http.client.HTTPConnection.putheader/__qualname__/__qualname__.__len__()==24/__name__.__len__()==9."
    - "http.client.__all__.__len__() == 19. __all__.__class__.__name__ == 'list'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTP_PORT == 80, HTTPS_PORT == 443 — both plain int. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.responses.__class__.__name__ == 'dict'; __len__() == 62 HTTP status codes defined. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Same for HTTPResponse and HTTPException. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.getresponse.__qualname__ == 'HTTPConnection.getresponse' — len 26. __name__ == 'getresponse' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.set_debuglevel.__qualname__ == 'HTTPConnection.set_debuglevel' — len 29. __name__ == 'set_debuglevel' — len 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.putheader.__qualname__ == 'HTTPConnection.putheader' — len 24. __name__ == 'putheader' — len 9. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# http.client.__all__.__len__() and __all__.__class__.__name__
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__.
# http.client.__all__ is a list of 19 public names.
# ---------------------------------------------------------------------------

invariant http_client_extra19.all_len:
  description: "http.client.__all__.__len__() == 19 — 19 public names exported"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 19

invariant http_client_extra19.all_class_name:
  description: "http.client.__all__.__class__.__name__ == 'list' — __all__ is a plain list"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# http.client.HTTP_PORT and HTTPS_PORT values and __class__.__name__
#
# http_client_extra14 covers HTTP_PORT/HTTPS_PORT existence. No prior spec
# checks __class__.__name__ for either. Both are plain int.
# ---------------------------------------------------------------------------

table http_client_extra19.port_constants:
  description: "http.client.HTTP_PORT==80, HTTPS_PORT==443; both __class__.__name__=='int'"
  kind: python_call_eq
  category: module_constants
  id_prefix: hcpc19

  columns: [id, function, args, expected, description]
  rows:
    - [HTTP_PORT_class,
       "HTTP_PORT.__class__.__name__.__eq__",
       ["int"],
       true,
       "http.client.HTTP_PORT.__class__.__name__ == 'int'"]
    - [HTTP_PORT_value,
       "HTTP_PORT.__eq__",
       [80],
       true,
       "http.client.HTTP_PORT == 80"]
    - [HTTPS_PORT_class,
       "HTTPS_PORT.__class__.__name__.__eq__",
       ["int"],
       true,
       "http.client.HTTPS_PORT.__class__.__name__ == 'int'"]
    - [HTTPS_PORT_value,
       "HTTPS_PORT.__eq__",
       [443],
       true,
       "http.client.HTTPS_PORT == 443"]

# ---------------------------------------------------------------------------
# http.client.responses.__class__.__name__ and __len__()
#
# No prior spec checks __class__.__name__ or __len__() for http.client.responses.
# responses is a dict mapping status codes to reason phrases; 62 entries on Python 3.12.
# ---------------------------------------------------------------------------

invariant http_client_extra19.responses_class_name:
  description: "http.client.responses.__class__.__name__ == 'dict' — status code mapping is a plain dict"
  category: module_constants
  kind: python_call_eq
  function: responses.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant http_client_extra19.responses_len:
  description: "http.client.responses.__len__() == 62 — 62 HTTP status codes defined on Python 3.12"
  category: module_constants
  kind: python_call_eq
  function: responses.__len__
  args: []
  expected: 62

# ---------------------------------------------------------------------------
# http.client.HTTPConnection, HTTPResponse, HTTPException __dict__.__class__.__name__
#
# No prior spec checks __dict__.__class__.__name__ for any http.client class.
# Class __dict__ is always a mappingproxy; __class__.__name__ == 'mappingproxy' (len 12).
# ---------------------------------------------------------------------------

invariant http_client_extra19.HTTPConnection_dict_class_name:
  description: "http.client.HTTPConnection.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_structure
  kind: python_call_eq
  function: "HTTPConnection.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant http_client_extra19.HTTPConnection_dict_class_name_len:
  description: "len(http.client.HTTPConnection.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"
  category: class_structure
  kind: python_call_eq
  function: "HTTPConnection.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

table http_client_extra19.class_dict_proxy_names:
  description: "http.client.HTTPResponse/HTTPException __dict__.__class__.__name__=='mappingproxy' and __len__()==12"
  kind: python_call_eq
  category: class_structure
  id_prefix: hcdpn19

  columns: [id, function, args, expected, description]
  rows:
    - [HTTPResponse_dict_class,
       "HTTPResponse.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "http.client.HTTPResponse.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [HTTPResponse_dict_class_len,
       "HTTPResponse.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]
    - [HTTPException_dict_class,
       "HTTPException.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "http.client.HTTPException.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [HTTPException_dict_class_len,
       "HTTPException.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# http.client.HTTPConnection.getresponse __qualname__ and __name__ lengths
#
# No prior spec checks __qualname__ or __name__ for getresponse.
# getresponse.__qualname__ == 'HTTPConnection.getresponse' (len 26).
# getresponse.__name__ == 'getresponse' (len 11).
# ---------------------------------------------------------------------------

invariant http_client_extra19.HTTPConnection.getresponse_qualname:
  description: "http.client.HTTPConnection.getresponse.__qualname__ == 'HTTPConnection.getresponse'"
  category: function_qualnames
  kind: python_call_eq
  function: HTTPConnection.getresponse.__qualname__.__eq__
  args: ["HTTPConnection.getresponse"]
  expected: true

invariant http_client_extra19.HTTPConnection.getresponse_qualname_len:
  description: "len(http.client.HTTPConnection.getresponse.__qualname__) == 26 — len('HTTPConnection.getresponse') == 26"
  category: function_qualnames
  kind: python_call_eq
  function: HTTPConnection.getresponse.__qualname__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# http.client.HTTPConnection.set_debuglevel and putheader __qualname__/__name__ lengths
#
# No prior spec checks __qualname__ or __name__ for set_debuglevel or putheader.
# set_debuglevel.__qualname__ == 'HTTPConnection.set_debuglevel' (len 29); __name__ == 'set_debuglevel' (len 14).
# putheader.__qualname__ == 'HTTPConnection.putheader' (len 24); __name__ == 'putheader' (len 9).
# ---------------------------------------------------------------------------

table http_client_extra19.HTTPConnection_extra_method_qualnames:
  description: "http.client.HTTPConnection.set_debuglevel/putheader __qualname__.__eq__ and __len__()"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hcemq19

  columns: [id, function, args, expected, description]
  rows:
    - [set_debuglevel_qualname,
       HTTPConnection.set_debuglevel.__qualname__.__eq__,
       ["HTTPConnection.set_debuglevel"],
       true,
       "HTTPConnection.set_debuglevel.__qualname__ == 'HTTPConnection.set_debuglevel'"]
    - [set_debuglevel_qualname_len,
       HTTPConnection.set_debuglevel.__qualname__.__len__,
       [],
       29,
       "len('HTTPConnection.set_debuglevel') == 29"]
    - [set_debuglevel_name_len,
       HTTPConnection.set_debuglevel.__name__.__len__,
       [],
       14,
       "len('set_debuglevel') == 14"]
    - [putheader_qualname,
       HTTPConnection.putheader.__qualname__.__eq__,
       ["HTTPConnection.putheader"],
       true,
       "HTTPConnection.putheader.__qualname__ == 'HTTPConnection.putheader'"]
    - [putheader_qualname_len,
       HTTPConnection.putheader.__qualname__.__len__,
       [],
       24,
       "len('HTTPConnection.putheader') == 24"]
    - [putheader_name_len,
       HTTPConnection.putheader.__name__.__len__,
       [],
       9,
       "len('putheader') == 9"]

table http_client_extra19.HTTPConnection_getresponse_name_len:
  description: "http.client.HTTPConnection.getresponse __name__.__len__() == 11"
  kind: python_call_eq
  category: function_names
  id_prefix: hcgnl19

  columns: [id, function, args, expected, description]
  rows:
    - [getresponse_name_len,
       HTTPConnection.getresponse.__name__.__len__,
       [],
       11,
       "len('getresponse') == 11"]
