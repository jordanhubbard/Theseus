spec: inspect_extra2341
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.Parameter.__slots__ == ('_name', '_kind', '_default', '_annotation'); len == 4."
    - "inspect.Signature.__slots__ == ('_return_annotation', '_parameters'); len == 2."
    - "inspect.BoundArguments.__slots__ == ('arguments', '_signature', '__weakref__'); len == 3."
    - "inspect.FullArgSpec is a namedtuple: __slots__ == () (empty); __dict__.__contains__('__slots__') == True."
    - "inspect.ArgInfo is a namedtuple: __slots__ == () (empty); __dict__.__contains__('__slots__') == True."
    - "inspect.Traceback.__dict__.__contains__('__slots__') == False (Traceback is a thin wrapper over _Traceback namedtuple; it adds no new __slots__ of its own)."
  created_at: "2026-04-12"

table inspect_extra2341.parameter_slots:
  description: "inspect.Parameter.__slots__ contains _name, _kind, _default, _annotation; len == 4"
  kind: python_call_eq
  category: slots_content
  id_prefix: in2341
  columns: [id, function, args, expected]
  rows:
    - ["in2341001", "inspect.Parameter.__slots__.__contains__", ["_name"], true]
    - ["in2341002", "inspect.Parameter.__slots__.__contains__", ["_kind"], true]
    - ["in2341003", "inspect.Parameter.__slots__.__contains__", ["_default"], true]
    - ["in2341004", "inspect.Parameter.__slots__.__contains__", ["_annotation"], true]
    - ["in2341005", "inspect.Parameter.__slots__.__len__", [], 4]
    - ["in2341006", "inspect.Parameter.__slots__.__contains__", ["nonexistent"], false]
    - ["in2341007", "inspect.Parameter.__slots__.__contains__", ["name"], false]
    - ["in2341008", "inspect.Parameter.__slots__.__contains__", ["kind"], false]

table inspect_extra2341.signature_slots:
  description: "inspect.Signature.__slots__ contains _return_annotation, _parameters; len == 2"
  kind: python_call_eq
  category: slots_content
  id_prefix: in2341
  columns: [id, function, args, expected]
  rows:
    - ["in2341009", "inspect.Signature.__slots__.__contains__", ["_return_annotation"], true]
    - ["in2341010", "inspect.Signature.__slots__.__contains__", ["_parameters"], true]
    - ["in2341011", "inspect.Signature.__slots__.__len__", [], 2]
    - ["in2341012", "inspect.Signature.__slots__.__contains__", ["nonexistent"], false]
    - ["in2341013", "inspect.Signature.__slots__.__contains__", ["return_annotation"], false]

table inspect_extra2341.bound_arguments_slots:
  description: "inspect.BoundArguments.__slots__ contains arguments, _signature, __weakref__; len == 3"
  kind: python_call_eq
  category: slots_content
  id_prefix: in2341
  columns: [id, function, args, expected]
  rows:
    - ["in2341014", "inspect.BoundArguments.__slots__.__contains__", ["arguments"], true]
    - ["in2341015", "inspect.BoundArguments.__slots__.__contains__", ["_signature"], true]
    - ["in2341016", "inspect.BoundArguments.__slots__.__contains__", ["__weakref__"], true]
    - ["in2341017", "inspect.BoundArguments.__slots__.__len__", [], 3]
    - ["in2341018", "inspect.BoundArguments.__slots__.__contains__", ["args"], false]
    - ["in2341019", "inspect.BoundArguments.__slots__.__contains__", ["kwargs"], false]

table inspect_extra2341.namedtuple_slots_empty:
  description: "inspect namedtuple types FullArgSpec and ArgInfo have __slots__==() in __dict__; Traceback does not"
  kind: python_call_eq
  category: slots_content
  id_prefix: in2341
  columns: [id, function, args, expected]
  rows:
    - ["in2341020", "inspect.FullArgSpec.__dict__.__contains__", ["__slots__"], true]
    - ["in2341021", "inspect.FullArgSpec.__slots__.__len__", [], 0]
    - ["in2341022", "inspect.ArgInfo.__dict__.__contains__", ["__slots__"], true]
    - ["in2341023", "inspect.ArgInfo.__slots__.__len__", [], 0]
    - ["in2341024", "inspect.Traceback.__dict__.__contains__", ["__slots__"], false]
