spec: io_extra29
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra28.zspec.zsdl — covers __qualname__ string lengths for io abstract base and concrete classes."
    - "io_extra26.zspec.zsdl — covers __qualname__ equality for io class objects (BytesIO, StringIO, etc.), not their methods."
    - "io_extra9.zspec.zsdl — covers __qualname__ equality for the class objects themselves, not instance methods."
  notes:
    - "This spec extends io_extra28.zspec.zsdl."
    - "Focus: __qualname__ values for io class instance methods (BytesIO.read, write, seek, tell; StringIO.read, write, getvalue; IOBase.close, readline)."
    - "No prior io spec covers __qualname__ for these methods."
    - "BytesIO.read.__qualname__ == 'BytesIO.read' — instance method qualname carries class prefix."
    - "BytesIO.write.__qualname__ == 'BytesIO.write' — instance method qualname carries class prefix."
    - "BytesIO.seek.__qualname__ == 'BytesIO.seek' — instance method qualname carries class prefix."
    - "BytesIO.tell.__qualname__ == 'BytesIO.tell' — instance method qualname carries class prefix."
    - "StringIO.read.__qualname__ == 'StringIO.read' — instance method qualname carries class prefix."
    - "StringIO.write.__qualname__ == 'StringIO.write' — instance method qualname carries class prefix."
    - "StringIO.getvalue.__qualname__ == 'StringIO.getvalue' — instance method qualname carries class prefix."
    - "IOBase.close.__qualname__ == '_IOBase.close' — IOBase is implemented in C as _IOBase; the qualname carries the internal name."
    - "IOBase.readline.__qualname__ == '_IOBase.readline' — same C-level naming as close."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for BytesIO instance methods
#
# BytesIO is a concrete bytes-oriented I/O class. Its methods (read, write,
# seek, tell) are implemented in C and exposed under the Python class name.
# For each method, __qualname__ == 'BytesIO.<method_name>'.
# No prior io spec covers __qualname__ for BytesIO instance methods.
# Verified: read='BytesIO.read', write='BytesIO.write',
#           seek='BytesIO.seek', tell='BytesIO.tell'.
# ---------------------------------------------------------------------------

table io_extra29.bytesio_method_qualnames:
  description: "__qualname__ for BytesIO instance methods read/write/seek/tell"
  kind: python_call_eq
  category: method_identity
  id_prefix: biomq29

  columns: [id, function, args, expected]
  rows:
    - [read,  BytesIO.read.__qualname__.__eq__,  ["BytesIO.read"],  true]
    - [write, BytesIO.write.__qualname__.__eq__, ["BytesIO.write"], true]
    - [seek,  BytesIO.seek.__qualname__.__eq__,  ["BytesIO.seek"],  true]
    - [tell,  BytesIO.tell.__qualname__.__eq__,  ["BytesIO.tell"],  true]

# ---------------------------------------------------------------------------
# Table: __qualname__ for StringIO instance methods
#
# StringIO is the text-mode I/O class. Its methods (read, write, getvalue)
# carry 'StringIO.<method_name>' as __qualname__.
# No prior io spec covers __qualname__ for StringIO instance methods.
# Verified: read='StringIO.read', write='StringIO.write',
#           getvalue='StringIO.getvalue'.
# ---------------------------------------------------------------------------

table io_extra29.stringio_method_qualnames:
  description: "__qualname__ for StringIO instance methods read/write/getvalue"
  kind: python_call_eq
  category: method_identity
  id_prefix: siomq29

  columns: [id, function, args, expected]
  rows:
    - [read,     StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true]
    - [write,    StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true]
    - [getvalue, StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true]

# ---------------------------------------------------------------------------
# Standalone: IOBase.close.__qualname__ == '_IOBase.close'
#
# io.IOBase is the abstract base class for all I/O. It is implemented in C as
# _io._IOBase. When accessing io.IOBase.close.__qualname__, the qualname
# reflects the C-level internal name '_IOBase.close', not the Python-exposed
# 'IOBase.close'. This is a notable distinction from pure-Python classes.
# Verified: io.IOBase.close.__qualname__ == '_IOBase.close'
# ---------------------------------------------------------------------------

invariant io_extra29.IOBase.close.qualname:
  description: "io.IOBase.close.__qualname__ == '_IOBase.close' — IOBase is implemented in C as _IOBase; qualname carries the internal C name"
  category: method_identity
  kind: python_call_eq
  function: IOBase.close.__qualname__.__eq__
  args: ["_IOBase.close"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: IOBase.readline.__qualname__ == '_IOBase.readline'
#
# Like close, readline is defined on the C-level _IOBase class. The qualname
# is '_IOBase.readline'. No prior io spec covers this method's qualname.
# Verified: io.IOBase.readline.__qualname__ == '_IOBase.readline'
# ---------------------------------------------------------------------------

invariant io_extra29.IOBase.readline.qualname:
  description: "io.IOBase.readline.__qualname__ == '_IOBase.readline' — readline is a C-level _IOBase method; qualname carries internal name"
  category: method_identity
  kind: python_call_eq
  function: IOBase.readline.__qualname__.__eq__
  args: ["_IOBase.readline"]
  expected: true
