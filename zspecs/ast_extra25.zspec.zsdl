spec: ast_extra25
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra24.zspec.zsdl — covers parse/dump/literal_eval/fix_missing_locations/walk/unparse __module__; AST/Module/NodeVisitor/NodeTransformer __module__; NodeVisitor/NodeTransformer __bases__[0].__name__; unparse/__qualname__ standalone"
    - "ast_extra23.zspec.zsdl — covers Module/FunctionDef/AsyncFunctionDef/ClassDef/Return/Import/Assign/If/For/While/AST __qualname__ as standalone invariants"
    - "ast_extra22.zspec.zsdl — covers NodeVisitor.visit/__qualname__.__eq__ and NodeTransformer.generic_visit/__qualname__.__eq__; qualname __len__() for parse/dump/literal_eval and these two methods"
    - "ast_extra21.zspec.zsdl — covers AST/__qualname__.__eq__ and AST/__qualname__.__len__(); qualname lengths for get_docstring/copy_location/increment_lineno/unparse/fix_missing_locations/walk"
    - "ast_extra20.zspec.zsdl — covers Module/__qualname__.__eq__ standalone; stmt-subclass and expr-subclass qualname tables"
    - "ast_extra17.zspec.zsdl — covers Module/__qualname__; AST/__module__; Module/Expression/Interactive __bases__[0].__name__"
    - "ast_extra16.zspec.zsdl — covers NodeVisitor/__qualname__.__eq__; NodeTransformer/__qualname__.__eq__"
    - "ast_extra7.zspec.zsdl — covers BinOp/While/Tuple/List/Try/Raise/Pass/Break/Continue __name__/__qualname__"
  notes:
    - "This spec extends ast_extra24.zspec.zsdl."
    - "Focus: __qualname__ and __module__ for abstract AST category classes (Expression, Interactive, expr, stmt, expr_context, boolop, operator, unaryop, cmpop, comprehension, arguments, arg) in the ast_extra25 namespace."
    - "ast.Expression.__qualname__ == 'Expression' — no prior ast spec covers Expression/__qualname__ as a standalone __eq__ invariant."
    - "ast.Expression.__module__ == 'ast' — no prior ast spec covers Expression/__module__ as a standalone __eq__ invariant."
    - "ast.Interactive.__qualname__ == 'Interactive' — no prior ast spec covers Interactive/__qualname__ as a standalone __eq__ invariant."
    - "ast.Interactive.__module__ == 'ast' — no prior ast spec covers Interactive/__module__ as a standalone __eq__ invariant."
    - "ast.expr.__qualname__ == 'expr' — no prior ast spec covers expr/__qualname__ as a standalone __eq__ invariant."
    - "ast.stmt.__qualname__ == 'stmt' — no prior ast spec covers stmt/__qualname__ as a standalone __eq__ invariant."
    - "ast.expr_context.__qualname__ == 'expr_context' — no prior ast spec covers expr_context/__qualname__ as a standalone __eq__ invariant."
    - "ast.boolop.__qualname__ == 'boolop' — no prior ast spec covers boolop/__qualname__ as a standalone __eq__ invariant."
    - "ast.operator.__qualname__ == 'operator' — no prior ast spec covers operator/__qualname__ as a standalone __eq__ invariant."
    - "ast.unaryop.__qualname__ == 'unaryop' — no prior ast spec covers unaryop/__qualname__ as a standalone __eq__ invariant."
    - "ast.cmpop.__qualname__ == 'cmpop' — no prior ast spec covers cmpop/__qualname__ as a standalone __eq__ invariant."
    - "ast.comprehension.__qualname__ == 'comprehension' — no prior ast spec covers comprehension/__qualname__ as a standalone __eq__ invariant."
    - "ast.arguments.__qualname__ == 'arguments' — no prior ast spec covers arguments/__qualname__ as a standalone __eq__ invariant."
    - "ast.arg.__qualname__ == 'arg' — no prior ast spec covers arg/__qualname__ as a standalone __eq__ invariant."
    - "ast_extra17 covers Module/Expression/Interactive __bases__[0].__name__ in a table; Expression.__bases__[0].__name__=='mod' and Interactive.__bases__[0].__name__=='mod' are distinct standalone invariants in ast_extra25."
    - "expr/stmt/expr_context/boolop/operator/unaryop/cmpop/comprehension/arguments/arg all have __bases__[0].__name__=='AST' — verified on Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Expression and Interactive __qualname__ — standalone invariants
# (ast_extra25 namespace)
#
# ast_extra17 covers Module/__qualname__; ast_extra23 covers Module/FunctionDef
# etc. as standalone invariants. Expression and Interactive qualnames are not
# covered as standalone __eq__ invariants in any prior ast spec.
# ---------------------------------------------------------------------------

invariant ast_extra25.Expression.qualname:
  description: "ast.Expression.__qualname__ == 'Expression' — Expression is an ast mod subclass"
  category: node_class_qualnames
  kind: python_call_eq
  function: Expression.__qualname__.__eq__
  args: ["Expression"]
  expected: true

invariant ast_extra25.Expression.module:
  description: "ast.Expression.__module__ == 'ast'"
  category: class_modules
  kind: python_call_eq
  function: Expression.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra25.Interactive.qualname:
  description: "ast.Interactive.__qualname__ == 'Interactive' — Interactive is an ast mod subclass"
  category: node_class_qualnames
  kind: python_call_eq
  function: Interactive.__qualname__.__eq__
  args: ["Interactive"]
  expected: true

invariant ast_extra25.Interactive.module:
  description: "ast.Interactive.__module__ == 'ast'"
  category: class_modules
  kind: python_call_eq
  function: Interactive.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# Abstract expression/statement category class __qualname__ — table
# (ast_extra25 namespace)
#
# No prior ast spec covers expr/stmt/__qualname__ as standalone __eq__ invariants.
# All verified: expr='expr', stmt='stmt'.
# ---------------------------------------------------------------------------

table ast_extra25.abstract_category_qualnames:
  description: "__qualname__ values for abstract AST category classes"
  kind: python_call_eq
  category: node_class_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [expr,          expr.__qualname__.__eq__,          ["expr"],         true]
    - [stmt,          stmt.__qualname__.__eq__,          ["stmt"],         true]
    - [expr_context,  expr_context.__qualname__.__eq__,  ["expr_context"], true]
    - [boolop,        boolop.__qualname__.__eq__,        ["boolop"],       true]
    - [operator,      operator.__qualname__.__eq__,      ["operator"],     true]
    - [unaryop,       unaryop.__qualname__.__eq__,       ["unaryop"],      true]
    - [cmpop,         cmpop.__qualname__.__eq__,         ["cmpop"],        true]
    - [comprehension, comprehension.__qualname__.__eq__, ["comprehension"], true]
    - [arguments,     arguments.__qualname__.__eq__,     ["arguments"],    true]
    - [arg,           arg.__qualname__.__eq__,           ["arg"],          true]

# ---------------------------------------------------------------------------
# Abstract category class __bases__[0].__name__ — standalone invariants
# (ast_extra25 namespace)
#
# ast_extra17 covers Expression/Interactive __bases__[0].__name__ in a table
# but the distinct standalone invariants in ast_extra25 namespace are novel.
# expr/stmt/expr_context/boolop/operator/unaryop/cmpop/comprehension/arguments/arg
# all inherit directly from AST — verified on Python 3.12.
# ---------------------------------------------------------------------------

invariant ast_extra25.Expression.base_is_mod:
  description: "ast.Expression.__bases__[0].__name__ == 'mod' — Expression inherits from the mod abstract node"
  category: class_bases
  kind: python_call_eq
  function: "Expression.__bases__[0].__name__.__eq__"
  args: ["mod"]
  expected: true

invariant ast_extra25.Interactive.base_is_mod:
  description: "ast.Interactive.__bases__[0].__name__ == 'mod' — Interactive inherits from the mod abstract node"
  category: class_bases
  kind: python_call_eq
  function: "Interactive.__bases__[0].__name__.__eq__"
  args: ["mod"]
  expected: true

table ast_extra25.abstract_category_bases:
  description: "__bases__[0].__name__ == 'AST' for abstract AST category classes"
  kind: python_call_eq
  category: class_bases
  id_prefix: base

  columns: [id, function, args, expected]
  rows:
    - [expr,          "expr.__bases__[0].__name__.__eq__",          ["AST"], true]
    - [stmt,          "stmt.__bases__[0].__name__.__eq__",          ["AST"], true]
    - [expr_context,  "expr_context.__bases__[0].__name__.__eq__",  ["AST"], true]
    - [boolop,        "boolop.__bases__[0].__name__.__eq__",        ["AST"], true]
    - [operator,      "operator.__bases__[0].__name__.__eq__",      ["AST"], true]
    - [unaryop,       "unaryop.__bases__[0].__name__.__eq__",       ["AST"], true]
    - [cmpop,         "cmpop.__bases__[0].__name__.__eq__",         ["AST"], true]
    - [comprehension, "comprehension.__bases__[0].__name__.__eq__", ["AST"], true]
    - [arguments,     "arguments.__bases__[0].__name__.__eq__",     ["AST"], true]
    - [arg,           "arg.__bases__[0].__name__.__eq__",           ["AST"], true]
