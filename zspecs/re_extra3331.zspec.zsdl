spec: re3331
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (re3331): __iand__, __ior__, __ixor__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __iand__, __ior__, __ixor__ dict-presence (in-place &=, |=, ^=)."
    - "No re class defines __iand__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; bitwise AND has no meaning for them."
    - "No re class defines __ior__ in its own __dict__: re types are not bitwise operands; in-place bitwise OR is not defined on any re type."
    - "No re class defines __ixor__ in its own __dict__: in-place bitwise XOR is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): although IntFlag defines bitwise operators (|, &, ^) at the class level, the in-place augmented assignment methods __iand__, __ior__, __ixor__ are not present in re.RegexFlag.__dict__ itself; they are not stored directly on the class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with waves 666/667/668 pattern: all in-place arithmetic/bitwise operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iand__ dict-presence — operator.contains(Cls.__dict__, '__iand__')
#
# No re class defines __iand__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but in-place bitwise AND is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3331.iand:
  description: "re types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3331

  columns: [id, function, args, expected]
  rows:
    - ["re3331001", operator.contains, [re.Pattern.__dict__,   "__iand__"], false]
    - ["re3331002", operator.contains, [re.Match.__dict__,     "__iand__"], false]
    - ["re3331003", operator.contains, [re.RegexFlag.__dict__, "__iand__"], false]

# ---------------------------------------------------------------------------
# __ior__ dict-presence — operator.contains(Cls.__dict__, '__ior__')
#
# No re class defines __ior__ in its own __dict__; all false.
# re types are not bitwise operands; in-place bitwise OR is not part
# of the re type protocol. re.RegexFlag (IntFlag) does not define __ior__
# in its own __dict__.
# ---------------------------------------------------------------------------

