spec: inspect_extra2446
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave (_extra2446): __enter__/__exit__ context manager protocol dict-presence checks."
    - "inspect.Parameter does not define __enter__ or __exit__ — not a context manager."
    - "inspect.Signature does not define __enter__ or __exit__ — not a context manager."
    - "inspect.BoundArguments does not define __enter__ or __exit__ — not a context manager."
    - "inspect.FrameInfo does not define __enter__ or __exit__ — not a context manager."
    - "inspect.BlockFinder does not define __enter__ or __exit__ — not a context manager."
    - "inspect.ClassFoundException does not define __enter__ or __exit__ — not a context manager."
    - "inspect.EndOfBlock does not define __enter__ or __exit__ — not a context manager."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table inspect_extra2446.enter_protocol:
  description: "inspect types __enter__ dict-presence checks — none are context managers"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2446
  columns: [id, function, args, expected]
  rows:
    - ["in2446001", "inspect.Parameter.__dict__.__contains__",          ["__enter__"], false]
    - ["in2446002", "inspect.Signature.__dict__.__contains__",          ["__enter__"], false]
    - ["in2446003", "inspect.BoundArguments.__dict__.__contains__",     ["__enter__"], false]
    - ["in2446004", "inspect.FrameInfo.__dict__.__contains__",          ["__enter__"], false]
    - ["in2446005", "inspect.BlockFinder.__dict__.__contains__",        ["__enter__"], false]
    - ["in2446006", "inspect.ClassFoundException.__dict__.__contains__", ["__enter__"], false]
    - ["in2446007", "inspect.EndOfBlock.__dict__.__contains__",         ["__enter__"], false]

table inspect_extra2446.exit_protocol:
  description: "inspect types __exit__ dict-presence checks — none are context managers"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2446
  columns: [id, function, args, expected]
  rows:
    - ["in2446008", "inspect.Parameter.__dict__.__contains__",          ["__exit__"], false]
    - ["in2446009", "inspect.Signature.__dict__.__contains__",          ["__exit__"], false]
    - ["in2446010", "inspect.BoundArguments.__dict__.__contains__",     ["__exit__"], false]
    - ["in2446011", "inspect.FrameInfo.__dict__.__contains__",          ["__exit__"], false]
    - ["in2446012", "inspect.BlockFinder.__dict__.__contains__",        ["__exit__"], false]
    - ["in2446013", "inspect.ClassFoundException.__dict__.__contains__", ["__exit__"], false]
    - ["in2446014", "inspect.EndOfBlock.__dict__.__contains__",         ["__exit__"], false]

table inspect_extra2446.own_attrs:
  description: "inspect types define their own domain-specific attrs (not context manager protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2446
  columns: [id, function, args, expected]
  rows:
    - ["in2446015", "inspect.Parameter.__dict__.__contains__",      ["__init__"],          true]
    - ["in2446016", "inspect.Parameter.__dict__.__contains__",      ["kind"],              true]
    - ["in2446017", "inspect.Parameter.__dict__.__contains__",      ["default"],           true]
    - ["in2446018", "inspect.Parameter.__dict__.__contains__",      ["annotation"],        true]
    - ["in2446019", "inspect.Parameter.__dict__.__contains__",      ["replace"],           true]
    - ["in2446020", "inspect.Parameter.__dict__.__contains__",      ["name"],              true]
    - ["in2446021", "inspect.Signature.__dict__.__contains__",      ["parameters"],        true]
    - ["in2446022", "inspect.Signature.__dict__.__contains__",      ["return_annotation"], true]
    - ["in2446023", "inspect.Signature.__dict__.__contains__",      ["bind"],              true]
    - ["in2446024", "inspect.Signature.__dict__.__contains__",      ["replace"],           true]
    - ["in2446025", "inspect.Signature.__dict__.__contains__",      ["from_callable"],     true]
    - ["in2446026", "inspect.BoundArguments.__dict__.__contains__", ["args"],              true]
    - ["in2446027", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"],            true]
    - ["in2446028", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"],    true]
    - ["in2446029", "inspect.BoundArguments.__dict__.__contains__", ["signature"],         true]
    - ["in2446030", "inspect.BoundArguments.__dict__.__contains__", ["arguments"],         true]
