spec: pathlib_extra370
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path method __name__ attributes all match their Python-level names: cwd, home, stat, is_file, is_dir, exists, mkdir, unlink"
    - "pathlib.Path.cwd and pathlib.Path.home are classmethods; their __name__ reflects the underlying function name"
    - "All __name__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __name__ identity — classmethods: cwd, home
# ---------------------------------------------------------------------------

table pathlib_extra370.path_classmethod_names:
  description: "pathlib.Path classmethod __name__ identity — cwd and home are classmethods that construct new Path instances; their __name__ matches their Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: plclsm370

  columns: [id, function, args, expected]
  rows:
    - [cwd_name,  pathlib.Path.cwd.__name__.__eq__,  ["cwd"],  true]
    - [home_name, pathlib.Path.home.__name__.__eq__, ["home"], true]

# ---------------------------------------------------------------------------
# pathlib.Path method __name__ identity — instance methods
# ---------------------------------------------------------------------------

table pathlib_extra370.path_instance_method_names:
  description: "pathlib.Path instance method __name__ identity — stat, is_file, is_dir, exists, mkdir, unlink; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: plinstm370

  columns: [id, function, args, expected]
  rows:
    - [stat_name,    pathlib.Path.stat.__name__.__eq__,    ["stat"],    true]
    - [is_file_name, pathlib.Path.is_file.__name__.__eq__, ["is_file"], true]
    - [is_dir_name,  pathlib.Path.is_dir.__name__.__eq__,  ["is_dir"],  true]
    - [exists_name,  pathlib.Path.exists.__name__.__eq__,  ["exists"],  true]
    - [mkdir_name,   pathlib.Path.mkdir.__name__.__eq__,   ["mkdir"],   true]
    - [unlink_name,  pathlib.Path.unlink.__name__.__eq__,  ["unlink"],  true]
