spec: gc_extra31
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc_extra30.zspec.zsdl."
    - "Prior specs covered: collect/disable/enable/isenabled __module__.__len__() (all 2) (extra30); collect/disable/enable/isenabled/get_count/get_threshold/set_threshold/get_objects __name__.__len__() (extra30)."
    - "This spec covers: get_count.__module__.__len__() (NOVEL — extra30 covers __name__.__len__ but not __module__.__len__ for get_count); get_threshold.__module__.__len__() (NOVEL); set_threshold.__module__.__len__() (NOVEL); get_objects.__module__.__len__() (NOVEL); get_referrers.__module__.__len__() (NOVEL); get_referents.__module__.__len__() (NOVEL); get_referrers.__name__.__len__() (NOVEL); get_referents.__name__.__len__() (NOVEL); get_referrers.__qualname__.__len__() (NOVEL); get_referents.__qualname__.__len__() (NOVEL); get_count.__qualname__.__len__() (NOVEL); get_threshold.__qualname__.__len__() (NOVEL)."
    - "gc.get_count.__module__ == 'gc' (len 2). All gc C builtins share the 'gc' module name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_threshold.__module__ == 'gc' (len 2). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.set_threshold.__module__ == 'gc' (len 2). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_objects.__module__ == 'gc' (len 2). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_referrers.__module__ == 'gc' (len 2). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_referents.__module__ == 'gc' (len 2). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_referrers.__name__ == 'get_referrers' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_referents.__name__ == 'get_referents' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_referrers.__qualname__ == 'get_referrers' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_referents.__qualname__ == 'get_referents' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_count.__qualname__ == 'get_count' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_threshold.__qualname__ == 'get_threshold' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc.get_count.__module__.__len__()
#
# extra30 covers get_count.__name__.__len__() == 9 from extra30 namespace.
# No prior spec verifies get_count.__module__.__len__() in any namespace.
# get_count.__module__ == 'gc', len('gc') == 2. Novel.
# ---------------------------------------------------------------------------

invariant gc_extra31.get_count.module.len:
  description: "gc.get_count.__module__.__len__() == 2 — 'gc' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: get_count.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# gc.get_threshold.__module__.__len__()
#
# extra30 covers get_threshold.__name__.__len__() == 13.
# No prior spec verifies get_threshold.__module__.__len__().
# get_threshold.__module__ == 'gc', len('gc') == 2. Novel.
# ---------------------------------------------------------------------------

invariant gc_extra31.get_threshold.module.len:
  description: "gc.get_threshold.__module__.__len__() == 2 — 'gc' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: get_threshold.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# gc.set_threshold.__module__.__len__()
#
# extra30 covers set_threshold.__name__.__len__() == 13.
# No prior spec verifies set_threshold.__module__.__len__().
# set_threshold.__module__ == 'gc', len('gc') == 2. Novel.
# ---------------------------------------------------------------------------

invariant gc_extra31.set_threshold.module.len:
  description: "gc.set_threshold.__module__.__len__() == 2 — 'gc' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: set_threshold.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# gc.get_objects.__module__.__len__()
#
# extra30 covers get_objects.__name__.__len__() == 11.
# No prior spec verifies get_objects.__module__.__len__().
# get_objects.__module__ == 'gc', len('gc') == 2. Novel.
# ---------------------------------------------------------------------------

invariant gc_extra31.get_objects.module.len:
  description: "gc.get_objects.__module__.__len__() == 2 — 'gc' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: get_objects.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# gc.get_referrers.__name__.__len__() and __module__.__len__()
#
# No prior spec verifies get_referrers.__name__.__len__() or
# __module__.__len__(). get_referrers.__name__ == 'get_referrers' (13);
# __module__ == 'gc' (2). Both novel.
# ---------------------------------------------------------------------------

invariant gc_extra31.get_referrers.name.len:
  description: "gc.get_referrers.__name__.__len__() == 13 — 'get_referrers' has 13 characters"
  category: string_length
  kind: python_call_eq
  function: get_referrers.__name__.__len__
  args: []
  expected: 13

invariant gc_extra31.get_referrers.module.len:
  description: "gc.get_referrers.__module__.__len__() == 2 — 'gc' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: get_referrers.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# gc.get_referents.__name__.__len__() and __module__.__len__()
#
# No prior spec verifies get_referents.__name__.__len__() or
# __module__.__len__(). get_referents.__name__ == 'get_referents' (13);
# __module__ == 'gc' (2). Both novel.
# ---------------------------------------------------------------------------

invariant gc_extra31.get_referents.name.len:
  description: "gc.get_referents.__name__.__len__() == 13 — 'get_referents' has 13 characters"
  category: string_length
  kind: python_call_eq
  function: get_referents.__name__.__len__
  args: []
  expected: 13

invariant gc_extra31.get_referents.module.len:
  description: "gc.get_referents.__module__.__len__() == 2 — 'gc' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: get_referents.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Consolidated table — __module__.__len__() for get_count through get_objects
#
# Covers the four functions where extra30 covered __name__ but not __module__:
# get_count, get_threshold, set_threshold, get_objects. All have __module__ == 'gc'
# (len 2). Plus get_referrers and get_referents as completely novel entries.
# ---------------------------------------------------------------------------

table gc_extra31.extended_module_lengths:
  description: "String lengths of __module__ for gc builtins not covered in extra30 — get_count, get_threshold, set_threshold, get_objects, get_referrers, get_referents"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected]
  rows:
    - [get_count_module_len,      get_count.__module__.__len__,      [], 2]
    - [get_threshold_module_len,  get_threshold.__module__.__len__,  [], 2]
    - [set_threshold_module_len,  set_threshold.__module__.__len__,  [], 2]
    - [get_objects_module_len,    get_objects.__module__.__len__,    [], 2]
    - [get_referrers_module_len,  get_referrers.__module__.__len__,  [], 2]
    - [get_referents_module_len,  get_referents.__module__.__len__,  [], 2]

# ---------------------------------------------------------------------------
# Consolidated table — __name__.__len__() and __qualname__.__len__() for
# get_referrers, get_referents, get_count, get_threshold
#
# get_referrers and get_referents are completely new; get_count and
# get_threshold __qualname__.__len__() are also novel (extra30 only covers
# __name__.__len__ for those two).
# ---------------------------------------------------------------------------

table gc_extra31.referrer_referent_name_lengths:
  description: "gc get_referrers/get_referents __name__ and __qualname__ lengths, plus get_count/get_threshold __qualname__ lengths"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected]
  rows:
    - [get_referrers_name_len,      get_referrers.__name__.__len__,      [], 13]
    - [get_referents_name_len,      get_referents.__name__.__len__,      [], 13]
    - [get_referrers_qualname_len,  get_referrers.__qualname__.__len__,  [], 13]
    - [get_referents_qualname_len,  get_referents.__qualname__.__len__,  [], 13]
    - [get_count_qualname_len,      get_count.__qualname__.__len__,      [], 9]
    - [get_threshold_qualname_len,  get_threshold.__qualname__.__len__,  [], 13]
