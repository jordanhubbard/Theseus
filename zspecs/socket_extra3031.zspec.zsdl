spec: sk3031
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (sk3031): __missing__, __init_subclass__, __class_getitem__ dict-presence checks for socket types."
    - "socket.socket is a networking file descriptor wrapper — not a mapping or generic alias; it does not define __missing__, __init_subclass__, or __class_getitem__ in its own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses — integral enum types do not expose __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "type(socket.socket()) is identical to socket.socket — verified on Python 3.14.4."
    - "None of the socket types define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3031.missing:
  description: "socket types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk3031
  columns: [id, function, args, expected]
  rows:
    - ["sk3031001", operator.contains, [socket.socket.__dict__,            "__missing__"], false]
    - ["sk3031002", operator.contains, [socket.AddressFamily.__dict__,     "__missing__"], false]
    - ["sk3031003", operator.contains, [socket.SocketKind.__dict__,        "__missing__"], false]
    - ["sk3031004", operator.contains, [type(socket.socket()).__dict__,    "__missing__"], false]

