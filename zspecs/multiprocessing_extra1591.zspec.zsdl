spec: multiprocessing_extra1591
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol"
    - "multiprocessing classes do not implement __get__, __set__, or __delete__ in their own __dict__"
    - "Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

table multiprocessing_extra1591.process_no_descriptor:
  description: "multiprocessing.Process, pool.Pool, pool.AsyncResult, and queues.Queue do not define descriptor protocol methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1591pr

  columns: [id, function, args, expected]
  rows:
    - ["mp1591pr001", "multiprocessing.Process.__dict__.__contains__",           ["__get__"],    false]
    - ["mp1591pr002", "multiprocessing.Process.__dict__.__contains__",           ["__set__"],    false]
    - ["mp1591pr003", "multiprocessing.Process.__dict__.__contains__",           ["__delete__"], false]
    - ["mp1591pr004", "multiprocessing.pool.Pool.__dict__.__contains__",         ["__get__"],    false]
    - ["mp1591pr005", "multiprocessing.pool.Pool.__dict__.__contains__",         ["__set__"],    false]
    - ["mp1591pr006", "multiprocessing.pool.Pool.__dict__.__contains__",         ["__delete__"], false]
    - ["mp1591pr007", "multiprocessing.pool.AsyncResult.__dict__.__contains__",  ["__get__"],    false]
    - ["mp1591pr008", "multiprocessing.pool.AsyncResult.__dict__.__contains__",  ["__set__"],    false]
    - ["mp1591pr009", "multiprocessing.pool.AsyncResult.__dict__.__contains__",  ["__delete__"], false]
    - ["mp1591pr010", "multiprocessing.queues.Queue.__dict__.__contains__",      ["__get__"],    false]
    - ["mp1591pr011", "multiprocessing.queues.Queue.__dict__.__contains__",      ["__set__"],    false]
    - ["mp1591pr012", "multiprocessing.queues.Queue.__dict__.__contains__",      ["__delete__"], false]
    - ["mp1591pr013", "multiprocessing.Process.__dict__.__contains__",           ["__module__"], true]
    - ["mp1591pr014", "multiprocessing.Process.__dict__.__contains__",           ["__doc__"],    true]
    - ["mp1591pr015", "multiprocessing.pool.Pool.__dict__.__contains__",         ["apply"],      true]
    - ["mp1591pr016", "multiprocessing.pool.Pool.__dict__.__contains__",         ["map"],        true]
    - ["mp1591pr017", "multiprocessing.pool.Pool.__dict__.__contains__",         ["close"],      true]
    - ["mp1591pr018", "multiprocessing.pool.Pool.__dict__.__contains__",         ["__module__"], true]
    - ["mp1591pr019", "multiprocessing.pool.Pool.__dict__.__contains__",         ["__doc__"],    true]
    - ["mp1591pr020", "multiprocessing.pool.AsyncResult.__dict__.__contains__",  ["get"],        true]
    - ["mp1591pr021", "multiprocessing.pool.AsyncResult.__dict__.__contains__",  ["ready"],      true]
    - ["mp1591pr022", "multiprocessing.pool.AsyncResult.__dict__.__contains__",  ["wait"],       true]
    - ["mp1591pr023", "multiprocessing.queues.Queue.__dict__.__contains__",      ["put"],        true]
    - ["mp1591pr024", "multiprocessing.queues.Queue.__dict__.__contains__",      ["get"],        true]
    - ["mp1591pr025", "multiprocessing.Process.__dict__.__contains__",           ["__set_name__"], false]
    - ["mp1591pr026", "multiprocessing.pool.Pool.__dict__.__contains__",         ["__set_name__"], false]
    - ["mp1591pr027", "multiprocessing.queues.Queue.__dict__.__contains__",      ["__module__"], true]

table multiprocessing_extra1591.exceptions_no_descriptor:
  description: "multiprocessing exception classes do not define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1591ex

  columns: [id, function, args, expected]
  rows:
    - ["mp1591ex001", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__get__"],    false]
    - ["mp1591ex002", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__set__"],    false]
    - ["mp1591ex003", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__delete__"], false]
    - ["mp1591ex004", "multiprocessing.ProcessError.__dict__.__contains__",        ["__get__"],    false]
    - ["mp1591ex005", "multiprocessing.ProcessError.__dict__.__contains__",        ["__set__"],    false]
    - ["mp1591ex006", "multiprocessing.ProcessError.__dict__.__contains__",        ["__delete__"], false]
    - ["mp1591ex007", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__get__"],    false]
    - ["mp1591ex008", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__set__"],    false]
    - ["mp1591ex009", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__delete__"], false]
    - ["mp1591ex010", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__get__"],    false]
    - ["mp1591ex011", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__set__"],    false]
    - ["mp1591ex012", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__delete__"], false]
    - ["mp1591ex013", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__module__"], true]
    - ["mp1591ex014", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__doc__"],    true]
    - ["mp1591ex015", "multiprocessing.ProcessError.__dict__.__contains__",        ["__module__"], true]
    - ["mp1591ex016", "multiprocessing.ProcessError.__dict__.__contains__",        ["__doc__"],    true]
    - ["mp1591ex017", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__module__"], true]
    - ["mp1591ex018", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__doc__"],    true]
    - ["mp1591ex019", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__module__"], true]
    - ["mp1591ex020", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__doc__"],    true]
    - ["mp1591ex021", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__set_name__"], false]
    - ["mp1591ex022", "multiprocessing.ProcessError.__dict__.__contains__",        ["__set_name__"], false]
    - ["mp1591ex023", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__set_name__"], false]
    - ["mp1591ex024", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__set_name__"], false]
    - ["mp1591ex025", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__init__"],   false]
    - ["mp1591ex026", "multiprocessing.ProcessError.__dict__.__contains__",        ["__init__"],   false]
    - ["mp1591ex027", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__init__"],   false]
    - ["mp1591ex028", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__init__"],   false]
