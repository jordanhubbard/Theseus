spec: copyreg_extra2
version: ">=3.9"
backend: python_module(copyreg)

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copyreg.html — Python copyreg module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copyreg.py"
  notes:
    - "This spec extends copyreg.zspec.zsdl and copyreg_extra.zspec.zsdl with additional name, module, and dispatch_table invariants."
    - "copyreg.pickle.__name__ == 'pickle' — the public API function name."
    - "copyreg.pickle.__module__ == 'copyreg' — function is defined in the copyreg module."
    - "copyreg.add_extension.__name__ == 'add_extension' — registers (module, name) -> code mappings for pickle optimization."
    - "copyreg.remove_extension.__name__ == 'remove_extension' — removes a registered extension code."
    - "copyreg.clear_extension_cache.__name__ == 'clear_extension_cache' — clears the runtime code-to-name cache."
    - "copyreg.dispatch_table is a plain dict mapping types to their registered reduce functions."
    - "copyreg.dispatch_table.__class__.__name__ == 'dict' — must be an exact dict, not a subclass."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — pickle, add_extension, remove_extension,
# clear_extension_cache
# ---------------------------------------------------------------------------

invariant copyreg_extra2.names.pickle:
  description: "copyreg.pickle.__name__ == 'pickle'"
  category: names
  kind: python_call_eq
  function: pickle.__name__.__eq__
  args: ["pickle"]
  expected: true

invariant copyreg_extra2.names.add_extension:
  description: "copyreg.add_extension.__name__ == 'add_extension'"
  category: names
  kind: python_call_eq
  function: add_extension.__name__.__eq__
  args: ["add_extension"]
  expected: true

invariant copyreg_extra2.names.remove_extension:
  description: "copyreg.remove_extension.__name__ == 'remove_extension'"
  category: names
  kind: python_call_eq
  function: remove_extension.__name__.__eq__
  args: ["remove_extension"]
  expected: true

invariant copyreg_extra2.names.clear_extension_cache:
  description: "copyreg.clear_extension_cache.__name__ == 'clear_extension_cache'"
  category: names
  kind: python_call_eq
  function: clear_extension_cache.__name__.__eq__
  args: ["clear_extension_cache"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — all public functions belong to copyreg
# ---------------------------------------------------------------------------

invariant copyreg_extra2.module.pickle:
  description: "copyreg.pickle.__module__ == 'copyreg'"
  category: module
  kind: python_call_eq
  function: pickle.__module__.__eq__
  args: ["copyreg"]
  expected: true

invariant copyreg_extra2.module.add_extension:
  description: "copyreg.add_extension.__module__ == 'copyreg'"
  category: module
  kind: python_call_eq
  function: add_extension.__module__.__eq__
  args: ["copyreg"]
  expected: true

invariant copyreg_extra2.module.remove_extension:
  description: "copyreg.remove_extension.__module__ == 'copyreg'"
  category: module
  kind: python_call_eq
  function: remove_extension.__module__.__eq__
  args: ["copyreg"]
  expected: true

invariant copyreg_extra2.module.clear_extension_cache:
  description: "copyreg.clear_extension_cache.__module__ == 'copyreg'"
  category: module
  kind: python_call_eq
  function: clear_extension_cache.__module__.__eq__
  args: ["copyreg"]
  expected: true

# ---------------------------------------------------------------------------
# Callable type checks — all exports are plain Python functions
# ---------------------------------------------------------------------------

invariant copyreg_extra2.callable_type.pickle:
  description: "copyreg.pickle.__class__.__name__ == 'function' — pickle is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: pickle.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant copyreg_extra2.callable_type.add_extension:
  description: "copyreg.add_extension.__class__.__name__ == 'function' — add_extension is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: add_extension.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant copyreg_extra2.callable_type.remove_extension:
  description: "copyreg.remove_extension.__class__.__name__ == 'function' — remove_extension is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: remove_extension.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant copyreg_extra2.callable_type.clear_extension_cache:
  description: "copyreg.clear_extension_cache.__class__.__name__ == 'function' — clear_extension_cache is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: clear_extension_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# dispatch_table — must be a plain dict
# ---------------------------------------------------------------------------

invariant copyreg_extra2.dispatch_table.is_dict:
  description: "copyreg.dispatch_table.__class__.__name__ == 'dict' — dispatch_table is a plain dict"
  category: dispatch_table
  kind: python_call_eq
  function: dispatch_table.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant copyreg_extra2.dispatch_table.class_is_type:
  description: "copyreg.dispatch_table.__class__.__class__.__name__ == 'type' — the dict class is itself a type"
  category: dispatch_table
  kind: python_call_eq
  function: dispatch_table.__class__.__class__.__name__.__eq__
  args: ["type"]
  expected: true
