  "types": {
    "format_string": {
      "description": "A string beginning with an optional endianness prefix ('>', '<', '!', '=', '@') followed by one or more format characters (B, b, H, h, I, i, Q, q, f, d, s, p, x). Each character specifies the type of one field.",
      "fields": []
    }
  },

  "functions": {
    "struct.pack": {
      "description": "Pack the given values according to the format string. Returns bytes of length calcsize(fmt).",
      "parameters": [
        { "name": "format", "ctype": "str",   "direction": "in", "description": "Format string" },
        { "name": "v1..vN","ctype": "any",    "direction": "in", "description": "Values to pack — one per format character" }
      ],
      "return_type": "bytes",
      "postconditions": [
        "len(pack(fmt, *values)) == calcsize(fmt)",
        "unpack(fmt, pack(fmt, *values)) == values (for integer types)"
      ]
    },
    "struct.unpack": {
      "description": "Unpack from the buffer according to the format string. Returns a tuple with one element per format character.",
      "parameters": [
        { "name": "format", "ctype": "str",   "direction": "in", "description": "Format string" },
        { "name": "buffer", "ctype": "bytes", "direction": "in", "description": "Bytes to unpack; len(buffer) must equal calcsize(fmt)" }
      ],
      "return_type": "tuple",
      "return_values": {
        "tuple":        "Unpacked values, one per format character",
        "struct.error": "If len(buffer) != calcsize(fmt)"
      }
    },
    "struct.calcsize": {
      "description": "Return the number of bytes required to pack the values described by the format string.",
      "parameters": [
        { "name": "format", "ctype": "str", "direction": "in", "description": "Format string" }
      ],
      "return_type": "int",
      "postconditions": [
        "calcsize(fmt) == len(pack(fmt, *values)) for any valid values"
      ]
    }
  },

