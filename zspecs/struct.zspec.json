    "backend": "python_module",
    "module_name": "struct",
    "soname_patterns": [],
    "version_function": null,
    "notes": "struct is a Python stdlib module with a C accelerator (_struct extension module). The behavioral spec is identical regardless of which implementation is active."
  },

