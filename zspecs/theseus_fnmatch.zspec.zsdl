spec: theseus_fnmatch
version: ">=3.9"
backend: python_cleanroom(theseus_fnmatch)
blocks: fnmatch

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html"
  notes:
    - "Clean-room fnmatch implementation. Do NOT import fnmatch."
    - "fnmatch(filename, pattern) — Unix shell-style wildcard matching."
    - "'*' matches everything, '?' matches one character, '[abc]' matches char class."
    - "fnmatch('foo.py', '*.py') == True."
    - "fnmatch('foo.txt', '*.py') == False."
    - "fnmatch('file_a.py', 'file_?.py') == True."
    - "Export: fnmatch(name: str, pat: str) -> bool."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_fnmatch.match_star:
  description: "fnmatch('foo.py', '*.py') == True"
  category: match
  kind: python_call_eq
  function: fnmatch_star_match
  args: []
  expected: true

invariant theseus_fnmatch.no_match:
  description: "fnmatch('foo.txt', '*.py') == False"
  category: match
  kind: python_call_eq
  function: fnmatch_star_no_match
  args: []
  expected: false

invariant theseus_fnmatch.question_mark:
  description: "fnmatch('file_a.py', 'file_?.py') == True"
  category: match
  kind: python_call_eq
  function: fnmatch_question_match
  args: []
  expected: true
