spec: concurrent_futures_extra40
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra39.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, BrokenExecutor/__bases__[0].__name__.__len__()==12, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, __spec__.__class__.__name__.__len__()==10, ThreadPoolExecutor/__name__=='ThreadPoolExecutor' (extra36), ProcessPoolExecutor/__name__=='ProcessPoolExecutor' (extra36), executor __module__ string equality (extra36), wait/__name__=='wait' (extra36), function __module__ string equality (extra36), Executor/__name__=='Executor'/__module__==concurrent.futures._base (extra37), Executor map/submit qualname lengths (extra37), InvalidStateError/BrokenExecutor __name__/__module__ string equality (extra37), ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths all 5 (extra38), ProcessPoolExecutor/__mro__.__len__()==3, ThreadPoolExecutor/__mro__.__len__()==3, Future/__mro__.__len__()==2, Executor/__mro__.__len__()==2, Executor/__bases__[0].__name__=='object', sentinel __class__.__name__=='str' (extra39)."
    - "This spec covers: ThreadPoolExecutor/__qualname__=='ThreadPoolExecutor' (18 chars); ThreadPoolExecutor/__qualname__.__len__()==18; ProcessPoolExecutor/__qualname__=='ProcessPoolExecutor' (19 chars); ProcessPoolExecutor/__qualname__.__len__()==19; Future/__qualname__=='Future' (6 chars); Executor/__qualname__=='Executor' (8 chars); CancelledError/__qualname__=='CancelledError' (14 chars); BrokenExecutor/__qualname__=='BrokenExecutor' (14 chars)."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (18 chars). ThreadPoolExecutor is a top-level class in concurrent.futures.thread; __qualname__ equals __name__ for top-level classes. len('ThreadPoolExecutor') == 18: T-h-r-e-a-d-P-o-o-l-E-x-e-c-u-t-o-r = 18."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (19 chars). ProcessPoolExecutor is a top-level class in concurrent.futures.process; __qualname__ equals __name__ for top-level classes. len('ProcessPoolExecutor') == 19: P-r-o-c-e-s-s-P-o-o-l-E-x-e-c-u-t-o-r = 19."
    - "concurrent.futures.Future.__qualname__ == 'Future' (6 chars). Future is defined at module level in concurrent.futures._base; __qualname__ equals __name__. len('Future') == 6."
    - "concurrent.futures.Executor.__qualname__ == 'Executor' (8 chars). Executor is the abstract base class defined in concurrent.futures._base; __qualname__ equals __name__. len('Executor') == 8."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (14 chars). CancelledError is a top-level exception class; __qualname__ equals __name__. len('CancelledError') == 14."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (14 chars). BrokenExecutor is a top-level exception class; __qualname__ equals __name__. len('BrokenExecutor') == 14. Note: CancelledError and BrokenExecutor share the same __qualname__ length of 14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor class __qualname__ — extra40 namespace
#
# All four core classes have __qualname__ equal to __name__ (top-level classes):
#   ThreadPoolExecutor.__qualname__  == 'ThreadPoolExecutor'  (18 chars)
#   ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (19 chars)
#   Future.__qualname__              == 'Future'              ( 6 chars)
#   Executor.__qualname__            == 'Executor'            ( 8 chars)
# Prior specs in extra36/extra37 captured __qualname__ string equality for
# individual classes; extra40 captures all four in one table together with
# their __len__() measurements.
# ---------------------------------------------------------------------------

table concurrent_futures_extra40.class_qualnames:
  description: "concurrent.futures core class __qualname__ string equality in extra40 namespace — ThreadPoolExecutor, ProcessPoolExecutor, Future, Executor"
  kind: python_call_eq
  category: class_names
  id_prefix: cfclassqualname40

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__qualname__.__eq__,  ["ThreadPoolExecutor"],  true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — top-level class; qualname equals name (18 chars)"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — top-level class; qualname equals name (19 chars)"]
    - [Future,              Future.__qualname__.__eq__,              ["Future"],              true, "Future.__qualname__ == 'Future' — top-level class in _base; qualname equals name (6 chars)"]
    - [Executor,            Executor.__qualname__.__eq__,            ["Executor"],            true, "Executor.__qualname__ == 'Executor' — abstract base class in _base; qualname equals name (8 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures executor class __qualname__ lengths — extra40 namespace
#
# __qualname__.__len__() for the four core classes:
#   ThreadPoolExecutor.__qualname__.__len__()  == 18
#   ProcessPoolExecutor.__qualname__.__len__() == 19
#   Future.__qualname__.__len__()              ==  6
#   Executor.__qualname__.__len__()            ==  8
# ThreadPoolExecutor is one char shorter than ProcessPoolExecutor
# ('Thread'(6) vs 'Process'(7), both followed by 'PoolExecutor'(12)).
# ---------------------------------------------------------------------------

table concurrent_futures_extra40.class_qualname_lengths:
  description: "concurrent.futures core class __qualname__.__len__() in extra40 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: cfclassqnlen40

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__qualname__.__len__,  [], 18, "ThreadPoolExecutor.__qualname__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__qualname__.__len__, [], 19, "ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters"]
    - [Future,              Future.__qualname__.__len__,              [],  6, "Future.__qualname__.__len__() == 6 — 'Future' has 6 characters"]
    - [Executor,            Executor.__qualname__.__len__,            [],  8, "Executor.__qualname__.__len__() == 8 — 'Executor' has 8 characters"]

# ---------------------------------------------------------------------------
# concurrent.futures exception class __qualname__ — extra40 namespace
#
# Two exception classes with their __qualname__ values:
#   CancelledError.__qualname__ == 'CancelledError'  (14 chars)
#   BrokenExecutor.__qualname__ == 'BrokenExecutor'  (14 chars)
# Both are top-level classes so __qualname__ equals __name__. Both have the
# same __qualname__ length of 14 despite different semantic roles:
# CancelledError is raised when a Future is cancelled; BrokenExecutor is raised
# when an executor has become unusable (e.g. worker processes terminated).
# ---------------------------------------------------------------------------

table concurrent_futures_extra40.exception_qualnames:
  description: "concurrent.futures exception class __qualname__ string equality in extra40 namespace — CancelledError, BrokenExecutor"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexcqualname40

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError, CancelledError.__qualname__.__eq__, ["CancelledError"], true, "CancelledError.__qualname__ == 'CancelledError' — top-level exception; qualname equals name (14 chars)"]
    - [BrokenExecutor, BrokenExecutor.__qualname__.__eq__, ["BrokenExecutor"], true, "BrokenExecutor.__qualname__ == 'BrokenExecutor' — top-level exception; qualname equals name (14 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra40
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra40.ThreadPoolExecutor_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — top-level class in concurrent.futures.thread; qualname equals name (18 chars)"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra40.ThreadPoolExecutor_qualname_len:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra40.ProcessPoolExecutor_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — top-level class in concurrent.futures.process; qualname equals name (19 chars)"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra40.ProcessPoolExecutor_qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__len__
  args: []
  expected: 19

invariant concurrent_futures_extra40.Future_qualname_eq:
  description: "concurrent.futures.Future.__qualname__ == 'Future' — top-level class in _base; qualname equals name (6 chars)"
  category: class_names
  kind: python_call_eq
  function: Future.__qualname__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra40.Executor_qualname_eq:
  description: "concurrent.futures.Executor.__qualname__ == 'Executor' — abstract base class in _base; qualname equals name (8 chars)"
  category: class_names
  kind: python_call_eq
  function: Executor.__qualname__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra40.CancelledError_qualname_eq:
  description: "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' — top-level exception class; qualname equals name (14 chars)"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__qualname__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra40.BrokenExecutor_qualname_eq:
  description: "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' — top-level exception class; qualname equals name (14 chars)"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true
