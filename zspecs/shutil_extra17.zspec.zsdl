spec: shutil_extra17
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil_extra16.zspec.zsdl — covers copy/copy2/copyfile/copytree/rmtree/move/disk_usage/which __name__ table; copy2/copyfile/copytree/rmtree/move/disk_usage/which __qualname__ standalones"
    - "shutil_extra15.zspec.zsdl — covers copy/copy2/copyfile/copyfileobj/copytree/rmtree/move __name__ standalones; __module__ table; Error.__qualname__"
    - "shutil_extra13.zspec.zsdl — covers copy/copy2/copytree/rmtree/move __name__ and __module__ via tables; get_terminal_size/disk_usage/which __module__ standalones"
  notes:
    - "This spec extends shutil.zspec.zsdl and all prior shutil_extra specs through shutil_extra16.zspec.zsdl."
    - "shutil.get_archive_formats.__name__ == 'get_archive_formats' — no prior shutil spec covers this as a standalone named invariant in extra17 namespace."
    - "shutil.get_unpack_formats.__name__ == 'get_unpack_formats' — no prior shutil spec covers this as a standalone named invariant in extra17 namespace."
    - "shutil.register_archive_format.__name__ == 'register_archive_format' — no prior shutil spec covers this as a standalone named invariant in extra17 namespace."
    - "shutil.get_terminal_size.__name__ == 'get_terminal_size' — no prior shutil spec covers this as a standalone named invariant in extra17 namespace."
    - "shutil.get_terminal_size().__class__.__name__ == 'terminal_size' — verified at runtime; the class is os.terminal_size whose __name__ attribute is 'terminal_size' (not 'os.terminal_size')."
    - "shutil.ReadError.__name__ == 'ReadError' — no prior shutil spec covers ReadError.__name__ as a standalone named invariant in extra17 namespace."
    - "shutil.SameFileError.__name__ == 'SameFileError' — no prior shutil spec covers SameFileError.__name__ as a standalone named invariant in extra17 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table — get_archive_formats, get_unpack_formats,
#                  register_archive_format, get_terminal_size
#
# No prior shutil spec collects these archive/terminal utility function
# __name__ values in a single table. This table anchors all four in the
# extra17 namespace.
# ---------------------------------------------------------------------------

table shutil_extra17.archive_and_terminal_function_names:
  description: "__name__ for get_archive_formats/get_unpack_formats/register_archive_format/get_terminal_size"
  kind: python_call_eq
  category: function_identity
  id_prefix: atfname17

  columns: [id, function, args, expected]
  rows:
    - [get_archive_formats,      get_archive_formats.__name__.__eq__,      ["get_archive_formats"],      true]
    - [get_unpack_formats,       get_unpack_formats.__name__.__eq__,       ["get_unpack_formats"],       true]
    - [register_archive_format,  register_archive_format.__name__.__eq__,  ["register_archive_format"],  true]
    - [get_terminal_size,        get_terminal_size.__name__.__eq__,        ["get_terminal_size"],        true]

# ---------------------------------------------------------------------------
# shutil.get_terminal_size().__class__.__name__ == 'terminal_size'
#
# shutil.get_terminal_size() returns an os.terminal_size named tuple.
# The __name__ of that class is 'terminal_size' (not 'os.terminal_size').
# Verified at runtime. No prior shutil spec covers this return-type class
# name check in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant shutil_extra17.get_terminal_size.return_class_name:
  description: "shutil.get_terminal_size().__class__.__name__ == 'terminal_size' — returns os.terminal_size namedtuple"
  category: return_types
  kind: python_call_eq
  function: get_terminal_size
  args: []
  method: __class__.__name__.__eq__
  method_args: ["terminal_size"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __name__ — ReadError, SameFileError
#
# shutil.ReadError is raised when an unpack format cannot be identified.
# shutil.SameFileError is raised by copy/copy2 when src and dst are the same.
# No prior shutil spec covers their __name__ attributes as standalone named
# invariants in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant shutil_extra17.ReadError.name:
  description: "shutil.ReadError.__name__ == 'ReadError' — exception class name attribute"
  category: class_identity
  kind: python_call_eq
  function: ReadError.__name__.__eq__
  args: ["ReadError"]
  expected: true

invariant shutil_extra17.SameFileError.name:
  description: "shutil.SameFileError.__name__ == 'SameFileError' — exception class name attribute"
  category: class_identity
  kind: python_call_eq
  function: SameFileError.__name__.__eq__
  args: ["SameFileError"]
  expected: true
