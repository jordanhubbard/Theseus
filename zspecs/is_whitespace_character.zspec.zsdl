spec: is_whitespace_character
version: ">=2.0.1"
backend: node(is-whitespace-character)

docs: https://www.npmjs.com/package/is-whitespace-character

provenance:
  derived_from:
    - "is-whitespace-character README — https://www.npmjs.com/package/is-whitespace-character"
    - "Test vectors verified with is-whitespace-character via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-whitespace-character source"
  notes:
    - "is-whitespace-character is an npm package. Install: npm install is-whitespace-character"
    - "Returns true if the character is a whitespace character (space, tab, newline, etc.)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_whitespace_character.check:
  kind: node_module_call_eq
  function: isWhitespaceCharacter
  category: string
  id_prefix: iswsc

  columns: [id, args, expected]
  rows:
    - [space,  [" "],   true]
    - [tab,    ["\t"],  true]
    - [letter, ["a"],   false]
