    - ["it1936029", "itertools.product.__dict__.__contains__",      ["__set_name__"], false]
    - ["it1936030", "itertools.combinations.__dict__.__contains__", ["__set_name__"], false]

table itertools_extra1936.class_name_checks:
  description: "itertools type and module __class__.__name__ identity checks"
  kind: python_call_eq
  category: class_name
  id_prefix: it1936
  columns: [id, function, args, expected]
  rows:
    - ["it1936031", "itertools.__class__.__name__.__eq__",          ["module"], true]
    - ["it1936032", "itertools.count.__class__.__name__.__eq__",    ["type"],   true]
    - ["it1936033", "itertools.cycle.__class__.__name__.__eq__",    ["type"],   true]
    - ["it1936034", "itertools.chain.__class__.__name__.__eq__",    ["type"],   true]
    - ["it1936035", "itertools.islice.__class__.__name__.__eq__",   ["type"],   true]
    - ["it1936036", "itertools.product.__class__.__name__.__eq__",  ["type"],   true]
    - ["it1936037", "itertools.permutations.__class__.__name__.__eq__", ["type"], true]
    - ["it1936038", "itertools.combinations.__class__.__name__.__eq__", ["type"], true]
    - ["it1936039", "itertools.zip_longest.__class__.__name__.__eq__",  ["type"], true]
