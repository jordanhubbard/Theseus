spec: itertools_extra1936
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__ attribute value checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All itertools C-extension types (count, cycle, chain, islice, zip_longest, product, combinations, permutations, etc.) do NOT define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "itertools module itself is a C extension module; itertools.__class__.__name__ == 'module'."
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra1936.descriptor_protocol_core:
  description: "itertools core C-type __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1936
  columns: [id, function, args, expected]
  rows:
    - ["it1936001", "itertools.count.__dict__.__contains__",        ["__get__"],    false]
    - ["it1936002", "itertools.count.__dict__.__contains__",        ["__set__"],    false]
    - ["it1936003", "itertools.count.__dict__.__contains__",        ["__delete__"], false]
    - ["it1936004", "itertools.cycle.__dict__.__contains__",        ["__get__"],    false]
    - ["it1936005", "itertools.cycle.__dict__.__contains__",        ["__set__"],    false]
    - ["it1936006", "itertools.cycle.__dict__.__contains__",        ["__delete__"], false]
    - ["it1936007", "itertools.chain.__dict__.__contains__",        ["__get__"],    false]
    - ["it1936008", "itertools.chain.__dict__.__contains__",        ["__set__"],    false]
    - ["it1936009", "itertools.chain.__dict__.__contains__",        ["__delete__"], false]

