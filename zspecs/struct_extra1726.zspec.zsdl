spec: struct_extra1726
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "struct.Struct is a C extension type describing a compiled pack/unpack format; it defines no comparison operators."
    - "struct.Struct.__dict__.__contains__('__lt__') is False — Struct objects have no ordering semantics."
    - "struct.Struct.__dict__.__contains__('__eq__') is False — Struct objects are not equality-comparable by value."
    - "struct.error is a subclass of Exception; comparison methods are inherited from BaseException/object, not in struct.error's own __dict__."
    - "None of __lt__, __le__, __gt__, __ge__, __ne__, __eq__, or __hash__ appear in Struct's or struct.error's own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra1726.comparison_protocol:
  description: "struct types comparison/ordering dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1726

  columns: [id, function, args, expected]
  rows:
    - ["st1726001", "struct.Struct.__dict__.__contains__", ["__lt__"], false]
    - ["st1726002", "struct.Struct.__dict__.__contains__", ["__le__"], false]
    - ["st1726003", "struct.Struct.__dict__.__contains__", ["__gt__"], false]
    - ["st1726004", "struct.Struct.__dict__.__contains__", ["__ge__"], false]
    - ["st1726005", "struct.Struct.__dict__.__contains__", ["__ne__"], false]
    - ["st1726006", "struct.error.__dict__.__contains__", ["__lt__"], false]
    - ["st1726007", "struct.error.__dict__.__contains__", ["__le__"], false]
    - ["st1726008", "struct.error.__dict__.__contains__", ["__gt__"], false]
    - ["st1726009", "struct.error.__dict__.__contains__", ["__ge__"], false]
    - ["st1726010", "struct.error.__dict__.__contains__", ["__ne__"], false]

table struct_extra1726.eq_hash_protocol:
  description: "struct types __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1726

  columns: [id, function, args, expected]
  rows:
    - ["st1726011", "struct.Struct.__dict__.__contains__", ["__eq__"], false]
    - ["st1726012", "struct.Struct.__dict__.__contains__", ["__hash__"], false]
    - ["st1726013", "struct.error.__dict__.__contains__", ["__eq__"], false]
    - ["st1726014", "struct.error.__dict__.__contains__", ["__hash__"], false]
