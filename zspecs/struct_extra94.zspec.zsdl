spec: struct_extra94
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra93

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra93.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __name__ / Struct.format/__qualname__ / error/__bases__[0]/__module__ / Struct/__module__/__qualname__/__bases__[0]/__name__ / Struct/__mro__/__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance (__bases__[0].__name__) and __module__/__qualname__ / Struct method __qualname__ cross-check (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
    - "struct_extra90.zspec.zsdl — covers struct module-level function __qualname__ / Struct method __qualname__ / Struct method class names (table + invariants)."
    - "struct_extra39.zspec.zsdl — covers Struct.size.__qualname__.__eq__('Struct.size') (invariant)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra93; it does NOT duplicate invariants present in those files."
    - "Wave 261 theme: struct Struct method __qualname__.__len__() values and struct.error __mro__ depth — Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() / struct.error.__mro__.__len__()==4 / error MRO entry names."
    - "struct.Struct.pack.__qualname__.__len__() == 11 ('Struct.pack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__.__len__() == 13 ('Struct.unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__.__len__() == 16 ('Struct.pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__.__len__() == 18 ('Struct.unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__.__len__() == 18 ('Struct.iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[0].__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[1].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[2].__name__ == 'BaseException'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[3].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct method __qualname__.__len__() values reflect 'Struct.' prefix (7 chars) plus the method name length."
    - "Note: pack_into and unpack_from share __qualname__ length 16 and 18 respectively due to 'Struct.' (7) + 'pack_into' (9) = 16, 'Struct.' (7) + 'unpack_from' (11) = 18."
    - "Note: iter_unpack and unpack_from both have __qualname__ length 18: 'Struct.' (7) + 'iter_unpack' (11) = 18, 'Struct.' (7) + 'unpack_from' (11) = 18."
    - "Note: struct.error's MRO depth of 4 reflects the Python exception hierarchy: error -> Exception -> BaseException -> object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__len__()==11
# struct.Struct.unpack.__qualname__.__len__()==13
# struct.Struct.pack_into.__qualname__.__len__()==16
# struct.Struct.unpack_from.__qualname__.__len__()==18
# struct.Struct.iter_unpack.__qualname__.__len__()==18
#
# Wave 261 theme: Struct method __qualname__.__len__() values.
#
# Each Struct method __qualname__ is 'Struct.' (7 chars) plus the method name.
# pack: 7 + 4 = 11, unpack: 7 + 6 = 13, pack_into: 7 + 9 = 16,
# unpack_from: 7 + 11 = 18, iter_unpack: 7 + 11 = 18.
# Prior specs anchor __qualname__.__eq__ (extra90/extra92) and __name__.__eq__
# (extra93); this table first anchors __qualname__.__len__() values for all
# five methods under structqlen94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra94.struct_Struct_method_qualname_lengths:
  description: "struct.Struct.pack/__qualname__/__len__()==11 / Struct.unpack/__qualname__/__len__()==13 / Struct.pack_into/__qualname__/__len__()==16 / Struct.unpack_from/__qualname__/__len__()==18 / Struct.iter_unpack/__qualname__/__len__()==18 — each __qualname__ is 'Struct.' (7 chars) plus the method name; extra90/extra92 anchor __qualname__.__eq__; extra93 anchors __name__.__eq__; this table first anchors __qualname__.__len__() for all five; first structqlen94 anchor for Struct method qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structqlen94

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qlen,        "Struct.pack.__qualname__.__len__",        [], 11, "'Struct.pack' is 7 + 4 = 11 chars"]
    - [unpack_qlen,      "Struct.unpack.__qualname__.__len__",      [], 13, "'Struct.unpack' is 7 + 6 = 13 chars"]
    - [pack_into_qlen,   "Struct.pack_into.__qualname__.__len__",   [], 16, "'Struct.pack_into' is 7 + 9 = 16 chars"]
    - [unpack_from_qlen, "Struct.unpack_from.__qualname__.__len__", [], 18, "'Struct.unpack_from' is 7 + 11 = 18 chars"]
    - [iter_unpack_qlen, "Struct.iter_unpack.__qualname__.__len__", [], 18, "'Struct.iter_unpack' is 7 + 11 = 18 chars"]

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__()==4
# struct.error.__mro__[0].__name__.__eq__('error')
# struct.error.__mro__[1].__name__.__eq__('Exception')
# struct.error.__mro__[2].__name__.__eq__('BaseException')
# struct.error.__mro__[3].__name__.__eq__('object')
#
# Wave 261 theme: struct.error MRO depth and entry names.
#
# struct.error.__mro__ has 4 entries: (error, Exception, BaseException, object).
# This reflects the standard Python exception hierarchy for a direct Exception
# subclass. struct_extra92 anchors error.__bases__[0].__name__=='Exception' and
# error.__module__=='struct'; struct_extra93 anchors error.__bases__[0].__module__;
# this table first anchors the full MRO depth and each entry name under
# structqlen94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra94.struct_error_mro_depth_and_names:
  description: "struct.error/__mro__/__len__()==4 / error.__mro__[0]/__name__.__eq__('error')==True / error.__mro__[1]/__name__.__eq__('Exception')==True / error.__mro__[2]/__name__.__eq__('BaseException')==True / error.__mro__[3]/__name__.__eq__('object')==True — MRO has 4 entries reflecting the exception hierarchy; extra92 anchors __bases__[0].__name__; extra93 anchors __bases__[0].__module__; this table first anchors MRO depth and all entry names; first structqlen94 anchor for error MRO"
  kind: python_call_eq
  category: type_identity
  id_prefix: structqlen94

  columns: [id, function, args, expected, description]
  rows:
    - [mro_len,       "error.__mro__.__len__",                [], 4,              "struct.error MRO has 4 entries: error, Exception, BaseException, object"]
    - [mro_0_name,    "error.__mro__[0].__name__.__eq__",    ["error"],          true, "MRO[0] is struct.error itself"]
    - [mro_1_name,    "error.__mro__[1].__name__.__eq__",    ["Exception"],      true, "MRO[1] is Exception (direct base class)"]
    - [mro_2_name,    "error.__mro__[2].__name__.__eq__",    ["BaseException"],  true, "MRO[2] is BaseException"]
    - [mro_3_name,    "error.__mro__[3].__name__.__eq__",    ["object"],         true, "MRO[3] is object (root of all Python classes)"]

# ---------------------------------------------------------------------------
# struct module-level function __qualname__ lengths
# struct.pack.__qualname__.__len__()==4
# struct.unpack.__qualname__.__len__()==6
# struct.calcsize.__qualname__.__len__()==8
#
# Wave 261 supplemental: module-level function __qualname__ lengths.
#
# The three primary module-level struct functions have short __qualname__ values
# equal to just the function name (no class prefix). pack: 'pack' (4 chars),
# unpack: 'unpack' (6 chars), calcsize: 'calcsize' (8 chars). struct_extra90
# and struct_extra91 anchor their __qualname__.__eq__ values; this table
# first anchors __qualname__.__len__() for module-level functions under
# structqlen94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra94.struct_module_level_qualname_lengths:
  description: "struct.pack/__qualname__/__len__()==4 / struct.unpack/__qualname__/__len__()==6 / struct.calcsize/__qualname__/__len__()==8 — module-level struct functions have __qualname__ equal to their simple name (no 'Struct.' prefix); pack (4), unpack (6), calcsize (8); extra90/extra91 anchor __qualname__.__eq__; this table first anchors module-level function __qualname__.__len__() under structqlen94"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structqlen94

  columns: [id, function, args, expected, description]
  rows:
    - [pack_fn_qlen,     pack.__qualname__.__len__,     [], 4, "struct.pack.__qualname__ is 'pack' (4 chars), no class prefix"]
    - [unpack_fn_qlen,   unpack.__qualname__.__len__,   [], 6, "struct.unpack.__qualname__ is 'unpack' (6 chars)"]
    - [calcsize_fn_qlen, calcsize.__qualname__.__len__,  [], 8, "struct.calcsize.__qualname__ is 'calcsize' (8 chars)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__len__()==11 — standalone
#
# struct.Struct.pack.__qualname__.__len__() is 11. Struct.pack.__qualname__ is
# 'Struct.pack': 'Struct.' (7 chars) + 'pack' (4 chars) = 11. This is the
# primary packing method for Struct instances. Prior specs (extra90/extra92)
# anchor __qualname__.__eq__('Struct.pack'); extra93 anchors __name__.__eq__;
# no prior spec anchors Struct.pack.__qualname__.__len__() as a standalone under
# structqlen94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra94.struct_pack_qualname_len_11:
  description: "struct.Struct.pack.__qualname__.__len__() == 11 — Struct.pack.__qualname__ is 'Struct.pack': 'Struct.' (7) + 'pack' (4) = 11; extra90/extra92 anchor __qualname__.__eq__; extra93 anchors __name__.__eq__; first standalone for Struct.pack.__qualname__.__len__() under structqlen94"
  category: qualname_lengths
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__()==4 — standalone
#
# struct.error.__mro__.__len__() is 4. The MRO (method resolution order) for
# struct.error is (error, Exception, BaseException, object) — exactly 4 classes.
# This depth of 4 is typical for any class that directly subclasses Exception,
# which itself subclasses BaseException, which subclasses object. struct_extra92
# anchors error.__bases__[0].__name__=='Exception'; no prior spec anchors
# error.__mro__.__len__()==4 as a standalone under structqlen94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra94.error_mro_len_4:
  description: "struct.error.__mro__.__len__() == 4 — error MRO is (error, Exception, BaseException, object); depth 4 is typical for direct Exception subclasses; extra92 anchors error.__bases__[0].__name__; first standalone for error.__mro__.__len__() under structqlen94"
  category: type_identity
  kind: python_call_eq
  function: "error.__mro__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__len__()==18 — standalone
#
# struct.Struct.unpack_from.__qualname__.__len__() is 18. Struct.unpack_from.__qualname__
# is 'Struct.unpack_from': 'Struct.' (7 chars) + 'unpack_from' (11 chars) = 18.
# unpack_from reads from a buffer at a given offset without consuming the whole
# buffer, unlike unpack which requires an exactly-sized bytes object. Prior specs
# anchor __qualname__.__eq__ and __name__.__eq__; no prior spec anchors
# Struct.unpack_from.__qualname__.__len__() as a standalone under structqlen94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra94.struct_unpack_from_qualname_len_18:
  description: "struct.Struct.unpack_from.__qualname__.__len__() == 18 — Struct.unpack_from.__qualname__ is 'Struct.unpack_from': 'Struct.' (7) + 'unpack_from' (11) = 18; prior specs anchor __qualname__.__eq__ and __name__.__eq__; first standalone for Struct.unpack_from.__qualname__.__len__() under structqlen94"
  category: qualname_lengths
  kind: python_call_eq
  function: "Struct.unpack_from.__qualname__.__len__"
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# struct.error.__mro__[1].__name__.__eq__('Exception') — standalone
#
# struct.error.__mro__[1].__name__ is 'Exception'. The second entry in the
# struct.error MRO is Exception, the direct base class. Exception is Python's
# standard base class for all non-fatal exceptions (those not related to
# system exit or keyboard interrupt). struct_extra92 anchors
# error.__bases__[0].__name__=='Exception' from the __bases__ perspective;
# this standalone anchors the same via the MRO index under structqlen94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra94.error_mro_1_exception:
  description: "struct.error.__mro__[1].__name__.__eq__('Exception') == True — MRO[1] is Exception, the direct base class of struct.error; extra92 anchors error.__bases__[0].__name__=='Exception' via __bases__; this standalone anchors the same via MRO index; first standalone for error.__mro__[1].__name__ under structqlen94"
  category: type_identity
  kind: python_call_eq
  function: "error.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true
