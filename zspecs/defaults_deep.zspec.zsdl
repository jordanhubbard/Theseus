spec: defaults_deep
version: ">=0.2.4"
backend: node(defaults-deep)

docs: https://www.npmjs.com/package/defaults-deep

provenance:
  derived_from:
    - "defaults-deep README — https://www.npmjs.com/package/defaults-deep"
    - "Test vectors verified with defaults-deep via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "defaults-deep source"
  notes:
    - "defaults-deep is an npm package. Install: npm install defaults-deep"
    - "Fills in undefined/missing properties in target from defaults. Existing properties are preserved."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the target object with defaults applied."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table defaults_deep.defaults:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: ddeep

  columns: [id, args, expected]
  rows:
    - [fill_missing,   [{"a": 1}, {"a": 99, "b": 2}],  {"a": 1, "b": 2}]
    - [empty_target,   [{}, {"a": 1, "b": 2}],          {"a": 1, "b": 2}]
    - [no_override,    [{"x": 5}, {"x": 10, "y": 20}], {"x": 5, "y": 20}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:09:18Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
