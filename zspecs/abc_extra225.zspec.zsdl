  columns: [id, function, args, expected, description]
  rows:
    - [acm_name_eq,      abstractclassmethod.__name__.__eq__,      ["abstractclassmethod"], true, "abc.abstractclassmethod.__name__ == 'abstractclassmethod'; verified with Python 3.14.3"]
    - [acm_name_len_19,  abstractclassmethod.__name__.__len__,     [],                      19,   "abc.abstractclassmethod.__name__.__len__() == 19 — 'abstractclassmethod' has 19 characters; verified with Python 3.14.3"]
    - [acm_module_eq,    abstractclassmethod.__module__.__eq__,    ["abc"],                 true, "abc.abstractclassmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [acm_qualname_eq,  abstractclassmethod.__qualname__.__eq__,  ["abstractclassmethod"], true, "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod'; verified with Python 3.14.3"]

