provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.abstractclassmethod.__name__ == 'abstractclassmethod' — 19 characters; deprecated since Python 3.3, still present in 3.14; module is 'abc'; verified with Python 3.14.3."
    - "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' — 20 characters; deprecated since Python 3.3, still present in 3.14; module is 'abc'; verified with Python 3.14.3."
    - "abc.abstractproperty.__name__ == 'abstractproperty' — 16 characters; deprecated since Python 3.3, still present in 3.14; module is 'abc'; verified with Python 3.14.3."
    - "All three deprecated decorators remain in abc as of Python 3.14.3; they have not been removed."
    - "All qualnames are simple (not nested): abstractclassmethod, abstractstaticmethod, abstractproperty; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

