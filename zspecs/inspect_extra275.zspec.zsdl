spec: inspect_extra275
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.BoundArguments is a pure-Python class; __module__ == 'inspect', __bases__[0].__name__ == 'object'."
    - "inspect.FullArgSpec is a namedtuple; __bases__[0].__name__ == 'tuple'; has 7 fields."
    - "FullArgSpec._fields == ('args','varargs','varkw','defaults','kwonlyargs','kwonlydefaults','annotations')."
    - "inspect.ArgInfo is a namedtuple; __bases__[0].__name__ == 'tuple'; has 4 fields."
    - "ArgInfo._fields == ('args','varargs','keywords','locals')."
    - "Both FullArgSpec and ArgInfo have __module__ == 'inspect' and __class__.__name__ == 'type'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.BoundArguments — class identity
#
# BoundArguments is a pure-Python class in inspect.
# __name__ == 'BoundArguments'; __module__ == 'inspect'.
# __bases__[0].__name__ == 'object'; __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table inspect_extra275.bound_arguments_identity:
  description: "inspect.BoundArguments class identity — __name__, __module__, __qualname__, __bases__[0].__name__, __class__.__name__; pure-Python class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex275bai

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_eq,    BoundArguments.__name__.__eq__,                       ["BoundArguments"], true, "inspect.BoundArguments.__name__ == 'BoundArguments'; verified with Python 3.14.3"]
    - [ba_name_len,   BoundArguments.__name__.__len__,                      [],                 14,   "inspect.BoundArguments.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [ba_mod_eq,     BoundArguments.__module__.__eq__,                     ["inspect"],        true, "inspect.BoundArguments.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ba_qn_eq,      BoundArguments.__qualname__.__eq__,                   ["BoundArguments"], true, "inspect.BoundArguments.__qualname__ == 'BoundArguments'; verified with Python 3.14.3"]
    - [ba_cls_eq,     BoundArguments.__class__.__name__.__eq__,             ["type"],           true, "inspect.BoundArguments.__class__.__name__ == 'type' (pure-Python class); verified with Python 3.14.3"]
    - [ba_base_name,  BoundArguments.__bases__.__getitem__(0).__name__.__eq__, ["object"],      true, "inspect.BoundArguments.__bases__[0].__name__ == 'object' — directly subclasses object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec and inspect.ArgInfo — namedtuple identity
#
# Both are namedtuples: __bases__[0].__name__ == 'tuple'.
# FullArgSpec has 7 fields; ArgInfo has 4 fields.
# Both have __module__ == 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra275.fullargspec_arginfo_identity:
  description: "inspect.FullArgSpec and ArgInfo namedtuple identity — __name__, __module__, __bases__[0].__name__; field counts; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex275fai

  columns: [id, function, args, expected, description]
  rows:
    - [fas_name_eq,   FullArgSpec.__name__.__eq__,                        ["FullArgSpec"], true, "inspect.FullArgSpec.__name__ == 'FullArgSpec'; verified with Python 3.14.3"]
    - [fas_mod_eq,    FullArgSpec.__module__.__eq__,                      ["inspect"],     true, "inspect.FullArgSpec.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [fas_cls_eq,    FullArgSpec.__class__.__name__.__eq__,              ["type"],        true, "inspect.FullArgSpec.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [fas_base_name, FullArgSpec.__bases__.__getitem__(0).__name__.__eq__, ["tuple"],     true, "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple; verified with Python 3.14.3"]
    - [fas_fld_len,   FullArgSpec._fields.__len__,                        [],              7,    "inspect.FullArgSpec._fields.__len__() == 7 — seven fields in the namedtuple; verified with Python 3.14.3"]
    - [ai_name_eq,    ArgInfo.__name__.__eq__,                            ["ArgInfo"],     true, "inspect.ArgInfo.__name__ == 'ArgInfo'; verified with Python 3.14.3"]
    - [ai_mod_eq,     ArgInfo.__module__.__eq__,                          ["inspect"],     true, "inspect.ArgInfo.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ai_cls_eq,     ArgInfo.__class__.__name__.__eq__,                  ["type"],        true, "inspect.ArgInfo.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [ai_base_name,  ArgInfo.__bases__.__getitem__(0).__name__.__eq__,   ["tuple"],       true, "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a namedtuple; verified with Python 3.14.3"]
    - [ai_fld_len,    ArgInfo._fields.__len__,                            [],              4,    "inspect.ArgInfo._fields.__len__() == 4 — four fields: args, varargs, keywords, locals; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra275
# ---------------------------------------------------------------------------

invariant inspect_extra275.bound_arguments_name_is_BoundArguments:
  description: "inspect.BoundArguments.__name__ == 'BoundArguments' — class name matches its export symbol"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra275.bound_arguments_module_is_inspect:
  description: "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in the pure-Python inspect module"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra275.bound_arguments_base_is_object:
  description: "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments directly subclasses object"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant inspect_extra275.fullargspec_base_is_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple, which directly subclasses tuple"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__bases__.__getitem__(0).__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra275.fullargspec_has_7_fields:
  description: "inspect.FullArgSpec._fields.__len__() == 7 — the namedtuple has seven fields covering args through annotations"
  category: identity
  kind: python_call_eq
  function: FullArgSpec._fields.__len__
  args: []
  expected: 7

invariant inspect_extra275.arginfo_base_is_tuple:
  description: "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a namedtuple, which directly subclasses tuple"
  category: identity
  kind: python_call_eq
  function: ArgInfo.__bases__.__getitem__(0).__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra275.arginfo_has_4_fields:
  description: "inspect.ArgInfo._fields.__len__() == 4 — the namedtuple has four fields: args, varargs, keywords, locals"
  category: identity
  kind: python_call_eq
  function: ArgInfo._fields.__len__
  args: []
  expected: 4

invariant inspect_extra275.arginfo_module_is_inspect:
  description: "inspect.ArgInfo.__module__ == 'inspect' — ArgInfo namedtuple is defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: ArgInfo.__module__.__eq__
  args: ["inspect"]
  expected: true
