spec: theseus_builtins_cr
version: ">=3.9"
backend: python_cleanroom(theseus_builtins_cr)
blocks: builtins

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html"
  notes:
    - "Clean-room reimplementations of selected built-in functions. Do NOT import builtins."
    - "all_(iterable): True if all elements are truthy (or iterable empty)."
    - "any_(iterable): True if any element is truthy."
    - "zip_(*iterables): yield tuples from parallel iterables, stops at shortest."
    - "enumerate_(iterable, start=0): yield (index, value) pairs."
    - "builtins_all_true(): all_([1, 2, 3]) == True."
    - "builtins_any_false(): any_([0, 0, 1]) == True."
    - "builtins_zip(): list(zip_([1,2],[3,4])) == [(1,3),(2,4)] returns True."
    - "builtins_enumerate(): list(enumerate_(['a','b']))[0] == (0,'a') returns True."
    - "Export: all_, any_, zip_, enumerate_."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_builtins_cr.all_true:
  description: "all_([1, 2, 3]) == True"
  category: all
  kind: python_call_eq
  function: builtins_all_true
  args: []
  expected: true

invariant theseus_builtins_cr.any_false:
  description: "any_([0, 0, 1]) == True"
  category: any
  kind: python_call_eq
  function: builtins_any_false
  args: []
  expected: true

invariant theseus_builtins_cr.zip:
  description: "list(zip_([1,2],[3,4])) == [(1,3),(2,4)]"
  category: zip
  kind: python_call_eq
  function: builtins_zip
  args: []
  expected: true
