# ---------------------------------------------------------------------------
# Table 1: inspect.Signature class identity
#
# Wave 259 theme: inspect.Signature is a pure-Python class defined in
# Lib/inspect.py. It inherits directly from object, has MRO depth 2,
# and its __module__ and __qualname__ are 'inspect' and 'Signature'.
# Its __init__ is a plain Python function.
#
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__qualname__ == 'Signature'
# inspect.Signature.__bases__[0].__name__ == 'object'
# inspect.Signature.__mro__.__len__() == 2
# inspect.Signature.__init__.__qualname__ == 'Signature.__init__'
# type(inspect.Signature.__init__).__name__ == 'function'
#
# New to extra106.
# ---------------------------------------------------------------------------

table inspect_extra106.signature_class_identity:
  description: "inspect.Signature class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__; plus __init__ qualname and type; wave 259; new to extra106"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectsig106

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — inspect.Signature is a pure-Python class defined in Lib/inspect.py; its __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra106"]
    - [signature_module_eq,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — inspect.Signature is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra106"]
    - [signature_qualname_eq,
       "Signature.__qualname__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — inspect.Signature is a top-level class in Lib/inspect.py; its __qualname__ equals __name__ equals 'Signature'; str.__eq__('Signature') returns True; new to extra106"]
    - ["signature_bases_0_name_object",
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — inspect.Signature inherits directly from object with no intermediate base classes; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra106"]
    - [signature_mro_len_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — inspect.Signature inherits directly from object; its MRO is [Signature, object] with length 2; new to extra106"]
    - [signature_init_qualname_eq,
       "Signature.__init__.__qualname__.__eq__",
       ["Signature.__init__"],
       true,
       "inspect.Signature.__init__.__qualname__.__eq__('Signature.__init__') == True — methods defined inside a class have __qualname__ equal to 'ClassName.method_name'; Signature.__init__.__qualname__ is 'Signature.__init__'; str.__eq__('Signature.__init__') returns True; new to extra106"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter class identity
#
# Wave 259 theme: inspect.Parameter is a pure-Python class defined in
# Lib/inspect.py that describes individual parameters of a function
# signature. It inherits from object with MRO depth 2. Its special
# sentinel Parameter.empty has __class__.__name__ == 'type' (it is itself
# a class). Parameter kind constants (POSITIONAL_ONLY etc.) are instances
# of the internal _ParameterKind enum.
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__qualname__ == 'Parameter'
# inspect.Parameter.__bases__[0].__name__ == 'object'
# inspect.Parameter.__mro__.__len__() == 2
# inspect.Parameter.empty.__class__.__name__ == 'type'
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
#
# New to extra106.
# ---------------------------------------------------------------------------

table inspect_extra106.parameter_class_identity:
  description: "inspect.Parameter class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__; plus Parameter.empty and POSITIONAL_ONLY class names; wave 259; new to extra106"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectparam106

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — inspect.Parameter is a pure-Python class in Lib/inspect.py describing a single function parameter; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra106"]
    - [parameter_module_eq,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — inspect.Parameter is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra106"]
    - [parameter_qualname_eq,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — inspect.Parameter is a top-level class; its __qualname__ equals __name__ equals 'Parameter'; str.__eq__('Parameter') returns True; new to extra106"]
    - ["parameter_bases_0_name_object",
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — inspect.Parameter inherits directly from object; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra106"]
    - [parameter_mro_len_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — inspect.Parameter inherits directly from object; its MRO is [Parameter, object] with length 2; new to extra106"]
    - [parameter_empty_class_name_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a sentinel class object (not an instance); it is itself a class, so its __class__ is 'type' (the metaclass); __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra106"]
    - [parameter_positional_only_class_name,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — Parameter.POSITIONAL_ONLY is an instance of the internal _ParameterKind IntEnum; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra106"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments class identity
#
# Wave 259 theme: inspect.BoundArguments is a pure-Python class in
# Lib/inspect.py representing the result of binding arguments to a
# Signature. It inherits from object with MRO depth 2.
#
# inspect.BoundArguments.__name__ == 'BoundArguments'
# inspect.BoundArguments.__module__ == 'inspect'
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
# inspect.BoundArguments.__mro__.__len__() == 2
#
# New to extra106.
# ---------------------------------------------------------------------------

table inspect_extra106.bound_arguments_class_identity:
  description: "inspect.BoundArguments class identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__; inherits directly from object with MRO depth 2; wave 259; new to extra106"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectbound106

  columns: [id, function, args, expected, description]
  rows:
    - [bound_arguments_name_eq,
       "BoundArguments.__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — inspect.BoundArguments is a pure-Python class in Lib/inspect.py representing the result of calling Signature.bind(); its __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra106"]
    - [bound_arguments_module_eq,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — inspect.BoundArguments is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra106"]
    - ["bound_arguments_bases_0_name_object",
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — inspect.BoundArguments inherits directly from object with no intermediate base classes; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra106"]
    - [bound_arguments_mro_len_2,
       "BoundArguments.__mro__.__len__",
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — inspect.BoundArguments inherits directly from object; its MRO is [BoundArguments, object] with length 2; new to extra106"]
    - [signature_init_type_function,
       "Signature.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.Signature.__init__.__class__.__name__.__eq__('function') == True — inspect.Signature.__init__ is defined as a Python def method; accessed as an unbound attribute from the class it is a plain Python function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra106
# ---------------------------------------------------------------------------

invariant inspect_extra106.signature_mro_len:
  description: "inspect.Signature.__mro__.__len__() == 2 — pure-Python class inheriting directly from object; wave 259; new to extra106"
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra106.parameter_mro_len:
  description: "inspect.Parameter.__mro__.__len__() == 2 — pure-Python class inheriting directly from object; wave 259; new to extra106"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra106.bound_arguments_mro_len:
  description: "inspect.BoundArguments.__mro__.__len__() == 2 — pure-Python class inheriting directly from object; wave 259; new to extra106"
  kind: python_call_eq
  function: BoundArguments.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra106.parameter_empty_is_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is a sentinel class object, so its metaclass is 'type'; wave 259; new to extra106"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra106.parameter_positional_only_kind:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — kind constants are instances of internal _ParameterKind IntEnum; wave 259; new to extra106"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

