spec: in3061
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (in3061): __aexit__, __await__, __anext__ dict-presence checks for inspect types."
    - "None of the inspect types define __aexit__, __await__, or __anext__ in their own __dict__."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are pure Python classes."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception classes."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3061.aexit:
  description: "inspect types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3061
  columns: [id, function, args, expected]
  rows:
    - ["in3061001", operator.contains, [inspect.Parameter.__dict__,           "__aexit__"], false]
    - ["in3061002", operator.contains, [inspect.Signature.__dict__,           "__aexit__"], false]
    - ["in3061003", operator.contains, [inspect.BoundArguments.__dict__,      "__aexit__"], false]
    - ["in3061004", operator.contains, [inspect.FrameInfo.__dict__,           "__aexit__"], false]
    - ["in3061005", operator.contains, [inspect.ArgInfo.__dict__,             "__aexit__"], false]
    - ["in3061006", operator.contains, [inspect.FullArgSpec.__dict__,         "__aexit__"], false]
    - ["in3061007", operator.contains, [inspect.Attribute.__dict__,           "__aexit__"], false]
    - ["in3061008", operator.contains, [inspect.ClassFoundException.__dict__,  "__aexit__"], false]
    - ["in3061009", operator.contains, [inspect.EndOfBlock.__dict__,           "__aexit__"], false]

