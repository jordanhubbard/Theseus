spec: decimal_extra48
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra47.zspec.zsdl — covers exception __bases__[0].__name__ equality (bracket form) for DivisionByZero/Underflow; Decimal.as_tuple/__qualname__.__eq__('Decimal.as_tuple'); Decimal.normalize/__qualname__.__eq__('Decimal.normalize'); method qualname lengths for from_float/as_tuple/quantize/normalize; exception MRO lengths for InvalidOperation/Inexact."
    - "decimal_extra46.zspec.zsdl — covers __doc__.__class__.__name__/__qualname__ for Decimal/Context/exceptions and module."
    - "decimal_extra45.zspec.zsdl — covers ROUND_HALF_DOWN/ROUND_05UP __class__.__name__=='str'; ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN __class__.__qualname__=='str'; __class__.__module__=='builtins' for ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_05UP."
    - "decimal_extra44.zspec.zsdl — covers DecimalException/InvalidOperation/DivisionByZero/Overflow __class__.__qualname__.__eq__('type'); getcontext/setcontext/localcontext __class__.__qualname__.__eq__('builtin_function_or_method')."
    - "decimal_extra43.zspec.zsdl — covers DecimalException/Context/Decimal __class__.__name__ identity."
    - "decimal_extra42.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__qualname__.__eq__('str')."
    - "decimal_extra38.zspec.zsdl — covers Rounded/Subnormal/Clamped/FloatOperation __module__.__eq__('decimal'); Context.__module__.__eq__('decimal')."
    - "decimal_extra37.zspec.zsdl — covers InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact __module__.__eq__('decimal')."
    - "decimal_extra36.zspec.zsdl — covers DecimalException/__name__/__module__; DecimalException.__module__.__eq__('decimal')."
    - "decimal_extra27.zspec.zsdl — covers exception class __module__.__len__()==7 for all decimal exceptions; getcontext/setcontext/localcontext __module__.__eq__('_decimal') (len 8, C extension)."
    - "decimal_extra24.zspec.zsdl — covers Decimal.__module__.__eq__('decimal'); Decimal.__module__.__len__()==7; ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__module__.__eq__('builtins')."
    - "decimal_extra22.zspec.zsdl — covers Decimal.quantize.__qualname__.__eq__('Decimal.quantize')."
    - "decimal_extra21.zspec.zsdl — covers Decimal.from_float.__qualname__.__eq__('Decimal.from_float')."
    - "decimal_extra13.zspec.zsdl — covers Decimal.__module__.__eq__('decimal')."
    - "decimal_extra9.zspec.zsdl — covers Context/__module__.__eq__('decimal')."
    - "decimal_extra6.zspec.zsdl — covers Context/__module__.__eq__('decimal'); DecimalException/__module__.__eq__('decimal'); InvalidOperation/__module__.__eq__('decimal')."
    - "decimal_extra3.zspec.zsdl — covers getcontext/__module__/__eq__ (old form, 'decimal' — superseded by decimal_extra27 correction: actual value on CPython is '_decimal')."
  notes:
    - "This spec extends decimal_extra47.zspec.zsdl."
    - "Prior specs collectively covered: Decimal.__module__.__eq__('decimal') (decimal_extra13/decimal_extra24); Decimal.__module__.__len__()==7 (decimal_extra24); Context.__module__.__eq__('decimal') (decimal_extra6/decimal_extra9/decimal_extra38); DecimalException.__module__.__eq__('decimal') (decimal_extra6/decimal_extra36); InvalidOperation.__module__.__eq__('decimal') (decimal_extra6/decimal_extra37); all exception __module__.__len__()==7 (decimal_extra27); getcontext/__module__=='_decimal' (decimal_extra27, len 8); ROUND_* __class__.__module__=='builtins' (decimal_extra24/decimal_extra45); Decimal.from_float/__qualname__.__eq__ (decimal_extra21); Decimal.quantize/__qualname__.__eq__ (decimal_extra22); Decimal.as_tuple/__qualname__.__eq__ (decimal_extra47); Decimal.normalize/__qualname__.__eq__ (decimal_extra47). NO prior decimal spec checks __module__.__class__.__name__.__eq__('str') for any decimal object — i.e., that the __module__ attribute itself is a str instance. This is the novel axis for decimal_extra48."
    - "This spec covers: decimal.Decimal.__module__.__class__.__name__.__eq__('str') (NOVEL — the __module__ attribute of Decimal is a str; no prior decimal spec checks the type of __module__ for any decimal class; novel chain-of-types anchor in decmod48 namespace); decimal.Context.__module__.__class__.__name__.__eq__('str') (NOVEL); decimal.DecimalException.__module__.__class__.__name__.__eq__('str') (NOVEL); decimal.InvalidOperation.__module__.__class__.__name__.__eq__('str') (NOVEL); decimal.getcontext.__module__.__class__.__name__.__eq__('str') (NOVEL — getcontext.__module__=='_decimal'; its type is still str; novel); decimal.Decimal.__module__.__class__.__name__.__len__()==3 (NOVEL — the class name 'str' has 3 characters; no prior decimal spec checks the length of __module__.__class__.__name__; novel); decimal.Context.__module__.__class__.__name__.__len__()==3 (NOVEL); decimal.Decimal.__module__.__eq__('decimal') (namespace anchor; covered in decimal_extra13/decimal_extra24); decimal.Context.__module__.__eq__('decimal') (namespace anchor; covered in decimal_extra6/decimal_extra9); decimal.DecimalException.__module__.__eq__('decimal') (namespace anchor; covered in decimal_extra6/decimal_extra36); decimal.getcontext.__module__.__eq__('_decimal') (namespace anchor; covered in decimal_extra27 — C extension function, not 'decimal')."
    - "decimal.Decimal.__module__.__class__.__name__ == 'str'. The __module__ attribute of every Python class is a string. Decimal.__module__ == 'decimal', which is a str instance. Its __class__.__name__ == 'str'. No prior decimal spec chains through __module__.__class__.__name__. Novel type-of-module anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Context.__module__.__class__.__name__ == 'str'. Context.__module__ == 'decimal' (str). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__module__.__class__.__name__ == 'str'. DecimalException.__module__ == 'decimal' (str). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__module__.__class__.__name__ == 'str'. InvalidOperation.__module__ == 'decimal' (str). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.getcontext.__module__.__class__.__name__ == 'str'. getcontext is a C-extension function; getcontext.__module__ == '_decimal' (str, C extension module name). Its type is still str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__module__.__class__.__name__.__len__() == 3. The string 'str' has 3 characters. No prior decimal spec checks the length of any __module__.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Context.__module__.__class__.__name__.__len__() == 3. 'str' has 3 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.getcontext.__module__.__eq__('_decimal'). getcontext is implemented in the _decimal C extension; its __module__ is '_decimal' not 'decimal'. decimal_extra27 covers this. Namespace anchor in decmod48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __module__.__class__.__name__ equality (novel type-of-module axis)
#
# Every class __module__ attribute is a str instance. This chains through
# __module__ -> __class__ -> __name__ to verify that the type of __module__
# is str. No prior decimal spec checks __module__.__class__.__name__ for any
# decimal class or function. This is the novel invariant axis for decimal_extra48.
#
#   Decimal.__module__.__class__.__name__        == 'str'
#   Context.__module__.__class__.__name__        == 'str'
#   DecimalException.__module__.__class__.__name__ == 'str'
#   InvalidOperation.__module__.__class__.__name__ == 'str'
#   getcontext.__module__.__class__.__name__     == 'str'
#
# All five equality anchors are novel in the decmod48 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra48.module_class_name_eq:
  description: "decimal class/function __module__.__class__.__name__.__eq__('str') for Decimal/Context/DecimalException/InvalidOperation/getcontext — __module__ is always a str instance; no prior decimal spec checks __module__.__class__.__name__ for any decimal object; all five novel chain-of-types equality anchors in decmod48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decmod48cname

  columns: [id, function, args, expected]
  rows:
    - [Decimal_module_class_name,          "Decimal.__module__.__class__.__name__.__eq__",          ["str"], true]
    - [Context_module_class_name,          "Context.__module__.__class__.__name__.__eq__",          ["str"], true]
    - [DecimalException_module_class_name, "DecimalException.__module__.__class__.__name__.__eq__", ["str"], true]
    - [InvalidOperation_module_class_name, "InvalidOperation.__module__.__class__.__name__.__eq__", ["str"], true]
    - [getcontext_module_class_name,       "getcontext.__module__.__class__.__name__.__eq__",       ["str"], true]

# ---------------------------------------------------------------------------
# decimal class __module__.__class__.__name__ lengths (novel length axis)
#
# The class name of str is 'str' which has 3 characters. No prior decimal spec
# checks the length of __module__.__class__.__name__ for any decimal object.
#
#   Decimal.__module__.__class__.__name__.__len__()  == 3
#   Context.__module__.__class__.__name__.__len__()  == 3
#
# Both length anchors are novel in the decmod48 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra48.module_class_name_len:
  description: "decimal class __module__.__class__.__name__.__len__() for Decimal(3)/Context(3) — 'str' has 3 characters; no prior decimal spec checks length of __module__.__class__.__name__; both novel length anchors in decmod48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: decmod48clen

  columns: [id, function, args, expected]
  rows:
    - [Decimal_module_class_name_len, "Decimal.__module__.__class__.__name__.__len__", [], 3]
    - [Context_module_class_name_len, "Context.__module__.__class__.__name__.__len__", [], 3]

# ---------------------------------------------------------------------------
# decimal class __module__ equality (decmod48 namespace anchors)
#
# These equality values were established in earlier specs. This table
# consolidates key anchors in the decmod48 namespace for cross-spec
# consistency:
#
#   Decimal.__module__         == 'decimal'   (decimal_extra13/decimal_extra24)
#   Context.__module__         == 'decimal'   (decimal_extra6/decimal_extra9)
#   DecimalException.__module__ == 'decimal'  (decimal_extra6/decimal_extra36)
#   getcontext.__module__      == '_decimal'  (decimal_extra27 — C extension)
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra48.class_module_eq:
  description: "decimal class/function __module__.__eq__() for Decimal/'decimal'/Context/'decimal'/DecimalException/'decimal'/getcontext/'_decimal' — getcontext is a C-extension function with __module__=='_decimal' (8 chars), not 'decimal'; namespace anchors in decmod48 complementing earlier specs; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decmod48eq

  columns: [id, function, args, expected]
  rows:
    - [Decimal_module_eq,          Decimal.__module__.__eq__,          ["decimal"],  true]
    - [Context_module_eq,          Context.__module__.__eq__,          ["decimal"],  true]
    - [DecimalException_module_eq, DecimalException.__module__.__eq__, ["decimal"],  true]
    - [getcontext_module_eq,       getcontext.__module__.__eq__,       ["_decimal"], true]
