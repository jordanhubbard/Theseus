spec: _datetime
version: ">=3.7"
backend: python_module(_datetime)

docs: https://docs.python.org/3/library/datetime.html
rfcs:
  - "RFC 3339 — Date and Time on the Internet: Timestamps"
  - "ISO 8601 — Date and time — Representations for information interchange"

provenance:
  derived_from:
    - "Python 3 datetime documentation — https://docs.python.org/3/library/datetime.html"
    - "ISO 8601 date/time format specification"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "_datetime is the optional C accelerator for the datetime module; it is imported directly here."
    - "When available, the C accelerator is used automatically by 'import datetime'; this spec tests it in isolation."
    - "Class names exposed by _datetime match those of the pure-Python fallback: date, time, datetime, timedelta, timezone."
    - "datetime.__module__ reports 'datetime' (the public module name), not '_datetime', on all tested platforms."
    - "timedelta(days=1).days == 1 and timedelta(seconds=3600).seconds == 3600 are foundational arithmetic invariants."
    - "timezone.utc is a class-level singleton; its __class__.__name__ == 'timezone'."
    - "date(2026, 4, 9).__class__.__name__ == 'date' confirms the C type is usable as a constructor."
    - "datetime(2026, 4, 9, 12, 0).__class__.__name__ == 'datetime' likewise."
    - "All expected values verified by running Python 3.12 _datetime on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant _datetime.date.class_name:
  description: "_datetime.date.__name__ == 'date'"
  category: classnames
  kind: python_call_eq
  function: date.__name__.__eq__
  args: ["date"]
  expected: true

invariant _datetime.datetime.class_name:
  description: "_datetime.datetime.__name__ == 'datetime'"
  category: classnames
  kind: python_call_eq
  function: datetime.__name__.__eq__
  args: ["datetime"]
  expected: true

invariant _datetime.timedelta.class_name:
  description: "_datetime.timedelta.__name__ == 'timedelta'"
  category: classnames
  kind: python_call_eq
  function: timedelta.__name__.__eq__
  args: ["timedelta"]
  expected: true

invariant _datetime.timezone.class_name:
  description: "_datetime.timezone.__name__ == 'timezone'"
  category: classnames
  kind: python_call_eq
  function: timezone.__name__.__eq__
  args: ["timezone"]
  expected: true

invariant _datetime.time.class_name:
  description: "_datetime.time.__name__ == 'time'"
  category: classnames
  kind: python_call_eq
  function: time.__name__.__eq__
  args: ["time"]
  expected: true

# ---------------------------------------------------------------------------
# timedelta — days and seconds attributes
# ---------------------------------------------------------------------------

invariant _datetime.timedelta.days_one:
  description: "_datetime.timedelta(days=1).days == 1"
  category: timedelta
  kind: python_call_eq
  function: timedelta
  args: [1]
  method: days
  expected: 1

invariant _datetime.timedelta.days_seven:
  description: "_datetime.timedelta(days=7).days == 7 — seven-day timedelta"
  category: timedelta
  kind: python_call_eq
  function: timedelta
  args: [7]
  method: days
  expected: 7

invariant _datetime.timedelta.seconds_3600:
  description: "_datetime.timedelta(0, 3600).seconds == 3600 — one hour as seconds component"
  category: timedelta
  kind: python_call_eq
  function: timedelta
  args: [0, 3600]
  method: seconds
  expected: 3600

invariant _datetime.timedelta.total_seconds:
  description: "_datetime.timedelta(0, 3600).total_seconds() == 3600.0"
  category: timedelta
  kind: python_call_eq
  function: timedelta
  args: [0, 3600]
  method: total_seconds
  expected: 3600.0

invariant _datetime.timedelta.negative:
  description: "_datetime.timedelta(-1).days == -1 — negative timedelta is supported"
  category: timedelta
  kind: python_call_eq
  function: timedelta
  args: [-1]
  method: days
  expected: -1

# ---------------------------------------------------------------------------
# date — constructor and isoformat
# ---------------------------------------------------------------------------

invariant _datetime.date.isoformat:
  description: "_datetime.date(2026, 4, 9).isoformat() == '2026-04-09'"
  category: date_construction
  rfc: "ISO 8601"
  kind: python_call_eq
  function: date
  args: [2026, 4, 9]
  method: isoformat
  expected: "2026-04-09"

invariant _datetime.date.instance_class_name:
  description: "_datetime.date(2026, 4, 9).__class__.__name__ == 'date'"
  category: date_construction
  kind: python_call_eq
  function: date
  args: [2026, 4, 9]
  method: __class__.__name__.__eq__
  method_args: ["date"]
  expected: true

# ---------------------------------------------------------------------------
# datetime — constructor and isoformat
# ---------------------------------------------------------------------------

invariant _datetime.datetime.isoformat:
  description: "_datetime.datetime(2026, 4, 9, 12, 0).isoformat() == '2026-04-09T12:00:00'"
  category: datetime_construction
  rfc: "ISO 8601"
  kind: python_call_eq
  function: datetime
  args: [2026, 4, 9, 12, 0]
  method: isoformat
  expected: "2026-04-09T12:00:00"

invariant _datetime.datetime.instance_class_name:
  description: "_datetime.datetime(2026, 4, 9, 12, 0).__class__.__name__ == 'datetime'"
  category: datetime_construction
  kind: python_call_eq
  function: datetime
  args: [2026, 4, 9, 12, 0]
  method: __class__.__name__.__eq__
  method_args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# timezone.utc — class-level singleton
# ---------------------------------------------------------------------------

invariant _datetime.timezone_utc.class_name:
  description: "_datetime.timezone.utc.__class__.__name__ == 'timezone'"
  category: classnames
  kind: python_call_eq
  function: timezone.utc.__class__.__name__.__eq__
  args: ["timezone"]
  expected: true

