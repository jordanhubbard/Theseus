spec: sys_extra15
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra14.zspec.zsdl."
    - "sys_extra6 covers version_info.major.__eq__(3) and version_info.minor/__qualname__."
    - "sys_extra2 covers sys.version.__class__.__name__=='str' and sys.platform.__class__.__name__=='str'."
    - "sys_extra10 covers prefix/__class__.__name__, executable/__class__.__name__."
    - "sys_extra8 covers argv.__class__.__name__=='list'."
    - "sys_extra.zspec covers flags.__class__.__name__=='flags'."
    - "sys_platform.zspec covers modules.__class__.__name__=='dict'."
    - "NOT yet covered: sys.version_info.major.__class__.__name__ == 'int'."
    - "NOT yet covered: sys.version_info.minor.__class__.__name__ == 'int'."
    - "NOT yet covered: sys.version_info.micro.__class__.__name__ == 'int'."
    - "NOT yet covered: sys.stdin.__class__.__name__ — type of the stdin stream object."
    - "NOT yet covered: sys.stdout.__class__.__name__ — type of the stdout stream object."
    - "NOT yet covered: sys.stderr.__class__.__name__ — type of the stderr stream object."
    - "NOT yet covered: sys.api_version.__class__.__name__ == 'int'."
    - "sys.version_info.major/minor/micro are always int — they are integer fields of the named tuple."
    - "sys.stdin/stdout/stderr are TextIOWrapper instances in normal execution."
    - "sys.api_version is always an int (the C API version number)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.version_info field types — major, minor, micro
#
# sys_extra6 covers version_info.major.__eq__(3) and version_info.minor.__ge__(0).
# sys_extra.zspec covers version_info.__class__.__name__ == 'version_info'.
# No prior spec covers the type of individual fields (major, minor, micro)
# via __class__.__name__. All three are always int.
# ---------------------------------------------------------------------------

invariant sys_extra15.version_info.major_is_int:
  description: "sys.version_info.major.__class__.__name__ == 'int' — major field is always int"
  category: version_info
  kind: python_call_eq
  function: version_info.major.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra15.version_info.minor_is_int:
  description: "sys.version_info.minor.__class__.__name__ == 'int' — minor field is always int"
  category: version_info
  kind: python_call_eq
  function: version_info.minor.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra15.version_info.micro_is_int:
  description: "sys.version_info.micro.__class__.__name__ == 'int' — micro field is always int"
  category: version_info
  kind: python_call_eq
  function: version_info.micro.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sys.stdin, sys.stdout, sys.stderr — type check
#
# No prior sys spec covers sys.stdin, sys.stdout, or sys.stderr. In normal
# CPython execution (not pytest capture mode), all three are TextIOWrapper
# instances. The class name is 'TextIOWrapper'.
# ---------------------------------------------------------------------------

invariant sys_extra15.stdin.class_name:
  description: "sys.stdin.__class__.__name__ == 'TextIOWrapper' — stdin is a text stream"
  category: streams
  kind: python_call_eq
  function: stdin.__class__.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant sys_extra15.stdout.class_name:
  description: "sys.stdout.__class__.__name__ == 'TextIOWrapper' — stdout is a text stream"
  category: streams
  kind: python_call_eq
  function: stdout.__class__.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant sys_extra15.stderr.class_name:
  description: "sys.stderr.__class__.__name__ == 'TextIOWrapper' — stderr is a text stream"
  category: streams
  kind: python_call_eq
  function: stderr.__class__.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

# ---------------------------------------------------------------------------
# sys.api_version — type check
#
# sys.zspec.zsdl covers sys.api_version.__eq__(1013) (the exact value).
# sys_extra5 covers sys.hexversion.__class__.__name__ == 'int'.
# No prior spec covers sys.api_version.__class__.__name__. The C API version
# is always an int.
# ---------------------------------------------------------------------------

invariant sys_extra15.api_version.is_int:
  description: "sys.api_version.__class__.__name__ == 'int' — C API version is always an int"
  category: attributes
  kind: python_call_eq
  function: api_version.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra15.api_version.ge_1000:
  description: "sys.api_version >= 1000 — API version is always a four-digit-or-larger number"
  category: attributes
  kind: python_call_eq
  function: api_version.__ge__
  args: [1000]
  expected: true

# ---------------------------------------------------------------------------
# sys.version_info — length check
#
# sys_extra.zspec covers version_info.__class__.__name__.
# sys_extra6 covers version_info.major and version_info.minor.
# No prior spec verifies len(sys.version_info) == 5 — the named tuple has
# five fields: major, minor, micro, releaselevel, serial.
# ---------------------------------------------------------------------------

invariant sys_extra15.version_info.length:
  description: "len(sys.version_info) == 5 — version_info has five fields: major, minor, micro, releaselevel, serial"
  category: version_info
  kind: python_call_eq
  function: version_info.__len__
  args: []
  expected: 5
