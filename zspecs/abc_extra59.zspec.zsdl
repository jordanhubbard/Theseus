spec: abc_extra59
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_name and co_argcount documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra58.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52), abc.__package__.__eq__('') (extra53), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str') (extra53), ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') (extra53), __loader__.__class__.__name__.__eq__('type') (extra54), __loader__.__name__.__eq__('FrozenImporter') (extra54), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra54), __file__.__class__.__name__.__eq__('str') (extra54), ABCMeta.__instancecheck__.__qualname__.__len__()==25 (extra54), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__name__.__len__() (extra55), ABCMeta.register/__instancecheck__/__subclasscheck__/update_abstractmethods __qualname__.__eq__ (extra56), abstractproperty.__init__.__qualname__.__eq__('property.__init__') (extra56), abstractmethod/__annotations__/__globals__ class identity, ABCMeta/__doc__.__contains__('Abstract'), get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') (extra57), abstractmethod/__defaults__/__code__/__closure__/__class__.__name__ checks, update_abstractmethods/__defaults__/__code__/__class__.__name__ checks (extra58)."
    - "This spec covers (abccode2_59 namespace): wave 230 theme — __code__.co_name equality + co_argcount values + co_name __class__.__name__ checks. NEW in extra59: abstractmethod.__code__.co_name.__eq__('abstractmethod') — abstractmethod is a pure-Python function defined in Lib/abc.py; co_name stores the definition name 'abstractmethod'; no prior abc spec has checked abstractmethod.__code__.co_name via __eq__; update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods') — co_name of update_abstractmethods is 'update_abstractmethods'; ABCMeta.__instancecheck__.__code__.co_name.__eq__('__instancecheck__') — co_name of ABCMeta.__instancecheck__ is '__instancecheck__'; abstractmethod.__code__.co_argcount.__eq__(1) — abstractmethod(funcobj) has 1 positional-or-keyword param; update_abstractmethods.__code__.co_argcount.__eq__(1) — update_abstractmethods(cls) has 1; ABCMeta.__instancecheck__.__code__.co_argcount.__eq__(2) — ABCMeta.__instancecheck__(self, instance) has 2."
    - "abc.abstractmethod.__code__.co_name == 'abstractmethod'. abstractmethod is defined as 'def abstractmethod(funcobj)' in Lib/abc.py. co_name stores the function's definition name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods'. update_abstractmethods is defined as 'def update_abstractmethods(cls)' in Lib/abc.py. co_name is 'update_abstractmethods'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__'. ABCMeta.__instancecheck__ is defined as 'def __instancecheck__(cls, instance)' in Lib/abc.py. co_name is '__instancecheck__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_argcount == 1. abstractmethod(funcobj) has one positional-or-keyword parameter: funcobj. co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_argcount == 1. update_abstractmethods(cls) has one positional-or-keyword parameter: cls. co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2. ABCMeta.__instancecheck__(cls, instance) has two positional-or-keyword parameters: cls and instance. co_argcount is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "co_name.__class__.__name__ == 'str'. The co_name attribute on all code objects is a str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "co_argcount.__class__.__name__ == 'int'. The co_argcount attribute on all code objects is an int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc __code__.co_name.__eq__ checks — extra59
#
# Wave 230 theme: __code__.co_name equality checks.
#
# co_name is the string name stored in the code object, matching the function's
# definition name. For abstractmethod, update_abstractmethods, and
# ABCMeta.__instancecheck__ the co_name equals the function's definition name.
#
# NEW: no prior abc spec has checked __code__.co_name via __eq__ for any of
# these functions.
# ---------------------------------------------------------------------------

table abc_extra59.function_code_co_name_eq:
  description: "abc __code__.co_name.__eq__ checks in abccode2_59 namespace — wave 230 theme: co_name equality; abstractmethod.__code__.co_name=='abstractmethod', update_abstractmethods.__code__.co_name=='update_abstractmethods', ABCMeta.__instancecheck__.__code__.co_name=='__instancecheck__'; co_name is the string name stored in the code object matching the function definition name; NEW in extra59: no prior abc spec has checked __code__.co_name via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode2_59

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_name_eq,       abstractmethod.__code__.co_name.__eq__,              ["abstractmethod"],       true, "abstractmethod.__code__.co_name == 'abstractmethod' — abstractmethod is defined as 'def abstractmethod(funcobj)' in Lib/abc.py; co_name stores the function's definition name as a str; __eq__('abstractmethod') returns True; NEW in extra59: first __code__.co_name.__eq__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_name_eq,                  update_abstractmethods.__code__.co_name.__eq__,       ["update_abstractmethods"], true, "update_abstractmethods.__code__.co_name == 'update_abstractmethods' — update_abstractmethods is defined as 'def update_abstractmethods(cls)' in Lib/abc.py; co_name stores the definition name; __eq__('update_abstractmethods') returns True; NEW in extra59: first __code__.co_name.__eq__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_name_eq,        ABCMeta.__instancecheck__.__code__.co_name.__eq__,    ["__instancecheck__"],    true, "ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__' — ABCMeta.__instancecheck__ is defined as 'def __instancecheck__(cls, instance)' in Lib/abc.py; co_name is '__instancecheck__'; __eq__('__instancecheck__') returns True; NEW in extra59: first __code__.co_name.__eq__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __code__.co_argcount.__eq__ checks — extra59
#
# Wave 230 theme: co_argcount values.
#
# co_argcount counts positional-or-keyword parameters only. *args, **kwargs,
# and keyword-only parameters do NOT contribute to co_argcount.
#
# abstractmethod(funcobj): co_argcount == 1
# update_abstractmethods(cls): co_argcount == 1
# ABCMeta.__instancecheck__(cls, instance): co_argcount == 2
# ---------------------------------------------------------------------------

table abc_extra59.function_code_co_argcount_eq:
  description: "abc __code__.co_argcount.__eq__ checks in abccode2_59 namespace — wave 230 theme: co_argcount values; co_argcount counts positional-or-keyword parameters only; abstractmethod==1 (funcobj), update_abstractmethods==1 (cls), ABCMeta.__instancecheck__==2 (cls+instance); NEW in extra59: no prior abc spec has checked __code__.co_argcount via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode2_59a

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_argcount_eq,   abstractmethod.__code__.co_argcount.__eq__,           [1], true, "abstractmethod.__code__.co_argcount == 1 — abstractmethod(funcobj) has one positional-or-keyword parameter: funcobj; co_argcount is 1; NEW in extra59: first __code__.co_argcount.__eq__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_argcount_eq,              update_abstractmethods.__code__.co_argcount.__eq__,    [1], true, "update_abstractmethods.__code__.co_argcount == 1 — update_abstractmethods(cls) has one positional-or-keyword parameter: cls; co_argcount is 1; NEW in extra59: first __code__.co_argcount.__eq__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_argcount_eq,    ABCMeta.__instancecheck__.__code__.co_argcount.__eq__, [2], true, "ABCMeta.__instancecheck__.__code__.co_argcount == 2 — ABCMeta.__instancecheck__(cls, instance) has two positional-or-keyword parameters: cls and instance; co_argcount is 2; NEW in extra59: first __code__.co_argcount.__eq__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __code__.co_name.__class__.__name__.__eq__ checks — extra59
#
# Wave 230 theme: co_name __class__.__name__ checks.
#
# co_name is always a str on all code objects. str.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table abc_extra59.function_code_co_name_class_name_eq:
  description: "abc __code__.co_name.__class__.__name__.__eq__('str') checks in abccode2_59 namespace — wave 230 theme: co_name type identity; co_name is always a str on all code objects; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ all have co_name.__class__.__name__=='str'; NEW in extra59: no prior abc spec has checked __code__.co_name.__class__.__name__ via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode2_59c

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_name_class_eq,  abstractmethod.__code__.co_name.__class__.__name__.__eq__,              ["str"], true, "abstractmethod.__code__.co_name.__class__.__name__ == 'str' — the co_name attribute of any code object is a str; abstractmethod.__code__.co_name is 'abstractmethod', a str; str.__class__.__name__ is 'str'; NEW in extra59: first __code__.co_name.__class__.__name__.__eq__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_name_class_eq,             update_abstractmethods.__code__.co_name.__class__.__name__.__eq__,       ["str"], true, "update_abstractmethods.__code__.co_name.__class__.__name__ == 'str' — update_abstractmethods.__code__.co_name is 'update_abstractmethods', a str; str.__class__.__name__ is 'str'; NEW in extra59: first __code__.co_name.__class__.__name__.__eq__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_name_class_eq,   ABCMeta.__instancecheck__.__code__.co_name.__class__.__name__.__eq__,    ["str"], true, "ABCMeta.__instancecheck__.__code__.co_name.__class__.__name__ == 'str' — ABCMeta.__instancecheck__.__code__.co_name is '__instancecheck__', a str; str.__class__.__name__ is 'str'; NEW in extra59: first __code__.co_name.__class__.__name__.__eq__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra59
# ---------------------------------------------------------------------------

invariant abc_extra59.abstractmethod_co_name_eq:
  description: "abc.abstractmethod.__code__.co_name.__eq__('abstractmethod') returns True — abstractmethod is defined as 'def abstractmethod(funcobj)' in Lib/abc.py; co_name stores the function's definition name; __eq__('abstractmethod') returns True; NEW in extra59: no prior abc spec has checked abstractmethod.__code__.co_name via __eq__; wave 230 first co_name equality invariant for abstractmethod in any abc spec; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_name.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra59.update_abstractmethods_co_name_eq:
  description: "abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods') returns True — update_abstractmethods is defined as 'def update_abstractmethods(cls)' in Lib/abc.py; co_name stores the definition name 'update_abstractmethods'; __eq__('update_abstractmethods') returns True; NEW in extra59: no prior abc spec has checked update_abstractmethods.__code__.co_name via __eq__; wave 230 invariant alongside abstractmethod co_name check; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: update_abstractmethods.__code__.co_name.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra59.abcmeta_instancecheck_co_name_eq:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_name.__eq__('__instancecheck__') returns True — ABCMeta.__instancecheck__ is defined as 'def __instancecheck__(cls, instance)' in Lib/abc.py; co_name is '__instancecheck__'; __eq__('__instancecheck__') returns True; NEW in extra59: no prior abc spec has checked ABCMeta.__instancecheck__.__code__.co_name via __eq__; wave 230 first co_name equality invariant for ABCMeta.__instancecheck__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__code__.co_name.__eq__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra59.abstractmethod_co_argcount_eq:
  description: "abc.abstractmethod.__code__.co_argcount.__eq__(1) returns True — abstractmethod(funcobj) has one positional-or-keyword parameter: funcobj; co_argcount is 1; NEW in extra59: no prior abc spec has checked abstractmethod.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant abc_extra59.update_abstractmethods_co_argcount_eq:
  description: "abc.update_abstractmethods.__code__.co_argcount.__eq__(1) returns True — update_abstractmethods(cls) has one positional-or-keyword parameter: cls; co_argcount is 1; NEW in extra59: no prior abc spec has checked update_abstractmethods.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for update_abstractmethods; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: update_abstractmethods.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant abc_extra59.abcmeta_instancecheck_co_argcount_eq:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_argcount.__eq__(2) returns True — ABCMeta.__instancecheck__(cls, instance) has two positional-or-keyword parameters: cls and instance; co_argcount is 2; NEW in extra59: no prior abc spec has checked ABCMeta.__instancecheck__.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for ABCMeta.__instancecheck__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra59.abstractmethod_co_name_class_name_eq:
  description: "abc.abstractmethod.__code__.co_name.__class__.__name__.__eq__('str') returns True — co_name on any code object is always a str; abstractmethod.__code__.co_name is 'abstractmethod', a str; str.__class__.__name__ is 'str'; NEW in extra59: no prior abc spec has checked abstractmethod.__code__.co_name.__class__.__name__ via __eq__; wave 230 co_name type identity invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra59.abcmeta_instancecheck_co_name_class_name_eq:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_name.__class__.__name__.__eq__('str') returns True — ABCMeta.__instancecheck__.__code__.co_name is '__instancecheck__', a str; str.__class__.__name__ is 'str'; NEW in extra59: no prior abc spec has checked ABCMeta.__instancecheck__.__code__.co_name.__class__.__name__ via __eq__; wave 230 co_name type identity invariant for ABCMeta.__instancecheck__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
