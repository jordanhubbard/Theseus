spec: decimal_extra86
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra85

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra85."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal dunders; Decimal comparison/equality/hash; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__/__module__; Decimal division/power operator; Context arithmetic method __class__.__name__; Decimal arithmetic/string/conversion dunder __qualname__; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__; Decimal.__dict__.__contains__; Decimal/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); Context/__name__/__module__/__qualname__; ROUND_* constants; Decimal method qualnames; Context class identity and __dict__ membership; signal exception __name__ and __module__."
    - "This spec covers: decimal.Decimal class __dict__ membership for math methods, dunder arithmetic operators, dunder string/repr methods, and the __dict__ proxy class identity."
    - "decimal.Decimal.__dict__.__contains__('quantize') == True — quantize is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('normalize') == True — normalize is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('sqrt') == True — sqrt is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('as_tuple') == True — as_tuple is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('compare') == True — compare is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('fma') == True — fma (fused multiply-add) is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('__add__') == True — __add__ is a C-level slot on Decimal."
    - "decimal.Decimal.__dict__.__contains__('__mul__') == True — __mul__ is a C-level slot on Decimal."
    - "decimal.Decimal.__dict__.__contains__('__str__') == True — __str__ is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('__repr__') == True — __repr__ is defined directly on Decimal."
    - "decimal.Decimal.__dict__.__contains__('__neg__') == True — __neg__ is a C-level slot on Decimal."
    - "decimal.Decimal.__dict__.__contains__('__pos__') == True — __pos__ is a C-level slot on Decimal."
    - "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' — __dict__ is a mappingproxy object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal __dict__ membership: math methods
# quantize/normalize/sqrt/as_tuple/compare/fma are all defined directly on Decimal.
# These are C-extension methods from the _decimal C module.
# ---------------------------------------------------------------------------

table decimal_extra86.Decimal_dict_math_methods:
  description: "decimal.Decimal.__dict__.__contains__ for quantize/normalize/sqrt/as_tuple/compare/fma (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimaldictmem86

  columns: [id, function, args, expected]
  rows:
    - [decimal_has_quantize,  Decimal.__dict__.__contains__, ["quantize"],  true]
    - [decimal_has_normalize, Decimal.__dict__.__contains__, ["normalize"], true]
    - [decimal_has_sqrt,      Decimal.__dict__.__contains__, ["sqrt"],      true]
    - [decimal_has_as_tuple,  Decimal.__dict__.__contains__, ["as_tuple"],  true]
    - [decimal_has_compare,   Decimal.__dict__.__contains__, ["compare"],   true]
    - [decimal_has_fma,       Decimal.__dict__.__contains__, ["fma"],       true]

# ---------------------------------------------------------------------------
# decimal.Decimal __dict__ membership: dunder arithmetic operators
# __add__ and __mul__ are C-level numeric slots defined directly on Decimal.
# ---------------------------------------------------------------------------

table decimal_extra86.Decimal_dict_dunder_arithmetic:
  description: "decimal.Decimal.__dict__.__contains__ for __add__/__mul__ and negative checks"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimaldictmem86

  columns: [id, function, args, expected]
  rows:
    - [decimal_has_add,       Decimal.__dict__.__contains__, ["__add__"],    true]
    - [decimal_has_mul,       Decimal.__dict__.__contains__, ["__mul__"],    true]
    - [decimal_has_neg,       Decimal.__dict__.__contains__, ["__neg__"],    true]
    - [decimal_has_pos,       Decimal.__dict__.__contains__, ["__pos__"],    true]

# ---------------------------------------------------------------------------
# decimal.Decimal __dict__ membership: __str__ and __repr__
# Both __str__ and __repr__ are defined directly on Decimal.
# ---------------------------------------------------------------------------

table decimal_extra86.Decimal_dict_str_repr:
  description: "decimal.Decimal.__dict__.__contains__ for __str__/__repr__ (both True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimaldictmem86

  columns: [id, function, args, expected]
  rows:
    - [decimal_has_str,       Decimal.__dict__.__contains__, ["__str__"],    true]
    - [decimal_has_repr,      Decimal.__dict__.__contains__, ["__repr__"],   true]
    - [decimal_no_format_str, Decimal.__dict__.__contains__, ["__format__"], true]
    - [decimal_no_bytes,      Decimal.__dict__.__contains__, ["__bytes__"],  false]

# ---------------------------------------------------------------------------
# decimal.Decimal __dict__ class identity + additional membership
# __dict__.__class__.__name__ is 'mappingproxy' for all Python type __dict__.
# ---------------------------------------------------------------------------

table decimal_extra86.Decimal_dict_class_identity:
  description: "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy'; additional membership checks"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimaldictmem86

  columns: [id, function, args, expected]
  rows:
    - [dict_class_name,       Decimal.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [dict_not_dict,         Decimal.__dict__.__class__.__name__.__eq__, ["dict"],         false]
    - [decimal_has_quantize2, Decimal.__dict__.__contains__,              ["quantize"],     true]
    - [decimal_no_nonexist,   Decimal.__dict__.__contains__,              ["nonexistent"],  false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra86.Decimal.dict_quantize:
  description: "decimal.Decimal.__dict__.__contains__('quantize') == True (quantize is a C-extension method defined directly on Decimal)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["quantize"]
  expected: true

invariant decimal_extra86.Decimal.dict_sqrt:
  description: "decimal.Decimal.__dict__.__contains__('sqrt') == True (sqrt is a C-extension method defined directly on Decimal)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["sqrt"]
  expected: true

invariant decimal_extra86.Decimal.dict_add:
  description: "decimal.Decimal.__dict__.__contains__('__add__') == True (__add__ is a C-level numeric slot defined on Decimal)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["__add__"]
  expected: true

invariant decimal_extra86.Decimal.dict_str:
  description: "decimal.Decimal.__dict__.__contains__('__str__') == True (__str__ is defined directly on Decimal)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["__str__"]
  expected: true

invariant decimal_extra86.Decimal.dict_class_mappingproxy:
  description: "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' (type __dict__ is always a mappingproxy)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
