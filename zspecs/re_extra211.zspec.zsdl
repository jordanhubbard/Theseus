spec: re_extra211
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers re.sub, re.findall, re.split, re.escape, re.error"
    - "re_extra.zspec.zsdl — covers re module-level function behavior"
  notes:
    - "re.compile.__annotations__ is an empty dict {}; Python 3.9+ re module functions carry no type annotations."
    - "re.match.__annotations__ is also an empty dict {}; confirmed Python 3.14.3 macOS."
    - "re.compile.__annotations__.__class__.__name__ == 'dict'; confirmed Python 3.14.3 macOS."
    - "re.match.__annotations__.__class__.__name__ == 'dict'; confirmed Python 3.14.3 macOS."
    - "re.Match.__dict__ contains the group, groups, start, end, span, groupdict methods."
    - "re.Match is the concrete match object type returned by re.match(), re.search(), etc."
    - "re.Match.__dict__.__contains__('group') == True; confirmed Python 3.14.3 macOS."
    - "re.Match.__dict__.__contains__('groups') == True; confirmed Python 3.14.3 macOS."
    - "re.Match.__dict__.__contains__('span') == True; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re function __annotations__ — class name checks
# re.compile, re.match, re.search, re.fullmatch carry no annotations (empty dict)
# __annotations__.__class__.__name__ == 'dict' for all re module functions
# ---------------------------------------------------------------------------

table re_extra211.re_function_annotations_class:
  description: "re module functions carry __annotations__ of type 'dict' (empty in Python 3.14.3)"
  kind: python_call_eq
  category: annotations
  id_prefix: reannotations211

  columns: [id, function, args, expected, description]
  rows:
    - [compile_annotations_class,   "re.compile.__annotations__.__class__.__name__.__eq__",   ["dict"],  true,  "re.compile.__annotations__.__class__.__name__ == 'dict'; annotations container is always a dict; confirmed Python 3.14.3 macOS"]
    - [match_annotations_class,     "re.match.__annotations__.__class__.__name__.__eq__",     ["dict"],  true,  "re.match.__annotations__.__class__.__name__ == 'dict'; annotations container is always a dict; confirmed Python 3.14.3 macOS"]
    - [search_annotations_class,    "re.search.__annotations__.__class__.__name__.__eq__",    ["dict"],  true,  "re.search.__annotations__.__class__.__name__ == 'dict'; annotations container is always a dict; confirmed Python 3.14.3 macOS"]
    - [fullmatch_annotations_class, "re.fullmatch.__annotations__.__class__.__name__.__eq__", ["dict"],  true,  "re.fullmatch.__annotations__.__class__.__name__ == 'dict'; annotations container is always a dict; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Match.__dict__ membership — match accessor methods
# group, groups, start, end are concrete methods in re.Match.__dict__
# ---------------------------------------------------------------------------

table re_extra211.match_dict_accessor_methods:
  description: "re.Match.__dict__ contains the concrete group-accessor method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reannotations211

  columns: [id, function, args, expected, description]
  rows:
    - [match_has_group,   "re.Match.__dict__.__contains__",  ["group"],   true,  "re.Match.__dict__.__contains__('group') == True; group is a concrete method on re.Match; confirmed Python 3.14.3 macOS"]
    - [match_has_groups,  "re.Match.__dict__.__contains__",  ["groups"],  true,  "re.Match.__dict__.__contains__('groups') == True; groups is a concrete method on re.Match; confirmed Python 3.14.3 macOS"]
    - [match_has_start,   "re.Match.__dict__.__contains__",  ["start"],   true,  "re.Match.__dict__.__contains__('start') == True; start is a concrete method on re.Match; confirmed Python 3.14.3 macOS"]
    - [match_has_end,     "re.Match.__dict__.__contains__",  ["end"],     true,  "re.Match.__dict__.__contains__('end') == True; end is a concrete method on re.Match; confirmed Python 3.14.3 macOS"]
    - [match_has_span,    "re.Match.__dict__.__contains__",  ["span"],    true,  "re.Match.__dict__.__contains__('span') == True; span is a concrete method on re.Match; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Match.__dict__ membership — groupdict and other methods
# groupdict is also present; re.Match does not carry arbitrary extra attributes
# ---------------------------------------------------------------------------

table re_extra211.match_dict_other_methods:
  description: "re.Match.__dict__ contains groupdict and does not carry non-existent methods"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reannotations211

  columns: [id, function, args, expected, description]
  rows:
    - [match_has_groupdict,    "re.Match.__dict__.__contains__",  ["groupdict"],   true,   "re.Match.__dict__.__contains__('groupdict') == True; groupdict is a concrete method on re.Match; confirmed Python 3.14.3 macOS"]
    - [match_no_compile,       "re.Match.__dict__.__contains__",  ["compile"],     false,  "re.Match.__dict__.__contains__('compile') == False; compile is a module-level function, not a Match method; confirmed Python 3.14.3 macOS"]
    - [match_no_findall,       "re.Match.__dict__.__contains__",  ["findall"],     false,  "re.Match.__dict__.__contains__('findall') == False; findall is a module-level function, not a Match method; confirmed Python 3.14.3 macOS"]
    - [match_no_sub,           "re.Match.__dict__.__contains__",  ["sub"],         false,  "re.Match.__dict__.__contains__('sub') == False; sub is a module-level function, not a Match method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra211.compile_annotations_class:
  description: "re.compile.__annotations__.__class__.__name__ == 'dict' — the annotations attribute is always a dict; confirmed Python 3.14.3 macOS"
  category: annotations
  kind: python_call_eq
  function: re.compile.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

