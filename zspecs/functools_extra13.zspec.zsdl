spec: functools_extra13
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra12.zspec.zsdl."
    - "functools_extra12 covers: __module__ for wraps/total_ordering/singledispatch/cache/lru_cache/singledispatchmethod/cached_property/partialmethod/TopologicalSorter as standalone invariants; partial/__module__ == '_functools'; reduce/__module__ == '_functools'; cmp_to_key/__module__ == '_functools'."
    - "NOT yet covered: reduce.__name__.__len__() — 'reduce' is 6 characters; partial.__name__.__len__() — 'partial' is 7; wraps.__name__.__len__() — 'wraps' is 5; cached_property.__name__.__len__() — 'cached_property' is 15."
    - "NOT yet covered: reduce.__qualname__.__len__() — structural length for 'reduce'; partial.__qualname__.__len__() — structural length for 'partial'."
    - "NOT yet covered: partial.__bases__[0].__name__ == 'object' (extra9 checks partial bases len but not the name); cached_property.__bases__[0].__name__ == 'object' (extra9 checks length only)."
    - "NOT yet covered: functools.WRAPPER_ASSIGNMENTS[0] == '__module__' (index 0 checked in extra9 via __eq__; here via table alongside others not yet checked by direct index)."
    - "NOT yet covered: functools.WRAPPER_ASSIGNMENTS[1] == '__name__'; functools.WRAPPER_ASSIGNMENTS[2] == '__qualname__'; functools.WRAPPER_ASSIGNMENTS[3] == '__doc__' — individual index checks (extra10 covers 1,2,3,-1 via table; adding standalone forms)."
    - "NOT yet covered: functools.reduce.__name__.__len__() == 6."
    - "NOT yet covered: functools.partial.__name__.__len__() == 7."
    - "NOT yet covered: functools.wraps.__name__.__len__() == 5."
    - "NOT yet covered: functools.cached_property.__name__.__len__() == 15."
    - "NOT yet covered: functools.partial.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: functools.cached_property.__bases__[0].__name__ == 'object'."
    - "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters."
    - "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters."
    - "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters."
    - "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ string lengths for key functools symbols
#
# All prior specs verify __name__ via __eq__ (returning true). None check
# the string length of the __name__ attribute. These are structural checks
# distinct from equality, covering reduce, partial, wraps, and cached_property.
# ---------------------------------------------------------------------------

table functools_extra13.function_name_lengths:
  kind: python_call_eq
  category: function_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [reduce,           reduce.__name__.__len__,           [], 6]
    - [partial,          partial.__name__.__len__,          [], 7]
    - [wraps,            wraps.__name__.__len__,            [], 5]
    - [cached_property,  cached_property.__name__.__len__,  [], 15]

# ---------------------------------------------------------------------------
# partial.__bases__[0].__name__ == 'object'
#
# functools_extra9 verified partial.__bases__.__len__() == 1.
# No prior spec checks the actual class name at __bases__[0] for partial.
# partial is a C-level type that inherits from object.
# ---------------------------------------------------------------------------

invariant functools_extra13.partial.base_is_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: partial.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# cached_property.__bases__[0].__name__ == 'object'
#
# functools_extra9 verified cached_property.__bases__.__len__() == 1.
# No prior spec checks the actual class name at __bases__[0] for
# cached_property. cached_property is a Python class that inherits from object.
# ---------------------------------------------------------------------------

invariant functools_extra13.cached_property.base_is_object:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: cached_property.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# reduce.__qualname__.__len__() and partial.__qualname__.__len__()
#
# functools_extra11 verifies reduce.__qualname__ == 'reduce' and
# functools_extra8 verifies partial.__qualname__ == 'partial' via tables.
# No prior spec checks the length of these qualname strings.
# 'reduce' == 6 chars, 'partial' == 7 chars.
# ---------------------------------------------------------------------------

invariant functools_extra13.reduce.qualname_len:
  description: "len(functools.reduce.__qualname__) == 6 — 'reduce' has 6 characters"
  category: qualnames
  kind: python_call_eq
  function: reduce.__qualname__.__len__
  args: []
  expected: 6

invariant functools_extra13.partial.qualname_len:
  description: "len(functools.partial.__qualname__) == 7 — 'partial' has 7 characters"
  category: qualnames
  kind: python_call_eq
  function: partial.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# wraps.__qualname__ standalone invariant
#
# functools_extra8 covers wraps.__qualname__ in a table row. Not yet verified
# as a standalone invariant. wraps is a top-level Python function so its
# __qualname__ equals its __name__ ('wraps').
# ---------------------------------------------------------------------------

invariant functools_extra13.wraps.qualname:
  description: "functools.wraps.__qualname__ == 'wraps' — top-level function, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

# ---------------------------------------------------------------------------
# cached_property.__qualname__ standalone invariant
#
# functools_extra8 covers cached_property.__qualname__ in a table row.
# Not yet verified as a standalone invariant. cached_property is a top-level
# class so its __qualname__ equals its __name__ ('cached_property').
# ---------------------------------------------------------------------------

invariant functools_extra13.cached_property.qualname:
  description: "functools.cached_property.__qualname__ == 'cached_property' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true
