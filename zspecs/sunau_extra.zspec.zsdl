spec: sunau_extra
version: ">=3.9,<3.13"
backend: python_module(sunau)

docs: https://docs.python.org/3/library/sunau.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sunau.html — Python sunau module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sunau.py"
  notes:
    - "Extends sunau.zspec.zsdl with additional function name, class name, module, and hierarchy invariants."
    - "sunau was deprecated in Python 3.11 and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "sunau.open.__name__ == 'open'; the open() function is a pure-Python wrapper defined in Lib/sunau.py."
    - "The implementation classes are Au_read and Au_write (lowercase 'u'), not AU_read / AU_write."
    - "sunau.Error inherits directly from Exception with no intermediate bases."
    - "AUDIO_FILE_MAGIC == 0x2e736e64 (778924900 decimal) — the four-byte '.snd' magic at the start of AU files."
    - "openfp is an alias for open present in Python >=3.9 (deprecated and removed in 3.13)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# open() — function name and module affiliation
# ---------------------------------------------------------------------------

invariant sunau_extra.open.name:
  description: "sunau.open.__name__ == 'open'"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant sunau_extra.open.module:
  description: "sunau.open.__module__ == 'sunau'"
  category: functions
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["sunau"]
  expected: true

# ---------------------------------------------------------------------------
# Error class — name, module, and hierarchy
# ---------------------------------------------------------------------------

invariant sunau_extra.Error.name:
  description: "sunau.Error.__name__ == 'Error'"
  category: classes
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant sunau_extra.Error.module:
  description: "sunau.Error.__module__ == 'sunau'"
  category: classes
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["sunau"]
  expected: true

invariant sunau_extra.Error.base_is_Exception:
  description: "sunau.Error.__bases__[0].__name__ == 'Exception'"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant sunau_extra.Error.bases_len:
  description: "len(sunau.Error.__bases__) == 1 — Error has exactly one direct base"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Au_read — class name and module affiliation
# ---------------------------------------------------------------------------

invariant sunau_extra.Au_read.name:
  description: "sunau.Au_read.__name__ == 'Au_read'"
  category: classes
  kind: python_call_eq
  function: Au_read.__name__.__eq__
  args: ["Au_read"]
  expected: true

invariant sunau_extra.Au_read.module:
  description: "sunau.Au_read.__module__ == 'sunau'"
  category: classes
  kind: python_call_eq
  function: Au_read.__module__.__eq__
  args: ["sunau"]
  expected: true

# ---------------------------------------------------------------------------
# Au_write — class name and module affiliation
# ---------------------------------------------------------------------------

invariant sunau_extra.Au_write.name:
  description: "sunau.Au_write.__name__ == 'Au_write'"
  category: classes
  kind: python_call_eq
  function: Au_write.__name__.__eq__
  args: ["Au_write"]
  expected: true

invariant sunau_extra.Au_write.module:
  description: "sunau.Au_write.__module__ == 'sunau'"
  category: classes
  kind: python_call_eq
  function: Au_write.__module__.__eq__
  args: ["sunau"]
  expected: true

# ---------------------------------------------------------------------------
# AUDIO_FILE_MAGIC constant — value and type
#
# The AU file format begins with the four-byte magic '.snd' = 0x2e736e64.
# As an unsigned 32-bit big-endian integer this is 778_924_900.
# ---------------------------------------------------------------------------

invariant sunau_extra.AUDIO_FILE_MAGIC.value:
  description: "sunau.AUDIO_FILE_MAGIC == 778924900 (0x2e736e64, '.snd' AU magic number)"
  category: constants
  kind: python_call_eq
  function: AUDIO_FILE_MAGIC.__eq__
  args: [778924900]
  expected: true

invariant sunau_extra.AUDIO_FILE_MAGIC.type:
  description: "sunau.AUDIO_FILE_MAGIC.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: AUDIO_FILE_MAGIC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# openfp alias — present in >=3.9 as a deprecated alias for open
# ---------------------------------------------------------------------------

invariant sunau_extra.openfp.is_callable:
  description: "sunau.openfp is callable (alias for open, present >=3.9,<3.13)"
  category: functions
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: openfp.__class__.__name__.__eq__
  args: ["function"]
  expected: true
