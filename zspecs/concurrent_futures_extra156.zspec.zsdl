spec: concurrent_futures_extra156
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: concurrent.futures.Executor method qualnames (submit, map, __enter__, __exit__) and concurrent.futures.process.ProcessPoolExecutor method qualnames (submit, shutdown). concurrent.futures.Executor.submit.__qualname__=='Executor.submit' (len=15); concurrent.futures.Executor.map.__qualname__=='Executor.map' (len=12); concurrent.futures.Executor.__enter__.__qualname__=='Executor.__enter__' (len=18); concurrent.futures.Executor.__exit__.__qualname__=='Executor.__exit__' (len=17); concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26); concurrent.futures.process.ProcessPoolExecutor.shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26: 'ProcessPoolExecutor'=19+'.'=1+'submit'=6=26); 'ProcessPoolExecutor'='Process'=7+'Pool'=4+'Executor'=8=19; len('ProcessPoolExecutor')==19; compare: ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25: 'ThreadPoolExecutor'=18+1+6=25); ProcessPoolExecutor name (19) is 1 char longer than ThreadPoolExecutor name (18) because 'Process'=7 > 'Thread'=6; so PPE qualnames are 1 char longer than TPE qualnames for the same method. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Key distinction from extra154/extra155 (ThreadPoolExecutor): ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23; PPE overrides map) whereas ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=12; TPE does NOT override map, inherits from Executor); this is a significant behavioral difference between TPE and PPE — PPE defines its own map() while TPE inherits it from Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__exit__.__qualname__=='Executor.__exit__' (len=17: 'Executor'=8+'.'=1+'__exit__'=8=17; '__exit__'='_'+'_'+'exit'=4+'_'+'_'=8); compare __enter__.__qualname__=='Executor.__enter__' (len=18: '__enter__'=9 because 'enter'=5 > 'exit'=4); __exit__(18-1=17) is 1 char shorter than __enter__(18). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor method qualnames — extra156
#
# concurrent.futures.Executor.submit.__qualname__    == 'Executor.submit'
# concurrent.futures.Executor.map.__qualname__       == 'Executor.map'
# concurrent.futures.Executor.__enter__.__qualname__ == 'Executor.__enter__'
# concurrent.futures.Executor.__exit__.__qualname__  == 'Executor.__exit__'
# ---------------------------------------------------------------------------

table concurrent_futures_extra156.cf_executor_qualnames:
  description: "concurrent.futures.Executor method qualname checks in cfexec156 namespace — concurrent.futures.Executor.submit.__qualname__=='Executor.submit' (len=15: 'Executor'=8+'.'=1+'submit'=6=15; submit is the abstract method that concrete executors must implement; Executor.submit raises NotImplementedError); concurrent.futures.Executor.map.__qualname__=='Executor.map' (len=12: 'Executor'=8+'.'=1+'map'=3=12; map is implemented on Executor using submit() — it returns a lazy iterator of futures; ThreadPoolExecutor inherits map from Executor but ProcessPoolExecutor overrides it); concurrent.futures.Executor.__enter__.__qualname__=='Executor.__enter__' (len=18: 'Executor'=8+'.'=1+'__enter__'=9=18; __enter__ returns self for context manager protocol); concurrent.futures.Executor.__exit__.__qualname__=='Executor.__exit__' (len=17: 'Executor'=8+'.'=1+'__exit__'=8=17; 1 char shorter than __enter__ because 'exit'=4 < 'enter'=5); qualname length: map(12) < submit(15) < __exit__(17) < __enter__(18); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexec156

  columns: [id, function, args, expected, description]
  rows:
    - [exec_submit_qn_eq,  concurrent.futures.Executor.submit.__qualname__.__eq__,    ["Executor.submit"],    true,  "Executor.submit.__qualname__ == 'Executor.submit' (len=15; abstract method); verified with Python 3.14.3"]
    - [exec_map_qn_eq,     concurrent.futures.Executor.map.__qualname__.__eq__,        ["Executor.map"],       true,  "Executor.map.__qualname__ == 'Executor.map' (len=12; implemented on Executor using submit()); verified with Python 3.14.3"]
    - [exec_enter_qn_eq,   concurrent.futures.Executor.__enter__.__qualname__.__eq__,  ["Executor.__enter__"], true,  "Executor.__enter__.__qualname__ == 'Executor.__enter__' (len=18; returns self); verified with Python 3.14.3"]
    - [exec_exit_qn_eq,    concurrent.futures.Executor.__exit__.__qualname__.__eq__,   ["Executor.__exit__"],  true,  "Executor.__exit__.__qualname__ == 'Executor.__exit__' (len=17; 1 shorter than __enter__=18); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor method qualname lengths — extra156
#
# Executor.map.__qualname__.__len__()      == 12
# Executor.submit.__qualname__.__len__()   == 15
# Executor.__exit__.__qualname__.__len__() == 17
# Executor.__enter__.__qualname__.__len__() == 18
# ---------------------------------------------------------------------------

table concurrent_futures_extra156.cf_executor_qualname_lengths:
  description: "concurrent.futures.Executor method qualname length checks in cfexeclen156 namespace — qualname length ordering on Executor: map(12) < submit(15) < __exit__(17) < __enter__(18); Executor.map.__qualname__.__len__()==12 (shortest: 'map'=3 is the shortest method name); Executor.submit.__qualname__.__len__()==15 ('submit'=6); Executor.__exit__.__qualname__.__len__()==17 ('__exit__'=8: '_'+'_'+'exit'=4+'_'+'_'=8); Executor.__enter__.__qualname__.__len__()==18 (longest: '__enter__'=9: '_'+'_'+'enter'=5+'_'+'_'=9; 1 longer than __exit__ because 'enter'=5 > 'exit'=4); all four methods are defined directly on Executor (qualnames start with 'Executor.'); contrast: ThreadPoolExecutor.map.__qualname__=='Executor.map' (TPE inherits map, not overriding it); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexeclen156

  columns: [id, function, args, expected, description]
  rows:
    - [exec_map_qn_len,    concurrent.futures.Executor.map.__qualname__.__len__,        [],  12,  "Executor.map.__qualname__.__len__() == 12 ('Executor.map'; shortest Executor qualname); verified with Python 3.14.3"]
    - [exec_submit_qn_len, concurrent.futures.Executor.submit.__qualname__.__len__,     [],  15,  "Executor.submit.__qualname__.__len__() == 15 ('Executor.submit'); verified with Python 3.14.3"]
    - [exec_exit_qn_len,   concurrent.futures.Executor.__exit__.__qualname__.__len__,   [],  17,  "Executor.__exit__.__qualname__.__len__() == 17 ('Executor.__exit__'); verified with Python 3.14.3"]
    - [exec_enter_qn_len,  concurrent.futures.Executor.__enter__.__qualname__.__len__,  [],  18,  "Executor.__enter__.__qualname__.__len__() == 18 ('Executor.__enter__'; longest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.process.ProcessPoolExecutor method qualnames — extra156
#
# concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__   == 'ProcessPoolExecutor.submit'
# concurrent.futures.process.ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'
# ---------------------------------------------------------------------------

table concurrent_futures_extra156.cf_ppe_method_qualnames:
  description: "concurrent.futures.process.ProcessPoolExecutor method qualname checks via process submodule in cfppe156 namespace — concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26: 'ProcessPoolExecutor'=19+'.'=1+'submit'=6=26; PPE defines its own submit() that submits callables to a process pool; 'ProcessPoolExecutor'=19 is 1 char longer than 'ThreadPoolExecutor'=18 because 'Process'=7 > 'Thread'=6); concurrent.futures.process.ProcessPoolExecutor.shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28: 'ProcessPoolExecutor'=19+'.'=1+'shutdown'=8=28; PPE defines its own shutdown() to terminate worker processes); qualname length: submit(26) < shutdown(28); both are defined on ProcessPoolExecutor (qualnames start with 'ProcessPoolExecutor.'); compare: TPE qualnames are 1 char shorter (submit=25, shutdown=27) because 'Thread'=6 < 'Process'=7; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppe156

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_submit_qn_eq,    concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__.__eq__,    ["ProcessPoolExecutor.submit"],    true,  "cf.process.PPE.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26); verified with Python 3.14.3"]
    - [ppe_shutdown_qn_eq,  concurrent.futures.process.ProcessPoolExecutor.shutdown.__qualname__.__eq__,  ["ProcessPoolExecutor.shutdown"],  true,  "cf.process.PPE.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28); verified with Python 3.14.3"]
    - [ppe_submit_qn_len,   concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__.__len__,   [],                                26,    "cf.process.PPE.submit.__qualname__.__len__() == 26 ('ProcessPoolExecutor.submit'); verified with Python 3.14.3"]
    - [ppe_shutdown_qn_len, concurrent.futures.process.ProcessPoolExecutor.shutdown.__qualname__.__len__, [],                                28,    "cf.process.PPE.shutdown.__qualname__.__len__() == 28 ('ProcessPoolExecutor.shutdown'; longest in this spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra156
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra156.cf_Executor_submit_qualname_eq:
  description: "concurrent.futures.Executor.submit.__qualname__.__eq__('Executor.submit') returns True — Executor.submit is the abstract method on the base Executor class; submit.__qualname__=='Executor.submit' (len=15: 'Executor'=8+'.'=1+'submit'=6=15); Executor.submit raises NotImplementedError when called directly — concrete subclasses (ThreadPoolExecutor, ProcessPoolExecutor) must override it; qualname 'Executor.submit' confirms this is the abstract definition on Executor (not on a subclass); compare: ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25; the concrete override, 10 chars longer because 'ThreadPoolExecutor'=18 > 'Executor'=8); NEW in extra156: first standalone Executor.submit.__qualname__ identity invariant via direct access in cfexec156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.submit.__qualname__.__eq__
  args: ["Executor.submit"]
  expected: true

invariant concurrent_futures_extra156.cf_Executor_exit_qualname_eq:
  description: "concurrent.futures.Executor.__exit__.__qualname__.__eq__('Executor.__exit__') returns True — concurrent.futures.Executor defines __exit__ to implement the context manager protocol; __exit__ calls shutdown(wait=True) to clean up the executor when leaving the 'with' block; __exit__.__qualname__=='Executor.__exit__' (len=17: 'Executor'=8+'.'=1+'__exit__'=8=17; '__exit__'='_'+'_'+'exit'=4+'_'+'_'=2+4+2=8); compare __enter__.__qualname__=='Executor.__enter__' (len=18; 1 char longer because '__enter__'=9 > '__exit__'=8 since 'enter'=5 > 'exit'=4); __exit__(17) < __enter__(18) by 1 char; NEW in extra156: first standalone Executor.__exit__.__qualname__ identity invariant in cfexec156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__exit__.__qualname__.__eq__
  args: ["Executor.__exit__"]
  expected: true

invariant concurrent_futures_extra156.cf_PPE_submit_qualname_eq:
  description: "concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__.__eq__('ProcessPoolExecutor.submit') returns True — ProcessPoolExecutor defines its own submit() to submit callables to a process pool; submit.__qualname__=='ProcessPoolExecutor.submit' (len=26: 'ProcessPoolExecutor'=19+'.'=1+'submit'=6=26); 'ProcessPoolExecutor' (len=19) is 1 char longer than 'ThreadPoolExecutor' (len=18) because 'Process'=7 > 'Thread'=6; so PPE.submit qualname (len=26) is 1 char longer than TPE.submit qualname (len=25); accessing via the process submodule gives the same method and qualname as concurrent.futures.ProcessPoolExecutor.submit; NEW in extra156: first standalone PPE.submit qualname invariant via process submodule in cfppe156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.process.ProcessPoolExecutor.submit.__qualname__.__eq__
  args: ["ProcessPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra156.cf_PPE_shutdown_qualname_eq:
  description: "concurrent.futures.process.ProcessPoolExecutor.shutdown.__qualname__.__eq__('ProcessPoolExecutor.shutdown') returns True — ProcessPoolExecutor defines its own shutdown() to terminate worker processes gracefully or forcefully; shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28: 'ProcessPoolExecutor'=19+'.'=1+'shutdown'=8=28); compare: Executor.shutdown.__qualname__=='Executor.shutdown' (len=17; abstract base); ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27; 1 shorter than PPE.shutdown=28 because 'Thread'=6 < 'Process'=7); PPE.shutdown(28) > TPE.shutdown(27) > Executor.shutdown(17); NEW in extra156: first standalone PPE.shutdown qualname invariant via process submodule in cfppe156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.process.ProcessPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ProcessPoolExecutor.shutdown"]
  expected: true

invariant concurrent_futures_extra156.cf_Executor_map_qualname_eq:
  description: "concurrent.futures.Executor.map.__qualname__.__eq__('Executor.map') returns True — Executor.map is the concrete map() implementation on the abstract base class; map.__qualname__=='Executor.map' (len=12: 'Executor'=8+'.'=1+'map'=3=12); Executor.map(fn, *iterables, timeout=None, chunksize=1) uses submit() internally to apply fn to each item and returns a lazy iterator over results; ThreadPoolExecutor does NOT override map (so TPE.map.__qualname__=='Executor.map') but ProcessPoolExecutor DOES override map (PPE.map.__qualname__=='ProcessPoolExecutor.map' (len=23)); Executor.map qualname (len=12) is the shortest Executor method qualname — shorter than submit(15), __exit__(17), __enter__(18); NEW in extra156: first standalone Executor.map.__qualname__ identity invariant in cfexec156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

