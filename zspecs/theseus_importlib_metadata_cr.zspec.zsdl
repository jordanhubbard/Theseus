spec: theseus_importlib_metadata_cr
version: ">=3.8"
backend: python_cleanroom(theseus_importlib_metadata_cr)
blocks: importlib.metadata

docs: https://docs.python.org/3/library/importlib.metadata.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/importlib.metadata.html"
  not_derived_from:
    - "CPython source: Lib/importlib/metadata/__init__.py"
  notes:
    - "Clean-room importlib.metadata module. Do NOT import importlib.metadata."

error_model: python_exceptions

invariant theseus_importlib_metadata_cr.impmeta2_version:
  description: "version() returns a version string for an installed package"
  category: behavior
  kind: python_call_eq
  function: impmeta2_version
  args: []
  expected: true

invariant theseus_importlib_metadata_cr.impmeta2_packages:
  description: "packages_distributions() returns a dict mapping packages to distributions"
  category: behavior
  kind: python_call_eq
  function: impmeta2_packages
  args: []
  expected: true

invariant theseus_importlib_metadata_cr.impmeta2_distribution:
  description: "Distribution class exists with metadata attribute"
  category: behavior
  kind: python_call_eq
  function: impmeta2_distribution
  args: []
  expected: true
