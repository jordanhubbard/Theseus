spec: dataclasses_extra11
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra10."
    - "dataclasses_extra10 covers Field/InitVar MRO length and MRO[0].__name__; FrozenInstanceError MRO length and MRO[1].__name__; KW_ONLY.__class__.__name__ and __qualname__; MISSING.__class__.__qualname__."
    - "NOT yet covered: Field.__mro__[1].__name__ == 'object'; InitVar.__mro__[1].__name__ == 'object'; FrozenInstanceError.__mro__[2].__name__ == 'Exception'; FrozenInstanceError.__mro__[3].__name__ == 'BaseException'; FrozenInstanceError.__mro__[4].__name__ == 'object'; FrozenInstanceError.__module__ == 'dataclasses'; asdict/__module__; astuple/__module__; replace/__module__; make_dataclass/__module__."
    - "dataclasses.Field.__mro__[1].__name__ == 'object' — Field's MRO ends with object."
    - "dataclasses.InitVar.__mro__[1].__name__ == 'object' — InitVar's MRO ends with object."
    - "dataclasses.FrozenInstanceError.__mro__[2].__name__ == 'Exception' — third entry in the exception chain."
    - "dataclasses.FrozenInstanceError.__mro__[3].__name__ == 'BaseException' — fourth entry."
    - "dataclasses.FrozenInstanceError.__mro__[4].__name__ == 'object' — final entry."
    - "dataclasses.FrozenInstanceError.__module__ == 'dataclasses' — defined in the dataclasses module."
    - "dataclasses.asdict.__module__ == 'dataclasses'."
    - "dataclasses.astuple.__module__ == 'dataclasses'."
    - "dataclasses.replace.__module__ == 'dataclasses'."
    - "dataclasses.make_dataclass.__module__ == 'dataclasses'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Field.__mro__[1].__name__ and InitVar.__mro__[1].__name__
#
# dataclasses_extra10 verified MRO lengths (both == 2) and MRO[0].__name__
# for Field and InitVar. Not yet verified: MRO[1].__name__, which must be
# 'object' because both classes inherit only from object.
# ---------------------------------------------------------------------------

invariant dataclasses_extra11.Field.mro_second:
  description: "dataclasses.Field.__mro__[1].__name__ == 'object' — Field's MRO ends with object"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

invariant dataclasses_extra11.InitVar.mro_second:
  description: "dataclasses.InitVar.__mro__[1].__name__ == 'object' — InitVar's MRO ends with object"
  category: class_hierarchy
  kind: python_call_eq
  function: InitVar.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# FrozenInstanceError.__mro__ — remaining entries [2], [3], [4]
#
# dataclasses_extra10 verified MRO length (5) and MRO[1].__name__ == 'AttributeError'.
# Not yet verified: entries at positions 2, 3, and 4 (Exception, BaseException, object).
# ---------------------------------------------------------------------------

table dataclasses_extra11.FrozenInstanceError_mro_tail:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_entry

  columns: [id, function, args, expected]
  rows:
    - [FrozenInstanceError_mro2, FrozenInstanceError.__mro__.__getitem__, [2], "Exception"]
    - [FrozenInstanceError_mro3, FrozenInstanceError.__mro__.__getitem__, [3], "BaseException"]
    - [FrozenInstanceError_mro4, FrozenInstanceError.__mro__.__getitem__, [4], "object"]

# ---------------------------------------------------------------------------
# FrozenInstanceError.__module__ == 'dataclasses'
#
# Prior specs covered FrozenInstanceError.__name__, __qualname__, and
# __bases__. Not yet covered: its __module__ attribute. FrozenInstanceError
# is defined in the dataclasses module (Lib/dataclasses.py).
# ---------------------------------------------------------------------------

invariant dataclasses_extra11.FrozenInstanceError.module:
  description: "dataclasses.FrozenInstanceError.__module__ == 'dataclasses'"
  category: module_attrs
  kind: python_call_eq
  function: FrozenInstanceError.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for utility functions: asdict, astuple, replace, make_dataclass
#
# dataclasses_extra7 covered __qualname__ for dataclass/field/fields/asdict/
# astuple/replace/make_dataclass via a table. dataclasses_extra8 covered
# __qualname__ for is_dataclass. No prior spec verified __module__ for
# asdict, astuple, replace, or make_dataclass — only dataclass/__module__
# appears in the base spec.
# ---------------------------------------------------------------------------

table dataclasses_extra11.utility_fn_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [asdict,         asdict.__module__.__eq__,         ["dataclasses"], true]
    - [astuple,        astuple.__module__.__eq__,        ["dataclasses"], true]
    - [replace,        replace.__module__.__eq__,        ["dataclasses"], true]
    - [make_dataclass, make_dataclass.__module__.__eq__, ["dataclasses"], true]

# ---------------------------------------------------------------------------
# is_dataclass.__module__ == 'dataclasses'
#
# dataclasses_extra8 verified is_dataclass.__qualname__ == 'is_dataclass'.
# Not yet verified: its __module__. It is defined in Lib/dataclasses.py.
# ---------------------------------------------------------------------------

invariant dataclasses_extra11.is_dataclass.module:
  description: "dataclasses.is_dataclass.__module__ == 'dataclasses'"
  category: module_attrs
  kind: python_call_eq
  function: is_dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.__name__ == 'dataclasses'
#
# The module's own __name__ attribute must equal its qualified import name.
# No prior spec checks this top-level module attribute directly.
# ---------------------------------------------------------------------------

invariant dataclasses_extra11.module.name:
  description: "dataclasses module __name__ == 'dataclasses'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["dataclasses"]
  expected: true
