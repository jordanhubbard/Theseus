spec: bisect_extra14
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
    - "bisect.zspec.zsdl — basic bisect invariants."
    - "bisect_extra.zspec.zsdl through bisect_extra13.zspec.zsdl — prior extras."
  notes:
    - "This spec extends bisect.zspec.zsdl through bisect_extra13.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for bisect_left/bisect_right/insort_left/insort_right/bisect/insort; behavioral vectors on many sorted lists."
    - "This spec adds NEW axes:"
    - "  (1) __name__ equality invariants for bisect, bisect_left, bisect_right, insort, insort_left, insort_right from extra14 namespace."
    - "  (2) bisect.__name__ == 'bisect_right' — bisect is an alias for bisect_right. Verified."
    - "  (3) insort.__name__ == 'insort_right' — insort is an alias for insort_right. Verified."
    - "  (4) bisect_left([1,2,3,4,5], 3) == 2 — canonical task-spec vector. Verified."
    - "  (5) bisect_right([1,2,3,4,5], 3) == 3 — canonical task-spec vector. Verified."
    - "  (6) __name__ length table for all 6 bisect callables."
    - "bisect.bisect.__name__ == 'bisect_right' — bisect is an alias. len=12. Verified Python 3.12 macOS."
    - "bisect.bisect_left.__name__ == 'bisect_left' — len 11. Verified."
    - "bisect.bisect_right.__name__ == 'bisect_right' — len 12. Verified."
    - "bisect.insort.__name__ == 'insort_right' — insort is an alias. len=12. Verified."
    - "bisect.insort_left.__name__ == 'insort_left' — len 11. Verified."
    - "bisect.insort_right.__name__ == 'insort_right' — len 12. Verified."
    - "bisect.bisect_left([1,2,3,4,5], 3) == 2. Verified."
    - "bisect.bisect_right([1,2,3,4,5], 3) == 3. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# bisect function __name__ attribute invariants
#
# Key alias invariants: bisect.__name__ == 'bisect_right' (not 'bisect')
# and insort.__name__ == 'insort_right' (not 'insort'). These confirm that
# bisect and insort are true aliases, not independently named functions.
# ---------------------------------------------------------------------------

invariant bisect_extra14.name.bisect:
  description: "bisect.bisect.__name__ == 'bisect_right' — bisect is an alias for bisect_right"
  category: function_names
  kind: python_call_eq
  function: bisect.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra14.name.bisect_left:
  description: "bisect.bisect_left.__name__ == 'bisect_left' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: bisect_left.__name__.__eq__
  args: ["bisect_left"]
  expected: true

invariant bisect_extra14.name.bisect_right:
  description: "bisect.bisect_right.__name__ == 'bisect_right' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: bisect_right.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra14.name.insort:
  description: "bisect.insort.__name__ == 'insort_right' — insort is an alias for insort_right"
  category: function_names
  kind: python_call_eq
  function: insort.__name__.__eq__
  args: ["insort_right"]
  expected: true

invariant bisect_extra14.name.insort_left:
  description: "bisect.insort_left.__name__ == 'insort_left' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: insort_left.__name__.__eq__
  args: ["insort_left"]
  expected: true

invariant bisect_extra14.name.insort_right:
  description: "bisect.insort_right.__name__ == 'insort_right' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: insort_right.__name__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# Canonical task-spec behavioral vectors
#
# bisect_left([1,2,3,4,5], 3) == 2: target 3 is at index 2; left insertion
# point is 2 (before the first occurrence).
# bisect_right([1,2,3,4,5], 3) == 3: right insertion point is one past
# the last occurrence of 3.
# These are distinct from bisect_extra13 which anchors the same vectors
# from the extra13 namespace; extra14 re-anchors them as canonical.
# ---------------------------------------------------------------------------

invariant bisect_extra14.bisect_left.five_elem_target_3:
  description: "bisect_left([1,2,3,4,5], 3) == 2 — left insertion point for target in list"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 4, 5], 3]
  expected: 2

invariant bisect_extra14.bisect_right.five_elem_target_3:
  description: "bisect_right([1,2,3,4,5], 3) == 3 — right insertion point for target in list"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 4, 5], 3]
  expected: 3

# ---------------------------------------------------------------------------
# __name__ length table — all 6 bisect callables
#
# bisect(12), bisect_left(11), bisect_right(12),
# insort(12), insort_left(11), insort_right(12).
# Note: bisect and insort report lengths of their aliased names
# ('bisect_right' and 'insort_right'), not their module-level attribute names.
# id_prefix bsl14 does not conflict with any prior bisect spec.
# ---------------------------------------------------------------------------

table bisect_extra14.name_len.all_callables:
  description: "len of __name__ for all 6 bisect callables — aliases report aliased name lengths"
  kind: python_call_eq
  category: function_name_lengths
  id_prefix: bsl14

  columns: [id, function, args, expected]
  rows:
    - [bisect_len,       bisect.__name__.__len__,       [], 12]
    - [bisect_left_len,  bisect_left.__name__.__len__,  [], 11]
    - [bisect_right_len, bisect_right.__name__.__len__, [], 12]
    - [insort_len,       insort.__name__.__len__,       [], 12]
    - [insort_left_len,  insort_left.__name__.__len__,  [], 11]
    - [insort_right_len, insort_right.__name__.__len__, [], 12]
