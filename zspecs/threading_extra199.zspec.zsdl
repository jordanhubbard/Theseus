spec: threading_extra199
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.RLock and threading.Lock class identity — __name__, __class__.__name__, __module__, __qualname__, __doc__.__class__.__name__."
    - "threading.RLock is a pure-Python factory function, NOT a class. type(threading.RLock).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' — the factory function is named 'RLock' but it returns a _RLock instance or a C-level lock. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — RLock is a Python function, not a type. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' — RLock is defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.RLock.__qualname__ == 'RLock' — RLock is a top-level function; __qualname__ is the simple name 'RLock'. Verified with Python 3.14.3."
    - "threading.RLock.__doc__.__class__.__name__ == 'str' — RLock has a docstring that is a plain Python str. Verified with Python 3.14.3."
    - "threading.Lock is a C extension type from _thread module. type(threading.Lock).__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' — the C extension type is named 'lock' (lowercase), not 'Lock'. Verified with Python 3.14.3."
    - "threading.Lock.__class__.__name__ == 'type' — Lock is a type (class object), not a function. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' — Lock is defined in the _thread C extension; __module__ is '_thread'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock identity — __name__, __class__.__name__, __module__
#
# threading.RLock.__name__.__eq__('RLock') == True
# threading.RLock.__class__.__name__.__eq__('function') == True
# threading.RLock.__module__.__eq__('threading') == True
#
# threading.RLock is a pure-Python factory function defined in Lib/threading.py.
# It is NOT a class; type(RLock) == 'function'. The factory returns a _RLock
# instance (or OS-level lock). New to extra199.
# ---------------------------------------------------------------------------

table threading_extra199.rlock_identity:
  description: "threading.RLock __name__, __class__.__name__, __module__; RLock is a pure-Python factory function not a class; new to extra199"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglock199

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq_rlock,
       RLock.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — RLock is a pure-Python factory function defined in Lib/threading.py; __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra199"]
    - [rlock_class_name_eq_function,
       RLock.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a pure-Python function, not a type; its __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra199"]
    - [rlock_module_eq_threading,
       RLock.__module__.__eq__,
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is defined at module scope in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra199"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock __qualname__ and __doc__ class; threading.Lock identity
#
# threading.RLock.__qualname__.__eq__('RLock') == True
# threading.RLock.__doc__.__class__.__name__.__eq__('str') == True
# threading.Lock.__name__.__eq__('lock') == True
#
# RLock is a top-level function so __qualname__ == __name__ == 'RLock'.
# Lock is the C extension type from _thread; its __name__ is lowercase 'lock'.
# New to extra199.
# ---------------------------------------------------------------------------

table threading_extra199.rlock_qualname_doc_lock_name:
  description: "threading.RLock __qualname__ and __doc__ class name; threading.Lock __name__ == 'lock' (lowercase, C type); new to extra199"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglock199

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_qualname_eq_rlock,
       RLock.__qualname__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — RLock is a top-level function with no enclosing class or function scope; __qualname__ is 'RLock'; str.__eq__('RLock') returns True; new to extra199"]
    - [rlock_doc_class_name_str,
       RLock.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.RLock.__doc__.__class__.__name__.__eq__('str') == True — RLock has a docstring that is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra199"]
    - [lock_name_eq_lock,
       Lock.__name__.__eq__,
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is the C extension type from _thread; its internal __name__ is lowercase 'lock', not 'Lock'; str.__eq__('lock') returns True; new to extra199"]

# ---------------------------------------------------------------------------
# Table 3: threading.Lock __class__.__name__ and __module__ cross-check
#
# threading.Lock.__class__.__name__.__eq__('type') == True
# threading.Lock.__module__.__eq__('_thread') == True
#
# Lock is a C extension type (class object) whose __class__ is <class 'type'>.
# Its __module__ is '_thread' (the underlying C extension), not 'threading'.
# New to extra199.
# ---------------------------------------------------------------------------

table threading_extra199.lock_class_and_module:
  description: "threading.Lock __class__.__name__=='type' and __module__=='_thread'; Lock is a C extension type from the _thread module; new to extra199"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglock199

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_name_eq_type,
       Lock.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is a C extension type (class object) from _thread; its __class__ is <class 'type'>; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra199"]
    - [lock_module_eq_thread,
       Lock.__module__.__eq__,
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is defined in the _thread C extension, not in Lib/threading.py; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra199"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra199
# ---------------------------------------------------------------------------

invariant threading_extra199.rlock_name:
  description: "threading.RLock.__name__ == 'RLock' — pure-Python factory function in Lib/threading.py; new to extra199"
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra199.rlock_class_name:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a function not a type; new to extra199"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra199.rlock_module:
  description: "threading.RLock.__module__ == 'threading' — defined in Lib/threading.py; __module__ is 'threading'; new to extra199"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra199.rlock_qualname:
  description: "threading.RLock.__qualname__ == 'RLock' — top-level function; no enclosing scope prefix; new to extra199"
  kind: python_call_eq
  function: RLock.__qualname__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra199.rlock_doc_class_name:
  description: "threading.RLock.__doc__.__class__.__name__ == 'str' — docstring is a plain Python string; new to extra199"
  kind: python_call_eq
  function: RLock.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra199.lock_name:
  description: "threading.Lock.__name__ == 'lock' — C extension type from _thread; internal name is lowercase 'lock'; new to extra199"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra199.lock_class_name:
  description: "threading.Lock.__class__.__name__ == 'type' — Lock is a class object (type), not a function; new to extra199"
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra199.lock_module:
  description: "threading.Lock.__module__ == '_thread' — Lock is defined in the _thread C extension; __module__ is '_thread'; new to extra199"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true
