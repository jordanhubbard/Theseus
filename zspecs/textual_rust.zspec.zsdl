spec: textual_rust
version: ">=3.9"
backend: rust_module(textual_rust)

docs: https://textual.textualize.io/

provenance:
  derived_from:
    - "https://textual.textualize.io/ — Textual documentation"
  not_derived_from:
    - "textual source: src/textual/__init__.py"
  notes:
    - "Textual provides a TUI (Text User Interface) framework for Python."
    - "textual.app.App is available."
    - "textual.app.App.__name__ == 'App'."
    - "textual.widgets is available."
    - "textual.__version__ is a non-empty string."
    - "Expose textual_app_name() -> str: textual.app.App.__name__."
    - "Expose textual_has_widgets() -> bool: hasattr(textual, 'widgets')."
    - "Expose textual_version_nonempty() -> bool: len(textual.__version__) > 0."
    - "All test vectors verified against textual 3.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# textual_app_name — App class name
invariant textual_rust.app.class_name:
  description: "textual.app.App.__name__ == 'App'"
  category: app
  kind: python_call_eq
  function: textual_app_name
  args: []
  expected: "App"

# textual_has_widgets — widgets module present
invariant textual_rust.module.has_widgets:
  description: "textual.widgets is available"
  category: module
  kind: python_call_eq
  function: textual_has_widgets
  args: []
  expected: true

# textual_version_nonempty — version non-empty
invariant textual_rust.version.nonempty:
  description: "textual.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: textual_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:58:31Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
