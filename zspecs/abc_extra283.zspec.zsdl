spec: abc_extra283
version: ">=3.9"
backend: python_module(collections.abc)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — MutableMapping, MutableSet, MutableSequence, Generator, AsyncGenerator, Collection, Reversible abstract base classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "MutableMapping has 5 abstract methods: __delitem__, __getitem__, __iter__, __len__, __setitem__"
    - "MutableSet has 5 abstract methods: __contains__, __iter__, __len__, add, discard"
    - "MutableSequence has 5 abstract methods: __delitem__, __getitem__, __len__, __setitem__, insert"
    - "Generator has 2 abstract methods: send, throw"
    - "AsyncGenerator has 2 abstract methods: asend, athrow"
    - "Collection has 3 abstract methods: __contains__, __iter__, __len__"
    - "Reversible has 2 abstract methods: __iter__, __reversed__"
    - "collections.abc.__package__ is the empty string '', not 'collections'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra283.abstractmethod_counts:
  description: "Abstract method counts for key ABCs in collections.abc"
  kind: python_call_eq
  category: identity
  id_prefix: abc283c

  columns: [id, function, args, expected, description]
  rows:
    - [abc283c_001, collections.abc.MutableMapping.__abstractmethods__.__len__, [], 5, "MutableMapping has 5 abstract methods"]
    - [abc283c_002, collections.abc.MutableSet.__abstractmethods__.__len__, [], 5, "MutableSet has 5 abstract methods"]
    - [abc283c_003, collections.abc.MutableSequence.__abstractmethods__.__len__, [], 5, "MutableSequence has 5 abstract methods"]
    - [abc283c_004, collections.abc.Generator.__abstractmethods__.__len__, [], 2, "Generator has 2 abstract methods: send, throw"]
    - [abc283c_005, collections.abc.AsyncGenerator.__abstractmethods__.__len__, [], 2, "AsyncGenerator has 2 abstract methods: asend, athrow"]
    - [abc283c_006, collections.abc.Collection.__abstractmethods__.__len__, [], 3, "Collection has 3 abstract methods"]
    - [abc283c_007, collections.abc.Reversible.__abstractmethods__.__len__, [], 2, "Reversible has 2 abstract methods: __iter__, __reversed__"]

table abc_extra283.module_identity:
  description: "collections.abc module identity: __name__, __package__, __spec__ class name"
  kind: python_call_eq
  category: identity
  id_prefix: abc283m

  columns: [id, function, args, expected, description]
  rows:
    - [abc283m_001, collections.abc.__name__.__eq__, ["collections.abc"], true, "collections.abc module __name__ is 'collections.abc'"]
    - [abc283m_002, collections.abc.__package__.__eq__, [""], true, "collections.abc __package__ is empty string"]
    - [abc283m_003, collections.abc.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "collections.abc __spec__ is a ModuleSpec"]

invariant abc_extra283.mutablemapping_count_confirmed:
  description: "MutableMapping abstract method count is 5 (getitem, setitem, delitem, iter, len)"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableMapping.__abstractmethods__.__len__
  args: []
  expected: 5

invariant abc_extra283.mutableset_count_confirmed:
  description: "MutableSet abstract method count is 5 (contains, iter, len, add, discard)"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableSet.__abstractmethods__.__len__
  args: []
  expected: 5

invariant abc_extra283.generator_count_confirmed:
  description: "Generator abstract method count is 2 (send, throw)"
  category: identity
  kind: python_call_eq
  function: collections.abc.Generator.__abstractmethods__.__len__
  args: []
  expected: 2

invariant abc_extra283.collection_count_confirmed:
  description: "Collection abstract method count is 3 (contains, iter, len)"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__abstractmethods__.__len__
  args: []
  expected: 3
