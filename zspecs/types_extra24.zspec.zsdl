spec: types_extra24
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra23.zspec.zsdl."
    - "Prior specs covered: FunctionType/LambdaType/MethodType/GeneratorType/CoroutineType/AsyncGeneratorType/CodeType/BuiltinFunctionType/ModuleType/TracebackType/FrameType/CellType/__name__/__module__/__qualname__, types.__name__/__package__, SimpleNamespace.__name__/__module__/__qualname__, MappingProxyType.__name__, DynamicClassAttribute.__name__, GenericAlias.__name__, UnionType.__name__, MappingProxyType.__bases__[0].__name__, various bases checks, SimpleNamespace.__bases__[0].__name__, NoneType/EllipsisType/NotImplementedType."
    - "This spec covers: types.FunctionType.__module__, types.MethodType.__module__, types.GeneratorType.__module__, types.CodeType.__module__, types.ModuleType.__module__, types.SimpleNamespace.__module__, types.MappingProxyType.__module__, types.FunctionType.__bases__[0].__name__, types.MethodType.__bases__[0].__name__, types.GeneratorType.__bases__[0].__name__, types.CodeType.__bases__[0].__name__, types.ModuleType.__bases__[0].__name__."
    - "types.FunctionType.__module__ == 'builtins' — C-level function type is defined in builtins."
    - "types.MethodType.__module__ == 'builtins' — C-level method type is defined in builtins."
    - "types.GeneratorType.__module__ == 'builtins' — C-level generator type is defined in builtins."
    - "types.CodeType.__module__ == 'builtins' — C-level code object type is defined in builtins."
    - "types.ModuleType.__module__ == 'builtins' — C-level module type is defined in builtins."
    - "types.SimpleNamespace.__module__ == 'types' — SimpleNamespace is a Python class defined in Lib/types.py."
    - "types.MappingProxyType.__module__ == 'builtins' — C-level mappingproxy type is defined in builtins."
    - "types.FunctionType.__bases__[0].__name__ == 'object' — FunctionType directly subclasses object."
    - "types.MethodType.__bases__[0].__name__ == 'object' — MethodType directly subclasses object."
    - "types.GeneratorType.__bases__[0].__name__ == 'object' — GeneratorType directly subclasses object."
    - "types.CodeType.__bases__[0].__name__ == 'object' — CodeType directly subclasses object."
    - "types.ModuleType.__bases__[0].__name__ == 'object' — ModuleType directly subclasses object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ combined table for C-level types plus SimpleNamespace (extra24 namespace)
#
# types_extra23 covers a larger group of ten types including BuiltinFunctionType/
# CoroutineType/NoneType/LambdaType. This extra24 table focuses on the subset
# FunctionType/MethodType/GeneratorType/CodeType/ModuleType/MappingProxyType
# (all 'builtins') plus SimpleNamespace ('types') — not previously combined in
# this exact grouping in a single extra24-namespaced table.
# ---------------------------------------------------------------------------

table types_extra24.modules:
  description: "__module__.__eq__ for selected types module class types in the extra24 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,     FunctionType.__module__.__eq__,     ["builtins"], true]
    - [MethodType,       MethodType.__module__.__eq__,       ["builtins"], true]
    - [GeneratorType,    GeneratorType.__module__.__eq__,    ["builtins"], true]
    - [CodeType,         CodeType.__module__.__eq__,         ["builtins"], true]
    - [ModuleType,       ModuleType.__module__.__eq__,       ["builtins"], true]
    - [MappingProxyType, MappingProxyType.__module__.__eq__, ["builtins"], true]
    - [SimpleNamespace,  SimpleNamespace.__module__.__eq__,  ["types"],    true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ combined table for FunctionType/MethodType/GeneratorType/
# CodeType/ModuleType (extra24 namespace)
#
# types_extra2 and types_extra19 cover these in various groupings. This table
# re-anchors them in the extra24 namespace, grouping exactly the five types
# mentioned in the task spec. All five directly subclass object.
# ---------------------------------------------------------------------------

table types_extra24.bases:
  description: "__bases__[0].__name__.__eq__ for selected types module class types in the extra24 namespace"
  kind: python_call_eq
  category: bases
  id_prefix: bases

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,  "FunctionType.__bases__[0].__name__.__eq__",  ["object"], true]
    - [MethodType,    "MethodType.__bases__[0].__name__.__eq__",    ["object"], true]
    - [GeneratorType, "GeneratorType.__bases__[0].__name__.__eq__", ["object"], true]
    - [CodeType,      "CodeType.__bases__[0].__name__.__eq__",      ["object"], true]
    - [ModuleType,    "ModuleType.__bases__[0].__name__.__eq__",    ["object"], true]

# ---------------------------------------------------------------------------
# types.SimpleNamespace.__module__ == 'types' — standalone (extra24 namespace)
#
# SimpleNamespace is defined in Lib/types.py, making it the only commonly-used
# class in the types module whose __module__ is 'types' rather than 'builtins'.
# Re-anchored as a standalone invariant in the extra24 namespace to emphasize
# this distinction.
# ---------------------------------------------------------------------------

invariant types_extra24.SimpleNamespace.module:
  description: "types.SimpleNamespace.__module__ == 'types' — Python class in Lib/types.py, not a C-level builtins type"
  category: module_attrs
  kind: python_call_eq
  function: SimpleNamespace.__module__.__eq__
  args: ["types"]
  expected: true

# ---------------------------------------------------------------------------
# types.CodeType.__module__ == 'builtins' — standalone (extra24 namespace)
#
# CodeType is the C-level code object type. Its __module__ is 'builtins'.
# Re-anchored as a standalone invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant types_extra24.CodeType.module:
  description: "types.CodeType.__module__ == 'builtins' — C-level code object type defined in builtins"
  category: module_attrs
  kind: python_call_eq
  function: CodeType.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# types.ModuleType.__bases__[0].__name__ == 'object' — standalone (extra24 namespace)
#
# ModuleType directly subclasses object. types_extra2 and types_extra19 record
# this in combined tables. Re-anchored as a standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant types_extra24.ModuleType.bases0.name:
  description: "types.ModuleType.__bases__[0].__name__ == 'object' — C-level module type directly subclasses object"
  category: bases
  kind: python_call_eq
  function: "ModuleType.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
