spec: itertools_extra1906
version: ">=3.9"
backend: python_module(itertools)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 574: __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "All itertools types are C-level types implemented in itertoolsmodule.c."
    - "itertools.count, itertools.chain, itertools.cycle, itertools.repeat, itertools.product, itertools.combinations, itertools.permutations, itertools.islice are all C-level types."
    - "None of these C types define __reversed__, __missing__, or __match_args__ in their __dict__."
    - "itertools.count.__qualname__ == 'count' — C-level type, top-level qualname."
    - "itertools.chain.__qualname__ == 'chain' — C-level type."
    - "itertools.cycle.__qualname__ == 'cycle' — C-level type."
    - "itertools.repeat.__qualname__ == 'repeat' — C-level type."
    - "itertools.product.__qualname__ == 'product' — C-level type."
    - "itertools.combinations.__qualname__ == 'combinations' — C-level type."
    - "itertools.permutations.__qualname__ == 'permutations' — C-level type."
    - "itertools.islice.__qualname__ == 'islice' — C-level type."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

