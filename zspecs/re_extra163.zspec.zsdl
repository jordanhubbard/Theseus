spec: re_extra163
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.compile, re.match, re.search, re.sub, re.split function __qualname__ values."
    - "re.compile.__qualname__ == 'compile' (len=7; the function is a module-level wrapper, not a method)."
    - "re.match.__qualname__ == 'match' (len=5)."
    - "re.search.__qualname__ == 'search' (len=6)."
    - "re.sub.__qualname__ == 'sub' (len=3; the shortest qualname among the five)."
    - "re.split.__qualname__ == 'split' (len=5; tied with match at 5)."
    - "All five re module-level functions have simple (non-dotted) __qualname__ values — they are module-level functions, not methods, so their qualname is just their function name."
    - "Length ranking: sub=3, match=split=5, search=6, compile=7."
    - "Two-way tie at 5: match and split — both 5-character function names."
    - "re.sub has the shortest qualname (3 chars); re.compile has the longest (7 chars)."
    - "Contrast with class methods: BytesIO.read.__qualname__ == 'BytesIO.read' (dotted, len=12); module-level functions have no class prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __qualname__ values (group 1)
# sub, match, split — the three shorter function qualnames.
# sub=3, match=5, split=5 (match and split tied at 5).
# Module-level functions have simple non-dotted qualnames equal to their name.
# ---------------------------------------------------------------------------

table re_extra163.module_func_qualnames_group1:
  description: "re module-level function __qualname__ values: sub='sub' (len=3), match='match' (len=5), split='split' (len=5); sub is the shortest; match and split tied at 5"
  kind: python_call_eq
  category: qualname
  id_prefix: req163

  columns: [id, function, args, expected, description]
  rows:
    - [sub_qeq,    re.sub.__qualname__.__eq__,    ["sub"],    true, "re.sub.__qualname__ == 'sub' (re.sub() is a module-level function so its qualname is simply its function name without any class prefix; 'sub' has 3 characters — the shortest qualname of any re module-level function in this spec; re.sub() replaces all non-overlapping occurrences of the pattern in the string with the replacement; sub(pattern, repl, string, count=0, flags=0) is the signature; 'sub' stands for 'substitute'; re.sub.__qualname__ == 're.sub.__name__' == 'sub' because module-level function qualnames are identical to their __name__)"]
    - [match_qeq,  re.match.__qualname__.__eq__,  ["match"],  true, "re.match.__qualname__ == 'match' (re.match() is a module-level function with a simple non-dotted qualname; 'match' has 5 characters: no class prefix because match() is not a method; re.match() attempts to apply the pattern at the start of the string; contrast with compiled pattern objects where Pattern.match.__qualname__ would be dotted; 'match' (5 chars) is tied with 'split' (also 5 chars) — both are 5-character function names; re.match() is anchored to the beginning, unlike re.search() which scans the entire string)"]
    - [split_qeq,  re.split.__qualname__.__eq__,  ["split"],  true, "re.split.__qualname__ == 'split' (re.split() is a module-level function with a simple non-dotted qualname; 'split' has 5 characters: tied with 'match' (also 5 chars) — both are 5-character function names; re.split() splits the string at each non-overlapping match of the pattern; split(pattern, string, maxsplit=0, flags=0) returns a list; re.split() is the counterpart to str.split() but uses regex patterns instead of fixed delimiters; module-level function qualnames are just the function name with no dotted prefix)"]
    - [sub_qlen,   re.sub.__qualname__.__len__,   [],          3,   "re.sub.__qualname__.__len__() == 3 ('sub' has 3 characters — the shortest qualname in this spec; as a module-level function its qualname equals its name with no class prefix; compare with io.BytesIO.read.__qualname__ (12 chars) or pathlib.Path.stat.__qualname__ (9 chars) — those are class method qualnames with 'ClassName.' prefixes; the absence of a dot in 're.sub.__qualname__' confirms sub() is a module-level function; length ranking: sub=3, match=split=5, search=6, compile=7)"]

# ---------------------------------------------------------------------------
# re module-level function __qualname__ values (group 2)
# search, compile — the two longer function qualnames.
# search=6, compile=7.
# compile is the longest qualname among all five re module-level functions in this spec.
# ---------------------------------------------------------------------------

table re_extra163.module_func_qualnames_group2:
  description: "re module-level function __qualname__ values: search='search' (len=6), compile='compile' (len=7); compile is the longest of all five module-level function qualnames in this spec"
  kind: python_call_eq
  category: qualname
  id_prefix: req163

  columns: [id, function, args, expected, description]
  rows:
    - [search_qeq,   re.search.__qualname__.__eq__,   ["search"],   true, "re.search.__qualname__ == 'search' (re.search() is a module-level function with a simple non-dotted qualname; 'search' has 6 characters — one more than 'match' or 'split' (both 5) and one fewer than 'compile' (7); re.search() scans through the string looking for the first position where the pattern produces a match, unlike re.match() which is anchored to the start; 'search' (6 chars) is the only 6-character function name in this spec; module-level function qualnames equal their __name__ with no class prefix)"]
    - [compile_qeq,  re.compile.__qualname__.__eq__,  ["compile"],  true, "re.compile.__qualname__ == 'compile' (re.compile() is a module-level function with a simple non-dotted qualname; 'compile' has 7 characters — the longest of all five re module-level function qualnames in this spec; re.compile() compiles a regex pattern string into a Pattern object for repeated use; the compiled Pattern is cached internally by the re module; 'compile' (7 chars) is the longest because 'compile' is a 7-letter word: 'c-o-m-p-i-l-e'; one more character than 'search' (6) and four more than 'sub' (3))"]
    - [search_qlen,  re.search.__qualname__.__len__,  [],            6,   "re.search.__qualname__.__len__() == 6 ('search' has 6 characters: 's-e-a-r-c-h'; search is the only function with a 6-character qualname in this spec; it falls between the two-way tie at 5 (match, split) and the sole occupant at 7 (compile); complete length ranking: sub=3, match=split=5, search=6, compile=7; re.search() is distinct from re.match() in that it scans the entire string rather than anchoring to the start — this behavioral distinction is not reflected in the qualname length difference of 1 character)"]
    - [compile_qlen, re.compile.__qualname__.__len__, [],            7,   "re.compile.__qualname__.__len__() == 7 ('compile' has 7 characters — the longest function qualname in this spec; the complete ascending order: sub=3, match=split=5, search=6, compile=7; re.compile() is often used when the same pattern is applied many times to improve performance through compiled pattern caching; qualname length 7 for compile() matches re.RegexFlag.__name__ length of 9 minus 2 — the qualname 'compile' (7) is shorter than the class name 'RegexFlag' (9); both are identifiers from the re module but serve different roles)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra163.compile_qualname_is_longest_at_7:
  description: "re.compile.__qualname__.__len__() == 7 — 'compile' has 7 characters and is the longest module-level function qualname in this spec; the complete ascending order is: sub=3, match=split=5, search=6, compile=7; all five re module-level functions have simple (non-dotted) qualnames because they are module-level functions, not class methods; 'compile' is the foundational re function that all others wrap internally; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: re.compile.__qualname__.__len__
  args: []
  expected: 7

invariant re_extra163.match_split_tied_at_5:
  description: "re.match.__qualname__.__len__() == 5 — 'match' has 5 characters; tied with re.split.__qualname__.__len__() == 5 ('split' also 5 characters); match and split form a two-way tie at qualname length 5 because both function names have exactly 5 characters; both are commonly used re functions — match() for anchored pattern matching and split() for splitting strings by a pattern; the two-way tie at 5 sits between sub (3) and search (6) in the length ranking; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: re.match.__qualname__.__len__
  args: []
  expected: 5

invariant re_extra163.sub_qualname_is_shortest_at_3:
  description: "re.sub.__qualname__.__len__() == 3 — 'sub' has 3 characters and is the shortest module-level function qualname in this spec; 'sub' is a 3-letter abbreviation for 'substitute'; module-level function qualnames are simple names with no dotted prefix, making 'sub' (3 chars) the minimal qualname for any useful re function; compare with the longest: 'compile' (7 chars) is more than twice the length of 'sub' (3 chars); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: re.sub.__qualname__.__len__
  args: []
  expected: 3

invariant re_extra163.search_qualname_eq:
  description: "re.search.__qualname__ == 'search' — search() is a module-level function so its qualname is simply 'search' (6 chars) with no class prefix; 're.search.__qualname__' == 're.search.__name__' == 'search'; this confirms search() is not a nested function or method; search (6 chars) is longer than match and split (both 5 chars) and shorter than compile (7 chars); re.search() scans the entire string for the first match of the pattern; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: re.search.__qualname__.__eq__
  args: ["search"]
  expected: true

