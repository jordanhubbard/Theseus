spec: fnmatch_extra8
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
  notes:
    - "This spec extends fnmatch.zspec.zsdl and fnmatch_extra through fnmatch_extra7.zspec.zsdl."
    - "fnmatch.zspec.zsdl covers: fnmatch star/question/charclass/empty tables; fnmatchcase case table; filter lists table; translate patterns table."
    - "fnmatch_extra covers: module/__module__ checks for all 4 functions; function kind; filter overlap; translate_returns_str; fnmatchcase bracket table; fnmatch compound table."
    - "fnmatch_extra2 covers: function_names/qualnames tables; translate star_py value/nonempty/contains_dot_escape; fnmatch/fnmatchcase callable checks."
    - "fnmatch_extra3 covers: function_names_direct table; fnmatch.module standalone; translate.returns_str; fnmatch hello.py/HELLO.PY; fnmatchcase uppercase; filter two_py_one_txt."
    - "fnmatch_extra4 covers: fnmatch py_vs_txt no-match; fnmatch mixed_case_py_match; fnmatchcase lowercase_vs_upper_pattern; filter hello_world_foo."
    - "fnmatch_extra5 covers: translate('*')/translate(''); fnmatch txt_extension_match; fnmatch empty_matches_empty; filter empty_list; fnmatchcase exact_lowercase_match; fnmatchcase lower_name_upper_literal_pattern."
    - "fnmatch_extra6 covers: translate('[a-z]'/'*.md'/'file.txt'/'[!abc]'/'?.py'); fnmatch digit-prefix; fnmatch compound_extension; fnmatch negation [!.]*; fnmatchcase prefix_star; fnmatchcase extension_case_mismatch; filter md_extension."
    - "fnmatch_extra7 covers: function __module__ anchors (extra7 namespace); fnmatch txt_extension_match/py_vs_txt_no_match/uppercase_posix_no_match; fnmatchcase uppercase_name/lowercase_match; filter mixed_list_txt/no_matches_empty; translate txt_returns_str/txt_starts_with_prefix."
    - "This spec adds: __class__.__name__ == 'function' for all 4 public fnmatch functions (not covered in any prior spec); fnmatch single-char wildcard '?' against single-char names; fnmatch '[a-z]' range matching individual characters; filter with '??.py' two-char prefix pattern; translate returns non-empty str for '[0-9]' pattern."
    - "Python module-level functions defined in pure Python report __class__.__name__ == 'function'."
    - "fnmatch.fnmatch('a', '[a-z]') == True — single lowercase letter matches [a-z] range."
    - "fnmatch.fnmatch('Z', '[a-z]') == False on POSIX — uppercase 'Z' is outside [a-z] range."
    - "fnmatch.fnmatch('1', '[0-9]') == True — digit matches [0-9] range."
    - "fnmatch.filter(['ab.py', 'a.py', 'abc.py'], '??.py') == ['ab.py'] — exactly two chars before extension."
    - "fnmatch.translate('[0-9]') is a non-empty str — translate always returns a string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __class__.__name__ == 'function' for all 4 public fnmatch functions
# No prior fnmatch spec checks __class__.__name__ for these functions.
# fnmatch_extra checks 'function kind' via a different mechanism; this spec
# uses the __class__.__name__.__eq__ dotted-chain pattern.
# ---------------------------------------------------------------------------

table fnmatch_extra8.func_class_names:
  kind: python_call_eq
  category: functions
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [fnmatch,     "fnmatch.__class__.__name__.__eq__",     ["function"], true]
    - [fnmatchcase, "fnmatchcase.__class__.__name__.__eq__", ["function"], true]
    - [filter,      "filter.__class__.__name__.__eq__",      ["function"], true]
    - [translate,   "translate.__class__.__name__.__eq__",   ["function"], true]

# ---------------------------------------------------------------------------
# fnmatch behavioral vectors — single character against [a-z] and [0-9] ranges
# fnmatch.zspec covers [hH]/[a-c] ranges with multi-char names.
# fnmatch_extra6 covers '[0-9]*' (digit prefix with star).
# New: single-char name vs single-char character class pattern.
# ---------------------------------------------------------------------------

invariant fnmatch_extra8.fnmatch.single_lower_in_range:
  description: "fnmatch.fnmatch('a', '[a-z]') == True — single lowercase letter matches [a-z] range"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["a", "[a-z]"]
  expected: true

invariant fnmatch_extra8.fnmatch.single_upper_out_of_range:
  description: "fnmatch.fnmatch('Z', '[a-z]') == False on POSIX — uppercase letter outside [a-z] range"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["Z", "[a-z]"]
  expected: false

invariant fnmatch_extra8.fnmatch.digit_in_range:
  description: "fnmatch.fnmatch('1', '[0-9]') == True — single digit matches [0-9] range"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["1", "[0-9]"]
  expected: true

invariant fnmatch_extra8.fnmatch.letter_not_in_digit_range:
  description: "fnmatch.fnmatch('a', '[0-9]') == False — letter 'a' is not in [0-9]"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["a", "[0-9]"]
  expected: false

# ---------------------------------------------------------------------------
# filter with '??.py' pattern — exactly two chars before '.py'
# fnmatch.zspec covers filter with '*.py'. No prior spec uses a '??' prefix pattern.
# ---------------------------------------------------------------------------

invariant fnmatch_extra8.filter.two_char_prefix_py:
  description: "fnmatch.filter(['ab.py', 'a.py', 'abc.py'], '??.py') == ['ab.py'] — exactly two chars before extension"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["ab.py", "a.py", "abc.py"], "??.py"]
  expected: ["ab.py"]

# ---------------------------------------------------------------------------
# translate('[0-9]') — returns a non-empty str
# fnmatch_extra6 covers translate('[a-z]') exact value.
# This spec adds a type/length check for the '[0-9]' pattern (new pattern string).
# ---------------------------------------------------------------------------

invariant fnmatch_extra8.translate.digit_range_returns_str:
  description: "fnmatch.translate('[0-9]').__class__.__name__ == 'str' — translate always returns a str"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["[0-9]"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant fnmatch_extra8.translate.digit_range_nonempty:
  description: "fnmatch.translate('[0-9]') is non-empty — translate never returns an empty string for a non-empty pattern"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["[0-9]"]
  method: __len__.__gt__
  method_args: [0]
  expected: true
