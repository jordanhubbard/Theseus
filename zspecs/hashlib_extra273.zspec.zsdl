spec: hashlib_extra273
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html — hmac module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hashlib_extra272.zspec.zsdl — covers hashlib module __spec__ and __loader__ identity."
    - "hashlib_extra271.zspec.zsdl — covers algorithms_available set membership and __class__.__name__ identity."
  notes:
    - "hmac.__name__ == 'hmac' — the pure-Python hmac module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.__package__ == '' — hmac is a top-level module with empty package. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.__spec__.name == 'hmac' — ModuleSpec.name attribute matches the module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.__loader__.__class__.__name__ == 'SourceFileLoader' — hmac is loaded from a .py source file. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.new.__name__ == 'new' — pure-Python function in hmac module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.new.__module__ == 'hmac' — new is defined in Lib/hmac.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.new.__class__.__name__ == 'function' — new is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.compare_digest.__name__ == 'compare_digest' — C builtin from _hashlib extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.compare_digest.__module__ == '_hashlib' — compare_digest is implemented in the _hashlib C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.compare_digest.__class__.__name__ == 'builtin_function_or_method' — compare_digest is a C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.HMAC.__name__ == 'HMAC' — the HMAC class defined in Lib/hmac.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.HMAC.__module__ == 'hmac' — HMAC is defined in the hmac module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.digest.__name__ == 'digest' — module-level convenience function in hmac. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.digest.__module__ == 'hmac' — digest is defined in Lib/hmac.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hmac.digest.__class__.__name__ == 'function' — digest is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac module __spec__ and __loader__ identity plus hmac.new function identity
# hmac is a pure-Python module loaded via SourceFileLoader.
# hmac.new is a pure-Python factory function; compare_digest is a C builtin
# from the _hashlib extension.
# ---------------------------------------------------------------------------

table hashlib_extra273.hmac_module_identity:
  description: "hmac module identity — __name__/'hmac', __package__/'', __spec__.name/'hmac', __loader__.__class__.__name__/'SourceFileLoader', new.__class__.__name__/'function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hmacmod273

  columns: [id, function, args, expected, description]
  rows:
    - [hmac_name,         __name__.__eq__,                          ["hmac"],             true, "hmac.__name__ == 'hmac' — pure-Python top-level module"]
    - [hmac_package,      __package__.__eq__,                       [""],                 true, "hmac.__package__ == '' — top-level module has empty package string"]
    - [hmac_spec_name,    __spec__.name.__eq__,                     ["hmac"],             true, "hmac.__spec__.name == 'hmac' — ModuleSpec.name matches module name"]
    - [hmac_loader,       __loader__.__class__.__name__.__eq__,     ["SourceFileLoader"], true, "hmac.__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python source loaded via SourceFileLoader"]
    - [new_class,         new.__class__.__name__.__eq__,            ["function"],         true, "hmac.new.__class__.__name__ == 'function' — hmac.new is a pure-Python function"]

# ---------------------------------------------------------------------------
# hmac function and class identity
# hmac.compare_digest is a C builtin from _hashlib; its __module__ is '_hashlib'.
# hmac.HMAC is a pure-Python class with object as its sole base.
# hmac.digest is a module-level pure-Python convenience function.
# ---------------------------------------------------------------------------

table hashlib_extra273.hmac_func_class_identity:
  description: "hmac function and class identity — compare_digest is C builtin from _hashlib; HMAC.__bases__[0] is object; digest is pure-Python function; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hmacfunc273

  columns: [id, function, args, expected, description]
  rows:
    - [cdigest_name,      compare_digest.__name__.__eq__,                  ["compare_digest"],             true, "hmac.compare_digest.__name__ == 'compare_digest' — C builtin from _hashlib extension"]
    - [cdigest_module,    compare_digest.__module__.__eq__,                ["_hashlib"],                   true, "hmac.compare_digest.__module__ == '_hashlib' — implemented in _hashlib C extension"]
    - [cdigest_class,     compare_digest.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "hmac.compare_digest.__class__.__name__ == 'builtin_function_or_method' — C builtin"]
    - [HMAC_name,         HMAC.__name__.__eq__,                            ["HMAC"],                       true, "hmac.HMAC.__name__ == 'HMAC' — the HMAC class defined in Lib/hmac.py"]
    - [HMAC_module,       HMAC.__module__.__eq__,                          ["hmac"],                       true, "hmac.HMAC.__module__ == 'hmac' — HMAC is defined in the hmac module"]

# ---------------------------------------------------------------------------
# Standalone invariants — hmac module identity
# ---------------------------------------------------------------------------

invariant hashlib_extra273.hmac_name_eq:
  description: "hmac.__name__ == 'hmac' — the module name attribute of the pure-Python hmac module; part of Python's crypto stdlib alongside hashlib; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hmac"]
  expected: true

invariant hashlib_extra273.hmac_package_eq:
  description: "hmac.__package__ == '' — hmac is a top-level module so __package__ is the empty string; same pattern as hashlib; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant hashlib_extra273.hmac_spec_name_eq:
  description: "hmac.__spec__.name == 'hmac' — the ModuleSpec.name attribute for the hmac module; mirrors __name__; set by the import system; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hmac"]
  expected: true

invariant hashlib_extra273.hmac_loader_class_eq:
  description: "hmac.__loader__.__class__.__name__ == 'SourceFileLoader' — hmac is a pure-Python module loaded from Lib/hmac.py via SourceFileLoader; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant hashlib_extra273.hmac_new_name_eq:
  description: "hmac.new.__name__ == 'new' — pure-Python factory function in Lib/hmac.py that returns an HMAC object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["new"]
  expected: true

invariant hashlib_extra273.hmac_new_module_eq:
  description: "hmac.new.__module__ == 'hmac' — hmac.new is defined in the hmac module (Lib/hmac.py); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hmac"]
  expected: true

invariant hashlib_extra273.hmac_compare_digest_module_eq:
  description: "hmac.compare_digest.__module__ == '_hashlib' — compare_digest is implemented in the _hashlib C extension and re-exported by the hmac module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: compare_digest.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra273.hmac_HMAC_bases0_name_eq:
  description: "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object; it is not a subclass of any digest or buffer type; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "HMAC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant hashlib_extra273.hmac_digest_name_eq:
  description: "hmac.digest.__name__ == 'digest' — module-level convenience function in hmac for computing a one-shot HMAC digest; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: digest.__name__.__eq__
  args: ["digest"]
  expected: true

invariant hashlib_extra273.hmac_digest_module_eq:
  description: "hmac.digest.__module__ == 'hmac' — the digest convenience function is defined in Lib/hmac.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: digest.__module__.__eq__
  args: ["hmac"]
  expected: true
