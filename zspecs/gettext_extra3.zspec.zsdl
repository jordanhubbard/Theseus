spec: gettext_extra3
version: ">=3.9"
backend: python_module(gettext)

docs: https://docs.python.org/3/library/gettext.html

provenance:
  derived_from:
    - "Python gettext documentation — https://docs.python.org/3/library/gettext.html"
    - "GNU gettext manual — https://www.gnu.org/software/gettext/manual/gettext.html"
    - "Test vectors verified by running Python 3.12 gettext module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gettext.py"
  notes:
    - "This spec extends gettext.zspec.zsdl, gettext_extra.zspec.zsdl, and gettext_extra2.zspec.zsdl."
    - "gettext.zspec.zsdl covers: func_names table (gettext/ngettext/dgettext/dngettext/bindtextdomain/textdomain/find/translation/install); NullTranslations/__name__; GNUTranslations/__name__/__bases__; Catalog/__name__; gettext/ngettext passthroughs."
    - "gettext_extra.zspec.zsdl covers: NullTranslations/__name__/__module__; GNUTranslations/__name__/__bases__; func_names table (gettext/ngettext/pgettext/npgettext/bindtextdomain/textdomain/find/translation/install)."
    - "gettext_extra2.zspec.zsdl covers: NullTranslations base is object; GNUTranslations single_base len; dgettext/dngettext/pgettext/npgettext passthroughs."
    - "This spec focuses on module affiliation for functions and Catalog/__module__."
    - "gettext.GNUTranslations.__module__ == 'gettext' — class is defined in the gettext module."
    - "gettext.Catalog is an alias for GNUTranslations; Catalog.__module__ == 'gettext'."
    - "gettext.dgettext.__module__ == 'gettext'; gettext.dngettext.__module__ == 'gettext'."
    - "gettext.pgettext.__module__ == 'gettext'; gettext.dpgettext.__module__ == 'gettext'."
    - "dpgettext(domain, context, msg) is the domain+context-aware variant added in Python 3.8."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GNUTranslations.__module__ — not covered in any prior spec
# gettext_extra covers NullTranslations.__module__ only.
# ---------------------------------------------------------------------------

invariant gettext_extra3.GNUTranslations.module:
  description: "gettext.GNUTranslations.__module__ == 'gettext'"
  category: classnames
  kind: python_call_eq
  function: GNUTranslations.__module__.__eq__
  args: ["gettext"]
  expected: true

# ---------------------------------------------------------------------------
# Catalog.__module__ — Catalog is an alias; its __module__ == 'gettext'
# gettext.zspec covers Catalog.__name__; __module__ not previously checked.
# ---------------------------------------------------------------------------

invariant gettext_extra3.Catalog.module:
  description: "gettext.Catalog.__module__ == 'gettext' — Catalog alias carries the same module as GNUTranslations"
  category: classnames
  kind: python_call_eq
  function: Catalog.__module__.__eq__
  args: ["gettext"]
  expected: true

# ---------------------------------------------------------------------------
# dpgettext — function name
# gettext/ngettext/dgettext/dngettext/pgettext/npgettext names are covered in
# prior specs; dpgettext.__name__ has not been checked yet.
# ---------------------------------------------------------------------------

invariant gettext_extra3.dpgettext.name:
  description: "gettext.dpgettext.__name__ == 'dpgettext'"
  category: functions
  kind: python_call_eq
  function: dpgettext.__name__.__eq__
  args: ["dpgettext"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ affiliation for locale-aware functions
# Prior specs check function __name__ values; none check __module__.
# ---------------------------------------------------------------------------

table gettext_extra3.func_modules:
  kind: python_call_eq
  category: modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [gettext,   "gettext.__module__.__eq__",   ["gettext"], true]
    - [ngettext,  "ngettext.__module__.__eq__",  ["gettext"], true]
    - [dgettext,  "dgettext.__module__.__eq__",  ["gettext"], true]
    - [dngettext, "dngettext.__module__.__eq__", ["gettext"], true]

# ---------------------------------------------------------------------------
# pgettext and dpgettext __module__
# ---------------------------------------------------------------------------

invariant gettext_extra3.pgettext.module:
  description: "gettext.pgettext.__module__ == 'gettext'"
  category: modules
  kind: python_call_eq
  function: pgettext.__module__.__eq__
  args: ["gettext"]
  expected: true

invariant gettext_extra3.dpgettext.module:
  description: "gettext.dpgettext.__module__ == 'gettext'"
  category: modules
  kind: python_call_eq
  function: dpgettext.__module__.__eq__
  args: ["gettext"]
  expected: true

# ---------------------------------------------------------------------------
# dpgettext passthrough — domain + context-aware, no catalog installed
# dpgettext(domain, context, msg) returns msg unchanged when no catalog.
# ---------------------------------------------------------------------------

invariant gettext_extra3.dpgettext.passthrough:
  description: "gettext.dpgettext('domain', 'context', 'hello') == 'hello' — dpgettext returns message unchanged when no catalog"
  category: behavior
  kind: python_call_eq
  function: dpgettext
  args: ["domain", "context", "hello"]
  expected: "hello"

# ---------------------------------------------------------------------------
# GNUTranslations — is a subclass of NullTranslations (verified via __mro__)
# len(__mro__) == 3: [GNUTranslations, NullTranslations, object]
# gettext_extra2 checks single_base (len(__bases__) == 1); here we check __mro__ length.
# ---------------------------------------------------------------------------

invariant gettext_extra3.GNUTranslations.mro_len:
  description: "len(gettext.GNUTranslations.__mro__) == 3 — MRO is [GNUTranslations, NullTranslations, object]"
  category: hierarchy
  kind: python_call_eq
  function: GNUTranslations.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# NullTranslations — __mro__ length == 2: [NullTranslations, object]
# gettext_extra2 checks __bases__[0].__name__ == 'object'; here we verify mro length.
# ---------------------------------------------------------------------------

invariant gettext_extra3.NullTranslations.mro_len:
  description: "len(gettext.NullTranslations.__mro__) == 2 — MRO is [NullTranslations, object]"
  category: hierarchy
  kind: python_call_eq
  function: NullTranslations.__mro__.__len__
  args: []
  expected: 2
