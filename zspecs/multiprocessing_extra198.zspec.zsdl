spec: multiprocessing_extra198
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/managers.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/connection.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "This spec covers __doc__.__class__.__name__ identity for eight multiprocessing members: Process, ProcessError, AuthenticationError, pool.Pool, managers.BaseManager, queues.Queue, connection.Connection, synchronize.Lock."
    - "multiprocessing.Process.__doc__.__class__.__name__ == 'NoneType' (len=8) — Process.__doc__ is None in Python 3.14.3. Verified with Python 3.14.3."
    - "multiprocessing.ProcessError.__doc__.__class__.__name__ == 'NoneType' (len=8) — ProcessError.__doc__ is None in Python 3.14.3. Verified with Python 3.14.3."
    - "multiprocessing.AuthenticationError.__doc__.__class__.__name__ == 'NoneType' (len=8) — AuthenticationError.__doc__ is None in Python 3.14.3. Verified with Python 3.14.3."
    - "multiprocessing.pool.Pool.__doc__.__class__.__name__ == 'str' (len=3) — pool.Pool has a non-None docstring. Verified with Python 3.14.3."
    - "multiprocessing.managers.BaseManager.__doc__.__class__.__name__ == 'str' (len=3) — managers.BaseManager has a non-None docstring. Verified with Python 3.14.3."
    - "multiprocessing.queues.Queue.__doc__.__class__.__name__ == 'NoneType' (len=8) — queues.Queue.__doc__ is None in Python 3.14.3. Verified with Python 3.14.3."
    - "multiprocessing.connection.Connection.__doc__.__class__.__name__ == 'str' (len=3) — connection.Connection has a non-None docstring. Verified with Python 3.14.3."
    - "multiprocessing.synchronize.Lock.__doc__.__class__.__name__ == 'NoneType' (len=8) — synchronize.Lock.__doc__ is None in Python 3.14.3. Verified with Python 3.14.3."
    - "Members with None __doc__ (NoneType, len=8): Process, ProcessError, AuthenticationError, queues.Queue, synchronize.Lock."
    - "Members with str __doc__ (str, len=3): pool.Pool, managers.BaseManager, connection.Connection."
    - "No prior multiprocessing spec covers the __doc__.__class__.__name__ attribute path for any submodule member."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing Process and exception __doc__.__class__.__name__
#
# multiprocessing.Process.__doc__.__class__.__name__ == 'NoneType' (len=8)
# multiprocessing.ProcessError.__doc__.__class__.__name__ == 'NoneType' (len=8)
# multiprocessing.AuthenticationError.__doc__.__class__.__name__ == 'NoneType' (len=8)
#
# Process and the two exception classes all have None __doc__ in Python 3.14.3.
# None.__class__.__name__ == 'NoneType'. New to multiprocessing_extra198.
# ---------------------------------------------------------------------------

table multiprocessing_extra198.process_exception_doc_class_names:
  description: "mp.Process/ProcessError/AuthenticationError __doc__.__class__.__name__ == 'NoneType'; all have None __doc__ in Python 3.14.3; new to multiprocessing_extra198"
  kind: python_call_eq
  category: doc_identity
  id_prefix: mpdocs198

  columns: [id, function, args, expected, description]
  rows:
    - [process_doc_class_name_eq_nonetype,
       "Process.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "mp.Process.__doc__.__class__.__name__.__eq__('NoneType') == True — Process.__doc__ is None in Python 3.14.3; None.__class__.__name__ is 'NoneType'; new to multiprocessing_extra198"]
    - [process_error_doc_class_name_eq_nonetype,
       "ProcessError.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "mp.ProcessError.__doc__.__class__.__name__.__eq__('NoneType') == True — ProcessError.__doc__ is None in Python 3.14.3; None.__class__.__name__ is 'NoneType'; new to multiprocessing_extra198"]
    - [auth_error_doc_class_name_eq_nonetype,
       "AuthenticationError.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "mp.AuthenticationError.__doc__.__class__.__name__.__eq__('NoneType') == True — AuthenticationError.__doc__ is None in Python 3.14.3; None.__class__.__name__ is 'NoneType'; new to multiprocessing_extra198"]
    - [process_doc_class_name_len_eq_8,
       "Process.__doc__.__class__.__name__.__len__",
       [],
       8,
       "mp.Process.__doc__.__class__.__name__.__len__() == 8 — 'NoneType' has 8 characters; new to multiprocessing_extra198"]

# ---------------------------------------------------------------------------
# Table 2: pool.Pool, managers.BaseManager, connection.Connection __doc__.__class__.__name__
#
# multiprocessing.pool.Pool.__doc__.__class__.__name__ == 'str' (len=3)
# multiprocessing.managers.BaseManager.__doc__.__class__.__name__ == 'str' (len=3)
# multiprocessing.connection.Connection.__doc__.__class__.__name__ == 'str' (len=3)
#
# These three submodule classes have non-None str docstrings.
# New to multiprocessing_extra198.
# ---------------------------------------------------------------------------

table multiprocessing_extra198.pool_manager_connection_doc_class_names:
  description: "mp.pool.Pool/managers.BaseManager/connection.Connection __doc__.__class__.__name__ == 'str'; all have str docstrings; new to multiprocessing_extra198"
  kind: python_call_eq
  category: doc_identity
  id_prefix: mpdocs198

  columns: [id, function, args, expected, description]
  rows:
    - [pool_doc_class_name_eq_str,
       "pool.Pool.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "mp.pool.Pool.__doc__.__class__.__name__.__eq__('str') == True — pool.Pool has a non-None str docstring; new to multiprocessing_extra198"]
    - [pool_doc_class_name_len_eq_3,
       "pool.Pool.__doc__.__class__.__name__.__len__",
       [],
       3,
       "mp.pool.Pool.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; new to multiprocessing_extra198"]
    - [base_manager_doc_class_name_eq_str,
       "managers.BaseManager.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "mp.managers.BaseManager.__doc__.__class__.__name__.__eq__('str') == True — managers.BaseManager has a non-None str docstring; new to multiprocessing_extra198"]
    - [connection_doc_class_name_eq_str,
       "connection.Connection.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "mp.connection.Connection.__doc__.__class__.__name__.__eq__('str') == True — connection.Connection has a non-None str docstring; new to multiprocessing_extra198"]

