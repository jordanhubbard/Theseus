spec: theseus_argparse_cr
version: ">=3.8"
backend: python_cleanroom(theseus_argparse_cr)
blocks: argparse

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/argparse.html"
  not_derived_from:
    - "CPython source: Lib/argparse.py (internal implementation)"
  notes:
    - "Clean-room argparse subset. Do NOT import argparse."
    - "ArgumentParser(prog, description): creates a parser."
    - "add_argument(name_or_flags, type, default, help, action): adds an argument."
    - "parse_args(args): parses a list of strings, returns Namespace."
    - "Namespace: simple object with parsed values as attributes."
    - "Supports positional args, optional --flags, --flag VALUE, store_true action."

error_model: python_exceptions

invariant theseus_argparse_cr.argparse2_positional:
  description: "parse positional arg: Namespace has correct value"
  category: parse_args
  kind: python_call_eq
  function: argparse2_positional
  args: []
  expected: "hello"

invariant theseus_argparse_cr.argparse2_optional:
  description: "parse --count 5: Namespace.count == 5"
  category: parse_args
  kind: python_call_eq
  function: argparse2_optional
  args: []
  expected: 5

invariant theseus_argparse_cr.argparse2_store_true:
  description: "parse --verbose: Namespace.verbose is True"
  category: store_true
  kind: python_call_eq
  function: argparse2_store_true
  args: []
  expected: true
