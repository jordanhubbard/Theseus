spec: inspect_extra418
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.ClosureVars.__name__ == 'ClosureVars' and inspect.ClosureVars.__module__ == 'inspect' and inspect.ClosureVars.__bases__[0].__name__ == 'tuple' — ClosureVars is a namedtuple defined in Lib/inspect.py; its base is the built-in tuple type. Verified with Python 3.14.0."
    - "inspect.ArgInfo.__name__ == 'ArgInfo' and inspect.ArgInfo.__module__ == 'inspect' and inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a namedtuple defined in Lib/inspect.py; its base is the built-in tuple type. Verified with Python 3.14.0."
    - "inspect.Attribute.__name__ == 'Attribute' and inspect.Attribute.__module__ == 'inspect' and inspect.Attribute.__bases__[0].__name__ == 'tuple' — Attribute is a namedtuple defined in Lib/inspect.py; its base is the built-in tuple type. Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect namedtuple type __name__ values
#
# inspect.ClosureVars, inspect.ArgInfo, and inspect.Attribute are all
# namedtuple types defined in Lib/inspect.py. Their __name__ attribute
# equals the bare class name string.
# ---------------------------------------------------------------------------

table inspect_extra418.namedtuple_name:
  description: "inspect namedtuple type __name__ values — ClosureVars, ArgInfo, Attribute defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectnn418

  columns: [id, function, args, expected, description]
  rows:
    - [closurevars_name_eq,
       "ClosureVars.__name__.__eq__",
       ["ClosureVars"],
       true,
       "inspect.ClosureVars.__name__.__eq__('ClosureVars') == True — ClosureVars is a namedtuple in Lib/inspect.py; __name__ is 'ClosureVars'; str.__eq__('ClosureVars') returns True; new to extra418"]
    - [arginfo_name_eq,
       "ArgInfo.__name__.__eq__",
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — ArgInfo is a namedtuple in Lib/inspect.py; __name__ is 'ArgInfo'; str.__eq__('ArgInfo') returns True; new to extra418"]
    - [attribute_name_eq,
       "Attribute.__name__.__eq__",
       ["Attribute"],
       true,
       "inspect.Attribute.__name__.__eq__('Attribute') == True — Attribute is a namedtuple in Lib/inspect.py; __name__ is 'Attribute'; str.__eq__('Attribute') returns True; new to extra418"]

# ---------------------------------------------------------------------------
# Table 2: inspect namedtuple type __module__ values
#
# All three namedtuple types are defined in Lib/inspect.py, so their
# __module__ attribute is 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra418.namedtuple_module:
  description: "inspect namedtuple type __module__ values — all defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectnm418

  columns: [id, function, args, expected, description]
  rows:
    - [closurevars_module_eq,
       "ClosureVars.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ClosureVars.__module__.__eq__('inspect') == True — ClosureVars is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra418"]
    - [arginfo_module_eq,
       "ArgInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra418"]
    - [attribute_module_eq,
       "Attribute.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Attribute.__module__.__eq__('inspect') == True — Attribute is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra418"]

# ---------------------------------------------------------------------------
# Table 3: inspect namedtuple base class __name__ values
#
# Each of these namedtuple types is created via collections.namedtuple,
# which produces a class whose single base is the built-in tuple type.
# __bases__[0].__name__ is therefore 'tuple' for all three.
# ---------------------------------------------------------------------------

table inspect_extra418.namedtuple_base:
  description: "inspect namedtuple type __bases__[0].__name__ values — each has tuple as its single base class; new to extra418"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectnb418

  columns: [id, function, args, expected, description]
  rows:
    - [closurevars_base_name_eq,
       "ClosureVars.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ClosureVars.__bases__[0].__name__.__eq__('tuple') == True — ClosureVars is a namedtuple whose sole base is the built-in tuple type; str.__eq__('tuple') returns True; new to extra418"]
    - [arginfo_base_name_eq,
       "ArgInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — ArgInfo is a namedtuple whose sole base is the built-in tuple type; str.__eq__('tuple') returns True; new to extra418"]
    - [attribute_base_name_eq,
       "Attribute.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.Attribute.__bases__[0].__name__.__eq__('tuple') == True — Attribute is a namedtuple whose sole base is the built-in tuple type; str.__eq__('tuple') returns True; new to extra418"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra418
# ---------------------------------------------------------------------------

invariant inspect_extra418.closurevars_name:
  description: "inspect.ClosureVars.__name__ == 'ClosureVars' — namedtuple defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  function: ClosureVars.__name__.__eq__
  args: ["ClosureVars"]
  expected: true

invariant inspect_extra418.closurevars_module:
  description: "inspect.ClosureVars.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  function: ClosureVars.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra418.closurevars_base:
  description: "inspect.ClosureVars.__bases__[0].__name__ == 'tuple' — namedtuple whose sole base is tuple; new to extra418"
  kind: python_call_eq
  function: ClosureVars.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "tuple"

invariant inspect_extra418.arginfo_name:
  description: "inspect.ArgInfo.__name__ == 'ArgInfo' — namedtuple defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  function: ArgInfo.__name__.__eq__
  args: ["ArgInfo"]
  expected: true

invariant inspect_extra418.arginfo_module:
  description: "inspect.ArgInfo.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  function: ArgInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra418.arginfo_base:
  description: "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — namedtuple whose sole base is tuple; new to extra418"
  kind: python_call_eq
  function: ArgInfo.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "tuple"

invariant inspect_extra418.attribute_name:
  description: "inspect.Attribute.__name__ == 'Attribute' — namedtuple defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  function: Attribute.__name__.__eq__
  args: ["Attribute"]
  expected: true

invariant inspect_extra418.attribute_module:
  description: "inspect.Attribute.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra418"
  kind: python_call_eq
  function: Attribute.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra418.attribute_base:
  description: "inspect.Attribute.__bases__[0].__name__ == 'tuple' — namedtuple whose sole base is tuple; new to extra418"
  kind: python_call_eq
  function: Attribute.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "tuple"
