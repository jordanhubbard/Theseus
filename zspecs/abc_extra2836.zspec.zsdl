spec: abc_extra2836
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra.zspec.zsdl — covers abstractmethod.__isabstractmethod__, ABC.__subclasshook__, ABC.__abstractmethods__, ABCMeta.__instancecheck__, get_cache_token"
    - "abc_extra2.zspec.zsdl — covers __name__, __module__, __qualname__, metaclass identity for ABC, ABCMeta, abstractmethod"
    - "abc_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
    - "abc_extra2821.zspec.zsdl — covers __radd__, __rsub__, __rmul__ dict-presence checks"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "None of the abc public objects define __rtruediv__, __rfloordiv__, or __rmod__ in their __dict__."
    - "ABCMeta is a metaclass (type of type); ABC is the abstract base class helper; abstractmethod is a decorator."
    - "abc.abstractproperty was removed in Python 3.13; it is not covered in this spec."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta — __rtruediv__/__rfloordiv__/__rmod__ dict-presence checks
#
# ABCMeta is the metaclass for abstract base classes. Its __dict__ contains
# metaclass machinery (__instancecheck__, __subclasscheck__, register, etc.)
# but no reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2836.abcmeta_operator_dict:
  description: "abc.ABCMeta __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2836am

  columns: [id, function, args, expected]
  rows:
    - ["ab2836am_rtd",  abc.ABCMeta.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["ab2836am_rfd",  abc.ABCMeta.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["ab2836am_rmd",  abc.ABCMeta.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# abc.ABC — __rtruediv__/__rfloordiv__/__rmod__ dict-presence checks
#
# ABC is the convenience helper class for creating abstract base classes via
# inheritance. Its __dict__ is minimal (only __doc__ and __abstractmethods__).
# It does not define reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2836.abc_operator_dict:
  description: "abc.ABC __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2836abc

  columns: [id, function, args, expected]
  rows:
    - ["ab2836abc_rtd",  abc.ABC.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["ab2836abc_rfd",  abc.ABC.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["ab2836abc_rmd",  abc.ABC.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# abc.abstractmethod — __rtruediv__/__rfloordiv__/__rmod__ dict-presence checks
#
# abstractmethod is a pure-Python decorator function. Its __dict__ holds only
# __isabstractmethod__ == True and the usual function attributes. It does not
# implement reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2836.abstractmethod_operator_dict:
  description: "abc.abstractmethod __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2836abm

  columns: [id, function, args, expected]
  rows:
    - ["ab2836abm_rtd",  abc.abstractmethod.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["ab2836abm_rfd",  abc.abstractmethod.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["ab2836abm_rmd",  abc.abstractmethod.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# Full cross-type matrix — ABCMeta, ABC, abstractmethod × three reflected division/modulo operator dunders
#
# Consolidates the 3×3 dict-presence check (excluding deprecated abstractproperty)
# in one table. Every cell is False: ABCMeta, ABC, and abstractmethod do not
# define /, //, or % reflected operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table abc_extra2836.all_types_rtruediv_rfloordiv_rmod_matrix:
  description: "Full 3×3 dict-presence matrix for abc.ABCMeta, abc.ABC, abc.abstractmethod vs __rtruediv__/__rfloordiv__/__rmod__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2836mx

  columns: [id, function, args, expected]
  rows:
    - ["ab2836mx_am_rtd",  abc.ABCMeta.__dict__.__contains__,        ["__rtruediv__"],   false]
    - ["ab2836mx_am_rfd",  abc.ABCMeta.__dict__.__contains__,        ["__rfloordiv__"],  false]
    - ["ab2836mx_am_rmd",  abc.ABCMeta.__dict__.__contains__,        ["__rmod__"],       false]
    - ["ab2836mx_ac_rtd",  abc.ABC.__dict__.__contains__,            ["__rtruediv__"],   false]
    - ["ab2836mx_ac_rfd",  abc.ABC.__dict__.__contains__,            ["__rfloordiv__"],  false]
    - ["ab2836mx_ac_rmd",  abc.ABC.__dict__.__contains__,            ["__rmod__"],       false]
    - ["ab2836mx_ab_rtd",  abc.abstractmethod.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["ab2836mx_ab_rfd",  abc.abstractmethod.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["ab2836mx_ab_rmd",  abc.abstractmethod.__dict__.__contains__, ["__rmod__"],       false]
