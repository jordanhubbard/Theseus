spec: concurrent_futures_extra147
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "This spec covers: wave 255 theme — concurrent.futures.__dict__.__contains__ membership checks. NEW in extra147: concurrent.futures.__dict__.__contains__('Future')==True; concurrent.futures.__dict__.__contains__('wait')==True; concurrent.futures.__dict__.__contains__('as_completed')==True; concurrent.futures.__dict__.__contains__('FIRST_COMPLETED')==True; concurrent.futures.__dict__.__contains__('ALL_COMPLETED')==True; concurrent.futures.__dict__.__contains__('Executor')==True; concurrent.futures.__dict__.__contains__('CancelledError')==True; concurrent.futures.__dict__.__contains__('TimeoutError')==True; concurrent.futures.__dict__.__contains__('FIRST_EXCEPTION')==True; concurrent.futures.__dict__.__contains__('BrokenExecutor')==True; concurrent.futures.__dict__.__contains__('ThreadPoolExecutor')==False (not in top-level __dict__, loaded lazily); concurrent.futures.__dict__.__contains__('foobar')==False. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__dict__.__contains__('ThreadPoolExecutor') == False. ThreadPoolExecutor and ProcessPoolExecutor are NOT in concurrent.futures.__dict__ at import time on Python 3.14.3 — they are loaded lazily. concurrent.futures.__dict__ has 26 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__dict__.__contains__('Future') == True. Future is re-exported from concurrent.futures._base through concurrent/futures/__init__.py; it appears directly in concurrent.futures.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__dict__.__contains__('FIRST_COMPLETED') == True. The wait-state constants FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED are re-exported from concurrent.futures._base into concurrent.futures.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.__dict__.__contains__ membership — True cases — extra147
#
# Wave 255 theme: concurrent.futures.__dict__.__contains__ membership checks.
#
# concurrent.futures.__dict__.__contains__('Future')          == True
# concurrent.futures.__dict__.__contains__('wait')            == True
# concurrent.futures.__dict__.__contains__('as_completed')    == True
# concurrent.futures.__dict__.__contains__('FIRST_COMPLETED') == True
# concurrent.futures.__dict__.__contains__('ALL_COMPLETED')   == True
# concurrent.futures.__dict__.__contains__('Executor')        == True
# concurrent.futures.__dict__.__contains__('CancelledError')  == True
# concurrent.futures.__dict__.__contains__('TimeoutError')    == True
# concurrent.futures.__dict__.__contains__('FIRST_EXCEPTION') == True
# concurrent.futures.__dict__.__contains__('BrokenExecutor')  == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra147.cf_dict_contains_true:
  description: "concurrent.futures.__dict__.__contains__ membership checks (True cases) in cfdictcontains147 namespace — wave 255 theme: concurrent.futures.__dict__ has 26 entries; Future, Executor, wait, as_completed, and the wait-result constants are re-exported from concurrent.futures._base; CancelledError, TimeoutError, and BrokenExecutor are exception classes re-exported from _base; FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED are string constants used as return conditions for wait(); concurrent.futures.__dict__.__contains__('Future')==True (core Future class); concurrent.futures.__dict__.__contains__('wait')==True; concurrent.futures.__dict__.__contains__('as_completed')==True; concurrent.futures.__dict__.__contains__('FIRST_COMPLETED')==True; concurrent.futures.__dict__.__contains__('ALL_COMPLETED')==True; concurrent.futures.__dict__.__contains__('Executor')==True (abstract base class for executors); concurrent.futures.__dict__.__contains__('CancelledError')==True; concurrent.futures.__dict__.__contains__('TimeoutError')==True; concurrent.futures.__dict__.__contains__('FIRST_EXCEPTION')==True; concurrent.futures.__dict__.__contains__('BrokenExecutor')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: cfdictcontains147

  columns: [id, function, args, expected, description]
  rows:
    - [future_in,      "concurrent.futures.__dict__.__contains__",  ["Future"],          true, "concurrent.futures.__dict__.__contains__('Future') == True — re-exported from _base; verified with Python 3.14.3"]
    - [wait_in,        "concurrent.futures.__dict__.__contains__",  ["wait"],            true, "concurrent.futures.__dict__.__contains__('wait') == True — re-exported from _base; verified with Python 3.14.3"]
    - [as_comp_in,     "concurrent.futures.__dict__.__contains__",  ["as_completed"],    true, "concurrent.futures.__dict__.__contains__('as_completed') == True — re-exported from _base; verified with Python 3.14.3"]
    - [first_comp_in,  "concurrent.futures.__dict__.__contains__",  ["FIRST_COMPLETED"], true, "concurrent.futures.__dict__.__contains__('FIRST_COMPLETED') == True — wait constant; verified with Python 3.14.3"]
    - [all_comp_in,    "concurrent.futures.__dict__.__contains__",  ["ALL_COMPLETED"],   true, "concurrent.futures.__dict__.__contains__('ALL_COMPLETED') == True — wait constant; verified with Python 3.14.3"]
    - [executor_in,    "concurrent.futures.__dict__.__contains__",  ["Executor"],        true, "concurrent.futures.__dict__.__contains__('Executor') == True — abstract base executor class; verified with Python 3.14.3"]
    - [cancel_in,      "concurrent.futures.__dict__.__contains__",  ["CancelledError"],  true, "concurrent.futures.__dict__.__contains__('CancelledError') == True — exception class; verified with Python 3.14.3"]
    - [timeout_in,     "concurrent.futures.__dict__.__contains__",  ["TimeoutError"],    true, "concurrent.futures.__dict__.__contains__('TimeoutError') == True — exception class; verified with Python 3.14.3"]
    - [first_exc_in,   "concurrent.futures.__dict__.__contains__",  ["FIRST_EXCEPTION"], true, "concurrent.futures.__dict__.__contains__('FIRST_EXCEPTION') == True — wait constant; verified with Python 3.14.3"]
    - [broken_in,      "concurrent.futures.__dict__.__contains__",  ["BrokenExecutor"],  true, "concurrent.futures.__dict__.__contains__('BrokenExecutor') == True — exception class for broken executors; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.__dict__.__contains__ membership — False cases — extra147
#
# concurrent.futures.__dict__.__contains__('ThreadPoolExecutor') == False (lazy-loaded)
# concurrent.futures.__dict__.__contains__('foobar')             == False
# ---------------------------------------------------------------------------

table concurrent_futures_extra147.cf_dict_contains_false:
  description: "concurrent.futures.__dict__.__contains__ membership checks (False cases) in cfdictcontains147 namespace — wave 255 theme: on Python 3.14.3, concurrent.futures.__dict__ has 26 entries; ThreadPoolExecutor and ProcessPoolExecutor are NOT in concurrent.futures.__dict__ at import time — they are lazy-loaded; this is a notable difference from asyncio where all classes appear in __dict__ immediately; concurrent.futures.__dict__.__contains__('ThreadPoolExecutor')==False; concurrent.futures.__dict__.__contains__('foobar')==False (arbitrary non-existent name); verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: cfdictcontains147a

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_out,    "concurrent.futures.__dict__.__contains__",  ["ThreadPoolExecutor"], false, "concurrent.futures.__dict__.__contains__('ThreadPoolExecutor') == False — lazy-loaded, not in top-level __dict__; verified with Python 3.14.3"]
    - [foobar_out, "concurrent.futures.__dict__.__contains__",  ["foobar"],             false, "concurrent.futures.__dict__.__contains__('foobar') == False — not in namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra147
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra147.cf_dict_contains_Future:
  description: "concurrent.futures.__dict__.__contains__('Future') returns True — concurrent.futures.Future is re-exported from concurrent.futures._base into concurrent.futures.__dict__; Future is the core result-holder class in concurrent.futures (Future.__module__ is 'concurrent.futures._base', Future.__mro__.__len__() is 2, MRO is [Future, object]); concurrent.futures.__dict__ has 26 entries; Future appears under the key 'Future' in this dict; contrasts with asyncio.__dict__ (136 entries) which also has 'Future' via the _asyncio C extension; both asyncio and concurrent.futures expose 'Future' in their top-level __dict__; NEW in extra147: first standalone concurrent.futures.__dict__.__contains__('Future') invariant in cfdictcontains147 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "concurrent.futures.__dict__.__contains__"
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra147.cf_dict_contains_wait:
  description: "concurrent.futures.__dict__.__contains__('wait') returns True — concurrent.futures.wait is re-exported from concurrent.futures._base; wait() blocks until the futures in a given set meet the condition specified by the return_when argument (FIRST_COMPLETED, FIRST_EXCEPTION, or ALL_COMPLETED); concurrent.futures.__dict__.__contains__('wait')==True confirms 'wait' is a top-level public name; concurrent.futures.__dict__.__contains__('as_completed')==True confirms the companion function; concurrent.futures.__dict__.__contains__('FIRST_COMPLETED')==True, __contains__('FIRST_EXCEPTION')==True, __contains__('ALL_COMPLETED')==True confirm the three wait constants are also in __dict__; NEW in extra147: first standalone concurrent.futures.__dict__.__contains__('wait') invariant in cfdictcontains147 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "concurrent.futures.__dict__.__contains__"
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra147.cf_dict_contains_as_completed:
  description: "concurrent.futures.__dict__.__contains__('as_completed') returns True — concurrent.futures.as_completed is re-exported from concurrent.futures._base; as_completed() is a generator that yields futures as they complete, allowing iteration over futures in completion order; concurrent.futures.__dict__.__contains__('as_completed')==True; concurrent.futures.__dict__.__contains__('wait')==True — both wait and as_completed are the two primary multi-future coordination functions in concurrent.futures; concurrent.futures.__dict__ has 26 entries; NEW in extra147: first standalone concurrent.futures.__dict__.__contains__('as_completed') invariant in cfdictcontains147 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "concurrent.futures.__dict__.__contains__"
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra147.cf_dict_contains_FIRST_COMPLETED:
  description: "concurrent.futures.__dict__.__contains__('FIRST_COMPLETED') returns True — concurrent.futures.FIRST_COMPLETED is a string constant re-exported from concurrent.futures._base; it is one of three wait-condition constants: FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED; all three are in concurrent.futures.__dict__: concurrent.futures.__dict__.__contains__('FIRST_COMPLETED')==True; concurrent.futures.__dict__.__contains__('FIRST_EXCEPTION')==True; concurrent.futures.__dict__.__contains__('ALL_COMPLETED')==True; these constants are passed as the return_when parameter to concurrent.futures.wait(); concurrent.futures.__dict__ has 26 entries; NEW in extra147: first standalone concurrent.futures.__dict__.__contains__('FIRST_COMPLETED') invariant in cfdictcontains147 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "concurrent.futures.__dict__.__contains__"
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra147.cf_dict_not_contains_ThreadPoolExecutor:
  description: "concurrent.futures.__dict__.__contains__('ThreadPoolExecutor') returns False — on Python 3.14.3, ThreadPoolExecutor and ProcessPoolExecutor are NOT in concurrent.futures.__dict__ at import time; they are loaded lazily (not immediately in the top-level __dict__); this is a notable structural difference: concurrent.futures.__dict__ has only 26 entries while asyncio.__dict__ has 136; concurrent.futures.__dict__.__contains__('Future')==True (Future IS eagerly exported), concurrent.futures.__dict__.__contains__('Executor')==True (abstract Executor IS eagerly exported), but concrete executor subclasses ThreadPoolExecutor and ProcessPoolExecutor are absent from __dict__; NEW in extra147: first standalone concurrent.futures.__dict__.__contains__('ThreadPoolExecutor') False invariant in cfdictcontains147 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "concurrent.futures.__dict__.__contains__"
  args: ["ThreadPoolExecutor"]
  expected: false
