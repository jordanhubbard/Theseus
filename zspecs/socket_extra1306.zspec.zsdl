spec: socket_extra1306
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad inputs."
    - "socket.socket(99) passes family=99 as first positional arg; raises OSError (Errno 47: Address family not supported)."
    - "socket.socket(2, 99) passes AF_INET=2 with type=99; raises OSError (Errno 43: Protocol not supported)."
    - "socket.gethostbyname(42) raises TypeError: gethostbyname() argument 1 must be str, bytes or bytearray, not int."
    - "socket.gethostbyname(None) raises TypeError: gethostbyname() argument 1 must be str, bytes or bytearray, not None."
    - "socket.inet_aton('not.an.ip') raises OSError: illegal IP address string passed to inet_aton."
    - "socket.inet_aton('999.999.999.999') raises OSError: illegal IP address string passed to inet_aton."
    - "socket.inet_aton('256.0.0.1') raises OSError: illegal IP address string passed to inet_aton."
    - "socket.inet_aton('1.2.3.4.5') raises OSError: illegal IP address string passed to inet_aton."
    - "socket.inet_aton('') raises OSError: illegal IP address string passed to inet_aton."
    - "socket.inet_aton(42) raises TypeError: inet_aton() argument must be str, not int."
    - "socket.getservbyname(42) raises TypeError: getservbyname() argument 1 must be str, not int."
    - "socket.htons('string') raises TypeError: 'str' object cannot be interpreted as an integer."
    - "socket.ntohs(-1) raises ValueError: Cannot convert negative int."
    - "socket.getaddrinfo(42, 80) raises TypeError: getaddrinfo() argument 1 must be string or None."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra1306.socket_constructor_oserrors:
  description: "socket.socket raises OSError when given unsupported address family (first positional arg) or type (second positional arg)"
  kind: python_call_raises
  category: os_errors
  id_prefix: sk1306sc
  columns: [id, function, args, exception]
  rows:
    - [sk1306sc001, socket.socket, [99],          "OSError"]
    - [sk1306sc002, socket.socket, [255],         "OSError"]
    - [sk1306sc003, socket.socket, [1000],        "OSError"]
    - [sk1306sc004, socket.socket, [2, 99],       "OSError"]
    - [sk1306sc005, socket.socket, [2, 255],      "OSError"]
    - [sk1306sc006, socket.socket, [50],          "OSError"]

table socket_extra1306.address_function_type_errors:
  description: "socket address utility functions raise TypeError when given non-string arguments"
  kind: python_call_raises
  category: type_errors
  id_prefix: sk1306at
  columns: [id, function, args, exception]
  rows:
    - [sk1306at001, socket.gethostbyname,  [42],       "TypeError"]
    - [sk1306at002, socket.gethostbyname,  [null],     "TypeError"]
    - [sk1306at003, socket.inet_aton,      [42],       "TypeError"]
    - [sk1306at004, socket.getservbyname,  [42],       "TypeError"]
    - [sk1306at005, socket.htons,          ["string"], "TypeError"]
    - [sk1306at006, socket.getaddrinfo,    [42, 80],   "TypeError"]

table socket_extra1306.inet_aton_oserrors:
  description: "socket.inet_aton raises OSError for invalid IP address strings; socket.ntohs raises ValueError for negative int"
  kind: python_call_raises
  category: inet_errors
  id_prefix: sk1306in
  columns: [id, function, args, exception]
  rows:
    - [sk1306in001, socket.inet_aton, ["not.an.ip"],       "OSError"]
    - [sk1306in002, socket.inet_aton, ["999.999.999.999"], "OSError"]
    - [sk1306in003, socket.inet_aton, ["256.0.0.1"],       "OSError"]
    - [sk1306in004, socket.inet_aton, ["1.2.3.4.5"],       "OSError"]
    - [sk1306in005, socket.inet_aton, [""],                "OSError"]
    - [sk1306in006, socket.ntohs,     [-1],                "ValueError"]
