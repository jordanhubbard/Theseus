spec: hashlib_extra155
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra154.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') / algorithms_guaranteed.__len__()==14 / algorithms_guaranteed.__contains__('sha256'/'md5'/'sha1'/'sha512'/'blake2b'/'sha3_256'/'shake_128') (table + invariants)."
    - "hashlib_extra153.zspec.zsdl — covers _hashlib.__dict__.__len__()==32 / _hashlib.__dict__.__class__.__name__.__eq__('dict') / _hashlib.__dict__.__contains__('HMAC'/'HASHXOF'/'compare_digest'/'hmac_digest'/'openssl_sha3_256'/'scrypt'/'new') (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / algorithms_guaranteed.__len__()==14."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra154."
    - "Wave 334 theme: hashlib hash constructor function identity — hashlib.sha256/__class__.__name__=='builtin_function_or_method' (26 chars) / sha256.__module__=='_hashlib' / sha256.__name__=='openssl_sha256' (14 chars) / md5.__name__=='openssl_md5' (11 chars) / sha1.__name__=='openssl_sha1' (12 chars) / sha512.__name__=='openssl_sha512' (14 chars) / pbkdf2_hmac.__module__=='_hashlib' (8 chars)."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__name__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.sha256 is NOT a class — it is a 'builtin_function_or_method' (26 chars), a C-level callable from _hashlib. Its __name__ is 'openssl_sha256', not 'sha256', because CPython delegates to OpenSSL's implementation and the constructor is named after the underlying OpenSSL function. Similarly, hashlib.md5.__name__ == 'openssl_md5', hashlib.sha1.__name__ == 'openssl_sha1', and hashlib.sha512.__name__ == 'openssl_sha512'. These are all 'openssl_' prefixed names exposed at the _hashlib C extension level."
    - "Note: hashlib.sha256.__module__ == '_hashlib' (8 chars). The four named hash constructors (sha256/md5/sha1/sha512) all come from the _hashlib C extension module. Their __module__ attribute is '_hashlib' (7 chars for the value '7 chars' = len('_hashlib') == 8). Extra152/153 anchor _hashlib as a C extension module dict; this spec anchors the __module__ of the constructor callables themselves."
    - "Note: hashlib.pbkdf2_hmac.__module__ == '_hashlib'. pbkdf2_hmac is the password-based key derivation function using HMAC as the pseudorandom function. It lives in _hashlib alongside the hash constructors, not in the pure-Python hashlib wrapper. Its __class__.__name__ is also 'builtin_function_or_method' — a C-level callable. Its __name__ is 'pbkdf2_hmac' (no 'openssl_' prefix, unlike the hash constructors)."
    - "Note: The __name__ values with 'openssl_' prefix: openssl_sha256 (14 chars), openssl_sha512 (14 chars), openssl_sha1 (12 chars), openssl_md5 (11 chars). The two 14-char names (openssl_sha256 / openssl_sha512) are sha256 and sha512. The 12-char name (openssl_sha1) is sha1. The 11-char name (openssl_md5) is md5. The 'openssl_' prefix is 8 chars; the algorithm suffix lengths: md5=3, sha1=4, sha256=6, sha512=6."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha256.__module__.__eq__('_hashlib')
# hashlib.sha256.__name__.__eq__('openssl_sha256')
# hashlib.md5.__name__.__eq__('openssl_md5')
#
# Wave 334 theme: hash constructor identity — class name, module, and __name__ values.
#
# hashlib.sha256 is a 'builtin_function_or_method' from _hashlib, not a class.
# Its __name__ is 'openssl_sha256' — the OpenSSL-backed constructor name.
# hashlib.md5.__name__ is 'openssl_md5'. All named hash constructors are
# 'builtin_function_or_method' objects from the _hashlib C extension.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra155.sha256_constructor_identity:
  description: "hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method')==True / sha256.__module__.__eq__('_hashlib')==True / sha256.__name__.__eq__('openssl_sha256')==True / md5.__name__.__eq__('openssl_md5')==True — sha256 is NOT a class but a builtin_function_or_method (26 chars); comes from _hashlib C extension (module='_hashlib', 8 chars); __name__ is 'openssl_sha256' (14 chars) not 'sha256'; md5.__name__ is 'openssl_md5' (11 chars); openssl_ prefix = 8 chars; first hashhc155 anchor for sha256/md5 constructor identity"
  kind: python_call_eq
  category: identity
  id_prefix: hashhc155

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_class_builtin,   "sha256.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' (26 chars; C-level callable, not a class)"]
    - [sha256_module_hashlib,  "sha256.__module__.__eq__",         ["_hashlib"],                   true, "hashlib.sha256.__module__ == '_hashlib' (8 chars; comes from the C extension, not the pure-Python hashlib)"]
    - [sha256_name_openssl,    "sha256.__name__.__eq__",           ["openssl_sha256"],              true, "hashlib.sha256.__name__ == 'openssl_sha256' (14 chars; OpenSSL-backed constructor; 'openssl_' prefix + 'sha256')"]
    - [md5_name_openssl,       "md5.__name__.__eq__",              ["openssl_md5"],                 true, "hashlib.md5.__name__ == 'openssl_md5' (11 chars; OpenSSL-backed constructor; shorter than sha256 name by 3 chars)"]

# ---------------------------------------------------------------------------
# hashlib.sha1.__name__.__eq__('openssl_sha1')
# hashlib.sha512.__name__.__eq__('openssl_sha512')
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
#
# Wave 334 theme: sha1 and sha512 constructor __name__ values; pbkdf2_hmac module.
#
# hashlib.sha1.__name__ == 'openssl_sha1' (12 chars). hashlib.sha512.__name__ ==
# 'openssl_sha512' (14 chars). hashlib.pbkdf2_hmac.__module__ == '_hashlib'.
# The two 14-char names (openssl_sha256/openssl_sha512) are for the SHA-2 family.
# No prior hashlib spec anchors sha1.__name__ or sha512.__name__ as a table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra155.sha1_sha512_pbkdf2_identity:
  description: "hashlib.sha1.__name__.__eq__('openssl_sha1')==True / sha512.__name__.__eq__('openssl_sha512')==True / pbkdf2_hmac.__module__.__eq__('_hashlib')==True / sha256.__name__.__len__()==14 — sha1.__name__ is 'openssl_sha1' (12 chars); sha512.__name__ is 'openssl_sha512' (14 chars; same length as sha256); pbkdf2_hmac comes from _hashlib (no 'openssl_' prefix in its name: just 'pbkdf2_hmac'); __name__ lengths: md5(11) < sha1(12) < sha256==sha512(14); first hashhc155 anchor for sha1/sha512 names and pbkdf2_hmac module"
  kind: python_call_eq
  category: identity
  id_prefix: hashhc155

  columns: [id, function, args, expected, description]
  rows:
    - [sha1_name_openssl,      "sha1.__name__.__eq__",        ["openssl_sha1"],   true, "hashlib.sha1.__name__ == 'openssl_sha1' (12 chars; OpenSSL-backed constructor; SHA-1 produces 20-byte digest)"]
    - [sha512_name_openssl,    "sha512.__name__.__eq__",      ["openssl_sha512"], true, "hashlib.sha512.__name__ == 'openssl_sha512' (14 chars; same length as openssl_sha256; both are 14 chars)"]
    - [pbkdf2_module_hashlib,  "pbkdf2_hmac.__module__.__eq__", ["_hashlib"],     true, "hashlib.pbkdf2_hmac.__module__ == '_hashlib' (8 chars; KDF lives in C extension alongside hash constructors)"]
    - [sha256_name_len_14,     "sha256.__name__.__len__",     [],                 14,   "hashlib.sha256.__name__.__len__() is 14 ('openssl_sha256' = 14 chars; 'openssl_'=8 + 'sha256'=6)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__class__.__name__.__len__()==26
# hashlib.sha256.__module__.__len__()==8
# hashlib.md5.__name__.__len__()==11
#
# Wave 334 theme: length of constructor class name, module, and md5 __name__.
#
# The class name 'builtin_function_or_method' is 26 chars. The module name '_hashlib'
# is 8 chars. The md5 constructor __name__ 'openssl_md5' is 11 chars.
# No prior hashlib spec anchors these length values as a table under hashhc155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra155.constructor_name_lengths:
  description: "hashlib.sha256.__class__.__name__.__len__()==26 / sha256.__module__.__len__()==8 / md5.__name__.__len__()==11 / sha1.__name__.__len__()==12 — 'builtin_function_or_method' is 26 chars (long C-type name); '_hashlib' is 8 chars (module name with underscore prefix); 'openssl_md5' is 11 chars ('openssl_'=8 + 'md5'=3); 'openssl_sha1' is 12 chars ('openssl_'=8 + 'sha1'=4); name length ordering: md5(11) < sha1(12) < sha256==sha512(14); first hashhc155 anchor for constructor name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: hashhc155

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_class_name_len_26,  "sha256.__class__.__name__.__len__", [], 26, "hashlib.sha256.__class__.__name__.__len__() is 26 ('builtin_function_or_method' = 26 chars)"]
    - [sha256_module_len_8,       "sha256.__module__.__len__",         [], 8,  "hashlib.sha256.__module__.__len__() is 8 ('_hashlib' = 8 chars including leading underscore)"]
    - [md5_name_len_11,           "md5.__name__.__len__",              [], 11, "hashlib.md5.__name__.__len__() is 11 ('openssl_md5' = 11 chars; 'openssl_'=8 + 'md5'=3)"]
    - [sha1_name_len_12,          "sha1.__name__.__len__",             [], 12, "hashlib.sha1.__name__.__len__() is 12 ('openssl_sha1' = 12 chars; 'openssl_'=8 + 'sha1'=4)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.sha256.__class__.__name__ is 'builtin_function_or_method' (26 chars).
# The named hash constructors in hashlib (sha256, md5, sha1, sha512) are NOT classes —
# they are C-level callable objects of type builtin_function_or_method. Calling
# hashlib.sha256() returns an instance of _hashlib.HASH (the C extension hash object),
# but sha256 itself is a callable function, not the type. This is distinct from e.g.
# struct.Struct which IS a class (__class__.__name__ == 'type'). extra99 anchors
# sha256().__class__.__name__ == 'HASH'; this spec anchors the constructor's own
# __class__.__name__ == 'builtin_function_or_method'. First standalone under hashhc155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra155.sha256_class_builtin_function:
  description: "hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') == True — sha256 is NOT a class but a C-level callable (26 chars); calling sha256() returns a _hashlib.HASH instance (extra99 anchors HASH class name); contrast with struct.Struct (a class, __class__.__name__=='type'); no prior hashlib spec anchors sha256 constructor's own __class__.__name__ as a standalone; first standalone under hashhc155"
  category: identity
  kind: python_call_eq
  function: sha256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__eq__('openssl_sha256') — standalone
#
# hashlib.sha256.__name__ is 'openssl_sha256' (14 chars). The 'openssl_' prefix (8 chars)
# indicates this constructor uses OpenSSL's implementation of SHA-256. On CPython 3.14.3
# macOS, all four named hash constructors (sha256, md5, sha1, sha512) use OpenSSL.
# This is because CPython links against OpenSSL on most modern systems. The __name__
# 'openssl_sha256' differs from the module-level name 'sha256' under which the callable
# is stored in the hashlib namespace. No prior hashlib spec anchors
# sha256.__name__.__eq__('openssl_sha256') as a standalone. First standalone under hashhc155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra155.sha256_name_openssl_sha256:
  description: "hashlib.sha256.__name__.__eq__('openssl_sha256') == True — 14 chars; 'openssl_' prefix (8 chars) shows OpenSSL-backed implementation; module-level name is 'sha256' but __name__ is 'openssl_sha256'; CPython 3.14.3 macOS links OpenSSL for all core hash algorithms; no prior hashlib spec anchors this as a standalone; first standalone under hashhc155"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha512.__name__.__eq__('openssl_sha512') — standalone
#
# hashlib.sha512.__name__ is 'openssl_sha512' (14 chars). Like sha256, sha512's
# __name__ carries the 'openssl_' prefix, indicating the OpenSSL-backed implementation.
# Both sha256 and sha512 have __name__ lengths of 14 chars: 'openssl_sha256' and
# 'openssl_sha512' differ only in their final digit (6 vs 2). sha512 produces
# 64-byte (512-bit) digests — twice the output size of sha256. Both are SHA-2 family
# algorithms. No prior hashlib spec anchors sha512.__name__.__eq__('openssl_sha512')
# as a standalone. First standalone under hashhc155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra155.sha512_name_openssl_sha512:
  description: "hashlib.sha512.__name__.__eq__('openssl_sha512') == True — 14 chars (same length as openssl_sha256); SHA-2 family; 64-byte/512-bit output (double sha256's 32-byte output); 'openssl_sha512' and 'openssl_sha256' differ only in last digit; both are OpenSSL-backed; no prior hashlib spec anchors this as a standalone; first standalone under hashhc155"
  category: identity
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib' (8 chars). pbkdf2_hmac is the
# PKCS#5 Password-Based Key Derivation Function 2 using HMAC as the pseudorandom
# function. It is implemented in the _hashlib C extension alongside the OpenSSL-backed
# hash constructors. Unlike the hash constructors, pbkdf2_hmac.__name__ is 'pbkdf2_hmac'
# (11 chars, no 'openssl_' prefix). Its __class__.__name__ is also
# 'builtin_function_or_method'. No prior hashlib spec anchors
# pbkdf2_hmac.__module__.__eq__('_hashlib') as a standalone. First standalone under hashhc155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra155.pbkdf2_hmac_module_hashlib:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — 8 chars; PKCS#5 PBKDF2 KDF using HMAC as PRF; implemented in _hashlib C extension; __name__ is 'pbkdf2_hmac' (11 chars, no 'openssl_' prefix unlike hash constructors); same module as sha256/md5/sha1/sha512; no prior hashlib spec anchors this as a standalone; first standalone under hashhc155"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

