spec: warnings_extra
version: ">=3.2"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "Python 3 warnings documentation — https://docs.python.org/3/library/warnings.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "warnings.warn is implemented in the _warnings C extension; warn.__module__ is '_warnings', not 'warnings'."
    - "warn_explicit is also in the _warnings C extension and reports __module__ == '_warnings'."
    - "DeprecationWarning, UserWarning, RuntimeWarning, FutureWarning, PendingDeprecationWarning are all built-in exception subclasses."
    - "All warning category classes inherit from Warning, which inherits from Exception."
    - "DeprecationWarning.__bases__[0].__name__ == 'Warning' — direct base is Warning."
    - "warnings.filters is a list of (action, message, category, module, lineno) filter tuples."
    - "warnings.defaultaction is a str with value 'default' in a fresh interpreter."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table warnings_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [warn,           warn.__name__.__eq__,           ["warn"],           true]
    - [warn_explicit,  warn_explicit.__name__.__eq__,  ["warn_explicit"],  true]
    - [filterwarnings, filterwarnings.__name__.__eq__,  ["filterwarnings"], true]
    - [simplefilter,   simplefilter.__name__.__eq__,   ["simplefilter"],   true]
    - [resetwarnings,  resetwarnings.__name__.__eq__,  ["resetwarnings"],  true]

# ---------------------------------------------------------------------------
# Function __module__ check — warn lives in the C extension _warnings
# ---------------------------------------------------------------------------

invariant warnings_extra.function_modules.warn:
  description: "warnings.warn.__module__ == '_warnings' — implemented in C extension"
  category: function_modules
  kind: python_call_eq
  function: warn.__module__.__eq__
  args: ["_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# catch_warnings — class __name__ check
# ---------------------------------------------------------------------------

invariant warnings_extra.class_names.catch_warnings:
  description: "warnings.catch_warnings.__name__ == 'catch_warnings'"
  category: class_names
  kind: python_call_eq
  function: catch_warnings.__name__.__eq__
  args: ["catch_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# Warning category class __name__ checks
# ---------------------------------------------------------------------------

table warnings_extra.warning_class_names:
  kind: python_call_eq
  category: warning_class_names
  id_prefix: wname

  columns: [id, function, args, expected]
  rows:
    - [deprecationwarning,        DeprecationWarning.__name__.__eq__,        ["DeprecationWarning"],        true]
    - [userwarning,               UserWarning.__name__.__eq__,               ["UserWarning"],               true]
    - [runtimewarning,            RuntimeWarning.__name__.__eq__,            ["RuntimeWarning"],            true]
    - [futurewarning,             FutureWarning.__name__.__eq__,             ["FutureWarning"],             true]
    - [pendingdeprecationwarning, PendingDeprecationWarning.__name__.__eq__,  ["PendingDeprecationWarning"],  true]

# ---------------------------------------------------------------------------
# DeprecationWarning base class
# ---------------------------------------------------------------------------

invariant warnings_extra.bases.deprecationwarning:
  description: "DeprecationWarning.__bases__[0].__name__ == 'Warning'"
  category: bases
  kind: python_call_eq
  function: DeprecationWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

# ---------------------------------------------------------------------------
# Module-level attribute type checks
# ---------------------------------------------------------------------------

invariant warnings_extra.constants.filters_is_list:
  description: "warnings.filters.__class__.__name__ == 'list'"
  category: constants
  kind: python_call_eq
  function: filters.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant warnings_extra.constants.defaultaction_is_str:
  description: "warnings.defaultaction.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: defaultaction.__class__.__name__.__eq__
  args: ["str"]
  expected: true
