spec: socket_extra199
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.socket.__doc__.__class__.__name__ == 'str' (len=3) — the socket class carries a docstring."
    - "socket.gethostname.__doc__.__class__.__name__ == 'str' (len=3) — gethostname function carries a docstring."
    - "socket.getaddrinfo.__doc__.__class__.__name__ == 'str' (len=3) — getaddrinfo function carries a docstring."
    - "socket.create_connection.__doc__.__class__.__name__ == 'str' (len=3) — create_connection function carries a docstring."
    - "socket.create_server.__doc__.__class__.__name__ == 'str' (len=3) — create_server function carries a docstring."
    - "socket.gethostbyname.__doc__.__class__.__name__ == 'str' (len=3) — gethostbyname function carries a docstring."
    - "socket.setdefaulttimeout.__doc__.__class__.__name__ == 'str' (len=3) — setdefaulttimeout function carries a docstring."
    - "socket.error.__doc__.__class__.__name__ == 'str' (len=3) — socket.error is an alias for OSError, which carries a docstring."
    - "All eight covered names carry docstrings on Python 3.14.3 macOS/Darwin 25.4.0; __doc__.__class__.__name__ == 'str' for all."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket class and function __doc__ class identity — group A
# socket.socket, socket.gethostname, socket.getaddrinfo
# ---------------------------------------------------------------------------

table socketdocs199.class_and_func_doc_class_a:
  kind: python_call_eq
  category: doc_identity
  id_prefix: socketdocs199

  columns: [id, function, args, expected, description]
  rows:
    - [socket_doc_class_len,      socket.__doc__.__class__.__name__.__len__,      [], 3, "socket.socket.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; socket class carries a docstring)"]
    - [gethostname_doc_class_len, gethostname.__doc__.__class__.__name__.__len__, [], 3, "socket.gethostname.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; gethostname carries a docstring)"]
    - [getaddrinfo_doc_class_len, getaddrinfo.__doc__.__class__.__name__.__len__, [], 3, "socket.getaddrinfo.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; getaddrinfo carries a docstring)"]

# ---------------------------------------------------------------------------
# socket function __doc__ class identity — group B
# socket.create_connection, socket.create_server, socket.gethostbyname
# ---------------------------------------------------------------------------

table socketdocs199.create_and_host_doc_class_b:
  kind: python_call_eq
  category: doc_identity
  id_prefix: socketdocs199

  columns: [id, function, args, expected, description]
  rows:
    - [create_connection_doc_class_len, create_connection.__doc__.__class__.__name__.__len__, [], 3, "socket.create_connection.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; create_connection carries a docstring)"]
    - [create_server_doc_class_len,     create_server.__doc__.__class__.__name__.__len__,     [], 3, "socket.create_server.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; create_server carries a docstring)"]
    - [gethostbyname_doc_class_len,     gethostbyname.__doc__.__class__.__name__.__len__,     [], 3, "socket.gethostbyname.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; gethostbyname carries a docstring)"]

# ---------------------------------------------------------------------------
# socket function and error __doc__ class identity — group C
# socket.setdefaulttimeout, socket.error (+ equality check)
# ---------------------------------------------------------------------------

table socketdocs199.timeout_and_error_doc_class_c:
  kind: python_call_eq
  category: doc_identity
  id_prefix: socketdocs199

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_doc_class_len, setdefaulttimeout.__doc__.__class__.__name__.__len__, [], 3, "socket.setdefaulttimeout.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; setdefaulttimeout carries a docstring)"]
    - [error_doc_class_len,             error.__doc__.__class__.__name__.__len__,             [], 3, "socket.error.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; socket.error is an alias for OSError, which carries a docstring)"]
    - [socket_doc_class_eq,             socket.__doc__.__class__.__name__.__eq__,             ["str"], true, "socket.socket.__doc__.__class__.__name__ == 'str' — socket class docstring is a plain Python str"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socketdocs199.socket_doc_class_name_len:
  description: "socket.socket.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; the socket class carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: socket.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

