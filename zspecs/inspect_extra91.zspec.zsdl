spec: inspect_extra91
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra90

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra90.zspec.zsdl."
    - "This spec covers: inspect predicate and utility function __module__ string equality (Wave 251)."
    - "Already covered in prior specs: isasyncgenfunction, isasyncgen, iscoroutine, iscoroutinefunction, isgeneratorfunction __module__ (in extra86). Not repeated here."
    - "inspect.ismodule.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isfunction.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismethod.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isgenerator.__module__ == 'inspect' — pure-Python predicate in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' — pure-Python utility in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.signature.__module__ == 'inspect' — pure-Python utility in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getdoc.__module__ == 'inspect' — pure-Python utility in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getfile.__module__ == 'inspect' — pure-Python utility in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getsource.__module__ == 'inspect' — pure-Python utility in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__module__ == 'inspect' — pure-Python utility in Lib/inspect.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ismodule/isclass/isfunction/ismethod __module__ strings
#
# Wave 251 theme: inspect predicate function __module__ == 'inspect' — group 1.
#
# inspect.ismodule.__module__.__eq__('inspect')   == True
# inspect.isclass.__module__.__eq__('inspect')    == True
# inspect.isfunction.__module__.__eq__('inspect') == True
# inspect.ismethod.__module__.__eq__('inspect')   == True
#
# Not covered in prior specs (extra86 covered async/coroutine predicates; extra88 covered qualname). New to extra91.
# ---------------------------------------------------------------------------

table inspect_extra91.predicate_modules_group1:
  description: "ismodule/isclass/isfunction/ismethod __module__ == 'inspect'; pure-Python predicates in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnmod91

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_module_eq_inspect,
       ismodule.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — ismodule is a pure-Python predicate function defined in Lib/inspect.py; it returns True if the object is a module; __module__ is 'inspect'; str.__eq__('inspect') returns True; extra86 covered async/coroutine predicates; this spec (extra91) covers the remaining predicates starting with ismodule; new to extra91"]
    - [isclass_module_eq_inspect,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is a pure-Python predicate function defined in Lib/inspect.py; it returns True if the object is a class; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]
    - [isfunction_module_eq_inspect,
       isfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is a pure-Python predicate function defined in Lib/inspect.py; it returns True if the object is a Python function created by a def statement; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]
    - [ismethod_module_eq_inspect,
       ismethod.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — ismethod is a pure-Python predicate function defined in Lib/inspect.py; it returns True if the object is a bound method; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]

# ---------------------------------------------------------------------------
# isbuiltin/isgenerator/getmembers/signature __module__ strings
#
# Wave 251 theme: inspect predicate and utility function __module__ == 'inspect' — group 2.
#
# inspect.isbuiltin.__module__.__eq__('inspect')   == True
# inspect.isgenerator.__module__.__eq__('inspect') == True
# inspect.getmembers.__module__.__eq__('inspect')  == True
# inspect.signature.__module__.__eq__('inspect')   == True
#
# No prior inspect spec checks these function __module__ values via inspectfnmod91. New to extra91.
# ---------------------------------------------------------------------------

table inspect_extra91.predicate_utility_modules_group2:
  description: "isbuiltin/isgenerator/getmembers/signature __module__ == 'inspect'; pure-Python functions in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnmod91

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_module_eq_inspect,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is a pure-Python predicate function defined in Lib/inspect.py; it returns True if the object is a built-in function or bound built-in method; __module__ is 'inspect'; str.__eq__('inspect') returns True; no prior inspect spec checks these function __module__ values via inspectfnmod91; new to extra91"]
    - [isgenerator_module_eq_inspect,
       isgenerator.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isgenerator.__module__.__eq__('inspect') == True — isgenerator is a pure-Python predicate function defined in Lib/inspect.py; it returns True if the object is a generator (an iterator produced by a generator function); __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]
    - [getmembers_module_eq_inspect,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is a pure-Python utility function defined in Lib/inspect.py; it returns all members of an object as a list of (name, value) pairs; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]
    - [signature_module_eq_inspect,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is a pure-Python utility function defined in Lib/inspect.py; it returns a Signature object for the given callable; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]

# ---------------------------------------------------------------------------
# getdoc/getfile/getsource/getsourcelines __module__ strings
#
# Wave 251 theme: inspect utility function __module__ == 'inspect' — group 3.
#
# inspect.getdoc.__module__.__eq__('inspect')          == True
# inspect.getfile.__module__.__eq__('inspect')         == True
# inspect.getsource.__module__.__eq__('inspect')       == True
# inspect.getsourcelines.__module__.__eq__('inspect')  == True
#
# No prior inspect spec checks these source-retrieval utility __module__ values via inspectfnmod91. New to extra91.
# ---------------------------------------------------------------------------

table inspect_extra91.source_utility_modules_group3:
  description: "getdoc/getfile/getsource/getsourcelines __module__ == 'inspect'; pure-Python utilities in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnmod91

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_module_eq_inspect,
       getdoc.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — getdoc is a pure-Python utility function defined in Lib/inspect.py; it retrieves and cleans the docstring for the given object; __module__ is 'inspect'; str.__eq__('inspect') returns True; no prior inspect spec checks these source-retrieval utility __module__ values via inspectfnmod91; new to extra91"]
    - [getfile_module_eq_inspect,
       getfile.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is a pure-Python utility function defined in Lib/inspect.py; it returns the Python source file in which the object was defined; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]
    - [getsource_module_eq_inspect,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is a pure-Python utility function defined in Lib/inspect.py; it returns the source code text for the given object; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]
    - [getsourcelines_module_eq_inspect,
       getsourcelines.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsourcelines.__module__.__eq__('inspect') == True — getsourcelines is a pure-Python utility function defined in Lib/inspect.py; it returns a list of source lines and starting line number for an object; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra91"]

# ---------------------------------------------------------------------------
# Cross-check: function __module__ is not 'builtins' or 'types'
#
# Wave 251 theme: confirm inspect functions have __module__ == 'inspect', not other modules.
#
# inspect.ismodule.__module__.__eq__('builtins')    == False
# inspect.isclass.__module__.__eq__('builtins')     == False
# inspect.getmembers.__module__.__eq__('builtins')  == False
# inspect.getsource.__module__.__eq__('types')      == False
#
# Cross-checks confirm all checked functions are pure-Python functions in Lib/inspect.py. New to extra91.
# ---------------------------------------------------------------------------

table inspect_extra91.module_cross_checks:
  description: "ismodule/isclass/getmembers/getsource __module__ != 'builtins'/'types'; cross-checks; wave 251; new to extra91"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnmod91

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_module_ne_builtins,
       ismodule.__module__.__eq__,
       ["builtins"],
       false,
       "inspect.ismodule.__module__.__eq__('builtins') == False — ismodule is defined in Lib/inspect.py so __module__ is 'inspect', not 'builtins'; built-in functions like len and print have __module__ == 'builtins'; str.__eq__('builtins') returns False; confirms ismodule is a pure-Python inspect function; new to extra91"]
    - [isclass_module_ne_builtins,
       isclass.__module__.__eq__,
       ["builtins"],
       false,
       "inspect.isclass.__module__.__eq__('builtins') == False — isclass is defined in Lib/inspect.py so __module__ is 'inspect', not 'builtins'; str.__eq__('builtins') returns False; new to extra91"]
    - [getmembers_module_ne_builtins,
       getmembers.__module__.__eq__,
       ["builtins"],
       false,
       "inspect.getmembers.__module__.__eq__('builtins') == False — getmembers is defined in Lib/inspect.py so __module__ is 'inspect', not 'builtins'; str.__eq__('builtins') returns False; confirms getmembers is a pure-Python inspect utility; new to extra91"]
    - [getsource_module_ne_types,
       getsource.__module__.__eq__,
       ["types"],
       false,
       "inspect.getsource.__module__.__eq__('types') == False — getsource is defined in Lib/inspect.py so __module__ is 'inspect', not 'types'; str.__eq__('types') returns False; confirms getsource is defined in inspect, not the types module; new to extra91"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant inspect_extra91.ismodule_module_eq_inspect:
  description: "inspect.ismodule.__module__.__eq__('inspect') == True — ismodule is a pure-Python predicate in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra91.isbuiltin_module_eq_inspect:
  description: "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is a pure-Python predicate in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra91.getmembers_module_eq_inspect:
  description: "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is a pure-Python utility in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra91.getsource_module_eq_inspect:
  description: "inspect.getsource.__module__.__eq__('inspect') == True — getsource is a pure-Python utility in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra91.getsourcelines_module_eq_inspect:
  description: "inspect.getsourcelines.__module__.__eq__('inspect') == True — getsourcelines is a pure-Python utility in Lib/inspect.py; wave 251; new to extra91"
  kind: python_call_eq
  function: getsourcelines.__module__.__eq__
  args: ["inspect"]
  expected: true
