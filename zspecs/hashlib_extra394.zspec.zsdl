spec: hashlib_extra394
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__name__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__ == 'openssl_md5' (same as __name__ for C builtins). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All four hash constructors have __module__ == '_hashlib' and __class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib exposes OpenSSL-backed hash constructors under their canonical names (md5, sha1, etc.) but the underlying C function objects carry the 'openssl_' prefix in their __name__ and __qualname__ attributes. This reflects that on macOS/Linux the implementation is the _hashlib extension built against OpenSSL. The __qualname__ for C builtin functions equals __name__ because C extension functions have no class scope in the Python sense."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib constructor name quirks: openssl_ prefix in __name__ and __qualname__
#
# Wave 394 theme: hashlib constructor identity — the openssl_ prefix.
#
# On macOS and Linux, hashlib delegates hash construction to the _hashlib C
# extension, which wraps OpenSSL. The constructor functions exposed as
# hashlib.md5, hashlib.sha1, hashlib.sha256, and hashlib.sha512 are C
# builtin_function_or_method objects whose __name__ carries the 'openssl_'
# prefix (e.g., 'openssl_md5'). Their __qualname__ equals their __name__
# because C extension functions do not participate in Python class scoping.
# Their __module__ is '_hashlib', not 'hashlib'.
#
# This is a common source of confusion: the attribute name in the hashlib
# namespace ('md5') differs from the function's own __name__ ('openssl_md5').
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra394.constructor_names:
  description: "hashlib constructor __name__ attributes carry openssl_ prefix — hashlib.md5.__name__ is 'openssl_md5', not 'md5'; same pattern for sha1/sha256/sha512; reflects _hashlib C extension backed by OpenSSL; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibcn394

  columns: [id, function, args, expected]
  rows:
    - [md5_name,    md5.__name__.__eq__,    ["openssl_md5"],    true]
    - [sha1_name,   sha1.__name__.__eq__,   ["openssl_sha1"],   true]
    - [sha256_name, sha256.__name__.__eq__, ["openssl_sha256"], true]
    - [sha512_name, sha512.__name__.__eq__, ["openssl_sha512"], true]

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__ — equals __name__ for C builtins
#
# For C extension builtin_function_or_method objects, __qualname__ is the
# same string as __name__. There is no class qualification because C functions
# are not defined inside a Python class body. hashlib.md5.__qualname__ is
# therefore 'openssl_md5', the same as __name__.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra394.md5_qualname:
  description: "hashlib.md5.__qualname__.__eq__('openssl_md5') == True — for C builtin_function_or_method objects __qualname__ equals __name__; no class scope qualification; hashlib.md5.__qualname__ is 'openssl_md5'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true
