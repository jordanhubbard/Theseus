spec: itertools_extra503
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools iterator class attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools classes are implemented in C; __qualname__ reflects the Python-visible name"
    - "All __qualname__ values match the simple unqualified class name as defined in the module"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra503.qualname_identity:
  description: "Each itertools class has the expected __qualname__ string"
  kind: python_call_eq
  category: attributes
  id_prefix: IQN

  columns: [id, function, args, expected]
  rows:
    - [IQN001, itertools.chain.__qualname__.__eq__, ["chain"], true]
    - [IQN002, itertools.cycle.__qualname__.__eq__, ["cycle"], true]
    - [IQN003, itertools.product.__qualname__.__eq__, ["product"], true]
    - [IQN004, itertools.count.__qualname__.__eq__, ["count"], true]
    - [IQN005, itertools.combinations.__qualname__.__eq__, ["combinations"], true]
    - [IQN006, itertools.permutations.__qualname__.__eq__, ["permutations"], true]
    - [IQN007, itertools.groupby.__qualname__.__eq__, ["groupby"], true]
    - [IQN008, itertools.islice.__qualname__.__eq__, ["islice"], true]
    - [IQN009, itertools.compress.__qualname__.__eq__, ["compress"], true]
    - [IQN010, itertools.dropwhile.__qualname__.__eq__, ["dropwhile"], true]
    - [IQN011, itertools.takewhile.__qualname__.__eq__, ["takewhile"], true]
    - [IQN012, itertools.starmap.__qualname__.__eq__, ["starmap"], true]
    - [IQN013, itertools.filterfalse.__qualname__.__eq__, ["filterfalse"], true]
    - [IQN014, itertools.zip_longest.__qualname__.__eq__, ["zip_longest"], true]
    - [IQN015, itertools.accumulate.__qualname__.__eq__, ["accumulate"], true]
    - [IQN016, itertools.repeat.__qualname__.__eq__, ["repeat"], true]
