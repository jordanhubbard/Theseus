spec: subprocess_extra6
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends subprocess.zspec.zsdl, subprocess_extra.zspec.zsdl, subprocess_extra2.zspec.zsdl, subprocess_extra3.zspec.zsdl, subprocess_extra4.zspec.zsdl, subprocess_extra5.zspec.zsdl, subprocess_popen.zspec.zsdl."
    - "Focus: __qualname__ attributes for subprocess classes and functions not yet covered."
    - "subprocess.Popen.__qualname__ == 'Popen' (the main class for spawning child processes)."
    - "subprocess.CompletedProcess.__qualname__ == 'CompletedProcess' (result type of subprocess.run())."
    - "subprocess.CalledProcessError.__qualname__ == 'CalledProcessError' (raised by check_call/check_output)."
    - "subprocess.TimeoutExpired.__qualname__ == 'TimeoutExpired' (raised on timeout)."
    - "subprocess.SubprocessError.__qualname__ == 'SubprocessError' (base exception class)."
    - "subprocess.getoutput and subprocess.getstatusoutput are convenience wrappers around check_output."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class qualnames — CalledProcessError, TimeoutExpired, SubprocessError
# (Popen and CompletedProcess are in the table below)
# ---------------------------------------------------------------------------

invariant subprocess_extra6.CalledProcessError.qualname:
  description: "subprocess.CalledProcessError.__qualname__ == 'CalledProcessError'"
  category: qualnames
  kind: python_call_eq
  function: CalledProcessError.__qualname__.__eq__
  args: ["CalledProcessError"]
  expected: true

invariant subprocess_extra6.TimeoutExpired.qualname:
  description: "subprocess.TimeoutExpired.__qualname__ == 'TimeoutExpired'"
  category: qualnames
  kind: python_call_eq
  function: TimeoutExpired.__qualname__.__eq__
  args: ["TimeoutExpired"]
  expected: true

invariant subprocess_extra6.SubprocessError.qualname:
  description: "subprocess.SubprocessError.__qualname__ == 'SubprocessError'"
  category: qualnames
  kind: python_call_eq
  function: SubprocessError.__qualname__.__eq__
  args: ["SubprocessError"]
  expected: true

# ---------------------------------------------------------------------------
# Convenience function qualnames — getoutput, getstatusoutput
# (not included in the table below to keep the table focused)
# ---------------------------------------------------------------------------

invariant subprocess_extra6.getoutput.qualname:
  description: "subprocess.getoutput.__qualname__ == 'getoutput'"
  category: qualnames
  kind: python_call_eq
  function: getoutput.__qualname__.__eq__
  args: ["getoutput"]
  expected: true

invariant subprocess_extra6.getstatusoutput.qualname:
  description: "subprocess.getstatusoutput.__qualname__ == 'getstatusoutput'"
  category: qualnames
  kind: python_call_eq
  function: getstatusoutput.__qualname__.__eq__
  args: ["getstatusoutput"]
  expected: true

# ---------------------------------------------------------------------------
# Table: qualname checks for core subprocess names
# ---------------------------------------------------------------------------

table subprocess_extra6.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [run,               run.__qualname__.__eq__,               ["run"],               true]
    - [call,              call.__qualname__.__eq__,               ["call"],              true]
    - [check_call,        check_call.__qualname__.__eq__,         ["check_call"],        true]
    - [check_output,      check_output.__qualname__.__eq__,       ["check_output"],      true]
    - [Popen,             Popen.__qualname__.__eq__,              ["Popen"],             true]
    - [CompletedProcess,  CompletedProcess.__qualname__.__eq__,   ["CompletedProcess"],  true]
