spec: textwrap_extra_rust
version: ">=3.9"
backend: rust_module(textwrap_extra_rust)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — textwrap stdlib"
  notes:
    - "textwrap provides text wrapping and filling."
    - "textwrap.fill('hello world', 5) wraps at 5 chars."
    - "textwrap.dedent('  hi') == 'hi'."
    - "textwrap.indent('hi', '  ') == '  hi'."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant textwrap_extra_rust.dedent_hi:
  description: "textwrap.dedent('  hi') == 'hi'"
  category: dedent
  kind: python_call_eq
  function: textwrap_extra_dedent_hi
  args: []
  expected: "hi"

invariant textwrap_extra_rust.indent_hi:
  description: "textwrap.indent('hi', '  ') == '  hi'"
  category: indent
  kind: python_call_eq
  function: textwrap_extra_indent_hi
  args: []
  expected: "  hi"

invariant textwrap_extra_rust.has_fill:
  description: "textwrap.fill is callable"
  category: presence
  kind: python_call_eq
  function: textwrap_extra_has_fill
  args: []
  expected: true

