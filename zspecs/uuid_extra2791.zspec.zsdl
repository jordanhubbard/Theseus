spec: uuid_extra2791
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for UUID, SafeUUID."
    - "uuid_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for UUID, SafeUUID."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "uuid.UUID.__dict__.__contains__('__iand__') == False — UUID is an immutable identifier type; it does not define in-place bitwise AND; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__ior__') == False — UUID does not define in-place bitwise OR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__ixor__') == False — UUID does not define in-place bitwise XOR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__iand__') == False — SafeUUID (an IntEnum subclass) does not add in-place bitwise AND to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__ior__') == False — SafeUUID does not add in-place bitwise OR to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__ixor__') == False — SafeUUID does not add in-place bitwise XOR to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID.__dict__ — __iand__, __ior__, __ixor__ absence
# UUID is a pure-Python class representing a universally unique identifier.
# It supports comparison operators (__eq__, __lt__, etc.) and __hash__, but
# not in-place bitwise operators (&=, |=, ^=).
# ---------------------------------------------------------------------------

table uuid_extra2791.uuid_dict_iand_ior_ixor:
  description: "uuid.UUID.__dict__ does not contain __iand__, __ior__, or __ixor__ — UUID defines no in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2791

  columns: [id, function, args, expected]
  rows:
    - ["uu2791-uuid-iand", uuid.UUID.__dict__.__contains__, ["__iand__"], false]
    - ["uu2791-uuid-ior",  uuid.UUID.__dict__.__contains__, ["__ior__"],  false]
    - ["uu2791-uuid-ixor", uuid.UUID.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 2: uuid.SafeUUID.__dict__ — __iand__, __ior__, __ixor__ absence
# SafeUUID is an IntEnum subclass with values -1 (unsafe) and 0 (safe).
# It does not add new in-place bitwise operators beyond those inherited
# from IntEnum; the __dict__ check is against SafeUUID's own namespace only.
# ---------------------------------------------------------------------------

table uuid_extra2791.safeuuid_dict_iand_ior_ixor:
  description: "uuid.SafeUUID.__dict__ does not contain __iand__, __ior__, or __ixor__ — SafeUUID (IntEnum subclass) defines no additional in-place bitwise operators in its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2791

  columns: [id, function, args, expected]
  rows:
    - ["uu2791-safe-iand", uuid.SafeUUID.__dict__.__contains__, ["__iand__"], false]
    - ["uu2791-safe-ior",  uuid.SafeUUID.__dict__.__contains__, ["__ior__"],  false]
    - ["uu2791-safe-ixor", uuid.SafeUUID.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID.__dict__ — per-dunder detail with descriptions
# Explicit per-dunder rows documenting why each operator is absent.
# ---------------------------------------------------------------------------

table uuid_extra2791.uuid_dict_detail:
  description: "uuid.UUID.__dict__ in-place bitwise operator absence detail — __iand__, __ior__, and __ixor__ are not defined because UUID is an immutable identifier type, not an integer operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2791

  columns: [id, function, args, expected, description]
  rows:
    - ["uu2791-d-iand", uuid.UUID.__dict__.__contains__, ["__iand__"], false, "uuid.UUID does not support &= — UUIDs are immutable identifiers; in-place bitwise AND is undefined"]
    - ["uu2791-d-ior",  uuid.UUID.__dict__.__contains__, ["__ior__"],  false, "uuid.UUID does not support |= — in-place bitwise OR has no meaning for a universally unique identifier"]
    - ["uu2791-d-ixor", uuid.UUID.__dict__.__contains__, ["__ixor__"], false, "uuid.UUID does not support ^= — in-place bitwise XOR is undefined for UUID objects"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — UUID and SafeUUID both lack all three dunders
# ---------------------------------------------------------------------------

table uuid_extra2791.all_types_all_dunders_absent:
  description: "uuid.UUID and uuid.SafeUUID both lack __iand__, __ior__, and __ixor__ in __dict__ — neither uuid type defines in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2791

  columns: [id, function, args, expected]
  rows:
    - ["uu2791-x-uuid-iand", uuid.UUID.__dict__.__contains__,     ["__iand__"], false]
    - ["uu2791-x-uuid-ior",  uuid.UUID.__dict__.__contains__,     ["__ior__"],  false]
    - ["uu2791-x-uuid-ixor", uuid.UUID.__dict__.__contains__,     ["__ixor__"], false]
    - ["uu2791-x-safe-iand", uuid.SafeUUID.__dict__.__contains__, ["__iand__"], false]
    - ["uu2791-x-safe-ior",  uuid.SafeUUID.__dict__.__contains__, ["__ior__"],  false]
    - ["uu2791-x-safe-ixor", uuid.SafeUUID.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra2791.uuid_no_iand:
  description: "uuid.UUID.__dict__.__contains__('__iand__') == False — UUID does not define the &= operator; UUID objects are immutable (the int field is fixed at construction); confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__iand__"]
  expected: false

invariant uuid_extra2791.uuid_no_ior:
  description: "uuid.UUID.__dict__.__contains__('__ior__') == False — UUID does not define the |= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__ior__"]
  expected: false

invariant uuid_extra2791.uuid_no_ixor:
  description: "uuid.UUID.__dict__.__contains__('__ixor__') == False — UUID does not define the ^= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__ixor__"]
  expected: false

invariant uuid_extra2791.safeuuid_no_iand:
  description: "uuid.SafeUUID.__dict__.__contains__('__iand__') == False — SafeUUID is an IntEnum subclass and does not add __iand__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__iand__"]
  expected: false

invariant uuid_extra2791.safeuuid_no_ior:
  description: "uuid.SafeUUID.__dict__.__contains__('__ior__') == False — SafeUUID does not add __ior__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__ior__"]
  expected: false

invariant uuid_extra2791.safeuuid_no_ixor:
  description: "uuid.SafeUUID.__dict__.__contains__('__ixor__') == False — SafeUUID does not add __ixor__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__ixor__"]
  expected: false
