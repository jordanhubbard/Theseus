spec: multiprocessing_extra1291
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "multiprocessing standard library documentation — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/managers.py"
    - "Test vectors verified with Python 3.13 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any third-party process management or parallelism library"
  notes:
    - "Wave 533 (_extra1291): focus on __init__ and __new__ method presence and qualname checks."
    - "multiprocessing.Process does NOT define __init__ in its own __dict__; it inherits from BaseProcess."
    - "multiprocessing.Process.__init__.__qualname__ is 'BaseProcess.__init__' — inherited, not overridden."
    - "multiprocessing.process.BaseProcess defines __init__ directly; __dict__.__contains__('__init__') is True."
    - "multiprocessing.pool.Pool defines __init__ directly with qualname 'Pool.__init__'."
    - "multiprocessing.managers.BaseManager defines __init__ directly with qualname 'BaseManager.__init__'."
    - "multiprocessing.Queue and multiprocessing.Lock are factory methods, not classes — not testable here."
    - "All expected values verified by running Python 3.13 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra1291.init_qualnames:
  description: "multiprocessing class __init__ qualname identity"
  kind: python_call_eq
  category: init_qualname
  id_prefix: mp1291
  columns: [id, function, args, expected]
  rows:
    - ["mp1291qi001", "multiprocessing.Process.__init__.__qualname__.__eq__", ["BaseProcess.__init__"], true]
    - ["mp1291qi002", "multiprocessing.process.BaseProcess.__init__.__qualname__.__eq__", ["BaseProcess.__init__"], true]
    - ["mp1291qi003", "multiprocessing.pool.Pool.__init__.__qualname__.__eq__", ["Pool.__init__"], true]
    - ["mp1291qi004", "multiprocessing.managers.BaseManager.__init__.__qualname__.__eq__", ["BaseManager.__init__"], true]
    - ["mp1291qi005", "multiprocessing.Process.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["mp1291qi006", "multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["mp1291qi007", "multiprocessing.managers.BaseManager.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["mp1291qi008", "multiprocessing.process.BaseProcess.__init__.__class__.__name__.__eq__", ["function"], true]

table multiprocessing_extra1291.dict_contains_init:
  description: "multiprocessing class __dict__ membership check for __init__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: mp1291
  columns: [id, function, args, expected]
  rows:
    - ["mp1291dc001", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__init__"], true]
    - ["mp1291dc002", "multiprocessing.Process.__dict__.__contains__", ["__init__"], false]
    - ["mp1291dc003", "multiprocessing.pool.Pool.__dict__.__contains__", ["__init__"], true]
    - ["mp1291dc004", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__init__"], true]
    - ["mp1291dc005", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["start"], true]
    - ["mp1291dc006", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["run"], true]
    - ["mp1291dc007", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["join"], true]
    - ["mp1291dc008", "multiprocessing.pool.Pool.__dict__.__contains__", ["map"], true]

table multiprocessing_extra1291.init_class_names:
  description: "multiprocessing __init__ method type via __class__.__name__"
  kind: python_call_eq
  category: init_class
  id_prefix: mp1291
  columns: [id, function, args, expected]
  rows:
    - ["mp1291ic001", "multiprocessing.Process.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["mp1291ic002", "multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["mp1291ic003", "multiprocessing.managers.BaseManager.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["mp1291ic004", "multiprocessing.process.BaseProcess.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["mp1291ic005", "multiprocessing.Process.__dict__.__contains__", ["__init__"], false]
    - ["mp1291ic006", "multiprocessing.managers.SyncManager.__dict__.__contains__", ["__init__"], false]
    - ["mp1291ic007", "multiprocessing.pool.Pool.__dict__.__contains__", ["__init__"], true]
    - ["mp1291ic008", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__init__"], true]
