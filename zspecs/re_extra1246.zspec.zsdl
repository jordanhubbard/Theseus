    - [re1246ff002, re.findall.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [re1246ff003, re.split.__doc__.__class__.__name__.__eq__,   ["str"],     true]
    - [re1246ff004, re.split.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [re1246ff005, re.error.__doc__.__class__.__name__.__eq__,   ["str"],     true]
    - [re1246ff006, re.error.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [re1246ff007, re.compile.__doc__.__class__.__name__.__eq__, ["str"],     true]
    - [re1246ff008, re.match.__doc__.__class__.__name__.__eq__,   ["str"],     true]
    - [re1246ff009, re.search.__doc__.__class__.__name__.__eq__,  ["str"],     true]
    - [re1246ff010, re.sub.__doc__.__class__.__name__.__eq__,     ["str"],     true]

