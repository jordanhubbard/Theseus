spec: re_extra1246
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re __doc__ class checks for module, compile, match, search, sub, findall, split, error, Pattern, Match"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["All inspected re items have str __doc__; none of these __doc__ class checks were covered in prior re_extra specs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1246.module_and_functions_doc_class:
  description: "re module and its top-level functions have str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: re1246mf
  columns: [id, function, args, expected]
  rows:
    - [re1246mf001, re.__doc__.__class__.__name__.__eq__,       ["str"],     true]
    - [re1246mf002, re.__doc__.__class__.__name__.__eq__,       ["NoneType"], false]
    - [re1246mf003, re.compile.__doc__.__class__.__name__.__eq__, ["str"],   true]
    - [re1246mf004, re.compile.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [re1246mf005, re.match.__doc__.__class__.__name__.__eq__, ["str"],     true]
    - [re1246mf006, re.match.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [re1246mf007, re.search.__doc__.__class__.__name__.__eq__, ["str"],    true]
    - [re1246mf008, re.search.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [re1246mf009, re.sub.__doc__.__class__.__name__.__eq__,   ["str"],     true]
    - [re1246mf010, re.sub.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]

table re_extra1246.more_functions_doc_class:
