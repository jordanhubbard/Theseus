spec: num_words
version: ">=1.2.3"
backend: node(num-words)

docs: https://www.npmjs.com/package/num-words

provenance:
  derived_from:
    - "num-words README — https://www.npmjs.com/package/num-words"
    - "Test vectors verified with num-words via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "num-words source"
  notes:
    - "num-words is an npm package. Install: npm install num-words"
    - "Converts a number to its English words representation."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table num_words.convert:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: numw

  columns: [id, args, expected]
  rows:
    - [one,      [1],    "one"]
    - [thirteen, [13],   "thirteen"]
    - [forty2,   [42],   "forty two"]
    - [hundred,  [100],  "one hundred"]
    - [thousand, [1000], "one thousand"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:04:33Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
