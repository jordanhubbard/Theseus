spec: threading_extra1411
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
    - "threading_extra.zspec.zsdl — covers class_modules, local name/module, get_ident, TIMEOUT_MAX, stack_size"
    - "threading_extra140.zspec.zsdl — covers other threading wave attrs"
  notes:
    - "Wave 541 theme: __sizeof__ method type on threading class objects; __sizeof__ and __reduce_ex__ in __dict__ membership."
    - "threading.Thread is a pure Python class defined in Lib/threading.py; __sizeof__ inherited from object as method_descriptor. Verified with Python 3.14.3."
    - "threading.Semaphore is a pure Python class defined in Lib/threading.py; __sizeof__ inherited from object. Verified with Python 3.14.3."
    - "threading.Barrier is a pure Python class defined in Lib/threading.py; __sizeof__ inherited from object. Verified with Python 3.14.3."
    - "threading.Condition is a pure Python class defined in Lib/threading.py; __sizeof__ inherited from object. Verified with Python 3.14.3."
    - "threading.Event is a pure Python class defined in Lib/threading.py; __sizeof__ inherited from object. Verified with Python 3.14.3."
    - "threading.Lock() returns an instance of the C-level _thread.lock type; the lock class itself has __sizeof__ as a method_descriptor inherited from object. Verified with Python 3.14.3."
    - "None of Thread, Semaphore, Barrier, Condition, or Event define '__sizeof__' in their own __dict__. Verified with Python 3.14.3."
    - "None of Thread, Semaphore, Barrier, Condition, or Event define '__reduce_ex__' in their own __dict__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading class __sizeof__ method type checks
#
# Wave 541 theme: __sizeof__ method class on threading Python class objects:
# Thread, Semaphore, Barrier, Condition, Event.
#
# All five classes are pure Python classes defined in Lib/threading.py.
# They all inherit __sizeof__ from object, where it appears as a
# 'method_descriptor' on the class object.
# None define __sizeof__ in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra1411.sizeof_method_type:
  description: "threading classes: __sizeof__.__class__.__name__ == 'method_descriptor' for Thread, Semaphore, Barrier, Condition, Event; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_method_type
  id_prefix: th1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [th1411sz001,
       "Thread.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Thread.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — Thread is a pure Python class in Lib/threading.py; __sizeof__ is inherited from object as a method_descriptor on the class object; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411sz002,
       "Semaphore.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Semaphore.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — Semaphore is a pure Python class in Lib/threading.py; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411sz003,
       "Barrier.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Barrier.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — Barrier is a pure Python class in Lib/threading.py; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411sz004,
       "Condition.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Condition.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — Condition is a pure Python class in Lib/threading.py; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411sz005,
       "Event.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Event.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — Event is a pure Python class in Lib/threading.py; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411sz006,
       "Thread.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Thread.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — Thread inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411sz007,
       "Semaphore.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Semaphore.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — Semaphore inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411sz008,
       "Barrier.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Barrier.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — Barrier inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 2: threading class __dict__ membership for __sizeof__ and __reduce_ex__
#
# Wave 541 theme: whether threading classes define __sizeof__ or __reduce_ex__
# in their own __dict__ vs. inheriting from object.
#
# Thread, Semaphore, Barrier, Condition, Event: all False for both.
# These pure Python classes do not override the low-level memory/pickling
# protocol methods from object.
# ---------------------------------------------------------------------------

table threading_extra1411.sizeof_dict_membership:
  description: "threading classes: '__sizeof__' and '__reduce_ex__' not in own __dict__ for Thread, Semaphore, Barrier, Condition, Event; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: th1411dm

  columns: [id, function, args, expected, description]
  rows:
    - [th1411dm001,
       "Thread.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "threading.Thread.__dict__.__contains__('__sizeof__') == False — Thread does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [th1411dm002,
       "Semaphore.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__sizeof__') == False — Semaphore does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [th1411dm003,
       "Barrier.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "threading.Barrier.__dict__.__contains__('__sizeof__') == False — Barrier does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [th1411dm004,
       "Condition.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "threading.Condition.__dict__.__contains__('__sizeof__') == False — Condition does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [th1411dm005,
       "Event.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "threading.Event.__dict__.__contains__('__sizeof__') == False — Event does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [th1411dm006,
       "Thread.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "threading.Thread.__dict__.__contains__('__reduce_ex__') == False — Thread does not define __reduce_ex__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [th1411dm007,
       "Semaphore.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__reduce_ex__') == False — Semaphore does not define __reduce_ex__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [th1411dm008,
       "Barrier.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "threading.Barrier.__dict__.__contains__('__reduce_ex__') == False — Barrier does not define __reduce_ex__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 3: threading class __reduce_ex__ and module/name identity
#
# Wave 541 context: confirms __reduce_ex__ type and verifies class identity
# for Condition and Event (in addition to checks in other tables), plus
# threading.Thread and threading.Barrier __module__ checks.
# ---------------------------------------------------------------------------

table threading_extra1411.reduce_ex_and_identity:
  description: "threading classes: __reduce_ex__ method_descriptor for Condition, Event; __module__ == 'threading' for Thread, Barrier, Condition, Event; wave 541; new to extra1411"
  kind: python_call_eq
  category: reduce_ex_and_identity
  id_prefix: th1411ri

  columns: [id, function, args, expected, description]
  rows:
    - [th1411ri001,
       "Condition.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Condition.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — Condition inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411ri002,
       "Event.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Event.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — Event inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [th1411ri003,
       "Condition.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "threading.Condition.__dict__.__contains__('__reduce_ex__') == False — Condition does not define __reduce_ex__ in its own class __dict__; dict.__contains__ returns False; new to extra1411"]
    - [th1411ri004,
       "Event.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "threading.Event.__dict__.__contains__('__reduce_ex__') == False — Event does not define __reduce_ex__ in its own class __dict__; dict.__contains__ returns False; new to extra1411"]
    - [th1411ri005,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra1411"]
    - [th1411ri006,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra1411"]
    - [th1411ri007,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra1411"]
    - [th1411ri008,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra1411"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1411
# ---------------------------------------------------------------------------

invariant threading_extra1411.thread_sizeof_is_method_descriptor:
  description: "threading.Thread.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: Thread.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra1411.thread_sizeof_not_in_dict:
  description: "'__sizeof__' not in threading.Thread.__dict__ — Thread does not override __sizeof__; wave 541; new to extra1411"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false

invariant threading_extra1411.thread_reduce_ex_is_method_descriptor:
  description: "threading.Thread.__reduce_ex__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: Thread.__reduce_ex__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra1411.thread_reduce_ex_not_in_dict:
  description: "'__reduce_ex__' not in threading.Thread.__dict__ — Thread does not override __reduce_ex__; wave 541; new to extra1411"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__reduce_ex__"]
  expected: false

invariant threading_extra1411.barrier_sizeof_is_method_descriptor:
  description: "threading.Barrier.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: Barrier.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra1411.semaphore_sizeof_not_in_dict:
  description: "'__sizeof__' not in threading.Semaphore.__dict__ — Semaphore does not override __sizeof__; wave 541; new to extra1411"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false
