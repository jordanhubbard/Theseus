spec: logging_handlers_extra
version: ">=3.2"
backend: python_module(logging.handlers)

docs: https://docs.python.org/3/library/logging.handlers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.handlers.html — Python logging.handlers documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/handlers.py"
  notes:
    - "This spec extends logging_handlers.zspec.zsdl."
    - "logging_handlers.zspec.zsdl covers __name__ for all handler classes via a table."
    - "This spec adds __qualname__ checks (not covered by any prior logging.handlers spec) and __module__ checks."
    - "For top-level classes, __qualname__ == __name__; these are orthogonal test axes."
    - "logging.handlers.RotatingFileHandler.__qualname__ == 'RotatingFileHandler'."
    - "logging.handlers.TimedRotatingFileHandler.__qualname__ == 'TimedRotatingFileHandler'."
    - "logging.handlers.SocketHandler.__qualname__ == 'SocketHandler'."
    - "logging.handlers.DatagramHandler.__qualname__ == 'DatagramHandler'."
    - "logging.handlers.SysLogHandler.__qualname__ == 'SysLogHandler'."
    - "logging.handlers.SMTPHandler.__qualname__ == 'SMTPHandler'."
    - "logging.handlers.MemoryHandler.__qualname__ == 'MemoryHandler'."
    - "logging.handlers.HTTPHandler.__qualname__ == 'HTTPHandler'."
    - "logging.handlers.QueueHandler.__qualname__ == 'QueueHandler'."
    - "logging.handlers.QueueListener.__qualname__ == 'QueueListener'."
    - "All handler classes have __module__ == 'logging.handlers' — defined in Lib/logging/handlers.py."
    - "NTEventLogHandler is Windows-only and excluded from cross-platform specs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ checks — not covered by logging_handlers.zspec.zsdl
#
# logging_handlers.zspec.zsdl covers __name__ for all handler classes.
# __qualname__ is a separate attribute and has not been verified for any
# logging.handlers class. For top-level class definitions __qualname__ equals
# __name__, but these remain distinct test vectors.
# ---------------------------------------------------------------------------

table logging_handlers_extra.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [baserotating,      BaseRotatingHandler.__qualname__.__eq__,      ["BaseRotatingHandler"],      true]
    - [rotatingfile,      RotatingFileHandler.__qualname__.__eq__,      ["RotatingFileHandler"],      true]
    - [timedrotatingfile, TimedRotatingFileHandler.__qualname__.__eq__, ["TimedRotatingFileHandler"], true]
    - [socket,            SocketHandler.__qualname__.__eq__,            ["SocketHandler"],            true]
    - [datagram,          DatagramHandler.__qualname__.__eq__,          ["DatagramHandler"],          true]
    - [syslog,            SysLogHandler.__qualname__.__eq__,            ["SysLogHandler"],            true]
    - [smtp,              SMTPHandler.__qualname__.__eq__,              ["SMTPHandler"],              true]
    - [memory,            MemoryHandler.__qualname__.__eq__,            ["MemoryHandler"],            true]
    - [http,              HTTPHandler.__qualname__.__eq__,              ["HTTPHandler"],              true]
    - [queue,             QueueHandler.__qualname__.__eq__,             ["QueueHandler"],             true]
    - [queuelistener,     QueueListener.__qualname__.__eq__,            ["QueueListener"],            true]
    - [watchedfile,       WatchedFileHandler.__qualname__.__eq__,       ["WatchedFileHandler"],       true]

# ---------------------------------------------------------------------------
# Class __module__ checks — all logging.handlers classes are defined in
# the 'logging.handlers' module (Lib/logging/handlers.py).
# Not covered by logging_handlers.zspec.zsdl.
# ---------------------------------------------------------------------------

table logging_handlers_extra.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [baserotating,      BaseRotatingHandler.__module__.__eq__,      ["logging.handlers"], true]
    - [rotatingfile,      RotatingFileHandler.__module__.__eq__,      ["logging.handlers"], true]
    - [timedrotatingfile, TimedRotatingFileHandler.__module__.__eq__, ["logging.handlers"], true]
    - [socket,            SocketHandler.__module__.__eq__,            ["logging.handlers"], true]
    - [datagram,          DatagramHandler.__module__.__eq__,          ["logging.handlers"], true]
    - [syslog,            SysLogHandler.__module__.__eq__,            ["logging.handlers"], true]
    - [smtp,              SMTPHandler.__module__.__eq__,              ["logging.handlers"], true]
    - [memory,            MemoryHandler.__module__.__eq__,            ["logging.handlers"], true]
    - [http,              HTTPHandler.__module__.__eq__,              ["logging.handlers"], true]
    - [queue,             QueueHandler.__module__.__eq__,             ["logging.handlers"], true]
    - [queuelistener,     QueueListener.__module__.__eq__,            ["logging.handlers"], true]
    - [watchedfile,       WatchedFileHandler.__module__.__eq__,       ["logging.handlers"], true]
