table decimal_extra706.context_identity:
  description: "Identity checks for decimal.Context class qualname, module, doc type, and method qualnames"
  kind: python_call_eq
  category: class_identity
  id_prefix: dc706ci
  columns: [id, function, args, expected]
  rows:
    - [dc706ci001, decimal.Context.__qualname__.__eq__, ["Context"], true]
    - [dc706ci002, decimal.Context.__module__.__eq__, ["decimal"], true]
    - [dc706ci003, decimal.Context.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [dc706ci004, decimal.Context.add.__qualname__.__eq__, ["Context.add"], true]
    - [dc706ci005, decimal.Context.subtract.__qualname__.__eq__, ["Context.subtract"], true]
    - [dc706ci006, decimal.Context.multiply.__qualname__.__eq__, ["Context.multiply"], true]
    - [dc706ci007, decimal.Context.divide.__qualname__.__eq__, ["Context.divide"], true]
    - [dc706ci008, decimal.Context.power.__qualname__.__eq__, ["Context.power"], true]
    - [dc706ci009, decimal.Context.sqrt.__qualname__.__eq__, ["Context.sqrt"], true]
    - [dc706ci010, decimal.Context.abs.__qualname__.__eq__, ["Context.abs"], true]
    - [dc706ci011, decimal.Context.copy_abs.__qualname__.__eq__, ["Context.copy_abs"], true]
    - [dc706ci012, decimal.Context.copy_negate.__qualname__.__eq__, ["Context.copy_negate"], true]
