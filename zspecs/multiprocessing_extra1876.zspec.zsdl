spec: multiprocessing_extra1876
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "multiprocessing module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party multiprocessing extensions"
  notes:
    - "Tests attribute access protocol membership in multiprocessing types"
    - "Process defines no custom attr protocol; pool.Pool and AsyncResult likewise"
    - "Process.pid and Process.exitcode are properties defined in class __dict__"
  created_at: "2026-04-12"

table multiprocessing_extra1876.attr_access_protocol:
