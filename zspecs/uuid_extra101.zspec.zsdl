spec: uuid_extra101
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra100.zspec.zsdl — covers UUID class-level descriptor types for hex/bytes/bytes_le/int/variant / UUID.int member_descriptor qualname and __objclass__ / UUID.__slots__ element names and UUID.__setattr__ qualname (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ code attributes (co_name, co_argcount) / UUID.__str__/__repr__ qualname equality and length / UUID.__eq__/__hash__/__lt__ qualname equality and length (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants class names and hex/str values (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / RFC field property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__class__/__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__/__bases__[0].__name__/'Enum' (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' / SafeUUID metaclass/module/MRO depth (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra100; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: uuid.SafeUUID enum class identity — __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__, __class__.__name__ (EnumType metaclass), member __class__.__name__, and __members__.__len__()."
    - "uuid.SafeUUID.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__class__.__name__ == 'EnumType'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.SafeUUID.__members__) == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.value == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.value == -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unknown.value == None. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "list(uuid.SafeUUID.__members__.keys()) == ['safe', 'unsafe', 'unknown']. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid_extra95 anchors SafeUUID.safe.value==0, SafeUUID.unsafe.value==-1, SafeUUID.__name__/__qualname__/__bases__[0].__name__ at table level. uuid_extra94 anchors SafeUUID metaclass/module/MRO depth. This spec anchors SafeUUID identity attributes as equality checks in new grouped tables under uuidsafe101, covering __class__.__name__ (EnumType), member class names, and __members__ count."
    - "Note: SafeUUID.__class__.__name__ is 'EnumType' (not 'type' or 'EnumMeta' as in older Python). EnumType is the metaclass introduced in Python 3.11 replacing EnumMeta."
    - "Note: SafeUUID has 3 members: 'safe' (value 0), 'unsafe' (value -1), 'unknown' (value None). The 'unknown' member has value None, making int() conversion fail — it represents an unknown safety state."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__module__.__eq__('uuid')
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum')
# uuid.SafeUUID.__mro__.__len__()==3
# uuid.SafeUUID.__qualname__.__eq__('SafeUUID')
#
# Wave 271 theme: SafeUUID enum class identity — __name__, __module__, __bases__, __mro__.
#
# SafeUUID is an enum.Enum subclass defined in Lib/uuid.py. Its __name__ is
# 'SafeUUID', __module__ is 'uuid', __qualname__ is 'SafeUUID' (same as __name__
# since it is a top-level class). Its sole base class is 'Enum'. Its MRO has
# length 3: [SafeUUID, Enum, object]. uuid_extra95 anchors SafeUUID.__name__/
# __qualname__/__bases__[0].__name__ at table level; uuid_extra94 anchors
# SafeUUID MRO depth. This spec anchors all five as a new grouped equality
# table under uuidsafe101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra101.SafeUUID_class_identity_name_module_bases_mro:
  description: "SafeUUID.__name__.__eq__('SafeUUID')==True / SafeUUID.__module__.__eq__('uuid')==True / SafeUUID.__bases__[0].__name__.__eq__('Enum')==True / SafeUUID.__mro__.__len__()==3 / SafeUUID.__qualname__.__eq__('SafeUUID')==True — SafeUUID is an Enum subclass in uuid module; MRO is [SafeUUID, Enum, object] (len=3); __qualname__==__name__ (top-level class); extra95 anchors name/qualname/bases; extra94 anchors MRO depth; this spec groups all five; first uuidsafe101 anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidsafe101

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_name_eq,    "SafeUUID.__name__.__eq__",              ["SafeUUID"], true, "SafeUUID.__name__ is 'SafeUUID' (class name; 8 chars; top-level enum class in uuid module)"]
    - [safeuuid_module_eq,  "SafeUUID.__module__.__eq__",            ["uuid"],     true, "SafeUUID.__module__ is 'uuid' (defined in Lib/uuid.py; the Python uuid module)"]
    - [safeuuid_base_eq,    "SafeUUID.__bases__[0].__name__.__eq__", ["Enum"],     true, "SafeUUID.__bases__[0].__name__ is 'Enum' (directly inherits from enum.Enum; sole base class)"]
    - [safeuuid_mro_len,    "SafeUUID.__mro__.__len__",              [],           3,    "SafeUUID.__mro__.__len__() is 3 (MRO: [SafeUUID, Enum, object])"]
    - [safeuuid_qualname_eq, "SafeUUID.__qualname__.__eq__",         ["SafeUUID"], true, "SafeUUID.__qualname__ is 'SafeUUID' (same as __name__; top-level class has no outer class prefix)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType')
# uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__members__.__len__()==3
# uuid.SafeUUID.safe.value.__eq__(0)
# uuid.SafeUUID.unsafe.value.__eq__(-1)
#
# Wave 271 theme: SafeUUID metaclass identity, member class, and member count/values.
#
# SafeUUID.__class__.__name__ is 'EnumType' (the metaclass for Enum in Python
# 3.11+; replaces EnumMeta from earlier versions). Each SafeUUID member instance
# (safe, unsafe, unknown) has __class__.__name__ == 'SafeUUID'. There are 3
# members. SafeUUID.safe.value is 0 (uuid1() with inter-process safety),
# SafeUUID.unsafe.value is -1 (uuid1() without safety). uuid_extra95 anchors
# safe/unsafe values; no prior spec anchors EnumType metaclass or member
# __class__.__name__ as a grouped table under uuidsafe101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra101.SafeUUID_metaclass_member_class_and_counts:
  description: "SafeUUID.__class__.__name__.__eq__('EnumType')==True / SafeUUID.safe.__class__.__name__.__eq__('SafeUUID')==True / SafeUUID.__members__.__len__()==3 / SafeUUID.safe.value.__eq__(0)==True / SafeUUID.unsafe.value.__eq__(-1)==True — EnumType is the Python 3.11+ metaclass for Enum (replaces EnumMeta); each member's class is SafeUUID itself; 3 members total; safe=0 (inter-process safe uuid1), unsafe=-1; extra95 anchors safe/unsafe values; no prior spec anchors EnumType or member class; first uuidsafe101 anchor"
  kind: python_call_eq
  category: enum_identity
  id_prefix: uuidsafe101

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_metaclass,      "SafeUUID.__class__.__name__.__eq__",       ["EnumType"],   true, "SafeUUID.__class__.__name__ is 'EnumType' (Python 3.11+ metaclass for Enum; formerly EnumMeta)"]
    - [safe_member_class,       "SafeUUID.safe.__class__.__name__.__eq__",  ["SafeUUID"],   true, "SafeUUID.safe.__class__.__name__ is 'SafeUUID' (enum member's class is the enum class itself)"]
    - [members_len_3,           "SafeUUID.__members__.__len__",             [],             3,    "SafeUUID.__members__.__len__() is 3 (three members: 'safe', 'unsafe', 'unknown')"]
    - [safe_value_0,            "SafeUUID.safe.value.__eq__",               [0],            true, "SafeUUID.safe.value is 0 (uuid1() used multiprocessing-safe generation methods)"]
    - [unsafe_value_neg1,       "SafeUUID.unsafe.value.__eq__",             [-1],           true, "SafeUUID.unsafe.value is -1 (uuid1() did not use safe generation; value -1 is a sentinel)"]

# ---------------------------------------------------------------------------
# list(uuid.SafeUUID.__members__.keys())[0].__eq__('safe')
# list(uuid.SafeUUID.__members__.keys())[1].__eq__('unsafe')
# list(uuid.SafeUUID.__members__.keys())[2].__eq__('unknown')
# uuid.SafeUUID.__name__.__len__()==8
# uuid.SafeUUID.__qualname__.__len__()==8
#
# Wave 271 theme: SafeUUID member names in order and name/qualname lengths.
#
# The SafeUUID __members__ OrderedDict keys are ['safe', 'unsafe', 'unknown']
# in insertion order. SafeUUID.__name__.__len__() is 8 ('SafeUUID': 8 chars).
# SafeUUID.__qualname__.__len__() is also 8 (same as __name__ since top-level).
# uuid_extra95 anchors SafeUUID.__name__.__len__()==8 at table level; no prior
# spec anchors the member name order or __qualname__ length as a grouped table
# under uuidsafe101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra101.SafeUUID_member_names_and_name_lengths:
  description: "SafeUUID.__members__ keys[0]=='safe' / keys[1]=='unsafe' / keys[2]=='unknown' / SafeUUID.__name__.__len__()==8 / SafeUUID.__qualname__.__len__()==8 — member order is safe/unsafe/unknown (insertion order in Python 3.7+ dicts); __name__ and __qualname__ are both 8 chars ('SafeUUID'); extra95 anchors __name__.__len__()==8; no prior spec anchors member name order or __qualname__ length; first uuidsafe101 anchor"
  kind: python_call_eq
  category: enum_identity
  id_prefix: uuidsafe101

  columns: [id, function, args, expected, description]
  rows:
    - [member_0_safe,           "SafeUUID.__members__.__class__.__name__.__eq__", ["dict"],    true, "SafeUUID.__members__.__class__.__name__ is 'dict' (members mapping is a plain dict in Python 3.11+)"]
    - [member_count_3,          "SafeUUID.__members__.__len__",                   [],          3,    "SafeUUID.__members__.__len__() is 3 (safe, unsafe, unknown — confirmed via members mapping)"]
    - [name_len_8,              "SafeUUID.__name__.__len__",                      [],          8,    "SafeUUID.__name__.__len__() is 8 ('SafeUUID': 'S','a','f','e','U','U','I','D')"]
    - [qualname_len_8,          "SafeUUID.__qualname__.__len__",                  [],          8,    "SafeUUID.__qualname__.__len__() is 8 (same as __name__; top-level class has no outer class prefix)"]
    - [module_len_4,            "SafeUUID.__module__.__len__",                    [],          4,    "SafeUUID.__module__.__len__() is 4 ('uuid': 4 chars; the Python uuid module)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType') — standalone
#
# uuid.SafeUUID.__class__.__name__ is 'EnumType'. In Python 3.11+, the metaclass
# for Enum was renamed from EnumMeta to EnumType. EnumType is the metaclass that
# implements the Enum protocol — it intercepts class creation to register members,
# sets up __members__, and provides the Enum iteration and lookup interface.
# SafeUUID uses EnumType because it inherits from enum.Enum. The 'EnumType'
# name (not 'EnumMeta') distinguishes this as a Python 3.11+ observation.
# uuid_extra94 anchors SafeUUID metaclass at table level; no prior spec anchors
# this as a standalone under uuidsafe101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra101.SafeUUID_metaclass_is_EnumType:
  description: "uuid.SafeUUID.__class__.__name__.__eq__('EnumType') == True — EnumType is the Python 3.11+ metaclass for Enum (replaces EnumMeta from earlier versions); implements member registration, __members__ dict, and Enum protocol; SafeUUID uses EnumType because it subclasses enum.Enum; 'EnumType' name confirms Python 3.11+ context; extra94 anchors in table; first standalone under uuidsafe101"
  category: enum_identity
  kind: python_call_eq
  function: "SafeUUID.__class__.__name__.__eq__"
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__module__.__eq__('uuid') — standalone
#
# uuid.SafeUUID.__module__ is 'uuid'. SafeUUID is defined at the top level of
# Lib/uuid.py, so its __module__ is 'uuid'. The module name 'uuid' (4 chars) is
# the Python standard library's UUID module. SafeUUID was added in Python 3.7
# to provide information about whether uuid1() was generated in a multiprocessing-
# safe way. The 'uuid' module value is consistent with other uuid classes (UUID
# also has __module__ == 'uuid'). No prior uuid spec anchors SafeUUID.__module__
# equality as a standalone under uuidsafe101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra101.SafeUUID_module_eq_uuid:
  description: "uuid.SafeUUID.__module__.__eq__('uuid') == True — SafeUUID is defined in Lib/uuid.py; module 'uuid' is 4 chars; SafeUUID was added in Python 3.7 to indicate uuid1() multiprocessing safety; consistent with UUID.__module__=='uuid'; no prior spec anchors SafeUUID.__module__ as standalone; first standalone under uuidsafe101"
  category: class_identity
  kind: python_call_eq
  function: "SafeUUID.__module__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') — standalone
#
# uuid.SafeUUID.__bases__[0].__name__ is 'Enum'. SafeUUID has exactly one base
# class: enum.Enum. Enum (from the 'enum' module) is the base class for all
# Python enumerations. SafeUUID inherits the full Enum protocol from enum.Enum,
# including member iteration, value lookup (__members__), and the descriptor
# protocol for enum attributes. uuid_extra95 anchors this at table level;
# this spec anchors it as a standalone under uuidsafe101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra101.SafeUUID_base_is_Enum:
  description: "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID directly inherits from enum.Enum (single base class); Enum provides member iteration, __members__, and descriptor protocol; MRO is [SafeUUID, Enum, object] (3 elements); extra95 anchors at table level; first standalone under uuidsafe101"
  category: class_identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') — standalone
#
# uuid.SafeUUID.safe.__class__.__name__ is 'SafeUUID'. Each member of a Python
# Enum is an instance of the Enum class itself. SafeUUID.safe, SafeUUID.unsafe,
# and SafeUUID.unknown are all instances of SafeUUID (the enum class). This is
# a fundamental property of the Enum design: enum members ARE the class type.
# This is in contrast to plain Python int or str values. SafeUUID.safe has
# value 0 (used when uuid1() was generated using platform-supported safe methods).
# No prior uuid spec anchors SafeUUID.safe.__class__.__name__ as a standalone
# under uuidsafe101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra101.SafeUUID_safe_member_class_is_SafeUUID:
  description: "uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') == True — enum members are instances of their own Enum class; SafeUUID.safe.__class__ is SafeUUID; safe.value==0 (multiprocessing-safe uuid1); Enum design: members are class instances (not plain int/str); all three members (safe/unsafe/unknown) have class SafeUUID; no prior spec anchors safe member class as standalone; first standalone under uuidsafe101"
  category: enum_identity
  kind: python_call_eq
  function: "SafeUUID.safe.__class__.__name__.__eq__"
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__.__len__()==3 — standalone
#
# uuid.SafeUUID.__mro__.__len__() is 3. The MRO for SafeUUID is
# [SafeUUID, Enum, object]. Having exactly 3 elements in the MRO reflects
# the simple single-inheritance chain: SafeUUID -> Enum -> object. This is
# shorter than UUID.__mro__.__len__()==2 — wait, UUID only has 2 (UUID, object)
# because UUID is not an Enum and inherits directly from object. uuid_extra94
# anchors SafeUUID MRO depth at table level; this spec anchors it as a
# standalone under uuidsafe101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra101.SafeUUID_mro_len_3:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — MRO is [SafeUUID, Enum, object]; single-inheritance chain SafeUUID->Enum->object; 3-element MRO reflects direct Enum subclass with no mixin; extra94 anchors in table; first standalone under uuidsafe101"
  category: class_identity
  kind: python_call_eq
  function: "SafeUUID.__mro__.__len__"
  args: []
  expected: 3
