spec: itertools_extra254
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools module identity (__name__, __package__, __spec__, __loader__) and itertools.tee function identity behavioral contracts."
    - "itertools.__name__ == 'itertools' — the module's own name attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.__package__ == '' — itertools is a top-level C extension module; __package__ is empty string. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — the loader for a built-in C extension is the type itself; __loader__.__class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.tee.__name__ == 'tee' — tee is a C-level builtin; __name__ is 'tee'. Verified with Python 3.14.3."
    - "itertools.tee.__module__ == 'itertools' — tee is defined in the itertools module; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a C-level builtin callable. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module identity
#
# itertools.__name__ == 'itertools'
# itertools.__package__ == ''
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__loader__.__class__.__name__ == 'type'
#
# itertools is a C extension module; __package__ is empty string (not None)
# and __loader__.__class__.__name__ is 'type'. New to extra254.
# ---------------------------------------------------------------------------

table itertools_extra254.module_identity:
  description: "itertools module __name__, __package__, __spec__.__class__.__name__, __loader__.__class__.__name__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmod254

  columns: [id, function, args, expected, description]
  rows:
    - [itertools_name_eq,
       __name__.__eq__,
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the module's own name attribute is 'itertools'; new to extra254"]
    - [itertools_package_eq,
       __package__.__eq__,
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level C extension; __package__ is empty string; new to extra254"]
    - [itertools_spec_class_eq,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — module spec is an importlib.machinery.ModuleSpec instance; new to extra254"]
    - [itertools_loader_class_eq,
       __loader__.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — loader for a built-in C extension is the type itself; __loader__.__class__.__name__ is 'type'; new to extra254"]
    - [itertools_name_len_9,
       __name__.__len__,
       [],
       9,
       "itertools.__name__.__len__() == 9 — 'itertools' has 9 characters; new to extra254"]

# ---------------------------------------------------------------------------
# Table 2: itertools.tee identity
#
# itertools.tee.__name__ == 'tee'
# itertools.tee.__module__ == 'itertools'
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
#
# tee is a C-level builtin_function_or_method (not a Python type despite
# returning a tuple of iterators). New to extra254.
# ---------------------------------------------------------------------------

table itertools_extra254.tee_identity:
  description: "itertools.tee __name__, __module__, __class__.__name__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: tee254

  columns: [id, function, args, expected, description]
  rows:
    - [tee_name_eq,
       tee.__name__.__eq__,
       ["tee"],
       true,
       "itertools.tee.__name__.__eq__('tee') == True — tee is a C-level builtin; __name__ is 'tee'; new to extra254"]
    - [tee_module_eq,
       tee.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.tee.__module__.__eq__('itertools') == True — tee is defined in the itertools module; __module__ is 'itertools'; new to extra254"]
    - [tee_class_eq,
       tee.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — tee is a C-level builtin callable, not a Python type; new to extra254"]
    - [tee_name_len_3,
       tee.__name__.__len__,
       [],
       3,
       "itertools.tee.__name__.__len__() == 3 — 'tee' has 3 characters; new to extra254"]
    - [tee_module_len_9,
       tee.__module__.__len__,
       [],
       9,
       "itertools.tee.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra254"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra254
# ---------------------------------------------------------------------------

invariant itertools_extra254.module.name_eq:
  description: "itertools.__name__ == 'itertools' — module's own name attribute; new to extra254"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra254.module.package_eq:
  description: "itertools.__package__ == '' — top-level C extension; __package__ is empty string; new to extra254"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra254.module.spec_class_eq:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.machinery.ModuleSpec instance; new to extra254"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra254.module.loader_class_eq:
  description: "itertools.__loader__.__class__.__name__ == 'type' — built-in C extension loader is the type itself; new to extra254"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra254.tee.name_eq:
  description: "itertools.tee.__name__ == 'tee' — C-level builtin_function_or_method; new to extra254"
  category: identity
  kind: python_call_eq
  function: tee.__name__.__eq__
  args: ["tee"]
  expected: true

invariant itertools_extra254.tee.module_eq:
  description: "itertools.tee.__module__ == 'itertools' — defined in the itertools C extension; new to extra254"
  category: identity
  kind: python_call_eq
  function: tee.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra254.tee.class_is_builtin:
  description: "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a C-level builtin, not a type; new to extra254"
  category: identity
  kind: python_call_eq
  function: tee.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
