# verified Python 3.14.3.
# ---------------------------------------------------------------------------

table abc_extra221.dict_deprecated_members:
  description: "abc.__dict__.__contains__ checks for deprecated decorators in abc221dd namespace"
  kind: python_call_eq
  category: dict_membership
  id_prefix: abc221dd

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_abstractclassmethod,  __dict__.__contains__, ["abstractclassmethod"],  true, "abc.__dict__.__contains__('abstractclassmethod') == True — abstractclassmethod deprecated but still exported in abc module; verified with Python 3.14.3"]
    - [dict_has_abstractstaticmethod, __dict__.__contains__, ["abstractstaticmethod"], true, "abc.__dict__.__contains__('abstractstaticmethod') == True — abstractstaticmethod deprecated but still exported in abc module; verified with Python 3.14.3"]
    - [dict_has_abstractproperty,     __dict__.__contains__, ["abstractproperty"],     true, "abc.__dict__.__contains__('abstractproperty') == True — abstractproperty deprecated but still exported in abc module; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module __dict__ class identity check — extra221 namespace
#
# abc.__dict__.__class__.__name__ == 'dict'; verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant abc_extra221.dict_class_name_is_dict:
  description: "abc.__dict__.__class__.__name__ == 'dict' — abc.__dict__ is a plain dict; __class__.__name__ is 'dict' when accessed via __dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
