spec: abc_extra221
version: ">=3.10"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.__dict__.__contains__('ABCMeta') == True — ABCMeta exported in abc module; verified with Python 3.14.3."
    - "abc.__dict__.__contains__('ABC') == True — ABC exported in abc module; verified with Python 3.14.3."
    - "abc.__dict__.__contains__('abstractmethod') == True — abstractmethod exported in abc module; verified with Python 3.14.3."
    - "abc.__dict__.__contains__('get_cache_token') == True — get_cache_token exported in abc module; verified with Python 3.14.3."
    - "abc.__dict__.__contains__('abstractclassmethod') == True — abstractclassmethod exported in abc module (deprecated but present); verified with Python 3.14.3."
    - "abc.__dict__.__contains__('abstractstaticmethod') == True — abstractstaticmethod exported in abc module (deprecated but present); verified with Python 3.14.3."
    - "abc.__dict__.__contains__('abstractproperty') == True — abstractproperty exported in abc module (deprecated but present); verified with Python 3.14.3."
    - "abc.__dict__.__contains__('update_abstractmethods') == True — update_abstractmethods added in Python 3.10; present in abc module; verified with Python 3.14.3."
    - "abc.__dict__.__class__.__name__ == 'dict' — abc.__dict__ is a plain dict (mappingproxy backed by dict); __class__.__name__ is 'dict' when accessed via __dict__; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module __dict__ membership — core ABC classes — extra221 namespace
#
# ABCMeta, ABC both present in abc.__dict__; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table abc_extra221.dict_core_members:
  description: "abc.__dict__.__contains__ checks for core ABC classes in abc221dc namespace"
  kind: python_call_eq
  category: dict_membership
  id_prefix: abc221dc

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_ABCMeta, __dict__.__contains__, ["ABCMeta"], true, "abc.__dict__.__contains__('ABCMeta') == True — ABCMeta exported in abc module; verified with Python 3.14.3"]
    - [dict_has_ABC,     __dict__.__contains__, ["ABC"],     true, "abc.__dict__.__contains__('ABC') == True — ABC exported in abc module; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module __dict__ membership — decorator and utility functions — extra221 namespace
#
# abstractmethod, get_cache_token, update_abstractmethods (added 3.10) all present; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table abc_extra221.dict_func_members:
  description: "abc.__dict__.__contains__ checks for decorator and utility functions in abc221df namespace"
  kind: python_call_eq
  category: dict_membership
  id_prefix: abc221df

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_abstractmethod,       __dict__.__contains__, ["abstractmethod"],       true, "abc.__dict__.__contains__('abstractmethod') == True — abstractmethod exported in abc module; verified with Python 3.14.3"]
    - [dict_has_get_cache_token,      __dict__.__contains__, ["get_cache_token"],      true, "abc.__dict__.__contains__('get_cache_token') == True — get_cache_token exported in abc module; verified with Python 3.14.3"]
    - [dict_has_update_abstractmethods, __dict__.__contains__, ["update_abstractmethods"], true, "abc.__dict__.__contains__('update_abstractmethods') == True — update_abstractmethods added in Python 3.10; present in abc module; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
