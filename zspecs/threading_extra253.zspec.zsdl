spec: threading_extra253
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.local class method identity (__init__, __getattribute__, __setattr__, __delattr__ qualnames and names), threading.excepthook function identity, and threading.ExceptHookArgs class identity behavioral contracts."
    - "threading.local.__init__.__name__ == '__init__' — local.__init__ is a wrapper_descriptor; __name__ is '__init__'. Verified with Python 3.14.3."
    - "threading.local.__init__.__qualname__ == 'object.__init__' — local inherits __init__ from object; the qualname reflects the origin as 'object.__init__'. Verified with Python 3.14.3."
    - "threading.local.__getattribute__.__name__ == '__getattribute__' — local.__getattribute__ is a wrapper_descriptor overriding object's __getattribute__ for thread-local storage; __name__ is '__getattribute__'. Verified with Python 3.14.3."
    - "threading.local.__getattribute__.__qualname__ == '_local.__getattribute__' — qualname reflects that this is defined on the _local class. Verified with Python 3.14.3."
    - "threading.local.__setattr__.__name__ == '__setattr__' — local.__setattr__ is a wrapper_descriptor managing thread-local attribute storage; __name__ is '__setattr__'. Verified with Python 3.14.3."
    - "threading.local.__setattr__.__qualname__ == '_local.__setattr__' — qualname reflects that this is defined on the _local class. Verified with Python 3.14.3."
    - "threading.local.__delattr__.__name__ == '__delattr__' — local.__delattr__ is a wrapper_descriptor managing thread-local attribute deletion; __name__ is '__delattr__'. Verified with Python 3.14.3."
    - "threading.local.__delattr__.__qualname__ == '_local.__delattr__' — qualname reflects that this is defined on the _local class. Verified with Python 3.14.3."
    - "threading.local.__init__.__class__.__name__ == 'wrapper_descriptor' — all four local dunder methods are wrapper_descriptor objects (C slot wrappers). Verified with Python 3.14.3."
    - "threading.excepthook.__name__ == '_excepthook' — threading.excepthook is the C-level _excepthook from the _thread extension; __name__ is '_excepthook'. Verified with Python 3.14.3."
    - "threading.excepthook.__module__ == '_thread' — threading.excepthook is implemented in the _thread C extension; __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — ExceptHookArgs is a named-tuple subclass; the class __name__ is '_ExceptHookArgs'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__module__ == '_thread' — ExceptHookArgs is defined in the _thread C extension; __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple' — ExceptHookArgs inherits directly from tuple (C-level named tuple); first base __name__ is 'tuple'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.local method name and qualname identity
#
# threading.local.__init__.__name__ == '__init__'
# threading.local.__init__.__qualname__ == 'object.__init__'
# threading.local.__getattribute__.__name__ == '__getattribute__'
# threading.local.__getattribute__.__qualname__ == '_local.__getattribute__'
# threading.local.__setattr__.__name__ == '__setattr__'
# threading.local.__setattr__.__qualname__ == '_local.__setattr__'
#
# local inherits __init__ from object; the other three are custom
# wrapper_descriptor slots defined on _local. New to extra253.
# ---------------------------------------------------------------------------

table threading_extra253.local_method_name_qualname:
  description: "threading.local method __name__ and __qualname__ identity contracts; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: thdlocalmethod253

  columns: [id, function, args, expected, description]
  rows:
    - [local_init_name_eq,
       local.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "threading.local.__init__.__name__.__eq__('__init__') == True — local.__init__ is a wrapper_descriptor; __name__ is '__init__'; new to extra253"]
    - [local_init_qualname_eq,
       local.__init__.__qualname__.__eq__,
       ["object.__init__"],
       true,
       "threading.local.__init__.__qualname__.__eq__('object.__init__') == True — local inherits __init__ from object; qualname is 'object.__init__'; new to extra253"]
    - [local_getattribute_name_eq,
       local.__getattribute__.__name__.__eq__,
       ["__getattribute__"],
       true,
       "threading.local.__getattribute__.__name__.__eq__('__getattribute__') == True — local.__getattribute__ is a wrapper_descriptor overriding object's __getattribute__ for thread-local storage; __name__ is '__getattribute__'; new to extra253"]
    - [local_getattribute_qualname_eq,
       local.__getattribute__.__qualname__.__eq__,
       ["_local.__getattribute__"],
       true,
       "threading.local.__getattribute__.__qualname__.__eq__('_local.__getattribute__') == True — qualname reflects that __getattribute__ is defined on the _local C class; new to extra253"]
    - [local_setattr_name_eq,
       local.__setattr__.__name__.__eq__,
       ["__setattr__"],
       true,
       "threading.local.__setattr__.__name__.__eq__('__setattr__') == True — local.__setattr__ is a wrapper_descriptor managing thread-local attribute storage; __name__ is '__setattr__'; new to extra253"]

# ---------------------------------------------------------------------------
# Table 2: threading.local.__setattr__ and __delattr__ qualname and class
#
# threading.local.__setattr__.__qualname__ == '_local.__setattr__'
# threading.local.__delattr__.__name__ == '__delattr__'
# threading.local.__delattr__.__qualname__ == '_local.__delattr__'
# threading.local.__init__.__class__.__name__ == 'wrapper_descriptor'
# threading.local.__getattribute__.__class__.__name__ == 'wrapper_descriptor'
#
# All four dunder methods are wrapper_descriptor objects. New to extra253.
# ---------------------------------------------------------------------------

table threading_extra253.local_method_qualname_class:
  description: "threading.local.__setattr__ and __delattr__ qualname identity, and wrapper_descriptor class checks; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: thdlocalmeth253b

  columns: [id, function, args, expected, description]
  rows:
    - [local_setattr_qualname_eq,
       local.__setattr__.__qualname__.__eq__,
       ["_local.__setattr__"],
       true,
       "threading.local.__setattr__.__qualname__.__eq__('_local.__setattr__') == True — qualname reflects that __setattr__ is defined on the _local C class; new to extra253"]
    - [local_delattr_name_eq,
       local.__delattr__.__name__.__eq__,
       ["__delattr__"],
       true,
       "threading.local.__delattr__.__name__.__eq__('__delattr__') == True — local.__delattr__ is a wrapper_descriptor managing thread-local attribute deletion; __name__ is '__delattr__'; new to extra253"]
    - [local_delattr_qualname_eq,
       local.__delattr__.__qualname__.__eq__,
       ["_local.__delattr__"],
       true,
       "threading.local.__delattr__.__qualname__.__eq__('_local.__delattr__') == True — qualname reflects that __delattr__ is defined on the _local C class; new to extra253"]
    - [local_init_class_eq,
       local.__init__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "threading.local.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — local.__init__ is a C slot wrapper (wrapper_descriptor); new to extra253"]
    - [local_getattribute_class_eq,
       local.__getattribute__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "threading.local.__getattribute__.__class__.__name__.__eq__('wrapper_descriptor') == True — local.__getattribute__ is a C slot wrapper (wrapper_descriptor); new to extra253"]

# ---------------------------------------------------------------------------
# Table 3: threading.excepthook and threading.ExceptHookArgs identity
#
# threading.excepthook.__name__ == '_excepthook'
# threading.excepthook.__module__ == '_thread'
# threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'
# threading.ExceptHookArgs.__module__ == '_thread'
# threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple'
#
# Both are C-level entities from the _thread extension. The public names
# threading.excepthook and threading.ExceptHookArgs are aliases for the
# internal _thread._excepthook and _thread._ExceptHookArgs. New to extra253.
# ---------------------------------------------------------------------------

table threading_extra253.excepthook_ExceptHookArgs_identity:
  description: "threading.excepthook and threading.ExceptHookArgs __name__, __module__, __bases__[0].__name__ identity contracts; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: thdexcepthook253

  columns: [id, function, args, expected, description]
  rows:
    - [excepthook_name_eq,
       excepthook.__name__.__eq__,
       ["_excepthook"],
       true,
       "threading.excepthook.__name__.__eq__('_excepthook') == True — threading.excepthook is the C-level _excepthook from the _thread extension; __name__ is '_excepthook'; new to extra253"]
    - [excepthook_module_eq,
       excepthook.__module__.__eq__,
       ["_thread"],
       true,
       "threading.excepthook.__module__.__eq__('_thread') == True — threading.excepthook is implemented in the _thread C extension; __module__ is '_thread'; new to extra253"]
    - [ExceptHookArgs_name_eq,
       ExceptHookArgs.__name__.__eq__,
       ["_ExceptHookArgs"],
       true,
       "threading.ExceptHookArgs.__name__.__eq__('_ExceptHookArgs') == True — ExceptHookArgs is a C-level named tuple subclass; its __name__ is '_ExceptHookArgs'; new to extra253"]
    - [ExceptHookArgs_module_eq,
       ExceptHookArgs.__module__.__eq__,
       ["_thread"],
       true,
       "threading.ExceptHookArgs.__module__.__eq__('_thread') == True — ExceptHookArgs is defined in the _thread C extension; __module__ is '_thread'; new to extra253"]
    - ["ExceptHookArgs_base0_name_eq",
       "ExceptHookArgs.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "threading.ExceptHookArgs.__bases__[0].__name__.__eq__('tuple') == True — ExceptHookArgs inherits directly from tuple (C-level named tuple); first base __name__ is 'tuple'; new to extra253"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra253
# ---------------------------------------------------------------------------

invariant threading_extra253.local.__init__.name_eq:
  description: "threading.local.__init__.__name__ == '__init__' — inherited wrapper_descriptor from object; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra253.local.__init__.qualname_eq:
  description: "threading.local.__init__.__qualname__ == 'object.__init__' — local inherits __init__ from object; qualname reflects origin; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant threading_extra253.local.__init__.class_is_wrapper_descriptor:
  description: "threading.local.__init__.__class__.__name__ == 'wrapper_descriptor' — local.__init__ is a C slot wrapper; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant threading_extra253.local.__getattribute__.name_eq:
  description: "threading.local.__getattribute__.__name__ == '__getattribute__' — custom wrapper_descriptor for thread-local attribute access; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__getattribute__.__name__.__eq__
  args: ["__getattribute__"]
  expected: true

invariant threading_extra253.local.__getattribute__.qualname_eq:
  description: "threading.local.__getattribute__.__qualname__ == '_local.__getattribute__' — qualname shows definition on _local C class; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__getattribute__.__qualname__.__eq__
  args: ["_local.__getattribute__"]
  expected: true

invariant threading_extra253.local.__setattr__.name_eq:
  description: "threading.local.__setattr__.__name__ == '__setattr__' — custom wrapper_descriptor for thread-local attribute storage; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__setattr__.__name__.__eq__
  args: ["__setattr__"]
  expected: true

invariant threading_extra253.local.__setattr__.qualname_eq:
  description: "threading.local.__setattr__.__qualname__ == '_local.__setattr__' — qualname shows definition on _local C class; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__setattr__.__qualname__.__eq__
  args: ["_local.__setattr__"]
  expected: true

invariant threading_extra253.local.__delattr__.name_eq:
  description: "threading.local.__delattr__.__name__ == '__delattr__' — custom wrapper_descriptor for thread-local attribute deletion; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__delattr__.__name__.__eq__
  args: ["__delattr__"]
  expected: true

invariant threading_extra253.local.__delattr__.qualname_eq:
  description: "threading.local.__delattr__.__qualname__ == '_local.__delattr__' — qualname shows definition on _local C class; new to extra253"
  category: identity
  kind: python_call_eq
  function: local.__delattr__.__qualname__.__eq__
  args: ["_local.__delattr__"]
  expected: true

invariant threading_extra253.excepthook.name_eq:
  description: "threading.excepthook.__name__ == '_excepthook' — C-level hook called when a thread raises an unhandled exception; __name__ is '_excepthook'; new to extra253"
  category: identity
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra253.excepthook.module_eq:
  description: "threading.excepthook.__module__ == '_thread' — threading.excepthook is implemented in the _thread C extension; new to extra253"
  category: identity
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra253.ExceptHookArgs.name_eq:
  description: "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — C-level named tuple subclass holding exception hook arguments; new to extra253"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__name__.__eq__
  args: ["_ExceptHookArgs"]
  expected: true

invariant threading_extra253.ExceptHookArgs.module_eq:
  description: "threading.ExceptHookArgs.__module__ == '_thread' — ExceptHookArgs is defined in the _thread C extension; new to extra253"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra253.ExceptHookArgs.name_len_15:
  description: "threading.ExceptHookArgs.__name__.__len__() == 15 — '_ExceptHookArgs' has 15 characters; new to extra253"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__name__.__len__
  args: []
  expected: 15
