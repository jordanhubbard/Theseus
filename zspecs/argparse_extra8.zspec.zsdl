spec: argparse_extra8
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers __name__ table for all public classes, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, MRO checks"
    - "argparse_formatters.zspec.zsdl — covers formatter __name__/__module__/__bases__ tables, FileType, BooleanOptionalAction __bases__, exception __bases__"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/Namespace/HelpFormatter/ArgumentError/Action __name__/__module__, Action.__bases__[0], ArgumentDefaultsHelpFormatter/__name__, FileType/__name__/__module__, parse_args/__name__, add_argument/__name__"
    - "argparse_extra2.zspec.zsdl — covers __module__ table for formatters/exceptions, __bases__[0].__name__ invariants for ArgumentParser/Namespace/ArgumentError/ArgumentTypeError/HelpFormatter/RawText*/RawDescription*/ArgumentDefaults*"
    - "argparse_extra3.zspec.zsdl — covers class_names table, nargs_constants table, ArgumentParser/__module__, Namespace instance class, ArgumentError/ArgumentTypeError __bases__[0], ArgumentParser().prog type"
    - "argparse_extra4.zspec.zsdl — covers __qualname__ table for ArgumentParser/Namespace/Action/FileType/HelpFormatter/RawDescription*/RawText*/ArgumentDefaults*/MetavarType*/ArgumentError/ArgumentTypeError"
    - "argparse_extra5.zspec.zsdl — covers argparse module __name__, FileType/__bases__[0], BooleanOptionalAction/__bases__[0], SUPPRESS/REMAINDER/ONE_OR_MORE/ZERO_OR_MORE/OPTIONAL __class__.__name__"
    - "argparse_extra6.zspec.zsdl — covers BooleanOptionalAction/__qualname__, PARSER value/class, Namespace/__bases__[0].__name__, HelpFormatter/__bases__[0].__name__, ArgumentParser method names (set_defaults/format_help/format_usage/parse_known_args), ArgumentParser().description"
    - "argparse_extra7.zspec.zsdl — covers Action/__module__, FileType/__module__, formatter_bases table, ONE_OR_MORE __ne__/__len__, ArgumentParser().prefix_chars, ArgumentParser().add_help, HelpFormatter/__name__, RawDescriptionHelpFormatter/__name__, MetavarTypeHelpFormatter/__name__ standalone invariants"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __bases__.__len__() == 1 for ArgumentParser, Namespace, Action, HelpFormatter (single-inheritance confirmation); ArgumentParser method names not yet covered (print_usage, print_help, convert_arg_line_to_args, exit, error)."
    - "argparse.ArgumentParser.__bases__.__len__() == 1 — ArgumentParser has exactly one direct base (_ActionsContainer). Confirmed by verifying __bases__[0].__name__ in extra2; this checks tuple length."
    - "argparse.Namespace.__bases__.__len__() == 1 — Namespace inherits only from _AttributeHolder. Extra2/extra6 check __bases__[0].__name__ but not __len__."
    - "argparse.Action.__bases__.__len__() == 1 — Action inherits only from _AttributeHolder. Extra checks __bases__[0].__name__ but not __len__."
    - "argparse.HelpFormatter.__bases__.__len__() == 1 — HelpFormatter inherits only from object. Extra2/extra6 check __bases__[0].__name__ but not __len__."
    - "argparse.ArgumentParser.print_usage.__name__ == 'print_usage' — no prior spec covers this method name."
    - "argparse.ArgumentParser.print_help.__name__ == 'print_help' — no prior spec covers this method name."
    - "argparse.ArgumentParser.convert_arg_line_to_args.__name__ == 'convert_arg_line_to_args' — no prior spec covers this method name."
    - "argparse.ArgumentParser.exit.__name__ == 'exit' — no prior spec covers this method name."
    - "argparse.ArgumentParser.error.__name__ == 'error' — no prior spec covers this method name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for core argparse classes.
# Prior specs verify __bases__[0].__name__ for each of these but no spec
# checks the length of the __bases__ tuple (single-inheritance confirmation).
# ---------------------------------------------------------------------------

table argparse_extra8.bases_len:
  kind: python_call_eq
  category: hierarchy
  id_prefix: baselen8

  columns: [id, function, args, expected]
  rows:
    - [ArgumentParser, ArgumentParser.__bases__.__len__, [], 1]
    - [Namespace,      Namespace.__bases__.__len__,      [], 1]
    - [Action,         Action.__bases__.__len__,         [], 1]
    - [HelpFormatter,  HelpFormatter.__bases__.__len__,  [], 1]

# ---------------------------------------------------------------------------
# ArgumentParser method names not covered in any prior argparse spec.
# extra covers: parse_args.__name__, add_argument.__name__
# extra6 covers: set_defaults.__name__, format_help.__name__,
#                format_usage.__name__, parse_known_args.__name__
# This table adds: print_usage, print_help, convert_arg_line_to_args, exit, error.
# ---------------------------------------------------------------------------

table argparse_extra8.ArgumentParser.additional_method_names:
  kind: python_call_eq
  category: methods
  id_prefix: mname8

  columns: [id, function, args, expected]
  rows:
    - [print_usage,                ArgumentParser.print_usage.__name__.__eq__,                ["print_usage"],                true]
    - [print_help,                 ArgumentParser.print_help.__name__.__eq__,                 ["print_help"],                 true]
    - [convert_arg_line_to_args,   ArgumentParser.convert_arg_line_to_args.__name__.__eq__,   ["convert_arg_line_to_args"],   true]
    - [exit,                       ArgumentParser.exit.__name__.__eq__,                       ["exit"],                       true]
    - [error,                      ArgumentParser.error.__name__.__eq__,                      ["error"],                      true]
