spec: reprlib_extra18
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl through reprlib_extra17.zspec.zsdl."
    - "reprlib_extra8 covers: Repr().maxstring.__class__.__name__=='int' via method chain (fresh Repr() form)."
    - "reprlib_extra9 covers: Repr().maxlist.__class__.__name__=='int' via method chain."
    - "reprlib_extra14 covers: aRepr.__class__.__qualname__=='Repr'; Repr.__module__=='reprlib'; recursive_repr identity."
    - "reprlib_extra17 covers: Repr.__init__/__repr__ qualnames; repr_frozenset/repr_deque/repr_array qualnames; recursive_repr.__qualname__ standalone."
    - "No prior spec verifies aRepr.__class__.__module__ as a standalone invariant."
    - "No prior spec verifies Repr.__init__.__module__ as a standalone invariant."
    - "No prior spec verifies Repr().maxother/__class__.__name__=='int' (method-chain form on fresh instance)."
    - "No prior spec verifies Repr().maxlong/__class__.__name__=='int' (method-chain form on fresh instance)."
    - "No prior spec verifies Repr().maxlevel/__class__.__name__=='int' (method-chain form on fresh instance)."
    - "No prior spec verifies Repr().maxdict/__class__.__name__=='int' (method-chain form on fresh instance)."
    - "reprlib.aRepr.__class__.__module__ == 'reprlib' — the module-level Repr instance's class is defined in reprlib. Verified at runtime."
    - "reprlib.Repr.__init__.__module__ == 'reprlib' — Repr.__init__ is defined in the reprlib module. Verified at runtime."
    - "reprlib.Repr().maxother == 30 — default; type is int. Verified at runtime."
    - "reprlib.Repr().maxlong == 40 — default; type is int. Verified at runtime."
    - "reprlib.Repr().maxlevel == 6 — default; type is int. Verified at runtime."
    - "reprlib.Repr().maxdict == 4 — default; type is int. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# aRepr.__class__.__module__
#
# reprlib_extra13 covers aRepr.__class__.__name__ == 'Repr'.
# reprlib_extra14 covers aRepr.__class__.__qualname__ == 'Repr'.
# No prior spec verifies aRepr.__class__.__module__ as a standalone invariant.
# The Repr class is defined in the reprlib module, so its __module__ == 'reprlib'.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra18.aRepr.class_module:
  description: "reprlib.aRepr.__class__.__module__ == 'reprlib' — module-level Repr instance's class is defined in reprlib"
  category: function_identity
  kind: python_call_eq
  function: aRepr.__class__.__module__.__eq__
  args: ["reprlib"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.__init__.__module__
#
# reprlib_extra17 covers Repr.__init__.__qualname__ == 'Repr.__init__'.
# No prior spec verifies Repr.__init__.__module__ as a standalone invariant.
# The constructor is defined in the reprlib module.
# Verified: Repr.__init__.__module__ == 'reprlib'.
# ---------------------------------------------------------------------------

invariant reprlib_extra18.Repr.__init__module:
  description: "reprlib.Repr.__init__.__module__ == 'reprlib' — constructor defined in reprlib module"
  category: function_identity
  kind: python_call_eq
  function: Repr.__init__.__module__.__eq__
  args: ["reprlib"]
  expected: true

# ---------------------------------------------------------------------------
# Repr() instance max-attribute type checks — maxother, maxlong, maxlevel, maxdict
#
# reprlib_extra8 covers Repr().maxstring.__class__.__name__ == 'int' (method chain).
# reprlib_extra9 covers Repr().maxlist.__class__.__name__ == 'int' (method chain).
# No prior spec checks the type (via __class__.__name__ method chain on a fresh
# Repr() instance) for maxother, maxlong, maxlevel, or maxdict.
# All four are plain Python ints. Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra18.Repr_instance.maxother_type:
  description: "reprlib.Repr().maxother.__class__.__name__ == 'int' — maxother on fresh Repr() is an int"
  category: class_structure
  kind: python_call_eq
  function: Repr
  args: []
  expected: "int"
  method: maxother.__class__.__name__.__eq__
  method_args: ["int"]

invariant reprlib_extra18.Repr_instance.maxlong_type:
  description: "reprlib.Repr().maxlong.__class__.__name__ == 'int' — maxlong on fresh Repr() is an int"
  category: class_structure
  kind: python_call_eq
  function: Repr
  args: []
  expected: "int"
  method: maxlong.__class__.__name__.__eq__
  method_args: ["int"]

invariant reprlib_extra18.Repr_instance.maxlevel_type:
  description: "reprlib.Repr().maxlevel.__class__.__name__ == 'int' — maxlevel on fresh Repr() is an int"
  category: class_structure
  kind: python_call_eq
  function: Repr
  args: []
  expected: "int"
  method: maxlevel.__class__.__name__.__eq__
  method_args: ["int"]

invariant reprlib_extra18.Repr_instance.maxdict_type:
  description: "reprlib.Repr().maxdict.__class__.__name__ == 'int' — maxdict on fresh Repr() is an int"
  category: class_structure
  kind: python_call_eq
  function: Repr
  args: []
  expected: "int"
  method: maxdict.__class__.__name__.__eq__
  method_args: ["int"]

# ---------------------------------------------------------------------------
# Table: aRepr and Repr.__init__ module identity
#
# Groups the two new module-identity checks in one indexed table.
# No prior table covers aRepr.__class__.__module__ or Repr.__init__.__module__.
# All verified at runtime.
# ---------------------------------------------------------------------------

table reprlib_extra18.module_identity:
  description: "reprlib aRepr class module and Repr.__init__ module identity checks"
  kind: python_call_eq
  category: function_identity
  id_prefix: rl18mi

  columns: [id, function, args, expected]
  rows:
    - [aRepr_class_module, aRepr.__class__.__module__.__eq__, ["reprlib"], true]
    - [Repr_init_module,   Repr.__init__.__module__.__eq__,   ["reprlib"], true]
