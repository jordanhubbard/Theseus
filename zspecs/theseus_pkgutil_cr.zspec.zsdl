spec: theseus_pkgutil_cr
version: ">=3.9"
backend: python_cleanroom(theseus_pkgutil_cr)
blocks: pkgutil

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html"
  notes:
    - "Clean-room pkgutil utilities. Do NOT import pkgutil."
    - "ModuleInfo: namedtuple(module_finder, name, ispkg)."
    - "resolve_name(name): import and return object by dotted name string."
    - "get_loader(fullname): return loader for a module (use importlib.util, import allowed)."
    - "pkgutil_resolve_os(): resolve_name('os') is the os module."
    - "pkgutil_resolve_attr(): resolve_name('os.path.join') is callable."
    - "pkgutil_module_info(): ModuleInfo(None,'test',False).name == 'test'."
    - "Export: resolve_name, ModuleInfo."
    - "For resolve_name: split on last dot to get module + attr; use importlib.import_module (import importlib allowed)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_pkgutil_cr.resolve_os:
  description: "resolve_name('os') is the os module (has __name__ == 'os')"
  category: resolve_name
  kind: python_call_eq
  function: pkgutil_resolve_os
  args: []
  expected: "os"

invariant theseus_pkgutil_cr.resolve_attr:
  description: "resolve_name('os.path.join') is callable"
  category: resolve_name
  kind: python_call_eq
  function: pkgutil_resolve_attr
  args: []
  expected: true

invariant theseus_pkgutil_cr.module_info:
  description: "ModuleInfo(None,'test',False).name == 'test'"
  category: module_info
  kind: python_call_eq
  function: pkgutil_module_info
  args: []
  expected: "test"
