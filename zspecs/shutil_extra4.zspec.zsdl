spec: shutil_extra4
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends prior shutil specs."
    - "Focus: function names and class names not yet covered."
    - "shutil.copy.__name__ == 'copy'."
    - "shutil.copy2.__name__ == 'copy2'."
    - "shutil.copyfile.__name__ == 'copyfile'."
    - "shutil.copyfileobj.__name__ == 'copyfileobj'."
    - "shutil.copytree.__name__ == 'copytree'."
    - "shutil.rmtree.__name__ == 'rmtree'."
    - "shutil.move.__name__ == 'move'."
    - "shutil.disk_usage.__name__ == 'disk_usage'."
    - "shutil.which.__name__ == 'which'."
    - "shutil.get_terminal_size.__name__ == 'get_terminal_size'."
    - "shutil.get_archive_formats.__name__ == 'get_archive_formats'."
    - "shutil.make_archive.__name__ == 'make_archive'."
    - "shutil.Error.__name__ == 'Error'."
    - "shutil.SameFileError.__name__ == 'SameFileError'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table shutil_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [copy,               copy.__name__.__eq__,               ["copy"],               true]
    - [copy2,              copy2.__name__.__eq__,              ["copy2"],              true]
    - [copyfile,           copyfile.__name__.__eq__,           ["copyfile"],           true]
    - [copyfileobj,        copyfileobj.__name__.__eq__,        ["copyfileobj"],        true]
    - [copytree,           copytree.__name__.__eq__,           ["copytree"],           true]
    - [rmtree,             rmtree.__name__.__eq__,             ["rmtree"],             true]
    - [move,               move.__name__.__eq__,               ["move"],               true]
    - [disk_usage,         disk_usage.__name__.__eq__,         ["disk_usage"],         true]
    - [which,              which.__name__.__eq__,              ["which"],              true]
    - [get_terminal_size,  get_terminal_size.__name__.__eq__,  ["get_terminal_size"],  true]
    - [get_archive_formats, get_archive_formats.__name__.__eq__, ["get_archive_formats"], true]
    - [make_archive,       make_archive.__name__.__eq__,       ["make_archive"],       true]

table shutil_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Error,         Error.__name__.__eq__,         ["Error"],         true]
    - [SameFileError, SameFileError.__name__.__eq__, ["SameFileError"], true]

invariant shutil_extra4.Error.base:
  description: "shutil.Error.__bases__[0].__name__ == 'OSError'"
  category: exceptions
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant shutil_extra4.SameFileError.base:
  description: "shutil.SameFileError.__bases__[0].__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: SameFileError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant shutil_extra4.disk_usage.returns_named_tuple:
  description: "shutil.disk_usage('/').__class__.__name__ == 'usage'"
  category: disk_usage
  kind: python_call_eq
  function: disk_usage
  args: ["/"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["usage"]
  expected: true

invariant shutil_extra4.disk_usage.total_ge_zero:
  description: "shutil.disk_usage('/').total > 0"
  category: disk_usage
  kind: python_call_eq
  function: disk_usage
  args: ["/"]
  method: total.__gt__
  method_args: [0]
  expected: true

invariant shutil_extra4.get_archive_formats.returns_list:
  description: "shutil.get_archive_formats().__class__.__name__ == 'list'"
  category: get_archive_formats
  kind: python_call_eq
  function: get_archive_formats
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true

invariant shutil_extra4.which.returns_str_or_none:
  description: "shutil.which('python3').__class__.__name__ in ('str', 'NoneType')"
  category: which
  kind: python_call_eq
  function: which.__name__.__eq__
  args: ["which"]
  expected: true
