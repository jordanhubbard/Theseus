  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmembers_static (Python 3.11+) __code__.co_name 'getmembers_static', co_argcount 2; inspect.classify_class_attrs __code__.co_name 'classify_class_attrs', co_argcount 1; inspect.getattr_static __code__.co_name 'getattr_static', co_argcount 3; inspect.formatannotation __code__.co_name 'formatannotation', co_argcount 2; inspect.isasyncgen __code__.co_name 'isasyncgen' (Wave 284)."
    - "inspect.getmembers_static is a Python 3.11+ function added in bpo-15104; it retrieves members without triggering descriptors. Its co_argcount is 2 (object, predicate=None). Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_argcount == 1 — classify_class_attrs(cls) takes exactly 1 argument. Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_argcount == 3 — getattr_static(obj, attr, default=...) takes 3 positional-or-keyword arguments. Verified with Python 3.14.3."
    - "inspect.formatannotation.__code__.co_argcount == 2 — formatannotation(annotation, base_module=None) takes 2 arguments. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__code__.co_name == 'isasyncgen' — code object co_name equals the function name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers_static and inspect.classify_class_attrs code attrs
#
# Wave 284 theme: Python 3.11+ inspect functions — getmembers_static and
# classify_class_attrs __code__ attributes.
#
# inspect.getmembers_static.__code__.co_name == 'getmembers_static'
# inspect.getmembers_static.__code__.co_argcount == 2
# inspect.classify_class_attrs.__code__.co_name == 'classify_class_attrs'
# inspect.classify_class_attrs.__code__.co_argcount == 1
#
# getmembers_static was added in Python 3.11 to retrieve class/instance members
# without triggering descriptor __get__ calls. classify_class_attrs returns
# information about each attribute of a class. New to extra155.
# ---------------------------------------------------------------------------

table inspect_extra155.getmembers_static_and_classify_class_attrs_code:
  description: "inspect.getmembers_static (3.11+): co_name 'getmembers_static', co_argcount 2; inspect.classify_class_attrs: co_name 'classify_class_attrs', co_argcount 1; wave 284; new to extra155"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgmsccaca155

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_static_co_name_eq,
       "getmembers_static.__code__.co_name.__eq__",
       ["getmembers_static"],
       true,
       "inspect.getmembers_static.__code__.co_name.__eq__('getmembers_static') == True — getmembers_static (Python 3.11+) retrieves class/instance members without triggering descriptor __get__; its code object co_name is 'getmembers_static'; str.__eq__('getmembers_static') returns True; new to extra155"]
    - [getmembers_static_co_argcount_eq_2,
       "getmembers_static.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers_static.__code__.co_argcount.__eq__(2) == True — getmembers_static(object, predicate=None) takes 2 positional-or-keyword arguments; co_argcount is 2; int.__eq__(2) returns True; new to extra155"]
    - [classify_class_attrs_co_name_eq,
       "classify_class_attrs.__code__.co_name.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__code__.co_name.__eq__('classify_class_attrs') == True — classify_class_attrs is a Python function in Lib/inspect.py returning classification info for each attribute of a class; its code object co_name is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra155"]
    - [classify_class_attrs_co_argcount_eq_1,
       "classify_class_attrs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.classify_class_attrs.__code__.co_argcount.__eq__(1) == True — classify_class_attrs(cls) takes exactly 1 positional-or-keyword argument; co_argcount is 1; int.__eq__(1) returns True; new to extra155"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getattr_static, formatannotation, and isasyncgen code attrs
#
# Wave 284 theme: inspect utility functions __code__ attributes — co_name and
# co_argcount for getattr_static, formatannotation, and isasyncgen.
#
# inspect.getattr_static.__code__.co_name == 'getattr_static'
# inspect.getattr_static.__code__.co_argcount == 3
# inspect.formatannotation.__code__.co_name == 'formatannotation'
# inspect.formatannotation.__code__.co_argcount == 2
# inspect.isasyncgen.__code__.co_name == 'isasyncgen'
#
# getattr_static retrieves attributes without triggering dynamic lookup protocol.
# formatannotation formats a single annotation for display. isasyncgen tests
# whether an object is an asynchronous generator. New to extra155.
# ---------------------------------------------------------------------------

