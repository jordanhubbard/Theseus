spec: struct_extra58
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra57.zspec.zsdl — covers struct.__doc__.__class__.__name__.__eq__('str') / Struct.__doc__.__contains__('Struct') / Struct.__doc__.__contains__('fmt') / error.__doc__.__class__.__name__.__len__()==8 / pack.__doc__.__contains__('format') (table + invariants)."
    - "struct_extra56.zspec.zsdl — covers Struct.__init_subclass__/__subclasshook__/__getattribute__/__delattr__/__setattr__ __qualname__.__eq__ string values (table + invariants)."
    - "struct_extra55.zspec.zsdl — covers struct.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "struct_extra54.zspec.zsdl — covers struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra11.zspec.zsdl — covers struct.error.__module__.__eq__('struct') and Struct.__module__.__eq__('_struct') as standalone invariants; struct.error.__module__ is already covered and NOT duplicated here."
    - "struct_extra8.zspec.zsdl — covers function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra57; it does NOT duplicate invariants present in those files."
    - "Wave 229 theme: __defaults__ and __code__ checks for Python functions + __doc__ content checks."
    - "struct module-level functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) are all C builtin_function_or_method objects from _struct — they do NOT have __defaults__ or __code__ attributes. struct.Struct is a C extension type. The __defaults__/__code__ wave 229 theme therefore applies only to __doc__ content checks for struct."
    - "struct.__doc__.__contains__('struct') — the module docstring begins 'Functions to convert between Python values and C structs.' The word 'struct' appears in the very first sentence. struct_extra57 checks struct.__doc__.__class__.__name__.__eq__('str') (type identity, not content). No prior struct spec checks struct.__doc__.__contains__ for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__contains__('format') is False — the Struct C type docstring is 'Struct(fmt) --> compiled struct object\n\n'. The abbreviation 'fmt' is used, not the full word 'format'. struct_extra57 already checks __contains__('fmt') and __contains__('Struct'). This spec instead checks struct.__doc__.__contains__('struct') (the module docstring) and pack.__doc__.__class__.__name__.__eq__('str') (a new axis on pack's doc)."
    - "struct.pack.__doc__.__class__.__name__ == 'str' — pack is a C builtin_function_or_method with a string docstring. struct_extra57 checks pack.__doc__.__contains__('format') (content axis); no prior struct spec checks pack.__doc__.__class__.__name__.__eq__('str') (type identity axis on pack's docstring). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__.__class__.__name__.__eq__('NoneType') — struct.error.__doc__ is None; None.__class__.__name__ == 'NoneType'. struct_extra57 checks error.__doc__.__class__.__name__.__len__()==8 (length axis). No prior struct spec checks error.__doc__.__class__.__name__.__eq__('NoneType') (the eq string form). These are orthogonal checks on the same chain. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__contains__('format') — the unpack C function docstring begins 'Return a tuple containing values unpacked according to the format string.' The word 'format' appears in the first sentence. struct_extra57 checks pack.__doc__.__contains__('format') but NOT unpack. No prior struct spec checks unpack.__doc__.__contains__ for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module __doc__ content check
#
# Wave 229 theme: __doc__ content checks.
#
# struct.__doc__ is the module-level docstring. It begins 'Functions to convert
# between Python values and C structs.' The word 'struct' appears in the very
# first sentence. struct_extra57 checks struct.__doc__.__class__.__name__.__eq__('str')
# (type identity axis, not content). No prior struct spec checks
# struct.__doc__.__contains__ for any keyword. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra58.module_doc_contains:
  description: "struct.__doc__.__contains__('struct') — module docstring begins 'Functions to convert between Python values and C structs.'; 'struct' appears in the first sentence; struct_extra57 checks __doc__.__class__.__name__.__eq__('str') (type identity axis only); no prior struct spec checks struct.__doc__.__contains__ for any keyword; first module docstring content check for struct"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc58

  columns: [id, function, args, expected]
  rows:
    - [module_doc_contains_struct, __doc__.__contains__, ["struct"], true]

# ---------------------------------------------------------------------------
# struct.error.__doc__ class name string eq
#
# struct.error.__doc__ is None. None.__class__.__name__ == 'NoneType'. The eq
# form confirms the exact string value. struct_extra57 checks
# error.__doc__.__class__.__name__.__len__()==8 (the length axis: 'NoneType'
# has 8 chars). No prior struct spec checks the __eq__('NoneType') string form
# directly — the two checks are orthogonal. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra58.error_doc_class_name_eq:
  description: "struct.error.__doc__.__class__.__name__.__eq__('NoneType') — struct.error.__doc__ is None; None.__class__.__name__ == 'NoneType'; struct_extra57 checks error.__doc__.__class__.__name__.__len__()==8 (length axis); no prior struct spec checks the __eq__('NoneType') string form directly; orthogonal eq confirmation of the NoneType class name"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc58

  columns: [id, function, args, expected]
  rows:
    - [error_doc_class_name_nonetype_eq, "error.__doc__.__class__.__name__.__eq__", ["NoneType"], true]

# ---------------------------------------------------------------------------
# struct.pack __doc__ class identity (type axis)
#
# struct.pack is a C builtin_function_or_method from _struct. Its docstring is
# a Python str. struct_extra57 checks pack.__doc__.__contains__('format')
# (content axis). No prior struct spec checks pack.__doc__.__class__.__name__.__eq__('str')
# (the type identity axis on pack's docstring). These are orthogonal checks.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra58.pack_doc_class_name:
  description: "struct.pack.__doc__.__class__.__name__.__eq__('str') — pack is a C builtin_function_or_method with a string docstring; struct_extra57 checks pack.__doc__.__contains__('format') (content axis); no prior struct spec checks pack.__doc__.__class__.__name__.__eq__('str') (type identity axis); orthogonal type anchor for pack's docstring"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc58

  columns: [id, function, args, expected]
  rows:
    - [pack_doc_class_name_eq, pack.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# struct.unpack __doc__ content check
#
# struct.unpack is a C builtin_function_or_method. Its docstring begins
# 'Return a tuple containing values unpacked according to the format string.'
# The word 'format' appears in the first sentence. struct_extra57 checks
# pack.__doc__.__contains__('format') but NOT unpack. No prior struct spec
# checks unpack.__doc__.__contains__ for any keyword. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra58.unpack_doc_contains:
  description: "struct.unpack.__doc__.__contains__('format') — C builtin_function_or_method docstring begins 'Return a tuple containing values unpacked according to the format string.'; 'format' appears in the first sentence; struct_extra57 checks pack.__doc__.__contains__('format') but not unpack; no prior struct spec checks unpack.__doc__.__contains__ for any keyword; first doc content check for struct.unpack"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc58

  columns: [id, function, args, expected]
  rows:
    - [unpack_doc_contains_format, unpack.__doc__.__contains__, ["format"], true]

# ---------------------------------------------------------------------------
# struct.__doc__.__contains__('struct') — standalone
#
# The struct module docstring describes its purpose: 'Functions to convert
# between Python values and C structs.' The word 'struct' appears in the very
# first sentence, making this the most direct content anchor for the module
# docstring. struct_extra57 checks __doc__.__class__.__name__.__eq__('str')
# (type identity); no prior struct spec checks __doc__.__contains__ for any
# keyword at the module level. First module docstring content anchor for struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra58.module_doc_contains_struct:
  description: "struct.__doc__.__contains__('struct') == True — module docstring begins 'Functions to convert between Python values and C structs.'; 'struct' is the key domain term appearing in the first sentence; struct_extra57 checks __doc__.__class__.__name__.__eq__('str') (type identity only); no prior struct spec checks struct.__doc__.__contains__ for any keyword; first module docstring content anchor for struct"
  category: docstrings
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__doc__.__class__.__name__.__eq__('NoneType') — standalone
#
# struct.error.__doc__ is None. None.__class__.__name__ == 'NoneType'. The
# __eq__('NoneType') form confirms the exact string value of the type name.
# struct_extra57 established the length variant: __len__()==8 confirms 'NoneType'
# has 8 characters. This invariant provides the complementary eq-form check,
# confirming the string value directly. No prior struct spec checks
# error.__doc__.__class__.__name__.__eq__('NoneType'). Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra58.error_doc_class_name_nonetype_eq:
  description: "struct.error.__doc__.__class__.__name__.__eq__('NoneType') == True — struct.error.__doc__ is None; None.__class__.__name__ == 'NoneType'; struct_extra57 checks __len__()==8 (length axis); this invariant checks the __eq__ string form directly (orthogonal); no prior struct spec checks error.__doc__.__class__.__name__.__eq__('NoneType')"
  category: docstrings
  kind: python_call_eq
  function: "error.__doc__.__class__.__name__.__eq__"
  args: ["NoneType"]
  expected: true
