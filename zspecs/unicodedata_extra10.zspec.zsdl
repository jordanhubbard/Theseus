spec: unicodedata_extra10
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl through unicodedata_extra9.zspec.zsdl."
    - "unicodedata_extra (base extra) covers: __name__ value for all major functions; unidata_version.__class__.__name__; name('A'); category('A')."
    - "unicodedata_extra2 covers: __module__ for normalize/decomposition/bidirectional/east_asian_width/combining/category/lookup/name; unidata_version dot/length."
    - "unicodedata_extra3 covers: __module__ for decimal/numeric/digit/mirrored; ucd_3_2_0.__class__.__name__=='UCD'."
    - "unicodedata_extra4 covers: __name__ table for all major functions; category A/a/0; bidirectional A; combining A; east_asian_width A; mirrored '('."
    - "unicodedata_extra5 covers: lookup small-a/digit-five; decimal '5'; digit 0/7/9; numeric '9'; normalize NFKC/NFKD; category tab/plus; bidirectional space; combining U+0301; decomposition e-acute; ucd_3_2_0.category('A')."
    - "unicodedata_extra6 covers: name('Z'/'9'); lookup('EURO SIGN'); east_asian_width fullwidth; mirrored ')' and 'A'; decimal '1'/'7'; ucd_3_2_0.name('A')."
    - "unicodedata_extra7 covers: name('!'/' '); lookup('LATIN CAPITAL LETTER Z'/'DIGIT NINE'); bidirectional('!'/'1'); east_asian_width(' '/'!'); category('Z'/'z'); digit('1'); ucd_3_2_0.decimal('0')."
    - "unicodedata_extra8 covers: __module__ table for all major functions; unidata_version and ucd_3_2_0 class names."
    - "unicodedata_extra9 covers: __name__ attribute type checks; unidata_version len >= 5; category('{'/'@'); digit('A') raises ValueError; name('\\u00e9'); combining(' ')."
    - "Focus: mirrored('[') and ']' (bracket pair, both mirrored); mirrored('0') == 0 (digit not mirrored); lookup('LATIN SMALL LETTER E WITH ACUTE') == '\\u00e9' (inverse of name from extra9); decimal('3') and decimal('6') (new digit vectors); numeric('3') == 3.0; category(']') == 'Pe' (close punctuation); east_asian_width('0') == 'Na'; ucd_3_2_0.digit('9') == 9."
    - "unicodedata.mirrored('[') == 1 — left square bracket is a mirrored character. Prior specs cover '(' -> 1, ')' -> 1, 'A' -> 0."
    - "unicodedata.mirrored(']') == 1 — right square bracket is also mirrored. Not covered in any prior spec."
    - "unicodedata.mirrored('0') == 0 — digit zero is not mirrored. Prior specs cover 'A' -> 0; '0' is a new non-mirrored vector."
    - "unicodedata.lookup('LATIN SMALL LETTER E WITH ACUTE') == '\\u00e9' — inverse of extra9's name('\\u00e9'); lookup not yet covered for this character."
    - "unicodedata.decimal('3') == 3 — prior specs cover 0,1,5,7,9; '3' is new."
    - "unicodedata.decimal('6') == 6 — prior specs cover 0,1,5,7,9; '6' is new."
    - "unicodedata.numeric('3') == 3.0 — numeric for '3'; prior specs cover 5.0 and 9.0."
    - "unicodedata.category(']') == 'Pe' — right square bracket is close punctuation. Prior specs cover '{' -> 'Ps' (extra9) but not ']' -> 'Pe'."
    - "unicodedata.east_asian_width('0') == 'Na' — ASCII digit zero is narrow. Prior specs cover 'A', ' ', '!' -> 'Na' but not '0'."
    - "unicodedata.ucd_3_2_0.digit('9') == 9 — digit via legacy UCD object. Prior specs use ucd_3_2_0.category, name, decimal but not digit."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mirrored() — new character vectors
#
# unicodedata_extra4 covers: '(' -> 1.
# unicodedata_extra6 covers: ')' -> 1, 'A' -> 0.
# New: '[' -> 1, ']' -> 1 (square bracket pair, both mirrored), '0' -> 0 (digit).
# ---------------------------------------------------------------------------

table unicodedata_extra10.mirrored.new_vectors:
  kind: python_call_eq
  category: mirrored
  id_prefix: mirrored
  function: mirrored

  columns: [id, args, expected]
  rows:
    - [open_bracket,  ["["], 1]
    - [close_bracket, ["]"], 1]
    - [digit_zero,    ["0"], 0]

# ---------------------------------------------------------------------------
# lookup() — LATIN SMALL LETTER E WITH ACUTE
#
# unicodedata_extra9 covers name('\u00e9') == 'LATIN SMALL LETTER E WITH ACUTE'.
# The inverse (lookup('LATIN SMALL LETTER E WITH ACUTE') == '\u00e9') is not
# covered in any prior spec. This is a new direction for the same character.
# ---------------------------------------------------------------------------

invariant unicodedata_extra10.lookup.e_acute:
  description: "unicodedata.lookup('LATIN SMALL LETTER E WITH ACUTE') == '\\u00e9'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["LATIN SMALL LETTER E WITH ACUTE"]
  expected: "\u00e9"

# ---------------------------------------------------------------------------
# decimal() — new digit vectors
#
# Prior specs cover: '0'->0 (base), '1'->1 (extra6), '5'->5 (extra5), '7'->7 (extra6), '9'->9 (base).
# New: '3' -> 3 and '6' -> 6.
# ---------------------------------------------------------------------------

table unicodedata_extra10.decimal.new_vectors:
  kind: python_call_eq
  category: decimal
  id_prefix: decimal
  function: decimal

  columns: [id, args, expected]
  rows:
    - [three, ["3"], 3]
    - [six,   ["6"], 6]

# ---------------------------------------------------------------------------
# numeric() — new value vector
#
# Base spec covers: numeric('½') == 0.5, numeric('5') == 5.0.
# unicodedata_extra5 covers: numeric('9') == 9.0.
# unicodedata_extra7 covers: numeric('½') type check (returns float).
# New: numeric('3') == 3.0.
# ---------------------------------------------------------------------------

invariant unicodedata_extra10.numeric.three:
  description: "unicodedata.numeric('3') == 3.0 — digit three has numeric value 3.0"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["3"]
  expected: 3.0

# ---------------------------------------------------------------------------
# category() — close punctuation
#
# unicodedata_extra9 covers: '{' -> 'Ps' (open punctuation).
# New: ']' -> 'Pe' (close punctuation). Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant unicodedata_extra10.category.close_bracket:
  description: "unicodedata.category(']') == 'Pe' — right square bracket is close punctuation"
  category: category
  kind: python_call_eq
  function: category
  args: ["]"]
  expected: "Pe"

# ---------------------------------------------------------------------------
# east_asian_width() — ASCII digit zero
#
# Prior specs cover 'Na' for: 'A' (base/extra4), ' ' (extra7), '!' (extra7).
# New: '0' -> 'Na' (narrow). ASCII digits are narrow.
# ---------------------------------------------------------------------------

invariant unicodedata_extra10.east_asian_width.digit_zero:
  description: "unicodedata.east_asian_width('0') == 'Na' — ASCII digit zero is narrow"
  category: east_asian_width
  kind: python_call_eq
  function: east_asian_width
  args: ["0"]
  expected: "Na"

# ---------------------------------------------------------------------------
# ucd_3_2_0.digit() — digit value via legacy UCD object
#
# Prior specs use ucd_3_2_0 for: category('A') (extra5), name('A') (extra6),
# decimal('0') (extra7). No prior spec calls ucd_3_2_0.digit().
# '9' -> 9 is a well-known ASCII digit value.
# ---------------------------------------------------------------------------

invariant unicodedata_extra10.ucd_3_2_0.digit_nine:
  description: "unicodedata.ucd_3_2_0.digit('9') == 9 — digit via legacy UCD object"
  category: ucd_object
  kind: python_call_eq
  function: ucd_3_2_0.digit
  args: ["9"]
  expected: 9
