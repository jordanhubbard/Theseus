spec: abc_extra260
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc documentation"
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Lib/_collections_abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc is a frozen module on Python 3.14: __loader__ is the FrozenImporter class itself (not an instance)."
    - "Because abc.__loader__ is a class, abc.__loader__.__class__.__name__ == 'type'."
    - "abc.__package__ is '' (empty string) — frozen top-level modules have an empty package."
    - "abc.__spec__.name == 'abc'; abc.__spec__.__class__.__name__ == 'ModuleSpec'."
    - "abc has NO __all__ attribute on Python 3.14 (frozen module exposes public names without __all__)."
    - "ABC, ABCMeta, abstractmethod, get_cache_token are all present as top-level names in abc."
    - "ABCMeta inherits from type: ABCMeta.__bases__[0].__name__ == 'type'."
    - "get_cache_token is a C-level builtin: get_cache_token.__class__.__name__ == 'builtin_function_or_method'."
    - "collections.abc is a separate module backed by _collections_abc: __spec__.name == '_collections_abc'."
    - "collections.abc.__package__ is '' (empty string) — it is a submodule but reports empty package."
    - "collections.abc.__all__ is a list of 26 ABCs including Callable, Iterable, Sequence, Mapping, etc."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module identity — __name__, __package__, __spec__, __loader__
#
# abc is a frozen module. __loader__ is the FrozenImporter class object
# (not an instance), so __loader__.__class__.__name__ == 'type'.
# __package__ is '' (empty string) for top-level frozen modules.
# ---------------------------------------------------------------------------

invariant abc_extra260.identity.module_name:
  description: "abc.__name__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra260.identity.package:
  description: "abc.__package__ == '' — frozen top-level module has empty package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant abc_extra260.identity.spec_class:
  description: "abc.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra260.identity.spec_name:
  description: "abc.__spec__.name == 'abc'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra260.identity.loader_class:
  description: "abc.__loader__.__class__.__name__ == 'type' — FrozenImporter is a class, not an instance"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# abc public names — ABC, ABCMeta, abstractmethod, get_cache_token
#
# abc has no __all__; membership checks are done via class/function identity.
# ABCMeta.__bases__[0] is 'type' (ABCMeta is a metaclass derived from type).
# abstractmethod is a plain Python function.
# get_cache_token is a C-level builtin from the _abc extension module.
# ---------------------------------------------------------------------------

invariant abc_extra260.ABC.class_name:
  description: "abc.ABC.__name__ == 'ABC'"
  category: ABC
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra260.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: ABC
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra260.ABCMeta.class_name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'"
  category: ABCMeta
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra260.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: ABCMeta
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra260.ABCMeta.base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass inheriting from type"
  category: ABCMeta
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

invariant abc_extra260.abstractmethod.name:
  description: "abc.abstractmethod.__name__ == 'abstractmethod'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra260.abstractmethod.module:
  description: "abc.abstractmethod.__module__ == 'abc'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra260.get_cache_token.name:
  description: "abc.get_cache_token.__name__ == 'get_cache_token'"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra260.get_cache_token.class:
  description: "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C-level function from _abc"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc module identity
#
# collections.abc is backed by the _collections_abc implementation module.
# __spec__.name == '_collections_abc' (the canonical backing name).
# __package__ is '' (empty) and __name__ is 'collections.abc'.
# collections.abc.__all__ is a list of 26 ABC names.
# ---------------------------------------------------------------------------

invariant abc_extra260.collections_abc.module_name:
  description: "collections.abc.__name__ == 'collections.abc'"
  category: collections_abc
  kind: python_call_eq
  function: collections.abc.__name__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra260.collections_abc.package:
  description: "collections.abc.__package__ == '' — reports empty package"
  category: collections_abc
  kind: python_call_eq
  function: collections.abc.__package__.__eq__
  args: [""]
  expected: true

invariant abc_extra260.collections_abc.spec_name:
  description: "collections.abc.__spec__.name == '_collections_abc' — backed by the C implementation module"
  category: collections_abc
  kind: python_call_eq
  function: collections.abc.__spec__.name.__eq__
  args: ["_collections_abc"]
  expected: true
