spec: uuid_extra242
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra241.zspec.zsdl — covers uuid3/uuid5 function identity and deterministic UUID generation test vectors (table + invariants)."
    - "uuid_extra240.zspec.zsdl — covers uuid4/uuid1 generator function identity / uuid4()/uuid1() instance __class__.__name__/__module__ / UUID.__name__/__bases__[0].__name__ (table + invariants)."
  notes:
    - "Wave 295 theme: uuid.UUID class attribute descriptor identity — property descriptors and member_descriptor / dunder method identity."
    - "type(uuid.UUID.hex).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__name__ == 'hex'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.bytes).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__name__ == 'bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.bytes_le).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__name__ == 'bytes_le'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.fields).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__name__ == 'fields'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.time_low).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_low.fget.__name__ == 'time_low'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.version).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__name__ == 'version'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.variant).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__name__ == 'variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.int).__name__ == 'member_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__objclass__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__name__ == '__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__name__ == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID is a pure Python class (Lib/uuid.py). Most of its attributes are Python property descriptors — their __class__.__name__ is 'property' and they have an fget whose __name__ matches the attribute name. The exception is 'int', which is a member_descriptor (a slot defined with __slots__ = ('int', 'is_safe', '__weakref__')). member_descriptor objects have __objclass__ and __name__ but no fget."
    - "Note: uuid.UUID.__str__ and __repr__ are pure Python functions (__class__.__name__=='function'). __str__ returns the canonical UUID string form '6ba7b810-9dad-11d1-80b4-00c04fd430c8'; __repr__ returns UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8'). Both are defined in Lib/uuid.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID property descriptor identity: hex, bytes, bytes_le, fields,
# time_low, version, variant
#
# Wave 295 theme: uuid.UUID property descriptor __class__.__name__ and
# fget.__name__ for the major UUID attribute properties.
#
# uuid.UUID is a pure Python class. Its attributes hex, bytes, bytes_le,
# fields, time_low, version, and variant are Python property descriptors
# (__class__.__name__=='property'). Each property has an fget function whose
# __name__ matches the attribute name. The 'int' attribute differs — it is
# a member_descriptor (C slot). No prior spec anchors these property
# descriptor identities together in a grouped table under uuidattr295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra242.UUID_property_descriptor_identity:
  description: "UUID.hex.__class__.__name__.__eq__('property')==True / UUID.hex.fget.__name__.__eq__('hex')==True / UUID.bytes.__class__.__name__.__eq__('property')==True / UUID.bytes_le.__class__.__name__.__eq__('property')==True / UUID.fields.__class__.__name__.__eq__('property')==True / UUID.time_low.__class__.__name__.__eq__('property')==True / UUID.version.__class__.__name__.__eq__('property')==True / UUID.variant.__class__.__name__.__eq__('property')==True — all seven are Python property descriptors; fget.__name__ matches attribute name; 'int' is a member_descriptor (slot); pure Python class in Lib/uuid.py; first uuidattr295 anchor for UUID property descriptor identity"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: uuidattr295

  columns: [id, function, args, expected, description]
  rows:
    - [hex_class_eq,         "UUID.hex.__class__.__name__.__eq__",      ["property"],  true, "uuid.UUID.hex is a property descriptor (not a direct slot)"]
    - [hex_fget_name_eq,     "UUID.hex.fget.__name__.__eq__",           ["hex"],       true, "uuid.UUID.hex.fget.__name__ is 'hex' (getter function name matches attribute name)"]
    - [bytes_class_eq,       "UUID.bytes.__class__.__name__.__eq__",    ["property"],  true, "uuid.UUID.bytes is a property descriptor"]
    - [bytes_fget_name_eq,   "UUID.bytes.fget.__name__.__eq__",         ["bytes"],     true, "uuid.UUID.bytes.fget.__name__ is 'bytes'"]
    - [bytes_le_class_eq,    "UUID.bytes_le.__class__.__name__.__eq__", ["property"],  true, "uuid.UUID.bytes_le is a property descriptor (little-endian byte representation)"]
    - [bytes_le_fget_eq,     "UUID.bytes_le.fget.__name__.__eq__",      ["bytes_le"],  true, "uuid.UUID.bytes_le.fget.__name__ is 'bytes_le'"]
    - [fields_class_eq,      "UUID.fields.__class__.__name__.__eq__",   ["property"],  true, "uuid.UUID.fields is a property descriptor (returns 6-tuple of UUID fields)"]
    - [version_class_eq,     "UUID.version.__class__.__name__.__eq__",  ["property"],  true, "uuid.UUID.version is a property descriptor (returns int 1–5 or None)"]
    - [variant_class_eq,     "UUID.variant.__class__.__name__.__eq__",  ["property"],  true, "uuid.UUID.variant is a property descriptor (returns RFC_4122, RESERVED_NCS, etc.)"]

# ---------------------------------------------------------------------------
# UUID.int member_descriptor identity and UUID dunder method identity
#
# Wave 295 theme: uuid.UUID.int member_descriptor / __str__ / __repr__ identity.
#
# uuid.UUID.int is a member_descriptor (C slot via __slots__). Unlike the
# property descriptors above, it has no fget; instead it has __name__ and
# __objclass__. uuid.UUID.__str__ and __repr__ are pure Python functions
# (__class__.__name__=='function') defined in Lib/uuid.py. __str__ returns the
# canonical hyphenated UUID string; __repr__ wraps it in UUID(...). No prior
# spec anchors UUID.int member_descriptor identity or __str__/__repr__ identity
# together in a grouped table under uuidattr295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra242.UUID_int_slot_and_dunder_identity:
  description: "UUID.int.__class__.__name__.__eq__('member_descriptor')==True / UUID.int.__name__.__eq__('int')==True / UUID.int.__objclass__.__name__.__eq__('UUID')==True / UUID.__str__.__name__.__eq__('__str__')==True / UUID.__str__.__class__.__name__.__eq__('function')==True / UUID.__repr__.__name__.__eq__('__repr__')==True / UUID.__repr__.__class__.__name__.__eq__('function')==True — UUID.int is a __slots__ member_descriptor (not a property); __str__/__repr__ are pure Python functions; first uuidattr295 anchor for int member_descriptor and dunder method identity"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: uuidattr295

  columns: [id, function, args, expected, description]
  rows:
    - [int_class_eq,         "UUID.int.__class__.__name__.__eq__",       ["member_descriptor"], true, "uuid.UUID.int.__class__.__name__ is 'member_descriptor' (C slot, not a Python property)"]
    - [int_name_eq,          "UUID.int.__name__.__eq__",                 ["int"],               true, "uuid.UUID.int.__name__ is 'int' (the slot name for the 128-bit integer value)"]
    - [int_objclass_eq,      "UUID.int.__objclass__.__name__.__eq__",    ["UUID"],              true, "uuid.UUID.int.__objclass__.__name__ is 'UUID' (the class that owns this slot)"]
    - [str_name_eq,          "UUID.__str__.__name__.__eq__",             ["__str__"],           true, "uuid.UUID.__str__.__name__ is '__str__' (returns canonical hyphenated UUID string)"]
    - [str_class_eq,         "UUID.__str__.__class__.__name__.__eq__",   ["function"],          true, "uuid.UUID.__str__.__class__.__name__ is 'function' (pure Python, not C builtin)"]
    - [repr_name_eq,         "UUID.__repr__.__name__.__eq__",            ["__repr__"],          true, "uuid.UUID.__repr__.__name__ is '__repr__' (returns UUID('...') repr form)"]
    - [repr_class_eq,        "UUID.__repr__.__class__.__name__.__eq__",  ["function"],          true, "uuid.UUID.__repr__.__class__.__name__ is 'function' (pure Python, not C builtin)"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property') — standalone
#
# uuid.UUID.hex is a Python property descriptor. The hex attribute returns the
# UUID as a 32-character lowercase hexadecimal string without hyphens (e.g.
# '6ba7b8109dad11d180b400c04fd430c8'). It is one of the key representations
# exposed by the UUID class alongside str() (hyphenated), bytes (big-endian
# bytes), bytes_le (little-endian bytes), int (128-bit integer), and fields
# (6-tuple). Its getter is a Python function defined in Lib/uuid.py.
# No prior spec anchors UUID.hex.__class__.__name__ as a standalone under
# uuidattr295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra242.UUID_hex_property_class_eq:
  description: "uuid.UUID.hex.__class__.__name__.__eq__('property') == True — UUID.hex is a Python property returning the 32-char lowercase hex string without hyphens; pure Python getter in Lib/uuid.py; fget.__name__=='hex'; contrasts with UUID.int which is a member_descriptor (slot); property descriptor pattern shared by hex/bytes/bytes_le/fields/time_low/version/variant; no prior spec anchors this as standalone; first standalone under uuidattr295"
  category: descriptor_identity
  kind: python_call_eq
  function: "UUID.hex.__class__.__name__.__eq__"
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') — standalone
#
# uuid.UUID.int is a member_descriptor, not a property. The UUID class uses
# __slots__ = ('int', 'is_safe', '__weakref__'). The 'int' slot stores the
# 128-bit integer representation of the UUID. Because it is a slot, accessing
# uuid_obj.int on an instance reads directly from the object's memory layout
# without going through a Python property getter — this is faster than a
# property. member_descriptor objects have __name__ and __objclass__ but no
# fget. No prior spec anchors UUID.int.__class__.__name__ as a standalone
# under uuidattr295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra242.UUID_int_member_descriptor_class_eq:
  description: "uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') == True — UUID.int is a __slots__ slot (not a property); stores the 128-bit integer UUID value; member_descriptor has __name__ and __objclass__ but no fget; slot access is faster than property; contrasts with UUID.hex/bytes/fields/version which are property descriptors; no prior spec anchors UUID.int member_descriptor class as standalone; first standalone under uuidattr295"
  category: descriptor_identity
  kind: python_call_eq
  function: "UUID.int.__class__.__name__.__eq__"
  args: ["member_descriptor"]
  expected: true
