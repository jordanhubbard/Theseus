spec: asyncio_extra219
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Futures documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "asyncio.Task.__module__ == '_asyncio' on CPython 3.14 — the C accelerator provides Task."
    - "asyncio.Future.__module__ == '_asyncio' on CPython 3.14 — the C accelerator provides Future."
    - "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits directly from Future."
    - "asyncio.Future.__bases__[0].__name__ == 'object' — Future is a top-level class."
    - "asyncio.Handle.__module__ == 'asyncio.events' — Handle is pure-Python in CPython 3.14."
    - "asyncio.AbstractEventLoop.__module__ == 'asyncio.events' — pure-Python abstract base."
    - "asyncio.get_event_loop.__module__ == '_asyncio' — provided by the C accelerator."
    - "asyncio.sleep.__module__ == 'asyncio.tasks' — pure-Python coroutine in CPython 3.14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task class identity — extra219 namespace
# ---------------------------------------------------------------------------

table asyncio_extra219.task_class_identity:
  description: "asyncio.Task class __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: aio219taskident

  columns: [id, function, args, expected, description]
  rows:
    - [task_name,   Task.__name__.__eq__,   ["Task"],     true, "asyncio.Task.__name__ == 'Task'"]
    - [task_module, Task.__module__.__eq__, ["_asyncio"], true, "asyncio.Task.__module__ == '_asyncio' (C accelerator)"]

# ---------------------------------------------------------------------------
# asyncio.Task.__bases__ — extra219 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra219.task_base_name:
  description: "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits directly from Future"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Future class identity — extra219 namespace
# ---------------------------------------------------------------------------

table asyncio_extra219.future_class_identity:
  description: "asyncio.Future class __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: aio219futident

  columns: [id, function, args, expected, description]
  rows:
    - [future_name,   Future.__name__.__eq__,   ["Future"],   true, "asyncio.Future.__name__ == 'Future'"]
    - [future_module, Future.__module__.__eq__, ["_asyncio"], true, "asyncio.Future.__module__ == '_asyncio' (C accelerator)"]

# ---------------------------------------------------------------------------
# asyncio.Future.__bases__ — extra219 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra219.future_base_name:
  description: "asyncio.Future.__bases__[0].__name__ == 'object' — Future inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Handle class identity — extra219 namespace
# ---------------------------------------------------------------------------

table asyncio_extra219.handle_class_identity:
  description: "asyncio.Handle class __name__, __module__, and base class checks"
  kind: python_call_eq
  category: identity
  id_prefix: aio219handleident

  columns: [id, function, args, expected, description]
  rows:
    - [handle_name,   Handle.__name__.__eq__,   ["Handle"],         true, "asyncio.Handle.__name__ == 'Handle'"]
    - [handle_module, Handle.__module__.__eq__, ["asyncio.events"], true, "asyncio.Handle.__module__ == 'asyncio.events'"]

invariant asyncio_extra219.handle_base_name:
  description: "asyncio.Handle.__bases__[0].__name__ == 'object' — Handle inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.Handle.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

