# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra135.Match.name_is_Match:
  description: "re.Match.__name__ == 'Match' (length 5) — the short class name without the module prefix; re.Match.__name__ is 'Match', not 're.Match'"
  category: class_identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra135.Pattern.name_is_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' (length 7) — the short class name without the module prefix; re.Pattern.__name__ is 'Pattern', not 're.Pattern'"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra135.Match.mro_len_2:
  description: "re.Match.__mro__.__len__() == 2 (MRO is [Match, object]; Match has no intermediate C base between itself and object)"
  category: class_identity
  kind: python_call_eq
  function: Match.__mro__.__len__
  args: []
  expected: 2

invariant re_extra135.Pattern.module_is_re:
  description: "re.Pattern.__module__ == 're' (length 2) — Pattern is attributed to the re module, not to _sre (the C implementation module)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra135.Pattern.fullmatch_qualname_len_17:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' is 17 chars: 'Pattern' (7) + '.' (1) + 'fullmatch' (9))"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

