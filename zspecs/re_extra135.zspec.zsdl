spec: re_extra135
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Match and re.Pattern class identity (__name__, __module__, __qualname__, __mro__.__len__()) and method descriptor __qualname__ strings and lengths."
    - "re.Match.__name__ == 'Match' (length 5) — the short name, not 're.Match'."
    - "re.Match.__module__ == 're' (length 2) — Match is attributed to the re module (not _sre)."
    - "re.Match.__qualname__ == 'Match' (length 5)."
    - "re.Match.__mro__.__len__() == 2 — MRO is [Match, object]; Match has no intermediate base."
    - "re.Pattern.__name__ == 'Pattern' (length 7)."
    - "re.Pattern.__module__ == 're' (length 2)."
    - "re.Pattern.__qualname__ == 'Pattern' (length 7)."
    - "re.Pattern.__mro__.__len__() == 2 — MRO is [Pattern, object]."
    - "re.Match.group.__qualname__ == 'Match.group' (length 11) — method_descriptor."
    - "re.Match.groups.__qualname__ == 'Match.groups' (length 12) — method_descriptor."
    - "re.Match.start.__qualname__ == 'Match.start' (length 11) — method_descriptor."
    - "re.Match.end.__qualname__ == 'Match.end' (length 9) — method_descriptor."
    - "re.Match.span.__qualname__ == 'Match.span' (length 10) — method_descriptor."
    - "re.Match.groupdict.__qualname__ == 'Match.groupdict' (length 15) — method_descriptor."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' (length 13) — method_descriptor."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' (length 14) — method_descriptor."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' (length 15) — method_descriptor."
    - "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' (length 16) — method_descriptor."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' (length 11) — method_descriptor."
    - "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (length 17) — method_descriptor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

