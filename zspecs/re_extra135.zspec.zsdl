    - [match_name_len,     Match.__name__.__len__,    [],         5]
    - [match_module_eq,    Match.__module__.__eq__,   ["re"],     true]
    - [match_module_len,   Match.__module__.__len__,  [],         2]
    - [match_qualname_eq,  Match.__qualname__.__eq__, ["Match"],  true]
    - [match_qualname_len, Match.__qualname__.__len__, [],        5]
    - [match_mro_len,      Match.__mro__.__len__,     [],         2]
    - [match_name_not_re,  Match.__name__.__eq__,     ["re.Match"], false]
    - [match_name_not_pat, Match.__name__.__eq__,     ["Pattern"], false]

