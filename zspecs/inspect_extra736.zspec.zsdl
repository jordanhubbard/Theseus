spec: inspect_extra736
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers inspect.Parameter kind constants and signature class identity"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra736.parameter_kind_constants:
  description: "Class name checks for inspect.Parameter kind constants"
  kind: python_call_eq
  category: identity
  id_prefix: in736pk
  columns: [id, function, args, expected]
  rows:
    - [in736pk001, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [in736pk002, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [in736pk003, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [in736pk004, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [in736pk005, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true]

table inspect_extra736.sentinel_identity:
  description: "Class name checks for inspect sentinel empty values"
  kind: python_call_eq
  category: identity
  id_prefix: in736se
  columns: [id, function, args, expected]
  rows:
    - [in736se001, inspect.Parameter.empty.__class__.__name__.__eq__, ["_empty"], true]
    - [in736se002, inspect.Signature.empty.__class__.__name__.__eq__, ["_empty"], true]

table inspect_extra736.class_qualname_identity:
  description: "Qualname and module identity for inspect signature classes"
  kind: python_call_eq
  category: identity
  id_prefix: in736cq
  columns: [id, function, args, expected]
  rows:
    - [in736cq001, inspect.Parameter.__qualname__.__eq__, ["Parameter"], true]
    - [in736cq002, inspect.Signature.__qualname__.__eq__, ["Signature"], true]
    - [in736cq003, inspect.BoundArguments.__qualname__.__eq__, ["BoundArguments"], true]
    - [in736cq004, inspect.Parameter.__module__.__eq__, ["inspect"], true]
    - [in736cq005, inspect.Signature.__module__.__eq__, ["inspect"], true]
