spec: inspect_extra99
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra98

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra98.zspec.zsdl."
    - "This spec covers: inspect.FullArgSpec namedtuple class identity and MRO; inspect.BoundArguments class identity; inspect.Signature class identity; inspect.ArgInfo class identity; inspect namedtuple __fields__ length (Wave 256)."
    - "inspect.FullArgSpec.__class__.__name__ == 'type' — FullArgSpec is a namedtuple, and namedtuples are types. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec inherits from tuple (as all namedtuples do). Verified with Python 3.14.3."
    - "len(inspect.FullArgSpec.__mro__) == 3 — MRO is [FullArgSpec, tuple, object]. Verified with Python 3.14.3."
    - "len(inspect.FullArgSpec._fields) == 7 — fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "len(inspect.BoundArguments.__mro__) == 2. Verified with Python 3.14.3."
    - "inspect.Signature.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "len(inspect.Signature.__mro__) == 2. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__class__.__name__ == 'type' — ArgInfo is also a namedtuple. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__bases__[0].__name__ == 'tuple'. Verified with Python 3.14.3."
    - "len(inspect.ArgInfo.__mro__) == 3 — MRO is [ArgInfo, tuple, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FullArgSpec namedtuple class identity and MRO
#
# Wave 256 theme: inspect.FullArgSpec namedtuple class identity.
#
# inspect.FullArgSpec.__class__.__name__ == 'type'
# inspect.FullArgSpec.__module__ == 'inspect'
# inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'
# len(inspect.FullArgSpec.__mro__) == 3
# len(inspect.FullArgSpec._fields) == 7
# inspect.FullArgSpec.__qualname__ == 'FullArgSpec'
#
# FullArgSpec is a namedtuple created with collections.namedtuple; its class
# is of type 'type'; it inherits from tuple; MRO is [FullArgSpec, tuple, object].
# New to extra99.
# ---------------------------------------------------------------------------

table inspect_extra99.fullargspec_identity:
  description: "inspect.FullArgSpec namedtuple class identity: __class__.__name__=='type', __module__=='inspect', __bases__[0].__name__=='tuple', MRO len==3, _fields len==7; wave 256; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfullarg99

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_class_name_eq_type,
       "FullArgSpec.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.FullArgSpec.__class__.__name__.__eq__('type') == True — FullArgSpec is a namedtuple created via collections.namedtuple('FullArgSpec', ...); namedtuples are classes whose metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [fullargspec_module_eq_inspect,
       "FullArgSpec.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in Lib/inspect.py; the namedtuple factory sets __module__ on the created type; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra99"]
    - [fullargspec_bases_first_eq_tuple,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — all namedtuples are subclasses of tuple; FullArgSpec's __bases__[0] is the built-in tuple class; __name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra99"]
    - [fullargspec_mro_len_eq_3,
       "FullArgSpec.__mro__.__len__",
       [],
       3,
       "inspect.FullArgSpec.__mro__.__len__() == 3 — the MRO of FullArgSpec is [FullArgSpec, tuple, object]; as a namedtuple (tuple subclass) it has exactly three entries in the MRO; len(__mro__) is 3; new to extra99"]
    - [fullargspec_fields_len_eq_7,
       "FullArgSpec._fields.__len__",
       [],
       7,
       "inspect.FullArgSpec._fields.__len__() == 7 — FullArgSpec is a namedtuple with 7 fields: 'args', 'varargs', 'varkw', 'defaults', 'kwonlyargs', 'kwonlydefaults', 'annotations'; _fields is a tuple of these field names; len(_fields) is 7; new to extra99"]
    - [fullargspec_qualname_eq,
       "FullArgSpec.__qualname__.__eq__",
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__qualname__.__eq__('FullArgSpec') == True — FullArgSpec is defined at module scope in Lib/inspect.py; the namedtuple factory sets __qualname__ to the simple class name; str.__eq__('FullArgSpec') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments and Signature class identity
#
# Wave 256 theme: inspect.BoundArguments and Signature class identity.
#
# inspect.BoundArguments.__class__.__name__ == 'type'
# inspect.BoundArguments.__module__ == 'inspect'
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
# len(inspect.BoundArguments.__mro__) == 2
# inspect.Signature.__class__.__name__ == 'type'
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__bases__[0].__name__ == 'object'
# len(inspect.Signature.__mro__) == 2
#
# BoundArguments and Signature are plain Python classes (not namedtuples);
# they inherit directly from object; MRO length is 2. New to extra99.
# ---------------------------------------------------------------------------

table inspect_extra99.boundarguments_signature_identity:
  description: "inspect.BoundArguments and Signature class identity: __class__.__name__=='type', __module__=='inspect', __bases__[0]=='object', MRO len==2; wave 256; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfullarg99

  columns: [id, function, args, expected, description]
  rows:
    - [boundarguments_class_name_eq_type,
       "BoundArguments.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments is a Python class defined with 'class BoundArguments:' in Lib/inspect.py; it holds the result of binding arguments to a Signature; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [boundarguments_module_eq_inspect,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra99"]
    - [boundarguments_bases_first_eq_object,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments inherits only from object with no intermediate base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra99"]
    - [boundarguments_mro_len_eq_2,
       "BoundArguments.__mro__.__len__",
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — BoundArguments inherits directly from object; MRO is [BoundArguments, object]; len(__mro__) is 2; new to extra99"]
    - [signature_class_name_eq_type,
       "Signature.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — Signature is a Python class defined in Lib/inspect.py; it represents the call signature of a callable; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [signature_module_eq_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra99"]
    - [signature_bases_first_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra99"]
    - [signature_mro_len_eq_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature inherits directly from object; MRO is [Signature, object]; len(__mro__) is 2; new to extra99"]

# ---------------------------------------------------------------------------
# Table 3: inspect.ArgInfo namedtuple class identity
#
# Wave 256 theme: inspect.ArgInfo namedtuple class identity.
#
# inspect.ArgInfo.__class__.__name__ == 'type'
# inspect.ArgInfo.__module__ == 'inspect'
# inspect.ArgInfo.__bases__[0].__name__ == 'tuple'
# len(inspect.ArgInfo.__mro__) == 3
# inspect.ArgInfo.__qualname__ == 'ArgInfo'
#
# ArgInfo is a namedtuple used to return results from inspect.getargvalues.
# Like all namedtuples it inherits from tuple; MRO length is 3. New to extra99.
# ---------------------------------------------------------------------------

table inspect_extra99.arginfo_identity:
  description: "inspect.ArgInfo namedtuple class identity: __class__.__name__=='type', __module__=='inspect', __bases__[0]=='tuple', MRO len==3, __qualname__=='ArgInfo'; wave 256; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfullarg99

  columns: [id, function, args, expected, description]
  rows:
    - [arginfo_class_name_eq_type,
       "ArgInfo.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.ArgInfo.__class__.__name__.__eq__('type') == True — ArgInfo is a namedtuple created by inspect to represent the result of getargvalues(); namedtuples are types whose metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [arginfo_module_eq_inspect,
       "ArgInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo is defined in Lib/inspect.py; the namedtuple factory sets __module__; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra99"]
    - [arginfo_bases_first_eq_tuple,
       "ArgInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — ArgInfo is a namedtuple and therefore a subclass of tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra99"]
    - [arginfo_mro_len_eq_3,
       "ArgInfo.__mro__.__len__",
       [],
       3,
       "inspect.ArgInfo.__mro__.__len__() == 3 — MRO of ArgInfo is [ArgInfo, tuple, object]; as a namedtuple subclass of tuple it has exactly 3 MRO entries; len(__mro__) is 3; new to extra99"]
    - [arginfo_qualname_eq,
       "ArgInfo.__qualname__.__eq__",
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__qualname__.__eq__('ArgInfo') == True — ArgInfo is defined at module scope; the namedtuple factory sets __qualname__ to the simple type name 'ArgInfo'; str.__eq__('ArgInfo') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra99
# ---------------------------------------------------------------------------

invariant inspect_extra99.fullargspec_bases_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple, inheriting from tuple; wave 256; new to extra99"
  kind: python_call_eq
  function: FullArgSpec.__bases__[0].__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra99.fullargspec_mro_len:
  description: "len(inspect.FullArgSpec.__mro__) == 3 — MRO is [FullArgSpec, tuple, object]; wave 256; new to extra99"
  kind: python_call_eq
  function: FullArgSpec.__mro__.__len__
  args: []
  expected: 3

invariant inspect_extra99.boundarguments_mro_len:
  description: "len(inspect.BoundArguments.__mro__) == 2 — BoundArguments inherits only from object; wave 256; new to extra99"
  kind: python_call_eq
  function: BoundArguments.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra99.signature_module:
  description: "inspect.Signature.__module__ == 'inspect' — Signature class defined in Lib/inspect.py; wave 256; new to extra99"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra99.arginfo_bases_tuple:
  description: "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a namedtuple subclassing tuple; wave 256; new to extra99"
  kind: python_call_eq
  function: ArgInfo.__bases__[0].__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra99.fullargspec_fields_len:
  description: "len(inspect.FullArgSpec._fields) == 7 — fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations; wave 256; new to extra99"
  kind: python_call_eq
  function: FullArgSpec._fields.__len__
  args: []
  expected: 7
