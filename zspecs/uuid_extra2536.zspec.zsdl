spec: uuid_extra2536
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec focuses on __format__, __bytes__, and __fspath__ dict-presence for uuid.UUID."
    - "uuid_extra.zspec.zsdl covers: UUID class name/module; function names; uuid4() type and version; NAMESPACE_* class names; UUID instance .int and .hex types."
    - "uuid_extra161.zspec.zsdl and uuid_extra180.zspec.zsdl cover other uuid invariants — this spec is distinct."
    - "uuid.UUID does NOT define __format__ in its __dict__ — format() falls back to object.__format__."
    - "uuid.UUID does NOT define __bytes__ in its __dict__ — even though UUID has a .bytes property, there is no __bytes__ dunder."
    - "uuid.UUID does NOT define __fspath__ in its __dict__ — UUIDs are not filesystem paths."
    - "uuid.UUID.__dict__ DOES contain: __init__, __eq__, __hash__, __str__, __repr__, __int__, __lt__, __gt__, __setattr__, plus property descriptors for bytes, hex, int, version, etc."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID class __dict__ presence: __format__ absent
# ---------------------------------------------------------------------------

table uuid_extra2536.UUID.format_absent:
  description: "uuid.UUID.__dict__ does NOT contain __format__ — no custom formatting protocol"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2536

  columns: [id, function, args, expected]
  rows:
    - ["uu2536-fmt-absent", uuid.UUID.__dict__.__contains__, ["__format__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID class __dict__ presence: __bytes__ absent
# ---------------------------------------------------------------------------

table uuid_extra2536.UUID.bytes_absent:
  description: "uuid.UUID.__dict__ does NOT contain __bytes__ — .bytes is a property, not a dunder"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2536

  columns: [id, function, args, expected]
  rows:
    - ["uu2536-bytes-absent", uuid.UUID.__dict__.__contains__, ["__bytes__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID class __dict__ presence: __fspath__ absent
# ---------------------------------------------------------------------------

table uuid_extra2536.UUID.fspath_absent:
  description: "uuid.UUID.__dict__ does NOT contain __fspath__ — UUIDs are not filesystem paths"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2536

  columns: [id, function, args, expected]
  rows:
    - ["uu2536-fspath-absent", uuid.UUID.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID class __dict__ presence: members that ARE present (positive control)
# These confirm __dict__.__contains__ works correctly for uuid.UUID.
# ---------------------------------------------------------------------------

table uuid_extra2536.UUID.dict_present:
  description: "uuid.UUID.__dict__ DOES contain these members (positive-control checks)"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2536

  columns: [id, function, args, expected]
  rows:
    - ["uu2536-init-present",     uuid.UUID.__dict__.__contains__, ["__init__"],     true]
    - ["uu2536-eq-present",       uuid.UUID.__dict__.__contains__, ["__eq__"],       true]
    - ["uu2536-hash-present",     uuid.UUID.__dict__.__contains__, ["__hash__"],     true]
    - ["uu2536-str-present",      uuid.UUID.__dict__.__contains__, ["__str__"],      true]
    - ["uu2536-repr-present",     uuid.UUID.__dict__.__contains__, ["__repr__"],     true]
    - ["uu2536-int-present",      uuid.UUID.__dict__.__contains__, ["__int__"],      true]
    - ["uu2536-setattr-present",  uuid.UUID.__dict__.__contains__, ["__setattr__"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID class __dict__ presence: all three protocols absent in one table
# Consolidates the three absent checks for compact cross-reference.
# ---------------------------------------------------------------------------

table uuid_extra2536.UUID.protocol_dunders_absent:
  description: "uuid.UUID.__dict__ contains none of __format__, __bytes__, __fspath__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2536

  columns: [id, function, args, expected]
  rows:
    - ["uu2536-p1-fmt",    uuid.UUID.__dict__.__contains__, ["__format__"], false]
    - ["uu2536-p1-bytes",  uuid.UUID.__dict__.__contains__, ["__bytes__"],  false]
    - ["uu2536-p1-fspath", uuid.UUID.__dict__.__contains__, ["__fspath__"], false]
