spec: struct_extra1876
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "struct module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party struct libraries"
  notes:
    - "Tests attribute access protocol membership in struct.Struct and struct.error"
    - "struct.Struct is a C extension type; __getattr__/__setattr__/__delattr__/__slots__ are not defined at the Python class level"
    - "struct.error is a subclass of Exception with no custom attribute protocol overrides"
    - "Buffer protocol methods (pack, unpack, pack_into, etc.) verified present in Struct dict"
  created_at: "2026-04-12"

table struct_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1876-aa-001", "struct.Struct.__dict__.__contains__", ["__getattr__"], false]
    - ["st1876-aa-002", "struct.Struct.__dict__.__contains__", ["__setattr__"], false]
    - ["st1876-aa-003", "struct.Struct.__dict__.__contains__", ["__delattr__"], false]
    - ["st1876-aa-004", "struct.Struct.__dict__.__contains__", ["__getattribute__"], false]
    - ["st1876-aa-005", "struct.error.__dict__.__contains__", ["__getattr__"], false]
    - ["st1876-aa-006", "struct.error.__dict__.__contains__", ["__setattr__"], false]
    - ["st1876-aa-007", "struct.__dict__.__contains__", ["__getattr__"], false]
    - ["st1876-aa-008", "struct.__dict__.__contains__", ["__setattr__"], false]

table struct_extra1876.introspection_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1876-ip-001", "struct.Struct.__dict__.__contains__", ["__dir__"], false]
    - ["st1876-ip-002", "struct.Struct.__dict__.__contains__", ["__sizeof__"], false]
    - ["st1876-ip-003", "struct.error.__dict__.__contains__", ["__dir__"], false]
    - ["st1876-ip-004", "struct.error.__dict__.__contains__", ["__sizeof__"], false]
    - ["st1876-ip-005", "struct.Struct.__dict__.__contains__", ["__slots__"], false]
    - ["st1876-ip-006", "struct.Struct.__dict__.__contains__", ["__dict__"], false]
    - ["st1876-ip-007", "struct.error.__dict__.__contains__", ["__slots__"], false]
    - ["st1876-ip-008", "struct.__dict__.__contains__", ["__slots__"], false]

table struct_extra1876.struct_buffer_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1876-bp-001", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st1876-bp-002", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st1876-bp-003", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st1876-bp-004", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1876-bp-005", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1876-bp-006", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st1876-bp-007", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st1876-bp-008", "struct.__dict__.__contains__", ["calcsize"], true]
    - ["st1876-bp-009", "struct.__dict__.__contains__", ["pack"], true]
    - ["st1876-bp-010", "struct.__dict__.__contains__", ["unpack"], true]
