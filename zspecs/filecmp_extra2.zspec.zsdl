spec: filecmp_extra2
version: ">=3.4"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/filecmp.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/filecmp.py"
    - "filecmp.zspec.zsdl — covers cmp() behavior, cmpfiles() structure, dircmp construction"
    - "filecmp_extra.zspec.zsdl — covers dircmp base class, dircmp.__module__, dircmp.__class__.__name__, DEFAULT_IGNORES VCS entries and length, cmpfiles/clear_cache module, dircmp.hide, cmpfiles/cmp class names"
  notes:
    - "This spec covers function __name__ checks for cmp, cmpfiles, and dircmp, plus DEFAULT_IGNORES type and dircmp class hierarchy."
    - "filecmp.cmp.__name__ == 'cmp' — verified on Python 3.12; cmp is a plain function in filecmp."
    - "filecmp.cmpfiles.__name__ == 'cmpfiles' — verified on Python 3.12."
    - "filecmp.dircmp.__name__ == 'dircmp' — dircmp is a class defined in filecmp."
    - "filecmp.DEFAULT_IGNORES is a list of filenames ignored by dircmp by default."
    - "filecmp.dircmp.__module__ == 'filecmp' — dircmp is defined in the filecmp module."
    - "filecmp.dircmp.__bases__[0].__name__ == 'object' — dircmp inherits directly from object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — cmp and cmpfiles
# ---------------------------------------------------------------------------

invariant filecmp_extra2.cmp.name:
  description: "filecmp.cmp.__name__ == 'cmp'"
  category: functions
  kind: python_call_eq
  function: cmp.__name__.__eq__
  args: ["cmp"]
  expected: true

invariant filecmp_extra2.cmpfiles.name:
  description: "filecmp.cmpfiles.__name__ == 'cmpfiles'"
  category: functions
  kind: python_call_eq
  function: cmpfiles.__name__.__eq__
  args: ["cmpfiles"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ check — dircmp
# ---------------------------------------------------------------------------

invariant filecmp_extra2.dircmp.name:
  description: "filecmp.dircmp.__name__ == 'dircmp'"
  category: classnames
  kind: python_call_eq
  function: dircmp.__name__.__eq__
  args: ["dircmp"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_IGNORES — class type is list
# ---------------------------------------------------------------------------

invariant filecmp_extra2.DEFAULT_IGNORES.class_name:
  description: "filecmp.DEFAULT_IGNORES.__class__.__name__ == 'list'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_IGNORES.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# dircmp — module membership and base class
# ---------------------------------------------------------------------------

invariant filecmp_extra2.dircmp.module:
  description: "filecmp.dircmp.__module__ == 'filecmp'"
  category: modules
  kind: python_call_eq
  function: dircmp.__module__.__eq__
  args: ["filecmp"]
  expected: true

invariant filecmp_extra2.dircmp.base_is_object:
  description: "filecmp.dircmp.__bases__[0].__name__ == 'object' — dircmp inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: dircmp.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"
