invariant pipdeptree_rust.has_models:
  description: "pipdeptree.models is importable"
  category: presence
  kind: python_call_eq
  function: pipdeptree_has_models
  args: []
  expected: true

invariant pipdeptree_rust.version_nonempty:
  description: "pipdeptree.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pipdeptree_version_nonempty
  args: []
  expected: true

