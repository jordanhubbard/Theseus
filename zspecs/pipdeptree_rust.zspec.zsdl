    - "https://github.com/tox-dev/pipdeptree — pipdeptree"
  notes:
    - "pipdeptree displays dependency trees."
    - "pipdeptree.__version__ is non-empty."
    - "pipdeptree has main module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pipdeptree_rust.has_main:
  description: "pipdeptree.main is importable"
  category: presence
