    - [ab1426dr002, abc.ABC.__dir__.__class__.__name__.__eq__,            ["method_descriptor"],         true]
    - [ab1426dr003, abc.abstractmethod.__dir__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
