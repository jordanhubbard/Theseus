spec: abc_extra1426
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc: Abstract Base Classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for abc module classes."
    - "abc.ABCMeta and abc.ABC have __format__ with type 'method_descriptor' (inherited from object/type hierarchy)."
    - "abc.abstractmethod (a function decorator, not a class) has __format__ with type 'builtin_function_or_method'."
    - "abc.ABCMeta and abc.ABC have __dir__ with type 'method_descriptor'."
    - "abc.abstractmethod has __dir__ with type 'builtin_function_or_method'."
    - "None of ABCMeta, ABC, or abstractmethod define __format__ or __dir__ in their own __dict__."
    - "abc.ABCMeta.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in abc.ABCMeta.__dict__."
    - "abc.ABC.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in abc.ABC.__dict__."
    - "abc.abstractmethod.__format__.__class__.__name__ == 'builtin_function_or_method'; '__format__' not in abc.abstractmethod.__dict__."
    - "abc.abstractmethod.__dir__.__class__.__name__ == 'builtin_function_or_method'; '__dir__' not in abc.abstractmethod.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1426.format_class_name:
  description: "abc class __format__.__class__.__name__ identity checks — ABCMeta and ABC have 'method_descriptor' (inherited via type/object); abstractmethod has 'builtin_function_or_method' (it is a function object, not a class instance); none define __format__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: format_class_name
  id_prefix: ab1426fm
  columns: [id, function, args, expected]
  rows:
    - [ab1426fm001, abc.ABCMeta.__format__.__class__.__name__.__eq__,       ["method_descriptor"],         true]
    - [ab1426fm002, abc.ABC.__format__.__class__.__name__.__eq__,            ["method_descriptor"],         true]
    - [ab1426fm003, abc.abstractmethod.__format__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1426fm004, abc.ABCMeta.__format__.__class__.__name__.__eq__,       ["method_descriptor"],         true]
    - [ab1426fm005, abc.ABC.__format__.__class__.__name__.__eq__,            ["method_descriptor"],         true]
    - [ab1426fm006, abc.abstractmethod.__format__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table abc_extra1426.format_not_in_dict:
  description: "abc class __format__ absence from own __dict__ — ABCMeta, ABC, and abstractmethod do not define __format__ in their own __dict__; all inherit it; __dict__.__contains__('__format__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: format_dict_membership
  id_prefix: ab1426fd
  columns: [id, function, args, expected]
  rows:
    - [ab1426fd001, abc.ABCMeta.__dict__.__contains__,       ["__format__"], false]
    - [ab1426fd002, abc.ABC.__dict__.__contains__,            ["__format__"], false]
    - [ab1426fd003, abc.abstractmethod.__dict__.__contains__, ["__format__"], false]
    - [ab1426fd004, abc.ABCMeta.__dict__.__contains__,       ["__dir__"],    false]
    - [ab1426fd005, abc.ABC.__dict__.__contains__,            ["__dir__"],    false]
    - [ab1426fd006, abc.abstractmethod.__dict__.__contains__, ["__dir__"],    false]

