  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra916.singledispatch_attrs:
  description: "functools.singledispatch __module__ and __qualname__ identity"
  kind: python_call_eq
  category: singledispatch_attrs
  id_prefix: ft916sd
  columns: [id, function, args, expected]
  rows:
    - [ft916sd001, functools.singledispatch.__module__.__eq__,    ["functools"], true]
    - [ft916sd002, functools.singledispatch.__qualname__.__eq__,  ["singledispatch"], true]
    - [ft916sd003, functools.singledispatch.__name__.__eq__,      ["singledispatch"], true]

