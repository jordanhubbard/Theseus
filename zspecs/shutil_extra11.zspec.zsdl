spec: shutil_extra11
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends shutil.zspec.zsdl through shutil_extra10.zspec.zsdl."
    - "shutil_extra10 covers SameFileError/ReadError/Error MRO entries and disk_usage _fields by index."
    - "shutil_extra8 covers copy2/copyfile/copyfileobj/copytree/make_archive/unpack_archive/chown/get_terminal_size __class__.__name__."
    - "shutil_extra7 covers copy/rmtree/move/which __class__.__name__ == 'function'."
    - "shutil_extra6 covers Error/SameFileError/ReadError __name__/__module__/__qualname__/bases."
    - "NOT yet covered: shutil.which('python3').__class__.__name__ == 'str' — return type when binary is found."
    - "NOT yet covered: shutil.which('nonexistent_binary_xyz_abc').__class__.__name__ == 'NoneType' — return type when binary is absent."
    - "NOT yet covered: shutil.get_terminal_size().__class__.__name__ == 'terminal_size' — named-tuple subclass name."
    - "NOT yet covered: shutil.get_terminal_size().columns.__class__.__name__ == 'int'."
    - "NOT yet covered: shutil.get_terminal_size().lines.__class__.__name__ == 'int'."
    - "NOT yet covered: shutil.which.__qualname__ == 'which'."
    - "NOT yet covered: shutil.get_terminal_size.__qualname__ == 'get_terminal_size'."
    - "shutil.which('python3') returns a str path on systems where python3 is on PATH."
    - "shutil.which('nonexistent_binary_xyz_abc') returns None; __class__.__name__ == 'NoneType'."
    - "shutil.get_terminal_size() returns an os.terminal_size named-tuple; __class__.__name__ == 'terminal_size'."
    - "columns and lines fields of terminal_size are int."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# shutil.which() — return type axes
#
# shutil_extra7 covers which.__class__.__name__ == 'function' (the callable).
# No prior spec checks the __class__.__name__ of the *return value* of which().
# which('python3') returns a str path; which('nonexistent') returns None.
# NoneType is accessed via type(None).__name__ or None.__class__.__name__.
# ---------------------------------------------------------------------------

invariant shutil_extra11.which.found_return_type:
  description: "shutil.which('python3') returns a str — __class__.__name__ == 'str'"
  category: which
  kind: python_call_eq
  function: which
  args: ["python3"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant shutil_extra11.which.missing_return_type:
  description: "shutil.which('nonexistent_binary_xyz_abc') returns None — __class__.__name__ == 'NoneType'"
  category: which
  kind: python_call_eq
  function: which
  args: ["nonexistent_binary_xyz_abc"]
  method: __class__.__name__.__eq__
  method_args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# shutil.get_terminal_size() — return type and field types
#
# shutil_extra8 checks get_terminal_size().__class__.__name__ via
# the __class__.__name__ chain on the function (not return value).
# No prior spec checks the __class__.__name__ of get_terminal_size() return,
# nor the __class__.__name__ of its .columns or .lines fields.
# The return type is os.terminal_size; __class__.__name__ == 'terminal_size'.
# ---------------------------------------------------------------------------

invariant shutil_extra11.get_terminal_size.return_class:
  description: "shutil.get_terminal_size() returns terminal_size — __class__.__name__ == 'terminal_size'"
  category: terminal_size
  kind: python_call_eq
  function: get_terminal_size
  args: []
  method: __class__.__name__.__eq__
  method_args: ["terminal_size"]
  expected: true

invariant shutil_extra11.get_terminal_size.columns_type:
  description: "shutil.get_terminal_size().columns is an int — __class__.__name__ == 'int'"
  category: terminal_size
  kind: python_call_eq
  function: get_terminal_size
  args: []
  method: columns.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant shutil_extra11.get_terminal_size.lines_type:
  description: "shutil.get_terminal_size().lines is an int — __class__.__name__ == 'int'"
  category: terminal_size
  kind: python_call_eq
  function: get_terminal_size
  args: []
  method: lines.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# shutil.which and shutil.get_terminal_size __qualname__ attributes
#
# shutil_extra7 covers which.__class__.__name__ == 'function'.
# shutil_extra6 covers __qualname__ for Error/SameFileError/ReadError (classes).
# No prior spec checks __qualname__ for which or get_terminal_size (functions).
# For module-level functions, __qualname__ == __name__ (no class nesting).
# ---------------------------------------------------------------------------

table shutil_extra11.function_qualnames:
  description: "shutil function __qualname__ attributes: which and get_terminal_size"
  kind: python_call_eq
  category: function_identity
  id_prefix: sqn11

  columns: [id, function, args, expected]
  rows:
    - [which_qn,             which.__qualname__.__eq__,             ["which"],             true]
    - [get_terminal_size_qn, get_terminal_size.__qualname__.__eq__, ["get_terminal_size"], true]

# ---------------------------------------------------------------------------
# shutil.copy __qualname__ — not covered in any prior shutil spec
#
# shutil_extra7 covers copy.__class__.__name__ == 'function'.
# No prior spec verifies copy.__qualname__ == 'copy'.
# ---------------------------------------------------------------------------

invariant shutil_extra11.copy.qualname:
  description: "shutil.copy.__qualname__ == 'copy'"
  category: function_identity
  kind: python_call_eq
  function: copy.__qualname__.__eq__
  args: ["copy"]
  expected: true
