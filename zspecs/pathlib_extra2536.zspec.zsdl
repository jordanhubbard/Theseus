  columns: [id, function, args, expected]
  rows:
    - ["pp2536007", pathlib.PurePosixPath.__dict__.__contains__, ["__format__"], false]
    - ["pp2536008", pathlib.PurePosixPath.__dict__.__contains__, ["__bytes__"], false]
    - ["pp2536009", pathlib.PurePosixPath.__dict__.__contains__, ["__fspath__"], false]

# ---------------------------------------------------------------------------
