spec: pathlib_extra2536
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence checks across pathlib classes."
    - "pathlib.PurePath defines __fspath__ in its own __dict__ (True): PurePath implements the os.fspath() filesystem path protocol."
    - "pathlib.PurePath defines __bytes__ in its own __dict__ (True): PurePath supports bytes() conversion for path serialization."
    - "pathlib.Path does NOT define __fspath__ directly; it inherits __fspath__ from PurePath (False for Path.__dict__)."
    - "pathlib.Path does NOT define __bytes__ directly; it inherits __bytes__ from PurePath (False for Path.__dict__)."
    - "pathlib.PurePosixPath and PureWindowsPath do not define __fspath__ in their own __dict__; they inherit from PurePath."
    - "None of the pathlib classes define __format__ in their own __dict__; they rely on object.__format__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath — __format__, __bytes__, __fspath__ dict-presence
#
# PurePath is the root of the pathlib hierarchy and is where the filesystem
# path protocol (__fspath__) and bytes conversion (__bytes__) are defined.
# PurePath does NOT define __format__; it relies on the inherited object.__format__.
# ---------------------------------------------------------------------------

table pathlib_extra2536.purepath_proto_dict:
  description: "pathlib.PurePath.__dict__ defines __fspath__ (True) and __bytes__ (True) but not __format__ (False); verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: pp2536

  columns: [id, function, args, expected]
  rows:
    - ["pp2536001", pathlib.PurePath.__dict__.__contains__, ["__format__"], false]
    - ["pp2536002", pathlib.PurePath.__dict__.__contains__, ["__bytes__"], true]
    - ["pp2536003", pathlib.PurePath.__dict__.__contains__, ["__fspath__"], true]

# ---------------------------------------------------------------------------
# pathlib.Path — __format__, __bytes__, __fspath__ dict-presence
#
# pathlib.Path inherits __fspath__ and __bytes__ from PurePath;
# neither is re-defined in Path.__dict__ itself.
# ---------------------------------------------------------------------------

table pathlib_extra2536.path_proto_dict:
  description: "pathlib.Path.__dict__ defines none of __format__, __bytes__, __fspath__; all inherited from PurePath; all return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: pp2536

  columns: [id, function, args, expected]
  rows:
    - ["pp2536004", pathlib.Path.__dict__.__contains__, ["__format__"], false]
    - ["pp2536005", pathlib.Path.__dict__.__contains__, ["__bytes__"], false]
    - ["pp2536006", pathlib.Path.__dict__.__contains__, ["__fspath__"], false]

