# ---------------------------------------------------------------------------
# Cross-class parity — __fspath__ defined only on PurePath, not subclasses
#
# __fspath__ is defined once in PurePath.__dict__ and inherited by all
# subclasses. This table contrasts the single True result (PurePath) against
# the False results for Path, PurePosixPath, and PureWindowsPath.
# ---------------------------------------------------------------------------

table pathlib_extra2536.fspath_parity:
  description: "pathlib __fspath__ dict-presence parity: True only for PurePath, False for all concrete subclasses; verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: pp2536

  columns: [id, function, args, expected]
  rows:
    - ["pp2536013", pathlib.PurePath.__dict__.__contains__, ["__fspath__"], true]
    - ["pp2536014", pathlib.Path.__dict__.__contains__, ["__fspath__"], false]
    - ["pp2536015", pathlib.PurePosixPath.__dict__.__contains__, ["__fspath__"], false]
    - ["pp2536016", pathlib.PureWindowsPath.__dict__.__contains__, ["__fspath__"], false]

