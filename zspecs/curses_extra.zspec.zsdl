spec: curses_extra
version: ">=3.3"
backend: python_module(curses)

docs: https://docs.python.org/3/library/curses.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/curses.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/curses/__init__.py"
    - "CPython source: Modules/_cursesmodule.c"
  notes:
    - "This spec covers identity and constant invariants not present in curses.zspec.zsdl or curses_ascii.zspec.zsdl."
    - "curses.error.__name__ == 'error' and __module__ == '_curses' (C-implemented exception)."
    - "curses.error.__bases__[0].__name__ == 'Exception' — error is a direct subclass of Exception."
    - "curses.ascii is the submodule curses.ascii; its __name__ == 'curses.ascii'."
    - "curses.ERR == -1 and curses.OK == 0 are the standard return-code sentinels."
    - "curses.COLOR_BLACK == 0 and curses.COLOR_RED == 1 are integer color-index constants."
    - "curses.A_BOLD, A_NORMAL, and A_UNDERLINE are integer bitmask attribute constants."
    - "All constants are available at import time without calling initscr() or opening a terminal."
    - "All expected values verified by running Python 3.14.3 curses module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class identity
# ---------------------------------------------------------------------------

invariant curses_extra.error.name:
  description: "curses.error.__name__ == 'error'"
  category: classnames
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant curses_extra.error.module:
  description: "curses.error.__module__ == '_curses' — C-implemented exception"
  category: classnames
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["_curses"]
  expected: true

invariant curses_extra.error.base_is_Exception:
  description: "curses.error.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# curses.ascii submodule identity
# ---------------------------------------------------------------------------

invariant curses_extra.ascii.name:
  description: "curses.ascii.__name__ == 'curses.ascii' — the ascii submodule full name"
  category: submodule
  kind: python_call_eq
  function: ascii.__name__.__eq__
  args: ["curses.ascii"]
  expected: true

# ---------------------------------------------------------------------------
# Integer return-code constants — ERR and OK
# ---------------------------------------------------------------------------

invariant curses_extra.ERR.class_is_int:
  description: "curses.ERR.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ERR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses_extra.OK.class_is_int:
  description: "curses.OK.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: OK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses_extra.ERR.value:
  description: "curses.ERR == -1"
  category: constants
  kind: python_call_eq
  function: ERR.__eq__
  args: [-1]
  expected: true

invariant curses_extra.OK.value:
  description: "curses.OK == 0"
  category: constants
  kind: python_call_eq
  function: OK.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Color-index constants — COLOR_BLACK and COLOR_RED
# ---------------------------------------------------------------------------

invariant curses_extra.COLOR_BLACK.class_is_int:
  description: "curses.COLOR_BLACK.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: COLOR_BLACK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses_extra.COLOR_RED.class_is_int:
  description: "curses.COLOR_RED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: COLOR_RED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Attribute bitmask constants — A_BOLD, A_NORMAL, A_UNDERLINE
# ---------------------------------------------------------------------------

invariant curses_extra.A_BOLD.class_is_int:
  description: "curses.A_BOLD.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: A_BOLD.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses_extra.A_NORMAL.class_is_int:
  description: "curses.A_NORMAL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: A_NORMAL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses_extra.A_UNDERLINE.class_is_int:
  description: "curses.A_UNDERLINE.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: A_UNDERLINE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
