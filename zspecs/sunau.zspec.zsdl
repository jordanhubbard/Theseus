spec: sunau
version: ">=3.3,<3.13"
backend: python_module(sunau)

docs: https://docs.python.org/3/library/sunau.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sunau.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "sunau source: Lib/sunau.py (PSF; source inspection permitted)"
  not_derived_from:
    - "sunau internal details"
  notes:
    - "Deprecated since Python 3.11; removed in Python 3.13."
    - "sunau provides support for reading and writing Sun AU sound files."
    - "sunau.open(file, mode) opens a Sun AU sound file; mode 'r' returns Au_read, 'w' returns Au_write."
    - "AUDIO_FILE_MAGIC is 0x2e736e64 (779316836), the four-byte magic number '.snd' at the start of AU files."
    - "AUDIO_FILE_ENCODING_MULAW_8 == 1: 8-bit mu-law encoding."
    - "AUDIO_FILE_ENCODING_LINEAR_8 == 2: 8-bit linear PCM encoding."
    - "AUDIO_FILE_ENCODING_LINEAR_16 == 3: 16-bit linear PCM encoding."
    - "Error is the module-level exception, inheriting from Exception."
    - "All expected values verified by running Python 3.12 sunau module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant sunau.Au_read_name:
  description: "Au_read.__name__ == 'Au_read'"
  category: classnames
  kind: python_call_eq
  function: Au_read.__name__.__eq__
  args: ["Au_read"]
  expected: true

invariant sunau.Au_write_name:
  description: "Au_write.__name__ == 'Au_write'"
  category: classnames
  kind: python_call_eq
  function: Au_write.__name__.__eq__
  args: ["Au_write"]
  expected: true

invariant sunau.Error_name:
  description: "Error.__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant sunau.Error_base:
  description: "Error.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant sunau.open_name:
  description: "sunau.open.__name__ == 'open'"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Module constants
# ---------------------------------------------------------------------------

invariant sunau.AUDIO_FILE_MAGIC_value:
  description: "AUDIO_FILE_MAGIC == 779316836 (0x2e736e64, '.snd' AU magic number)"
  category: constants
  kind: python_call_eq
  function: AUDIO_FILE_MAGIC.__eq__
  args: [779316836]
  expected: true

invariant sunau.AUDIO_FILE_MAGIC_type:
  description: "AUDIO_FILE_MAGIC is an int"
  category: constants
  kind: python_call_eq
  function: AUDIO_FILE_MAGIC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sunau.AUDIO_FILE_ENCODING_MULAW_8_value:
  description: "AUDIO_FILE_ENCODING_MULAW_8 == 1"
  category: constants
  kind: python_call_eq
  function: AUDIO_FILE_ENCODING_MULAW_8.__eq__
  args: [1]
  expected: true

invariant sunau.AUDIO_FILE_ENCODING_LINEAR_8_value:
  description: "AUDIO_FILE_ENCODING_LINEAR_8 == 2"
  category: constants
  kind: python_call_eq
  function: AUDIO_FILE_ENCODING_LINEAR_8.__eq__
  args: [2]
  expected: true

invariant sunau.AUDIO_FILE_ENCODING_LINEAR_16_value:
  description: "AUDIO_FILE_ENCODING_LINEAR_16 == 3"
  category: constants
  kind: python_call_eq
  function: AUDIO_FILE_ENCODING_LINEAR_16.__eq__
  args: [3]
  expected: true

