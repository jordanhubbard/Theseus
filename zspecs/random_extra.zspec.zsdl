spec: random_extra
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "Python random documentation — https://docs.python.org/3/library/random.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
    - "CPython source: internal Mersenne Twister implementation"
  notes:
    - "This spec extends random.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "random.zspec.zsdl covers: Random.__name__, SystemRandom.__name__, and deterministic randint/choice/randrange/getrandbits/sample vectors."
    - "This spec adds: module-level function __name__ checks and return-type checks for random() and randint()."
    - "random.random() returns a float in [0.0, 1.0); its __class__.__name__ == 'float'."
    - "random.randint(1, 10) returns an int; its __class__.__name__ == 'int'."
    - "Module-level functions (randint, randrange, uniform, choice, choices, sample, shuffle, gauss, normalvariate, seed, getstate, setstate) expose __name__ equal to their string name."
    - "Random.__module__ == 'random' — the class lives in the random module."
    - "SystemRandom.__name__ == 'SystemRandom' is already covered in random.zspec.zsdl; __module__ is added here."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class module identity
# ---------------------------------------------------------------------------

invariant random_extra.Random.module:
  description: "random.Random.__module__ == 'random'"
  category: class_metadata
  kind: python_call_eq
  function: Random.__module__.__eq__
  args: ["random"]
  expected: true

invariant random_extra.SystemRandom.class_name:
  description: "random.SystemRandom.__name__ == 'SystemRandom'"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__name__.__eq__
  args: ["SystemRandom"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function name identity
# ---------------------------------------------------------------------------

table random_extra.functions.names:
  description: "Module-level random functions have __name__ equal to their string name"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [randint_name,       randint.__name__.__eq__,       ["randint"],       true]
    - [randrange_name,     randrange.__name__.__eq__,     ["randrange"],     true]
    - [uniform_name,       uniform.__name__.__eq__,       ["uniform"],       true]
    - [choice_name,        choice.__name__.__eq__,        ["choice"],        true]
    - [choices_name,       choices.__name__.__eq__,       ["choices"],       true]
    - [sample_name,        sample.__name__.__eq__,        ["sample"],        true]
    - [shuffle_name,       shuffle.__name__.__eq__,       ["shuffle"],       true]
    - [gauss_name,         gauss.__name__.__eq__,         ["gauss"],         true]
    - [normalvariate_name, normalvariate.__name__.__eq__, ["normalvariate"], true]
    - [seed_name,          seed.__name__.__eq__,          ["seed"],          true]
    - [getstate_name,      getstate.__name__.__eq__,      ["getstate"],      true]
    - [setstate_name,      setstate.__name__.__eq__,      ["setstate"],      true]

# ---------------------------------------------------------------------------
# Return type checks
# ---------------------------------------------------------------------------

invariant random_extra.random.return_type:
  description: "random.random().__class__.__name__ == 'float' — random() always returns a float"
  category: return_types
  kind: python_call_eq
  function: random
  args: []
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

invariant random_extra.randint.return_type:
  description: "random.randint(1, 10).__class__.__name__ == 'int' — randint() always returns an int"
  category: return_types
  kind: python_call_eq
  function: randint
  args: [1, 10]
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true
