invariant asyncio_extra54.Queue_dict_class_qualname_eq:
  description: "asyncio.Queue.__dict__.__class__.__qualname__ == 'mappingproxy' — mappingproxy is a built-in type with no enclosing scope; __qualname__ == __name__ == 'mappingproxy' (12 chars); first __dict__.__class__.__qualname__ check in asyncio specs"
  category: class_names
  kind: python_call_eq
  function: Queue.__dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
