invariant asyncio_extra54.Condition_dict_class_name_eq:
  description: "asyncio.Condition.__dict__.__class__.__name__ == 'mappingproxy' — Condition class __dict__ is a mappingproxy; prior extra31 captured __len__()==12, extra54 adds the string equality"
  category: class_names
  kind: python_call_eq
  function: Condition.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant asyncio_extra54.BoundedSemaphore_dict_class_name_eq:
  description: "asyncio.BoundedSemaphore.__dict__.__class__.__name__ == 'mappingproxy' — BoundedSemaphore class __dict__ is a mappingproxy; prior extra31 captured __len__()==12, extra54 adds the string equality"
  category: class_names
  kind: python_call_eq
  function: BoundedSemaphore.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
