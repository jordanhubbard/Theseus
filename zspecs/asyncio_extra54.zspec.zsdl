invariant asyncio_extra54.Lock_dict_class_qualname_eq:
  description: "asyncio.Lock.__dict__.__class__.__qualname__ == 'mappingproxy' — mappingproxy is a built-in type; __qualname__ == __name__ == 'mappingproxy'; novel __dict__.__class__.__qualname__ check for Lock"
  category: class_names
  kind: python_call_eq
  function: Lock.__dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true
