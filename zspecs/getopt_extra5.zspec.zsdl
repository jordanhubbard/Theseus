spec: getopt_extra5
version: ">=3.9"
backend: python_module(getopt)

docs: https://docs.python.org/3/library/getopt.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/getopt.html — Python getopt module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/getopt.py"
  notes:
    - "Extends getopt.zspec.zsdl, getopt_extra.zspec.zsdl, getopt_extra2.zspec.zsdl, getopt_extra3.zspec.zsdl, and getopt_extra4.zspec.zsdl."
    - "getopt.zspec.zsdl covers: getopt/gnu_getopt __name__ table; GetoptError __name__/__module__; error alias __name__; behavioral vectors: '-a', '-b', '--foo', '--verbose', '--output', empty, unrecognized, gnu_getopt permissive, mixed."
    - "getopt_extra.zspec.zsdl covers: getopt/gnu_getopt __name__/__module__/__class__.__name__; GetoptError __name__/__module__/__class__.__name__/__bases__/__bases__.__len__; error __name__/__module__; GetoptError.__init__.__name__; GetoptError.__str__.__name__."
    - "getopt_extra2.zspec.zsdl covers: getopt/__qualname__, gnu_getopt/__qualname__, GetoptError/__qualname__; GetoptError.__module__ standalone invariant; getopt/__module__ and gnu_getopt/__module__ standalone invariants."
    - "getopt_extra3.zspec.zsdl covers: error/__qualname__; getopt(['-h'], 'h') opts/args; getopt([], 'h') opts/args."
    - "getopt_extra4.zspec.zsdl covers: GetoptError.__init__.__qualname__; gnu_getopt with long options requiring values; getopt with short option requiring a value; getopt with option requiring value plus remaining args; getopt(['--unknown'], '', []) raises GetoptError."
    - "This spec adds: GetoptError.__str__.__qualname__ (extra4 adds __init__.__qualname__; __str__.__qualname__ is the symmetric gap); GetoptError.__init__.__module__ (extra covers __name__ and extra4 covers __qualname__; __module__ is new); GetoptError.__str__.__module__ (same gap); getopt([], '')==([], []) verified via element access (getopt.zspec.zsdl covers empty call but as a compound result; this spec verifies each element independently); gnu_getopt([], '')==([], []) element access (same gap)."
    - "getopt.GetoptError.__str__.__qualname__ == 'GetoptError.__str__' — getopt_extra covers __name__; extra4 covers __init__.__qualname__; no prior spec covers __str__.__qualname__."
    - "getopt.GetoptError.__init__.__module__ == 'getopt' — extra covers __name__; extra4 covers __qualname__; __module__ is new."
    - "getopt.GetoptError.__str__.__module__ == 'getopt' — same gap as __init__.__module__."
    - "getopt.getopt([], '')[0] == [] — opts element of empty call; independent element-level verification."
    - "getopt.getopt([], '')[1] == [] — remaining args element of empty call."
    - "getopt.gnu_getopt([], '')[0] == [] — opts element of gnu_getopt empty call."
    - "getopt.gnu_getopt([], '')[1] == [] — remaining args element of gnu_getopt empty call."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GetoptError.__str__.__qualname__ and __module__
#
# getopt_extra covers GetoptError.__str__.__name__ == '__str__'.
# getopt_extra4 adds GetoptError.__init__.__qualname__.
# This spec covers GetoptError.__str__.__qualname__ (symmetric gap) and
# GetoptError.__init__.__module__ and GetoptError.__str__.__module__.
# ---------------------------------------------------------------------------

invariant getopt_extra5.GetoptError.str_qualname:
  description: "getopt.GetoptError.__str__.__qualname__ == 'GetoptError.__str__'"
  category: attributes
  kind: python_call_eq
  function: GetoptError.__str__.__qualname__.__eq__
  args: ["GetoptError.__str__"]
  expected: true

invariant getopt_extra5.GetoptError.init_module:
  description: "getopt.GetoptError.__init__.__module__ == 'getopt'"
  category: attributes
  kind: python_call_eq
  function: GetoptError.__init__.__module__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra5.GetoptError.str_module:
  description: "getopt.GetoptError.__str__.__module__ == 'getopt'"
  category: attributes
  kind: python_call_eq
  function: GetoptError.__str__.__module__.__eq__
  args: ["getopt"]
  expected: true

# ---------------------------------------------------------------------------
# getopt([], '') — empty parse, element-level verification
#
# getopt.zspec.zsdl tests the empty call but as a combined result.
# This spec verifies each element independently via __getitem__ to establish
# that opts and remaining args are each empty lists.
# ---------------------------------------------------------------------------

invariant getopt_extra5.getopt.empty_opts:
  description: "getopt.getopt([], '')[0] == [] — opts from empty parse is empty list"
  category: behavior
  kind: python_call_eq
  function: getopt
  args: [[], ""]
  method: __getitem__
  method_args: [0]
  expected: []

invariant getopt_extra5.getopt.empty_args:
  description: "getopt.getopt([], '')[1] == [] — remaining args from empty parse is empty list"
  category: behavior
  kind: python_call_eq
  function: getopt
  args: [[], ""]
  method: __getitem__
  method_args: [1]
  expected: []

# ---------------------------------------------------------------------------
# gnu_getopt([], '') — empty parse, element-level verification
#
# Symmetric to the getopt empty parse vectors above, for gnu_getopt.
# No prior spec verifies gnu_getopt([], '') at the element level.
# ---------------------------------------------------------------------------

invariant getopt_extra5.gnu_getopt.empty_opts:
  description: "getopt.gnu_getopt([], '')[0] == [] — opts from empty gnu_getopt parse is empty list"
  category: behavior
  kind: python_call_eq
  function: gnu_getopt
  args: [[], ""]
  method: __getitem__
  method_args: [0]
  expected: []

invariant getopt_extra5.gnu_getopt.empty_args:
  description: "getopt.gnu_getopt([], '')[1] == [] — remaining args from empty gnu_getopt parse is empty list"
  category: behavior
  kind: python_call_eq
  function: gnu_getopt
  args: [[], ""]
  method: __getitem__
  method_args: [1]
  expected: []
