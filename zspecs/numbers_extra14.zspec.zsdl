spec: numbers_extra14
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra through numbers_extra13."
    - "numbers_extra13 covers __qualname__.__eq__ and __qualname__.__len__ for all five ABC classes themselves."
    - "No prior spec covers __qualname__ for individual abstract methods defined on the ABC classes."
    - "Complex.__add__, __mul__, __neg__, __abs__, __pow__ have qualname 'Complex.<name>'."
    - "Real.__lt__, __le__, __floor__, __ceil__, __float__ have qualname 'Real.<name>'."
    - "Integral.__and__, __or__, __xor__, __invert__, __int__ have qualname 'Integral.<name>'."
    - "numbers.Real.__add__.__qualname__ == 'Complex.__add__' — Real inherits __add__ from Complex."
    - "numbers.Integral.__add__.__qualname__ == 'Complex.__add__' — Integral also inherits from Complex."
    - "Focus: numbers ABC class method __qualname__ values across Complex, Real, and Integral."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Complex abstract method __qualname__ values
#
# No prior spec records __qualname__ for methods defined on numbers.Complex.
# All methods are abstract and defined directly on Complex; qualname is 'Complex.<name>'.
# ---------------------------------------------------------------------------

table numbers_extra14.complex_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [add, Complex.__add__.__qualname__.__eq__, ["Complex.__add__"], true, "numbers.Complex.__add__.__qualname__ == 'Complex.__add__'"]
    - [mul, Complex.__mul__.__qualname__.__eq__, ["Complex.__mul__"], true, "numbers.Complex.__mul__.__qualname__ == 'Complex.__mul__'"]
    - [neg, Complex.__neg__.__qualname__.__eq__, ["Complex.__neg__"], true, "numbers.Complex.__neg__.__qualname__ == 'Complex.__neg__'"]
    - [abs, Complex.__abs__.__qualname__.__eq__, ["Complex.__abs__"], true, "numbers.Complex.__abs__.__qualname__ == 'Complex.__abs__'"]
    - [pow, Complex.__pow__.__qualname__.__eq__, ["Complex.__pow__"], true, "numbers.Complex.__pow__.__qualname__ == 'Complex.__pow__'"]

# ---------------------------------------------------------------------------
# Inherited __add__ via Real and Integral
#
# numbers.Real and numbers.Integral do not override __add__; they inherit it
# from Complex.  Both report __qualname__ == 'Complex.__add__'.
# ---------------------------------------------------------------------------

invariant numbers_extra14.Real.add_qualname_inherited:
  description: "numbers.Real.__add__.__qualname__ == 'Complex.__add__' — inherited from Complex, not overridden"
  category: method_identity
  kind: python_call_eq
  function: Real.__add__.__qualname__.__eq__
  args: ["Complex.__add__"]
  expected: true

invariant numbers_extra14.Integral.add_qualname_inherited:
  description: "numbers.Integral.__add__.__qualname__ == 'Complex.__add__' — inherited through MRO from Complex"
  category: method_identity
  kind: python_call_eq
  function: Integral.__add__.__qualname__.__eq__
  args: ["Complex.__add__"]
  expected: true

# ---------------------------------------------------------------------------
# Real abstract method __qualname__ values
#
# Real adds abstract methods for ordering and float conversion.
# No prior spec records __qualname__ for these Real-specific methods.
# ---------------------------------------------------------------------------

table numbers_extra14.real_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [lt,    Real.__lt__.__qualname__.__eq__,    ["Real.__lt__"],    true, "numbers.Real.__lt__.__qualname__ == 'Real.__lt__'"]
    - [le,    Real.__le__.__qualname__.__eq__,    ["Real.__le__"],    true, "numbers.Real.__le__.__qualname__ == 'Real.__le__'"]
    - [floor, Real.__floor__.__qualname__.__eq__, ["Real.__floor__"], true, "numbers.Real.__floor__.__qualname__ == 'Real.__floor__'"]
    - [ceil,  Real.__ceil__.__qualname__.__eq__,  ["Real.__ceil__"],  true, "numbers.Real.__ceil__.__qualname__ == 'Real.__ceil__'"]
    - [float, Real.__float__.__qualname__.__eq__, ["Real.__float__"], true, "numbers.Real.__float__.__qualname__ == 'Real.__float__'"]

# ---------------------------------------------------------------------------
# Integral abstract method __qualname__ values
#
# Integral adds bitwise and integer-conversion abstract methods.
# No prior spec records __qualname__ for these Integral-specific methods.
# ---------------------------------------------------------------------------

table numbers_extra14.integral_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [and_,    Integral.__and__.__qualname__.__eq__,    ["Integral.__and__"],    true, "numbers.Integral.__and__.__qualname__ == 'Integral.__and__'"]
    - [or_,     Integral.__or__.__qualname__.__eq__,     ["Integral.__or__"],     true, "numbers.Integral.__or__.__qualname__ == 'Integral.__or__'"]
    - [xor,     Integral.__xor__.__qualname__.__eq__,    ["Integral.__xor__"],    true, "numbers.Integral.__xor__.__qualname__ == 'Integral.__xor__'"]
    - [invert,  Integral.__invert__.__qualname__.__eq__, ["Integral.__invert__"], true, "numbers.Integral.__invert__.__qualname__ == 'Integral.__invert__'"]
    - [int,     Integral.__int__.__qualname__.__eq__,    ["Integral.__int__"],    true, "numbers.Integral.__int__.__qualname__ == 'Integral.__int__'"]

# ---------------------------------------------------------------------------
# Method __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant numbers_extra14.Complex.add.qualname_len:
  description: "len(numbers.Complex.__add__.__qualname__) == 15 — 'Complex.__add__' is 15 chars"
  category: method_identity
  kind: python_call_eq
  function: Complex.__add__.__qualname__.__len__
  args: []
  expected: 15

invariant numbers_extra14.Integral.invert.qualname_len:
  description: "len(numbers.Integral.__invert__.__qualname__) == 19 — 'Integral.__invert__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: Integral.__invert__.__qualname__.__len__
  args: []
  expected: 19

invariant numbers_extra14.Real.floor.qualname_len:
  description: "len(numbers.Real.__floor__.__qualname__) == 14 — 'Real.__floor__' is 14 chars"
  category: method_identity
  kind: python_call_eq
  function: Real.__floor__.__qualname__.__len__
  args: []
  expected: 14
