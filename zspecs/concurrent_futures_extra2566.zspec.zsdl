spec: concurrent_futures_extra2566
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "concurrent.futures.Future defines NONE of __getattr__, __setattr__, or __delattr__ in its own __dict__."
    - "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor likewise define none of these three dunders."
    - "concurrent.futures.Executor (the abstract base) also defines none of the three attribute-access dunders."
    - "Despite Future using an internal lock (_condition) for thread safety, attribute setting is NOT intercepted via __setattr__."
    - "concurrent.futures.Future.__dict__ contains cancel, result, done, running, exception, add_done_callback, __init__, __repr__."
    - "ThreadPoolExecutor.__dict__ contains submit, __init__, shutdown but no attribute-access protocol overrides."
    - "ProcessPoolExecutor.__dict__ contains submit, shutdown but no attribute-access protocol overrides."
    - "Executor.__dict__ contains submit, map, shutdown — the abstract base API — but no attribute-access dunders."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# concurrent.futures.Future — attribute access protocol absent
# ---------------------------------------------------------------------------

table concurrent_futures_extra2566.future_attr_protocol:
  description: "concurrent.futures.Future defines none of __getattr__, __setattr__, __delattr__ in its class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2566

  columns: [id, function, args, expected]
  rows:
    - ["cf2566001", "concurrent.futures.Future.__dict__.__contains__", ["__getattr__"], false]
    - ["cf2566002", "concurrent.futures.Future.__dict__.__contains__", ["__setattr__"], false]
    - ["cf2566003", "concurrent.futures.Future.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# concurrent.futures.Future — positive presence of core API in __dict__
# ---------------------------------------------------------------------------

table concurrent_futures_extra2566.future_dict_positive:
  description: "concurrent.futures.Future core methods are defined directly in the class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2566

  columns: [id, function, args, expected]
  rows:
    - ["cf2566004", "concurrent.futures.Future.__dict__.__contains__", ["__init__"],           true]
    - ["cf2566005", "concurrent.futures.Future.__dict__.__contains__", ["__repr__"],           true]
    - ["cf2566006", "concurrent.futures.Future.__dict__.__contains__", ["cancel"],             true]
    - ["cf2566007", "concurrent.futures.Future.__dict__.__contains__", ["result"],             true]
    - ["cf2566008", "concurrent.futures.Future.__dict__.__contains__", ["done"],               true]
    - ["cf2566009", "concurrent.futures.Future.__dict__.__contains__", ["running"],            true]
    - ["cf2566010", "concurrent.futures.Future.__dict__.__contains__", ["exception"],          true]
    - ["cf2566011", "concurrent.futures.Future.__dict__.__contains__", ["add_done_callback"],  true]

