spec: hashlib_extra2311
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ absence checks and additional dict-presence."
    - "hashlib.blake2b and hashlib.blake2s are C extension types with no abstract methods."
    - "__abstractmethods__ is absent from both class dicts; accessing it raises AttributeError."
    - "Additional dict-presence checks for protocol dunders and metaclass methods confirm none are defined directly on these C types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ absence from __dict__ — blake2b and blake2s
#
# C extension types never set __abstractmethods__; it is absent from __dict__.
# All expected false.
# ---------------------------------------------------------------------------

table hashlib_extra2311.blake2b_abstract:
  description: "hashlib.blake2b __abstractmethods__ absence — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2311
  columns: [id, function, args, expected]
  rows:
    - ["hl2311001", "hashlib.blake2b.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["hl2311002", "hashlib.blake2s.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__ direct attribute access raises AttributeError
#
# Since __abstractmethods__ is absent from each class's __dict__ and no base
# class in the MRO provides it, accessing cls.__abstractmethods__ raises
# AttributeError for both C extension types.
# ---------------------------------------------------------------------------

table hashlib_extra2311.blake2_abstract_attr_error:
  description: "hashlib blake2 types raise AttributeError on __abstractmethods__ access — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: hl2311
  columns: [id, function, args, expected]
  rows:
    - ["hl2311003", "hashlib.blake2b.__abstractmethods__.__len__", [], "AttributeError"]
    - ["hl2311004", "hashlib.blake2s.__abstractmethods__.__len__", [], "AttributeError"]
    - ["hl2311005", "hashlib.blake2b.__abstractmethods__.__contains__", ["update"], "AttributeError"]
    - ["hl2311006", "hashlib.blake2s.__abstractmethods__.__contains__", ["update"], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: additional protocol dunder dict-presence — blake2b
#
# Checks that various protocol and metaclass dunders are NOT directly present
# in hashlib.blake2b.__dict__. These methods are inherited from object or
# the C type machinery and are not re-defined on the blake2b type itself.
# All expected false.
# ---------------------------------------------------------------------------

table hashlib_extra2311.blake2b_dict_contains:
  description: "hashlib.blake2b additional dict-presence checks for protocol dunders — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2311
  columns: [id, function, args, expected]
  rows:
    - ["hl2311007", "hashlib.blake2b.__dict__.__contains__", ["__buffer__"], false]
    - ["hl2311008", "hashlib.blake2b.__dict__.__contains__", ["__release_buffer__"], false]
    - ["hl2311009", "hashlib.blake2b.__dict__.__contains__", ["__sizeof__"], false]
    - ["hl2311010", "hashlib.blake2b.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2311011", "hashlib.blake2b.__dict__.__contains__", ["__init_subclass__"], false]
    - ["hl2311012", "hashlib.blake2b.__dict__.__contains__", ["__subclasshook__"], false]
    - ["hl2311013", "hashlib.blake2b.__dict__.__contains__", ["mro"], false]
    - ["hl2311014", "hashlib.blake2b.__dict__.__contains__", ["__prepare__"], false]

# ---------------------------------------------------------------------------
# Table 4: additional protocol dunder dict-presence — blake2s
#
# Same checks as Table 3, applied to hashlib.blake2s. Both types are C
# extension wrappers and share the same absence pattern.
# All expected false.
# ---------------------------------------------------------------------------

table hashlib_extra2311.blake2s_dict_contains:
  description: "hashlib.blake2s additional dict-presence checks for protocol dunders — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2311
  columns: [id, function, args, expected]
  rows:
    - ["hl2311015", "hashlib.blake2s.__dict__.__contains__", ["__buffer__"], false]
    - ["hl2311016", "hashlib.blake2s.__dict__.__contains__", ["__release_buffer__"], false]
    - ["hl2311017", "hashlib.blake2s.__dict__.__contains__", ["__sizeof__"], false]
    - ["hl2311018", "hashlib.blake2s.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2311019", "hashlib.blake2s.__dict__.__contains__", ["__init_subclass__"], false]
    - ["hl2311020", "hashlib.blake2s.__dict__.__contains__", ["__subclasshook__"], false]
    - ["hl2311021", "hashlib.blake2s.__dict__.__contains__", ["mro"], false]
    - ["hl2311022", "hashlib.blake2s.__dict__.__contains__", ["__prepare__"], false]
