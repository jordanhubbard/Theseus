spec: abc_extra101
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra100.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc.abstractmethod __code__ attributes (co_name, co_argcount, co_qualname, co_firstlineno), get_cache_token identity, ABC.__init_subclass__ qualname, ABCMeta.__instancecheck__ qualname. NEW in extra101: abc.abstractmethod.__code__.co_name=='abstractmethod' (co_argcount=1); abc.abstractmethod.__code__.co_qualname=='abstractmethod' (Python 3.11+ attribute, matches co_name since abstractmethod is module-level); abc.abstractmethod.__code__.co_firstlineno==7 (line 7 of Lib/abc.py); abc.abstractmethod.__defaults__==None (no default arguments); abc.abstractmethod.__annotations__.__class__.__name__=='dict', len==0; type(abc.get_cache_token).__name__=='builtin_function_or_method'; abc.get_cache_token.__qualname__=='get_cache_token' (module='_abc'); abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__', type=='builtin_function_or_method'; abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__', type=='function'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_qualname == 'abstractmethod'. co_qualname is a Python 3.11+ code object attribute that stores the qualified name; for module-level functions it equals the function name (no class prefix); identical to co_name for abstractmethod since it is not a nested or class-level function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_firstlineno == 7. abstractmethod is defined starting at line 7 of Lib/abc.py in CPython. This value is Python-version-specific but verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'. Unlike __prepare__ and __subclasshook__ which are builtin_function_or_method (C-level), __instancecheck__ is a Python function (type='function') defined in Lib/abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__'. type(ABC.__init_subclass__).__name__=='builtin_function_or_method' (C-level inherited classmethod). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod __code__ attributes — extra101
#
# Wave 254 theme: abc.abstractmethod code object attributes.
#
# abc.abstractmethod.__code__.co_name      == 'abstractmethod' (co_argcount=1)
# abc.abstractmethod.__code__.co_qualname  == 'abstractmethod' (Python 3.11+ matches co_name)
# abc.abstractmethod.__code__.co_firstlineno == 7
# abc.abstractmethod.__defaults__          == None  (no default args)
# ---------------------------------------------------------------------------

table abc_extra101.abc_abstractmethod_code_attrs:
  description: "abc.abstractmethod __code__ attribute checks in abccode101 namespace — wave 254 theme: abstractmethod.__code__.co_name.__eq__('abstractmethod')==True (co_name is the function name as defined; len=14: 'abstractmethod'=14); abstractmethod.__code__.co_argcount.__eq__(1)==True (single parameter: funcobj); abstractmethod.__code__.co_qualname.__eq__('abstractmethod')==True (Python 3.11+ attribute — equals co_name for module-level functions); abstractmethod.__code__.co_firstlineno.__eq__(7)==True (defined at line 7 of Lib/abc.py in Python 3.14.3); abstractmethod.__defaults__==None (no default argument values); abstractmethod.__annotations__.__class__.__name__.__eq__('dict')==True (annotations is an empty dict); len(abstractmethod.__annotations__)==0; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abccode101

  columns: [id, function, args, expected, description]
  rows:
    - [am_co_name,      abc.abstractmethod.__code__.co_name.__eq__,          ["abstractmethod"], true, "abc.abstractmethod.__code__.co_name == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_co_argc,      abc.abstractmethod.__code__.co_argcount.__eq__,      [1],               true, "abc.abstractmethod.__code__.co_argcount == 1 (funcobj); verified with Python 3.14.3"]
    - [am_co_qualname,  abc.abstractmethod.__code__.co_qualname.__eq__,      ["abstractmethod"], true, "abc.abstractmethod.__code__.co_qualname == 'abstractmethod' (Python 3.11+ attribute, equals co_name for module-level function); verified with Python 3.14.3"]
    - [am_co_firstline, abc.abstractmethod.__code__.co_firstlineno.__eq__,   [7],               true, "abc.abstractmethod.__code__.co_firstlineno == 7 (line 7 of Lib/abc.py in Python 3.14.3); verified with Python 3.14.3"]
    - [am_ann_cls,      abc.abstractmethod.__annotations__.__class__.__name__.__eq__, ["dict"], true, "abc.abstractmethod.__annotations__.__class__.__name__ == 'dict'; verified with Python 3.14.3"]
    - [am_ann_len,      abc.abstractmethod.__annotations__.__len__,          [],                0,    "len(abc.abstractmethod.__annotations__) == 0 (no annotations); verified with Python 3.14.3"]
    - [am_qname_eq,     abc.abstractmethod.__qualname__.__eq__,              ["abstractmethod"], true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14, matches co_name and co_qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token identity and qualname — extra101
#
# Wave 254 theme: get_cache_token C-level identity.
#
# type(abc.get_cache_token).__name__  == 'builtin_function_or_method'
# abc.get_cache_token.__qualname__    == 'get_cache_token'  (len=15)
# abc.get_cache_token.__module__      == '_abc'
# ---------------------------------------------------------------------------

table abc_extra101.abc_get_cache_token_identity:
  description: "abc.get_cache_token identity checks in abccode101 namespace — wave 254 theme: get_cache_token is a C-level function from Modules/_abc.c; type(abc.get_cache_token).__name__.__eq__('builtin_function_or_method')==True (C-implemented, no __code__ attribute); get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15: 'get_cache_token'=15 — 'get_'=4+'cache'=5+'_token'=6=15); get_cache_token.__module__.__eq__('_abc')==True (C extension module, not Python 'abc'); compare: abc.abstractmethod is a Python function (type='function', module='abc') while get_cache_token is C-level (type='builtin_function_or_method', module='_abc'); get_cache_token.__qualname__.__len__()==15; ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True (len=21); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abccode101a

  columns: [id, function, args, expected, description]
  rows:
    - [gct_type_eq,    abc.get_cache_token.__class__.__name__.__eq__,            ["builtin_function_or_method"], true, "type(abc.get_cache_token).__name__ == 'builtin_function_or_method' (C-level from _abc.c); verified with Python 3.14.3"]
    - [gct_qn_eq,      abc.get_cache_token.__qualname__.__eq__,                  ["get_cache_token"],            true, "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_qn_len,     abc.get_cache_token.__qualname__.__len__,                 [],                             15,   "abc.get_cache_token.__qualname__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]
    - [gct_module,     abc.get_cache_token.__module__.__eq__,                    ["_abc"],                       true, "abc.get_cache_token.__module__ == '_abc' (C extension, not 'abc'); verified with Python 3.14.3"]
    - [iss_qn_eq,      abc.ABC.__init_subclass__.__qualname__.__eq__,            ["ABC.__init_subclass__"],      true, "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified with Python 3.14.3"]
    - [iss_qn_len,     abc.ABC.__init_subclass__.__qualname__.__len__,           [],                             21,   "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.'=4+'__init_subclass__'=17=21); verified with Python 3.14.3"]
    - [iss_type_eq,    abc.ABC.__init_subclass__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "type(abc.ABC.__init_subclass__).__name__ == 'builtin_function_or_method' (C-level inherited classmethod); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__instancecheck__ qualname — extra101
#
# Wave 254 theme: ABCMeta.__instancecheck__ is a Python function.
#
# abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'  (len=25)
# type(abc.ABCMeta.__instancecheck__).__name__ == 'function'  (Python-defined, not C-level)
# ---------------------------------------------------------------------------

table abc_extra101.abc_instancecheck_identity:
  description: "abc.ABCMeta.__instancecheck__ identity checks in abccode101 namespace — wave 254 theme: ABCMeta.__instancecheck__ is a Python function (type='function'), unlike ABCMeta.__prepare__ and __subclasshook__ which are C-level (type='builtin_function_or_method'); ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25); type(ABCMeta.__instancecheck__).__name__.__eq__('function')==True; ABCMeta.__instancecheck__.__qualname__.__len__()==25; abstractmethod.__qualname__.__len__()==14 (shorter, module-level, no class prefix); compare qualname lengths: abstractmethod=14, get_cache_token=15, ABC.__init_subclass__=21 (len check: 'ABC.'=4+'__init_subclass__'=17=21), ABCMeta.__instancecheck__=25 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abccode101b

  columns: [id, function, args, expected, description]
  rows:
    - [ic_qn_eq,      abc.ABCMeta.__instancecheck__.__qualname__.__eq__,         ["ABCMeta.__instancecheck__"], true, "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25); verified with Python 3.14.3"]
    - [ic_qn_len,     abc.ABCMeta.__instancecheck__.__qualname__.__len__,        [],                            25,   "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 ('ABCMeta.'=8+'__instancecheck__'=17); verified with Python 3.14.3"]
    - [ic_type_eq,    abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,   ["function"],                  true, "type(abc.ABCMeta.__instancecheck__).__name__ == 'function' (Python-defined, has __code__ attribute); verified with Python 3.14.3"]
    - [am_co_qn_eq,   abc.abstractmethod.__code__.co_qualname.__eq__,            ["abstractmethod"],            true, "abc.abstractmethod.__code__.co_qualname == 'abstractmethod' (co_qualname equals co_name for module-level functions); verified with Python 3.14.3"]
    - [am_qn_len,     abc.abstractmethod.__qualname__.__len__,                   [],                            14,   "abc.abstractmethod.__qualname__.__len__() == 14 ('abstractmethod'=14); shortest function qualname in spec; verified with Python 3.14.3"]
    - [iss_qn_eq2,    abc.ABC.__init_subclass__.__qualname__.__eq__,             ["ABC.__init_subclass__"],     true, "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__'; verified with Python 3.14.3"]
    - [ic_module,     abc.ABCMeta.__instancecheck__.__module__.__eq__,           ["abc"],                       true, "abc.ABCMeta.__instancecheck__.__module__ == 'abc' (Python-defined in Lib/abc.py); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra101
# ---------------------------------------------------------------------------

invariant abc_extra101.abstractmethod_co_qualname_eq_co_name:
  description: "abc.abstractmethod.__code__.co_qualname.__eq__('abstractmethod') returns True — co_qualname is a Python 3.11+ code object attribute; for module-level functions it equals the function name (no class prefix), so co_qualname=='abstractmethod'==co_name; compare: for a method defined inside a class, co_qualname would be 'ClassName.method_name' while co_name would be just 'method_name'; abstractmethod.__code__.co_name=='abstractmethod' (len=14); abstractmethod.__code__.co_argcount==1 (funcobj); abstractmethod.__code__.co_firstlineno==7; abstractmethod is defined at module level in Lib/abc.py; this spec requires Python 3.11+ (version: '>=3.11') because co_qualname was added in 3.11; NEW in extra101: first standalone abstractmethod co_qualname invariant in abccode101 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_qualname.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra101.abstractmethod_co_firstlineno_7:
  description: "abc.abstractmethod.__code__.co_firstlineno == 7 — abstractmethod is defined at line 7 of Lib/abc.py in CPython Python 3.14.3; co_firstlineno is the line number of the first line of the function definition; abstractmethod.__code__.co_name=='abstractmethod'; abstractmethod.__code__.co_argcount==1 (funcobj); abstractmethod.__code__.co_qualname=='abstractmethod'; abstractmethod.__module__=='abc' (Python-defined); abstractmethod is a decorator function that marks a method as abstract — subclasses must override it; this value (7) is specific to Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10; NEW in extra101: first standalone abstractmethod co_firstlineno invariant in abccode101 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_firstlineno.__eq__
  args: [7]
  expected: true

invariant abc_extra101.ABCMeta_instancecheck_is_function:
  description: "abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__('function') returns True — ABCMeta.__instancecheck__ is a Python function (has __code__ attribute), unlike ABCMeta.__prepare__ and ABCMeta.__subclasshook__ which are C-level builtin_function_or_method; ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25); ABCMeta.__instancecheck__.__module__=='abc'; __instancecheck__ is called by isinstance() when checking if an object is an instance of an ABC — it checks the MRO plus registered virtual subclasses; compare: ABCMeta.__prepare__ has type 'builtin_function_or_method', but __instancecheck__ has type 'function' (Python-level); NEW in extra101: first standalone ABCMeta.__instancecheck__ type invariant in abccode101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra101.get_cache_token_is_builtin:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — get_cache_token is implemented in C (Modules/_abc.c) and has no __code__ attribute; type(get_cache_token).__name__=='builtin_function_or_method'; get_cache_token.__module__=='_abc' (C extension); get_cache_token.__qualname__=='get_cache_token' (len=15); compare: abc.abstractmethod is type 'function' (Python-defined, has __code__) while get_cache_token is type 'builtin_function_or_method' (C-defined, no __code__); also ABC.__init_subclass__ is type 'builtin_function_or_method' (C-level classmethod); ABCMeta.__instancecheck__ is type 'function' (Python-defined); the contrast between Python-level and C-level implementations in the abc module is notable; NEW in extra101: first standalone get_cache_token type invariant in abccode101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra101.ABC_init_subclass_qualname_len_21:
  description: "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — 'ABC.__init_subclass__' = 'ABC.'=4 + '__init_subclass__'=17 = 21; type(ABC.__init_subclass__).__name__=='builtin_function_or_method' (C-level inherited classmethod); compare qualname lengths in extra101: abstractmethod=14 (shortest, no class prefix), get_cache_token=15, ABC.__init_subclass__=21, ABCMeta.__instancecheck__=25 (longest); abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True; '__init_subclass__'=17 chars: '__init'=6+'_subclass'=9+'__'=2=17; ABC.__init_subclass__ is a classmethod called when ABC is subclassed; NEW in extra101: first standalone ABC.__init_subclass__ qualname length invariant in abccode101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__len__
  args: []
  expected: 21
