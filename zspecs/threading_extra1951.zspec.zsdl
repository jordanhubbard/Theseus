spec: threading_extra1951
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread, Event, Lock, Condition, Semaphore, and Barrier do NOT define __contains__ — Condition does not expose waiting-thread membership via __contains__ in its own __dict__."
    - "None of the threading classes define __iter__ or __next__ — threading primitives are synchronization objects, not iterators."
    - "None of the threading classes define __aiter__ or __anext__ — threading has no async iterator types."
    - "BoundedSemaphore, Timer, and threading.local also do not define any of the five operators."
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra1951.contains_protocol_thread_event:
  description: "threading.Thread, Event, and Lock __contains__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1951
  columns: [id, function, args, expected]
  rows:
    - ["th1951001", "threading.Thread.__dict__.__contains__", ["__contains__"], false]
    - ["th1951002", "threading.Event.__dict__.__contains__",  ["__contains__"], false]
    - ["th1951003", "threading.Lock.__dict__.__contains__",   ["__contains__"], false]

