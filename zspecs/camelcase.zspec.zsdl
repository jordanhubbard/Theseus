spec: camelcase
version: ">=6.0.0"
backend: node(camelcase)

docs: https://github.com/sindresorhus/camelcase#readme

provenance:
  derived_from:
    - "camelcase README — https://github.com/sindresorhus/camelcase#readme"
    - "Test vectors verified with camelcase@6.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "camelcase source: index.js"
  notes:
    - "camelcase exports the function as the module default (CJS in v6)."
    - "Converts strings or arrays of strings to camelCase."
    - "Spaces, hyphens, and underscores are treated as word separators."
    - "pascalCase option capitalizes the first letter."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a camelCase string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table camelcase.basic:
  kind: node_module_call_eq
  function: ~
  category: basic
  id_prefix: cc

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],   "helloWorld"]
    - [hyphen,  ["hello-world"],   "helloWorld"]

table camelcase.options:
  kind: node_module_call_eq
  function: ~
  category: options
  id_prefix: cc_opt

  columns: [id, args, expected]
  rows:
    - [pascal,  ["hello world", {"pascalCase": true}],  "HelloWorld"]

table camelcase.array:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: cc_arr

  columns: [id, args, expected]
  rows:
    - [two_words,  [["hello", "world"]],  "helloWorld"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:07:15Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
