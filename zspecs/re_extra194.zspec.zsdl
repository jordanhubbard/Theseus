spec: re_extra194
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra193.zspec.zsdl."
    - "This spec covers re.Pattern method qualnames: match, search, findall, sub, split, fullmatch, plus __name__ and __module__."
    - "re.Pattern.__name__ == 'Pattern' (len=7); confirmed Python 3.14.3 macOS."
    - "re.Pattern.__module__ == 're' (len=2); confirmed Python 3.14.3 macOS."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' (len=13); confirmed Python 3.14.3 macOS."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' (len=14); confirmed Python 3.14.3 macOS."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' (len=15); confirmed Python 3.14.3 macOS."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' (len=11); confirmed Python 3.14.3 macOS."
    - "re.Pattern.split.__qualname__ == 'Pattern.split' (len=13); same length as match; confirmed Python 3.14.3 macOS."
    - "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (len=17, longest in spec); confirmed Python 3.14.3 macOS."
    - "Qualname length ordering: sub(11) < match(13)==split(13) < search(14) < findall(15) < fullmatch(17); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern method __qualname__ equality (matching methods)
# match(13), search(14), findall(15), fullmatch(17)
# ---------------------------------------------------------------------------

table re_extra194.pattern_match_method_qualnames:
  description: "re.Pattern matching method __qualname__ values: match='Pattern.match'(13), search='Pattern.search'(14), findall='Pattern.findall'(15), fullmatch='Pattern.fullmatch'(17)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods194

  columns: [id, function, args, expected, description]
  rows:
    - [match_qn_eq,     re.Pattern.match.__qualname__.__eq__,     ["Pattern.match"],     true, "re.Pattern.match.__qualname__ == 'Pattern.match' (len=13); confirmed Python 3.14.3 macOS"]
    - [search_qn_eq,    re.Pattern.search.__qualname__.__eq__,    ["Pattern.search"],    true, "re.Pattern.search.__qualname__ == 'Pattern.search' (len=14); confirmed Python 3.14.3 macOS"]
    - [findall_qn_eq,   re.Pattern.findall.__qualname__.__eq__,   ["Pattern.findall"],   true, "re.Pattern.findall.__qualname__ == 'Pattern.findall' (len=15); confirmed Python 3.14.3 macOS"]
    - [fullmatch_qn_eq, re.Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true, "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (len=17, longest in spec); confirmed Python 3.14.3 macOS"]
    - [match_qn_len,    re.Pattern.match.__qualname__.__len__,    [],                    13,   "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.'=8+'match'=5); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern method __qualname__ equality (mutation/split methods)
# sub(11), split(13)
# ---------------------------------------------------------------------------

table re_extra194.pattern_other_method_qualnames:
  description: "re.Pattern sub/split method __qualname__ values: sub='Pattern.sub'(11), split='Pattern.split'(13)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods194

  columns: [id, function, args, expected, description]
  rows:
    - [sub_qn_eq,   re.Pattern.sub.__qualname__.__eq__,   ["Pattern.sub"],   true, "re.Pattern.sub.__qualname__ == 'Pattern.sub' (len=11, shortest in spec); confirmed Python 3.14.3 macOS"]
    - [split_qn_eq, re.Pattern.split.__qualname__.__eq__, ["Pattern.split"], true, "re.Pattern.split.__qualname__ == 'Pattern.split' (len=13, same as match); confirmed Python 3.14.3 macOS"]
    - [sub_qn_len,   re.Pattern.sub.__qualname__.__len__,   [], 11, "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.'=8+'sub'=3); shortest qualname in spec; confirmed Python 3.14.3 macOS"]
    - [split_qn_len, re.Pattern.split.__qualname__.__len__, [], 13, "re.Pattern.split.__qualname__.__len__() == 13 ('Pattern.'=8+'split'=5); same length as match; confirmed Python 3.14.3 macOS"]
    - [fullmatch_qn_len, re.Pattern.fullmatch.__qualname__.__len__, [], 17, "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.'=8+'fullmatch'=9); longest in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Pattern class-level identity and __qualname__ lengths
# __name__(Pattern,7), __module__(re,2), qualname lengths ordering
# ---------------------------------------------------------------------------

table re_extra194.pattern_class_identity_and_lengths:
  description: "re.Pattern class identity: __name__='Pattern'(7), __module__='re'(2); qualname length ordering: sub(11) < match(13)==split(13) < search(14) < findall(15) < fullmatch(17)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods194

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,           re.Pattern.__name__.__eq__,              ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (len=7); confirmed Python 3.14.3 macOS"]
    - [module_eq,         re.Pattern.__module__.__eq__,            ["re"],      true, "re.Pattern.__module__ == 're' (len=2); confirmed Python 3.14.3 macOS"]
    - [search_qn_len,     re.Pattern.search.__qualname__.__len__,  [],          14,   "re.Pattern.search.__qualname__.__len__() == 14 ('Pattern.'=8+'search'=6); confirmed Python 3.14.3 macOS"]
    - [findall_qn_len,    re.Pattern.findall.__qualname__.__len__, [],          15,   "re.Pattern.findall.__qualname__.__len__() == 15 ('Pattern.'=8+'findall'=7); confirmed Python 3.14.3 macOS"]
    - [module_len,        re.Pattern.__module__.__len__,           [],          2,    "re.Pattern.__module__.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra194.pattern_name_eq:
  description: "re.Pattern.__name__ == 'Pattern' — class name string length 7 ('Pattern'); re.Pattern is the type of compiled regular expression objects returned by re.compile(); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra194.pattern_module_eq:
  description: "re.Pattern.__module__ == 're' — Pattern objects report their module as 're' (len=2); although the implementation is in the _sre C extension, the module attribute is set to 're' so the public API is correctly attributed; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra194.pattern_match_qualname_eq:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' — the qualified name of the match method is 'Pattern.match' (len=13: 'Pattern.'=8 + 'match'=5 = 13); match tries to match the pattern at the beginning of the string; same length as split.__qualname__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra194.pattern_search_qualname_eq:
  description: "re.Pattern.search.__qualname__ == 'Pattern.search' — the qualified name of the search method is 'Pattern.search' (len=14: 'Pattern.'=8 + 'search'=6 = 14); search scans through the string looking for the first location where the pattern produces a match; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.search.__qualname__.__eq__
  args: ["Pattern.search"]
  expected: true

invariant re_extra194.pattern_findall_qualname_eq:
  description: "re.Pattern.findall.__qualname__ == 'Pattern.findall' — the qualified name of the findall method is 'Pattern.findall' (len=15: 'Pattern.'=8 + 'findall'=7 = 15); findall returns all non-overlapping matches of the pattern in the string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.findall.__qualname__.__eq__
  args: ["Pattern.findall"]
  expected: true

invariant re_extra194.pattern_sub_qualname_eq:
  description: "re.Pattern.sub.__qualname__ == 'Pattern.sub' — the qualified name of the sub method is 'Pattern.sub' (len=11: 'Pattern.'=8 + 'sub'=3 = 11); sub is the shortest qualname in this spec; sub returns the string obtained by replacing the leftmost non-overlapping occurrences of the pattern; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.sub.__qualname__.__eq__
  args: ["Pattern.sub"]
  expected: true

invariant re_extra194.pattern_split_qualname_eq:
  description: "re.Pattern.split.__qualname__ == 'Pattern.split' — the qualified name of the split method is 'Pattern.split' (len=13: 'Pattern.'=8 + 'split'=5 = 13); split splits the string by occurrences of the pattern; split.__qualname__ has the same length as match.__qualname__ (both 13); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.split.__qualname__.__eq__
  args: ["Pattern.split"]
  expected: true

invariant re_extra194.pattern_fullmatch_qualname_eq:
  description: "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' — the qualified name of the fullmatch method is 'Pattern.fullmatch' (len=17: 'Pattern.'=8 + 'fullmatch'=9 = 17); this is the longest qualname in the spec; fullmatch tries to apply the pattern to the entire string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.fullmatch.__qualname__.__eq__
  args: ["Pattern.fullmatch"]
  expected: true
