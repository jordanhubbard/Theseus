spec: socket_extra646
version: ">=3.9"
backend: python_module(socket)
docs: "Behavioral spec for socket top-level function __doc__ types and constant class identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __doc__.__class__.__name__ identity for gethostname, gethostbyname, getaddrinfo, getnameinfo, socket, timeout, herror, gaierror; and __class__.__name__ for AF_INET, AF_INET6, AF_UNIX, SOCK_STREAM, SOCK_DGRAM constants."
  created_at: "2026-04-12T00:00:00Z"

table socket_extra646.function_doc_class_identity:
  description: "Verifies that top-level socket functions and exceptions have str-typed __doc__."
  kind: python_call_eq
  category: doc_identity
  id_prefix: sk646fn
  columns: [id, function, args, expected]
  rows:
    - [sk646fn001, socket.gethostname.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk646fn002, socket.gethostbyname.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk646fn003, socket.getaddrinfo.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk646fn004, socket.getnameinfo.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk646fn005, socket.socket.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk646fn006, socket.timeout.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk646fn007, socket.herror.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk646fn008, socket.gaierror.__doc__.__class__.__name__.__eq__, ["str"], true]

table socket_extra646.constant_class_identity:
  description: "Verifies __class__.__name__ for AF_INET, AF_INET6, AF_UNIX, SOCK_STREAM, and SOCK_DGRAM constants."
  kind: python_call_eq
  category: constant_identity
  id_prefix: sk646dc
  columns: [id, function, args, expected]
  rows:
    - [sk646dc001, socket.AF_INET.__class__.__name__.__eq__, ["AddressFamily"], true]
    - [sk646dc002, socket.AF_INET6.__class__.__name__.__eq__, ["AddressFamily"], true]
    - [sk646dc003, socket.AF_UNIX.__class__.__name__.__eq__, ["AddressFamily"], true]
    - [sk646dc004, socket.SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"], true]
    - [sk646dc005, socket.SOCK_DGRAM.__class__.__name__.__eq__, ["SocketKind"], true]
