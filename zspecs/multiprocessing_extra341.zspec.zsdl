spec: multiprocessing_extra341
version: ">=3.9"
backend: python_module(multiprocessing.pool)
docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — multiprocessing.pool documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All pool classes live in module multiprocessing.pool"
    - "Pool derives directly from object"
    - "AsyncResult's internal class name is ApplyResult (Pool.apply_async returns an ApplyResult)"
    - "MapResult derives from ApplyResult"
    - "IMapIterator derives directly from object"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra341.class_names:
  description: "Verify __name__ attribute of multiprocessing.pool classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp341n

  columns: [id, function, args, expected]
  rows:
    - [mp341n001, multiprocessing.pool.Pool.__name__.__eq__, ["Pool"], true]
    - [mp341n002, multiprocessing.pool.AsyncResult.__name__.__eq__, ["ApplyResult"], true]
    - [mp341n003, multiprocessing.pool.MapResult.__name__.__eq__, ["MapResult"], true]
    - [mp341n004, multiprocessing.pool.IMapIterator.__name__.__eq__, ["IMapIterator"], true]

table multiprocessing_extra341.class_modules:
  description: "Verify __module__ attribute of multiprocessing.pool classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp341m

  columns: [id, function, args, expected]
  rows:
    - [mp341m001, multiprocessing.pool.Pool.__module__.__eq__, ["multiprocessing.pool"], true]
    - [mp341m002, multiprocessing.pool.AsyncResult.__module__.__eq__, ["multiprocessing.pool"], true]
    - [mp341m003, multiprocessing.pool.MapResult.__module__.__eq__, ["multiprocessing.pool"], true]
    - [mp341m004, multiprocessing.pool.IMapIterator.__module__.__eq__, ["multiprocessing.pool"], true]

table multiprocessing_extra341.class_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of multiprocessing.pool classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp341b

  columns: [id, function, args, expected]
  rows:
    - [mp341b001, "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__", ["object"], true]
    - [mp341b002, "multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__", ["object"], true]
    - [mp341b003, "multiprocessing.pool.MapResult.__bases__[0].__name__.__eq__", ["ApplyResult"], true]
    - [mp341b004, "multiprocessing.pool.IMapIterator.__bases__[0].__name__.__eq__", ["object"], true]
