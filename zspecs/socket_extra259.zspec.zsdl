spec: socket_extra259
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra258.zspec.zsdl — covers getfqdn/gethostname/gethostbyaddr/getservbyname/getservbyport function identity."
    - "_socket_extra.zspec.zsdl — covers IPPROTO_TCP.__class__.__name__=='int' and IPPROTO_TCP==6; IPPROTO_UDP==17 is covered in _socket.zspec.zsdl."
  notes:
    - "socket.create_connection is a pure-Python function defined in Lib/socket.py; __module__ == 'socket', __class__.__name__ == 'function'."
    - "socket.create_server is a pure-Python function defined in Lib/socket.py; __module__ == 'socket', __class__.__name__ == 'function'."
    - "socket.has_dualstack_ipv6 is a pure-Python function defined in Lib/socket.py; __module__ == 'socket', __class__.__name__ == 'function'."
    - "All three functions are module-level; their __qualname__ equals __name__."
    - "socket.IPPROTO_TCP == 6 (IANA TCP protocol number); socket.IPPROTO_UDP == 17 (IANA UDP protocol number); socket.IPPROTO_IP == 0 (dummy protocol for IP)."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int' — these constants are plain int values in the socket module (not IntEnum members at the socket level)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.create_connection function identity (pure Python, Lib/socket.py)
# ---------------------------------------------------------------------------

table socket_extra259.create_connection_identity:
  description: "socket.create_connection function identity — pure Python function from Lib/socket.py; __module__=='socket', __class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockcc259

  columns: [id, function, args, expected, description]
  rows:
    - [cc_name,     create_connection.__name__.__eq__,              ["create_connection"], true, "socket.create_connection.__name__ == 'create_connection'"]
    - [cc_qualname, create_connection.__qualname__.__eq__,          ["create_connection"], true, "socket.create_connection.__qualname__ == 'create_connection' (module-level function)"]
    - [cc_module,   create_connection.__module__.__eq__,            ["socket"],            true, "socket.create_connection.__module__ == 'socket' (pure Python in Lib/socket.py)"]
    - [cc_class,    create_connection.__class__.__name__.__eq__,    ["function"],          true, "socket.create_connection.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# socket.create_server function identity (pure Python, Lib/socket.py)
# ---------------------------------------------------------------------------

table socket_extra259.create_server_identity:
  description: "socket.create_server function identity — pure Python function from Lib/socket.py; __module__=='socket', __class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockcs259

  columns: [id, function, args, expected, description]
  rows:
    - [cs_name,     create_server.__name__.__eq__,              ["create_server"], true, "socket.create_server.__name__ == 'create_server'"]
    - [cs_qualname, create_server.__qualname__.__eq__,          ["create_server"], true, "socket.create_server.__qualname__ == 'create_server' (module-level function)"]
    - [cs_module,   create_server.__module__.__eq__,            ["socket"],        true, "socket.create_server.__module__ == 'socket' (pure Python in Lib/socket.py)"]
    - [cs_class,    create_server.__class__.__name__.__eq__,    ["function"],      true, "socket.create_server.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# socket.has_dualstack_ipv6 function identity (pure Python, Lib/socket.py)
# ---------------------------------------------------------------------------

invariant socket_extra259.has_dualstack_ipv6.name:
  description: "socket.has_dualstack_ipv6.__name__ == 'has_dualstack_ipv6'"
  category: identity
  kind: python_call_eq
  function: has_dualstack_ipv6.__name__.__eq__
  args: ["has_dualstack_ipv6"]
  expected: true

invariant socket_extra259.has_dualstack_ipv6.qualname:
  description: "socket.has_dualstack_ipv6.__qualname__ == 'has_dualstack_ipv6' (module-level function)"
  category: identity
  kind: python_call_eq
  function: has_dualstack_ipv6.__qualname__.__eq__
  args: ["has_dualstack_ipv6"]
  expected: true

invariant socket_extra259.has_dualstack_ipv6.class_name:
  description: "socket.has_dualstack_ipv6.__class__.__name__ == 'function' (pure Python function)"
  category: identity
  kind: python_call_eq
  function: has_dualstack_ipv6.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# IPPROTO_TCP, IPPROTO_UDP, IPPROTO_IP — constant values and class name
#
# IPPROTO_TCP == 6 (IANA), IPPROTO_UDP == 17 (IANA), IPPROTO_IP == 0.
# At the socket module level these are plain int constants.
# ---------------------------------------------------------------------------

table socket_extra259.ipproto_constants:
  description: "socket.IPPROTO_TCP==6 / IPPROTO_UDP==17 / IPPROTO_IP==0; all plain int constants; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: sockproto259

  columns: [id, function, args, expected, description]
  rows:
    - [tcp_value,   IPPROTO_TCP.__eq__,              [6],    true, "socket.IPPROTO_TCP == 6 (IANA TCP protocol number)"]
    - [udp_value,   IPPROTO_UDP.__eq__,              [17],   true, "socket.IPPROTO_UDP == 17 (IANA UDP protocol number)"]
    - [ip_value,    IPPROTO_IP.__eq__,               [0],    true, "socket.IPPROTO_IP == 0 (dummy protocol for IP)"]
    - [tcp_class,   IPPROTO_TCP.__class__.__name__.__eq__,   ["int"], true, "socket.IPPROTO_TCP.__class__.__name__ == 'int'"]
