spec: struct_extra100
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality and lengths / struct module __doc__ length (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / descriptor qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6 (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__() (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / error __bases__/__module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 267 theme: Struct instance method qualname lengths / module-level function qualname lengths cross-check / Struct class-level method_descriptor qualnames."
    - "struct.Struct('I').pack.__qualname__.__len__() == 11 ('Struct.pack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').unpack.__qualname__.__len__() == 13 ('Struct.unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').pack_into.__qualname__.__len__() == 16 ('Struct.pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').unpack_from.__qualname__.__len__() == 18 ('Struct.unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').iter_unpack.__qualname__.__len__() == 18 ('Struct.iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__.__len__() == 4 ('pack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__.__len__() == 6 ('unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__.__len__() == 8 ('calcsize'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__.__len__() == 9 ('pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__.__len__() == 11 ('unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__.__len__() == 11 ('iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct instance methods are builtin_function_or_method (bound); Struct class-level methods are method_descriptor. Both have the same __qualname__ with 'Struct.' prefix."
    - "Note: Module-level function qualnames lack the 'Struct.' prefix since they are standalone functions: pack=4, unpack=6, calcsize=8, pack_into=9, unpack_from=11, iter_unpack=11."
    - "Note: struct_extra94 anchors Struct class-level method __qualname__.__len__() values (same values since class and instance qualnames agree); this spec confirms at instance level."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct('I').pack.__qualname__.__len__()==11
# struct.Struct('I').unpack.__qualname__.__len__()==13
# struct.Struct('I').pack_into.__qualname__.__len__()==16
# struct.Struct('I').unpack_from.__qualname__.__len__()==18
# struct.Struct('I').iter_unpack.__qualname__.__len__()==18
#
# Wave 267 theme: Struct instance method qualname lengths.
#
# Struct instance methods are bound builtin_function_or_method objects with
# __qualname__ values using the 'Struct.' prefix: pack=11, unpack=13,
# pack_into=16, unpack_from=18, iter_unpack=18. unpack_from and iter_unpack
# share length 18. struct_extra94 anchors class-level Struct method
# __qualname__.__len__() values; these instance-level values agree.
# No prior struct spec anchors instance-level Struct method qualname lengths
# as a grouped table under structmeth100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra100.Struct_instance_method_qlen:
  description: "Struct('I').pack/__qualname__/__len__()==11 / unpack/__qualname__/__len__()==13 / pack_into/__qualname__/__len__()==16 / unpack_from/__qualname__/__len__()==18 / iter_unpack/__qualname__/__len__()==18 — instance methods are builtin_function_or_method; qualnames use 'Struct.' prefix (7 chars including dot); pack=11, unpack=13, pack_into=16, unpack_from==iter_unpack==18; extra94 anchors class-level values; first structmeth100 instance-level anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structmeth100

  columns: [id, function, args, expected, description]
  rows:
    - [pack_inst_qlen,        "Struct.__new__(Struct, 'I').pack.__qualname__.__len__",        [], 11, "'Struct.pack' is 11 chars ('Struct.' 7 + 'pack' 4)"]
    - [unpack_inst_qlen,      "Struct.__new__(Struct, 'I').unpack.__qualname__.__len__",      [], 13, "'Struct.unpack' is 13 chars ('Struct.' 7 + 'unpack' 6)"]
    - [pack_into_inst_qlen,   "Struct.__new__(Struct, 'I').pack_into.__qualname__.__len__",   [], 16, "'Struct.pack_into' is 16 chars ('Struct.' 7 + 'pack_into' 9)"]
    - [unpack_from_inst_qlen, "Struct.__new__(Struct, 'I').unpack_from.__qualname__.__len__", [], 18, "'Struct.unpack_from' is 18 chars ('Struct.' 7 + 'unpack_from' 11)"]
    - [iter_unpack_inst_qlen, "Struct.__new__(Struct, 'I').iter_unpack.__qualname__.__len__", [], 18, "'Struct.iter_unpack' is 18 chars ('Struct.' 7 + 'iter_unpack' 11)"]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__len__()==4
# struct.unpack.__qualname__.__len__()==6
# struct.calcsize.__qualname__.__len__()==8
# struct.pack_into.__qualname__.__len__()==9
# struct.unpack_from.__qualname__.__len__()==11
# struct.iter_unpack.__qualname__.__len__()==11
#
# Wave 267 theme: module-level function qualname lengths.
#
# Module-level struct functions lack the 'Struct.' prefix in their qualname
# since they are standalone C builtins. pack=4, unpack=6, calcsize=8,
# pack_into=9, unpack_from=11, iter_unpack=11. unpack_from and iter_unpack
# share qualname length 11. struct_extra95 anchors pack_into/unpack_from/
# iter_unpack __qualname__.__len__(); struct_extra94 anchors their values
# in a table mixing method and function qualnames. This table groups only
# module-level function qualname lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra100.module_fn_qualname_lengths:
  description: "struct.pack/__qualname__/__len__()==4 / unpack/__qualname__/__len__()==6 / calcsize/__qualname__/__len__()==8 / pack_into/__qualname__/__len__()==9 / unpack_from/__qualname__/__len__()==11 / iter_unpack/__qualname__/__len__()==11 — module-level functions have no 'Struct.' prefix; pack=4, unpack=6, calcsize=8, pack_into=9, unpack_from==iter_unpack==11; extra95 anchors pack_into/unpack_from/iter_unpack values; first structmeth100 anchor grouping all six module-level qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structmeth100

  columns: [id, function, args, expected, description]
  rows:
    - [pack_fn_qlen,        pack.__qualname__.__len__,        [], 4,  "'pack' is 4 chars (shortest module-level struct function qualname)"]
    - [unpack_fn_qlen,      unpack.__qualname__.__len__,      [], 6,  "'unpack' is 6 chars"]
    - [calcsize_fn_qlen,    calcsize.__qualname__.__len__,    [], 8,  "'calcsize' is 8 chars"]
    - [pack_into_fn_qlen,   pack_into.__qualname__.__len__,   [], 9,  "'pack_into' is 9 chars"]
    - [unpack_from_fn_qlen, unpack_from.__qualname__.__len__,  [], 11, "'unpack_from' is 11 chars (tied with iter_unpack)"]
    - [iter_unpack_fn_qlen, iter_unpack.__qualname__.__len__,  [], 11, "'iter_unpack' is 11 chars (tied with unpack_from)"]

# ---------------------------------------------------------------------------
# type(struct.Struct.pack).__name__.__eq__('method_descriptor')
# type(struct.Struct.unpack).__name__.__eq__('method_descriptor')
# type(struct.Struct.pack_into).__name__.__eq__('method_descriptor')
# type(struct.Struct.unpack_from).__name__.__eq__('method_descriptor')
# type(struct.Struct.iter_unpack).__name__.__eq__('method_descriptor')
#
# Wave 267 theme: Struct class-level method types.
#
# At the class level, Struct methods are method_descriptor objects (a C-level
# slot-wrapper type). At the instance level they become builtin_function_or_method.
# struct_extra92 anchors Struct method __class__.__name__ == 'method-wrapper' and
# 'builtin_function_or_method' (instance-level); no prior struct spec anchors
# class-level method_descriptor type names under structmeth100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra100.Struct_class_method_types:
  description: "type(Struct.pack).__name__=='method_descriptor' / type(Struct.unpack).__name__=='method_descriptor' / type(Struct.pack_into).__name__=='method_descriptor' / type(Struct.unpack_from).__name__=='method_descriptor' / type(Struct.iter_unpack).__name__=='method_descriptor' — at class level Struct methods are method_descriptor (C slot-wrapper); at instance level they become builtin_function_or_method; extra92 anchors instance-level class names; first structmeth100 anchor for class-level method_descriptor type"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmeth100

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class_type,        "Struct.pack.__class__.__name__.__eq__",        ["method_descriptor"], true, "Struct.pack at class level is a method_descriptor (C slot-wrapper)"]
    - [unpack_class_type,      "Struct.unpack.__class__.__name__.__eq__",      ["method_descriptor"], true, "Struct.unpack at class level is a method_descriptor"]
    - [pack_into_class_type,   "Struct.pack_into.__class__.__name__.__eq__",   ["method_descriptor"], true, "Struct.pack_into at class level is a method_descriptor"]
    - [unpack_from_class_type, "Struct.unpack_from.__class__.__name__.__eq__", ["method_descriptor"], true, "Struct.unpack_from at class level is a method_descriptor"]
    - [iter_unpack_class_type, "Struct.iter_unpack.__class__.__name__.__eq__", ["method_descriptor"], true, "Struct.iter_unpack at class level is a method_descriptor"]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__len__()==4 — standalone
#
# struct.pack.__qualname__.__len__() is 4. struct.pack is a C builtin function
# from _struct.c. Its __qualname__ is 'pack' (4 chars) — the same as its
# __name__. The short qualname 'pack' distinguishes it from the Struct
# instance method whose qualname is 'Struct.pack' (11 chars). struct_extra94
# anchors struct.pack.__qualname__.__len__() at the table level (mixing it
# with Struct method qualname lengths); no prior struct spec anchors
# struct.pack.__qualname__.__len__() as a standalone under structmeth100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra100.pack_fn_qualname_len_4:
  description: "struct.pack.__qualname__.__len__() == 4 — struct.pack qualname is 'pack' (4 chars); same as __name__; distinguishes from Struct.pack instance method qualname 'Struct.pack' (11 chars); extra94 anchors at table level; first standalone for struct.pack.__qualname__.__len__() under structmeth100"
  category: qualname_lengths
  kind: python_call_eq
  function: pack.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.pack.__class__.__name__ is 'method_descriptor'. At the class
# level, Struct.pack is a method_descriptor — the C-level descriptor type that
# binds the C method implementation to the class. When accessed on an instance,
# this descriptor creates a bound builtin_function_or_method. struct_extra92
# anchors instance-level Struct method __class__.__name__; no prior struct spec
# anchors Struct.pack class-level method_descriptor as a standalone under
# structmeth100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra100.Struct_pack_class_method_descriptor:
  description: "struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') == True — Struct.pack at class level is a method_descriptor; C-level descriptor type that creates bound builtin_function_or_method when accessed on instance; extra92 anchors instance-level class names; first standalone for Struct.pack class-level type under structmeth100"
  category: type_identity
  kind: python_call_eq
  function: "Struct.pack.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__qualname__.__len__()==11 — standalone
#
# struct.unpack_from.__qualname__.__len__() is 11. struct.unpack_from is a
# C builtin function that unpacks data from a buffer at a given byte offset.
# Its __qualname__ is 'unpack_from' (11 chars), tied with iter_unpack for
# the longest module-level function qualname. struct_extra95 anchors
# struct.unpack_from.__qualname__.__len__()==11 at the table level (as part
# of a pack_into/unpack_from/iter_unpack group); no prior struct spec anchors
# it as a standalone under structmeth100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra100.unpack_from_qualname_len_11:
  description: "struct.unpack_from.__qualname__.__len__() == 11 — qualname 'unpack_from' is 11 chars; tied with iter_unpack for longest module-level struct function qualname; C builtin unpacking from buffer at given byte offset; extra95 anchors at table level; first standalone for unpack_from qualname length under structmeth100"
  category: qualname_lengths
  kind: python_call_eq
  function: unpack_from.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.Struct.__mro__.__len__()==2 — standalone
#
# struct.Struct.__mro__.__len__() is 2. Struct is a C type from _struct.c
# and its MRO is (Struct, object) — the minimal depth 2. struct_extra93
# anchors Struct.__mro__.__len__()==2 and Struct.__bases__[0].__name__=='object'
# at the table level; no prior struct spec anchors Struct.__mro__.__len__()==2
# as a standalone under structmeth100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra100.Struct_mro_len_2:
  description: "struct.Struct.__mro__.__len__() == 2 — Struct MRO is (Struct, object) depth 2; minimal MRO for a C type; inherits directly from object; extra93 anchors at table level with __bases__[0] check; first standalone for Struct.__mro__.__len__()==2 under structmeth100"
  category: type_identity
  kind: python_call_eq
  function: Struct.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# struct.calcsize.__qualname__.__len__()==8 — standalone
#
# struct.calcsize.__qualname__.__len__() is 8. calcsize is a C builtin function
# that returns the number of bytes required to pack a given format string. Its
# __qualname__ is 'calcsize' (8 chars). Among the six module-level struct
# functions, calcsize has the shortest docstring (66 chars) but a mid-range
# qualname length (between unpack=6 and pack_into=9). struct_extra94 anchors
# calcsize.__qualname__.__len__() as part of a larger table; no prior struct
# spec anchors it as a standalone under structmeth100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra100.calcsize_qualname_len_8:
  description: "struct.calcsize.__qualname__.__len__() == 8 — qualname 'calcsize' is 8 chars; C builtin returning byte count for a packed format string; among the six module-level struct functions: pack=4, unpack=6, calcsize=8, pack_into=9, unpack_from=iter_unpack=11; extra94 anchors at table level; first standalone for calcsize qualname length under structmeth100"
  category: qualname_lengths
  kind: python_call_eq
  function: calcsize.__qualname__.__len__
  args: []
  expected: 8

