spec: abc_extra486
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module abstractmethod and helper class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers identity of abstractmethod decorator and legacy abstract helper classes"
    - "abstractclassmethod, abstractstaticmethod, and abstractproperty are deprecated since 3.3 but remain in the module"
    - "abc.ABC.__doc__ is a non-None string"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra486.abstractmethod_identity:
  description: "abc.abstractmethod decorator identity"
  kind: python_call_eq
  category: identity
  id_prefix: AM

  columns: [id, function, args, expected]
  rows:
    - [AM001, abc.abstractmethod.__name__.__eq__, ["abstractmethod"], true]
    - [AM002, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [AM003, abc.abstractmethod.__module__.__eq__, ["abc"], true]
    - [AM004, abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra486.abstractclassmethod_identity:
  description: "abc.abstractclassmethod class identity and inheritance"
  kind: python_call_eq
  category: identity
  id_prefix: ACM

  columns: [id, function, args, expected]
  rows:
    - [ACM001, abc.abstractclassmethod.__name__.__eq__, ["abstractclassmethod"], true]
    - [ACM002, "abc.abstractclassmethod.__bases__[0].__name__.__eq__", ["classmethod"], true]

table abc_extra486.abstractstaticmethod_identity:
  description: "abc.abstractstaticmethod class identity and inheritance"
  kind: python_call_eq
  category: identity
  id_prefix: ASM

  columns: [id, function, args, expected]
  rows:
    - [ASM001, abc.abstractstaticmethod.__name__.__eq__, ["abstractstaticmethod"], true]
    - [ASM002, "abc.abstractstaticmethod.__bases__[0].__name__.__eq__", ["staticmethod"], true]

table abc_extra486.abstractproperty_identity:
  description: "abc.abstractproperty class identity and inheritance"
  kind: python_call_eq
  category: identity
  id_prefix: APR

  columns: [id, function, args, expected]
  rows:
    - [APR001, abc.abstractproperty.__name__.__eq__, ["abstractproperty"], true]
    - [APR002, "abc.abstractproperty.__bases__[0].__name__.__eq__", ["property"], true]

table abc_extra486.abc_class_identity:
  description: "abc.ABC helper class identity"
  kind: python_call_eq
  category: identity
  id_prefix: ABC

  columns: [id, function, args, expected]
  rows:
    - [ABC001, abc.ABC.__doc__.__class__.__name__.__eq__, ["str"], true]
