spec: http_client_extra11
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra2.zspec.zsdl — covers __qualname__.__eq__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected/InvalidURL; __module__.__eq__ for HTTPException/HTTPResponse/NotConnected/InvalidURL."
    - "http_client_extra9.zspec.zsdl — covers __name__.__len__() for HTTPSConnection/HTTPResponse/HTTPConnection/BadStatusLine/LineTooLong; __bases__[0].__name__ for HTTPSConnection/HTTPResponse/LineTooLong."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected; __module__.__len__()==11 for HTTPConnection/HTTPSConnection/HTTPException."
  notes:
    - "This spec extends the http.client chain through http_client_extra10; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__eq__ for HTTPConnection and HTTPResponse instance methods — no prior http.client spec checks the __qualname__ of any instance method. http_client_extra2 covers __qualname__.__eq__ for the classes themselves, but not for their methods."
    - "Covered methods: HTTPConnection.request (qualname 'HTTPConnection.request'), HTTPConnection.getresponse ('HTTPConnection.getresponse'), HTTPConnection.connect ('HTTPConnection.connect'), HTTPConnection.close ('HTTPConnection.close'), HTTPResponse.read ('HTTPResponse.read'), HTTPResponse.getheader ('HTTPResponse.getheader')."
    - "http.client.HTTPConnection.request.__qualname__ == 'HTTPConnection.request' — len == 22. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.getresponse.__qualname__ == 'HTTPConnection.getresponse' — len == 26. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.connect.__qualname__ == 'HTTPConnection.connect' — len == 22. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.close.__qualname__ == 'HTTPConnection.close' — len == 20. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.read.__qualname__ == 'HTTPResponse.read' — len == 17. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.getheader.__qualname__ == 'HTTPResponse.getheader' — len == 22. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPConnection instance method __qualname__.__eq__ checks
#
# http_client_extra2 covers __qualname__.__eq__ for HTTPConnection the class
# ('HTTPConnection'), but not for any of its methods.
# No prior http.client spec checks the __qualname__ of any instance method.
# Method qualnames take the form 'ClassName.method_name'.
# ---------------------------------------------------------------------------

table http_client_extra11.http_connection_method_qualnames:
  description: "__qualname__.__eq__ for HTTPConnection instance methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hcmqn11

  columns: [id, function, args, expected]
  rows:
    - [request,     HTTPConnection.request.__qualname__.__eq__,     ["HTTPConnection.request"],     true]
    - [getresponse, HTTPConnection.getresponse.__qualname__.__eq__, ["HTTPConnection.getresponse"], true]
    - [connect,     HTTPConnection.connect.__qualname__.__eq__,     ["HTTPConnection.connect"],     true]
    - [close,       HTTPConnection.close.__qualname__.__eq__,       ["HTTPConnection.close"],       true]

# ---------------------------------------------------------------------------
# HTTPResponse instance method __qualname__.__eq__ checks
#
# http_client_extra2 covers __qualname__.__eq__ for HTTPResponse the class
# ('HTTPResponse'), but not for any of its methods.
# No prior http.client spec checks the __qualname__ of any HTTPResponse method.
# ---------------------------------------------------------------------------

table http_client_extra11.http_response_method_qualnames:
  description: "__qualname__.__eq__ for HTTPResponse instance methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hrmqn11

  columns: [id, function, args, expected]
  rows:
    - [read,      HTTPResponse.read.__qualname__.__eq__,      ["HTTPResponse.read"],      true]
    - [getheader, HTTPResponse.getheader.__qualname__.__eq__, ["HTTPResponse.getheader"], true]

# ---------------------------------------------------------------------------
# HTTPConnection and HTTPResponse method __qualname__.__len__() checks
#
# No prior http.client spec checks __qualname__.__len__ for any instance
# method (http_client_extra10 only checks class-level __qualname__.__len__).
# Lengths: 'HTTPConnection.request'==22, 'HTTPConnection.getresponse'==26,
# 'HTTPConnection.connect'==22, 'HTTPConnection.close'==20,
# 'HTTPResponse.read'==17, 'HTTPResponse.getheader'==22.
# ---------------------------------------------------------------------------

table http_client_extra11.method_qualname_lengths:
  description: "Length of __qualname__ strings for HTTPConnection and HTTPResponse methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: mqlen11

  columns: [id, function, args, expected]
  rows:
    - [request,     HTTPConnection.request.__qualname__.__len__,     [], 22]
    - [getresponse, HTTPConnection.getresponse.__qualname__.__len__, [], 26]
    - [connect,     HTTPConnection.connect.__qualname__.__len__,     [], 22]
    - [close,       HTTPConnection.close.__qualname__.__len__,       [], 20]
    - [read,        HTTPResponse.read.__qualname__.__len__,          [], 17]
    - [getheader,   HTTPResponse.getheader.__qualname__.__len__,     [], 22]
