spec: asyncio_extra2821
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronisation primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task and future documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "asyncio_extra.zspec.zsdl — covers __name__ and __module__ checks for Queue, Task, Future, Lock, Event, Semaphore, Condition"
    - "asyncio_extra2.zspec.zsdl — covers module checks for event loop classes and exception classes"
    - "asyncio_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "None of the asyncio synchronisation or task primitives define __radd__, __rsub__, or __rmul__ in their __dict__."
    - "Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier are async coordination primitives, not numeric types."
    - "asyncio.Barrier was added in Python 3.11; version constraint >=3.9 applies to all other types."
    - "All eight types checked: Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue, asyncio.Task, asyncio.Future — __radd__/__rsub__/__rmul__
# dict-presence checks
#
# Queue is an async FIFO queue; Task wraps a coroutine; Future is a low-level
# awaitable. None of them define reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2821.queue_task_future_operator_dict:
  description: "asyncio.Queue, Task, Future __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2821qtf

  columns: [id, function, args, expected]
  rows:
    - ["as2821qtf_q_rad",  Queue.__dict__.__contains__,  ["__radd__"],  false]
    - ["as2821qtf_q_rsb",  Queue.__dict__.__contains__,  ["__rsub__"],  false]
    - ["as2821qtf_q_rml",  Queue.__dict__.__contains__,  ["__rmul__"],  false]
    - ["as2821qtf_t_rad",  Task.__dict__.__contains__,   ["__radd__"],  false]
    - ["as2821qtf_t_rsb",  Task.__dict__.__contains__,   ["__rsub__"],  false]
    - ["as2821qtf_t_rml",  Task.__dict__.__contains__,   ["__rmul__"],  false]
    - ["as2821qtf_f_rad",  Future.__dict__.__contains__, ["__radd__"],  false]
    - ["as2821qtf_f_rsb",  Future.__dict__.__contains__, ["__rsub__"],  false]
    - ["as2821qtf_f_rml",  Future.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# asyncio.Lock, asyncio.Event, asyncio.Semaphore — __radd__/__rsub__/__rmul__
# dict-presence checks
#
# Lock, Event, and Semaphore are async synchronisation primitives defined in
# asyncio.locks. They do not implement reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2821.lock_event_semaphore_operator_dict:
  description: "asyncio.Lock, Event, Semaphore __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2821les

  columns: [id, function, args, expected]
  rows:
    - ["as2821les_l_rad",  Lock.__dict__.__contains__,      ["__radd__"],  false]
    - ["as2821les_l_rsb",  Lock.__dict__.__contains__,      ["__rsub__"],  false]
    - ["as2821les_l_rml",  Lock.__dict__.__contains__,      ["__rmul__"],  false]
    - ["as2821les_e_rad",  Event.__dict__.__contains__,     ["__radd__"],  false]
    - ["as2821les_e_rsb",  Event.__dict__.__contains__,     ["__rsub__"],  false]
    - ["as2821les_e_rml",  Event.__dict__.__contains__,     ["__rmul__"],  false]
    - ["as2821les_s_rad",  Semaphore.__dict__.__contains__, ["__radd__"],  false]
    - ["as2821les_s_rsb",  Semaphore.__dict__.__contains__, ["__rsub__"],  false]
    - ["as2821les_s_rml",  Semaphore.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# asyncio.Condition and asyncio.Barrier — __radd__/__rsub__/__rmul__
# dict-presence checks
#
# Condition is a combination lock/condition variable. Barrier (added in 3.11)
# is a synchronisation barrier. Neither defines reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2821.condition_barrier_operator_dict:
  description: "asyncio.Condition and Barrier __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2821cb

  columns: [id, function, args, expected]
  rows:
    - ["as2821cb_c_rad",  Condition.__dict__.__contains__, ["__radd__"],  false]
    - ["as2821cb_c_rsb",  Condition.__dict__.__contains__, ["__rsub__"],  false]
    - ["as2821cb_c_rml",  Condition.__dict__.__contains__, ["__rmul__"],  false]
    - ["as2821cb_b_rad",  Barrier.__dict__.__contains__,   ["__radd__"],  false]
    - ["as2821cb_b_rsb",  Barrier.__dict__.__contains__,   ["__rsub__"],  false]
    - ["as2821cb_b_rml",  Barrier.__dict__.__contains__,   ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# Full 8×3 cross-type matrix — all asyncio types, all three reflected arithmetic operator dunders
#
# Consolidates the full 8×3 dict-presence check in one table.
# Every cell is False: Queue, Task, Future, Lock, Event, Semaphore, Condition,
# and Barrier do not define +, -, or * reflected operator dunders.
# ---------------------------------------------------------------------------

