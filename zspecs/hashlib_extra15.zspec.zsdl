spec: hashlib_extra15
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions, August 2015"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC, November 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_sha3/sha3module.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "This spec extends hashlib through hashlib_extra14; it does NOT duplicate invariants present in those files."
    - "hashlib_extra14 covers: algorithms_guaranteed/available class_name=='set'; new('md5'/'sha1'/'sha512'/'sha3_256') block_size; new('sha256') class_name=='HASH'; sha256().copy() name/digest_size/block_size; sha256/md5/sha1 hexdigest for b'abc'."
    - "hashlib_extra13 covers: sha3_256/__name__/__qualname__/__module__; shake_256 attrs; new('sha3_256').name; new('sha384'/'sha224') digest_size; algorithms_guaranteed contains 'sha3_224'."
    - "hashlib_extra6 covers: sha3_256 digest_size==32 and block_size==136 via method_chain on sha3_256() object."
    - "NOT yet covered: new('sha3_256').digest_size == 32 as standalone python_call_eq from extra15 namespace."
    - "NOT yet covered: new('sha3_512').digest_size == 64 as standalone python_call_eq from extra15 namespace."
    - "NOT yet covered: new('blake2b').digest_size == 64 as standalone invariant from extra15 namespace."
    - "NOT yet covered: new('sha3_512').block_size == 72 as standalone invariant."
    - "NOT yet covered: new('blake2b').block_size == 128 as standalone invariant."
    - "NOT yet covered: new('shake_128').digest_size == 0 (variable-output XOF) as standalone invariant."
    - "NOT yet covered: new('shake_128').block_size == 168 as standalone invariant."
    - "NOT yet covered: new('sha3_256').name == 'sha3_256' from extra15 namespace."
    - "NOT yet covered: new('sha3_512').name == 'sha3_512' from extra15 namespace."
    - "NOT yet covered: new('blake2b').name == 'blake2b' from extra15 namespace."
    - "NOT yet covered: pbkdf2_hmac.__name__ == 'pbkdf2_hmac' as standalone invariant."
    - "NOT yet covered: pbkdf2_hmac.__module__ == '_hashlib' as standalone invariant."
    - "NOT yet covered: algorithms_guaranteed contains 'sha3_512' as standalone invariant."
    - "NOT yet covered: algorithms_guaranteed contains 'blake2b' as standalone invariant."
    - "NOT yet covered: algorithms_guaranteed contains 'shake_128' as standalone invariant."
    - "NOT yet covered: sha3_512(b'abc').hexdigest() known value (FIPS 202)."
    - "shake_128 digest_size == 0 because SHAKE-128 is a variable-length XOF; the property returns 0 per Python docs."
    - "shake_128 block_size == 168 (1344 bits = 168 bytes per FIPS 202 Table 4)."
    - "blake2b block_size == 128 (1024-bit internal block width per RFC 7693 Section 2.1)."
    - "sha3_512 block_size == 72 (576 bits = 72 bytes = 1600 - 2*512 bits per FIPS 202)."
    - "pbkdf2_hmac is implemented in _hashlib (C extension), hence __module__ == '_hashlib'."
    - "sha3_512(b'abc') == 'b751850b1a57168a5693cd924b6b096e08f621827444f70d884f5d0240d2712e10e116e9192af3c91a7ec57647e3934057340b4cf408d5a56592f8274eec53f0' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# new() factory — digest_size for SHA-3 and BLAKE2 algorithms
#
# hashlib_extra6 covers sha3_256 digest_size via method_chain on the
# sha3_256() constructor. No prior spec provides standalone python_call_eq
# invariants for sha3_256, sha3_512, blake2b digest_size from new() in the
# extra15 namespace.
# ---------------------------------------------------------------------------

table hashlib_extra15.new_digest_sizes:
  kind: python_call_eq
  category: new_factory
  id_prefix: dsize15

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [sha3_256,   new, ["sha3_256"],   digest_size.__eq__, [32], true]
    - [sha3_512,   new, ["sha3_512"],   digest_size.__eq__, [64], true]
    - [blake2b,    new, ["blake2b"],    digest_size.__eq__, [64], true]
    - [shake_128,  new, ["shake_128"],  digest_size.__eq__, [0],  true]

# ---------------------------------------------------------------------------
# new() factory — block_size for SHA-3 and BLAKE2 algorithms
#
# hashlib_extra14 covers block_size for md5/sha1/sha512/sha3_256.
# Not yet covered: sha3_512 (72 bytes), blake2b (128 bytes),
# shake_128 (168 bytes).
# ---------------------------------------------------------------------------

table hashlib_extra15.new_block_sizes:
  kind: python_call_eq
  category: new_factory
  id_prefix: bsize15

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [sha3_512,  new, ["sha3_512"],  block_size.__eq__, [72],  true]
    - [blake2b,   new, ["blake2b"],   block_size.__eq__, [128], true]
    - [shake_128, new, ["shake_128"], block_size.__eq__, [168], true]

# ---------------------------------------------------------------------------
# new() factory — name attribute for SHA-3 and BLAKE2 algorithms
#
# hashlib_extra13 covers new('sha3_256').name from the extra13 namespace.
# These invariants add sha3_512 and blake2b from the extra15 namespace
# with a distinct id prefix.
# ---------------------------------------------------------------------------

invariant hashlib_extra15.new.sha3_256.name:
  description: "hashlib.new('sha3_256').name == 'sha3_256' — name attribute matches constructor argument"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_256"]
  method: name.__eq__
  method_args: ["sha3_256"]
  expected: true

invariant hashlib_extra15.new.sha3_512.name:
  description: "hashlib.new('sha3_512').name == 'sha3_512' — name attribute matches constructor argument"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_512"]
  method: name.__eq__
  method_args: ["sha3_512"]
  expected: true

invariant hashlib_extra15.new.blake2b.name:
  description: "hashlib.new('blake2b').name == 'blake2b' — name attribute matches constructor argument"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["blake2b"]
  method: name.__eq__
  method_args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed membership — sha3_512, blake2b, shake_128
#
# hashlib_extra13 covers algorithms_guaranteed contains 'sha3_224'.
# No prior spec covers 'sha3_512', 'blake2b', or 'shake_128' membership.
# ---------------------------------------------------------------------------

invariant hashlib_extra15.algorithms_guaranteed.contains_sha3_512:
  description: "hashlib.algorithms_guaranteed contains 'sha3_512' — mandatory in Python >=3.6"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_512"]
  expected: true

invariant hashlib_extra15.algorithms_guaranteed.contains_blake2b:
  description: "hashlib.algorithms_guaranteed contains 'blake2b' — available since Python 3.6"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra15.algorithms_guaranteed.contains_shake_128:
  description: "hashlib.algorithms_guaranteed contains 'shake_128' — XOF available since Python 3.6"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# pbkdf2_hmac — identity attributes
#
# hashlib.pbkdf2_hmac is a C extension function in _hashlib. No prior hashlib
# spec verifies its __name__ or __module__ attributes.
# ---------------------------------------------------------------------------

invariant hashlib_extra15.pbkdf2_hmac.function_name:
  description: "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'"
  category: function_names
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra15.pbkdf2_hmac.module:
  description: "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — implemented in C extension"
  category: function_modules
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# sha3_512 known-good hexdigest value
#
# FIPS 202 defines SHA3-512; the digest of b'abc' is a well-known test vector.
# No prior hashlib spec covers the sha3_512(b'abc') hexdigest value.
# ---------------------------------------------------------------------------

invariant hashlib_extra15.sha3_512.hexdigest_abc:
  description: "hashlib.sha3_512(b'abc').hexdigest() — FIPS 202 SHA3-512 known vector"
  category: known_vector
  kind: python_call_eq
  function: sha3_512
  args: [!hex 616263]
  method: hexdigest
  method_args: []
  expected: "b751850b1a57168a5693cd924b6b096e08f621827444f70d884f5d0240d2712e10e116e9192af3c91a7ec57647e3934057340b4cf408d5a56592f8274eec53f0"
