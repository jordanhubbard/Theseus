spec: dataclasses_extra14
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra13."
    - "dataclasses_extra13 covers: function __name__.__len__ for field/asdict/astuple/make_dataclass; function __qualname__ for fields/asdict/astuple/replace/is_dataclass; Field/__qualname__ and InitVar/__qualname__; __loader__.__class__.__name__; FrozenInstanceError/__qualname__.__len__."
    - "NOT yet covered: dataclasses.Field.__bases__.__len__() == 1 — Field has one direct base (object)."
    - "NOT yet covered: dataclasses.Field.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' — via standalone invariant using __bases__.__getitem__."
    - "NOT yet covered: dataclasses.MISSING.__class__.__qualname__ == '_MISSING_TYPE' — standalone invariant (extra10 covers it; verify here via __eq__ chain)."
    - "NOT yet covered: dataclasses.__name__ == 'dataclasses' — the module's own __name__ attribute as __eq__ boolean invariant."
    - "NOT yet covered: dataclasses.dataclass.__qualname__ == 'dataclass' — qualname of the dataclass decorator function."
    - "NOT yet covered: dataclasses.replace.__name__ == 'replace' — standalone invariant (extra12 table covers dataclass/field/fields; replace is missing)."
    - "NOT yet covered: dataclasses.replace.__name__.__len__() == 7 — 'replace' has 7 characters."
    - "NOT yet covered: dataclasses.is_dataclass.__name__.__len__() == 11 — 'is_dataclass' has 11 characters."
    - "dataclasses.Field.__bases__.__len__() == 1 — Field inherits directly from object only."
    - "dataclasses.Field.__bases__[0].__name__ == 'object' — Field's only direct base is object."
    - "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' — direct base via __getitem__."
    - "dataclasses.__name__ == 'dataclasses' — module __name__ attribute."
    - "dataclasses.dataclass.__qualname__ == 'dataclass' — top-level function qualname."
    - "dataclasses.replace.__name__ == 'replace'."
    - "dataclasses.replace.__name__.__len__() == 7."
    - "dataclasses.is_dataclass.__name__.__len__() == 11."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Field class __bases__ — length and first entry
#
# Prior specs check Field.__name__, Field.__qualname__, and Field.__module__.
# No prior spec verifies Field.__bases__.__len__() or Field.__bases__[0].__name__.
# dataclasses.Field is a plain class inheriting from object.
# ---------------------------------------------------------------------------

invariant dataclasses_extra14.Field.bases_len:
  description: "dataclasses.Field.__bases__.__len__() == 1 — Field has one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__bases__.__len__
  args: []
  expected: 1

invariant dataclasses_extra14.Field.base0_is_object:
  description: "dataclasses.Field.__bases__[0].__name__ == 'object' — Field's only direct base is object"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# FrozenInstanceError __bases__[0] — standalone direct-base invariant
#
# dataclasses_extra10 covers FrozenInstanceError.__mro__[1].__name__ == 'AttributeError'.
# dataclasses_extra12 covers FrozenInstanceError.__mro__[0].__name__ == 'FrozenInstanceError'.
# No prior spec accesses FrozenInstanceError.__bases__[0] directly.
# FrozenInstanceError inherits from AttributeError as its single direct base.
# ---------------------------------------------------------------------------

invariant dataclasses_extra14.FrozenInstanceError.base0:
  description: "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AttributeError"

# ---------------------------------------------------------------------------
# Module __name__ — boolean eq invariant
#
# dataclasses_extra11 covers __name__ returned as a direct value.
# No prior spec verifies __name__ via __eq__ as a boolean invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra14.module.name_eq:
  description: "dataclasses.__name__ == 'dataclasses' — module __name__ via boolean eq"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# dataclass decorator __qualname__
#
# dataclasses_extra12 covers dataclass.__name__.__eq__ in a table row.
# No prior spec checks dataclass.__qualname__ as a standalone invariant.
# For a top-level function __qualname__ == __name__ == 'dataclass'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra14.dataclass.qualname:
  description: "dataclasses.dataclass.__qualname__ == 'dataclass' — top-level function qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: dataclass.__qualname__.__eq__
  args: ["dataclass"]
  expected: true

# ---------------------------------------------------------------------------
# replace — __name__ and __name__ length
#
# dataclasses_extra13 covers replace.__qualname__ in a table row.
# No prior spec checks replace.__name__ directly or its length.
# 'replace' has 7 characters.
# ---------------------------------------------------------------------------

invariant dataclasses_extra14.replace.name:
  description: "dataclasses.replace.__name__ == 'replace'"
  category: function_names
  kind: python_call_eq
  function: replace.__name__.__eq__
  args: ["replace"]
  expected: true

invariant dataclasses_extra14.replace.name_len:
  description: "dataclasses.replace.__name__.__len__() == 7 — 'replace' is 7 characters"
  category: function_names
  kind: python_call_eq
  function: replace.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# is_dataclass — __name__ length
#
# dataclasses_extra12 covers is_dataclass.__doc__.__class__.__name__ (table).
# dataclasses_extra13 covers is_dataclass.__qualname__.__eq__ (table row).
# No prior spec checks is_dataclass.__name__.__len__().
# 'is_dataclass' is 11 characters.
# ---------------------------------------------------------------------------

invariant dataclasses_extra14.is_dataclass.name_len:
  description: "dataclasses.is_dataclass.__name__.__len__() == 11 — 'is_dataclass' is 11 characters"
  category: function_names
  kind: python_call_eq
  function: is_dataclass.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Table: __name__.__len__ for additional dataclasses functions
#
# Groups function name-length checks not already in extra13 table.
# replace (7), is_dataclass (11) — both new.
# dataclass (9) — not yet checked for length in any prior spec.
# fields (6) — not checked for length in any prior spec.
# ---------------------------------------------------------------------------

table dataclasses_extra14.function_name_lengths2:
  kind: python_call_eq
  category: function_names
  id_prefix: namelen2

  columns: [id, function, args, expected]
  rows:
    - [dataclass,    dataclass.__name__.__len__,    [], 9]
    - [fields,       fields.__name__.__len__,       [], 6]
    - [replace,      replace.__name__.__len__,      [], 7]
    - [is_dataclass, is_dataclass.__name__.__len__, [], 11]
