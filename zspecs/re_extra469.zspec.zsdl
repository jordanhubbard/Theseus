spec: re_extra469
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module function name and module identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All functions listed are public API in the re module and have been stable across Python versions"
    - "re.fullmatch was added in Python 3.4; all others predate Python 3"
    - "No regex pattern strings with special sequences are used in this spec"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra469.function_names:
  description: "re module function __name__ identity checks"
  kind: python_call_eq
  category: function_identity
  id_prefix: REN

  columns: [id, function, args, expected]
  rows:
    - [REN001, re.compile.__name__.__eq__, ["compile"], true]
    - [REN002, re.match.__name__.__eq__, ["match"], true]
    - [REN003, re.search.__name__.__eq__, ["search"], true]
    - [REN004, re.fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [REN005, re.findall.__name__.__eq__, ["findall"], true]
    - [REN006, re.finditer.__name__.__eq__, ["finditer"], true]
    - [REN007, re.sub.__name__.__eq__, ["sub"], true]
    - [REN008, re.subn.__name__.__eq__, ["subn"], true]
    - [REN009, re.split.__name__.__eq__, ["split"], true]
    - [REN010, re.escape.__name__.__eq__, ["escape"], true]
    - [REN011, re.purge.__name__.__eq__, ["purge"], true]

table re_extra469.function_modules:
  description: "re module function __module__ identity checks"
  kind: python_call_eq
  category: function_identity
  id_prefix: REM

  columns: [id, function, args, expected]
  rows:
    - [REM001, re.compile.__module__.__eq__, ["re"], true]
    - [REM002, re.match.__module__.__eq__, ["re"], true]
    - [REM003, re.search.__module__.__eq__, ["re"], true]
