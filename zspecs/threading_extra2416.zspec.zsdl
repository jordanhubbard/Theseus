spec: threading_extra2416
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "CPython source — Lib/threading.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "threading.Thread, Event, Condition, Semaphore, and Barrier are NOT iterable."
    - "threading.Lock is also not iterable; threading.Timer subclasses Thread and is also not iterable."
    - "threading.BoundedSemaphore and threading.local are also non-iterable."
    - "None of these classes define __iter__ or __next__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ not in class __dict__ for threading synchronization primitives
# ===

table threading_extra2416.iter_not_in_dict:
  description: "__iter__ is absent from __dict__ for threading synchronization and coordination types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2416
  columns: [id, function, args, expected]
  rows:
    - ["th2416001", "threading.Thread.__dict__.__contains__", ["__iter__"], false]
    - ["th2416002", "threading.Event.__dict__.__contains__", ["__iter__"], false]
    - ["th2416003", "threading.Condition.__dict__.__contains__", ["__iter__"], false]
    - ["th2416004", "threading.Semaphore.__dict__.__contains__", ["__iter__"], false]
    - ["th2416005", "threading.Barrier.__dict__.__contains__", ["__iter__"], false]
    - ["th2416006", "threading.Lock.__dict__.__contains__", ["__iter__"], false]
    - ["th2416007", "threading.Timer.__dict__.__contains__", ["__iter__"], false]
    - ["th2416008", "threading.BoundedSemaphore.__dict__.__contains__", ["__iter__"], false]
    - ["th2416009", "threading.local.__dict__.__contains__", ["__iter__"], false]

