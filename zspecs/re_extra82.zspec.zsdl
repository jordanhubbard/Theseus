spec: re_extra82
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra81."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern.match/search/__doc__.__class__.__name__; Pattern.findall/finditer/sub/subn/split/fullmatch __doc__.__class__.__name__; Match.group/groups/groupdict/start/end/span __qualname__ values and lengths."
    - "This spec covers: re.compile/__code__.co_name and co_argcount; re.match/__code__.co_name and co_argcount; re.search/__code__.co_name and co_argcount; re.sub/__code__.co_name and co_argcount; re.findall/__code__.co_name and co_argcount; re.split/__code__.co_name and co_argcount; re.fullmatch/__code__.co_name and co_argcount; re.purge/__code__.co_name and co_argcount."
    - "re.compile.__code__.co_name == 'compile' — the Python wrapper function name."
    - "re.compile.__code__.co_argcount == 2 — compile(pattern, flags=0): 2 positional-or-keyword args."
    - "re.match.__code__.co_name == 'match' — the Python wrapper function name."
    - "re.match.__code__.co_argcount == 3 — match(pattern, string, flags=0): 3 positional-or-keyword args."
    - "re.search.__code__.co_name == 'search' — the Python wrapper function name."
    - "re.search.__code__.co_argcount == 3 — search(pattern, string, flags=0): 3 positional-or-keyword args."
    - "re.sub.__code__.co_name == 'sub' — the Python wrapper function name."
    - "re.sub.__code__.co_argcount == 3 — sub(pattern, repl, string, *, count=0, flags=0): 3 positional-or-keyword args (count and flags are keyword-only)."
    - "re.findall.__code__.co_name == 'findall' — the Python wrapper function name."
    - "re.findall.__code__.co_argcount == 3 — findall(pattern, string, flags=0): 3 positional-or-keyword args."
    - "re.split.__code__.co_name == 'split' — the Python wrapper function name."
    - "re.split.__code__.co_argcount == 2 — split(pattern, string, *, maxsplit=0, flags=0): 2 positional-or-keyword args (maxsplit and flags are keyword-only)."
    - "re.fullmatch.__code__.co_name == 'fullmatch' — the Python wrapper function name."
    - "re.fullmatch.__code__.co_argcount == 3 — fullmatch(pattern, string, flags=0): 3 positional-or-keyword args."
    - "re.purge.__code__.co_name == 'purge' — the Python function name."
    - "re.purge.__code__.co_argcount == 0 — purge(): no parameters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile and re.match __code__ attributes
# compile(pattern, flags=0): co_argcount == 2.
# match(pattern, string, flags=0): co_argcount == 3.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra82.compile_match_code:
  description: "re.compile and re.match __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: reextra82

  columns: [id, function, args, expected]
  rows:
    - [compile_co_name, compile.__code__.co_name.__eq__,      ["compile"], true]
    - [compile_co_argc, compile.__code__.co_argcount.__eq__,  [2],         true]
    - [match_co_name,   match.__code__.co_name.__eq__,        ["match"],   true]
    - [match_co_argc,   match.__code__.co_argcount.__eq__,    [3],         true]

# ---------------------------------------------------------------------------
# re.search and re.sub __code__ attributes
# search(pattern, string, flags=0): co_argcount == 3.
# sub(pattern, repl, string, *, count=0, flags=0): co_argcount == 3 (count/flags are keyword-only).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra82.search_sub_code:
  description: "re.search and re.sub __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: reextra82

  columns: [id, function, args, expected]
  rows:
    - [search_co_name, search.__code__.co_name.__eq__,      ["search"], true]
    - [search_co_argc, search.__code__.co_argcount.__eq__,  [3],        true]
    - [sub_co_name,    sub.__code__.co_name.__eq__,         ["sub"],    true]
    - [sub_co_argc,    sub.__code__.co_argcount.__eq__,     [3],        true]

# ---------------------------------------------------------------------------
# re.findall and re.split __code__ attributes
# findall(pattern, string, flags=0): co_argcount == 3.
# split(pattern, string, *, maxsplit=0, flags=0): co_argcount == 2 (maxsplit/flags keyword-only).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra82.findall_split_code:
  description: "re.findall and re.split __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: reextra82

  columns: [id, function, args, expected]
  rows:
    - [findall_co_name, findall.__code__.co_name.__eq__,      ["findall"], true]
    - [findall_co_argc, findall.__code__.co_argcount.__eq__,  [3],         true]
    - [split_co_name,   split.__code__.co_name.__eq__,        ["split"],   true]
    - [split_co_argc,   split.__code__.co_argcount.__eq__,    [2],         true]

# ---------------------------------------------------------------------------
# re.fullmatch and re.purge __code__ attributes
# fullmatch(pattern, string, flags=0): co_argcount == 3.
# purge(): co_argcount == 0 (no parameters).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra82.fullmatch_purge_code:
  description: "re.fullmatch and re.purge __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: reextra82

  columns: [id, function, args, expected]
  rows:
    - [fullmatch_co_name, fullmatch.__code__.co_name.__eq__,      ["fullmatch"], true]
    - [fullmatch_co_argc, fullmatch.__code__.co_argcount.__eq__,  [3],           true]
    - [purge_co_name,     purge.__code__.co_name.__eq__,          ["purge"],     true]
    - [purge_co_argc,     purge.__code__.co_argcount.__eq__,      [0],           true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra82.compile_code.co_name:
  description: "re.compile.__code__.co_name == 'compile' (Python wrapper function)"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_name.__eq__
  args: ["compile"]
  expected: true

invariant re_extra82.compile_code.co_argcount:
  description: "re.compile.__code__.co_argcount == 2 (pattern + flags)"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra82.sub_code.co_argcount:
  description: "re.sub.__code__.co_argcount == 3 (pattern + repl + string; count/flags are keyword-only)"
  category: code_attrs
  kind: python_call_eq
  function: sub.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra82.split_code.co_argcount:
  description: "re.split.__code__.co_argcount == 2 (pattern + string; maxsplit/flags are keyword-only)"
  category: code_attrs
  kind: python_call_eq
  function: split.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra82.purge_code.co_argcount:
  description: "re.purge.__code__.co_argcount == 0 (no parameters)"
  category: code_attrs
  kind: python_call_eq
  function: purge.__code__.co_argcount.__eq__
  args: [0]
  expected: true
