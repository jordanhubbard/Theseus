spec: socket_extra616
version: ">=3.9"
backend: python_module(socket)
docs: "https://docs.python.org/3/library/socket.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers socket.socket method qualified names, doc string class check, and module identity"
  created_at: "2026-04-12T00:00:00Z"

table socket_extra616.socket_method_qualnames:
  description: "Qualified name checks for socket.socket methods"
  kind: python_call_eq
  category: function_identity
  id_prefix: sk616ss
  columns: [id, function, args, expected]
  rows:
    - [sk616ss001, socket.socket.setblocking.__qualname__.__eq__, ["socket.setblocking"], true]
    - [sk616ss002, socket.socket.settimeout.__qualname__.__eq__, ["socket.settimeout"], true]
    - [sk616ss003, socket.socket.gettimeout.__qualname__.__eq__, ["socket.gettimeout"], true]
    - [sk616ss004, socket.socket.makefile.__qualname__.__eq__, ["socket.makefile"], true]
    - [sk616ss005, socket.socket.fileno.__qualname__.__eq__, ["socket.fileno"], true]
    - [sk616ss006, socket.socket.setsockopt.__qualname__.__eq__, ["socket.setsockopt"], true]
    - [sk616ss007, socket.socket.getsockopt.__qualname__.__eq__, ["socket.getsockopt"], true]
    - [sk616ss008, socket.socket.getsockname.__qualname__.__eq__, ["socket.getsockname"], true]
    - [sk616ss009, socket.socket.getpeername.__qualname__.__eq__, ["socket.getpeername"], true]
    - [sk616ss010, socket.socket.shutdown.__qualname__.__eq__, ["socket.shutdown"], true]

table socket_extra616.socket_class_attrs:
  description: "Doc string class check and module identity for socket.socket"
  kind: python_call_eq
  category: class_identity
  id_prefix: sk616fn
  columns: [id, function, args, expected]
  rows:
    - [sk616fn001, socket.socket.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk616fn002, socket.socket.__module__.__eq__, ["socket"], true]
