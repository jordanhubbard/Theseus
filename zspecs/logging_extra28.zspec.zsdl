spec: logging_extra28
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra27.zspec.zsdl — covers Logger/Handler/Formatter/Filter/LogRecord __init__.__name__, NOTSET/WARN/FATAL values, Logger/Handler/Formatter/Filter __module__ cross-namespace anchors."
    - "logging_extra26.zspec.zsdl — covers Logger/__qualname__/__module__/__bases__[0].__name__, RootLogger/__qualname__/__module__/__bases__[0].__name__, level constants DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET values."
    - "logging_extra25.zspec.zsdl — covers Handler/Formatter __qualname__/__module__, StreamHandler/FileHandler __qualname__/__bases__[0].__name__, LogRecord.__module__."
    - "logging_extra24.zspec.zsdl — covers __qualname__ for StreamHandler.emit, FileHandler.emit, NullHandler.emit, Filter.filter, LogRecord class and getMessage, getLogger/basicConfig/makeLogRecord."
    - "logging_extra23.zspec.zsdl — covers __qualname__ for Logger.debug/info/warning/error/critical/exception, Handler.emit/handle, Formatter.format."
  notes:
    - "This spec extends logging_extra27.zspec.zsdl."
    - "Prior specs covered: Logger/Handler/Formatter/Filter/LogRecord __name__/__module__/__qualname__/__bases__[0].__name__, DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET/WARN/FATAL values, getLogger/basicConfig/__name__, Logger/Handler/Formatter/Filter/__init__.__name__, LogRecord/__init__.__name__, Logger/Handler/Formatter/Filter/__module__."
    - "This spec covers: __module__.__len__() for Logger/Handler/Formatter/Filter/LogRecord; __name__.__len__() for Logger/Handler/Formatter/Filter/LogRecord; getLogger/__qualname__, basicConfig/__qualname__."
    - "logging.Logger.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Handler.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Formatter.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Filter.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.LogRecord.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Logger.__name__ == 'Logger' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Handler.__name__ == 'Handler' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Formatter.__name__ == 'Formatter' — len 9. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Filter.__name__ == 'Filter' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.LogRecord.__name__ == 'LogRecord' — len 9. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.getLogger.__qualname__ == 'getLogger' — logging_extra24 covers __qualname__.__eq__ in context; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.basicConfig.__qualname__ == 'basicConfig' — logging_extra24 covers __qualname__.__eq__ in context; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for Logger, Handler, Formatter, Filter, LogRecord
#
# logging_extra25/26/27 cover __module__.__eq__ for these classes (all 'logging').
# No prior spec checks __module__.__len__() as a standalone for any of them.
# All five have __module__ == 'logging' (len 7).
# ---------------------------------------------------------------------------

table logging_extra28.class_module_lengths:
  description: "len(__module__) == 7 for Logger/Handler/Formatter/Filter/LogRecord — all defined in 'logging'; cross-namespace anchors from extra28"
  kind: python_call_eq
  category: class_module
  id_prefix: cml28

  columns: [id, function, args, expected]
  rows:
    - [Logger,    Logger.__module__.__len__,    [], 7]
    - [Handler,   Handler.__module__.__len__,   [], 7]
    - [Formatter, Formatter.__module__.__len__, [], 7]
    - [Filter,    Filter.__module__.__len__,    [], 7]
    - [LogRecord, LogRecord.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# __name__.__len__() for Logger, Handler, Formatter, Filter, LogRecord
#
# No prior spec checks __name__.__len__() for any of these five major logging
# classes. Logger: 6, Handler: 7, Formatter: 9, Filter: 6, LogRecord: 9.
# ---------------------------------------------------------------------------

invariant logging_extra28.Logger.name_len:
  description: "len(logging.Logger.__name__) == 6 — len('Logger') == 6"
  category: class_names
  kind: python_call_eq
  function: Logger.__name__.__len__
  args: []
  expected: 6

invariant logging_extra28.Handler.name_len:
  description: "len(logging.Handler.__name__) == 7 — len('Handler') == 7"
  category: class_names
  kind: python_call_eq
  function: Handler.__name__.__len__
  args: []
  expected: 7

table logging_extra28.formatter_filter_logrecord_name_lengths:
  description: "len(__name__) for Formatter (9), Filter (6), LogRecord (9)"
  kind: python_call_eq
  category: class_names
  id_prefix: ffln28

  columns: [id, function, args, expected]
  rows:
    - [Formatter, Formatter.__name__.__len__, [], 9]
    - [Filter,    Filter.__name__.__len__,    [], 6]
    - [LogRecord, LogRecord.__name__.__len__, [], 9]

# ---------------------------------------------------------------------------
# logging.getLogger.__qualname__ and logging.basicConfig.__qualname__
#
# logging_extra24 covers __qualname__.__eq__ for getLogger and basicConfig in
# the context of the makeLogRecord table. These standalone invariants provide
# cross-namespace anchors from the extra28 namespace.
# getLogger.__qualname__ == 'getLogger'; basicConfig.__qualname__ == 'basicConfig'.
# ---------------------------------------------------------------------------

invariant logging_extra28.getLogger.qualname_eq:
  description: "logging.getLogger.__qualname__ == 'getLogger' — cross-namespace anchor from extra28; extra24 covers in context"
  category: function_qualnames
  kind: python_call_eq
  function: getLogger.__qualname__.__eq__
  args: ["getLogger"]
  expected: true

invariant logging_extra28.getLogger.qualname_len:
  description: "len(logging.getLogger.__qualname__) == 9 — len('getLogger') == 9"
  category: function_qualnames
  kind: python_call_eq
  function: getLogger.__qualname__.__len__
  args: []
  expected: 9

invariant logging_extra28.basicConfig.qualname_eq:
  description: "logging.basicConfig.__qualname__ == 'basicConfig' — cross-namespace anchor from extra28; extra24 covers in context"
  category: function_qualnames
  kind: python_call_eq
  function: basicConfig.__qualname__.__eq__
  args: ["basicConfig"]
  expected: true

invariant logging_extra28.basicConfig.qualname_len:
  description: "len(logging.basicConfig.__qualname__) == 11 — len('basicConfig') == 11"
  category: function_qualnames
  kind: python_call_eq
  function: basicConfig.__qualname__.__len__
  args: []
  expected: 11
