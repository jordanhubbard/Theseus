spec: trim_left
version: ">=2.0.0"
backend: node(trim-left)

docs: https://www.npmjs.com/package/trim-left

provenance:
  derived_from:
    - "trim-left README — https://www.npmjs.com/package/trim-left"
    - "Test vectors verified with trim-left via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "trim-left source"
  notes:
    - "trim-left is an npm package. Install: npm install trim-left"
    - "Removes leading whitespace from a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table trim_left.trim:
  kind: node_module_call_eq
  function: "default"
  category: strings
  id_prefix: triml

  columns: [id, args, expected]
  rows:
    - [both_sides, ["  hello  "], "hello  "]
    - [right_only, ["hello  "],   "hello  "]
    - [no_spaces,  ["hello"],     "hello"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:51:11Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
