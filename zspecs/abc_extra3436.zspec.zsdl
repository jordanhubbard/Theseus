    - ["ab3436005", operator.contains, [abc.ABCMeta.__dict__,                             "__gt__"], false]
    - ["ab3436006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__gt__"], false]

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# All 3 abc subjects return false for __ge__.
# >= delegates to __ge__ when defined in the class's own __dict__.
# abc.ABC: no __ge__ in its own __dict__; >= raises TypeError by default
#   since object does not define __ge__.
# abc.ABCMeta: does not define __ge__ in ABCMeta.__dict__. The metaclass
#   is focused on abstract method registration and subclass checking, not
#   ordering. Wave 655 (ab3121) first confirmed this result.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __ge__ in their own __dict__. >= between two
#   functions raises TypeError at runtime since object provides no __ge__.
#   Wave 655 (ab3121) first confirmed this result.
# ---------------------------------------------------------------------------

