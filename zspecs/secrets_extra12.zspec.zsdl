spec: secrets_extra12
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra11.zspec.zsdl — covers __module__.__len__() for token_bytes/hex/urlsafe/choice/randbelow; __class__.__name__.__len__() for token_bytes/choice; token_urlsafe(16/32) output length."
    - "secrets_extra10.zspec.zsdl — covers token_bytes/hex/urlsafe/choice/randbelow __name__ as standalone invariants; token_bytes(16) class/len; token_hex(8) class/len."
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table and standalone invariants for token_bytes/token_hex/token_urlsafe/SystemRandom/choice/randbelow/randbits; DEFAULT_ENTROPY == 32; token_urlsafe/bytes/hex lengths."
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__."
  notes:
    - "This spec extends the secrets chain through secrets_extra11; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __qualname__.__len__() checks for all secrets callables. secrets_extra4 covers __qualname__.__eq__ for all; no prior spec checks the length of any __qualname__ string in the secrets module."
    - "secrets.token_bytes.__qualname__ == 'token_bytes': len == 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__qualname__ == 'token_hex': len == 9. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__qualname__ == 'token_urlsafe': len == 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__qualname__ == 'Random.choice': len == 13 (includes 'Random.' prefix). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbelow.__qualname__ == 'randbelow': len == 9. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbits.__qualname__ == 'SystemRandom.getrandbits': len == 24 (includes 'SystemRandom.' prefix). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__qualname__ == 'SystemRandom': len == 12. Top-level class; qualname equals name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# secrets callable __qualname__.__len__() table
#
# secrets_extra4 covers __qualname__.__eq__ for all seven callables.
# No prior spec checks the length of any __qualname__ string in secrets.
# Lengths: token_bytes=11, token_hex=9, token_urlsafe=13, choice=13
# (includes 'Random.' prefix), randbelow=9, randbits=24
# (includes 'SystemRandom.' prefix), SystemRandom=12.
# ---------------------------------------------------------------------------

table secrets_extra12.qualname_lengths:
  description: "Length of __qualname__ strings for all secrets callables"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: secqlen12

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,    token_bytes.__qualname__.__len__,    [], 11]
    - [token_hex,      token_hex.__qualname__.__len__,      [],  9]
    - [token_urlsafe,  token_urlsafe.__qualname__.__len__,  [], 13]
    - [choice,         choice.__qualname__.__len__,         [], 13]
    - [randbelow,      randbelow.__qualname__.__len__,      [],  9]
    - [randbits,       randbits.__qualname__.__len__,       [], 24]
    - [SystemRandom,   SystemRandom.__qualname__.__len__,   [], 12]
