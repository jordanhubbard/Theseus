spec: ab3541
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 683 (ab3541): __format__, __sizeof__, __dir__ dict-presence checks for abc types."
    - "All values false — abc.ABC, abc.ABCMeta, and abc.abstractmethod do not define __format__, __sizeof__, or __dir__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ab3541.format:
  description: "abc types __format__ dict-presence checks; wave 683"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3541
  columns: [id, function, args, expected]
  rows:
    - ["ab3541001", operator.contains, [abc.ABC.__dict__,                                 "__format__"], false]
    - ["ab3541002", operator.contains, [abc.ABCMeta.__dict__,                             "__format__"], false]
    - ["ab3541003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__format__"], false]

