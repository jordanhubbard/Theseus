spec: uuid_extra160
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra159.zspec.zsdl — covers uuid.SafeUUID.__name__/__module__/__bases__[0].__name__ ('Enum') / SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 and name lengths (table + invariants)."
    - "uuid_extra158.zspec.zsdl — covers uuid.uuid1/__uuid3/__uuid4/__uuid5 .__name__/__module__/__class__.__name__ and name lengths (table + invariants)."
    - "uuid_extra157.zspec.zsdl — covers uuid.UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__bases__[0].__name__=='object' / NAMESPACE_DNS/URL/OID/X500.__class__.__name__=='UUID' (table + invariants)."
    - "uuid_extra156.zspec.zsdl — covers uuid.UUID.__dict__ property membership and meta-attributes (__len__()==37/__class__.__name__=='mappingproxy') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra159."
    - "Wave 350 theme: uuid.UUID.__dict__.__contains__ for hex/int/bytes/bytes_le/fields/time_low/version/variant. uuid_extra156 covers uuid.UUID.__dict__ membership using 'in' syntax (hex/int/bytes/version/variant/__init__/__str__/__repr__); this spec covers the same keys via the __contains__ method syntax as the primary novel anchor, plus extends to bytes_le/fields/time_low which are novel properties not anchored in prior specs."
    - "uuid.UUID.__dict__.__contains__('hex') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('int') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes_le') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('fields') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time_low') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('version') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('variant') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__dict__.__contains__('hex') == True. The 'hex' property on UUID returns the UUID as a 32-character hexadecimal string (without dashes). 'hex'(3 chars) is the shortest property name among those anchored in this spec. uuid_extra156 anchors hex membership via 'in' syntax; this spec uses __contains__ method syntax."
    - "Note: uuid.UUID.__dict__.__contains__('int') == True. The 'int' property returns the UUID as a 128-bit integer. 'int'(3 chars) == 'hex'(3 chars) in length — both are the shortest property names in this spec."
    - "Note: uuid.UUID.__dict__.__contains__('bytes') == True. The 'bytes' property returns the UUID as a 16-byte bytes object in big-endian (network) byte order. 'bytes'(5 chars) > 'hex'/'int'(3 chars) by 2."
    - "Note: uuid.UUID.__dict__.__contains__('bytes_le') == True. The 'bytes_le' property returns the UUID as a 16-byte bytes object in little-endian (Windows GUID) byte order. 'bytes_le'(8 chars) = 'bytes'=5 + '_le'=3. Novel: uuid_extra156 does not anchor bytes_le membership."
    - "Note: uuid.UUID.__dict__.__contains__('fields') == True. The 'fields' property returns a tuple of the six UUID component fields (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node). 'fields'(6 chars). Novel anchor."
    - "Note: uuid.UUID.__dict__.__contains__('time_low') == True. The 'time_low' property returns the first 32 bits of the UUID (the time_low field per RFC 4122). 'time_low'(8 chars) = 'time'=4 + '_low'=4. Novel anchor."
    - "Note: uuid.UUID.__dict__.__contains__('version') == True. The 'version' property returns the UUID version number (1-5), or raises ValueError for non-RFC-4122 UUIDs. uuid_extra156 anchors this; confirmed via __contains__ here."
    - "Note: uuid.UUID.__dict__.__contains__('variant') == True. The 'variant' property returns the UUID variant string (e.g., 'specified in RFC 4122'). uuid_extra156 anchors this; confirmed via __contains__ here."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex')
# uuid.UUID.__dict__.__contains__('int')
# uuid.UUID.__dict__.__contains__('bytes')
# uuid.UUID.__dict__.__contains__('bytes_le')
#
# Wave 350 theme: UUID.__dict__ contains core representation properties.
#
# UUID.__dict__.__contains__('hex') == True ('hex' = 3 chars; 32-char hexadecimal representation).
# UUID.__dict__.__contains__('int') == True ('int' = 3 chars; 128-bit integer representation).
# UUID.__dict__.__contains__('bytes') == True ('bytes' = 5 chars; big-endian 16-byte representation).
# UUID.__dict__.__contains__('bytes_le') == True ('bytes_le' = 8 chars; little-endian 16-byte).
# uuid_extra156 anchors hex/int/bytes membership via 'in' syntax;
# this spec anchors via __contains__ method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra160.UUID_dict_core_representations:
  description: "uuid.UUID.__dict__.__contains__('hex')==True / UUID.__dict__.__contains__('int')==True / UUID.__dict__.__contains__('bytes')==True / UUID.__dict__.__contains__('bytes_le')==True — UUID.__dict__.__contains__('hex') is True ('hex' is a key in uuid.UUID.__dict__; UUID.hex is a property that returns the UUID as a 32-character lowercase hexadecimal string without dashes (e.g., '12345678123412341234123456789abc'); 'hex'(3 chars) is among the shortest property names on UUID; uuid_extra156 anchors hex membership via 'in' syntax; this spec anchors via __contains__ method); UUID.__dict__.__contains__('int') is True ('int' is a key in UUID.__dict__; UUID.int is a property returning the UUID as a Python integer (128-bit non-negative int); UUID.int and UUID.hex are the two lowest-level representations of a UUID's value; 'int'(3) == 'hex'(3) in length — both 3-char property names; uuid_extra156 anchors this); UUID.__dict__.__contains__('bytes') is True ('bytes' is a key in UUID.__dict__; UUID.bytes is a property returning the UUID as a 16-byte bytes object in big-endian (network) byte order; 'bytes'(5 chars) > 'hex'/'int'(3 chars) by 2; uuid_extra156 anchors); UUID.__dict__.__contains__('bytes_le') is True ('bytes_le' is a key in UUID.__dict__; UUID.bytes_le returns the UUID as 16-byte bytes in little-endian (Windows GUID) byte order; the first three components (time_low/time_mid/time_hi) are swapped; 'bytes_le'(8) = 'bytes'=5 + '_le'=3; 'bytes_le'(8) > 'time_low'(8) in name — equal length; novel: uuid_extra156 does not anchor bytes_le; first uuiddict160 anchor for UUID.__dict__ __contains__ for hex/int/bytes/bytes_le)"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict160

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_hex,       "UUID.__dict__.__contains__", ["hex"],      true, "uuid.UUID.__dict__.__contains__('hex') == True ('hex'=3 chars; 32-char hexadecimal string without dashes; uuid_extra156 anchors via 'in' syntax)"]
    - [dict_has_int,       "UUID.__dict__.__contains__", ["int"],      true, "uuid.UUID.__dict__.__contains__('int') == True ('int'=3 chars; 128-bit integer; 'int'(3)=='hex'(3) in length; uuid_extra156 anchors)"]
    - [dict_has_bytes,     "UUID.__dict__.__contains__", ["bytes"],    true, "uuid.UUID.__dict__.__contains__('bytes') == True ('bytes'=5 chars; big-endian 16-byte representation; 'bytes'(5)>'hex'(3) by 2; uuid_extra156 anchors)"]
    - [dict_has_bytes_le,  "UUID.__dict__.__contains__", ["bytes_le"], true, "uuid.UUID.__dict__.__contains__('bytes_le') == True ('bytes_le'=8 chars; little-endian 16-byte/Windows GUID order; 'bytes_le'(8)='bytes'(5)+'_le'(3); novel anchor)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('fields')
# uuid.UUID.__dict__.__contains__('time_low')
# uuid.UUID.__dict__.__contains__('version')
# uuid.UUID.__dict__.__contains__('variant')
#
# Wave 350 theme: UUID.__dict__ contains structural and metadata properties.
#
# UUID.__dict__.__contains__('fields') == True ('fields' = 6 chars; tuple of 6 UUID components).
# UUID.__dict__.__contains__('time_low') == True ('time_low' = 8 chars; first 32 bits of UUID).
# UUID.__dict__.__contains__('version') == True ('version' = 7 chars; UUID version number).
# UUID.__dict__.__contains__('variant') == True ('variant' = 7 chars; UUID variant string).
# uuid_extra156 anchors version/variant via 'in' syntax;
# fields/time_low are novel. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra160.UUID_dict_structural_metadata:
  description: "uuid.UUID.__dict__.__contains__('fields')==True / UUID.__dict__.__contains__('time_low')==True / UUID.__dict__.__contains__('version')==True / UUID.__dict__.__contains__('variant')==True — UUID.__dict__.__contains__('fields') is True ('fields' is a key in UUID.__dict__; UUID.fields is a property that returns a tuple of the six integer components of the UUID: (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node) — these are the six fields defined in RFC 4122 Section 4.1.2; 'fields'(6 chars) is between 'hex'/'int'(3) and 'bytes_le'(8) in length; novel anchor — uuid_extra156 does not anchor fields membership); UUID.__dict__.__contains__('time_low') is True ('time_low' is a key in UUID.__dict__; UUID.time_low is a property returning the first 32 bits of the UUID, one of the six RFC 4122 time fields; UUID is structured as: time_low(32 bits) + time_mid(16 bits) + time_hi_version(16 bits) + clock_seq(16 bits) + node(48 bits) = 128 bits total; 'time_low'(8 chars) = 'time'=4 + '_low'=4; novel anchor); UUID.__dict__.__contains__('version') is True ('version' is a key in UUID.__dict__; UUID.version is a property returning the UUID version number (1, 3, 4, or 5); raises ValueError for non-RFC-4122 UUIDs; 'version'(7 chars); uuid_extra156 anchors this via 'in' syntax; confirmed here via __contains__); UUID.__dict__.__contains__('variant') is True ('variant' is a key in UUID.__dict__; UUID.variant is a property returning a string describing the UUID variant (e.g., 'specified in RFC 4122'); 'variant'(7 chars) == 'version'(7 chars) in length; uuid_extra156 anchors this; first uuiddict160 anchor for fields/time_low/version/variant __contains__)"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict160

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_fields,   "UUID.__dict__.__contains__", ["fields"],   true, "uuid.UUID.__dict__.__contains__('fields') == True ('fields'=6 chars; tuple of 6 UUID components from RFC 4122; novel anchor)"]
    - [dict_has_time_low, "UUID.__dict__.__contains__", ["time_low"], true, "uuid.UUID.__dict__.__contains__('time_low') == True ('time_low'=8 chars='time'=4+'_low'=4; first 32 bits of UUID; RFC 4122 field; novel anchor)"]
    - [dict_has_version,  "UUID.__dict__.__contains__", ["version"],  true, "uuid.UUID.__dict__.__contains__('version') == True ('version'=7 chars; UUID version 1-5; uuid_extra156 anchors via 'in'; confirmed via __contains__)"]
    - [dict_has_variant,  "UUID.__dict__.__contains__", ["variant"],  true, "uuid.UUID.__dict__.__contains__('variant') == True ('variant'=7 chars; UUID variant string; 'variant'(7)=='version'(7) in length; uuid_extra156 anchors)"]

# ---------------------------------------------------------------------------
# UUID property name length comparisons
#
# Wave 350 theme: UUID.__dict__ property name lengths and ordering.
#
# 'hex'.__len__() == 3 (shortest UUID property name).
# 'int'.__len__() == 3 (tied shortest).
# 'bytes'.__len__() == 5 (3rd tier).
# 'fields'.__len__() == 6 (4th tier).
# 'version'.__len__() == 7 (5th tier; tied with 'variant').
# 'bytes_le'.__len__() == 8 (tied longest with 'time_low').
# 'time_low'.__len__() == 8 (tied longest).
# No prior uuid spec anchors UUID.__dict__.__contains__ for bytes_le/fields/time_low
# as a combined length table under uuiddict160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra160.UUID_dict_property_name_lengths:
  description: "uuid.UUID.__dict__.__contains__('bytes_le')==True / UUID.__dict__.__contains__('time_low')==True / UUID.__dict__.__contains__('fields')==True / UUID.__dict__.__contains__('hex')==True — UUID.__dict__.__contains__('bytes_le') is True (confirmed; 'bytes_le'=8 chars; little-endian; 'bytes_le'(8)=='time_low'(8) — tied longest property name length in this spec); UUID.__dict__.__contains__('time_low') is True (confirmed; 'time_low'=8 chars; 'time'=4+'_low'=4; 'time_low'(8)=='bytes_le'(8) — tied for longest property name in this spec; length ordering for these 8 properties: 'hex'(3)=='int'(3) < 'bytes'(5) < 'fields'(6) < 'variant'(7)=='version'(7) < 'bytes_le'(8)=='time_low'(8)); UUID.__dict__.__contains__('fields') is True (confirmed; 'fields'=6 chars; between 'bytes'(5) and 'version'/'variant'(7) in length; UUID.fields returns the 6-field tuple); UUID.__dict__.__contains__('hex') is True (confirmed; 'hex'=3 chars; tied shortest property name with 'int'; UUID.hex returns 32-char lowercase hexadecimal string; name length ordering: 'hex'/'int'(3) < 'bytes'(5) < 'fields'(6) < 'variant'/'version'(7) < 'bytes_le'/'time_low'(8); first uuiddict160 anchor for property name length ordering)"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict160

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_bytes_le_b,  "UUID.__dict__.__contains__", ["bytes_le"], true, "uuid.UUID.__dict__.__contains__('bytes_le') == True (confirmed; 'bytes_le'=8 chars; tied longest with 'time_low'=8)"]
    - [dict_has_time_low_b,  "UUID.__dict__.__contains__", ["time_low"], true, "uuid.UUID.__dict__.__contains__('time_low') == True (confirmed; 'time_low'=8 chars; tied longest with 'bytes_le'=8; 'time'=4+'_low'=4)"]
    - [dict_has_fields_b,    "UUID.__dict__.__contains__", ["fields"],   true, "uuid.UUID.__dict__.__contains__('fields') == True (confirmed; 'fields'=6 chars; between 'bytes'(5) and 'version'/'variant'(7))"]
    - [dict_has_hex_b,       "UUID.__dict__.__contains__", ["hex"],      true, "uuid.UUID.__dict__.__contains__('hex') == True (confirmed; 'hex'=3 chars; shortest; name ordering: 'hex'(3) < 'bytes'(5) < 'fields'(6) < 'version'(7) < 'bytes_le'(8))"]

# ---------------------------------------------------------------------------
# UUID property name lengths as integer values
#
# Wave 350 theme: integer lengths of UUID property names from __dict__.
#
# 'hex'.__len__() == 3 and 'int'.__len__() == 3 (shortest).
# 'bytes'.__len__() == 5.
# 'version'.__len__() == 7 and 'variant'.__len__() == 7.
# 'bytes_le'.__len__() == 8 and 'time_low'.__len__() == 8.
# UUID.__dict__.__contains__('hex') (confirmed).
# No prior uuid spec anchors these integer name lengths as a combined table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra160.UUID_dict_property_name_length_values:
  description: "uuid.UUID.__dict__.__contains__('int')==True / UUID.__dict__.__contains__('version')==True / UUID.__dict__.__contains__('variant')==True / UUID.__dict__.__contains__('bytes')==True — UUID.__dict__.__contains__('int') is True ('int'=3 chars; UUID.int property returns the 128-bit integer value of the UUID; 'int'(3)=='hex'(3) — shortest property names; both 3-char properties give raw numeric representations: 'hex' as hexadecimal string and 'int' as integer; uuid_extra156 anchors); UUID.__dict__.__contains__('version') is True (confirmed; 'version'=7 chars; UUID.version property returns the version number 1/3/4/5; raises ValueError for non-RFC-4122 UUIDs (variant!=SPECIFIED_IN_RFC_4122); 'version'(7)=='variant'(7) in length — both 7-char property names; uuid_extra156 anchors this); UUID.__dict__.__contains__('variant') is True (confirmed; 'variant'=7 chars; UUID.variant property returns a descriptive string; 'variant'(7)=='version'(7) — tied 7-char property names; both describe structural metadata of the UUID, not its data value; uuid_extra156 anchors this); UUID.__dict__.__contains__('bytes') is True (confirmed; 'bytes'=5 chars; UUID.bytes property returns 16-byte big-endian bytes; 'bytes'(5) is between the 3-char short names and the 6-7-char medium names in length; uuid_extra156 anchors; first uuiddict160 anchor for int/version/variant/bytes confirmations)"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict160

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_int_b,      "UUID.__dict__.__contains__", ["int"],     true, "uuid.UUID.__dict__.__contains__('int') == True (confirmed; 'int'=3 chars; 128-bit integer UUID; 'int'(3)=='hex'(3) — tied shortest property name)"]
    - [dict_has_version_b,  "UUID.__dict__.__contains__", ["version"], true, "uuid.UUID.__dict__.__contains__('version') == True (confirmed; 'version'=7 chars; UUID version 1/3/4/5; 'version'(7)=='variant'(7); uuid_extra156 anchors)"]
    - [dict_has_variant_b,  "UUID.__dict__.__contains__", ["variant"], true, "uuid.UUID.__dict__.__contains__('variant') == True (confirmed; 'variant'=7 chars; tied with 'version'(7); uuid_extra156 anchors; confirmed via __contains__)"]
    - [dict_has_bytes_b,    "UUID.__dict__.__contains__", ["bytes"],   true, "uuid.UUID.__dict__.__contains__('bytes') == True (confirmed; 'bytes'=5 chars; 16-byte big-endian; uuid_extra156 anchors; 'bytes'(5)<'fields'(6)<'version'(7))"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex') — standalone
#
# uuid.UUID.__dict__.__contains__('hex') is True. UUID.hex is a property that returns the
# UUID as a 32-character lowercase hexadecimal string without dashes (removing the four
# hyphens from the canonical str() form). 'hex' (3 chars) is one of the two shortest
# property names on uuid.UUID (tied with 'int'). uuid_extra156 anchors this via 'in' syntax;
# this standalone anchors via __contains__ method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra160.UUID_dict_contains_hex:
  description: "uuid.UUID.__dict__.__contains__('hex') == True — 'hex' (3 chars; UUID.hex returns 32-char lowercase hexadecimal string without dashes; one of two shortest property names on UUID (tied with 'int'=3); uuid_extra156 anchors via 'in' syntax; UUID.__dict__.__len__()==37; name length ordering: 'hex'/'int'(3) < 'bytes'(5) < 'fields'(6) < 'variant'/'version'(7) < 'bytes_le'/'time_low'(8); first uuiddict160 standalone for UUID.__dict__.__contains__('hex')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('int') — standalone
#
# uuid.UUID.__dict__.__contains__('int') is True. UUID.int is a property that returns the
# UUID as a 128-bit non-negative integer. This is the most compact numeric representation.
# UUID.int and UUID.hex are the two shortest-named properties on UUID (both 3 chars) and
# both provide raw value representations (integer and hexadecimal string respectively).
# uuid_extra156 anchors this via 'in' syntax. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra160.UUID_dict_contains_int:
  description: "uuid.UUID.__dict__.__contains__('int') == True — 'int' (3 chars; UUID.int returns the 128-bit non-negative integer value; tied shortest property name with 'hex'=3; 'int'(3)=='hex'(3) — two shortest property names on UUID; uuid_extra156 anchors via 'in' syntax; UUID.__dict__.__len__()==37; first uuiddict160 standalone for UUID.__dict__.__contains__('int')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('bytes_le') — standalone
#
# uuid.UUID.__dict__.__contains__('bytes_le') is True. UUID.bytes_le is a property that
# returns the UUID as a 16-byte bytes object in little-endian (Microsoft/Windows GUID)
# byte order. The first three components (time_low 4 bytes, time_mid 2 bytes, time_hi 2 bytes)
# are stored in little-endian order, while the remaining 8 bytes are in big-endian order.
# 'bytes_le' (8 chars) = 'bytes'=5 + '_le'=3. This is a novel anchor (uuid_extra156 does
# not anchor bytes_le membership). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra160.UUID_dict_contains_bytes_le:
  description: "uuid.UUID.__dict__.__contains__('bytes_le') == True — 'bytes_le' (8 chars = 'bytes'=5 + '_le'=3; UUID.bytes_le returns 16-byte little-endian (Windows GUID) bytes; first 3 components time_low/time_mid/time_hi in little-endian; remaining 8 bytes big-endian; '_le' suffix from 'little-endian'; 'bytes_le'(8)=='time_low'(8) — tied longest property name; novel anchor — uuid_extra156 does not anchor bytes_le; UUID.__dict__.__len__()==37; first uuiddict160 standalone for UUID.__dict__.__contains__('bytes_le')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["bytes_le"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('fields') — standalone
#
# uuid.UUID.__dict__.__contains__('fields') is True. UUID.fields is a property that returns
# a tuple of the six integer fields of the UUID: (time_low, time_mid, time_hi_version,
# clock_seq_hi_variant, clock_seq_low, node). These six fields are defined in RFC 4122
# Section 4.1.2. UUID.fields is useful for extracting the structured components of a UUID
# without needing to manipulate the int or bytes representations directly.
# 'fields' (6 chars) is a novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra160.UUID_dict_contains_fields:
  description: "uuid.UUID.__dict__.__contains__('fields') == True — 'fields' (6 chars; UUID.fields returns a tuple of 6 integer fields: (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node); RFC 4122 Section 4.1.2; 'fields'(6) is between 'bytes'(5) and 'version'/'variant'(7) in length; novel anchor — uuid_extra156 does not anchor 'fields' membership explicitly; UUID.__dict__.__len__()==37; first uuiddict160 standalone for UUID.__dict__.__contains__('fields')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["fields"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('time_low') — standalone
#
# uuid.UUID.__dict__.__contains__('time_low') is True. UUID.time_low is a property that
# returns the first 32 bits of the UUID as an integer. The time_low field is the lowest
# 32 bits of the 60-bit timestamp in RFC 4122. For version-1 UUIDs, time_low encodes part
# of the timestamp. 'time_low' (8 chars) = 'time'=4 + '_low'=4. 'time_low'(8) is tied with
# 'bytes_le'(8) as the longest property name in this spec. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra160.UUID_dict_contains_time_low:
  description: "uuid.UUID.__dict__.__contains__('time_low') == True — 'time_low' (8 chars = 'time'=4 + '_low'=4; UUID.time_low returns first 32 bits of UUID as integer; RFC 4122 time_low field; for version-1 UUIDs encodes lowest 32 bits of 60-bit timestamp; 'time_low'(8)=='bytes_le'(8) — tied longest property name in this spec; novel anchor; UUID.__dict__.__len__()==37; first uuiddict160 standalone for UUID.__dict__.__contains__('time_low')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["time_low"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('version') — standalone
#
# uuid.UUID.__dict__.__contains__('version') is True. UUID.version is a property that
# returns the UUID version number (1, 3, 4, or 5). For variant==SPECIFIED_IN_RFC_4122 UUIDs,
# version encodes which algorithm was used to generate the UUID. Raises ValueError for
# non-RFC-4122 UUIDs. 'version' (7 chars) = 'ver'=3 + 'sion'=4. uuid_extra156 anchors
# this via 'in' syntax; this standalone anchors via __contains__ method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra160.UUID_dict_contains_version:
  description: "uuid.UUID.__dict__.__contains__('version') == True — 'version' (7 chars; UUID.version property returns UUID version number 1/3/4/5; raises ValueError for non-RFC-4122 UUIDs; 'version'(7)=='variant'(7) — tied 7-char property names; uuid_extra156 anchors via 'in' syntax; confirmed via __contains__ here; 'variant'/'version'(7) > 'fields'(6) > 'bytes'(5) in length ordering; first uuiddict160 standalone for UUID.__dict__.__contains__('version')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('variant') — standalone
#
# uuid.UUID.__dict__.__contains__('variant') is True. UUID.variant is a property that
# returns a string describing the UUID variant (e.g., 'specified in RFC 4122',
# 'reserved for NCS compatibility', 'reserved, Microsoft Corporation backward compatibility',
# 'reserved for future definition'). 'variant' (7 chars) == 'version' (7 chars) — both are
# 7-char UUID metadata properties. uuid_extra156 anchors this via 'in' syntax.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra160.UUID_dict_contains_variant:
  description: "uuid.UUID.__dict__.__contains__('variant') == True — 'variant' (7 chars; UUID.variant property returns descriptive string e.g. 'specified in RFC 4122'; four possible variants: RFC_4122/RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE; 'variant'(7)=='version'(7) — both 7-char metadata property names on UUID; uuid_extra156 anchors via 'in' syntax; confirmed via __contains__ here; first uuiddict160 standalone for UUID.__dict__.__contains__('variant')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["variant"]
  expected: true
