spec: dequal
version: ">=2.0.0"
backend: node(dequal)

docs: https://github.com/lukeed/dequal#readme

provenance:
  derived_from:
    - "dequal README — https://github.com/lukeed/dequal#readme"
    - "Test vectors verified with dequal@2.0.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "dequal source: dist/index.js"
  notes:
    - "dequal exports { dequal } as a named export."
    - "require('dequal').dequal returns the function."
    - "Returns true if two values are deeply equal, false otherwise."
    - "Handles objects, arrays, dates, regexes, and primitives."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean. No errors."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table dequal.equal:
  kind: node_module_call_eq
  function: dequal
  category: equal
  id_prefix: deq

  columns: [id, args, expected]
  rows:
    - [obj_eq,   [{"a": 1}, {"a": 1}],     true]
    - [obj_ne,   [{"a": 1}, {"a": 2}],     false]
    - [arr_eq,   [[1, 2, 3], [1, 2, 3]],   true]
    - [num_eq,   [1, 1],                    true]
    - [str_ne,   ["a", "b"],               false]
