spec: theseus_csv
version: ">=3.9"
backend: python_cleanroom(theseus_csv)
blocks: csv

docs: https://www.rfc-editor.org/rfc/rfc4180

provenance:
  derived_from:
    - "https://www.rfc-editor.org/rfc/rfc4180 — CSV RFC"
  notes:
    - "Clean-room CSV reader/writer. Do NOT import csv."
    - "reader(lines, delimiter=',') parses an iterable of strings into rows (lists of strings)."
    - "writer output: join fields with delimiter, quoting fields containing delimiter or newline."
    - "Round-trip: write then read returns the same data."
    - "csv_parse_simple_row(['a,b,c']) returns [['a', 'b', 'c']]."
    - "csv_parse_quoted_row(['\"hello, world\",foo']) returns [['hello, world', 'foo']]."
    - "csv_write_row(['a', 'b,c']) returns 'a,\"b,c\"'."
    - "Export: reader(lines, delimiter=',') -> list[list[str]], writer_row(fields, delimiter=',') -> str."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_csv.parse_simple:
  description: "csv_parse_simple_row() returns [['a', 'b', 'c']]"
  category: parse
  kind: python_call_eq
  function: csv_parse_simple_row
  args: []
  expected: [["a", "b", "c"]]

invariant theseus_csv.parse_quoted:
  description: "csv_parse_quoted_row() returns [['hello, world', 'foo']]"
  category: parse
  kind: python_call_eq
  function: csv_parse_quoted_row
  args: []
  expected: [["hello, world", "foo"]]

invariant theseus_csv.write_row:
  description: "csv_write_row() returns 'a,\"b,c\"'"
  category: write
  kind: python_call_eq
  function: csv_write_row
  args: []
  expected: "a,\"b,c\""
