spec: socket_extra248
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
    - "socket_extra247.zspec.zsdl — covers AF_INET/SOCK_STREAM/SOCK_DGRAM/IPPROTO_TCP/IPPROTO_UDP integer values / AF_INET/SOCK_STREAM enum class names and .name / socket.socket class __name__/__module__/__qualname__ (table + invariants)."
  notes:
    - "Wave 294 theme: socket module error classes identity and additional socket constants on macOS."
    - "socket.timeout.__name__ == 'TimeoutError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout is TimeoutError == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error is OSError == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__ == 'gaierror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.AF_UNIX).__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RD == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_WR == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RDWR == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.SHUT_RD).__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET == 65535. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOMAXCONN == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.timeout was deprecated in Python 3.11 and is now an alias for the built-in TimeoutError. socket.timeout.__name__ is 'TimeoutError' (not 'timeout') because it IS TimeoutError — socket.timeout is TimeoutError evaluates to True."
    - "Note: socket.error is OSError — a long-standing alias. socket.error.__name__ is 'OSError' (not 'error') for the same reason. These aliases exist for backward compatibility with code that caught socket.error or socket.timeout."
    - "Note: socket.gaierror is the genuine socket module exception for getaddrinfo/getnameinfo errors; it has its own name 'gaierror' (lowercase) and inherits from OSError (not directly from socket.error)."
    - "Note: socket.AF_UNIX==1 is specific to macOS/BSD; on Linux AF_UNIX==1 as well. SHUT_RD=0/SHUT_WR=1/SHUT_RDWR=2 are plain ints (not IntEnum) on macOS/Python 3.14.3. SOL_SOCKET=65535 is macOS-specific (Linux uses 1)."
    - "Note: socket.SOMAXCONN==128 is the maximum queue length for pending connections — may be overridden by the OS at runtime, but the Python constant is 128 on macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket error class identity: timeout, error, gaierror
#
# Wave 294 theme: socket module exception class __name__ and inheritance.
#
# socket.timeout is now an alias for built-in TimeoutError (since Python 3.11).
# socket.error is an alias for OSError. socket.gaierror is a genuine socket
# exception for getaddrinfo/getnameinfo failures; its __name__ is 'gaierror'
# and it inherits from OSError. socket_extra96 does not anchor these error
# class names; no prior spec anchors timeout/__name__, error/__name__, and
# gaierror/__name__/__module__ together as a grouped table under sockconst294.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra248.error_class_identity:
  description: "timeout.__name__.__eq__('TimeoutError')==True / error.__name__.__eq__('OSError')==True / gaierror.__name__.__eq__('gaierror')==True / gaierror.__module__.__eq__('socket')==True / \"socket.gaierror.__bases__[0].__name__.__eq__\"('OSError')==True — socket.timeout is an alias for built-in TimeoutError (deprecated in 3.11); socket.error is an alias for OSError; socket.gaierror is a genuine exception with __name__=='gaierror' and __module__=='socket'; gaierror inherits from OSError; extra96 does not anchor error class names; first sockconst294 anchor"
  kind: python_call_eq
  category: error_classes
  id_prefix: sockconst294

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_name_eq,   "timeout.__name__.__eq__",                          ["TimeoutError"], true, "socket.timeout.__name__ is 'TimeoutError' (socket.timeout is TimeoutError alias since 3.11)"]
    - [error_name_eq,     "error.__name__.__eq__",                            ["OSError"],      true, "socket.error.__name__ is 'OSError' (socket.error is OSError backward-compat alias)"]
    - [gaierror_name_eq,  "gaierror.__name__.__eq__",                         ["gaierror"],     true, "socket.gaierror.__name__ is 'gaierror' (genuine socket exception, lowercase)"]
    - [gaierror_module_eq, "gaierror.__module__.__eq__",                      ["socket"],       true, "socket.gaierror.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [gaierror_bases_eq, "socket.gaierror.__bases__[0].__name__.__eq__",     ["OSError"],      true, "socket.gaierror inherits from OSError (not directly from Exception)"]

# ---------------------------------------------------------------------------
# socket.AF_UNIX and SHUT_RD/SHUT_WR/SHUT_RDWR integer values
#
# Wave 294 theme: socket.AF_UNIX and SHUT_* shutdown constants integer values.
#
# AF_UNIX==1 on macOS/BSD (Unix domain sockets). SHUT_RD=0, SHUT_WR=1,
# SHUT_RDWR=2 are used as the 'how' argument to socket.shutdown(). These
# SHUT_* constants are plain ints (not IntEnum) on macOS/Python 3.14.3.
# AF_UNIX is an AddressFamily IntEnum member. socket_extra247 anchors AF_INET
# and SOCK_STREAM integer values; no prior spec anchors AF_UNIX==1 and
# SHUT_* values as a grouped table under sockconst294.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra248.AF_UNIX_and_SHUT_constants:
  description: "AF_UNIX.__eq__(1)==True / SHUT_RD.__eq__(0)==True / SHUT_WR.__eq__(1)==True / SHUT_RDWR.__eq__(2)==True — AF_UNIX==1 on macOS/BSD (Unix domain sockets; same value on Linux); SHUT_RD=0/SHUT_WR=1/SHUT_RDWR=2 are shutdown(how) argument constants (plain int, not IntEnum); extra247 anchors AF_INET/SOCK_STREAM integer values; first sockconst294 anchor for AF_UNIX and SHUT_* values"
  kind: python_call_eq
  category: socket_constants
  id_prefix: sockconst294

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_eq,    AF_UNIX.__eq__,    [1], true, "AF_UNIX == 1 (Unix domain socket address family; macOS/BSD and Linux)"]
    - [shut_rd_eq,    SHUT_RD.__eq__,    [0], true, "SHUT_RD == 0 (shutdown further receives; socket.shutdown(SHUT_RD))"]
    - [shut_wr_eq,    SHUT_WR.__eq__,    [1], true, "SHUT_WR == 1 (shutdown further sends; socket.shutdown(SHUT_WR))"]
    - [shut_rdwr_eq,  SHUT_RDWR.__eq__,  [2], true, "SHUT_RDWR == 2 (shutdown both sends and receives; full close)"]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET and SOMAXCONN constants
#
# Wave 294 theme: socket.SOL_SOCKET and SOMAXCONN integer values on macOS.
#
# SOL_SOCKET==65535 is a macOS-specific value for the socket-level option layer
# used with setsockopt/getsockopt (e.g., SO_REUSEADDR, SO_KEEPALIVE). On Linux
# the value is 1, so this is platform-specific. SOMAXCONN==128 is the Python
# constant for the maximum listen backlog; the OS may support higher values via
# sysctl but the constant is 128. Both are plain int types on macOS/Python 3.14.3.
# socket_extra247 does not anchor SOL_SOCKET or SOMAXCONN; no prior spec anchors
# these as a grouped table under sockconst294.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra248.SOL_SOCKET_and_SOMAXCONN:
  description: "SOL_SOCKET.__eq__(65535)==True / SOMAXCONN.__eq__(128)==True — SOL_SOCKET=65535 is macOS-specific socket option level for setsockopt/getsockopt (Linux uses 1); SOMAXCONN=128 is the maximum listen backlog constant (OS may allow higher via sysctl); both are plain int on macOS/Python 3.14.3; extra247 anchors IPPROTO_TCP/UDP; first sockconst294 anchor for SOL_SOCKET and SOMAXCONN"
  kind: python_call_eq
  category: socket_constants
  id_prefix: sockconst294

  columns: [id, function, args, expected, description]
  rows:
    - [sol_socket_eq,  SOL_SOCKET.__eq__,  [65535], true, "SOL_SOCKET == 65535 on macOS (socket option level; Linux uses 1)"]
    - [somaxconn_eq,   SOMAXCONN.__eq__,   [128],   true, "SOMAXCONN == 128 (maximum listen backlog constant on macOS)"]

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror') — standalone
#
# socket.gaierror.__name__ is 'gaierror'. This is the exception raised by
# socket.getaddrinfo() and socket.getnameinfo() when address-related errors
# occur (e.g., DNS lookup failure, unknown host). The name 'gaierror' follows
# the lowercase C extension naming convention (like struct.error). It is a
# genuine socket exception class (not an alias) defined in Lib/socket.py
# and inherits from OSError. socket_extra96 does not anchor gaierror.__name__;
# no prior spec anchors this as a standalone under sockconst294.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra248.gaierror_name_eq:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — raised by getaddrinfo()/getnameinfo() for DNS/address errors; lowercase name 'gaierror' follows C extension convention (like struct.error); genuine socket exception (not an alias, unlike socket.error/socket.timeout); defined in Lib/socket.py; inherits from OSError; extra96 does not anchor gaierror.__name__; first standalone under sockconst294"
  category: error_classes
  kind: python_call_eq
  function: "gaierror.__name__.__eq__"
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout.__name__ is 'TimeoutError'. In Python 3.3, TimeoutError was
# added to the built-in exceptions. In Python 3.11, socket.timeout was
# officially deprecated and made a full alias for the built-in TimeoutError.
# As a result, socket.timeout is TimeoutError (identity check), and its
# __name__ is 'TimeoutError' (the built-in's name), not 'timeout'.
# Code catching socket.timeout is catching exactly the same class as TimeoutError.
# No prior spec anchors socket.timeout.__name__.__eq__ as a standalone
# under sockconst294. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra248.timeout_name_eq_TimeoutError:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — socket.timeout is a full alias for built-in TimeoutError since Python 3.11 (identity check: socket.timeout is TimeoutError == True); __name__ is 'TimeoutError' not 'timeout'; code catching socket.timeout catches exactly TimeoutError; deprecated in 3.11 for backward compat; no prior spec anchors timeout.__name__ as standalone; first standalone under sockconst294"
  category: error_classes
  kind: python_call_eq
  function: "timeout.__name__.__eq__"
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNIX.__eq__(1) — standalone
#
# socket.AF_UNIX is 1 on macOS. AF_UNIX is the address family for Unix domain
# sockets, which communicate via the filesystem rather than over a network.
# On both macOS/BSD and Linux, AF_UNIX has the value 1. It is an AddressFamily
# IntEnum member (like AF_INET). Unix domain sockets are used for local IPC
# (inter-process communication) and are faster than loopback TCP for local use.
# socket_extra96 anchors AF_UNIX.__class__.__name__; no prior spec anchors
# AF_UNIX.__eq__(1) as a standalone under sockconst294.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra248.AF_UNIX_eq_1:
  description: "socket.AF_UNIX.__eq__(1) == True — AF_UNIX==1 on macOS and Linux; AddressFamily IntEnum member; used for Unix domain sockets (filesystem-based IPC); faster than loopback TCP for local communication; extra96 anchors AF_UNIX.__class__.__name__; no prior spec anchors AF_UNIX.__eq__(1) as standalone; first standalone under sockconst294"
  category: socket_constants
  kind: python_call_eq
  function: AF_UNIX.__eq__
  args: [1]
  expected: true
