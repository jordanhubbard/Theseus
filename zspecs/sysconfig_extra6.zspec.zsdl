spec: sysconfig_extra6
version: ">=3.9"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sysconfig.html — Python sysconfig documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
  notes:
    - "This spec extends sysconfig.zspec.zsdl through sysconfig_extra5.zspec.zsdl."
    - "sysconfig (base) covers: function names table (10 functions); return types for get_python_version/get_scheme_names/get_path_names/get_platform; get_scheme_names len==7 (note: current CPython returns a larger tuple); get_path_names contains stdlib/platlib."
    - "sysconfig_extra covers: function names (9 functions); return types via method."
    - "sysconfig_extra2 covers: get_config_vars/get_paths return dict and non-empty; get_scheme_names contains 'posix_prefix'; get_path_names contains scripts/data; get_python_version contains dot/len>=3."
    - "sysconfig_extra3 covers: __qualname__ for 8 functions; __module__ for get_python_version/get_platform; get_default_scheme __name__/__qualname__/returns_str/non-empty."
    - "sysconfig_extra4 covers: module __name__; is_python_build returns_bool; get_platform nonempty; get_path_names len==8; get_scheme_names posix_home; __module__ for get_config_var/parse_config_h/get_path/get_paths; __qualname__ for get_config_var/parse_config_h."
    - "sysconfig_extra5 covers: __doc__ type for 4 functions; get_path_names contains include/purelib; get_scheme_names contains posix_local; get_python_version len>=3; get_config_var.__name__ class is str."
    - "This spec adds new axes: get_path_names().__class__.__name__ == 'tuple'; get_scheme_names().__class__.__name__ == 'tuple'; get_scheme_names() contains 'venv'; get_scheme_names() contains 'posix_user'; get_path_names() contains 'platstdlib'; get_config_vars() len >= 100; parse_config_h __doc__ type == 'str'; get_paths() contains key 'stdlib'; get_paths() contains key 'include'; get_config_var.__name__.__len__() > 0."
    - "get_path_names().__class__.__name__ == 'tuple' — the return value is a tuple of path-name strings."
    - "get_scheme_names().__class__.__name__ == 'tuple' — the return value is a tuple of scheme-name strings."
    - "'venv' in get_scheme_names() — the 'venv' scheme is present in CPython >= 3.11+ on all platforms."
    - "'posix_user' in get_scheme_names() — always present on POSIX (macOS, Linux, FreeBSD)."
    - "'platstdlib' in get_path_names() — platform-specific standard library path is always one of the 7 names."
    - "len(get_config_vars()) >= 100 — the build configuration dictionary always has many entries."
    - "parse_config_h.__doc__ is a str — all sysconfig public functions have docstrings."
    - "'stdlib' in get_paths() — get_paths() always returns the stdlib install path as a key."
    - "'include' in get_paths() — get_paths() always returns the include install path as a key."
    - "len(get_config_var.__name__) > 0 — __name__ is a non-empty string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Return type checks for get_path_names() and get_scheme_names()
#
# sysconfig (base) verifies return types via method_chain but not __class__.__name__
# directly. No prior spec confirms the tuple type via __class__.__name__.
# ---------------------------------------------------------------------------

table sysconfig_extra6.collection_return_types:
  description: "get_path_names() and get_scheme_names() return tuple objects"
  kind: python_call_eq
  category: runtime
  id_prefix: rtype

  columns: [id, function, args, expected]
  rows:
    - [path_names,   "get_path_names().__class__.__name__.__eq__",   ["tuple"], true]
    - [scheme_names, "get_scheme_names().__class__.__name__.__eq__", ["tuple"], true]

# ---------------------------------------------------------------------------
# get_scheme_names() additional membership checks
#
# sysconfig_extra2 covers 'posix_prefix'; extra4 covers 'posix_home';
# extra5 covers 'posix_local'. New here: 'venv' and 'posix_user'.
# ---------------------------------------------------------------------------

invariant sysconfig_extra6.get_scheme_names.venv:
  description: "sysconfig.get_scheme_names().__contains__('venv') — venv scheme present on CPython"
  category: runtime
  kind: python_call_eq
  function: get_scheme_names
  args: []
  method: __contains__
  method_args: ["venv"]
  expected: true

invariant sysconfig_extra6.get_scheme_names.posix_user:
  description: "sysconfig.get_scheme_names().__contains__('posix_user') — posix_user scheme present on POSIX"
  category: runtime
  kind: python_call_eq
  function: get_scheme_names
  args: []
  method: __contains__
  method_args: ["posix_user"]
  expected: true

# ---------------------------------------------------------------------------
# get_path_names() — 'platstdlib' membership
#
# sysconfig (base) covers 'stdlib' and 'platlib'; extra2 covers 'scripts' and 'data';
# extra5 covers 'include' and 'purelib'. New here: 'platstdlib'.
# ---------------------------------------------------------------------------

invariant sysconfig_extra6.get_path_names.platstdlib:
  description: "sysconfig.get_path_names().__contains__('platstdlib') — platform stdlib path is always present"
  category: runtime
  kind: python_call_eq
  function: get_path_names
  args: []
  method: __contains__
  method_args: ["platstdlib"]
  expected: true

# ---------------------------------------------------------------------------
# get_config_vars() — minimum length check
#
# sysconfig_extra2 confirms get_config_vars() returns a non-empty dict (len > 0).
# New here: a stronger lower bound of 100 entries, which holds on every supported
# CPython build (macOS, Linux, FreeBSD all produce hundreds of build variables).
# ---------------------------------------------------------------------------

invariant sysconfig_extra6.get_config_vars.len_ge_100:
  description: "len(sysconfig.get_config_vars()) >= 100 — build config dict has many entries"
  category: runtime
  kind: python_call_eq
  function: get_config_vars
  args: []
  method: __len__
  method_args: []
  method_chain: __ge__
  method_chain_args: [100]
  expected: true

# ---------------------------------------------------------------------------
# parse_config_h __doc__ type
#
# sysconfig_extra5 covers __doc__ type for get_python_version/get_platform/
# is_python_build/get_config_var. parse_config_h __doc__ is new here.
# ---------------------------------------------------------------------------

invariant sysconfig_extra6.parse_config_h.doc_is_str:
  description: "sysconfig.parse_config_h.__doc__.__class__.__name__ == 'str' — has a docstring"
  category: function_identity
  kind: python_call_eq
  function: parse_config_h.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# get_paths() key membership — 'stdlib' and 'include'
#
# sysconfig_extra2 confirms get_paths() is a non-empty dict but does not check
# specific keys. get_paths() always contains at least 'stdlib' and 'include'
# on every supported POSIX platform.
# ---------------------------------------------------------------------------

invariant sysconfig_extra6.get_paths.stdlib_key:
  description: "sysconfig.get_paths().__contains__('stdlib') — stdlib path key is always present"
  category: runtime
  kind: python_call_eq
  function: get_paths
  args: []
  method: __contains__
  method_args: ["stdlib"]
  expected: true

invariant sysconfig_extra6.get_paths.include_key:
  description: "sysconfig.get_paths().__contains__('include') — include path key is always present"
  category: runtime
  kind: python_call_eq
  function: get_paths
  args: []
  method: __contains__
  method_args: ["include"]
  expected: true

# ---------------------------------------------------------------------------
# get_config_var.__name__ is non-empty
#
# sysconfig_extra5 confirms get_config_var.__name__.__class__.__name__ == 'str'.
# New here: the name is non-empty (len > 0). This is a distinct behavioral axis.
# ---------------------------------------------------------------------------

invariant sysconfig_extra6.get_config_var.name_nonempty:
  description: "len(sysconfig.get_config_var.__name__) > 0 — __name__ is a non-empty string"
  category: function_identity
  kind: python_call_eq
  function: get_config_var.__name__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true
