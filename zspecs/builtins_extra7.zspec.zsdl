spec: builtins_extra7
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/builtins.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/builtins.html — Python builtins module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins.zspec.zsdl — covers exception/type/function __name__ checks and basic function calls"
    - "builtins_extra.zspec.zsdl — covers function call behavior"
    - "builtins_extra2.zspec.zsdl — covers exception class hierarchies"
    - "builtins_extra3.zspec.zsdl — covers __name__ for print/input/open/vars/dir/id/frozenset/memoryview/slice/staticmethod/classmethod/super; __module__ for int/str/list/dict/tuple/set/frozenset/bytes/bytearray/bool/float/complex/type/object; base class hierarchy"
    - "builtins_extra4.zspec.zsdl — covers __qualname__ for abs through id (26 entries)"
    - "builtins_extra5.zspec.zsdl — covers __qualname__ for input through zip (36 entries)"
    - "builtins_extra6.zspec.zsdl — covers __qualname__ for bytearray/bytes/classmethod; NotImplemented/Ellipsis class names; __module__ for abs/len/print/type"
  notes:
    - "This spec adds __module__ checks for built-in functions NOT yet covered: ord, hex, bin, chr, sorted, hash, repr, callable, iter, next, all, any, sum, min, max, divmod, round, pow, id, vars, dir."
    - "builtins_extra3 covers __module__ for built-in TYPES (int, str, list, dict, tuple, set, frozenset, bytes, bytearray, bool, float, complex, type, object)."
    - "builtins_extra6 covers __module__ for abs, len, print, type (4 functions)."
    - "All remaining built-in functions have __module__ == 'builtins' — they are implemented in CPython's C core."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — built-in functions not yet covered
#
# builtins_extra3 covers __module__ for types: int, str, list, dict, tuple,
# set, frozenset, bytes, bytearray, bool, float, complex, type, object.
# builtins_extra6 covers __module__ for functions: abs, len, print, type.
#
# This table covers the remaining built-in functions. All have __module__ ==
# 'builtins' because they are defined in CPython's built-in module (C level).
# ---------------------------------------------------------------------------

table builtins_extra7.function_modules_a:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [ord,      ord.__module__.__eq__,      ["builtins"], true]
    - [hex,      hex.__module__.__eq__,      ["builtins"], true]
    - [bin,      bin.__module__.__eq__,      ["builtins"], true]
    - [chr,      chr.__module__.__eq__,      ["builtins"], true]
    - [sorted,   sorted.__module__.__eq__,   ["builtins"], true]
    - [hash,     hash.__module__.__eq__,     ["builtins"], true]
    - [repr,     repr.__module__.__eq__,     ["builtins"], true]
    - [callable, callable.__module__.__eq__, ["builtins"], true]
    - [iter,     iter.__module__.__eq__,     ["builtins"], true]
    - [next,     next.__module__.__eq__,     ["builtins"], true]

table builtins_extra7.function_modules_b:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [all,    all.__module__.__eq__,    ["builtins"], true]
    - [any,    any.__module__.__eq__,    ["builtins"], true]
    - [sum,    sum.__module__.__eq__,    ["builtins"], true]
    - [min,    min.__module__.__eq__,    ["builtins"], true]
    - [max,    max.__module__.__eq__,    ["builtins"], true]
    - [divmod, divmod.__module__.__eq__, ["builtins"], true]
    - [round,  round.__module__.__eq__,  ["builtins"], true]
    - [pow,    pow.__module__.__eq__,    ["builtins"], true]
    - [id,     id.__module__.__eq__,     ["builtins"], true]
    - [vars,   vars.__module__.__eq__,   ["builtins"], true]
    - [dir,    dir.__module__.__eq__,    ["builtins"], true]
