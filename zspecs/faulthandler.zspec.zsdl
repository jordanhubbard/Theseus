spec: faulthandler
version: ">=3.3"
backend: python_module(faulthandler)

docs: https://docs.python.org/3/library/faulthandler.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/faulthandler.html — Python faulthandler module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/faulthandler.c"
  notes:
    - "faulthandler was added in Python 3.3 to dump tracebacks on fatal errors."
    - "All public functions are implemented in C (Modules/faulthandler.c) and exposed as module-level built-in functions."
    - "faulthandler.enable, disable, is_enabled, dump_traceback, dump_traceback_later, cancel_dump_traceback_later are always present."
    - "faulthandler.register and faulthandler.unregister are available on POSIX platforms only (not Windows)."
    - "For __qualname__ of built-in functions, __qualname__ == __name__ (no nesting)."
    - "faulthandler functions have __module__ == 'faulthandler'."
    - "faulthandler.is_enabled() returns a bool — the faulthandler is not enabled by default in normal Python sessions."
    - "is_enabled() may return True if the Python interpreter was launched with -X faulthandler or PYTHONFAULTHANDLER is set; test only verifies the return type is bool."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks
#
# All module-level built-in functions in faulthandler have __qualname__ equal
# to __name__ (no nesting). These are the first faulthandler test vectors.
# register/unregister are POSIX-only; the remaining six are always present.
# ---------------------------------------------------------------------------

table faulthandler.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [enable,                      enable.__qualname__.__eq__,                      ["enable"],                      true]
    - [disable,                     disable.__qualname__.__eq__,                     ["disable"],                     true]
    - [is_enabled,                  is_enabled.__qualname__.__eq__,                  ["is_enabled"],                  true]
    - [dump_traceback,              dump_traceback.__qualname__.__eq__,              ["dump_traceback"],              true]
    - [dump_traceback_later,        dump_traceback_later.__qualname__.__eq__,        ["dump_traceback_later"],        true]
    - [cancel_dump_traceback_later, cancel_dump_traceback_later.__qualname__.__eq__, ["cancel_dump_traceback_later"], true]

# ---------------------------------------------------------------------------
# Function __name__ checks
#
# Verify the __name__ attribute for each built-in function, confirming
# identity separate from __qualname__.
# ---------------------------------------------------------------------------

table faulthandler.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [enable,                      enable.__name__.__eq__,                      ["enable"],                      true]
    - [disable,                     disable.__name__.__eq__,                     ["disable"],                     true]
    - [is_enabled,                  is_enabled.__name__.__eq__,                  ["is_enabled"],                  true]
    - [dump_traceback,              dump_traceback.__name__.__eq__,              ["dump_traceback"],              true]
    - [dump_traceback_later,        dump_traceback_later.__name__.__eq__,        ["dump_traceback_later"],        true]
    - [cancel_dump_traceback_later, cancel_dump_traceback_later.__name__.__eq__, ["cancel_dump_traceback_later"], true]

# ---------------------------------------------------------------------------
# Function __module__ checks
#
# All faulthandler built-in functions report __module__ == 'faulthandler'.
# ---------------------------------------------------------------------------

table faulthandler.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [enable,                      enable.__module__.__eq__,                      ["faulthandler"], true]
    - [disable,                     disable.__module__.__eq__,                     ["faulthandler"], true]
    - [is_enabled,                  is_enabled.__module__.__eq__,                  ["faulthandler"], true]
    - [dump_traceback,              dump_traceback.__module__.__eq__,              ["faulthandler"], true]
    - [dump_traceback_later,        dump_traceback_later.__module__.__eq__,        ["faulthandler"], true]
    - [cancel_dump_traceback_later, cancel_dump_traceback_later.__module__.__eq__, ["faulthandler"], true]

# ---------------------------------------------------------------------------
# Behavioral — is_enabled() return type is bool
#
# faulthandler.is_enabled() always returns a bool regardless of state.
# We verify the return type rather than a fixed truth value because the
# result depends on whether -X faulthandler was passed at interpreter startup.
# ---------------------------------------------------------------------------

invariant faulthandler.is_enabled.return_class_name:
  description: "faulthandler.is_enabled().__class__.__name__ == 'bool'"
  category: behavioral
  kind: python_call_eq
  function: is_enabled
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bool"]
  expected: true

