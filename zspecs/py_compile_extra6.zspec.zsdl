spec: py_compile_extra6
version: ">=3.9"
backend: python_module(py_compile)

docs: https://docs.python.org/3/library/py_compile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/py_compile.html — Python py_compile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/py_compile.py"
    - "py_compile.zspec.zsdl — covers compile/__name__/__module__, PyCompileError/__name__/base/__str__.__name__, PycInvalidationMode/__name__ and TIMESTAMP/CHECKED_HASH/UNCHECKED_HASH class names and values"
    - "py_compile_extra.zspec.zsdl — covers compile/__name__/__module__, PycInvalidationMode/__name__, PyCompileError/__name__/__module__/base, enum member class names/values, value ordering"
    - "py_compile_extra2.zspec.zsdl — covers PycInvalidationMode/__module__/__bases__[0]/__name__=='int', class_names table"
    - "py_compile_extra3.zspec.zsdl — covers compile/__qualname__, PycInvalidationMode/__qualname__, PyCompileError/__qualname__ via table"
    - "py_compile_extra4.zspec.zsdl — covers compile/__class__.__name__=='function', PyCompileError/__bases__/__len__()==1, PyCompileError/__str__.__module__, PycInvalidationMode/_member_names_ len/membership, PycInvalidationMode TIMESTAMP/CHECKED_HASH/UNCHECKED_HASH .name attribute"
    - "py_compile_extra5.zspec.zsdl — covers PycInvalidationMode/_value2member_map_ len/membership, UNCHECKED_HASH.value.__gt__(1), PyCompileError.__init__.__name__, compile/__doc__ is str, PyCompileError/__doc__ is str"
  notes:
    - "This spec adds invariants not covered in any prior py_compile spec."
    - "PycInvalidationMode.__class__.__name__ == 'EnumType' — the metaclass for IntEnum-derived classes is EnumType in CPython 3.11+."
    - "PyCompileError.__init__.__qualname__ == 'PyCompileError.__init__' — constructor qualname is scoped to the class."
    - "PyCompileError.__str__.__qualname__ == 'PyCompileError.__str__' — method qualname confirms it is defined on PyCompileError."
    - "compile.__qualname__.__len__() == 7 — 'compile' has 7 characters."
    - "PycInvalidationMode.__qualname__.__len__() == 19 — 'PycInvalidationMode' has 19 characters."
    - "PyCompileError.__qualname__.__len__() == 14 — 'PyCompileError' has 14 characters."
    - "PyCompileError.__doc__.__class__.__name__ == 'str' — documented in prior spec (extra5). This spec verifies PyCompileError.__doc__.__len__() > 0 instead."
    - "PycInvalidationMode.__doc__ is None on CPython 3.12 — the enum itself has no docstring."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PycInvalidationMode metaclass — EnumType
# No prior py_compile spec checks PycInvalidationMode.__class__.__name__.
# On CPython 3.11+, the metaclass for enum classes is 'EnumType'.
# ---------------------------------------------------------------------------

invariant py_compile_extra6.PycInvalidationMode.metaclass_name:
  description: "py_compile.PycInvalidationMode.__class__.__name__ == 'EnumType' — IntEnum metaclass on CPython 3.11+"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

invariant py_compile_extra6.PycInvalidationMode.metaclass_module:
  description: "py_compile.PycInvalidationMode.__class__.__module__ == 'enum' — EnumType is defined in the enum module"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.__class__.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# PyCompileError.__init__ and __str__ qualified names
# No prior spec checks __qualname__ for these method objects.
# py_compile_extra5 checks PyCompileError.__init__.__name__ == '__init__'.
# This spec adds the qualified-name form which encodes class scoping.
# ---------------------------------------------------------------------------

invariant py_compile_extra6.PyCompileError.init_qualname:
  description: "py_compile.PyCompileError.__init__.__qualname__ == 'PyCompileError.__init__'"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__init__.__qualname__.__eq__
  args: ["PyCompileError.__init__"]
  expected: true

invariant py_compile_extra6.PyCompileError.str_qualname:
  description: "py_compile.PyCompileError.__str__.__qualname__ == 'PyCompileError.__str__'"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__str__.__qualname__.__eq__
  args: ["PyCompileError.__str__"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ string lengths
# py_compile_extra3 adds equality checks for __qualname__. No prior spec
# checks the string lengths of these qualname values.
# ---------------------------------------------------------------------------

table py_compile_extra6.qualname_lengths:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname_len

  columns: [id, function, args, expected]
  rows:
    - [compile,             compile.__qualname__.__len__,             [], 7]
    - [PycInvalidationMode, PycInvalidationMode.__qualname__.__len__, [], 19]
    - [PyCompileError,      PyCompileError.__qualname__.__len__,      [], 14]

# ---------------------------------------------------------------------------
# PycInvalidationMode __doc__ — the enum class itself has no docstring on CPython 3.12
# (individual members may have docs, but the class doc is None).
# No prior spec checks PycInvalidationMode.__doc__ directly.
# ---------------------------------------------------------------------------

invariant py_compile_extra6.PycInvalidationMode.doc_is_none:
  description: "py_compile.PycInvalidationMode.__doc__ is None — enum class has no class-level docstring on CPython 3.12"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# compile.__qualname__ string — confirms module-level function qualname
# py_compile_extra3 checks compile.__qualname__.__eq__("compile") == true.
# This table extends that with the length check (no prior spec uses __len__
# on compile.__qualname__) and cross-checks all three symbols.
# ---------------------------------------------------------------------------

invariant py_compile_extra6.compile.qualname_eq_name:
  description: "py_compile.compile.__qualname__ == py_compile.compile.__name__ — module-level function qualname matches name"
  category: compile
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true
