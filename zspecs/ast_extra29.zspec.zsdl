spec: ast_extra29
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra28.zspec.zsdl — covers __qualname__.__len__() for parse/dump/literal_eval and NodeVisitor/NodeTransformer methods; AST __name__/__module__ lengths (all 3); NodeTransformer.__qualname__.__len__() (15)."
    - "ast_extra27.zspec.zsdl — covers parse/dump/literal_eval __module__.__len__(); NodeVisitor/NodeTransformer __module__.__len__() and __name__.__len__(); visitor method __name__ lengths."
    - "ast_extra22.zspec.zsdl — covers NodeVisitor.visit/__qualname__.__eq__ and NodeTransformer.generic_visit/__qualname__.__eq__; qualname __len__() for parse/dump/literal_eval and various methods."
  notes:
    - "This spec extends ast_extra28.zspec.zsdl."
    - "Prior specs covered: all ast function __name__/__module__/__qualname__ strings and lengths; AST/__name__/__module__/__qualname__ lengths (all 3); NodeVisitor/NodeTransformer class-level identity lengths; visitor method qualname lengths."
    - "This spec covers: ast.__spec__.__class__.__name__ ('ModuleSpec'); ast.AST.__reduce__.__qualname__.__len__() (14); ast.NodeVisitor.__reduce__.__qualname__.__len__() (17); ast module-level constant class names (PyCF_ONLY_AST, PyCF_ALLOW_TOP_LEVEL_AWAIT both 'int'); __qualname__.__len__() for get_docstring/fix_missing_locations/walk."
    - "ast.__spec__.__class__.__name__ == 'ModuleSpec'. Verified."
    - "ast.AST.__reduce__.__qualname__ == 'AST.__reduce__', __qualname__.__len__() == 14. Verified."
    - "ast.NodeVisitor.__reduce__.__qualname__ == 'object.__reduce__', __qualname__.__len__() == 17. Verified."
    - "ast.PyCF_ONLY_AST == 1024, __class__.__name__ == 'int'. Verified."
    - "ast.PyCF_ALLOW_TOP_LEVEL_AWAIT == 8192, __class__.__name__ == 'int'. Verified."
    - "ast.get_docstring.__qualname__ == 'get_docstring', __qualname__.__len__() == 13. Verified."
    - "ast.fix_missing_locations.__qualname__ == 'fix_missing_locations', __qualname__.__len__() == 21. Verified."
    - "ast.walk.__qualname__ == 'walk', __qualname__.__len__() == 4. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: ast module-level constant class names
#
# ast.PyCF_ONLY_AST and ast.PyCF_ALLOW_TOP_LEVEL_AWAIT are compile flags
# stored as plain Python ints. No prior ast spec covers __class__.__name__
# for these constants. Both should report 'int' (len 3).
# Verified: PyCF_ONLY_AST.__class__.__name__ == 'int';
# PyCF_ALLOW_TOP_LEVEL_AWAIT.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table ast_extra29.constant_class_names:
  description: "ast compile-flag constants PyCF_ONLY_AST and PyCF_ALLOW_TOP_LEVEL_AWAIT are plain ints — __class__.__name__ len == 3"
  kind: python_call_eq
  category: module_constants
  id_prefix: ccn29

  columns: [id, function, args, expected]
  rows:
    - [PyCF_ONLY_AST_class_len,              "PyCF_ONLY_AST.__class__.__name__.__len__",              [], 3]
    - [PyCF_ALLOW_TOP_LEVEL_AWAIT_class_len, "PyCF_ALLOW_TOP_LEVEL_AWAIT.__class__.__name__.__len__", [], 3]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for additional ast module-level functions
#
# No prior ast spec covers __qualname__.__len__() for get_docstring,
# fix_missing_locations, or walk. For module-level functions, __qualname__
# equals __name__ (no class prefix).
# Verified: get_docstring=13, fix_missing_locations=21, walk=4.
# ---------------------------------------------------------------------------

table ast_extra29.extra_function_qualname_lengths:
  description: "__qualname__.__len__() for ast.get_docstring/fix_missing_locations/walk — 13/21/4"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: efqlen29

  columns: [id, function, args, expected]
  rows:
    - [get_docstring,         "get_docstring.__qualname__.__len__",         [], 13]
    - [fix_missing_locations, "fix_missing_locations.__qualname__.__len__", [], 21]
    - [walk,                  "walk.__qualname__.__len__",                  [], 4]

# ---------------------------------------------------------------------------
# Standalone: ast.__spec__.__class__.__name__ length == 10
#
# ast.__spec__ is a ModuleSpec instance. 'ModuleSpec' has 10 characters.
# No prior ast spec covers __spec__.__class__.__name__ or its length.
# Verified: ast.__spec__.__class__.__name__ == 'ModuleSpec', len=10.
# ---------------------------------------------------------------------------

invariant ast_extra29.spec_class_name_len:
  description: "ast.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone: ast.AST.__reduce__.__qualname__.__len__() == 14
#
# ast.AST defines its own __reduce__ (qualname 'AST.__reduce__', len 14).
# No prior ast spec covers __reduce__.__qualname__.__len__() for AST.
# Verified: ast.AST.__reduce__.__qualname__ == 'AST.__reduce__', len=14.
# ---------------------------------------------------------------------------

invariant ast_extra29.AST_reduce_qualname_len:
  description: "ast.AST.__reduce__.__qualname__.__len__() == 14 — 'AST.__reduce__' has 14 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "AST.__reduce__.__qualname__.__len__"
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# Standalone: ast.NodeVisitor.__reduce__.__qualname__.__len__() == 17
#
# NodeVisitor inherits __reduce__ from object, so the qualname is
# 'object.__reduce__' (17 chars). No prior ast spec covers __reduce__
# qualname length for NodeVisitor.
# Verified: ast.NodeVisitor.__reduce__.__qualname__ == 'object.__reduce__', len=17.
# ---------------------------------------------------------------------------

invariant ast_extra29.NodeVisitor_reduce_qualname_len:
  description: "ast.NodeVisitor.__reduce__.__qualname__.__len__() == 17 — inherits 'object.__reduce__' (17 chars)"
  category: method_qualnames
  kind: python_call_eq
  function: "NodeVisitor.__reduce__.__qualname__.__len__"
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# Standalone: ast.fix_missing_locations.__qualname__.__len__() == 21
#
# 'fix_missing_locations' has 21 characters — the longest qualname among all
# ast module-level functions. No prior ast spec covers this as a standalone
# invariant in the extra29 namespace.
# Verified: ast.fix_missing_locations.__qualname__ == 'fix_missing_locations', len=21.
# ---------------------------------------------------------------------------

invariant ast_extra29.fix_missing_locations_qualname_len:
  description: "ast.fix_missing_locations.__qualname__.__len__() == 21 — longest ast function qualname"
  category: method_qualnames
  kind: python_call_eq
  function: "fix_missing_locations.__qualname__.__len__"
  args: []
  expected: 21
