spec: re_extra87
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra86."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern/Match method __doc__.__class__.__name__; Match method __qualname__ values and lengths; re module function __code__ attributes; Pattern/Match identity (__name__/__module__/__bases__/__mro__); Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError __name__ and __module__; Pattern/Match method __qualname__ string equality; PatternError/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); re.error alias; re.IGNORECASE/MULTILINE/DOTALL/__class__.__name__; re.RegexFlag/__name__/__module__; re.compile __qualname__/__module__/__qualname__.__len__(); re.IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE values and class names; re.RegexFlag.__bases__[0].__name__; re.RegexFlag.__mro__.__len__(); re.NOFLAG value."
    - "This spec covers: re.Pattern.match.__doc__.__len__() == 63; re.Pattern.search.__doc__.__len__() == 141; re.Pattern.findall.__doc__.__len__() == 66; re.Pattern.finditer.__doc__.__len__() == 135; re.Pattern.sub.__doc__.__len__() == 126; re.Pattern.subn.__doc__.__len__() == 148; re.Pattern.split.__doc__.__len__() == 43; re.Pattern.fullmatch.__doc__.__len__() == 34; re.Match.group.__doc__.__len__() == 130; re.Match.groups.__doc__.__len__() == 138; re.Match.start.__doc__.__len__() == 60; re.Match.end.__doc__.__len__() == 58; re.Match.span.__doc__.__len__() == 70."
    - "re.Pattern.match.__doc__.__len__() == 63 — verified on Python 3.14.3 macOS."
    - "re.Pattern.search.__doc__.__len__() == 141 — verified on Python 3.14.3 macOS."
    - "re.Pattern.findall.__doc__.__len__() == 66 — verified on Python 3.14.3 macOS."
    - "re.Pattern.finditer.__doc__.__len__() == 135 — verified on Python 3.14.3 macOS."
    - "re.Pattern.sub.__doc__.__len__() == 126 — verified on Python 3.14.3 macOS."
    - "re.Pattern.subn.__doc__.__len__() == 148 — verified on Python 3.14.3 macOS."
    - "re.Pattern.split.__doc__.__len__() == 43 — verified on Python 3.14.3 macOS."
    - "re.Pattern.fullmatch.__doc__.__len__() == 34 — verified on Python 3.14.3 macOS."
    - "re.Match.group.__doc__.__len__() == 130 — verified on Python 3.14.3 macOS."
    - "re.Match.groups.__doc__.__len__() == 138 — verified on Python 3.14.3 macOS."
    - "re.Match.start.__doc__.__len__() == 60 — verified on Python 3.14.3 macOS."
    - "re.Match.end.__doc__.__len__() == 58 — verified on Python 3.14.3 macOS."
    - "re.Match.span.__doc__.__len__() == 70 — verified on Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __doc__ lengths: match, search, findall, finditer
# Docstring lengths are stable across Python 3.11+ for these methods.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra87.Pattern_doc_lens_match_search_findall_finditer:
  description: "re.Pattern match/search/findall/finditer __doc__.__len__()"
  kind: python_call_eq
  category: doc_length
  id_prefix: reextra87

  columns: [id, function, args, expected]
  rows:
    - [pat_match_doclen,    "Pattern.match.__doc__.__len__",    [], 63]
    - [pat_search_doclen,   "Pattern.search.__doc__.__len__",   [], 141]
    - [pat_findall_doclen,  "Pattern.findall.__doc__.__len__",  [], 66]
    - [pat_finditer_doclen, "Pattern.finditer.__doc__.__len__", [], 135]

# ---------------------------------------------------------------------------
# re.Pattern method __doc__ lengths: sub, subn, split, fullmatch
