  rows:
    - [match_group_doclen,  "Match.group.__doc__.__len__",  [], 130]
    - [match_groups_doclen, "Match.groups.__doc__.__len__", [], 138]
    - [match_start_doclen,  "Match.start.__doc__.__len__",  [], 60]
    - [match_end_doclen,    "Match.end.__doc__.__len__",    [], 58]

# ---------------------------------------------------------------------------
# re.Match.span __doc__.__len__()
