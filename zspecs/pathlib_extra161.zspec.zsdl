spec: pathlib_extra161
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path.__dict__ and pathlib.PurePath.__dict__ method presence checks using __contains__."
    - "All tested methods are present in pathlib.Path.__dict__: mkdir, exists, glob, iterdir, stat, unlink all return True for __contains__. These methods are defined directly on Path (not inherited from PurePath), so they appear in Path.__dict__."
    - "All tested methods are present in pathlib.PurePath.__dict__: joinpath, with_name, with_suffix all return True for __contains__. These are pure path manipulation methods defined on PurePath."
    - "__dict__.__contains__ checks the class's own __dict__ (not inherited attributes). A method returning True here is defined on that class itself, not inherited. Path.__dict__.__contains__('mkdir') == True confirms mkdir is a Path-specific method."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ method presence checks
# mkdir, exists, glob, iterdir, stat, unlink are all defined on Path directly.
# All return True for __dict__.__contains__.
# These are filesystem-access methods, so they live on Path (not PurePath).
# ---------------------------------------------------------------------------

table pathlib_extra161.Path_dict_contains:
  description: "pathlib.Path.__dict__.__contains__ checks for filesystem methods: mkdir, exists, glob, iterdir, stat, unlink — all True (defined directly on Path, not inherited from PurePath)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdict161

  columns: [id, function, args, expected, description]
  rows:
    - [mkdir_in_dict,    "Path.__dict__.__contains__",   ["mkdir"],   true, "pathlib.Path.__dict__.__contains__('mkdir') == True (mkdir is defined directly on pathlib.Path, not on PurePath; it creates the directory; accepts parents=True for recursive creation and exist_ok=True to suppress FileExistsError; its presence in Path.__dict__ confirms it is a concrete Path method, not inherited from PurePath)"]
    - [exists_in_dict,   "Path.__dict__.__contains__",   ["exists"],  true, "pathlib.Path.__dict__.__contains__('exists') == True (exists() is defined on Path because it requires filesystem access — PurePath is a pure path representation with no filesystem interaction; exists() returns True if the path points to an existing file or directory; follows symlinks by default)"]
    - [glob_in_dict,     "Path.__dict__.__contains__",   ["glob"],    true, "pathlib.Path.__dict__.__contains__('glob') == True (glob() is a Path-specific method that yields all paths matching a glob pattern under this path; defined on Path because it requires filesystem traversal; PurePath has no glob() method; glob() uses fnmatch-style patterns like '*.py' or '**/*.txt')"]
    - [iterdir_in_dict,  "Path.__dict__.__contains__",   ["iterdir"], true, "pathlib.Path.__dict__.__contains__('iterdir') == True (iterdir() yields Path objects for directory contents and requires filesystem access, so it is defined on Path not PurePath; its presence in Path.__dict__ confirms it is a direct Path method; iterdir() does not recurse — use rglob() or walk() for recursive listing)"]
    - [stat_in_dict,     "Path.__dict__.__contains__",   ["stat"],    true, "pathlib.Path.__dict__.__contains__('stat') == True (stat() returns os.stat_result for the path and requires filesystem access; defined directly on Path; Path.stat().__qualname__ == 'Path.stat' (len=9, one of the shortest Path method qualnames as established in pathlib_extra160); presence in Path.__dict__ confirms it is not inherited from PurePath)"]
    - [unlink_in_dict,   "Path.__dict__.__contains__",   ["unlink"],  true, "pathlib.Path.__dict__.__contains__('unlink') == True (unlink() removes a file or symlink and requires filesystem access; defined on Path not PurePath; presence in Path.__dict__ confirms it is a direct Path method; accepts missing_ok=True (Python 3.8+) to suppress FileNotFoundError when the file does not exist)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ method presence checks
# joinpath, with_name, with_suffix are all defined on PurePath directly.
# These are pure path manipulation methods that do not require filesystem access.
# ---------------------------------------------------------------------------

table pathlib_extra161.PurePath_dict_contains:
  description: "pathlib.PurePath.__dict__.__contains__ checks for path manipulation methods: joinpath, with_name, with_suffix — all True (defined on PurePath itself, no filesystem access needed)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdict161

  columns: [id, function, args, expected, description]
  rows:
    - [joinpath_in_dict,   "PurePath.__dict__.__contains__",  ["joinpath"],    true, "pathlib.PurePath.__dict__.__contains__('joinpath') == True (joinpath is defined on PurePath because it is a pure path manipulation operation requiring no filesystem access; joinpath() appends one or more path segments and returns a new PurePath (or Path); it is equivalent to the / operator; PurePath.joinpath.__qualname__ == 'PurePath.joinpath' (len=17))"]
    - [with_name_in_dict,  "PurePath.__dict__.__contains__",  ["with_name"],   true, "pathlib.PurePath.__dict__.__contains__('with_name') == True (with_name() replaces the final filename component and returns a new path; defined on PurePath as a pure string operation; raises ValueError if path has no name; PurePath.with_name.__qualname__ == 'PurePath.with_name' (len=18) as established in pathlib_extra159)"]
    - [with_suffix_in_dict,"PurePath.__dict__.__contains__",  ["with_suffix"], true, "pathlib.PurePath.__dict__.__contains__('with_suffix') == True (with_suffix() replaces the file extension and returns a new path; a pure string operation on PurePath; passing '' removes the extension; PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix' (len=20) — the longest of the with_* method qualnames as established in pathlib_extra159)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra161.Path_dict_contains_mkdir:
  description: "pathlib.Path.__dict__.__contains__('mkdir') == True — mkdir is defined directly on pathlib.Path (in its own __dict__), not inherited from PurePath; this is expected because mkdir() creates a directory on the filesystem and PurePath is explicitly designed to be a pure path representation with no I/O operations; all filesystem-mutating methods (mkdir, unlink, rmdir, touch, rename, replace) live in Path.__dict__ not PurePath.__dict__"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["mkdir"]
  expected: true

invariant pathlib_extra161.PurePath_dict_contains_joinpath:
  description: "pathlib.PurePath.__dict__.__contains__('joinpath') == True — joinpath is defined on PurePath itself because it is a pure string operation that requires no filesystem access; PurePath exists to represent paths as pure string objects (suitable for cross-platform path manipulation without touching the filesystem); joinpath(), with_name(), with_suffix(), with_stem(), parts, name, stem, suffix, parent, parents are all pure operations defined on PurePath"
  category: identity
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["joinpath"]
  expected: true

invariant pathlib_extra161.Path_dict_contains_glob:
  description: "pathlib.Path.__dict__.__contains__('glob') == True — glob() is defined on Path because it traverses the filesystem to find matching paths; glob() accepts fnmatch-style patterns (e.g., '*.py', '**/*.txt') and yields Path objects; the double-star '**' pattern recursively matches all subdirectories; the presence in Path.__dict__ (not PurePath.__dict__) correctly reflects the filesystem-access requirement"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["glob"]
  expected: true

invariant pathlib_extra161.PurePath_dict_contains_with_suffix:
  description: "pathlib.PurePath.__dict__.__contains__('with_suffix') == True — with_suffix() replaces the file extension with a new suffix and returns a new PurePath; it is a pure string transformation requiring no filesystem access, so it is correctly defined on PurePath; with_suffix() has the longest qualname of the with_* methods: 'PurePath.with_suffix' (len=20, 'PurePath.' (9) + 'with_suffix' (11) = 20) as established in pathlib_extra159"
  category: identity
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["with_suffix"]
  expected: true

invariant pathlib_extra161.Path_dict_contains_stat:
  description: "pathlib.Path.__dict__.__contains__('stat') == True — stat() is defined directly on Path (not PurePath) because it calls os.stat() to query filesystem metadata; stat() returns an os.stat_result containing size, permissions, timestamps, inode number, etc.; Path.stat().__qualname__ == 'Path.stat' (len=9); the presence of 'stat' in Path.__dict__ confirms it is a filesystem-access method not a pure path operation"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["stat"]
  expected: true

