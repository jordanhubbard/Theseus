spec: decimal_extra180
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/decimal.py"
  notes:
    - "decimal.ROUND_UP=='ROUND_UP'; decimal.ROUND_DOWN=='ROUND_DOWN'; decimal.ROUND_CEILING=='ROUND_CEILING'; decimal.ROUND_FLOOR=='ROUND_FLOOR'."
    - "decimal.ROUND_HALF_UP=='ROUND_HALF_UP'; decimal.ROUND_HALF_DOWN=='ROUND_HALF_DOWN'; decimal.ROUND_HALF_EVEN=='ROUND_HALF_EVEN'; decimal.ROUND_05UP=='ROUND_05UP'."
    - "All eight rounding constants are plain Python strings; __eq__ comparison returns True against the matching string literal."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: basic rounding constants — ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR
# ---------------------------------------------------------------------------

table decimal_extra180.basic_rounding_constants:
  description: "decimal rounding constants ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR — string identity verified with __eq__"
  kind: python_call_eq
  category: identity
  id_prefix: decimalround180

  columns: [id, function, args, expected, description]
  rows:
    - [rup_eq,   ROUND_UP.__eq__,      ["ROUND_UP"],       true, "decimal.ROUND_UP.__eq__('ROUND_UP') == True — rounds away from zero; confirmed Python 3.14.3 macOS"]
    - [rdn_eq,   ROUND_DOWN.__eq__,    ["ROUND_DOWN"],     true, "decimal.ROUND_DOWN.__eq__('ROUND_DOWN') == True — rounds towards zero (truncates); confirmed Python 3.14.3 macOS"]
    - [rce_eq,   ROUND_CEILING.__eq__, ["ROUND_CEILING"],  true, "decimal.ROUND_CEILING.__eq__('ROUND_CEILING') == True — rounds towards positive infinity; confirmed Python 3.14.3 macOS"]
    - [rfl_eq,   ROUND_FLOOR.__eq__,   ["ROUND_FLOOR"],    true, "decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR') == True — rounds towards negative infinity; confirmed Python 3.14.3 macOS"]
    - [rup_ne_dn, ROUND_UP.__eq__,     ["ROUND_DOWN"],     false,"decimal.ROUND_UP.__eq__('ROUND_DOWN') == False — ROUND_UP and ROUND_DOWN are distinct constants; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: half-rounding constants — ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN
# ---------------------------------------------------------------------------

table decimal_extra180.half_rounding_constants:
  description: "decimal rounding constants ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN — string identity verified with __eq__"
  kind: python_call_eq
  category: identity
  id_prefix: decimalround180

  columns: [id, function, args, expected, description]
  rows:
    - [rhu_eq,   ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true, "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True — rounds to nearest with ties going away from zero; confirmed Python 3.14.3 macOS"]
    - [rhd_eq,   ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"],  true, "decimal.ROUND_HALF_DOWN.__eq__('ROUND_HALF_DOWN') == True — rounds to nearest with ties going towards zero; confirmed Python 3.14.3 macOS"]
    - [rhe_eq,   ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — rounds to nearest with ties going to nearest even (banker's rounding); confirmed Python 3.14.3 macOS"]
    - [rhu_ne_hd, ROUND_HALF_UP.__eq__,  ["ROUND_HALF_DOWN"],  false,"decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_DOWN') == False — ROUND_HALF_UP and ROUND_HALF_DOWN are distinct constants; confirmed Python 3.14.3 macOS"]
    - [rhd_ne_he, ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_EVEN"], false,"decimal.ROUND_HALF_DOWN.__eq__('ROUND_HALF_EVEN') == False — ROUND_HALF_DOWN and ROUND_HALF_EVEN are distinct constants; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: ROUND_05UP constant identity and cross-constant distinctness
# ---------------------------------------------------------------------------

table decimal_extra180.round05up_and_cross_checks:
  description: "decimal.ROUND_05UP constant identity; cross-checks confirming all eight rounding constants are mutually distinct strings"
  kind: python_call_eq
  category: identity
  id_prefix: decimalround180

  columns: [id, function, args, expected, description]
  rows:
    - [r05_eq,     ROUND_05UP.__eq__,      ["ROUND_05UP"],     true,  "decimal.ROUND_05UP.__eq__('ROUND_05UP') == True — rounds away from zero if the last digit before rounding is 0 or 5; confirmed Python 3.14.3 macOS"]
    - [r05_ne_up,  ROUND_05UP.__eq__,      ["ROUND_UP"],       false, "decimal.ROUND_05UP.__eq__('ROUND_UP') == False — ROUND_05UP and ROUND_UP are distinct constants; confirmed Python 3.14.3 macOS"]
    - [r05_ne_dn,  ROUND_05UP.__eq__,      ["ROUND_DOWN"],     false, "decimal.ROUND_05UP.__eq__('ROUND_DOWN') == False — ROUND_05UP and ROUND_DOWN are distinct constants; confirmed Python 3.14.3 macOS"]
    - [rce_ne_fl,  ROUND_CEILING.__eq__,   ["ROUND_FLOOR"],    false, "decimal.ROUND_CEILING.__eq__('ROUND_FLOOR') == False — ceiling and floor rounding are distinct; confirmed Python 3.14.3 macOS"]
    - [rhe_ne_up,  ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_UP"],  false, "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_UP') == False — banker's rounding differs from half-up; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra180.round_up_eq:
  description: "decimal.ROUND_UP.__eq__('ROUND_UP') == True — rounds away from zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra180.round_down_eq:
  description: "decimal.ROUND_DOWN.__eq__('ROUND_DOWN') == True — rounds towards zero (truncates); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_DOWN.__eq__
  args: ["ROUND_DOWN"]
  expected: true

invariant decimal_extra180.round_ceiling_eq:
  description: "decimal.ROUND_CEILING.__eq__('ROUND_CEILING') == True — rounds towards positive infinity; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_CEILING.__eq__
  args: ["ROUND_CEILING"]
  expected: true

invariant decimal_extra180.round_floor_eq:
  description: "decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR') == True — rounds towards negative infinity; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_FLOOR.__eq__
  args: ["ROUND_FLOOR"]
  expected: true

invariant decimal_extra180.round_half_up_eq:
  description: "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True — rounds to nearest with ties going away from zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra180.round_half_down_eq:
  description: "decimal.ROUND_HALF_DOWN.__eq__('ROUND_HALF_DOWN') == True — rounds to nearest with ties going towards zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_DOWN.__eq__
  args: ["ROUND_HALF_DOWN"]
  expected: true

invariant decimal_extra180.round_half_even_eq:
  description: "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — rounds to nearest with ties going to nearest even (banker's rounding); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra180.round_05up_eq:
  description: "decimal.ROUND_05UP.__eq__('ROUND_05UP') == True — rounds away from zero if last digit before rounding is 0 or 5, otherwise towards zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_05UP.__eq__
  args: ["ROUND_05UP"]
  expected: true
