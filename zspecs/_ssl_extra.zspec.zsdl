spec: _ssl_extra
version: ">=3.9"
backend: python_module(_ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
  notes:
    - "This spec extends ssl.zspec.zsdl, ssl_extra.zspec.zsdl, ssl_extra2.zspec.zsdl, ssl_extra3.zspec.zsdl, and _ssl.zspec.zsdl."
    - "_ssl is the C extension that backs the ssl stdlib module; it wraps OpenSSL."
    - "_ssl.SSLError.__name__ == 'SSLError'; base class is OSError."
    - "_ssl.txt2obj.__name__ == 'txt2obj' — C function for OID text-to-object lookup."
    - "_ssl.nid2obj.__name__ == 'nid2obj' — C function for numeric OID to object lookup."
    - "_ssl.RAND_bytes.__name__ == 'RAND_bytes' — C function for generating random bytes via OpenSSL."
    - "_ssl.TLSVersion is an IntEnum; __name__ == 'TLSVersion'; base class is IntEnum."
    - "_ssl.TLSVersion.TLSv1_2 and _ssl.TLSVersion.TLSv1_3 are TLSVersion members."
    - "_ssl.OP_NO_SSLv2.__class__.__name__ == 'Options' — an IntFlag member in Python 3.6+."
    - "_ssl.OP_ALL.__class__.__name__ == 'Options' — all OP_* bitmask constants share this type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLError — class name and hierarchy
# ---------------------------------------------------------------------------

invariant _ssl_extra.SSLError.name:
  description: "_ssl.SSLError.__name__ == 'SSLError'"
  category: classnames
  kind: python_call_eq
  function: SSLError.__name__.__eq__
  args: ["SSLError"]
  expected: true

invariant _ssl_extra.SSLError.base:
  description: "_ssl.SSLError.__bases__[0].__name__ == 'OSError'"
  category: hierarchy
  kind: python_call_eq
  function: SSLError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OSError"

# ---------------------------------------------------------------------------
# C function __name__ checks — txt2obj, nid2obj, RAND_bytes
# ---------------------------------------------------------------------------

invariant _ssl_extra.txt2obj.name:
  description: "_ssl.txt2obj.__name__ == 'txt2obj'"
  category: functions
  kind: python_call_eq
  function: txt2obj.__name__.__eq__
  args: ["txt2obj"]
  expected: true

invariant _ssl_extra.nid2obj.name:
  description: "_ssl.nid2obj.__name__ == 'nid2obj'"
  category: functions
  kind: python_call_eq
  function: nid2obj.__name__.__eq__
  args: ["nid2obj"]
  expected: true

invariant _ssl_extra.RAND_bytes.name:
  description: "_ssl.RAND_bytes.__name__ == 'RAND_bytes'"
  category: functions
  kind: python_call_eq
  function: RAND_bytes.__name__.__eq__
  args: ["RAND_bytes"]
  expected: true

# ---------------------------------------------------------------------------
# TLSVersion — class name and base class
# TLSVersion is an IntEnum defined in the _ssl C extension (Python 3.7+).
# ---------------------------------------------------------------------------

invariant _ssl_extra.TLSVersion.name:
  description: "_ssl.TLSVersion.__name__ == 'TLSVersion'"
  category: classnames
  kind: python_call_eq
  function: TLSVersion.__name__.__eq__
  args: ["TLSVersion"]
  expected: true

invariant _ssl_extra.TLSVersion.base:
  description: "_ssl.TLSVersion.__bases__[0].__name__ == 'IntEnum' — TLSVersion is an IntEnum subclass"
  category: hierarchy
  kind: python_call_eq
  function: TLSVersion.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "IntEnum"

# ---------------------------------------------------------------------------
# TLSVersion member names — TLSv1_2 and TLSv1_3
# ---------------------------------------------------------------------------

invariant _ssl_extra.TLSVersion.TLSv1_2.name:
  description: "_ssl.TLSVersion.TLSv1_2.name == 'TLSv1_2'"
  category: constants
  kind: python_call_eq
  function: TLSVersion.TLSv1_2.name.__eq__
  args: ["TLSv1_2"]
  expected: true

invariant _ssl_extra.TLSVersion.TLSv1_3.name:
  description: "_ssl.TLSVersion.TLSv1_3.name == 'TLSv1_3'"
  category: constants
  kind: python_call_eq
  function: TLSVersion.TLSv1_3.name.__eq__
  args: ["TLSv1_3"]
  expected: true

# ---------------------------------------------------------------------------
# OP_NO_SSLv2 — IntFlag Options member
# OP_NO_SSLv2.__class__.__name__ == 'Options' on Python 3.6+ (IntFlag enum).
# ---------------------------------------------------------------------------

invariant _ssl_extra.OP_NO_SSLv2.class_name:
  description: "_ssl.OP_NO_SSLv2.__class__.__name__ == 'Options' (IntFlag member)"
  category: constants
  kind: python_call_eq
  function: OP_NO_SSLv2.__class__.__name__.__eq__
  args: ["Options"]
  expected: true

# ---------------------------------------------------------------------------
# OP_ALL — IntFlag Options member (always present; confirms the Options type)
# ---------------------------------------------------------------------------

invariant _ssl_extra.OP_ALL.class_name:
  description: "_ssl.OP_ALL.__class__.__name__ == 'Options' (IntFlag member)"
  category: constants
  kind: python_call_eq
  function: OP_ALL.__class__.__name__.__eq__
  args: ["Options"]
  expected: true

# ---------------------------------------------------------------------------
# txt2obj and nid2obj module affiliation
# These C functions belong to the _ssl module.
# ---------------------------------------------------------------------------

table _ssl_extra.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [txt2obj,    txt2obj.__module__.__eq__,    ["_ssl"], true]
    - [nid2obj,    nid2obj.__module__.__eq__,    ["_ssl"], true]
    - [RAND_bytes, RAND_bytes.__module__.__eq__, ["_ssl"], true]
