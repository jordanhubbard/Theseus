    - ["mp3481019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__call__"], false]
    - ["mp3481020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__call__"], false]
    - ["mp3481021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__call__"], false]
    - ["mp3481022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__call__"], false]
    - ["mp3481023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__call__"], false]
    - ["mp3481024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__call__"], false]

# ---------------------------------------------------------------------------
# combined — __enter__, __exit__, __call__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __enter__: true for pool.Pool only; false for all other 7 types.
# __exit__:  true for pool.Pool only; false for all other 7 types.
# __call__:  false for all 8 types.
# Total true values: 2 (pool.Pool __enter__ and __exit__).
# Total false values: 22.
# pool.Pool is the only multiprocessing type across waves 659–679 to define
#   a non-arithmetic dunder in its own __dict__ (other than BaseListProxy
#   __add__ and __mul__ from wave 658). Pool's context manager support reflects
#   the standard pattern: 'with Pool() as p: ...' is idiomatic for managing
#   a process pool lifetime.
# managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy clarification: these
#   proxy types relay operations to a managed server process via IPC dispatch.
#   They do not define __enter__, __exit__, or __call__ in their own Python-level
#   __dict__ — context manager and callable protocol support, if any, is not
#   expressed through these dunders at the class __dict__ level.
# multiprocessing.Process note: although Process can be used as a context
#   manager in some forms (e.g., via multiprocessing.pool.Pool's underlying
#   mechanism), multiprocessing.Process itself does NOT define __enter__ or
#   __exit__ in its own __dict__.
# ---------------------------------------------------------------------------

