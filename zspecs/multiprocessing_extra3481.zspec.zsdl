spec: mp3481
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (mp3481): __enter__, __exit__, __call__ dict-presence checks for multiprocessing types."
    - "Theme: __enter__/__exit__/__call__ dict-presence (context manager and callable protocols)."
    - "multiprocessing.pool.Pool defines __enter__ and __exit__ (true): Pool is a context manager — 'with Pool() as p:' is valid."
    - "All other multiprocessing types: false for __enter__ and __exit__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__enter__): pool.Pool defines __enter__ in its own __dict__ (true). 'with Pool() as p:' is a standard and idiomatic pattern for managing a worker process pool lifetime. Pool directly defines __enter__ in its class __dict__. All other 7 multiprocessing types return false for __enter__. multiprocessing.Process: a subprocess lifecycle manager with no __enter__ in its own __dict__. pool.AsyncResult/pool.MapResult: result handles with no __enter__ in their own __dict__. managers.SyncManager: server process manager with no __enter__ in its __dict__. managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy: IPC proxy types with no __enter__ in their own __dict__."
    - "Key finding (__exit__): pool.Pool defines __exit__ in its own __dict__ (true). The __exit__ implementation terminates the pool. All other 7 multiprocessing types return false for __exit__. No other type in this wave defines __exit__ in its own __dict__."
    - "Key finding (__call__): all 8 multiprocessing classes return false for __call__. None of the multiprocessing types define __call__ in their own __dict__. These types expose their functionality via explicit method calls, subprocess lifecycle management, and IPC — not by being callable."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
    - "  Wave 668 (mp3316): __ipow__/__ilshift__/__irshift__ — all false for all 8."
    - "  Wave 669 (mp3331): __iand__/__ior__/__ixor__ — all false for all 8."
    - "  Wave 670 (mp3346): __neg__/__pos__/__abs__ — all false for all 8."
    - "  Wave 671 (mp3361): __invert__/__floor__/__ceil__ — all false for all 8."
    - "  Wave 672 (mp3376): __trunc__/__round__/__index__ — all false for all 8."
    - "  Wave 673 (mp3391): __int__/__float__/__complex__ — all false for all 8."
    - "  Wave 674 (mp3406): __bool__/__str__/__repr__ — all false for all 8."
    - "  Wave 675 (mp3421): __hash__/__eq__/__lt__ — all false for all 8."
    - "  Wave 676 (mp3436): __le__/__gt__/__ge__ — all false for all 8."
    - "  Wave 677 (mp3451): __getitem__/__setitem__/__delitem__ — all false for all 8."
    - "  Wave 678 (mp3466): __iter__/__next__/__len__ — all false for all 8."
    - "  Wave 679 (mp3481): __enter__/__exit__/__call__ — pool.Pool __enter__=true, __exit__=true; all others false."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# pool.Pool defines __enter__ in its own __dict__ (true).
# 'with Pool() as p:' is an idiomatic Python pattern for managing a worker
#   process pool lifetime. Pool directly defines __enter__ in its class __dict__.
# All other 7 multiprocessing classes return false for __enter__.
# multiprocessing.Process: a subprocess lifecycle manager; context manager
#   usage is not part of the Process API. __enter__ absent from Process.__dict__.
# pool.AsyncResult/pool.MapResult: result handles with no __enter__ in their
#   own __dict__.
# managers.SyncManager: server process manager; no __enter__ in its __dict__.
# managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy: IPC proxy types with
#   no __enter__ defined in their own __dict__.
# ---------------------------------------------------------------------------

table mp3481.enter:
  description: "multiprocessing types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3481

  columns: [id, function, args, expected]
  rows:
    - ["mp3481001", operator.contains, [multiprocessing.Process.__dict__,                 "__enter__"], false]
    - ["mp3481002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__enter__"], true]
    - ["mp3481003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__enter__"], false]
    - ["mp3481004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__enter__"], false]
    - ["mp3481005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__enter__"], false]
    - ["mp3481006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__enter__"], false]
    - ["mp3481007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__enter__"], false]
    - ["mp3481008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__enter__"], false]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — operator.contains(Cls.__dict__, '__exit__')
#
# pool.Pool defines __exit__ in its own __dict__ (true).
# The __exit__ implementation terminates the pool on exit from the 'with'
#   block. This is defined directly in pool.Pool.__dict__.
# All other 7 multiprocessing classes return false for __exit__.
# multiprocessing.Process: no __exit__ in Process.__dict__; Process objects
#   are managed via start()/join()/terminate() method calls.
# pool.AsyncResult/pool.MapResult: result handles; no __exit__ defined.
# managers.SyncManager: no __exit__ in its __dict__; managers expose their
#   lifecycle via start()/shutdown() methods.
# managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy: IPC proxy types with
#   no __exit__ in their own __dict__.
# ---------------------------------------------------------------------------

table mp3481.exit:
  description: "multiprocessing types __exit__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3481

  columns: [id, function, args, expected]
  rows:
    - ["mp3481009",  operator.contains, [multiprocessing.Process.__dict__,                 "__exit__"], false]
    - ["mp3481010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__exit__"], true]
    - ["mp3481011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__exit__"], false]
    - ["mp3481012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__exit__"], false]
    - ["mp3481013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__exit__"], false]
    - ["mp3481014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__exit__"], false]
    - ["mp3481015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__exit__"], false]
    - ["mp3481016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__exit__"], false]

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# All 8 multiprocessing classes return false for __call__.
# None of the multiprocessing types define __call__ in their own __dict__.
# pool.Pool: work is dispatched via apply(), map(), apply_async(), map_async()
#   method calls — not by calling the pool directly. No __call__ in Pool.__dict__.
# multiprocessing.Process: lifecycle is managed via start()/join()/terminate();
#   no __call__ defined in Process.__dict__.
# pool.AsyncResult/pool.MapResult: result handles accessed via get()/wait();
#   no __call__ defined in their own __dict__.
# managers.SyncManager: managed via start()/shutdown(); no __call__ defined.
# managers.BaseListProxy/_BaseDictProxy/_BaseSetProxy: IPC proxy types with
#   no __call__ in their own __dict__.
# ---------------------------------------------------------------------------

