spec: decimal_extra394
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Decimal.from_float.__name__ == 'from_float' — classmethod that converts a float to a Decimal exactly"
    - "decimal.Decimal.__add__.__name__ == '__add__' — binary addition operator"
    - "decimal.Decimal.__mul__.__name__ == '__mul__' — binary multiplication operator"
    - "decimal.Decimal.__sub__.__name__ == '__sub__' — binary subtraction operator"
    - "decimal.Decimal.__neg__.__name__ == '__neg__' — unary negation operator"
    - "decimal.Decimal.__abs__.__name__ == '__abs__' — unary absolute value operator"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

