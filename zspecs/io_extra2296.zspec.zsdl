spec: io_extra2296
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "The abstract base classes io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase have __module__ == 'io'."
    - "The concrete C-extension classes (FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, TextIOWrapper, IncrementalNewlineDecoder, BufferedRandom) have __module__ == '_io'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2296.abstract_bases_module:
  description: "Abstract base classes in io expose __module__ == 'io' (pure-Python layer)"
  kind: python_call_eq
  category: module_identity
  id_prefix: io2296

  columns: [id, function, args, expected]
  rows:
    - ["io2296001", "io.IOBase.__module__", [], "io"]
    - ["io2296002", "io.RawIOBase.__module__", [], "io"]
    - ["io2296003", "io.BufferedIOBase.__module__", [], "io"]
    - ["io2296004", "io.TextIOBase.__module__", [], "io"]

table io_extra2296.abstract_bases_qualname:
  description: "Abstract base classes in io have simple __qualname__ matching class name"
  kind: python_call_eq
  category: module_identity
  id_prefix: io2296

  columns: [id, function, args, expected]
  rows:
    - ["io2296005", "io.IOBase.__qualname__", [], "IOBase"]
    - ["io2296006", "io.RawIOBase.__qualname__", [], "RawIOBase"]
    - ["io2296007", "io.BufferedIOBase.__qualname__", [], "BufferedIOBase"]
    - ["io2296008", "io.TextIOBase.__qualname__", [], "TextIOBase"]

table io_extra2296.concrete_classes_module:
  description: "Concrete io classes are C types with __module__ == '_io'"
  kind: python_call_eq
  category: module_identity
  id_prefix: io2296

  columns: [id, function, args, expected]
  rows:
    - ["io2296009", "io.FileIO.__module__", [], "_io"]
    - ["io2296010", "io.BytesIO.__module__", [], "_io"]
    - ["io2296011", "io.StringIO.__module__", [], "_io"]
    - ["io2296012", "io.BufferedReader.__module__", [], "_io"]
    - ["io2296013", "io.BufferedWriter.__module__", [], "_io"]
    - ["io2296014", "io.TextIOWrapper.__module__", [], "_io"]
    - ["io2296015", "io.IncrementalNewlineDecoder.__module__", [], "_io"]
    - ["io2296016", "io.BufferedRandom.__module__", [], "_io"]

table io_extra2296.concrete_classes_qualname:
  description: "Concrete io C-extension classes have simple __qualname__ matching class name"
  kind: python_call_eq
  category: module_identity
  id_prefix: io2296

  columns: [id, function, args, expected]
  rows:
    - ["io2296017", "io.FileIO.__qualname__", [], "FileIO"]
    - ["io2296018", "io.BytesIO.__qualname__", [], "BytesIO"]
    - ["io2296019", "io.StringIO.__qualname__", [], "StringIO"]
    - ["io2296020", "io.BufferedReader.__qualname__", [], "BufferedReader"]
    - ["io2296021", "io.BufferedWriter.__qualname__", [], "BufferedWriter"]
    - ["io2296022", "io.TextIOWrapper.__qualname__", [], "TextIOWrapper"]
    - ["io2296023", "io.IncrementalNewlineDecoder.__qualname__", [], "IncrementalNewlineDecoder"]
