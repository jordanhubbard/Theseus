spec: io3226
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (io3226): __radd__, __rsub__, __rmul__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic)."
    - "No io class defines __radd__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types, and do not implement reflected addition."
    - "No io class defines __rsub__ in its own __dict__: stream I/O classes do not implement reflected subtraction."
    - "No io class defines __rmul__ in its own __dict__: stream I/O classes do not implement reflected multiplication."
    - "Key finding: decimal.Decimal defines all 3 reflected operators (complete numeric type supporting right-hand arithmetic); all other classes in this wave are False."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __radd__ dict-presence — operator.contains(Cls.__dict__, '__radd__')
#
# No io class defines __radd__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the reflected addition operator.
# ---------------------------------------------------------------------------

table io3226.radd:
  description: "io types __radd__ dict-presence checks; wave 662"
