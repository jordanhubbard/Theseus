spec: asyncio_extra2446
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2446: __enter__/__exit__ and __aenter__/__aexit__ context manager protocol dict-presence checks."
    - "asyncio primitives (Lock, Event, Condition, Semaphore, BoundedSemaphore) inherit __aenter__/__aexit__ from asyncio.locks._ContextManagerMixin; they do NOT define them in their own __dict__."
    - "asyncio.TaskGroup defines __aenter__ and __aexit__ directly in its own __dict__."
    - "asyncio.timeouts.Timeout defines __aenter__ and __aexit__ in its own __dict__; does NOT define __enter__/__exit__."
    - "asyncio.Barrier defines __aenter__/__aexit__ in its own __dict__ (not via _ContextManagerMixin)."
    - "asyncio.Task, asyncio.Future, asyncio.StreamReader, asyncio.StreamWriter, asyncio.Queue do not define any context manager protocol in their own __dict__."
    - "None of the checked asyncio classes define __enter__ or __exit__ (sync context manager) in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table asyncio_extra2446.sync_cm_enter:
  description: "asyncio classes __enter__ sync context manager protocol dict-presence — all false"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2446

  columns: [id, function, args, expected]
  rows:
    - ["as2446001", "asyncio.Lock.__dict__.__contains__", ["__enter__"], false]
    - ["as2446002", "asyncio.Event.__dict__.__contains__", ["__enter__"], false]
    - ["as2446003", "asyncio.Condition.__dict__.__contains__", ["__enter__"], false]
    - ["as2446004", "asyncio.Semaphore.__dict__.__contains__", ["__enter__"], false]
    - ["as2446005", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__enter__"], false]
    - ["as2446006", "asyncio.TaskGroup.__dict__.__contains__", ["__enter__"], false]
    - ["as2446007", "asyncio.Task.__dict__.__contains__", ["__enter__"], false]
    - ["as2446008", "asyncio.Future.__dict__.__contains__", ["__enter__"], false]

