spec: threading_extra82
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra81

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra81.zspec.zsdl."
    - "This spec covers: threading.local identity, current_thread/main_thread/active_count/enumerate/settrace code attrs, and stack_size class name (Wave 245)."
    - "threading.local.__name__ == '_local' — local is actually _thread._local, a C type; __name__ is '_local'. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — the C extension module where _local is defined. Verified with Python 3.14.3."
    - "threading.local.__bases__[0].__name__ == 'object' — _local inherits directly from object. Verified with Python 3.14.3."
    - "threading.local.__mro__.__len__() == 2 — MRO is (_thread._local, object); length 2. Verified with Python 3.14.3."
    - "threading.current_thread.__code__.co_name == 'current_thread' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.current_thread.__code__.co_argcount == 0 — takes no arguments. Verified with Python 3.14.3."
    - "threading.main_thread.__code__.co_name == 'main_thread' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.main_thread.__code__.co_argcount == 0 — takes no arguments. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_name == 'active_count' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_argcount == 0 — takes no arguments. Verified with Python 3.14.3."
    - "threading.enumerate.__code__.co_name == 'enumerate' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.enumerate.__code__.co_argcount == 0 — takes no arguments. Verified with Python 3.14.3."
    - "threading.settrace.__code__.co_name == 'settrace' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.settrace.__code__.co_argcount == 1 — takes one argument: func. Verified with Python 3.14.3."
    - "threading.stack_size.__class__.__name__ == 'builtin_function_or_method' — stack_size is a C builtin from _thread. Verified with Python 3.14.3."
    - "threading.stack_size.__module__ == '_thread' — stack_size is defined in the _thread C extension. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.local identity attributes — extra82
#
# Wave 245 theme: threading.local C-type identity.
#
# threading.local.__name__             == '_local'
# threading.local.__module__           == '_thread'
# threading.local.__bases__[0].__name__ == 'object'
# threading.local.__mro__.__len__()    == 2
#
# No prior threading spec checks local C-type identity via threadingextra82. New to extra82.
# ---------------------------------------------------------------------------

table threading_extra82.local_identity:
  description: "local.__name__=='_local'; local.__module__=='_thread'; local.__bases__[0].__name__=='object'; local.__mro__.__len__()==2; wave 245 threading.local C-type identity; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra82

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq__local,
       local.__name__.__eq__,
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is actually _thread._local, a C extension type defined in Modules/_threadmodule.c; its __name__ attribute is '_local' (6 chars with leading underscore); str.__eq__('_local') returns True; no prior threading spec checks local.__name__ via threadingextra82; new to extra82"]
    - [local_module_eq__thread,
       local.__module__.__eq__,
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is the C extension type _thread._local; its __module__ attribute records '_thread' (7 chars), the C extension module where it is defined; str.__eq__('_thread') returns True; no prior threading spec checks local.__module__ via threadingextra82; new to extra82"]
    - [local_bases_0_name_eq_object,
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — _thread._local is a C extension type that inherits directly from object; its only base class is object whose __name__ is 'object' (6 chars); str.__eq__('object') returns True; no prior threading spec checks local.__bases__[0].__name__ via threadingextra82; new to extra82"]
    - [local_mro_len_eq_2,
       local.__mro__.__len__,
       [],
       2,
       "threading.local.__mro__.__len__() == 2 — _thread._local inherits directly from object; its MRO is (_thread._local, object) — exactly 2 entries; tuple.__len__() returns 2; no prior threading spec checks local.__mro__.__len__() via threadingextra82; new to extra82"]

# ---------------------------------------------------------------------------
# current_thread and main_thread code attributes — extra82
#
# Wave 245 theme: threading module-level function code object attributes.
#
# threading.current_thread.__code__.co_name     == 'current_thread'
# threading.current_thread.__code__.co_argcount == 0
# threading.main_thread.__code__.co_name        == 'main_thread'
# threading.main_thread.__code__.co_argcount    == 0
#
# No prior threading spec checks current_thread/main_thread code attrs via threadingextra82. New to extra82.
# ---------------------------------------------------------------------------

table threading_extra82.current_main_thread_code:
  description: "current_thread.__code__.co_name=='current_thread', co_argcount==0; main_thread co_name=='main_thread', co_argcount==0; wave 245 threading function code attrs; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra82

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_code_co_name_eq_current_thread,
       current_thread.__code__.co_name.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__code__.co_name.__eq__('current_thread') == True — current_thread is a pure-Python function defined in Lib/threading.py; its code object co_name records the function name 'current_thread' (14 chars); str.__eq__('current_thread') returns True; no prior threading spec checks current_thread.__code__.co_name via threadingextra82; new to extra82"]
    - [current_thread_code_co_argcount_eq_0,
       current_thread.__code__.co_argcount.__eq__,
       [0],
       true,
       "threading.current_thread.__code__.co_argcount.__eq__(0) == True — current_thread() takes no arguments; the code object's co_argcount is 0; int.__eq__(0) returns True; no prior threading spec checks current_thread.__code__.co_argcount via threadingextra82; new to extra82"]
    - [main_thread_code_co_name_eq_main_thread,
       main_thread.__code__.co_name.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__code__.co_name.__eq__('main_thread') == True — main_thread is a pure-Python function defined in Lib/threading.py; its code object co_name records the function name 'main_thread' (11 chars); str.__eq__('main_thread') returns True; no prior threading spec checks main_thread.__code__.co_name via threadingextra82; new to extra82"]
    - [main_thread_code_co_argcount_eq_0,
       main_thread.__code__.co_argcount.__eq__,
       [0],
       true,
       "threading.main_thread.__code__.co_argcount.__eq__(0) == True — main_thread() takes no arguments; the code object's co_argcount is 0; int.__eq__(0) returns True; no prior threading spec checks main_thread.__code__.co_argcount via threadingextra82; new to extra82"]

# ---------------------------------------------------------------------------
# active_count and enumerate code attributes — extra82
#
# Wave 245 theme: threading module-level function code object attributes.
#
# threading.active_count.__code__.co_name     == 'active_count'
# threading.active_count.__code__.co_argcount == 0
# threading.enumerate.__code__.co_name        == 'enumerate'
# threading.enumerate.__code__.co_argcount    == 0
#
# No prior threading spec checks active_count/enumerate code attrs via threadingextra82. New to extra82.
# ---------------------------------------------------------------------------

table threading_extra82.active_count_enumerate_code:
  description: "active_count.__code__.co_name=='active_count', co_argcount==0; enumerate co_name=='enumerate', co_argcount==0; wave 245 threading function code attrs; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra82

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_code_co_name_eq_active_count,
       active_count.__code__.co_name.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__code__.co_name.__eq__('active_count') == True — active_count is a pure-Python function defined in Lib/threading.py; its code object co_name records the function name 'active_count' (12 chars); str.__eq__('active_count') returns True; no prior threading spec checks active_count.__code__.co_name via threadingextra82; new to extra82"]
    - [active_count_code_co_argcount_eq_0,
       active_count.__code__.co_argcount.__eq__,
       [0],
       true,
       "threading.active_count.__code__.co_argcount.__eq__(0) == True — active_count() takes no arguments; the code object's co_argcount is 0; int.__eq__(0) returns True; no prior threading spec checks active_count.__code__.co_argcount via threadingextra82; new to extra82"]
    - [enumerate_code_co_name_eq_enumerate,
       enumerate.__code__.co_name.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__code__.co_name.__eq__('enumerate') == True — threading.enumerate is a pure-Python function defined in Lib/threading.py (distinct from the builtin enumerate); its code object co_name records the function name 'enumerate' (9 chars); str.__eq__('enumerate') returns True; no prior threading spec checks threading.enumerate.__code__.co_name via threadingextra82; new to extra82"]
    - [enumerate_code_co_argcount_eq_0,
       enumerate.__code__.co_argcount.__eq__,
       [0],
       true,
       "threading.enumerate.__code__.co_argcount.__eq__(0) == True — threading.enumerate() takes no arguments; the code object's co_argcount is 0; int.__eq__(0) returns True; no prior threading spec checks threading.enumerate.__code__.co_argcount via threadingextra82; new to extra82"]

# ---------------------------------------------------------------------------
# settrace code attributes and stack_size class identity — extra82
#
# Wave 245 theme: threading.settrace code attrs and stack_size C-builtin class name.
#
# threading.settrace.__code__.co_name          == 'settrace'
# threading.settrace.__code__.co_argcount      == 1
# threading.stack_size.__class__.__name__      == 'builtin_function_or_method'
# threading.stack_size.__module__              == '_thread'
#
# No prior threading spec checks settrace code attrs and stack_size class name via threadingextra82. New to extra82.
# ---------------------------------------------------------------------------

table threading_extra82.settrace_and_stack_size:
  description: "settrace.__code__.co_name=='settrace', co_argcount==1; stack_size.__class__.__name__=='builtin_function_or_method'; stack_size.__module__=='_thread'; wave 245; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra82

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_code_co_name_eq_settrace,
       settrace.__code__.co_name.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__code__.co_name.__eq__('settrace') == True — settrace is a pure-Python function defined in Lib/threading.py; its code object co_name records the function name 'settrace' (8 chars); str.__eq__('settrace') returns True; no prior threading spec checks settrace.__code__.co_name via threadingextra82; new to extra82"]
    - [settrace_code_co_argcount_eq_1,
       settrace.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.settrace.__code__.co_argcount.__eq__(1) == True — settrace(func) takes exactly one positional argument: func; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior threading spec checks settrace.__code__.co_argcount via threadingextra82; new to extra82"]
    - [stack_size_class_name_eq_builtin_function_or_method,
       stack_size.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "threading.stack_size.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.stack_size is actually _thread.stack_size, a C builtin function from Modules/_threadmodule.c; its __class__.__name__ is 'builtin_function_or_method' (26 chars); str.__eq__('builtin_function_or_method') returns True; no prior threading spec checks stack_size.__class__.__name__ via threadingextra82; new to extra82"]
    - [stack_size_module_eq__thread,
       stack_size.__module__.__eq__,
       ["_thread"],
       true,
       "threading.stack_size.__module__.__eq__('_thread') == True — threading.stack_size is the C builtin _thread.stack_size; its __module__ attribute records '_thread' (7 chars), the C extension module where it is defined; str.__eq__('_thread') returns True; no prior threading spec checks stack_size.__module__ via threadingextra82; new to extra82"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra82
# ---------------------------------------------------------------------------

invariant threading_extra82.local_name:
  description: "threading.local.__name__.__eq__('_local') == True — threading.local is _thread._local; __name__ is '_local'; wave 245 threading.local C-type identity; new to extra82"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra82.local_module:
  description: "threading.local.__module__.__eq__('_thread') == True — threading.local is defined in the _thread C extension; wave 245 threading.local C-type identity; new to extra82"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra82.local_mro_len:
  description: "threading.local.__mro__.__len__() == 2 — _thread._local MRO is (_thread._local, object); wave 245 threading.local C-type identity; new to extra82"
  kind: python_call_eq
  function: local.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra82.current_thread_code_co_argcount:
  description: "threading.current_thread.__code__.co_argcount.__eq__(0) == True — current_thread() takes no arguments; wave 245 threading function code attrs; new to extra82"
  kind: python_call_eq
  function: current_thread.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant threading_extra82.settrace_code_co_argcount:
  description: "threading.settrace.__code__.co_argcount.__eq__(1) == True — settrace(func) has 1 positional arg; wave 245 threading.settrace code attrs; new to extra82"
  kind: python_call_eq
  function: settrace.__code__.co_argcount.__eq__
  args: [1]
  expected: true
