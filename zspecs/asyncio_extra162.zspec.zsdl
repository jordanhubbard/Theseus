spec: asyncio_extra162
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec covers: asyncio.AbstractEventLoop class identity (name, module, base) and asyncio.AbstractEventLoopPolicy class identity. asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'Event'=5+'Loop'=4=17); asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14; AbstractEventLoop is defined in Lib/asyncio/events.py); asyncio.AbstractEventLoop.__bases__[0].__name__=='object' (len=6; AbstractEventLoop inherits directly from object — it is the abstract base for all event loop implementations); asyncio.AbstractEventLoopPolicy actual __name__=='_AbstractEventLoopPolicy' (len=24: '_'=1+'Abstract'=8+'Event'=5+'Loop'=4+'Policy'=6=24; the public name 'AbstractEventLoopPolicy' has a leading-underscore actual __name__ in Python 3.14.3 — the class is deprecated and slated for removal in Python 3.16); asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' (same module as AbstractEventLoop). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14) — AbstractEventLoop is defined in Lib/asyncio/events.py and accessed via the asyncio package namespace; compare module lengths: 'asyncio.events' (len=14) == 'asyncio.queues' (len=14) — both are 14 chars (both submodule names are 6 chars: 'events'=6 == 'queues'=6); contrast with 'asyncio.locks' (len=13: 'locks'=5 is 1 char shorter than 'events'=6); AbstractEventLoop is a pure Python abstract class (not C-accelerated) with __module__=='asyncio.events'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (leading underscore) — in Python 3.14.3 the public name 'asyncio.AbstractEventLoopPolicy' resolves to a class whose actual __name__ is '_AbstractEventLoopPolicy' (len=24: '_Abstract'=9+'EventLoop'=9+'Policy'=6=24); this is a Python 3.14.3 behavior where the deprecated policy class has a mangled name; accessing asyncio.AbstractEventLoopPolicy emits DeprecationWarning ('asyncio.AbstractEventLoopPolicy is deprecated and slated for removal in Python 3.16'); __module__=='asyncio.events' (same module as AbstractEventLoop); __bases__[0].__name__=='object' (also inherits from object). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoop.__dict__ membership — AbstractEventLoop defines abstract method stubs that all concrete event loop implementations must provide: AbstractEventLoop.__dict__ contains 'run_forever', 'run_until_complete', 'stop', 'create_task', and 'call_soon'; these are the core event loop API methods defined on the abstract base; AbstractEventLoop.__bases__[0].__name__=='object' confirms it has no asyncio-specific parent class — it IS the root of the asyncio event loop class hierarchy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop class identity — extra162
#
# asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop')         == True
# asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events')          == True
# asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__('object')       == True
# ---------------------------------------------------------------------------

table asyncio_extra162.asyncio_abstract_event_loop_identity:
  description: "asyncio.AbstractEventLoop class identity checks in asyncioael162 namespace — asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'Event'=5+'Loop'=4=17; the abstract base class defining the asyncio event loop interface; all concrete event loop implementations such as asyncio.SelectorEventLoop and asyncio.ProactorEventLoop inherit from AbstractEventLoop); asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14; AbstractEventLoop is defined in Lib/asyncio/events.py — the events submodule is different from the locks submodule (len=13) and queues submodule (len=14: same length as events)); asyncio.AbstractEventLoop.__bases__[0].__name__=='object' (len=6; AbstractEventLoop inherits directly from object — it is the root of the asyncio event loop class hierarchy with no intermediate bases); AbstractEventLoop.__name__.__len__()==17 ('AbstractEventLoop'=17: 'Abstract'=8+'EventLoop'=9=17); compare: asyncio.AbstractEventLoopPolicy actual __name__.__len__()==24 ('_AbstractEventLoopPolicy'=24: longer by 7); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioael162

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_eq,   asyncio.AbstractEventLoop.__name__.__eq__,                ["AbstractEventLoop"],  true,  "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop' (len=17; abstract base for event loops); verified with Python 3.14.3"]
    - [ael_mod_eq,    asyncio.AbstractEventLoop.__module__.__eq__,               ["asyncio.events"],     true,  "asyncio.AbstractEventLoop.__module__ == 'asyncio.events' (len=14; events submodule, same len as asyncio.queues); verified with Python 3.14.3"]
    - [ael_base_eq,   "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__",  ["object"],             true,  "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object' (inherits from object directly); verified with Python 3.14.3"]
    - [ael_name_len,  asyncio.AbstractEventLoop.__name__.__len__,                [],                     17,    "asyncio.AbstractEventLoop.__name__.__len__() == 17 ('AbstractEventLoop'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop.__dict__ membership — extra162
#
# AbstractEventLoop.__dict__.__contains__('run_forever')        == True
# AbstractEventLoop.__dict__.__contains__('run_until_complete') == True
# AbstractEventLoop.__dict__.__contains__('create_task')        == True
# AbstractEventLoop.__dict__.__contains__('call_soon')          == True
# ---------------------------------------------------------------------------

table asyncio_extra162.asyncio_abstract_event_loop_dict:
  description: "asyncio.AbstractEventLoop.__dict__ membership checks in asyncioaeld162 namespace — AbstractEventLoop defines the complete asyncio event loop interface as abstract methods that raise NotImplementedError; AbstractEventLoop.__dict__.__contains__('run_forever')==True (run_forever() runs the event loop until stop() is called); AbstractEventLoop.__dict__.__contains__('run_until_complete')==True (run_until_complete(future) runs until the future is done — the primary way to drive a coroutine to completion); AbstractEventLoop.__dict__.__contains__('create_task')==True (create_task(coro) schedules a coroutine to run and returns a Task); AbstractEventLoop.__dict__.__contains__('call_soon')==True (call_soon(callback, *args) schedules callback to be called in the next iteration of the event loop); all four methods are defined directly on AbstractEventLoop (in its __dict__) as part of the abstract event loop protocol; AbstractEventLoop.__bases__[0].__name__=='object' (no asyncio-specific base); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioaeld162

  columns: [id, function, args, expected, description]
  rows:
    - [ael_has_run_forever,        asyncio.AbstractEventLoop.__dict__.__contains__,  ["run_forever"],         true,  "AbstractEventLoop.__dict__.__contains__('run_forever') == True (abstract: runs loop until stop()); verified with Python 3.14.3"]
    - [ael_has_run_until_complete, asyncio.AbstractEventLoop.__dict__.__contains__,  ["run_until_complete"],  true,  "AbstractEventLoop.__dict__.__contains__('run_until_complete') == True (abstract: runs until future done); verified with Python 3.14.3"]
    - [ael_has_create_task,        asyncio.AbstractEventLoop.__dict__.__contains__,  ["create_task"],         true,  "AbstractEventLoop.__dict__.__contains__('create_task') == True (abstract: schedules coroutine as task); verified with Python 3.14.3"]
    - [ael_has_call_soon,          asyncio.AbstractEventLoop.__dict__.__contains__,  ["call_soon"],           true,  "AbstractEventLoop.__dict__.__contains__('call_soon') == True (abstract: schedules callback next iteration); verified with Python 3.14.3"]

