table asyncio_extra162.asyncio_abstract_event_loop_policy_identity:
  description: "asyncio.AbstractEventLoopPolicy class identity checks in asyncioaelp162 namespace — asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24: '_'=1+'Abstract'=8+'EventLoop'=9+'Policy'=6=24; NOTE: in Python 3.14.3 the public name 'asyncio.AbstractEventLoopPolicy' resolves to a class whose actual __name__ attribute has a leading underscore '_AbstractEventLoopPolicy'; this class is deprecated and slated for removal in Python 3.16 — accessing it emits DeprecationWarning; despite the public access name having no underscore, the __name__ attribute itself starts with '_'); asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' (len=14; same submodule as AbstractEventLoop — both are defined in Lib/asyncio/events.py); asyncio.AbstractEventLoopPolicy.__bases__[0].__name__=='object' (also inherits from object directly); '_AbstractEventLoopPolicy' (len=24) > 'AbstractEventLoop' (len=17) by 7 chars; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioaelp162

  columns: [id, function, args, expected, description]
  rows:
    - [aelp_name_eq,   asyncio.AbstractEventLoopPolicy.__name__.__eq__,                ["_AbstractEventLoopPolicy"],  true,  "asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy' (leading underscore in actual __name__; deprecated in 3.14); verified with Python 3.14.3"]
    - [aelp_mod_eq,    asyncio.AbstractEventLoopPolicy.__module__.__eq__,               ["asyncio.events"],            true,  "asyncio.AbstractEventLoopPolicy.__module__ == 'asyncio.events' (same module as AbstractEventLoop); verified with Python 3.14.3"]
    - [aelp_base_eq,   "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__.__eq__",  ["object"],                    true,  "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__ == 'object' (inherits from object); verified with Python 3.14.3"]
    - [aelp_name_len,  asyncio.AbstractEventLoopPolicy.__name__.__len__,                [],                            24,    "asyncio.AbstractEventLoopPolicy.__name__.__len__() == 24 ('_AbstractEventLoopPolicy'; 7 longer than AbstractEventLoop=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra162
# ---------------------------------------------------------------------------

invariant asyncio_extra162.asyncio_AbstractEventLoop_name_eq:
  description: "asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop') returns True — asyncio.AbstractEventLoop is the pure-Python abstract base class that defines the complete asyncio event loop API; AbstractEventLoop.__name__=='AbstractEventLoop' (len=17: 'Abstract'=8+'Event'=5+'Loop'=4=17; alternatively: 'AbstractEventLoop'='Abstract'=8+'EventLoop'=9=17); AbstractEventLoop is defined in Lib/asyncio/events.py with __module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); AbstractEventLoop.__bases__[0].__name__=='object' (inherits from object directly — no asyncio or abc intermediate base); AbstractEventLoop defines abstract methods (run_forever, run_until_complete, create_task, call_soon, stop, etc.) that concrete event loop implementations must override; compare: asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24; the policy class has a leading underscore in its actual __name__ in Python 3.14.3); NEW in extra162: first standalone asyncio.AbstractEventLoop.__name__ identity invariant in asyncioael162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra162.asyncio_AbstractEventLoop_module_eq:
  description: "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') returns True — asyncio.AbstractEventLoop is defined in Lib/asyncio/events.py; __module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); the events submodule houses the abstract event loop and policy interfaces; compare submodule lengths: 'asyncio.events' (len=14) == 'asyncio.queues' (len=14) — both are 14 chars; 'asyncio.events' (len=14) > 'asyncio.locks' (len=13) by 1 char; AbstractEventLoop is NOT in the C extension module '_asyncio' (which hosts asyncio.Future and asyncio.Task); AbstractEventLoop is pure Python; compare: asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' (same module — both abstract interfaces live in events.py); NEW in extra162: first standalone asyncio.AbstractEventLoop.__module__ identity invariant in asyncioael162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra162.asyncio_AbstractEventLoop_base_is_object:
  description: "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__('object') returns True — asyncio.AbstractEventLoop inherits directly from object; __bases__[0].__name__=='object' (len=6); AbstractEventLoop is the root of the asyncio event loop class hierarchy — it has no asyncio-specific parent class; compare: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (Semaphore has a private mixin as its base; established in extra161) and asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (Queue also uses a private mixin; established in extra160); AbstractEventLoop, unlike Lock/Queue/Semaphore, inherits from object directly; AbstractEventLoop is the abstract API, not a concrete implementation — concrete loops (SelectorEventLoop, ProactorEventLoop) inherit from both AbstractEventLoop and a BaseEventLoop; NEW in extra162: first standalone asyncio.AbstractEventLoop.__bases__[0].__name__ identity invariant in asyncioael162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra162.asyncio_AbstractEventLoopPolicy_name_eq:
  description: "asyncio.AbstractEventLoopPolicy.__name__.__eq__('_AbstractEventLoopPolicy') returns True — in Python 3.14.3, the class accessible as asyncio.AbstractEventLoopPolicy has an actual __name__ attribute of '_AbstractEventLoopPolicy' (len=24: '_Abstract'=9+'EventLoop'=9+'Policy'=6=24); the leading underscore in the __name__ reflects the internal/deprecated nature of this class; accessing asyncio.AbstractEventLoopPolicy emits DeprecationWarning: 'asyncio.AbstractEventLoopPolicy is deprecated and slated for removal in Python 3.16'; AbstractEventLoopPolicy.__module__=='asyncio.events' (same module as AbstractEventLoop); AbstractEventLoopPolicy.__bases__[0].__name__=='object' (also inherits from object directly); the actual __name__ (len=24) is 7 chars longer than AbstractEventLoop.__name__ (len=17) because of the added '_' prefix and 'Policy'=6 suffix; NEW in extra162: first standalone asyncio.AbstractEventLoopPolicy.__name__ identity invariant in asyncioaelp162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoopPolicy.__name__.__eq__
  args: ["_AbstractEventLoopPolicy"]
  expected: true

invariant asyncio_extra162.asyncio_AbstractEventLoop_module_len:
  description: "asyncio.AbstractEventLoop.__module__.__len__().__eq__(14) — expressing the module length check as an eq invariant: 'asyncio.events' has length 14 ('asyncio'=7+'.'=1+'events'=6=14); this equals the length of 'asyncio.queues' (len=14; established in extra160 — both 'events' and 'queues' are 6-char submodule names); 'asyncio.events' (len=14) > 'asyncio.locks' (len=13) by 1 char because 'events'=6 > 'locks'=5; asyncio.AbstractEventLoop.__module__ (len=14) == asyncio.Queue.__module__ (len=14) — both live in 14-char module paths; compare: asyncio.Semaphore.__module__=='asyncio.locks' (len=13; established in extra161 — 1 shorter); NEW in extra162: first standalone asyncio.AbstractEventLoop.__module__.__len__ invariant in asyncioael162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__module__.__len__
  args: []
  expected: 14

