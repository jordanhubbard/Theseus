spec: threading_extra143
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread (Python class) — doc len 247, method qualnames (__init__, start, run, join) and co_argcount; threading.BoundedSemaphore (Python class) — doc len 641, __init__ qualname, MRO len 3; threading.Timer (Python class) — doc len 171, MRO len 3; threading.Barrier (Python class) — doc len 200, method qualnames (__init__, wait, reset, abort) and co_argcount (Wave 270)."
    - "threading.Thread.__doc__ len == 247. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15); co_argcount == 6. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' (len 12); co_argcount == 1. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' (len 10); co_argcount == 1. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' (len 11); co_argcount == 2. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__doc__ len == 641; MRO len == 3 ([BoundedSemaphore, Semaphore, object]). Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__init__.__qualname__ == 'BoundedSemaphore.__init__' (len 25); co_argcount == 2. Verified with Python 3.14.3."
    - "threading.Timer.__doc__ len == 171; __name__ == 'Timer' (len 5); MRO len == 3 ([Timer, Thread, object]). Verified with Python 3.14.3."
    - "threading.Barrier.__doc__ len == 200; __name__ == 'Barrier' (len 7); MRO len == 2. Verified with Python 3.14.3."
    - "threading.Barrier.__init__.__qualname__ == 'Barrier.__init__' (len 16); co_argcount == 4. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len 12); co_argcount == 2. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len 13); co_argcount == 1. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len 13); co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread — class identity, doc, method qualnames/argcounts
#
# Wave 270 theme: threading.Thread — the core Python thread class.
#
# threading.Thread.__class__.__name__ == 'type'
# threading.Thread.__name__ == 'Thread' (len 6)
# threading.Thread.__module__ == 'threading' (len 9)
# len(threading.Thread.__doc__) == 247
# threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15)
# threading.Thread.__init__.__code__.co_argcount == 6
# threading.Thread.start.__qualname__ == 'Thread.start' (len 12)
# threading.Thread.start.__code__.co_argcount == 1
# threading.Thread.run.__qualname__ == 'Thread.run' (len 10)
# threading.Thread.run.__code__.co_argcount == 1
# threading.Thread.join.__qualname__ == 'Thread.join' (len 11)
# threading.Thread.join.__code__.co_argcount == 2
#
# Thread(target, name, args, kwargs, daemon) represents a thread of control.
# New to extra143.
# ---------------------------------------------------------------------------

table threading_extra143.thread_class_and_methods:
  description: "threading.Thread: Python class, __doc__ str len 247, __init__ qualname len 15 co_argcount 6, start qualname len 12, run len 10, join len 11 co_argcount 2; wave 270; new to extra143"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread143

