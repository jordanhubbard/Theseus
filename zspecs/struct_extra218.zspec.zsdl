spec: struct_extra218
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__class__.__name__ == 'type' — Struct is a type object."
    - "struct.Struct.__mro__.__len__() == 2 — Struct MRO: Struct -> object (2 entries)."
    - "struct.Struct.__mro__[0].__name__ == 'Struct' — first MRO entry is Struct itself."
    - "struct.Struct.__mro__[1].__name__ == 'object' — second MRO entry is object."
    - "struct.error.__class__.__name__ == 'type' — error is a type object."
    - "struct.error.__mro__.__len__() == 4 — error MRO: error -> Exception -> BaseException -> object."
    - "struct.error.__mro__[0].__name__ == 'error' — first MRO entry is error itself."
    - "struct.error.__mro__[1].__name__ == 'Exception' — error directly extends Exception."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method' — pack is C-level."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — unpack is C-level."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — calcsize is C-level."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct Struct class MRO contracts
#
# struct.Struct.__class__.__name__    == 'type'
# struct.Struct.__mro__.__len__()     == 2
# struct.Struct.__mro__[0].__name__   == 'Struct'
# struct.Struct.__mro__[1].__name__   == 'object'
# ---------------------------------------------------------------------------

table struct_extra218.Struct_class_mro_contracts:
  description: "struct Struct class MRO contracts in struct218 namespace — wave 218 theme: Struct is a type; MRO is Struct -> object (length 2); error MRO is error -> Exception -> BaseException -> object (length 4); pack/unpack/calcsize are builtin_function_or_method; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: struct218

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_class_name,     struct.Struct.__class__.__name__.__eq__,            ["type"],                      true, "struct.Struct.__class__.__name__ == 'type' — Struct is a type (metaclass is type)"]
    - [Struct_mro_len,        struct.Struct.__mro__.__len__,                      [],                            2,    "struct.Struct.__mro__.__len__() == 2 — Struct MRO has 2 entries: Struct and object"]
    - [Struct_mro_0_name,     "struct.Struct.__mro__[0].__name__.__eq__",         ["Struct"],                    true, "struct.Struct.__mro__[0].__name__ == 'Struct' — first MRO entry is Struct itself"]
    - [Struct_mro_1_name,     "struct.Struct.__mro__[1].__name__.__eq__",         ["object"],                    true, "struct.Struct.__mro__[1].__name__ == 'object' — second MRO entry is object; no intermediate bases"]
    - [error_class_name,      struct.error.__class__.__name__.__eq__,             ["type"],                      true, "struct.error.__class__.__name__ == 'type' — error is a type object"]
    - [error_mro_len,         struct.error.__mro__.__len__,                       [],                            4,    "struct.error.__mro__.__len__() == 4 — error MRO: error -> Exception -> BaseException -> object"]
    - [error_mro_0_name,      "struct.error.__mro__[0].__name__.__eq__",          ["error"],                     true, "struct.error.__mro__[0].__name__ == 'error' — first MRO entry is error itself"]
    - [error_mro_1_name,      "struct.error.__mro__[1].__name__.__eq__",          ["Exception"],                 true, "struct.error.__mro__[1].__name__ == 'Exception' — error directly extends Exception"]
    - [pack_class_name,       struct.pack.__class__.__name__.__eq__,              ["builtin_function_or_method"], true, "struct.pack.__class__.__name__ == 'builtin_function_or_method' — pack is a C-level builtin"]
    - [unpack_class_name,     struct.unpack.__class__.__name__.__eq__,            ["builtin_function_or_method"], true, "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — unpack is a C-level builtin"]

# ---------------------------------------------------------------------------
# struct module-level calcsize function type check
# ---------------------------------------------------------------------------

table struct_extra218.struct_calcsize_type:
  description: "struct.calcsize type contract in struct218a namespace — wave 218 theme: calcsize is a C-level builtin_function_or_method; returns the size of a struct described by the given format string; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: struct218a

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_class_name,  struct.calcsize.__class__.__name__.__eq__,         ["builtin_function_or_method"], true, "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — calcsize is a C-level builtin"]

# ---------------------------------------------------------------------------
# Standalone invariants for Struct and error MRO entries
# ---------------------------------------------------------------------------

invariant struct_extra218.Struct_mro_entry0_name_eq:
  description: "struct.Struct.__mro__[0].__name__.__eq__('Struct') == True — first MRO entry of Struct is Struct itself; C-level type exposed by _struct extension module; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "struct.Struct.__mro__[0].__name__.__eq__"
  args: ["Struct"]
  expected: true

invariant struct_extra218.Struct_mro_entry1_name_eq:
  description: "struct.Struct.__mro__[1].__name__.__eq__('object') == True — second and final MRO entry is object; Struct has no intermediate base classes; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "struct.Struct.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant struct_extra218.error_mro_entry0_name_eq:
  description: "struct.error.__mro__[0].__name__.__eq__('error') == True — first MRO entry of struct.error is error itself; struct.error is the exception raised for packing/unpacking errors; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "struct.error.__mro__[0].__name__.__eq__"
  args: ["error"]
  expected: true

invariant struct_extra218.error_mro_entry1_name_eq:
  description: "struct.error.__mro__[1].__name__.__eq__('Exception') == True — error directly extends Exception (not OSError or ValueError); verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "struct.error.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true
