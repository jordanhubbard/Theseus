table concurrent_futures_extra140.broken_pool_classes:
  description: "concurrent.futures BrokenThreadPool and BrokenProcessPool identity checks — BrokenThreadPool.__name__.__eq__('BrokenThreadPool')==True (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16); BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')==True (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25, the thread submodule); BrokenThreadPool.__doc__.__len__()==74 (same length as concurrent.futures.BrokenExecutor.__doc__, both inherit and share the same docstring); BrokenProcessPool.__name__.__eq__('BrokenProcessPool')==True (len=17: 'Broken'=6+'Process'=7+'Pool'=4=17, one more than BrokenThreadPool); BrokenProcessPool.__module__.__eq__('concurrent.futures.process')==True (len=26: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26, one more than thread variant); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbroken140

  columns: [id, function, args, expected, description]
  rows:
    - [btp_name_eq,  concurrent.futures.thread.BrokenThreadPool.__name__.__eq__,    ["BrokenThreadPool"],           true,  "concurrent.futures.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16); verified with Python 3.14.3"]
    - [btp_name_len, concurrent.futures.thread.BrokenThreadPool.__name__.__len__,    [],                            16,    "concurrent.futures.thread.BrokenThreadPool.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [btp_mod_eq,   concurrent.futures.thread.BrokenThreadPool.__module__.__eq__,  ["concurrent.futures.thread"],  true,  "concurrent.futures.thread.BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [btp_mod_len,  concurrent.futures.thread.BrokenThreadPool.__module__.__len__,  [],                            25,    "concurrent.futures.thread.BrokenThreadPool.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [btp_doc_len,  concurrent.futures.thread.BrokenThreadPool.__doc__.__len__,     [],                            74,    "concurrent.futures.thread.BrokenThreadPool.__doc__.__len__() == 74; verified with Python 3.14.3"]
    - [bpp_name_eq,  concurrent.futures.process.BrokenProcessPool.__name__.__eq__,  ["BrokenProcessPool"],          true,  "concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17); verified with Python 3.14.3"]
    - [bpp_name_len, concurrent.futures.process.BrokenProcessPool.__name__.__len__,  [],                            17,    "concurrent.futures.process.BrokenProcessPool.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [bpp_mod_eq,   concurrent.futures.process.BrokenProcessPool.__module__.__eq__, ["concurrent.futures.process"], true, "concurrent.futures.process.BrokenProcessPool.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
