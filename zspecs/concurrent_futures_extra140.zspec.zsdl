spec: concurrent_futures_extra140
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: concurrent.futures.wait — __qualname__=='wait' (len=4); __module__=='concurrent.futures._base' (len=24); __doc__.__len__()==1054; co_argcount==3 ('fs','timeout','return_when'); co_varnames.__len__()==7. concurrent.futures.as_completed — __qualname__=='as_completed' (len=12); __module__=='concurrent.futures._base' (len=24); __doc__.__len__()==570; co_argcount==2 ('fs','timeout'); co_varnames.__len__()==9. concurrent.futures.FIRST_COMPLETED=='FIRST_COMPLETED' (len=15); concurrent.futures.FIRST_EXCEPTION=='FIRST_EXCEPTION' (len=15); concurrent.futures.ALL_COMPLETED=='ALL_COMPLETED' (len=13). concurrent.futures.thread.BrokenThreadPool — __name__=='BrokenThreadPool' (len=16); __module__=='concurrent.futures.thread' (len=25); __doc__.__len__()==74. concurrent.futures.process.BrokenProcessPool — __name__=='BrokenProcessPool' (len=17); __module__=='concurrent.futures.process' (len=26). concurrent.futures.ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor' (len=18); concurrent.futures.ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor' (len=19). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait and as_completed both have __module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24). wait co_argcount==3 (fs, timeout, return_when); as_completed co_argcount==2 (fs, timeout). FIRST_COMPLETED and FIRST_EXCEPTION are string constants of equal length (15); ALL_COMPLETED is shorter (13). BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25); BrokenProcessPool.__module__=='concurrent.futures.process' (len=26). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed __doc__, qualname, code — extra140
#
# concurrent.futures.wait.__qualname__         == 'wait'  (len=4)
# concurrent.futures.wait.__module__           == 'concurrent.futures._base' (len=24)
# concurrent.futures.wait.__doc__.__len__()    == 1054
# concurrent.futures.wait co_argcount          == 3
# concurrent.futures.wait co_varnames len      == 7
# concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12)
# concurrent.futures.as_completed.__doc__.__len__() == 570
# concurrent.futures.as_completed co_argcount  == 2
# concurrent.futures.as_completed co_varnames len == 9
# ---------------------------------------------------------------------------

table concurrent_futures_extra140.wait_and_as_completed:
  description: "concurrent.futures.wait and as_completed __doc__, qualname, and code checks — wait.__qualname__.__eq__('wait')==True (len=4: top-level function, qualname equals name); wait.__module__.__eq__('concurrent.futures._base')==True (len=24: same _base module as Future and Executor); wait.__doc__.__len__()==1054 (multi-section doc with Args, Returns, and Raises); wait.__code__.co_argcount.__eq__(3)==True ('fs','timeout','return_when'); wait.__code__.co_varnames.__len__()==7 ('fs','timeout','return_when','f','done','not_done','waiter'); as_completed.__qualname__.__eq__('as_completed')==True (len=12: 'as_completed'=12); as_completed.__module__.__eq__('concurrent.futures._base')==True (len=24); as_completed.__doc__.__len__()==570 (multi-section doc with Args, Returns, Raises); as_completed.__code__.co_argcount.__eq__(2)==True ('fs','timeout'); as_completed.__code__.co_varnames.__len__()==9 (more locals than wait due to iterator state); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait140

  columns: [id, function, args, expected, description]
  rows:
    - [w_qn_eq,      concurrent.futures.wait.__qualname__.__eq__,                      ["wait"],                         true,  "concurrent.futures.wait.__qualname__ == 'wait' (len=4); verified with Python 3.14.3"]
    - [w_qn_len,     concurrent.futures.wait.__qualname__.__len__,                      [],                              4,     "concurrent.futures.wait.__qualname__.__len__() == 4; verified with Python 3.14.3"]
    - [w_mod_eq,     concurrent.futures.wait.__module__.__eq__,                        ["concurrent.futures._base"],     true,  "concurrent.futures.wait.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [w_mod_len,    concurrent.futures.wait.__module__.__len__,                        [],                              24,    "concurrent.futures.wait.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [w_doc_len,    concurrent.futures.wait.__doc__.__len__,                           [],                              1054,  "concurrent.futures.wait.__doc__.__len__() == 1054; verified with Python 3.14.3"]
    - [w_argc,       concurrent.futures.wait.__code__.co_argcount.__eq__,              [3],                              true,  "concurrent.futures.wait.__code__.co_argcount == 3 ('fs','timeout','return_when'); verified with Python 3.14.3"]
    - [w_vlen,       concurrent.futures.wait.__code__.co_varnames.__len__,              [],                              7,     "concurrent.futures.wait.__code__.co_varnames.__len__() == 7; verified with Python 3.14.3"]
    - [ac_qn_eq,     concurrent.futures.as_completed.__qualname__.__eq__,              ["as_completed"],                 true,  "concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12); verified with Python 3.14.3"]
    - [ac_qn_len,    concurrent.futures.as_completed.__qualname__.__len__,              [],                              12,    "concurrent.futures.as_completed.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [ac_mod_len,   concurrent.futures.as_completed.__module__.__len__,                [],                              24,    "concurrent.futures.as_completed.__module__.__len__() == 24 ('concurrent.futures._base'); verified with Python 3.14.3"]
    - [ac_doc_len,   concurrent.futures.as_completed.__doc__.__len__,                   [],                              570,   "concurrent.futures.as_completed.__doc__.__len__() == 570; verified with Python 3.14.3"]
    - [ac_argc,      concurrent.futures.as_completed.__code__.co_argcount.__eq__,      [2],                              true,  "concurrent.futures.as_completed.__code__.co_argcount == 2 ('fs','timeout'); verified with Python 3.14.3"]
    - [ac_vlen,      concurrent.futures.as_completed.__code__.co_varnames.__len__,      [],                              9,     "concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9; verified with Python 3.14.3"]

