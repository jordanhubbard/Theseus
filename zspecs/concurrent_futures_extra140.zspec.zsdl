# ---------------------------------------------------------------------------

table concurrent_futures_extra140.return_when_constants:
  description: "concurrent.futures return_when string constants — FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True (len=15: 'FIRST_COMPLETED'=15); FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True (len=15: ties with FIRST_COMPLETED, both are 'FIRST_'=6+'COMPLETED'=9 or 'EXCEPTION'=9=15); ALL_COMPLETED.__eq__('ALL_COMPLETED')==True (len=13: 'ALL_COMPLETED'=13, two shorter than the FIRST_ variants); all three are plain string constants (not Enum members) used as the return_when parameter to concurrent.futures.wait; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfconst140

  columns: [id, function, args, expected, description]
  rows:
    - [fc_eq,   concurrent.futures.FIRST_COMPLETED.__eq__,  ["FIRST_COMPLETED"],  true,  "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (len=15); verified with Python 3.14.3"]
    - [fc_len,  concurrent.futures.FIRST_COMPLETED.__len__,  [],                  15,    "concurrent.futures.FIRST_COMPLETED.__len__() == 15; verified with Python 3.14.3"]
    - [fe_eq,   concurrent.futures.FIRST_EXCEPTION.__eq__,  ["FIRST_EXCEPTION"],  true,  "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' (len=15); verified with Python 3.14.3"]
    - [fe_len,  concurrent.futures.FIRST_EXCEPTION.__len__,  [],                  15,    "concurrent.futures.FIRST_EXCEPTION.__len__() == 15; verified with Python 3.14.3"]
    - [ac_eq,   concurrent.futures.ALL_COMPLETED.__eq__,    ["ALL_COMPLETED"],    true,  "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' (len=13); verified with Python 3.14.3"]
    - [ac_len,  concurrent.futures.ALL_COMPLETED.__len__,    [],                  13,    "concurrent.futures.ALL_COMPLETED.__len__() == 13; verified with Python 3.14.3"]

