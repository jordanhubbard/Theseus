spec: uuid_extra25
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra24.zspec.zsdl — covers SafeUUID __name__/__qualname__/__mro__/__bases__[0].__name__; uuid.getnode __name__/__qualname__/__module__; UUID.node/time/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__len__()."
    - "uuid_extra23.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__len__()==12; UUID.hex/bytes/bytes_le.fget.__qualname__.__len__(); NAMESPACE_DNS/URL __class__.__name__.__len__()==4; RFC_4122.__class__.__name__.__len__()==3; RFC_4122.__len__()==21; uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra22.zspec.zsdl — covers UUID.__mro__.__len__()==2; UUID.__str__/__repr__/__hash__/__eq__ __qualname__.__len__(); UUID.__slots__.__class__.__name__/__len__()==3."
    - "uuid_extra18.zspec.zsdl — covers UUID property fget __qualname__ values and lengths for hex/bytes/urn/version/bytes_le/fields/variant."
    - "uuid_extra14.zspec.zsdl — covers uuid1/3/4/5 __qualname__.__len__()==5; SafeUUID.__qualname__.__len__()==8; UUID.__bases__[0].__name__.__len__()==6; NAMESPACE_OID/X500 __class__.__name__.__len__()==4."
    - "uuid_extra12.zspec.zsdl — covers UUID.__qualname__.__len__()==4; uuid1/3/5 __name__.__len__()==5; NAMESPACE_DNS/URL __class__.__name__.__len__()==4."
  notes:
    - "This spec extends uuid through uuid_extra24; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: UUID.__qualname__.__len__()==4 (extra12); UUID.__dict__.__class__.__name__.__len__()==12 (extra23); uuid4().version==4 (extra/extra3/extra4/extra7); uuid4().__class__.__name__=='UUID' (extra/extra3/extra4/extra7); NAMESPACE_DNS/URL __class__.__name__.__len__()==4 (extra12/extra23); uuid1/3/4/5 __name__.__len__()==5 (extra12); uuid1/3/4/5 __qualname__.__len__()==5 (extra23/extra14); RFC_4122.__class__.__name__.__len__()==3 (extra23); SafeUUID __name__/__qualname__/__mro__/__bases__[0] (extra7/extra14/extra24); UUID.node/time/clock_seq fget qualname lens (extra24)."
    - "This spec covers: UUID.__init_subclass__.__qualname__.__len__() (NOVEL — 'UUID.__init_subclass__' is 22 chars; no prior uuid spec checks __init_subclass__ for UUID); UUID.__subclasshook__.__qualname__.__len__() (NOVEL — 'UUID.__subclasshook__' is 21 chars; no prior uuid spec checks __subclasshook__); uuid.__spec__.__name__.__len__() (NOVEL — 'uuid' is 4 chars; no prior uuid spec checks the module-level __spec__.__name__); uuid.__loader__.__class__.__name__.__len__() (NOVEL — 'SourceFileLoader' is 16 chars; no prior uuid spec checks the module loader class); UUID.__new__.__qualname__.__len__() (NOVEL — 'object.__new__' is 14 chars; no prior uuid spec checks UUID.__new__.__qualname__); uuid4().__class__.__qualname__.__len__() (NOVEL — 'UUID' is 4 chars; extra checks __class__.__name__=='UUID' via eq but not __qualname__.__len__())."
    - "uuid.UUID.__init_subclass__.__qualname__ == 'UUID.__init_subclass__' (len 22). UUID inherits __init_subclass__ from object but it is bound to UUID; no prior uuid spec touches __init_subclass__ at all. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.UUID.__subclasshook__.__qualname__ == 'UUID.__subclasshook__' (len 21). Inherited from object; bound to UUID class. No prior uuid spec touches __subclasshook__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__name__ == 'uuid' (len 4). No prior uuid spec checks any module import machinery attribute. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). uuid is a pure-Python module loaded by importlib.machinery.SourceFileLoader. No prior uuid spec checks the loader class name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__qualname__ == 'object.__new__' (len 14). UUID does not define __new__; it delegates to object.__new__. No prior uuid spec checks UUID.__new__.__qualname__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.uuid4().__class__.__qualname__ == 'UUID' (len 4). Prior specs check __class__.__name__ via __eq__ but no spec checks __class__.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__init_subclass__ and __subclasshook__ __qualname__.__len__()
#
# No prior uuid spec touches __init_subclass__ or __subclasshook__ for UUID.
# Both are inherited from object but bound to UUID:
#   UUID.__init_subclass__.__qualname__ == 'UUID.__init_subclass__' -> len 22
#   UUID.__subclasshook__.__qualname__ == 'UUID.__subclasshook__' -> len 21
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra25.UUID.init_subclass_qualname_len:
  description: "uuid.UUID.__init_subclass__.__qualname__.__len__() == 22 — 'UUID.__init_subclass__' has 22 characters; novel: no prior uuid spec touches __init_subclass__"
  category: class_introspection
  kind: python_call_eq
  function: "UUID.__init_subclass__.__qualname__.__len__"
  args: []
  expected: 22

invariant uuid_extra25.UUID.subclasshook_qualname_len:
  description: "uuid.UUID.__subclasshook__.__qualname__.__len__() == 21 — 'UUID.__subclasshook__' has 21 characters; novel: no prior uuid spec touches __subclasshook__"
  category: class_introspection
  kind: python_call_eq
  function: "UUID.__subclasshook__.__qualname__.__len__"
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# uuid module-level import machinery — __spec__ and __loader__
#
# No prior uuid spec checks any module import machinery attribute.
# uuid.__spec__.__name__ == 'uuid' -> len 4
# uuid.__loader__.__class__.__name__ == 'SourceFileLoader' -> len 16
# uuid is a pure-Python module loaded by importlib.machinery.SourceFileLoader.
# ---------------------------------------------------------------------------

invariant uuid_extra25.module_spec_name_len:
  description: "uuid.__spec__.__name__.__len__() == 4 — 'uuid' has 4 characters; novel module-level import machinery check"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__name__.__len__
  args: []
  expected: 4

invariant uuid_extra25.module_loader_class_name_len:
  description: "uuid.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; uuid is a pure-Python module"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# UUID.__new__.__qualname__.__len__() and uuid4().__class__.__qualname__.__len__()
#
# UUID.__new__ delegates to object.__new__; its qualname is 'object.__new__' (len 14).
# No prior uuid spec checks UUID.__new__.__qualname__.
#
# uuid4().__class__.__qualname__ == 'UUID' (len 4).
# Prior specs check __class__.__name__ via __eq__ (extra/extra3/extra4/extra7) but
# no prior spec checks uuid4().__class__.__qualname__.__len__().
# ---------------------------------------------------------------------------

invariant uuid_extra25.UUID.new_qualname_len:
  description: "uuid.UUID.__new__.__qualname__.__len__() == 14 — 'object.__new__' has 14 characters; UUID delegates __new__ to object; novel invariant"
  category: class_introspection
  kind: python_call_eq
  function: UUID.__new__.__qualname__.__len__
  args: []
  expected: 14

invariant uuid_extra25.uuid4_class_qualname_len:
  description: "uuid.uuid4().__class__.__qualname__.__len__() == 4 — 'UUID' has 4 characters; prior specs check __class__.__name__ via __eq__ but not __class__.__qualname__.__len__()"
  category: functional
  kind: python_call_eq
  function: uuid4
  args: []
  method: __class__.__qualname__.__len__
  method_args: []
  expected: 4
