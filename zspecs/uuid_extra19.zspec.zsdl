spec: uuid_extra19
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Extends uuid.zspec.zsdl through uuid_extra18.zspec.zsdl."
    - "uuid_extra5 covers: UUID.__qualname__.__eq__('UUID'); uuid1/3/4/5 __qualname__.__eq__ in a table."
    - "uuid_extra15 covers: NAMESPACE_DNS/URL/OID.__class__.__qualname__.__eq__('UUID')."
    - "uuid_extra17 covers: UUID comparison method __qualname__ values; NAMESPACE_X500.__class__.__qualname__; NAMESPACE_DNS.version and .variant types."
    - "uuid_extra18 covers: UUID.__module__; UUID.__bases__[0].__name__; uuid1/3/4/5 __module__; UUID property fget __qualname__ values and lengths."
    - "This spec adds: uuid.UUID.__name__.__eq__('UUID') — extra5 checks UUID.__qualname__.__eq__ and extra18 checks UUID.__module__.__eq__ but no prior uuid spec checks UUID.__name__.__eq__; uuid1/uuid3/uuid4/uuid5 __name__.__eq__ — extra5 checks __qualname__ and extra18 checks __module__, but no prior spec checks __name__ on any factory function; NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — extra15/17 check __class__.__qualname__ on namespace constants, but no prior spec checks __class__.__name__ on any NAMESPACE constant; UUID.__name__.__len__()==4 and uuid1/3/4/5 __name__ lengths."
    - "uuid.UUID.__name__ == 'UUID' — for top-level classes __name__ equals __qualname__; the attribute path is distinct. extra5 checks __qualname__.__eq__; no prior uuid spec checks __name__.__eq__ on UUID."
    - "uuid.uuid1.__name__ == 'uuid1' — extra5 checks uuid1.__qualname__.__eq__; extra18 checks uuid1.__module__.__eq__; no prior spec checks uuid1.__name__.__eq__."
    - "uuid.uuid3.__name__ == 'uuid3' — same rationale as uuid1."
    - "uuid.uuid4.__name__ == 'uuid4' — same rationale as uuid1."
    - "uuid.uuid5.__name__ == 'uuid5' — same rationale as uuid1."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — extra15 checks NAMESPACE_DNS.__class__.__qualname__.__eq__('UUID'); no prior spec checks __class__.__name__ (vs. __qualname__) on any NAMESPACE constant. For top-level classes these are equal but use distinct attribute paths."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — extra15 covers NAMESPACE_URL.__class__.__qualname__; extra17 adds NAMESPACE_X500.__class__.__qualname__; no spec checks __class__.__name__ on any NAMESPACE constant."
    - "len(uuid.UUID.__name__) == 4 — no prior uuid spec checks UUID.__name__.__len__()."
    - "uuid factory function __name__ lengths: uuid1/uuid3/uuid4/uuid5 are all 5 characters. No prior uuid spec checks __name__.__len__() on any factory function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__name__
#
# uuid_extra5 checks UUID.__qualname__.__eq__('UUID'). uuid_extra18 checks
# UUID.__module__.__eq__('uuid'). No prior uuid spec checks UUID.__name__.__eq__.
# For top-level classes __name__ == __qualname__, but the attribute path is
# distinct and provides a separate invariant.
# ---------------------------------------------------------------------------

invariant uuid_extra19.UUID.name:
  description: "uuid.UUID.__name__ == 'UUID' — distinct from __qualname__ checked in extra5; no prior spec checks UUID.__name__"
  category: class_identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid factory function __name__ values
#
# uuid_extra5 checks uuid1/3/4/5 __qualname__.__eq__ in a table.
# uuid_extra18 checks uuid1/3/4/5 __module__.__eq__ in a table.
# No prior uuid spec checks __name__.__eq__ on any factory function.
# For module-level functions, __name__ == __qualname__ (simple name), but the
# attribute path is distinct.
# ---------------------------------------------------------------------------

table uuid_extra19.factory_names:
  description: "uuid1/uuid3/uuid4/uuid5 __name__ — distinct from __qualname__ in extra5 and __module__ in extra18"
  kind: python_call_eq
  category: function_identity
  id_prefix: factname19

  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__name__.__eq__, ["uuid1"], true]
    - [uuid3, uuid3.__name__.__eq__, ["uuid3"], true]
    - [uuid4, uuid4.__name__.__eq__, ["uuid4"], true]
    - [uuid5, uuid5.__name__.__eq__, ["uuid5"], true]

# ---------------------------------------------------------------------------
# NAMESPACE_DNS and NAMESPACE_URL __class__.__name__
#
# uuid_extra15 checks NAMESPACE_DNS/URL/OID.__class__.__qualname__.__eq__('UUID').
# uuid_extra17 checks NAMESPACE_X500.__class__.__qualname__.__eq__('UUID').
# No prior uuid spec checks __class__.__name__ (as opposed to __class__.__qualname__)
# on any NAMESPACE constant. For top-level classes these values are equal but
# the attribute path is distinct, providing novel invariants.
# ---------------------------------------------------------------------------

table uuid_extra19.namespace_class_names:
  description: "NAMESPACE_DNS/URL __class__.__name__ == 'UUID' — distinct from __class__.__qualname__ checked in extra15/17"
  kind: python_call_eq
  category: namespace_metadata
  id_prefix: nscname19

  columns: [id, function, args, expected]
  rows:
    - [DNS, NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
    - [URL, NAMESPACE_URL.__class__.__name__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# UUID.__name__ string length
#
# len('UUID') == 4. uuid_extra5 checks __qualname__.__eq__; uuid_extra18
# checks property fget __qualname__ lengths. No prior uuid spec checks
# UUID.__name__.__len__().
# ---------------------------------------------------------------------------

invariant uuid_extra19.UUID.name_len:
  description: "uuid.UUID.__name__.__len__() == 4 — len('UUID') == 4; no prior uuid spec checks UUID.__name__.__len__()"
  category: class_identity
  kind: python_call_eq
  function: UUID.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid factory function __name__ string lengths
#
# All four factory functions (uuid1/uuid3/uuid4/uuid5) have __name__ strings
# of length 5. No prior uuid spec checks __name__.__len__() on any factory
# function. uuid_extra10 checks __qualname__.__len__() for uuid1/3/4/5 in a
# table; __name__.__len__() uses a distinct attribute path.
# ---------------------------------------------------------------------------

table uuid_extra19.factory_name_lengths:
  description: "uuid1/uuid3/uuid4/uuid5 __name__ string lengths — all 5 characters; distinct from __qualname__.__len__() in extra10"
  kind: python_call_eq
  category: function_identity
  id_prefix: factnlen19

  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__name__.__len__, [], 5]
    - [uuid3, uuid3.__name__.__len__, [], 5]
    - [uuid4, uuid4.__name__.__len__, [], 5]
    - [uuid5, uuid5.__name__.__len__, [], 5]
