spec: networkx
version: ">=2.0"
backend: python_module(networkx)

docs: https://networkx.org/documentation/stable/reference/

provenance:
  derived_from:
    - "NetworkX documentation — https://networkx.org/documentation/stable/reference/"
    - "NetworkX Graph API — https://networkx.org/documentation/stable/reference/classes/graph.html"
    - "NetworkX algorithms — https://networkx.org/documentation/stable/reference/algorithms/"
    - "Test vectors verified with networkx 3.6.1 on Python 3.x / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "networkx source: networkx/classes/graph.py"
    - "networkx source: networkx/algorithms/"
  notes:
    - "Graph instances are constructed via function: / args: — no JSON graph objects needed."
    - "Method calls on constructed instances use method: field (zero-arg methods called directly)."
    - "is_directed() is tested via instance method on Graph/DiGraph, not module-level function."
    - "density() and is_connected() require graph args not expressible in JSON; tested via __name__."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ is a string containing a dot
# ---------------------------------------------------------------------------

invariant networkx.version.is_string:
  description: "nx.__version__ is a str (type name == 'str')"
  category: version
  kind: python_call_eq
  function: __version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant networkx.version.contains_dot:
  description: "nx.__version__ contains a dot (e.g. '3.6.1')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# graph — empty Graph, path_graph, node/edge counts
# ---------------------------------------------------------------------------

invariant networkx.graph.empty_nodes:
  description: "Graph().number_of_nodes() == 0 — empty graph has no nodes"
  category: graph
  kind: python_call_eq
  function: Graph
  args: []
  method: number_of_nodes
  expected: 0

invariant networkx.graph.empty_edges:
  description: "Graph().number_of_edges() == 0 — empty graph has no edges"
  category: graph
  kind: python_call_eq
  function: Graph
  args: []
  method: number_of_edges
  expected: 0

invariant networkx.graph.path4_nodes:
  description: "path_graph(4).number_of_nodes() == 4"
  category: graph
  kind: python_call_eq
  function: path_graph
  args: [4]
  method: number_of_nodes
  expected: 4

invariant networkx.graph.path4_edges:
  description: "path_graph(4).number_of_edges() == 3 — path of 4 nodes has 3 edges"
  category: graph
  kind: python_call_eq
  function: path_graph
  args: [4]
  method: number_of_edges
  expected: 3

# ---------------------------------------------------------------------------
# complete_graph — node and edge counts
# ---------------------------------------------------------------------------

invariant networkx.complete_graph.nodes:
  description: "complete_graph(3).number_of_nodes() == 3"
  category: complete_graph
  kind: python_call_eq
  function: complete_graph
  args: [3]
  method: number_of_nodes
  expected: 3

invariant networkx.complete_graph.edges:
  description: "complete_graph(3).number_of_edges() == 3 — K3 has 3 edges"
  category: complete_graph
  kind: python_call_eq
  function: complete_graph
  args: [3]
  method: number_of_edges
  expected: 3

# ---------------------------------------------------------------------------
# directed — is_directed() via instance method
# ---------------------------------------------------------------------------

invariant networkx.directed.digraph_is_directed:
  description: "DiGraph().is_directed() == True"
  category: directed
  kind: python_call_eq
  function: DiGraph
  args: []
  method: is_directed
  expected: true

invariant networkx.directed.graph_not_directed:
  description: "Graph().is_directed() == False"
  category: directed
  kind: python_call_eq
  function: Graph
  args: []
  method: is_directed
  expected: false

# ---------------------------------------------------------------------------
# algorithms — function identity checks (density, is_connected, is_directed)
#
# These module-level functions accept graph objects as args which cannot be
# expressed as JSON literals. We verify them via __name__ attribute lookup,
# confirming the correct callable is present and correctly named.
# ---------------------------------------------------------------------------

invariant networkx.algorithms.density_name:
  description: "nx.density.__name__ == 'density' — module-level density function is present"
  category: algorithms
  kind: python_call_eq
  function: density.__name__.__eq__
  args: ["density"]
  expected: true

invariant networkx.algorithms.is_connected_name:
  description: "nx.is_connected.__name__ == 'is_connected' — module-level is_connected is present"
  category: algorithms
  kind: python_call_eq
  function: is_connected.__name__.__eq__
  args: ["is_connected"]
  expected: true

invariant networkx.algorithms.is_directed_name:
  description: "nx.is_directed.__name__ == 'is_directed' — module-level is_directed is present"
  category: algorithms
  kind: python_call_eq
  function: is_directed.__name__.__eq__
  args: ["is_directed"]
  expected: true

invariant networkx.algorithms.shortest_path_name:
  description: "nx.shortest_path.__name__ == 'shortest_path' — module-level shortest_path is present"
  category: algorithms
  kind: python_call_eq
  function: shortest_path.__name__.__eq__
  args: ["shortest_path"]
  expected: true
