# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.index() protocol in own __dict__
#
# None of the io classes define __index__ in their own __dict__.
# __index__ requires an integer-like type; io stream classes are not integers.
# ---------------------------------------------------------------------------

table io2971.index:
  description: "operator.contains(cls.__dict__, '__index__') is False for all io classes"
  kind: python_call_eq
  category: dict_presence
