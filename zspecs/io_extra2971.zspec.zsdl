spec: io2971
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io class __dict__ floor / ceil / index presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/"
  notes:
    - "io I/O classes are stream/file types; they do not define __floor__, __ceil__, or __index__."
    - "operator.contains(cls.__dict__, '__floor__') is False for all io classes — these are not numeric types."
    - "operator.contains(cls.__dict__, '__ceil__') is False for all io classes."
    - "operator.contains(cls.__dict__, '__index__') is False for all io classes."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — math.floor() protocol in own __dict__
#
# None of the io classes define __floor__ in their own __dict__.
# These are stream/file abstractions, not numeric types.
# ---------------------------------------------------------------------------

table io2971.floor:
  description: "operator.contains(cls.__dict__, '__floor__') is False for all io classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: iof2971

  columns: [id, function, args, expected]
  rows:
    - ["iof2971_001", operator.contains, [io.IOBase.__dict__,         "__floor__"], false]
    - ["iof2971_002", operator.contains, [io.RawIOBase.__dict__,      "__floor__"], false]
    - ["iof2971_003", operator.contains, [io.BufferedIOBase.__dict__,  "__floor__"], false]
    - ["iof2971_004", operator.contains, [io.TextIOBase.__dict__,     "__floor__"], false]
    - ["iof2971_005", operator.contains, [io.FileIO.__dict__,         "__floor__"], false]
    - ["iof2971_006", operator.contains, [io.BytesIO.__dict__,        "__floor__"], false]
    - ["iof2971_007", operator.contains, [io.StringIO.__dict__,       "__floor__"], false]
    - ["iof2971_008", operator.contains, [io.BufferedReader.__dict__,  "__floor__"], false]
    - ["iof2971_009", operator.contains, [io.BufferedWriter.__dict__,  "__floor__"], false]
    - ["iof2971_010", operator.contains, [io.BufferedRandom.__dict__,  "__floor__"], false]
    - ["iof2971_011", operator.contains, [io.TextIOWrapper.__dict__,   "__floor__"], false]

