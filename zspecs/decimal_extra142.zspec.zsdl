spec: decimal_extra142
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal predicate method __qualname__ values (is_nan, is_infinite, is_finite, is_signed, is_zero, is_normal, radix, number_class), Decimal copy/conversion method __qualname__ values (copy_abs, copy_negate, copy_sign, as_tuple, as_integer_ratio, to_integral_value, to_integral_exact), Decimal class identity (__name__, __module__, __doc__ len, MRO), and Decimal dunder methods not covered in decimal_extra140 (__format__, __reduce__, __copy__, __deepcopy__)."
    - "Previous specs covered: decimal_extra140 (Decimal arithmetic, comparison, conversion, higher-level method qualnames); decimal_extra141 (Context identity and method qualnames)."
    - "decimal.Decimal.__name__ == 'Decimal' (len=7); __module__ == 'decimal' (len=7); MRO length == 2 ([Decimal, object]); __doc__ len == 260."
    - "decimal.Decimal predicate qualname lengths: radix=13, is_nan=14, is_zero=15, is_finite/is_signed/is_normal=17, is_infinite=19."
    - "decimal.Decimal copy/conversion qualname lengths: copy_abs=16, as_tuple=16, copy_sign=17, is_signed=17, copy_negate=19, as_integer_ratio=24, to_integral_value=25 (tied with to_integral_exact for longest)."
    - "decimal.Decimal.__format__.__qualname__ == 'Decimal.__format__' (len=18); __reduce__=18 (tied); __copy__=16; __deepcopy__=20."
    - "decimal.Decimal.number_class.__qualname__ == 'Decimal.number_class' (len=20; tied with __deepcopy__ for a 20-character qualname)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal class identity
# __name__ == 'Decimal' (len=7); __module__ == 'decimal' (len=7).
# MRO length == 2 ([Decimal, object]); __doc__ len == 260.
# Not covered in decimal_extra140 or decimal_extra141.
# ---------------------------------------------------------------------------

table decimal_extra142.Decimal_class_identity:
  description: "decimal.Decimal class identity: __name__='Decimal' (7), __module__='decimal' (7), MRO length=2, __doc__ len=260"
  kind: python_call_eq
  category: class_identity
  id_prefix: decid142

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name_eq,    Decimal.__name__.__eq__,                    ["Decimal"], true, "decimal.Decimal.__name__ == 'Decimal'"]
    - [dec_name_len,   Decimal.__name__.__len__,                   [],          7,    "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters; the same length as 'Context' — both pathlib classes have 7-character names as noted in decimal_extra141)"]
    - [dec_qname_eq,   Decimal.__qualname__.__eq__,                ["Decimal"], true, "decimal.Decimal.__qualname__ == 'Decimal' (top-level class; qualname equals name)"]
    - [dec_module_eq,  Decimal.__module__.__eq__,                  ["decimal"], true, "decimal.Decimal.__module__ == 'decimal' (len=7; __module__ is 'decimal', the same length as __name__ 'Decimal' — both are 7 characters)"]
    - [dec_module_len, Decimal.__module__.__len__,                 [],          7,    "decimal.Decimal.__module__.__len__() == 7 ('decimal' has 7 characters)"]
    - [dec_cls_eq,     Decimal.__class__.__name__.__eq__,          ["type"],    true, "decimal.Decimal.__class__.__name__ == 'type' (Decimal is a regular class with the standard 'type' metaclass)"]
    - [dec_mro_len,    "Decimal.__mro__.__len__",                  [],          2,    "decimal.Decimal.__mro__.__len__() == 2 (MRO: [Decimal, object]; Decimal directly subclasses object with no intermediate types)"]
    - [dec_base0_eq,   "Decimal.__bases__[0].__name__.__eq__",     ["object"],  true, "decimal.Decimal.__bases__[0].__name__ == 'object' (Decimal directly subclasses object)"]
    - [dec_doc_cls,    Decimal.__doc__.__class__.__name__.__eq__,  ["str"],     true, "decimal.Decimal.__doc__ is a str (non-None; describes the constructor's 'value' parameter)"]
    - [dec_doc_len,    Decimal.__doc__.__len__,                    [],          260,  "decimal.Decimal.__doc__.__len__() == 260 (260 characters; describes that 'value' can be integer, string, tuple, or another Decimal; shorter than Context.__doc__ (406) from decimal_extra141)"]

# ---------------------------------------------------------------------------
# decimal.Decimal predicate method __qualname__ values and lengths
# All follow 'Decimal.<method>' pattern.
# radix=13, is_nan=14, is_zero=15, is_finite/is_signed/is_normal=17, is_infinite=19.
# number_class=20.
# ---------------------------------------------------------------------------

table decimal_extra142.Decimal_predicate_qualnames:
  description: "decimal.Decimal predicate method __qualname__ values: radix=13, is_nan=14, is_zero=15, is_finite/is_signed/is_normal=17, is_infinite=19, number_class=20"
  kind: python_call_eq
  category: qualname
  id_prefix: decid142

  columns: [id, function, args, expected, description]
  rows:
    - [radix_qeq,     Decimal.radix.__qualname__.__eq__,        ["Decimal.radix"],        true, "decimal.Decimal.radix.__qualname__ == 'Decimal.radix' (len=13; returns 10, the decimal radix; the shortest predicate method qualname)"]
    - [radix_qlen,    Decimal.radix.__qualname__.__len__,       [],                        13,   "decimal.Decimal.radix.__qualname__.__len__() == 13 ('Decimal.radix' has 13 characters; 'Decimal.' (8) + 'radix' (5) = 13)"]
    - [isnan_qeq,     Decimal.is_nan.__qualname__.__eq__,       ["Decimal.is_nan"],        true, "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (len=14; returns True if the Decimal is a NaN — quiet or signaling)"]
    - [isnan_qlen,    Decimal.is_nan.__qualname__.__len__,      [],                        14,   "decimal.Decimal.is_nan.__qualname__.__len__() == 14 ('Decimal.is_nan' has 14 characters)"]
    - [iszero_qeq,    Decimal.is_zero.__qualname__.__eq__,      ["Decimal.is_zero"],       true, "decimal.Decimal.is_zero.__qualname__ == 'Decimal.is_zero' (len=15; returns True if the value is zero)"]
    - [iszero_qlen,   Decimal.is_zero.__qualname__.__len__,     [],                        15,   "decimal.Decimal.is_zero.__qualname__.__len__() == 15 ('Decimal.is_zero' has 15 characters)"]
    - [isfinite_qeq,  Decimal.is_finite.__qualname__.__eq__,    ["Decimal.is_finite"],     true, "decimal.Decimal.is_finite.__qualname__ == 'Decimal.is_finite' (len=17; returns True if the value is finite — not infinity or NaN)"]
    - [isfinite_qlen, Decimal.is_finite.__qualname__.__len__,   [],                        17,   "decimal.Decimal.is_finite.__qualname__.__len__() == 17 ('Decimal.is_finite' has 17 characters; tied with is_signed and is_normal)"]
    - [issigned_qeq,  Decimal.is_signed.__qualname__.__eq__,    ["Decimal.is_signed"],     true, "decimal.Decimal.is_signed.__qualname__ == 'Decimal.is_signed' (len=17; returns True if the sign bit is set; tied with is_finite and is_normal)"]
    - [isnormal_qeq,  Decimal.is_normal.__qualname__.__eq__,    ["Decimal.is_normal"],     true, "decimal.Decimal.is_normal.__qualname__ == 'Decimal.is_normal' (len=17; returns True if the value is normal — finite, nonzero, not subnormal; tied with is_finite and is_signed)"]
    - [isinf_qeq,     Decimal.is_infinite.__qualname__.__eq__,  ["Decimal.is_infinite"],   true, "decimal.Decimal.is_infinite.__qualname__ == 'Decimal.is_infinite' (len=19; returns True if the value is positive or negative infinity)"]
    - [isinf_qlen,    Decimal.is_infinite.__qualname__.__len__, [],                        19,   "decimal.Decimal.is_infinite.__qualname__.__len__() == 19 ('Decimal.is_infinite' has 19 characters; 'is_infinite' at 11 chars is the longest predicate name)"]
    - [numcls_qeq,    Decimal.number_class.__qualname__.__eq__, ["Decimal.number_class"],  true, "decimal.Decimal.number_class.__qualname__ == 'Decimal.number_class' (len=20; returns a string describing the class of the number: 'sNaN', 'NaN', '-Infinity', etc.)"]
    - [numcls_qlen,   Decimal.number_class.__qualname__.__len__,[],                        20,   "decimal.Decimal.number_class.__qualname__.__len__() == 20 ('Decimal.number_class' has 20 characters; the longest predicate method qualname)"]

