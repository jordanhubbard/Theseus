table decimal_extra142.Decimal_copy_conversion_qualnames:
  description: "decimal.Decimal copy/conversion method __qualname__ values: copy_abs/as_tuple=16, copy_sign=17, copy_negate=19, as_integer_ratio=24, to_integral_value/to_integral_exact=25"
  kind: python_call_eq
  category: qualname
  id_prefix: decid142

  columns: [id, function, args, expected, description]
  rows:
    - [cabs_qeq,      Decimal.copy_abs.__qualname__.__eq__,          ["Decimal.copy_abs"],          true, "decimal.Decimal.copy_abs.__qualname__ == 'Decimal.copy_abs' (len=16; returns a copy of the Decimal with its sign set to positive)"]
    - [cabs_qlen,     Decimal.copy_abs.__qualname__.__len__,         [],                             16,   "decimal.Decimal.copy_abs.__qualname__.__len__() == 16 ('Decimal.copy_abs' has 16 characters; tied with as_tuple)"]
    - [astup_qeq,     Decimal.as_tuple.__qualname__.__eq__,          ["Decimal.as_tuple"],           true, "decimal.Decimal.as_tuple.__qualname__ == 'Decimal.as_tuple' (len=16; returns a named tuple (sign, digits, exponent); tied with copy_abs)"]
    - [astup_qlen,    Decimal.as_tuple.__qualname__.__len__,         [],                             16,   "decimal.Decimal.as_tuple.__qualname__.__len__() == 16 (tied with copy_abs at 16)"]
    - [csign_qeq,     Decimal.copy_sign.__qualname__.__eq__,         ["Decimal.copy_sign"],          true, "decimal.Decimal.copy_sign.__qualname__ == 'Decimal.copy_sign' (len=17; returns a copy with the sign taken from the second operand)"]
    - [csign_qlen,    Decimal.copy_sign.__qualname__.__len__,        [],                             17,   "decimal.Decimal.copy_sign.__qualname__.__len__() == 17 ('Decimal.copy_sign' has 17 characters)"]
    - [cneg_qeq,      Decimal.copy_negate.__qualname__.__eq__,       ["Decimal.copy_negate"],        true, "decimal.Decimal.copy_negate.__qualname__ == 'Decimal.copy_negate' (len=19; returns a copy of the Decimal with its sign inverted)"]
    - [cneg_qlen,     Decimal.copy_negate.__qualname__.__len__,      [],                             19,   "decimal.Decimal.copy_negate.__qualname__.__len__() == 19 ('Decimal.copy_negate' has 19 characters)"]
    - [airatio_qeq,   Decimal.as_integer_ratio.__qualname__.__eq__,  ["Decimal.as_integer_ratio"],   true, "decimal.Decimal.as_integer_ratio.__qualname__ == 'Decimal.as_integer_ratio' (len=24; returns a pair (n, d) of integers such that n/d == Decimal value)"]
    - [airatio_qlen,  Decimal.as_integer_ratio.__qualname__.__len__, [],                             24,   "decimal.Decimal.as_integer_ratio.__qualname__.__len__() == 24 ('Decimal.as_integer_ratio' has 24 characters)"]
    - [tointv_qeq,    Decimal.to_integral_value.__qualname__.__eq__, ["Decimal.to_integral_value"],  true, "decimal.Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' (len=25; rounds to nearest integer using current context rounding; longest Decimal method qualname)"]
    - [tointv_qlen,   Decimal.to_integral_value.__qualname__.__len__,[],                             25,   "decimal.Decimal.to_integral_value.__qualname__.__len__() == 25 ('Decimal.to_integral_value' has 25 characters; tied with to_integral_exact)"]
    - [tointe_qeq,    Decimal.to_integral_exact.__qualname__.__eq__, ["Decimal.to_integral_exact"],  true, "decimal.Decimal.to_integral_exact.__qualname__ == 'Decimal.to_integral_exact' (len=25; like to_integral_value but also signals Inexact/Rounded if rounding occurs; tied for longest)"]
    - [tointe_qlen,   Decimal.to_integral_exact.__qualname__.__len__,[],                             25,   "decimal.Decimal.to_integral_exact.__qualname__.__len__() == 25 (tied with to_integral_value at 25; both are the longest Decimal method qualnames)"]

