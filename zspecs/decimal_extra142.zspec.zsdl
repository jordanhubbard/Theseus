# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra142.Decimal.mro_len_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 (MRO: [Decimal, object]; Decimal directly subclasses object with no intermediate types; this flat MRO is the same as decimal.Context.__mro__ (len=2) from decimal_extra141, both having only two entries)"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__mro__.__len__"
  args: []
  expected: 2

invariant decimal_extra142.Decimal.doc_len_260:
  description: "decimal.Decimal.__doc__.__len__() == 260 (the Decimal class docstring is 260 characters; shorter than decimal.Context.__doc__ (406 from decimal_extra141); describes that the 'value' constructor parameter can be an integer, string, tuple, or another Decimal)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__doc__.__len__
  args: []
  expected: 260

invariant decimal_extra142.Decimal.to_integral_value_qualname_len_25:
  description: "decimal.Decimal.to_integral_value.__qualname__.__len__() == 25 ('Decimal.to_integral_value' has 25 characters; the longest Decimal method qualname — 'Decimal.' (8) + 'to_integral_value' (17) = 25; this exceeds to_integral from decimal_extra140 (len=19), which is the shorter alias)"
  category: qualname
  kind: python_call_eq
  function: Decimal.to_integral_value.__qualname__.__len__
  args: []
  expected: 25

invariant decimal_extra142.Decimal.is_infinite_qualname_len_19:
  description: "decimal.Decimal.is_infinite.__qualname__.__len__() == 19 ('Decimal.is_infinite' has 19 characters; the longest predicate method qualname — 'Decimal.' (8) + 'is_infinite' (11) = 19; longer than is_finite/is_signed/is_normal (17) by 2 characters)"
  category: qualname
  kind: python_call_eq
  function: Decimal.is_infinite.__qualname__.__len__
  args: []
  expected: 19

invariant decimal_extra142.Decimal.radix_qualname_len_13:
  description: "decimal.Decimal.radix.__qualname__.__len__() == 13 ('Decimal.radix' has 13 characters; the shortest predicate method qualname; radix() returns 10, which is the mathematical radix of the decimal number system)"
  category: qualname
  kind: python_call_eq
  function: Decimal.radix.__qualname__.__len__
  args: []
  expected: 13

invariant decimal_extra142.Decimal.__format__qualname_eq:
  description: "decimal.Decimal.__format__.__qualname__ == 'Decimal.__format__' (len=18) — Decimal implements __format__ to support the full decimal format spec (e.g., 'f', 'e', 'g', 'E', 'n' types, sign, width, precision, grouping); the same 18-character length as __reduce__ (both have 8-character method names: 'format' + 6 chars vs 'reduce' + 6 chars, plus the double-underscore wrapping)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__format__.__qualname__.__eq__
  args: ["Decimal.__format__"]
  expected: true

invariant decimal_extra142.Decimal.copy_negate_qualname_len_19:
  description: "decimal.Decimal.copy_negate.__qualname__.__len__() == 19 ('Decimal.copy_negate' has 19 characters; 'Decimal.' (8) + 'copy_negate' (11) = 19; copy_negate returns a copy with the sign bit flipped, i.e. positive becomes negative and vice versa)"
  category: qualname
  kind: python_call_eq
  function: Decimal.copy_negate.__qualname__.__len__
  args: []
  expected: 19

invariant decimal_extra142.Decimal.as_integer_ratio_qualname_len_24:
  description: "decimal.Decimal.as_integer_ratio.__qualname__.__len__() == 24 ('Decimal.as_integer_ratio' has 24 characters; 'Decimal.' (8) + 'as_integer_ratio' (16) = 24; as_integer_ratio returns a pair of integers (numerator, denominator) such that their ratio exactly equals the Decimal value)"
  category: qualname
  kind: python_call_eq
  function: Decimal.as_integer_ratio.__qualname__.__len__
  args: []
  expected: 24

