    - [copy_qeq,      Decimal.__copy__.__qualname__.__eq__,      ["Decimal.__copy__"],      true, "decimal.Decimal.__copy__.__qualname__ == 'Decimal.__copy__' (len=16; implements copy.copy(); returns a shallow copy of the Decimal)"]
    - [copy_qlen,     Decimal.__copy__.__qualname__.__len__,     [],                         16,   "decimal.Decimal.__copy__.__qualname__.__len__() == 16 ('Decimal.__copy__' has 16 characters; tied with copy_abs and as_tuple in the len=16 group)"]
