spec: xss
version: ">=1.0.0"
backend: node(xss)

docs: https://www.npmjs.com/package/xss

provenance:
  derived_from:
    - "xss README — https://www.npmjs.com/package/xss"
    - "Test vectors verified with xss via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "xss source"
  notes:
    - "xss is an npm package. Install: npm install xss"
    - "xss(str) sanitizes HTML, removing dangerous tags/attributes."
    - "Script tags are escaped; safe tags like <b> are passed through; javascript: href is stripped."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sanitized HTML string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table xss.sanitize:
  kind: node_module_call_eq
  function: ~
  category: sanitize
  id_prefix: xss

  columns: [id, args, expected]
  rows:
    - [script,  ["<script>alert(1)</script>Hello"],
       "&lt;script&gt;alert(1)&lt;/script&gt;Hello"]
    - [bold,    ["<b>bold</b>"],           "<b>bold</b>"]
    - [js_href, ["<a href=\"javascript:void(0)\">click</a>"],
       "<a href>click</a>"]
