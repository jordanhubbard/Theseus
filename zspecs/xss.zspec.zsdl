spec: xss
version: ">=1.0.0"
backend: node(xss)

docs: https://github.com/leizongmin/js-xss#readme

provenance:
  derived_from:
    - "xss README — https://github.com/leizongmin/js-xss#readme"
    - "Test vectors verified with xss@1.0.15 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "xss source"
  notes:
    - "xss exports the filterXSS function directly as module.exports."
    - "filterXSS(html) sanitizes HTML by escaping dangerous tags and attributes."
    - "Safe tags like <b> and <i> are preserved; <script> and <iframe> are escaped."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sanitized HTML string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table xss.sanitize:
  kind: node_module_call_eq
  function: ~
  category: sanitize
  id_prefix: xss

  columns: [id, args, expected]
  rows:
    - [safe,    ["hello"],                                "hello"]
    - [script,  ["<script>alert(1)</script>hello"],       "&lt;script&gt;alert(1)&lt;/script&gt;hello"]
    - [bold,    ["<b>hello</b>"],                         "<b>hello</b>"]
