spec: decimal_extra117
version: ">=3.9"
backend: python_module(_pydecimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra116.zspec.zsdl."
    - "This spec covers: _pydecimal.Context.__init__.__code__ and Context.create_decimal.__code__ co_varnames elements not yet covered."
    - "decimal.Context is a C extension type (no __code__); _pydecimal.Context is the pure Python reference implementation with full code objects."
    - "No prior decimal_extra spec has asserted any attribute of Context.__init__.__code__ or Context.create_decimal.__code__."
    - "_pydecimal.Context.__init__.__code__.co_varnames: ('self','prec','rounding','Emin','Emax','capitals','clamp','flags','traps','_ignored_flags','dc') — 11 entries."
    - "_pydecimal.Context.__init__.__code__.co_argcount == 10 (9 keyword parameters plus 'self'; excludes the local variable 'dc')."
    - "_pydecimal.Context.__init__.__code__.co_varnames[0] == 'self' (len 4)."
    - "_pydecimal.Context.__init__.__code__.co_varnames[1] == 'prec' (len 4)."
    - "_pydecimal.Context.__init__.__code__.co_varnames[2] == 'rounding' (len 8)."
    - "_pydecimal.Context.__init__.__code__.co_varnames[9] == '_ignored_flags' (len 14); longest varname."
    - "_pydecimal.Context.__init__.__code__.co_varnames[10] == 'dc' (len 2); shortest varname; a local temp for DefaultContext."
    - "_pydecimal.Context.create_decimal.__code__.co_argcount == 2 (self, num)."
    - "_pydecimal.Context.create_decimal.__code__.co_varnames[0] == 'self' (len 4)."
    - "_pydecimal.Context.create_decimal.__code__.co_varnames[1] == 'num' (len 3)."
    - "_pydecimal.Context.create_decimal.__code__.co_varnames[2] == 'd' (len 1); local Decimal temp."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _pydecimal.Context.__init__.__code__.co_varnames[0], [1], [2], [9], [10]
# co_varnames[0] == 'self' (4 chars) — the Context instance being initialized.
# co_varnames[1] == 'prec' (4 chars) — precision parameter (number of significant digits).
# co_varnames[2] == 'rounding' (8 chars) — rounding mode parameter.
# co_varnames[9] == '_ignored_flags' (14 chars) — longest varname; internal trap tracking.
# co_varnames[10] == 'dc' (2 chars) — shortest varname; temp for copying DefaultContext.
# co_argcount == 10 — self plus 9 keyword parameters (prec through _ignored_flags).
# co_varnames.__len__() == 11 — 10 parameters plus local 'dc'.
# No prior decimal_extra spec has asserted any attribute of Context.__init__.__code__.
# ---------------------------------------------------------------------------

table decimal_extra117.Context_init_code_varnames:
  description: "_pydecimal.Context.__init__.__code__.co_varnames[0]=='self'(4); [1]=='prec'(4); [2]=='rounding'(8); [9]=='_ignored_flags'(14); [10]=='dc'(2); co_argcount==10; co_varnames.__len__()==11; all assertions novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: decctxinit117a

  columns: [id, function, args, expected, description]
  rows:
    - [cv0_eq,        "Context.__init__.__code__.co_varnames[0].__eq__",    ["self"],            true,  "_pydecimal.Context.__init__.__code__.co_varnames[0] == 'self' (4 chars; the Context instance being initialized; first parameter of every Python __init__ method)"]
    - [cv0_len,       "Context.__init__.__code__.co_varnames[0].__len__",   [],                  4,     "_pydecimal.Context.__init__.__code__.co_varnames[0].__len__() == 4 ('self' has 4 characters)"]
    - [cv1_eq,        "Context.__init__.__code__.co_varnames[1].__eq__",    ["prec"],            true,  "_pydecimal.Context.__init__.__code__.co_varnames[1] == 'prec' (4 chars; the precision parameter specifying the number of significant decimal digits in arithmetic results)"]
    - [cv1_len,       "Context.__init__.__code__.co_varnames[1].__len__",   [],                  4,     "_pydecimal.Context.__init__.__code__.co_varnames[1].__len__() == 4 ('prec' has 4 characters; same length as 'self' at position 0)"]
    - [cv2_eq,        "Context.__init__.__code__.co_varnames[2].__eq__",    ["rounding"],        true,  "_pydecimal.Context.__init__.__code__.co_varnames[2] == 'rounding' (8 chars; controls how results are rounded when more digits than the precision allows are produced)"]
    - [cv2_len,       "Context.__init__.__code__.co_varnames[2].__len__",   [],                  8,     "_pydecimal.Context.__init__.__code__.co_varnames[2].__len__() == 8 ('rounding' has 8 characters; longest of the first three co_varnames entries)"]
    - [cv9_eq,        "Context.__init__.__code__.co_varnames[9].__eq__",    ["_ignored_flags"],  true,  "_pydecimal.Context.__init__.__code__.co_varnames[9] == '_ignored_flags' (14 chars; internal parameter tracking which signals are suppressed during nested context operations)"]
    - [cv9_len,       "Context.__init__.__code__.co_varnames[9].__len__",   [],                  14,    "_pydecimal.Context.__init__.__code__.co_varnames[9].__len__() == 14 ('_ignored_flags' has 14 characters; the longest variable name in Context.__init__)"]

# ---------------------------------------------------------------------------
# _pydecimal.Context.__init__.__code__ co_varnames[10], co_argcount, co_varnames.__len__()
# co_varnames[10] == 'dc' (2 chars) — local variable for copying DefaultContext.
# co_argcount == 10 — 'self' plus 9 keyword parameters; 'dc' is local, not a parameter.
# co_varnames.__len__() == 11 — 10 parameters (indices 0-9) plus local 'dc' (index 10).
# ---------------------------------------------------------------------------

table decimal_extra117.Context_init_code_argcount_and_last:
  description: "_pydecimal.Context.__init__.__code__.co_varnames[10]=='dc'(2); co_argcount==10; co_varnames.__len__()==11; 'dc' is a local temp not a parameter; argcount(10) == varnames.__len__()(11) - 1; all assertions novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: decctxinit117b

  columns: [id, function, args, expected, description]
  rows:
    - [cv10_eq,       "Context.__init__.__code__.co_varnames[10].__eq__",   ["dc"],              true,  "_pydecimal.Context.__init__.__code__.co_varnames[10] == 'dc' (2 chars; a local variable that holds a copy of DefaultContext when no arguments are supplied to Context())"]
    - [cv10_len,      "Context.__init__.__code__.co_varnames[10].__len__",  [],                  2,     "_pydecimal.Context.__init__.__code__.co_varnames[10].__len__() == 2 ('dc' has 2 characters; the shortest variable name in Context.__init__)"]
    - [argcount_10,   "Context.__init__.__code__.co_argcount.__eq__",       [10],                true,  "_pydecimal.Context.__init__.__code__.co_argcount == 10 (self plus 9 keyword parameters: prec, rounding, Emin, Emax, capitals, clamp, flags, traps, _ignored_flags; 'dc' at index 10 is a local variable, not counted in co_argcount)"]
    - [varnames_11,   "Context.__init__.__code__.co_varnames.__len__",      [],                  11,    "_pydecimal.Context.__init__.__code__.co_varnames.__len__() == 11 (10 parameters at indices 0-9, plus the local variable 'dc' at index 10)"]
    - [cv10_lt_cv0,   "Context.__init__.__code__.co_varnames[10].__len__.__lt__", [4],           true,  "len('dc') < len('self') (2 < 4; the last local variable 'dc' is shorter than the first parameter 'self')"]
    - [cv9_gt_cv2,    "Context.__init__.__code__.co_varnames[9].__len__.__gt__", [8],            true,  "len('_ignored_flags') > len('rounding') (14 > 8; '_ignored_flags' at index 9 is the longest varname; 'rounding' at index 2 is second longest)"]
    - [argcount_gt_1, "Context.__init__.__code__.co_argcount.__gt__",       [9],                 true,  "_pydecimal.Context.__init__.__code__.co_argcount > 9 (10 > 9; Context.__init__ accepts more formal parameters than any typical class __init__ due to the many arithmetic context parameters)"]
    - [varnames_gt_argcount, "Context.__init__.__code__.co_varnames.__len__.__gt__", [10],       true,  "co_varnames.__len__() > co_argcount (11 > 10; the local variable 'dc' at index 10 is not a parameter so varnames count exceeds argcount by exactly 1)"]

# ---------------------------------------------------------------------------
# _pydecimal.Context.create_decimal.__code__ co_varnames and co_argcount
# co_varnames[0] == 'self' (4 chars) — the Context instance.
# co_varnames[1] == 'num' (3 chars) — the number argument to convert to Decimal.
# co_varnames[2] == 'd' (1 char) — local Decimal temp; shortest possible varname.
# co_argcount == 2 — self and num; 'd' is a local temp, not a parameter.
# co_varnames.__len__() == 3 — two parameters plus one local.
# No prior decimal_extra spec has asserted any attribute of Context.create_decimal.__code__.
# ---------------------------------------------------------------------------

table decimal_extra117.Context_create_decimal_code_varnames:
  description: "_pydecimal.Context.create_decimal.__code__.co_varnames[0]=='self'(4); [1]=='num'(3); [2]=='d'(1); co_argcount==2; co_varnames.__len__()==3; 'd' is shortest possible varname (1 char); all assertions novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: decctxcd117c

  columns: [id, function, args, expected, description]
  rows:
    - [cd_cv0_eq,     "Context.create_decimal.__code__.co_varnames[0].__eq__",   ["self"],  true,  "_pydecimal.Context.create_decimal.__code__.co_varnames[0] == 'self' (4 chars; the Context instance whose settings govern the decimal conversion)"]
    - [cd_cv0_len,    "Context.create_decimal.__code__.co_varnames[0].__len__",  [],         4,     "_pydecimal.Context.create_decimal.__code__.co_varnames[0].__len__() == 4 ('self' has 4 characters)"]
    - [cd_cv1_eq,     "Context.create_decimal.__code__.co_varnames[1].__eq__",   ["num"],   true,  "_pydecimal.Context.create_decimal.__code__.co_varnames[1] == 'num' (3 chars; the number argument to be converted to a Decimal using the context's precision and rounding settings)"]
    - [cd_cv1_len,    "Context.create_decimal.__code__.co_varnames[1].__len__",  [],         3,     "_pydecimal.Context.create_decimal.__code__.co_varnames[1].__len__() == 3 ('num' has 3 characters; 1 char shorter than 'self')"]
    - [cd_cv2_eq,     "Context.create_decimal.__code__.co_varnames[2].__eq__",   ["d"],     true,  "_pydecimal.Context.create_decimal.__code__.co_varnames[2] == 'd' (1 char; a local variable holding the Decimal object during construction; the shortest possible Python variable name)"]
    - [cd_cv2_len,    "Context.create_decimal.__code__.co_varnames[2].__len__",  [],         1,     "_pydecimal.Context.create_decimal.__code__.co_varnames[2].__len__() == 1 ('d' has 1 character; shorter than all other variables in both create_decimal and Context.__init__)"]
    - [cd_argcount,   "Context.create_decimal.__code__.co_argcount.__eq__",      [2],       true,  "_pydecimal.Context.create_decimal.__code__.co_argcount == 2 (self and num are the two formal positional parameters; 'd' at index 2 is a local variable not counted in co_argcount)"]
    - [cd_varnames_3, "Context.create_decimal.__code__.co_varnames.__len__",     [],         3,     "_pydecimal.Context.create_decimal.__code__.co_varnames.__len__() == 3 (two parameters plus one local variable; far simpler than Context.__init__ which has 11 co_varnames)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra117.Context_init_cv1_prec:
  description: "_pydecimal.Context.__init__.__code__.co_varnames[1] == 'prec' (4 chars; 'prec' is the first keyword argument to Context.__init__ and controls the number of significant decimal digits in arithmetic results; the default precision in a new Context is 28, matching IEEE 754 decimal128; 'prec' at index 1 immediately follows 'self' at index 0; no prior decimal_extra spec has asserted any attribute of Context.__init__.__code__; _pydecimal is the pure Python fallback implementation accessed via python_module(_pydecimal)); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "Context.__init__.__code__.co_varnames[1].__eq__"
  args: ["prec"]
  expected: true

invariant decimal_extra117.Context_init_cv9_ignored_flags:
  description: "_pydecimal.Context.__init__.__code__.co_varnames[9] == '_ignored_flags' (14 chars; '_ignored_flags' is an internal parameter at index 9 that tracks which exception flags are suppressed during nested context operations; it has a leading underscore indicating it is private to the implementation; with 14 characters it is the longest variable name in Context.__init__; no prior decimal_extra spec has asserted co_varnames[9] or any attribute of Context.__init__.__code__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "Context.__init__.__code__.co_varnames[9].__eq__"
  args: ["_ignored_flags"]
  expected: true

invariant decimal_extra117.Context_init_co_argcount_10:
  description: "_pydecimal.Context.__init__.__code__.co_argcount == 10 (10 formal positional parameters: self plus prec, rounding, Emin, Emax, capitals, clamp, flags, traps, _ignored_flags; the local variable 'dc' at co_varnames[10] is not a parameter and is therefore not included in co_argcount; this makes Context.__init__ one of the most parameter-rich __init__ methods in the Python standard library, reflecting the many configurable dimensions of IEEE 754 decimal arithmetic; no prior decimal_extra spec has asserted co_argcount for any Context method); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: Context.__init__.__code__.co_argcount.__eq__
  args: [10]
  expected: true

invariant decimal_extra117.Context_create_decimal_cv2_d:
  description: "_pydecimal.Context.create_decimal.__code__.co_varnames[2] == 'd' (1 char; 'd' is the shortest possible Python identifier; it is a local variable holding the Decimal object being constructed during create_decimal; create_decimal converts a number (integer, string, tuple, or another Decimal) into a Decimal under the context's arithmetic settings; the 1-char name reflects a common convention for temporary Decimal variables in _pydecimal.py; no prior decimal_extra spec has asserted any attribute of Context.create_decimal.__code__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "Context.create_decimal.__code__.co_varnames[2].__eq__"
  args: ["d"]
  expected: true

invariant decimal_extra117.Context_create_decimal_co_argcount_2:
  description: "_pydecimal.Context.create_decimal.__code__.co_argcount == 2 (two formal positional parameters: 'self' at index 0 and 'num' at index 1; the local variable 'd' at index 2 is not a parameter and is not counted; co_argcount(2) is much smaller than Context.__init__'s co_argcount(10) reflecting that create_decimal is a simple conversion method while __init__ configures many arithmetic properties; no prior decimal_extra spec has asserted co_argcount for Context.create_decimal); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: Context.create_decimal.__code__.co_argcount.__eq__
  args: [2]
  expected: true

