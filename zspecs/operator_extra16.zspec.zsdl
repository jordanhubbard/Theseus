spec: operator_extra16
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra15.zspec.zsdl."
    - "operator_extra15 covers: __name__.__len__ for add(3), truediv(7), floordiv(8), pow(3), mod(3), eq(2), truth(5), not_(4), itemgetter(10), attrgetter(10), methodcaller(12), contains(8); __module__.__len__ for add(9) and itemgetter/attrgetter(8)."
    - "operator_extra10 covers: invert.__qualname__.__eq__('invert'); is_not.__qualname__.__eq__('is_not'); __name__.__len__ for imatmul(7)/ifloordiv(8)/length_hint(11)."
    - "operator_extra9 covers: and_/__name__.__eq__; or_/__name__.__eq__ as standalone invariants."
    - "operator_extra12 covers: xor/__name__.__eq__."
    - "operator_extra14 covers: truth/__name__.__eq__; not_/__name__.__eq__; index/__name__.__eq__."
    - "No prior operator spec records __name__.__len__() for and_, or_, xor, invert, lshift, rshift, is_, is_not, not_. (extra15 covers not_(4) — skip. extra14 covers not_ __name__.__eq__ only.)"
    - "Wait: extra15 covers not_.__name__.__len__ == 4. Do not duplicate. Focus on and_, or_, xor, invert, lshift, rshift, is_, is_not, concat, index."
    - "Name lengths: and_==4, or_==3, xor==3, invert==6, lshift==6, rshift==6, is_==3, is_not==6, concat==6, index==5."
    - "No prior operator spec records __qualname__.__len__() for and_, or_, xor, invert, lshift, rshift, is_, is_not."
    - "operator_extra13 covers __qualname__.__eq__ for arithmetic ops; extra10 covers invert/is_not __qualname__.__eq__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for bitwise operators not yet measured
#
# operator_extra15 covers __name__.__len__ for arithmetic and logical operators
# (add, truediv, floordiv, pow, mod, eq, truth, not_). No prior spec records
# __name__.__len__() for and_, or_, xor, invert, lshift, rshift, is_, or is_not.
# and_==4, or_==3, xor==3, invert==6, lshift==6, rshift==6, is_==3, is_not==6.
# ---------------------------------------------------------------------------

invariant operator_extra16.and_.name_len:
  description: "operator.and_.__name__.__len__() == 4 — len('and_')"
  category: name_lengths
  kind: python_call_eq
  function: and_.__name__.__len__
  args: []
  expected: 4

invariant operator_extra16.or_.name_len:
  description: "operator.or_.__name__.__len__() == 3 — len('or_')"
  category: name_lengths
  kind: python_call_eq
  function: or_.__name__.__len__
  args: []
  expected: 3

invariant operator_extra16.xor.name_len:
  description: "operator.xor.__name__.__len__() == 3 — len('xor')"
  category: name_lengths
  kind: python_call_eq
  function: xor.__name__.__len__
  args: []
  expected: 3

invariant operator_extra16.invert.name_len:
  description: "operator.invert.__name__.__len__() == 6 — len('invert')"
  category: name_lengths
  kind: python_call_eq
  function: invert.__name__.__len__
  args: []
  expected: 6

invariant operator_extra16.lshift.name_len:
  description: "operator.lshift.__name__.__len__() == 6 — len('lshift')"
  category: name_lengths
  kind: python_call_eq
  function: lshift.__name__.__len__
  args: []
  expected: 6

invariant operator_extra16.rshift.name_len:
  description: "operator.rshift.__name__.__len__() == 6 — len('rshift')"
  category: name_lengths
  kind: python_call_eq
  function: rshift.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# __name__.__len__() for identity and sequence operators not yet measured
#
# No prior operator spec records __name__.__len__() for is_, is_not, concat,
# or index. operator_extra14 covers index/__name__/__eq__ (string equality only).
# is_==3, is_not==6, concat==6, index==5.
# ---------------------------------------------------------------------------

invariant operator_extra16.is_.name_len:
  description: "operator.is_.__name__.__len__() == 3 — len('is_')"
  category: name_lengths
  kind: python_call_eq
  function: is_.__name__.__len__
  args: []
  expected: 3

invariant operator_extra16.is_not.name_len:
  description: "operator.is_not.__name__.__len__() == 6 — len('is_not')"
  category: name_lengths
  kind: python_call_eq
  function: is_not.__name__.__len__
  args: []
  expected: 6

invariant operator_extra16.concat.name_len:
  description: "operator.concat.__name__.__len__() == 6 — len('concat')"
  category: name_lengths
  kind: python_call_eq
  function: concat.__name__.__len__
  args: []
  expected: 6

invariant operator_extra16.index.name_len:
  description: "operator.index.__name__.__len__() == 5 — len('index')"
  category: name_lengths
  kind: python_call_eq
  function: index.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __qualname__.__len__() for bitwise and identity operators
#
# No prior operator spec records __qualname__.__len__() for and_, or_, xor,
# invert, lshift, rshift, is_, or is_not. For C-level module-scope functions
# __qualname__ == __name__, so their lengths are identical to __name__.__len__.
# operator_extra13 covers __qualname__.__eq__ for arithmetic operators.
# operator_extra10 covers invert/__qualname__.__eq__ and is_not/__qualname__.__eq__.
# These __qualname__.__len__ checks provide a second behavioral axis.
# ---------------------------------------------------------------------------

invariant operator_extra16.and_.qualname_len:
  description: "operator.and_.__qualname__.__len__() == 4 — len('and_')"
  category: qualname_lengths
  kind: python_call_eq
  function: and_.__qualname__.__len__
  args: []
  expected: 4

invariant operator_extra16.lshift.qualname_len:
  description: "operator.lshift.__qualname__.__len__() == 6 — len('lshift')"
  category: qualname_lengths
  kind: python_call_eq
  function: lshift.__qualname__.__len__
  args: []
  expected: 6

invariant operator_extra16.is_not.qualname_len:
  description: "operator.is_not.__qualname__.__len__() == 6 — len('is_not')"
  category: qualname_lengths
  kind: python_call_eq
  function: is_not.__qualname__.__len__
  args: []
  expected: 6
