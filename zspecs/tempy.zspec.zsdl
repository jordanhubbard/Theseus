spec: tempy
version: ">=3.0.0"
backend: node(tempy)
esm: true

docs: https://github.com/sindresorhus/tempy#readme

provenance:
  derived_from:
    - "tempy README — https://github.com/sindresorhus/tempy#readme"
    - "Test vectors verified with tempy via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tempy source"
  notes:
    - "Get a unique temporary file or directory path — wraps os.tmpdir() with random suffix."
    - "Install: npm install tempy"
    - "v3 ESM only; named exports temporaryFile / temporaryDirectory / rootTemporaryDirectory / temporaryFileTask / temporaryDirectoryTask / temporaryWrite / temporaryWriteSync."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; never throw."
  stderr: "null"
  stickiness: "Each call returns a fresh path under os.tmpdir()."
  codes: {}

invariant tempy.has_temporaryFile:
  description: "temporaryFile is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "temporaryFile.constructor.name"}
  expected: "Function"

invariant tempy.has_temporaryDirectory:
  description: "temporaryDirectory is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "temporaryDirectory.constructor.name"}
  expected: "Function"

invariant tempy.rootTemporaryDirectory_is_string:
  description: "rootTemporaryDirectory is a String constant"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "rootTemporaryDirectory.constructor.name"}
  expected: "String"

invariant tempy.has_temporaryWrite:
  description: "temporaryWrite (async) is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "temporaryWrite.constructor.name"}
  expected: "AsyncFunction"

invariant tempy.has_temporaryWriteSync:
  description: "temporaryWriteSync is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "temporaryWriteSync.constructor.name"}
  expected: "Function"

invariant tempy.has_temporaryFileTask:
  description: "temporaryFileTask wrapper is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "temporaryFileTask.constructor.name"}
  expected: "AsyncFunction"

invariant tempy.temporaryFile_returns_string:
  description: "temporaryFile() returns a String path"
  category: usage
  kind: node_chain_eq
  entry: named
  function: temporaryFile
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"

invariant tempy.temporaryDirectory_returns_string:
  description: "temporaryDirectory() returns a String path"
  category: usage
  kind: node_chain_eq
  entry: named
  function: temporaryDirectory
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"

invariant tempy.temporaryFile_extension_option:
  description: "{extension: 'txt'} appends .txt to the path"
  category: usage
  kind: node_chain_eq
  entry: named
  function: temporaryFile
  entry_args: [{extension: "txt"}]
  chain:
    - {method: endsWith, args: [".txt"]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:30:13Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
