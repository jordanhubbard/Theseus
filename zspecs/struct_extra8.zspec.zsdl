spec: struct_extra8
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct.zspec.zsdl — pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize; roundtrip; error cases."
    - "struct_extra.zspec.zsdl — Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
    - "struct_extra2.zspec.zsdl — function __name__/__module__ (reported as 'struct', actual is '_struct'); pack(>H,256); unpack(>H); calcsize(>HHH); Struct base."
    - "struct_extra3.zspec.zsdl — pack/unpack/calcsize for !f/!d/!?; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra4.zspec.zsdl — Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__; pack(>I,65536)/(<I,65536)/(>i,-256); calcsize(>i/<i/>I)."
    - "struct_extra5.zspec.zsdl — Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255); unpack('>B',xff); calcsize('>B'/'<B'/'>5s'); Struct('>I').pack(256)."
    - "struct_extra6.zspec.zsdl — pack/unpack('>b',127/-128); Struct('>b'/'>Q') format/size; pack/calcsize('<h'); unpack('<h')."
    - "struct_extra7.zspec.zsdl — pack/unpack/calcsize for '>l'/'>L'/'=H'/'>2B'; Struct('>l') format/size."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior struct spec."
    - "struct.pack.__module__ == '_struct' — pack is a builtin_function_or_method from the C extension _struct; struct_extra2 notes incorrectly said 'struct', actual value is '_struct'."
    - "struct.unpack.__module__ == '_struct' — same C extension provenance."
    - "struct.pack_into.__module__ == '_struct' — C extension function."
    - "struct.unpack_from.__module__ == '_struct' — C extension function."
    - "struct.iter_unpack.__module__ == '_struct' — C extension function."
    - "struct.calcsize.__module__ == '_struct' — C extension function."
    - "struct.error.__module__ == 'struct' — the error exception is defined in the pure-Python wrapper module 'struct', not '_struct'."
    - "struct.Struct.__module__ == '_struct' — Struct class is from the C extension."
    - "struct.pack('>I', 0).__class__.__name__ == 'bytes' — pack always returns bytes."
    - "struct.pack('>I', 0).__len__() == 4 — '>I' is unsigned int, 4 bytes."
    - "struct.pack('>H', 256) == b'\\x01\\x00' — confirmed (also in struct_extra2, but struct_extra8 re-examines via __len__)."
    - "struct.unpack('>H', b'\\x01\\x00') == (256,) — inverse of pack '>H' 256."
    - "struct.calcsize('>IHB') == 7 — I=4, H=2, B=1 bytes in standard big-endian format."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# Function __module__ attributes — actual values from C extension _struct
#
# struct_extra2 covered __module__ for all six functions but noted the value
# as 'struct'. The actual runtime value for pack/unpack/pack_into/unpack_from/
# iter_unpack/calcsize/Struct is '_struct' (the C extension). Only error.__module__
# is 'struct' (the pure-Python wrapper). This spec records the correct values.
# ---------------------------------------------------------------------------

table struct_extra8.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [pack_mod,        pack.__module__.__eq__,        ["_struct"], true]
    - [unpack_mod,      unpack.__module__.__eq__,      ["_struct"], true]
    - [pack_into_mod,   pack_into.__module__.__eq__,   ["_struct"], true]
    - [unpack_from_mod, unpack_from.__module__.__eq__, ["_struct"], true]
    - [iter_unpack_mod, iter_unpack.__module__.__eq__, ["_struct"], true]
    - [calcsize_mod,    calcsize.__module__.__eq__,    ["_struct"], true]
    - [Struct_mod,      Struct.__module__.__eq__,      ["_struct"], true]

# ---------------------------------------------------------------------------
# error.__module__ — 'struct' (pure-Python wrapper), not '_struct'
#
# All other public names are from _struct (C extension). The error exception
# class lives in the pure-Python module 'struct'. No prior spec confirms
# this distinction explicitly using the correct '_struct' context.
# ---------------------------------------------------------------------------

invariant struct_extra8.error.module:
  description: "struct.error.__module__ == 'struct' — error exception is in the pure-Python wrapper, not _struct"
  category: function_modules
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# pack() return type — bytes class and length
#
# No prior spec checks the __class__.__name__ of the return value of pack(),
# nor checks __len__ of the result directly as an invariant. Both are new.
# ---------------------------------------------------------------------------

invariant struct_extra8.pack.result_class_name:
  description: "struct.pack('>I', 0).__class__.__name__ == 'bytes' — pack always returns bytes"
  category: types
  kind: python_call_eq
  function: pack
  args: [">I", 0]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant struct_extra8.pack.result_len_uint32:
  description: "struct.pack('>I', 0).__len__() == 4 — big-endian unsigned int is 4 bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">I", 0]
  method: __len__
  method_args: []
  expected: 4

# ---------------------------------------------------------------------------
# pack() and unpack() — big-endian unsigned short 256 (via method_chain)
#
# struct_extra2 also has pack('>H', 256) and unpack('>H', ...), but as
# standalone pack/unpack correctness checks. This spec re-examines the
# pack result's __len__ (new angle not in any prior spec).
# ---------------------------------------------------------------------------

invariant struct_extra8.pack.uint16_256_len:
  description: "struct.pack('>H', 256).__len__() == 2 — big-endian unsigned short is 2 bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">H", 256]
  method: __len__
  method_args: []
  expected: 2

# ---------------------------------------------------------------------------
# calcsize() — composite format '>IHB'
#
# I=4 bytes, H=2 bytes, B=1 byte → total 7 bytes in standard big-endian
# format. No prior struct spec uses the '>IHB' compound format string in
# calcsize. (struct_extra used '>BHI' in pack_into and calcsize('>BHI')==7,
# but '>IHB' with a different field ordering is a new test vector.)
# ---------------------------------------------------------------------------

invariant struct_extra8.calcsize.compound_IHB:
  description: "struct.calcsize('>IHB') == 7 — I(4)+H(2)+B(1) bytes in big-endian standard format"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: [">IHB"]
  expected: 7

# ---------------------------------------------------------------------------
# unpack() — big-endian unsigned short 256
#
# Re-confirms unpack('>H', b'\x01\x00') == (256,) as a standalone invariant
# in the extra8 namespace (struct_extra2 had this; here it cross-validates
# with the __module__ == '_struct' context established above).
# ---------------------------------------------------------------------------

invariant struct_extra8.unpack.uint16_256:
  description: "struct.unpack('>H', b'\\x01\\x00') == (256,) — round-trip for big-endian uint16 256"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">H", !hex 0100]
  expected: [256]

# ---------------------------------------------------------------------------
# Struct.__module__ standalone — '_struct' (C extension)
#
# Confirms Struct.__module__ == '_struct' as an individual named invariant
# separate from the table above, for traceability.
# ---------------------------------------------------------------------------

invariant struct_extra8.Struct.module:
  description: "struct.Struct.__module__ == '_struct' — Struct class originates from the C extension"
  category: class_identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# pack() and unpack() — compound format '>IHB'
#
# struct_extra and struct_extra2 used '>BHI' for pack_into and calcsize.
# '>IHB' in a pack/unpack behavioral test is new. Result byte length == 7.
# unpack round-trip verifies both directions for the compound format.
# ---------------------------------------------------------------------------

invariant struct_extra8.pack.compound_IHB:
  description: "struct.pack('>IHB', 1, 2, 3) == 7-byte sequence — compound format pack"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">IHB", 1, 2, 3]
  method: __len__
  method_args: []
  expected: 7

invariant struct_extra8.unpack.compound_IHB:
  description: "struct.unpack('>IHB', ...) == (1, 2, 3) — round-trip for compound '>IHB' format"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">IHB", !hex 00000001000203]
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# calcsize() — '>Q' (64-bit unsigned integer)
#
# struct.zspec.zsdl has calcsize for Q via '>Q' in the roundtrip section.
# No prior spec checks calcsize('>Q') as a standalone invariant in extra8.
# '>Q' is 8 bytes in standard format.
# ---------------------------------------------------------------------------

invariant struct_extra8.calcsize.uint64:
  description: "struct.calcsize('>Q') == 8 — big-endian unsigned 64-bit integer is 8 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: [">Q"]
  expected: 8

# ---------------------------------------------------------------------------
# Struct instance — format and size for '>IHB'
#
# No prior spec constructs Struct('>IHB'). Confirms the compound format is
# preserved and the size matches calcsize('>IHB') == 7.
# ---------------------------------------------------------------------------

invariant struct_extra8.Struct_IHB.format:
  description: "struct.Struct('>IHB').format == '>IHB' — compound format is preserved"
  category: struct_attrs
  kind: python_call_eq
  function: Struct
  args: [">IHB"]
  method: format.__eq__
  method_args: [">IHB"]
  expected: true

invariant struct_extra8.Struct_IHB.size:
  description: "struct.Struct('>IHB').size == 7 — compound format size matches calcsize"
  category: struct_attrs
  kind: python_call_eq
  function: Struct
  args: [">IHB"]
  method: size.__eq__
  method_args: [7]
  expected: true
