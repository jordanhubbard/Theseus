spec: pathlib_extra100
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra99

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra99.zspec.zsdl."
    - "This spec covers: pathlib module identity (__name__, __package__, __loader__, __spec__) and pathlib class __dict__ class names."
    - "pathlib.__name__ = 'pathlib' — the module's __name__ attribute equals its dotted name."
    - "pathlib.__package__ = 'pathlib' — pathlib is a package (its __package__ equals its own name)."
    - "pathlib.__loader__.__class__.__name__ = 'SourceFileLoader' — pathlib is a pure Python module, loaded by SourceFileLoader."
    - "pathlib.__spec__.__class__.__name__ = 'ModuleSpec' — the module spec is a ModuleSpec instance."
    - "pathlib.Path.__dict__.__class__.__name__ = 'mappingproxy' — class __dict__ attributes are always mappingproxy."
    - "All pathlib.Path.__dict__ membership checks for with_*, parts, stem, etc. return False because those properties are defined in PurePath, not Path."
    - "pathlib.PurePath.__dict__ contains parts, drive, root, anchor, stem, suffix, suffixes, name, parent, parents — these are all True."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module string identity + __spec__/__loader__ class names
# pathlib.__name__ == 'pathlib', __package__ == 'pathlib'
# __loader__ is SourceFileLoader, __spec__ is ModuleSpec
# ---------------------------------------------------------------------------

table pathlib_extra100.module_identity:
  description: "pathlib module identity: __name__, __package__, __loader__ and __spec__ class names"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibmodule100

  columns: [id, function, args, expected]
  rows:
    - [mod_name_eq,          __name__.__eq__,                            ["pathlib"],          true]
    - [mod_name_not_path,    __name__.__eq__,                            ["path"],             false]
    - [mod_pkg_eq,           __package__.__eq__,                         ["pathlib"],          true]
    - [mod_loader_cls_eq,    __loader__.__class__.__name__.__eq__,       ["SourceFileLoader"], true]
    - [mod_spec_cls_eq,      __spec__.__class__.__name__.__eq__,         ["ModuleSpec"],       true]
    - [mod_doc_cls_eq,       __doc__.__class__.__name__.__eq__,          ["str"],              true]

# ---------------------------------------------------------------------------
# pathlib class __dict__ class names
# All classes in pathlib have __dict__ of type mappingproxy.
# ---------------------------------------------------------------------------

table pathlib_extra100.class_dict_classname:
  description: "pathlib class __dict__ class names — all are 'mappingproxy'"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmodule100

  columns: [id, function, args, expected]
  rows:
    - [path_dict_cls,         Path.__dict__.__class__.__name__.__eq__,            ["mappingproxy"], true]
    - [purepath_dict_cls,     PurePath.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true]
    - [pureposix_dict_cls,    PurePosixPath.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [purewin_dict_cls,      PureWindowsPath.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [posixpath_dict_cls,    PosixPath.__dict__.__class__.__name__.__eq__,       ["mappingproxy"], true]
    - [path_dict_not_dict,    Path.__dict__.__class__.__name__.__eq__,            ["dict"],         false]

# ---------------------------------------------------------------------------
# pathlib.Path __dict__ membership for with_* methods and property names
# All with_* methods and path property names (parts, stem, etc.) return False
# because they are defined in PurePath, not in Path itself.
# ---------------------------------------------------------------------------

table pathlib_extra100.Path_dict_membership:
  description: "pathlib.Path.__dict__ membership for with_* methods and path properties — all False (defined in PurePath)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibmodule100

  columns: [id, function, args, expected]
  rows:
    - [path_has_with_stem,    "Path.__dict__.__contains__",   ["with_stem"],    false]
    - [path_has_with_suffix,  "Path.__dict__.__contains__",   ["with_suffix"],  false]
    - [path_has_with_name,    "Path.__dict__.__contains__",   ["with_name"],    false]
    - [path_has_with_segs,    "Path.__dict__.__contains__",   ["with_segments"], false]
    - [path_has_joinpath,     "Path.__dict__.__contains__",   ["joinpath"],     false]
    - [path_has_parts,        "Path.__dict__.__contains__",   ["parts"],        false]
    - [path_has_stem,         "Path.__dict__.__contains__",   ["stem"],         false]
    - [path_has_suffix,       "Path.__dict__.__contains__",   ["suffix"],       false]

# ---------------------------------------------------------------------------
# pathlib.PurePath __dict__ membership for property names
# parts, drive, root, anchor, stem, suffix, suffixes, name, parent, parents
# are all defined in PurePath.__dict__ (all True).
# ---------------------------------------------------------------------------

table pathlib_extra100.PurePath_dict_membership:
  description: "pathlib.PurePath.__dict__ membership for property names — all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibmodule100

  columns: [id, function, args, expected]
  rows:
    - [pp_has_parts,    "PurePath.__dict__.__contains__",  ["parts"],    true]
    - [pp_has_drive,    "PurePath.__dict__.__contains__",  ["drive"],    true]
    - [pp_has_root,     "PurePath.__dict__.__contains__",  ["root"],     true]
    - [pp_has_anchor,   "PurePath.__dict__.__contains__",  ["anchor"],   true]
    - [pp_has_stem,     "PurePath.__dict__.__contains__",  ["stem"],     true]
    - [pp_has_suffix,   "PurePath.__dict__.__contains__",  ["suffix"],   true]
    - [pp_has_suffixes, "PurePath.__dict__.__contains__",  ["suffixes"], true]
    - [pp_has_name,     "PurePath.__dict__.__contains__",  ["name"],     true]
    - [pp_has_parent,   "PurePath.__dict__.__contains__",  ["parent"],   true]
    - [pp_has_parents,  "PurePath.__dict__.__contains__",  ["parents"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra100.module.name_eq_pathlib:
  description: "pathlib.__name__ == 'pathlib' (the module's __name__ equals its dotted module name)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra100.module.loader_is_SourceFileLoader:
  description: "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' (pathlib is a pure Python module loaded by SourceFileLoader)"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant pathlib_extra100.Path.dict_classname_is_mappingproxy:
  description: "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' (class __dict__ is always a mappingproxy in Python)"
  category: class_identity
  kind: python_call_eq
  function: Path.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant pathlib_extra100.PurePath.dict_has_parts:
  description: "pathlib.PurePath.__dict__.__contains__('parts') == True (parts property is defined in PurePath, not in Path)"
  category: dict_membership
  kind: python_call_eq
  function: "PurePath.__dict__.__contains__"
  args: ["parts"]
  expected: true

invariant pathlib_extra100.Path.dict_not_has_stem:
  description: "pathlib.Path.__dict__.__contains__('stem') == False (stem is defined in PurePath, not overridden in Path)"
  category: dict_membership
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["stem"]
  expected: false
