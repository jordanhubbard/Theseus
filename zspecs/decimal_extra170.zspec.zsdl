spec: decimal_extra170
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal class MRO analysis for Decimal, Context, DecimalException, and InvalidOperation."
    - "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]; Decimal is a C type from _decimal with no intermediate base class."
    - "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]; Context is also a C type from _decimal."
    - "decimal.DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.InvalidOperation.__mro__.__len__() == 6 — MRO is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Decimal.__name__ == 'Decimal' (len=7)."
    - "decimal.Decimal.__module__ == 'decimal' (len=7) — the public module, not _decimal."
    - "decimal.Context.__name__ == 'Context' (len=7)."
    - "decimal.Context.__module__ == 'decimal' (len=7)."
    - "decimal.DecimalException.__name__ == 'DecimalException' (len=16: 'Decimal' (7) + 'Exception' (9) = 16)."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' (len=16: 'Invalid' (7) + 'Operation' (9) = 16)."
    - "DecimalException (16) == InvalidOperation (16): a two-way tie at 16 in class name length."
    - "Decimal (7) == Context (7): a two-way tie at 7 in class name length."
    - "MRO length ordering: Decimal=Context (2) < DecimalException (5) < InvalidOperation (6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal MRO lengths — Decimal, Context, DecimalException, InvalidOperation
# Decimal.__mro__.__len__() == 2 (Decimal > object — C type)
# Context.__mro__.__len__() == 2 (Context > object — C type)
# DecimalException.__mro__.__len__() == 5 (exception hierarchy)
# InvalidOperation.__mro__.__len__() == 6 (exception subclass)
# ---------------------------------------------------------------------------

table decimal_extra170.mro_lengths:
  description: "MRO lengths: Decimal=Context (len=2, C types), DecimalException (len=5), InvalidOperation (len=6); Decimal and Context tie at 2 (minimum); InvalidOperation (6) > DecimalException (5) by 1; MRO ordering: Decimal=Context (2) < DecimalException (5) < InvalidOperation (6)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmro170

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_mro_len,   Decimal.__mro__.__len__,          [], 2, "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]; Decimal is a C type from the _decimal extension module; as a C type it has no Python intermediate base classes, yielding the minimum 2-step MRO; Decimal (2) == Context (2): the two core decimal C types tie at the minimum MRO length 2; Decimal (2) << DecimalException (5) << InvalidOperation (6): the C types have drastically shorter MROs than the exception classes; Decimal.__name__ == 'Decimal' (7 chars); Decimal.__module__ == 'decimal' (7 chars): the public module name and the class name have the same 7-character length; confirmed Python 3.14.3 macOS"]
    - [context_mro_len,   Context.__mro__.__len__,          [], 2, "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]; Context is a C type from the _decimal extension module; like Decimal, Context has no Python intermediate base classes; Context (2) == Decimal (2): the two principal decimal C types tie at MRO length 2; Context.__name__ == 'Context' (7 chars) == len('Decimal') (7): Context and Decimal tie in both MRO length (2) and class name length (7); Context.__module__ == 'decimal' (7 chars) == Context.__name__ (7 chars): module name and class name have equal length; confirmed Python 3.14.3 macOS"]
    - [decexc_mro_len,    DecimalException.__mro__.__len__, [], 5, "decimal.DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]; DecimalException is the root exception class for all decimal arithmetic errors; the 5-step MRO follows the standard Python exception hierarchy: custom > ArithmeticError > Exception > BaseException > object; DecimalException (5) > Decimal=Context (2) by 3: the exception class has a 3-step deeper MRO than the C types because it inherits from the built-in exception hierarchy; DecimalException (5) < InvalidOperation (6) by 1: DecimalException is one step above its subclass; confirmed Python 3.14.3 macOS"]
    - [invalidop_mro_len, InvalidOperation.__mro__.__len__, [], 6, "decimal.InvalidOperation.__mro__.__len__() == 6 — MRO is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]; InvalidOperation is one level below DecimalException in the decimal exception hierarchy; InvalidOperation (6) == DecimalException (5) + 1: adding one direct base (DecimalException) extends the MRO by exactly 1 step; InvalidOperation (6) is the maximum MRO length among the four decimal classes in this spec: Decimal=Context (2) < DecimalException (5) < InvalidOperation (6); InvalidOperation.__name__ == 'InvalidOperation' (16 chars): the longest class name in this spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal class name lengths and module attributes
# Decimal (7) == Context (7): two-way tie at 7
# DecimalException (16) == InvalidOperation (16): two-way tie at 16
# All four have __module__ == 'decimal' (len=7)
# ---------------------------------------------------------------------------

table decimal_extra170.class_name_lengths_and_modules:
  description: "Class name lengths: Decimal=Context (len=7, tie), DecimalException=InvalidOperation (len=16, tie); all have __module__=='decimal' (len=7); Decimal.__name__ (7) == Decimal.__module__ (7): unique tie where class and module names have equal length"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmro170

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_name_len,   Decimal.__name__.__len__,          [], 7,  "decimal.Decimal.__name__.__len__() == 7 — 'Decimal' has 7 characters; Decimal (7) == Context (7): a two-way tie at 7 between the two core decimal C types; Decimal (7) << DecimalException (16): the exception class name is more than twice as long; Decimal.__module__ == 'decimal' (7 chars): the class name 'Decimal' (7) equals the module name 'decimal' (7) in length — a rare tie where a class name length equals its own module name length; confirmed Python 3.14.3 macOS"]
    - [context_name_len,   Context.__name__.__len__,          [], 7,  "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters; Context (7) == Decimal (7): the two-way tie at 7 for the core decimal C type class names; both Decimal (7) and Context (7) have the same class name length, and both have __module__ == 'decimal' (7 chars), so both have the property that class name length equals module name length; Context (7) < DecimalException (16) by 9 characters; confirmed Python 3.14.3 macOS"]
    - [decimal_module,     Decimal.__module__.__eq__,         ["decimal"], true, "decimal.Decimal.__module__ == 'decimal' — the public module name; Decimal is implemented in the C extension _decimal but exposed via the public 'decimal' module wrapper; 'decimal' has 7 characters; Decimal.__module__ (7) == Decimal.__name__.__len__() (7): the module name and class name have equal 7-character length — an unusual coincidence; Decimal.__module__ == 'decimal' (not '_decimal'): the public module name is returned even though the implementation lives in _decimal; confirmed Python 3.14.3 macOS"]
    - [context_module,     Context.__module__.__eq__,         ["decimal"], true, "decimal.Context.__module__ == 'decimal' — the public module name; like Decimal, Context is implemented in _decimal but its __module__ returns 'decimal'; 'decimal' has 7 characters; Context.__module__ (7) == Context.__name__.__len__() (7): module name length equals class name length; Context.__module__ (7) == Decimal.__module__ (7): both core C types share the same 7-character module name; confirmed Python 3.14.3 macOS"]
    - [decexc_name_len,    DecimalException.__name__.__len__, [], 16, "decimal.DecimalException.__name__.__len__() == 16 — 'DecimalException' has 16 characters: 'Decimal' (7) + 'Exception' (9) = 16; DecimalException (16) == InvalidOperation (16): a two-way tie at 16 for the exception class names in this spec; DecimalException (16) > Context=Decimal (7) by 9 characters: the exception suffix 'Exception' (9 chars) accounts for the entire gap; DecimalException (16 chars) contains 'Decimal' (7 chars) as a prefix — the exception name is literally the class name 'Decimal' plus the suffix 'Exception'; confirmed Python 3.14.3 macOS"]
    - [invalidop_name_len, InvalidOperation.__name__.__len__, [], 16, "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation' has 16 characters: 'Invalid' (7) + 'Operation' (9) = 16; InvalidOperation (16) == DecimalException (16): a two-way tie at 16; both exception class names happen to be 16 characters: 'Decimal'(7)+'Exception'(9) and 'Invalid'(7)+'Operation'(9); both component pairs sum the same: 7+9=16; coincidentally, both first components ('Decimal' and 'Invalid') have 7 characters and both second components ('Exception' and 'Operation') have 9 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal MRO entry names for DecimalException and InvalidOperation
# DecimalException mro[1].__name__ == 'ArithmeticError' (len=15)
# InvalidOperation mro[1].__name__ == 'DecimalException' (len=16)
# ---------------------------------------------------------------------------

table decimal_extra170.exception_mro_entries:
  description: "MRO entry names: DecimalException.mro[1]='ArithmeticError' (len=15), InvalidOperation.mro[1]='DecimalException' (len=16), InvalidOperation.mro[2]='ArithmeticError' (len=15); DecimalException inherits from ArithmeticError; InvalidOperation inherits from DecimalException"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmro170

  columns: [id, function, args, expected, description]
  rows:
    - [decexc_mro0,     "DecimalException.__mro__[0].__name__.__eq__",    ["DecimalException"], true, "decimal.DecimalException.__mro__[0].__name__ == 'DecimalException' — the first MRO entry is the class itself; DecimalException.__mro__[0] is DecimalException; 'DecimalException' has 16 characters; this confirms the MRO tuple starts with the class itself (a Python MRO invariant); confirmed Python 3.14.3 macOS"]
    - [decexc_mro1,     "DecimalException.__mro__[1].__name__.__eq__",    ["ArithmeticError"],  true, "decimal.DecimalException.__mro__[1].__name__ == 'ArithmeticError' — DecimalException inherits directly from ArithmeticError; 'ArithmeticError' has 15 characters; ArithmeticError is the built-in Python exception class for arithmetic errors (ZeroDivisionError, OverflowError, FloatingPointError also inherit from it); DecimalException extends ArithmeticError to define decimal-specific exceptions; confirmed Python 3.14.3 macOS"]
    - [invalidop_mro1,  "InvalidOperation.__mro__[1].__name__.__eq__",    ["DecimalException"], true, "decimal.InvalidOperation.__mro__[1].__name__ == 'DecimalException' — InvalidOperation inherits directly from DecimalException; 'DecimalException' has 16 characters; InvalidOperation.__mro__[1] being DecimalException confirms the two-level exception hierarchy: InvalidOperation > DecimalException > ArithmeticError > Exception > BaseException > object (6 steps); InvalidOperation is one of the primary decimal exception types raised when an invalid operation is attempted; confirmed Python 3.14.3 macOS"]
    - [invalidop_mro2,  "InvalidOperation.__mro__[2].__name__.__eq__",    ["ArithmeticError"],  true, "decimal.InvalidOperation.__mro__[2].__name__ == 'ArithmeticError' — the third MRO entry for InvalidOperation is ArithmeticError, the same class that appears at mro[1] for DecimalException; 'ArithmeticError' has 15 characters; InvalidOperation.__mro__[2] == DecimalException.__mro__[1]: the offset-by-one shift in MRO position reflects that InvalidOperation adds one level (DecimalException) above the ArithmeticError base; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra170.Decimal_mro_len_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]; Decimal is a C type from _decimal with the minimum 2-step MRO; Decimal (2) == Context (2): the two primary decimal C types tie at MRO length 2; Decimal (2) is the global minimum in this spec; Decimal.__module__ == 'decimal' (7 chars), not '_decimal' — the public module attribution masks the C implementation; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra170.Context_mro_len_2:
  description: "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]; Context is a C type from _decimal with the minimum 2-step MRO; Context (2) == Decimal (2): the two-way tie at MRO length 2 for the core decimal C types; Context.__name__ (7 chars) == Context.__module__.__len__() (7 chars): class name and module name lengths are equal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra170.DecimalException_mro_len_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]; DecimalException (5) is the intermediate value in the MRO-length ordering: Decimal=Context (2) < DecimalException (5) < InvalidOperation (6); DecimalException (5) > Decimal (2) by 3: the exception hierarchy adds ArithmeticError, Exception, and BaseException above object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra170.InvalidOperation_mro_len_6:
  description: "decimal.InvalidOperation.__mro__.__len__() == 6 — MRO is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]; InvalidOperation (6) is the maximum MRO length in this spec; InvalidOperation (6) == DecimalException (5) + 1: adding DecimalException as a direct base extends the MRO by one step; InvalidOperation.__name__ (16 chars) is also the maximum class name length in this spec: a coincidental tie at the maximum for both MRO length ordering and class name length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: InvalidOperation.__mro__.__len__
  args: []
  expected: 6

invariant decimal_extra170.Decimal_module_is_decimal:
  description: "decimal.Decimal.__module__ == 'decimal' — the public module name 'decimal' has 7 characters; Decimal is implemented in the C extension _decimal but __module__ returns the public 'decimal' wrapper module name; Decimal.__module__ (7 chars) == Decimal.__name__.__len__() (7 chars): the module name and the class name have equal 7-character length; Decimal.__module__ (7) == Context.__module__ (7) == 'decimal': both core C type classes share the same public module attribution; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra170.Decimal_Context_name_len_tie_at_7:
  description: "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters; Context (7) == Decimal (7): a two-way tie at 7 for the core decimal C type class names; both Context (7) and Decimal (7) tie with the module name 'decimal' in character count (7), creating a three-way tie: Decimal.__name__ (7) == Context.__name__ (7) == Decimal.__module__.__len__() (7) == Context.__module__.__len__() (7); this four-way tie at 7 (class names, module name length) is a defining numerical signature of the decimal module's core types; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.__name__.__len__
  args: []
  expected: 7
