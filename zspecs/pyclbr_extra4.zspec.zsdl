spec: pyclbr_extra4
version: ">=3.9"
backend: python_module(pyclbr)

docs: https://docs.python.org/3/library/pyclbr.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pyclbr.html — Python pyclbr module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pyclbr.py"
  notes:
    - "Extends pyclbr.zspec.zsdl through pyclbr_extra3.zspec.zsdl."
    - "pyclbr (base) covers: readmodule/__name__/__qualname__, readmodule_ex/__name__/__qualname__, Class/__name__/__module__, Function/__name__/__module__, type_checks, readmodule('math')/__class__/__name__, readmodule_ex('math')/__class__/__name__."
    - "pyclbr_extra covers: function names/modules table, Function/__name__/__module__, Class/__name__/__module__, Class.__bases__[0].__name__=='_Object', Class.__bases__[0].__module__=='pyclbr', Function.__bases__[0].__name__=='_Object', class_is_type table."
    - "pyclbr_extra2 covers: Class/__qualname__, Function/__qualname__, Function.__bases__[0].__module__, Class/__bases__.__len__==1, Function/__bases__.__len__==1, readmodule('math').__len__()==0."
    - "pyclbr_extra3 covers: Class.__bases__[0].__name__ via method_args: [], readmodule_ex('math').__len__()==0, Class/__name__/__len__==5, Function/__name__/__len__==8, readmodule/__module__/__len__==6, readmodule_ex/__module__/__len__==6."
    - "This spec adds: pyclbr._Object class introspection (__name__, __module__, __qualname__, __bases__[0].__name__, __bases__.__len__, __class__.__name__), readmodule('pyclbr') returns dict with 4 entries (__len__==4), Function.__bases__[0].__name__ confirmed via __qualname__ of base."
    - "pyclbr._Object is the internal base class shared by Class and Function."
    - "pyclbr._Object.__name__ == '_Object', __module__ == 'pyclbr', __qualname__ == '_Object'."
    - "pyclbr._Object.__bases__[0].__name__ == 'object' — _Object inherits from object."
    - "pyclbr._Object.__bases__.__len__() == 1 — _Object has exactly one base class."
    - "pyclbr._Object.__class__.__name__ == 'type' — _Object is a class object."
    - "readmodule('pyclbr').__len__() == 4 — pyclbr itself exposes Class, Function, _ModuleBrowser, and _Object as Python-level classes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pyclbr._Object — internal private base class, never directly tested
# in any prior pyclbr spec (prior specs access it only via Class.__bases__[0]
# or Function.__bases__[0]; this spec tests _Object directly).
# ---------------------------------------------------------------------------

invariant pyclbr_extra4._Object.name:
  description: "pyclbr._Object.__name__ == '_Object'"
  category: _object_class
  kind: python_call_eq
  function: _Object.__name__.__eq__
  args: ["_Object"]
  expected: true

invariant pyclbr_extra4._Object.module:
  description: "pyclbr._Object.__module__ == 'pyclbr'"
  category: _object_class
  kind: python_call_eq
  function: _Object.__module__.__eq__
  args: ["pyclbr"]
  expected: true

invariant pyclbr_extra4._Object.qualname:
  description: "pyclbr._Object.__qualname__ == '_Object'"
  category: _object_class
  kind: python_call_eq
  function: _Object.__qualname__.__eq__
  args: ["_Object"]
  expected: true

invariant pyclbr_extra4._Object.is_type:
  description: "type(pyclbr._Object).__name__ == 'type' — _Object is a class object"
  category: _object_class
  kind: python_call_eq
  function: _Object.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pyclbr_extra4._Object.base_is_object:
  description: "pyclbr._Object.__bases__[0].__name__ == 'object' — _Object inherits directly from object"
  category: _object_class
  kind: python_call_eq
  function: _Object.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant pyclbr_extra4._Object.bases_len:
  description: "len(pyclbr._Object.__bases__) == 1 — _Object has exactly one base class (object)"
  category: _object_class
  kind: python_call_eq
  function: _Object.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# readmodule('pyclbr') — runtime check for non-empty result
# Prior specs only test readmodule('math') which returns an empty dict.
# pyclbr itself has Python-level classes, so readmodule('pyclbr') returns
# a non-empty dict with 4 entries: Class, Function, _ModuleBrowser, _Object.
# ---------------------------------------------------------------------------

invariant pyclbr_extra4.readmodule.pyclbr_nonempty:
  description: "pyclbr.readmodule('pyclbr').__len__() == 4 — pyclbr module has 4 visible Python classes"
  category: runtime
  kind: python_call_eq
  function: readmodule
  args: ["pyclbr"]
  method: __len__
  method_args: []
  expected: 4

# ---------------------------------------------------------------------------
# _Object __qualname__ string length
# '_Object' has 7 characters. Complements the __name__ length checks in
# pyclbr_extra3 (which covered Class==5, Function==8) with the _Object entry.
# ---------------------------------------------------------------------------

invariant pyclbr_extra4._Object.qualname_len:
  description: "len(pyclbr._Object.__qualname__) == 7 — '_Object' has 7 characters"
  category: _object_class
  kind: python_call_eq
  function: _Object.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# _Object __module__ string length
# 'pyclbr' has 6 characters — parallel to the readmodule/__module__.__len__
# checks in pyclbr_extra3, extended to _Object.
# ---------------------------------------------------------------------------

invariant pyclbr_extra4._Object.module_len:
  description: "len(pyclbr._Object.__module__) == 6 — 'pyclbr' has 6 characters"
  category: _object_class
  kind: python_call_eq
  function: _Object.__module__.__len__
  args: []
  expected: 6
