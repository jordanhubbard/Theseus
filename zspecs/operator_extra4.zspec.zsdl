spec: operator_extra4
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "Python operator documentation — https://docs.python.org/3/library/operator.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl, operator_extra.zspec.zsdl, operator_extra2.zspec.zsdl, and operator_extra3.zspec.zsdl."
    - "operator.zspec.zsdl: behavioral call results for all arithmetic/comparison/logical/sequence operators."
    - "operator_extra.zspec.zsdl: __name__ and call behaviour for itemgetter/attrgetter/methodcaller; iadd/isub/imul/itruediv."
    - "operator_extra2.zspec.zsdl: attrgetter/__name__, itemgetter/__name__, methodcaller/__name__; instance class names; length_hint/index/concat/abs/pos/iadd/truth/is_."
    - "operator_extra3.zspec.zsdl: __module__ == '_operator' for add/sub/mul/truediv/floordiv/mod/pow/neg/abs/eq/ne/lt/le/gt/ge/not_/and_/or_/xor/lshift/rshift/getitem/setitem/delitem/contains."
    - "Focus: __qualname__ checks for add/sub/mul/truediv/floordiv/mod/pow/neg/pos/abs and eq/ne/lt/le/gt/ge — all are C-extension builtins whose __qualname__ equals their __name__."
    - "operator.add.__qualname__ == 'add' — C builtin functions have flat qualnames."
    - "operator.sub.__qualname__ == 'sub'."
    - "operator.mul.__qualname__ == 'mul'."
    - "operator.truediv.__qualname__ == 'truediv'."
    - "operator.floordiv.__qualname__ == 'floordiv'."
    - "operator.mod.__qualname__ == 'mod'."
    - "operator.pow.__qualname__ == 'pow'."
    - "operator.neg.__qualname__ == 'neg'."
    - "operator.pos.__qualname__ == 'pos'."
    - "operator.abs.__qualname__ == 'abs'."
    - "operator.eq.__qualname__ == 'eq'."
    - "operator.ne.__qualname__ == 'ne'."
    - "operator.lt.__qualname__ == 'lt'."
    - "operator.le.__qualname__ == 'le'."
    - "operator.gt.__qualname__ == 'gt'."
    - "operator.ge.__qualname__ == 'ge'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — arithmetic operators
#
# operator_extra3 verified __module__ for these functions; this spec adds the
# corresponding __qualname__ checks. C builtin functions defined at module
# top-level have flat qualnames identical to their __name__.
# ---------------------------------------------------------------------------

table operator_extra4.arithmetic_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [add,      add.__qualname__.__eq__,      ["add"],      true]
    - [sub,      sub.__qualname__.__eq__,      ["sub"],      true]
    - [mul,      mul.__qualname__.__eq__,      ["mul"],      true]
    - [truediv,  truediv.__qualname__.__eq__,  ["truediv"],  true]
    - [floordiv, floordiv.__qualname__.__eq__, ["floordiv"], true]
    - [mod,      mod.__qualname__.__eq__,      ["mod"],      true]
    - [pow,      pow.__qualname__.__eq__,      ["pow"],      true]
    - [neg,      neg.__qualname__.__eq__,      ["neg"],      true]
    - [pos,      pos.__qualname__.__eq__,      ["pos"],      true]
    - [abs,      abs.__qualname__.__eq__,      ["abs"],      true]

# ---------------------------------------------------------------------------
# __qualname__ checks — comparison operators
# ---------------------------------------------------------------------------

table operator_extra4.comparison_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [eq, eq.__qualname__.__eq__, ["eq"], true]
    - [ne, ne.__qualname__.__eq__, ["ne"], true]
    - [lt, lt.__qualname__.__eq__, ["lt"], true]
    - [le, le.__qualname__.__eq__, ["le"], true]
    - [gt, gt.__qualname__.__eq__, ["gt"], true]
    - [ge, ge.__qualname__.__eq__, ["ge"], true]
