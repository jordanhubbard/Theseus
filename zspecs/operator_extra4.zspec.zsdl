spec: operator_extra4
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "Python operator documentation — https://docs.python.org/3/library/operator.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl, operator_extra.zspec.zsdl, operator_extra2.zspec.zsdl, operator_extra3.zspec.zsdl."
    - "operator_extra.zspec covers: itemgetter/attrgetter/methodcaller __name__ and call behaviour: itemgetter(0)([1,2,3])==1, itemgetter(2)([1,2,3])==3, itemgetter('x')({'x':42})==42; methodcaller('upper')('hello')=='HELLO', methodcaller('strip')('  hi  ')=='hi'; iadd/isub/imul/itruediv in-place vectors."
    - "operator_extra2.zspec covers: attrgetter/__name__, itemgetter/__name__, methodcaller/__name__ (invariants); instance class names; length_hint([1,2,3])==3; index(42)==42; concat/abs/pos/iadd/truth/is_."
    - "operator_extra3.zspec covers: __module__ for add/sub/mul/truediv/floordiv/mod/pow/neg/abs/eq/ne/lt/le/gt/ge/not_/and_/or_/xor/lshift/rshift/getitem/setitem/delitem/contains — all '_operator'."
    - "This spec adds: attrgetter/__module__, itemgetter/__module__, methodcaller/__module__; itemgetter(0)([10,20,30])==10 and itemgetter(1)([10,20,30])==20 (new list/index combinations); methodcaller('lower')('WORLD')=='world' and methodcaller('upper')('world')=='WORLD' as new call vectors; length_hint on empty list and on tuple; index on 0 and negative int; a table of __name__ cross-checks for attrgetter/itemgetter/methodcaller/length_hint/index."
    - "operator.attrgetter.__module__ == 'operator' — attrgetter is defined in the operator module (not _operator); same for itemgetter and methodcaller."
    - "operator.itemgetter(0)([10,20,30]) == 10 — itemgetter with index 0 on a different list than in operator_extra."
    - "operator.itemgetter(1)([10,20,30]) == 20 — itemgetter with index 1."
    - "operator.methodcaller('lower')('WORLD') == 'world' — new method name not covered in operator_extra."
    - "operator.length_hint([]) == 0 — empty list has length_hint of 0."
    - "operator.length_hint((1,2)) == 2 — tuple has length_hint equal to its length."
    - "operator.index(0) == 0 — index on zero."
    - "operator.index(-1) == -1 — index on a negative integer."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function_names table — __name__ for attrgetter, itemgetter, methodcaller,
# length_hint, index. operator_extra2 covers the first three as individual
# invariants; this table adds length_hint and index __name__ checks.
# ---------------------------------------------------------------------------

table operator_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [attrgetter,   attrgetter.__name__.__eq__,   ["attrgetter"],   true]
    - [itemgetter,   itemgetter.__name__.__eq__,   ["itemgetter"],   true]
    - [methodcaller, methodcaller.__name__.__eq__, ["methodcaller"], true]
    - [length_hint,  length_hint.__name__.__eq__,  ["length_hint"],  true]
    - [index,        index.__name__.__eq__,         ["index"],        true]

# ---------------------------------------------------------------------------
# __module__ checks — attrgetter, itemgetter, methodcaller
# operator_extra3 only covers C-extension functions (__module__ == '_operator').
# attrgetter/itemgetter/methodcaller are also C builtins but from _operator;
# verified as 'operator' on Python 3.12 (the public module re-exports them
# and their __module__ is set to 'operator').
# ---------------------------------------------------------------------------

invariant operator_extra4.attrgetter.module:
  description: "operator.attrgetter.__module__ == 'operator'"
  category: module
  kind: python_call_eq
  function: attrgetter.__module__.__eq__
  args: ["operator"]
  expected: true

invariant operator_extra4.itemgetter.module:
  description: "operator.itemgetter.__module__ == 'operator'"
  category: module
  kind: python_call_eq
  function: itemgetter.__module__.__eq__
  args: ["operator"]
  expected: true

invariant operator_extra4.methodcaller.module:
  description: "operator.methodcaller.__module__ == 'operator'"
  category: module
  kind: python_call_eq
  function: methodcaller.__module__.__eq__
  args: ["operator"]
  expected: true

# ---------------------------------------------------------------------------
# itemgetter — new list/index combinations
# operator_extra covers itemgetter(0)([1,2,3])==1 and itemgetter(2)([1,2,3])==3.
# We add itemgetter(0) and itemgetter(1) on [10, 20, 30].
# ---------------------------------------------------------------------------

invariant operator_extra4.itemgetter.index0_of_10_20_30:
  description: "operator.itemgetter(0)([10, 20, 30]) == 10 — fetches first element"
  category: itemgetter
  kind: python_call_eq
  function: itemgetter
  args: [0]
  method: __call__
  method_args: [[10, 20, 30]]
  expected: 10

invariant operator_extra4.itemgetter.index1_of_10_20_30:
  description: "operator.itemgetter(1)([10, 20, 30]) == 20 — fetches second element"
  category: itemgetter
  kind: python_call_eq
  function: itemgetter
  args: [1]
  method: __call__
  method_args: [[10, 20, 30]]
  expected: 20

invariant operator_extra4.itemgetter.index_neg1_of_10_20_30:
  description: "operator.itemgetter(-1)([10, 20, 30]) == 30 — fetches last element via negative index"
  category: itemgetter
  kind: python_call_eq
  function: itemgetter
  args: [-1]
  method: __call__
  method_args: [[10, 20, 30]]
  expected: 30

# ---------------------------------------------------------------------------
# attrgetter — new attribute target
# operator_extra covers attrgetter('__name__')(int) via a {type:...} object
# (which is flagged as a non-standard arg form). We skip that and test
# attrgetter instance class name (not yet covered with 'x' attr name).
# ---------------------------------------------------------------------------

invariant operator_extra4.attrgetter.instance_with_attr_x:
  description: "operator.attrgetter('x').__class__.__name__ == 'attrgetter'"
  category: attrgetter
  kind: python_call_eq
  function: attrgetter
  args: ["x"]
  method: __class__.__name__.__eq__
  method_args: ["attrgetter"]
  expected: true

# ---------------------------------------------------------------------------
# methodcaller — new method names
# operator_extra covers upper and strip; operator_extra2 covers upper.
# We add lower and capitalize.
# ---------------------------------------------------------------------------

invariant operator_extra4.methodcaller.lower:
  description: "operator.methodcaller('lower')('WORLD') == 'world'"
  category: methodcaller
  kind: python_call_eq
  function: methodcaller
  args: ["lower"]
  method: __call__
  method_args: ["WORLD"]
  expected: "world"

invariant operator_extra4.methodcaller.capitalize:
  description: "operator.methodcaller('capitalize')('hello world') == 'Hello world'"
  category: methodcaller
  kind: python_call_eq
  function: methodcaller
  args: ["capitalize"]
  method: __call__
  method_args: ["hello world"]
  expected: "Hello world"

# ---------------------------------------------------------------------------
# length_hint — additional inputs
# operator_extra2 covers length_hint([1,2,3]) == 3.
# We add an empty list and a two-element tuple.
# ---------------------------------------------------------------------------

invariant operator_extra4.length_hint.empty_list:
  description: "operator.length_hint([]) == 0 — empty list has length_hint of 0"
  category: sequence
  kind: python_call_eq
  function: length_hint
  args: [[]]
  expected: 0

invariant operator_extra4.length_hint.two_tuple:
  description: "operator.length_hint((1, 2)) == 2 — two-element tuple has length_hint 2"
  category: sequence
  kind: python_call_eq
  function: length_hint
  args: [[1, 2]]
  expected: 2

invariant operator_extra4.length_hint.five_element_list:
  description: "operator.length_hint([0, 1, 2, 3, 4]) == 5 — five-element list"
  category: sequence
  kind: python_call_eq
  function: length_hint
  args: [[0, 1, 2, 3, 4]]
  expected: 5

# ---------------------------------------------------------------------------
# index — additional inputs
# operator_extra2 covers index(42) == 42.
# We add index(0), index(-1), and index(100).
# ---------------------------------------------------------------------------

invariant operator_extra4.index.zero:
  description: "operator.index(0) == 0 — index on zero returns zero"
  category: arithmetic
  kind: python_call_eq
  function: index
  args: [0]
  expected: 0

invariant operator_extra4.index.negative_one:
  description: "operator.index(-1) == -1 — index on -1 returns -1"
  category: arithmetic
  kind: python_call_eq
  function: index
  args: [-1]
  expected: -1

invariant operator_extra4.index.one_hundred:
  description: "operator.index(100) == 100 — index on 100 returns 100"
  category: arithmetic
  kind: python_call_eq
  function: index
  args: [100]
  expected: 100
