spec: pathlib_extra991
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.PurePath method __qualname__ identity; with_stem and is_relative_to require Python 3.9+"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra991.purepath_navigation_qualnames:
  description: "pathlib.PurePath navigation method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl991n
  columns: [id, function, args, expected]
  rows:
    - [pl991n001, pathlib.PurePath.with_name.__qualname__.__eq__,      ["PurePath.with_name"],      true]
    - [pl991n002, pathlib.PurePath.with_suffix.__qualname__.__eq__,    ["PurePath.with_suffix"],    true]
    - [pl991n003, pathlib.PurePath.with_stem.__qualname__.__eq__,      ["PurePath.with_stem"],      true]
    - [pl991n004, pathlib.PurePath.joinpath.__qualname__.__eq__,       ["PurePath.joinpath"],       true]
    - [pl991n005, pathlib.PurePath.relative_to.__qualname__.__eq__,    ["PurePath.relative_to"],    true]

table pathlib_extra991.purepath_predicate_qualnames:
  description: "pathlib.PurePath predicate method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl991p
  columns: [id, function, args, expected]
  rows:
    - [pl991p001, pathlib.PurePath.is_absolute.__qualname__.__eq__,    ["PurePath.is_absolute"],    true]
    - [pl991p002, pathlib.PurePath.is_relative_to.__qualname__.__eq__, ["PurePath.is_relative_to"], true]
    - [pl991p003, pathlib.PurePath.match.__qualname__.__eq__,          ["PurePath.match"],          true]

table pathlib_extra991.purepath_class_identity:
  description: "pathlib.PurePath class identity and property checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: pl991c
  columns: [id, function, args, expected]
  rows:
    - [pl991c001, pathlib.PurePath.__module__.__eq__,                    ["pathlib"],    true]
    - [pl991c002, pathlib.PurePath.__qualname__.__eq__,                  ["PurePath"],   true]
    - [pl991c003, pathlib.PurePath.__class__.__name__.__eq__,            ["ABCMeta"],    true]
    - [pl991c004, pathlib.PurePath.parts.__class__.__name__.__eq__,      ["property"],   true]
    - [pl991c005, pathlib.PurePath.name.__class__.__name__.__eq__,       ["property"],   true]
    - [pl991c006, pathlib.PurePath.suffix.__class__.__name__.__eq__,     ["property"],   true]
    - [pl991c007, pathlib.PurePath.stem.__class__.__name__.__eq__,       ["property"],   true]
    - [pl991c008, pathlib.PurePath.parent.__class__.__name__.__eq__,     ["property"],   true]
    - [pl991c009, pathlib.PurePath.parents.__class__.__name__.__eq__,    ["property"],   true]
