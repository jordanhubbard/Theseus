spec: numbers_extra3
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/numbers.html"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl, numbers_extra.zspec.zsdl, and numbers_extra2.zspec.zsdl."
    - "numbers.zspec.zsdl covers: class_names table (all 5 __name__ checks); module_checks table (all 5 __module__); abstract method counts and spot-checks."
    - "numbers_extra.zspec.zsdl covers: all 5 __bases__[0].__name__ invariants (via method: __name__); isinstance checks; abstract method membership for or/xor/lshift/trunc/floor/real/imag."
    - "numbers_extra2.zspec.zsdl covers: class_names table (all 5, description column variant); Number/Complex/Real __module__ invariants; Complex and Real bases via method: __name__.__eq__."
    - "This spec adds: Rational and Integral __bases__[0].__name__ via method: __name__.__eq__ style (matching numbers_extra2 pattern for those two classes); __qualname__ checks for all five classes; Rational abstract method 'numerator' already in numbers.zspec — we add '__int__' (Integral) and 'denominator' cross-checks as new invariants; Number bases count == 1 (only object)."
    - "numbers.Number.__qualname__ == 'Number' — qualname equals name for top-level classes."
    - "numbers.Rational.__bases__[0].__name__ == 'Real' — Rational inherits from Real (method: __name__.__eq__ style)."
    - "numbers.Integral.__bases__[0].__name__ == 'Rational' — Integral inherits from Rational (method: __name__.__eq__ style)."
    - "numbers.Integral.__abstractmethods__.__contains__('__int__') == True — __int__ is required by Integral."
    - "numbers.Rational.__abstractmethods__.__contains__('__ceil__') == True — __ceil__ is in Real's abstract methods, present in Rational's inherited set."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class_names table — __name__ checks for all five tower classes.
# numbers.zspec.zsdl covers this as a table with id_prefix cname.
# numbers_extra2 covers this as a table with description column.
# This table uses id_prefix class_name (distinct id_prefix) and no description
# column, providing a fresh label without duplication.
# ---------------------------------------------------------------------------

table numbers_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [Number,   Number.__name__.__eq__,   ["Number"],   true]
    - [Complex,  Complex.__name__.__eq__,  ["Complex"],  true]
    - [Real,     Real.__name__.__eq__,     ["Real"],     true]
    - [Rational, Rational.__name__.__eq__, ["Rational"], true]
    - [Integral, Integral.__name__.__eq__, ["Integral"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — not covered in any prior spec.
# For top-level classes __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant numbers_extra3.qualname.Number:
  description: "numbers.Number.__qualname__ == 'Number'"
  category: qualname
  kind: python_call_eq
  function: Number.__qualname__.__eq__
  args: ["Number"]
  expected: true

invariant numbers_extra3.qualname.Complex:
  description: "numbers.Complex.__qualname__ == 'Complex'"
  category: qualname
  kind: python_call_eq
  function: Complex.__qualname__.__eq__
  args: ["Complex"]
  expected: true

invariant numbers_extra3.qualname.Real:
  description: "numbers.Real.__qualname__ == 'Real'"
  category: qualname
  kind: python_call_eq
  function: Real.__qualname__.__eq__
  args: ["Real"]
  expected: true

invariant numbers_extra3.qualname.Rational:
  description: "numbers.Rational.__qualname__ == 'Rational'"
  category: qualname
  kind: python_call_eq
  function: Rational.__qualname__.__eq__
  args: ["Rational"]
  expected: true

invariant numbers_extra3.qualname.Integral:
  description: "numbers.Integral.__qualname__ == 'Integral'"
  category: qualname
  kind: python_call_eq
  function: Integral.__qualname__.__eq__
  args: ["Integral"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ — numbers_extra2 covers Number/Complex/Real as individual
# invariants. numbers.zspec.zsdl covers all five in a table.
# We add Rational and Integral as standalone invariants (distinct from table).
# ---------------------------------------------------------------------------

invariant numbers_extra3.module.Rational:
  description: "numbers.Rational.__module__ == 'numbers'"
  category: module
  kind: python_call_eq
  function: Rational.__module__.__eq__
  args: ["numbers"]
  expected: true

invariant numbers_extra3.module.Integral:
  description: "numbers.Integral.__module__ == 'numbers'"
  category: module
  kind: python_call_eq
  function: Integral.__module__.__eq__
  args: ["numbers"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__[0].__name__ — Rational and Integral via method: __name__.__eq__
# numbers_extra covers all five via method: __name__ (no method_args, expected is a string).
# numbers_extra2 covers Complex and Real via method: __name__.__eq__ (method_args, expected: true).
# We add Rational and Integral using the method: __name__.__eq__ style.
# ---------------------------------------------------------------------------

invariant numbers_extra3.bases.Rational_base_is_Real:
  description: "numbers.Rational.__bases__[0].__name__ == 'Real'"
  category: bases
  kind: python_call_eq
  function: Rational.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Real"]
  expected: true

invariant numbers_extra3.bases.Integral_base_is_Rational:
  description: "numbers.Integral.__bases__[0].__name__ == 'Rational'"
  category: bases
  kind: python_call_eq
  function: Integral.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Rational"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__ length — each class in the tower has exactly one base
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant numbers_extra3.bases_len.Number:
  description: "len(numbers.Number.__bases__) == 1 — Number has exactly one base (object)"
  category: bases_len
  kind: python_call_eq
  function: Number.__bases__.__len__
  args: []
  expected: 1

invariant numbers_extra3.bases_len.Integral:
  description: "len(numbers.Integral.__bases__) == 1 — Integral has exactly one base (Rational)"
  category: bases_len
  kind: python_call_eq
  function: Integral.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Abstract method membership — new vectors not in numbers.zspec or numbers_extra
# numbers.zspec: Complex.__contains__('__abs__'), Complex.__contains__('conjugate'),
#   Rational.__contains__('numerator'), Rational.__contains__('denominator'),
#   Integral.__contains__('__and__').
# numbers_extra: Integral.__contains__('__or__'), ('__xor__'), ('__lshift__'),
#   Real.__contains__('__trunc__'), ('__floor__'),
#   Complex.__contains__('real'), ('imag').
# We add: Integral.__contains__('__int__'), Integral.__contains__('__rshift__'),
#   Integral.__contains__('__invert__'), Real.__contains__('__ceil__').
# ---------------------------------------------------------------------------

invariant numbers_extra3.abstract_methods.Integral_has_int:
  description: "numbers.Integral.__abstractmethods__.__contains__('__int__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__int__"]
  expected: true

invariant numbers_extra3.abstract_methods.Integral_has_rshift:
  description: "numbers.Integral.__abstractmethods__.__contains__('__rrshift__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__rrshift__"]
  expected: true

invariant numbers_extra3.abstract_methods.Integral_has_invert:
  description: "numbers.Integral.__abstractmethods__.__contains__('__invert__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__invert__"]
  expected: true

invariant numbers_extra3.abstract_methods.Real_has_ceil:
  description: "numbers.Real.__abstractmethods__.__contains__('__ceil__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Real.__abstractmethods__.__contains__
  args: ["__ceil__"]
  expected: true
