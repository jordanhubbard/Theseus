spec: asyncio_extra273
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queues documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.Queue, asyncio.LifoQueue, and asyncio.PriorityQueue are defined in asyncio.queues; __module__ == 'asyncio.queues'."
    - "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'; asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (internal mixin, not object)."
    - "Top-level coroutine functions create_task, ensure_future, and gather have __module__ == 'asyncio.tasks'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue class identity — table
#
# asyncio.Queue: class name, module, base class, and method __name__ values.
# ---------------------------------------------------------------------------

table asyncio_extra273.queue_identity:
  description: "asyncio.Queue class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: qid

  columns: [id, function, args, expected, description]
  rows:
    - [q_name,         Queue.__name__.__eq__,          ["Queue"],          true, "asyncio.Queue.__name__ == 'Queue'"]
    - [q_module,       Queue.__module__.__eq__,         ["asyncio.queues"], true, "asyncio.Queue.__module__ == 'asyncio.queues'"]
    - [q_get_name,     Queue.get.__name__.__eq__,       ["get"],            true, "asyncio.Queue.get.__name__ == 'get'"]
    - [q_put_name,     Queue.put.__name__.__eq__,       ["put"],            true, "asyncio.Queue.put.__name__ == 'put'"]
    - [q_qsize_name,   Queue.qsize.__name__.__eq__,     ["qsize"],          true, "asyncio.Queue.qsize.__name__ == 'qsize'"]
    - [q_empty_name,   Queue.empty.__name__.__eq__,     ["empty"],          true, "asyncio.Queue.empty.__name__ == 'empty'"]
    - [q_full_name,    Queue.full.__name__.__eq__,      ["full"],           true, "asyncio.Queue.full.__name__ == 'full'"]

# ---------------------------------------------------------------------------
# asyncio task-function module identity — table
#
# create_task, ensure_future, gather all live in asyncio.tasks.
# ---------------------------------------------------------------------------

table asyncio_extra273.task_func_module_identity:
  description: "asyncio top-level coroutine helpers — __module__ and __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: tfid

  columns: [id, function, args, expected, description]
  rows:
    - [ct_module,  create_task.__module__.__eq__,    ["asyncio.tasks"], true, "asyncio.create_task.__module__ == 'asyncio.tasks'"]
    - [ct_name,    create_task.__name__.__eq__,      ["create_task"],   true, "asyncio.create_task.__name__ == 'create_task'"]
    - [ef_module,  ensure_future.__module__.__eq__,  ["asyncio.tasks"], true, "asyncio.ensure_future.__module__ == 'asyncio.tasks'"]
    - [ef_name,    ensure_future.__name__.__eq__,    ["ensure_future"], true, "asyncio.ensure_future.__name__ == 'ensure_future'"]
    - [ga_module,  gather.__module__.__eq__,         ["asyncio.tasks"], true, "asyncio.gather.__module__ == 'asyncio.tasks'"]
    - [ga_name,    gather.__name__.__eq__,           ["gather"],        true, "asyncio.gather.__name__ == 'gather'"]

# ---------------------------------------------------------------------------
# asyncio.Queue base class — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra273.Queue.bases0_name:
  description: "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin'"
  category: identity
  kind: python_call_eq
  function: "Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.LifoQueue identity and inheritance — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra273.LifoQueue.name:
  description: "asyncio.LifoQueue.__name__ == 'LifoQueue'"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__name__.__eq__
  args: ["LifoQueue"]
  expected: true

invariant asyncio_extra273.LifoQueue.module:
  description: "asyncio.LifoQueue.__module__ == 'asyncio.queues'"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra273.LifoQueue.bases0_name:
  description: "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'"
  category: identity
  kind: python_call_eq
  function: "LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.PriorityQueue identity and inheritance — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra273.PriorityQueue.name:
  description: "asyncio.PriorityQueue.__name__ == 'PriorityQueue'"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__name__.__eq__
  args: ["PriorityQueue"]
  expected: true

invariant asyncio_extra273.PriorityQueue.module:
  description: "asyncio.PriorityQueue.__module__ == 'asyncio.queues'"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra273.PriorityQueue.bases0_name:
  description: "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'"
  category: identity
  kind: python_call_eq
  function: "PriorityQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Queue method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra273.Queue.get_qualname:
  description: "asyncio.Queue.get.__qualname__ == 'Queue.get'"
  category: identity
  kind: python_call_eq
  function: Queue.get.__qualname__.__eq__
  args: ["Queue.get"]
  expected: true

invariant asyncio_extra273.Queue.put_qualname:
  description: "asyncio.Queue.put.__qualname__ == 'Queue.put'"
  category: identity
  kind: python_call_eq
  function: Queue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true

invariant asyncio_extra273.Queue.get_nowait_name:
  description: "asyncio.Queue.get_nowait.__name__ == 'get_nowait'"
  category: identity
  kind: python_call_eq
  function: Queue.get_nowait.__name__.__eq__
  args: ["get_nowait"]
  expected: true

invariant asyncio_extra273.Queue.put_nowait_name:
  description: "asyncio.Queue.put_nowait.__name__ == 'put_nowait'"
  category: identity
  kind: python_call_eq
  function: Queue.put_nowait.__name__.__eq__
  args: ["put_nowait"]
  expected: true
