spec: loguru_rust
version: ">=3.9"
backend: rust_module(loguru_rust)

docs: https://loguru.readthedocs.io/

provenance:
  derived_from:
    - "https://loguru.readthedocs.io/ — loguru library documentation"
  not_derived_from:
    - "loguru source: loguru/_logger.py"
  notes:
    - "loguru provides simple logging with no setup required."
    - "loguru.logger.opt(capture=True) — capture log output to string."
    - "Expose log_capture_msg(level, msg) -> str: captures log message text."
    - "Expose log_has_level(level) -> bool: logger has the given level method."
    - "Expose logger_levels() -> list: list of standard level names."
    - "loguru.logger has levels: DEBUG, INFO, WARNING, ERROR, CRITICAL."
    - "logger.info('hello') can be captured via StringIO."
    - "Expose log_format_contains(msg, sub) -> bool: formatted log contains msg."
    - "All test vectors verified against loguru 0.7.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# log_has_level — check logger has standard levels
table loguru_rust.levels.exists:
  kind: python_call_eq
  category: levels
  id_prefix: log_lvl
  function: log_has_level

  columns: [id, args, expected]
  rows:
    - [debug,    ["debug"],    true]
    - [info,     ["info"],     true]
    - [warning,  ["warning"],  true]
    - [error,    ["error"],    true]
    - [critical, ["critical"], true]

# log_format_contains — captured log contains message
table loguru_rust.capture.contains:
  kind: python_call_eq
  category: capture
  id_prefix: log_cap
  function: log_format_contains

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello world", "hello world"], true]
    - [info,   ["test message", "test message"], true]

# logger is not None
invariant loguru_rust.logger.exists:
  description: "loguru.logger is not None"
  category: exists
  kind: python_call_eq
  function: logger_exists
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:31:34Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
