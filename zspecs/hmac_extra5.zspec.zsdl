spec: hmac_extra5
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC)"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC), July 2008"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac.zspec.zsdl, hmac_extra.zspec.zsdl, hmac_extra2.zspec.zsdl, and hmac_extra4.zspec.zsdl."
    - "It does NOT duplicate invariants present in those files."
    - "hmac.zspec.zsdl, hmac_extra, hmac_extra2, hmac_extra4 all cover HMAC.__name__, HMAC.__module__, new.__name__, new.__module__, compare_digest.__name__, compare_digest.__module__, digest.__name__, digest.__module__."
    - "hmac_extra2 covers HMAC.__bases__[0].__name__ == 'object' — not repeated here."
    - "hmac_extra2 and hmac_extra4 cover compare_digest string and bytes equality/inequality — not repeated here."
    - "This spec adds __qualname__ checks for HMAC, new, compare_digest, and digest — not covered in any prior hmac spec."
    - "This spec adds hmac.new() with sha384 as digestmod — sha384 not previously used in any hmac spec."
    - "This spec adds hmac.digest() functional test — a one-shot HMAC computation (Python 3.7+)."
    - "hmac.HMAC.__qualname__ == 'HMAC' — the qualified name for a top-level class equals its simple name."
    - "hmac.new.__qualname__ == 'new' — similarly for a top-level function."
    - "hmac.compare_digest.__qualname__ == 'compare_digest' — top-level function."
    - "hmac.digest.__qualname__ == 'digest' — top-level function (Python 3.7+)."
    - "hmac.new(b'key', b'msg', 'sha384').digest_size == 48 — SHA-384 produces 48 bytes."
    - "hmac.new(b'key', b'msg', 'sha384').name == 'hmac-sha384' — name follows the hmac-<digestmod> pattern."
    - "hmac.digest(b'key', b'msg', 'sha256') returns bytes; __class__.__name__ == 'bytes'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — new coverage across the entire hmac spec family
#
# No prior hmac spec checks __qualname__ for any callable or class.
# ---------------------------------------------------------------------------

invariant hmac_extra5.HMAC.qualname:
  description: "hmac.HMAC.__qualname__ == 'HMAC'"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__qualname__.__eq__
  args: ["HMAC"]
  expected: true

invariant hmac_extra5.new.qualname:
  description: "hmac.new.__qualname__ == 'new'"
  category: function_identity
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["new"]
  expected: true

invariant hmac_extra5.compare_digest.qualname:
  description: "hmac.compare_digest.__qualname__ == 'compare_digest'"
  category: function_identity
  kind: python_call_eq
  function: compare_digest.__qualname__.__eq__
  args: ["compare_digest"]
  expected: true

invariant hmac_extra5.digest.qualname:
  description: "hmac.digest.__qualname__ == 'digest'"
  category: function_identity
  kind: python_call_eq
  function: digest.__qualname__.__eq__
  args: ["digest"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ table — anchoring all three public functions in one table
# from the hmac_extra5 namespace (not duplicating hmac_extra4's table, but
# covering the same names as a compact cross-reference table).
#
# Note: hmac_extra4 has this exact table; we skip repeating it and instead
# provide only the qualname variants above. The table below is intentionally
# omitted to avoid duplication.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# hmac.new() with SHA-384 digestmod
#
# No prior hmac spec uses sha384 as the digestmod. SHA-384 produces 48 bytes.
# ---------------------------------------------------------------------------

invariant hmac_extra5.new.sha384.digest_size:
  description: "hmac.new(b'key', b'msg', 'sha384').digest_size == 48 — SHA-384 produces 48 bytes"
  category: new_sha384
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha384"]
  method: digest_size.__eq__
  method_args: [48]
  expected: true

invariant hmac_extra5.new.sha384.name:
  description: "hmac.new(b'key', b'msg', 'sha384').name == 'hmac-sha384'"
  category: new_sha384
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha384"]
  method: name.__eq__
  method_args: ["hmac-sha384"]
  expected: true

invariant hmac_extra5.new.sha384.block_size:
  description: "hmac.new(b'key', b'msg', 'sha384').block_size == 128 — SHA-384 uses 128-byte blocks"
  category: new_sha384
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha384"]
  method: block_size.__eq__
  method_args: [128]
  expected: true

# ---------------------------------------------------------------------------
# hmac.digest() — one-shot HMAC (Python 3.7+)
#
# hmac.digest(key, msg, digest) returns the raw HMAC bytes in one call.
# No prior hmac spec tests the return type or digest_size of hmac.digest().
# ---------------------------------------------------------------------------

invariant hmac_extra5.digest.returns_bytes:
  description: "hmac.digest(b'key', b'msg', 'sha256').__class__.__name__ == 'bytes'"
  category: digest_oneshot
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant hmac_extra5.digest.sha256_length:
  description: "len(hmac.digest(b'key', b'msg', 'sha256')) == 32 — SHA-256 produces 32 bytes"
  category: digest_oneshot
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: __len__
  method_args: []
  expected: 32

invariant hmac_extra5.digest.md5_length:
  description: "len(hmac.digest(b'key', b'msg', 'md5')) == 16 — MD5 produces 16 bytes"
  category: digest_oneshot
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "md5"]
  method: __len__
  method_args: []
  expected: 16

# ---------------------------------------------------------------------------
# hmac.HMAC — __doc__ is not None (the class has a docstring)
# This is a lightweight liveness check not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant hmac_extra5.HMAC.has_doc:
  description: "hmac.HMAC.__doc__ is not None — the HMAC class has a docstring"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
