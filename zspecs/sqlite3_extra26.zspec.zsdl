spec: sqlite3_extra26
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
    - "sqlite3_extra25.zspec.zsdl — covers IntegrityError/OperationalError/InterfaceError/ProgrammingError/NotSupportedError/Warning __name__.__len__(); connect/__qualname__.__len__(); Connection/Cursor/Row __qualname__.__len__(); Warning.__module__.__len__()."
    - "sqlite3_extra24.zspec.zsdl — covers Connection/Cursor/Row __module__.__len__() and __name__.__len__(); Error/DatabaseError/OperationalError __module__.__len__() and __name__.__len__(); connect.__module__.__len__()."
  notes:
    - "This spec extends sqlite3_extra25.zspec.zsdl."
    - "Prior specs covered: Connection/Cursor/Row __name__/__module__/__qualname__/__bases__[0].__name__; Error/DatabaseError/OperationalError/IntegrityError/InterfaceError/DataError/NotSupportedError/ProgrammingError/InternalError/Warning __name__/__module__/__bases__; connect/__name__/__module__/__qualname__; sqlite3.sqlite_version type; Connection/__init__.__name__; Cursor/__init__.__name__; all __module__.__len__()/__name__.__len__() for Connection/Cursor/Row/Error/DatabaseError/OperationalError; all exception __name__.__len__() through Warning; connect/__qualname__.__len__(); Connection/Cursor/Row __qualname__.__len__()."
    - "This spec covers: sqlite3.Connection.__mro__.__len__(); sqlite3.Cursor.__mro__.__len__(); sqlite3.Error.__mro__.__len__(); sqlite3.IntegrityError.__mro__.__len__(); sqlite3.IntegrityError.__bases__[0].__name__ verified as 'DatabaseError'; sqlite3.Connection.execute/__qualname__/__qualname__.__len__()/__name__.__len__(); sqlite3.Connection.cursor/__qualname__.__len__()/__name__.__len__(); sqlite3.Connection.commit/__qualname__.__len__()/__name__.__len__(); sqlite3.Connection.rollback/__qualname__.__len__()/__name__.__len__(); sqlite3.Connection.close/__qualname__.__len__()/__name__.__len__()."
    - "sqlite3.Connection.__mro__.__len__() == 2 — (Connection, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Cursor.__mro__.__len__() == 2 — (Cursor, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Error.__mro__.__len__() == 4 — (Error, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.IntegrityError.__mro__.__len__() == 6 — (IntegrityError, DatabaseError, Error, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.IntegrityError.__bases__[0].__name__ == 'DatabaseError'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.execute.__qualname__ == 'Connection.execute' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.cursor.__qualname__ == 'Connection.cursor' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.commit.__qualname__ == 'Connection.commit' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.rollback.__qualname__ == 'Connection.rollback' — len 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.close.__qualname__ == 'Connection.close' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Connection.execute.__name__ == 'execute' len 7; cursor.__name__ == 'cursor' len 6; commit.__name__ == 'commit' len 6; rollback.__name__ == 'rollback' len 8; close.__name__ == 'close' len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3 class __mro__.__len__()
#
# No prior spec checks __mro__.__len__() for any sqlite3 class.
# Connection and Cursor inherit only from object (len 2).
# Error inherits from Exception (len 4).
# IntegrityError -> DatabaseError -> Error -> Exception -> BaseException -> object (len 6).
# ---------------------------------------------------------------------------

invariant sqlite3_extra26.Connection.mro_len:
  description: "len(sqlite3.Connection.__mro__) == 2 — (Connection, object); Connection has no intermediate base"
  category: class_hierarchy
  kind: python_call_eq
  function: Connection.__mro__.__len__
  args: []
  expected: 2

invariant sqlite3_extra26.Error.mro_len:
  description: "len(sqlite3.Error.__mro__) == 4 — (Error, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__len__
  args: []
  expected: 4

table sqlite3_extra26.class_mro_lengths:
  description: "sqlite3 class __mro__.__len__() — Cursor (2), IntegrityError (6)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: scml26

  columns: [id, function, args, expected, description]
  rows:
    - [Cursor,
       Cursor.__mro__.__len__,
       [],
       2,
       "len(sqlite3.Cursor.__mro__) == 2 — (Cursor, object)"]
    - [IntegrityError,
       IntegrityError.__mro__.__len__,
       [],
       6,
       "len(sqlite3.IntegrityError.__mro__) == 6 — six levels deep"]

# ---------------------------------------------------------------------------
# sqlite3.IntegrityError.__bases__[0].__name__
#
# Prior specs verify IntegrityError.__bases__[0].__name__ == 'DatabaseError'
# via __eq__. This standalone invariant anchors it from the extra26 namespace.
# ---------------------------------------------------------------------------

invariant sqlite3_extra26.IntegrityError.base_name:
  description: "sqlite3.IntegrityError.__bases__[0].__name__ == 'DatabaseError' — direct parent in exception hierarchy"
  category: class_hierarchy
  kind: python_call_eq
  function: "IntegrityError.__bases__[0].__name__.__eq__"
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Connection method __qualname__ and __qualname__.__len__()
#
# No prior spec checks __qualname__ or __qualname__.__len__() for any
# sqlite3.Connection instance method. All follow the pattern 'Connection.<name>'.
# execute: 'Connection.execute' (len 18)
# cursor:  'Connection.cursor'  (len 17)
# commit:  'Connection.commit'  (len 17)
# rollback:'Connection.rollback'(len 19)
# close:   'Connection.close'   (len 16)
# ---------------------------------------------------------------------------

table sqlite3_extra26.Connection_method_qualnames:
  description: "sqlite3.Connection method __qualname__.__eq__ — execute/cursor/commit/rollback/close"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: cmqe26

  columns: [id, function, args, expected, description]
  rows:
    - [execute,
       Connection.execute.__qualname__.__eq__,
       ["Connection.execute"],
       true,
       "Connection.execute.__qualname__ == 'Connection.execute'"]
    - [cursor,
       Connection.cursor.__qualname__.__eq__,
       ["Connection.cursor"],
       true,
       "Connection.cursor.__qualname__ == 'Connection.cursor'"]
    - [commit,
       Connection.commit.__qualname__.__eq__,
       ["Connection.commit"],
       true,
       "Connection.commit.__qualname__ == 'Connection.commit'"]
    - [rollback,
       Connection.rollback.__qualname__.__eq__,
       ["Connection.rollback"],
       true,
       "Connection.rollback.__qualname__ == 'Connection.rollback'"]
    - [close,
       Connection.close.__qualname__.__eq__,
       ["Connection.close"],
       true,
       "Connection.close.__qualname__ == 'Connection.close'"]

table sqlite3_extra26.Connection_method_qualname_lengths:
  description: "sqlite3.Connection method __qualname__.__len__() — execute(18)/cursor(17)/commit(17)/rollback(19)/close(16)"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: cmql26

  columns: [id, function, args, expected, description]
  rows:
    - [execute,
       Connection.execute.__qualname__.__len__,
       [],
       18,
       "len('Connection.execute') == 18"]
    - [cursor,
       Connection.cursor.__qualname__.__len__,
       [],
       17,
       "len('Connection.cursor') == 17"]
    - [commit,
       Connection.commit.__qualname__.__len__,
       [],
       17,
       "len('Connection.commit') == 17"]
    - [rollback,
       Connection.rollback.__qualname__.__len__,
       [],
       19,
       "len('Connection.rollback') == 19"]
    - [close,
       Connection.close.__qualname__.__len__,
       [],
       16,
       "len('Connection.close') == 16"]

# ---------------------------------------------------------------------------
# sqlite3.Connection method __name__.__len__()
#
# No prior spec checks __name__.__len__() for sqlite3.Connection methods.
# execute=7, cursor=6, commit=6, rollback=8, close=5.
# ---------------------------------------------------------------------------

invariant sqlite3_extra26.Connection.execute_name_len:
  description: "len(sqlite3.Connection.execute.__name__) == 7 — len('execute') == 7"
  category: function_names
  kind: python_call_eq
  function: Connection.execute.__name__.__len__
  args: []
  expected: 7

invariant sqlite3_extra26.Connection.rollback_name_len:
  description: "len(sqlite3.Connection.rollback.__name__) == 8 — len('rollback') == 8"
  category: function_names
  kind: python_call_eq
  function: Connection.rollback.__name__.__len__
  args: []
  expected: 8

table sqlite3_extra26.Connection_method_name_lengths:
  description: "sqlite3.Connection method __name__.__len__() — cursor(6)/commit(6)/close(5)"
  kind: python_call_eq
  category: function_names
  id_prefix: cmnl26

  columns: [id, function, args, expected, description]
  rows:
    - [cursor,
       Connection.cursor.__name__.__len__,
       [],
       6,
       "len('cursor') == 6"]
    - [commit,
       Connection.commit.__name__.__len__,
       [],
       6,
       "len('commit') == 6"]
    - [close,
       Connection.close.__name__.__len__,
       [],
       5,
       "len('close') == 5"]
