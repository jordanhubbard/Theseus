spec: hashlib_extra205
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "hashlib.__spec__.name == 'hashlib' — the ModuleSpec name matches the module name."
    - "hashlib.__spec__.has_location == True — hashlib is a Python source file with a known location on disk."
    - "hashlib.__spec__.parent == '' — hashlib is a top-level module; parent is the empty string."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance."
    - "hashlib.__spec__.origin.__class__.__name__ == 'str' — the origin attribute (path to hashlib.py) is a plain str."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__spec__ deeper attributes — name, has_location, parent
# ---------------------------------------------------------------------------

table hashlib_extra205.spec_name_has_location_parent:
  description: "hashlib __spec__ name, has_location, and parent attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibspec205nhp

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,              __spec__.name.__eq__,                          ["hashlib"], true, "hashlib.__spec__.name == 'hashlib'"]
    - [spec_name_is_str,          __spec__.name.__class__.__name__.__eq__,       ["str"],     true, "hashlib.__spec__.name is a str object"]
    - [spec_has_location_true,    __spec__.has_location.__eq__,                  [true],      true, "hashlib.__spec__.has_location == True — hashlib.py has a known file location"]
    - [spec_has_location_is_bool, __spec__.has_location.__class__.__name__.__eq__, ["bool"],  true, "hashlib.__spec__.has_location is a bool object"]
    - [spec_parent_empty,         __spec__.parent.__eq__,                        [""],        true, "hashlib.__spec__.parent == '' — hashlib is a top-level module"]
    - [spec_parent_is_str,        __spec__.parent.__class__.__name__.__eq__,     ["str"],     true, "hashlib.__spec__.parent is a str object"]

# ---------------------------------------------------------------------------
# hashlib.__spec__ deeper attributes — __class__.__name__ and origin type
# ---------------------------------------------------------------------------

table hashlib_extra205.spec_class_origin_type:
  description: "hashlib __spec__ class name and origin type attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibspec205cot

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,      __spec__.__class__.__name__.__eq__,         ["ModuleSpec"], true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_origin_class_str,      __spec__.origin.__class__.__name__.__eq__,  ["str"],        true, "hashlib.__spec__.origin.__class__.__name__ == 'str' — origin is a file path string"]
    - [spec_name_matches_module,   __spec__.name.__eq__,                        ["hashlib"],   true, "hashlib.__spec__.name equals the module name 'hashlib'"]
    - [spec_parent_not_none,       __spec__.parent.__class__.__name__.__eq__,   ["str"],       true, "hashlib.__spec__.parent is a str (not None)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__ deeper attributes — loader and submodule_search_locations
# ---------------------------------------------------------------------------

table hashlib_extra205.spec_loader_search_locations:
  description: "hashlib __spec__ loader class name and submodule_search_locations checks"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibspec205lsl

  columns: [id, function, args, expected, description]
  rows:
    - [spec_loader_class_eq,        __spec__.loader.__class__.__name__.__eq__, ["SourceFileLoader"], true, "hashlib.__spec__.loader.__class__.__name__ == 'SourceFileLoader'"]
    - [spec_loader_module_eq,       __spec__.loader.__class__.__module__.__eq__, ["_frozen_importlib_external"], true, "hashlib.__spec__.loader lives in _frozen_importlib_external"]
    - [spec_has_location_is_bool2,  __spec__.has_location.__class__.__name__.__eq__, ["bool"], true, "hashlib.__spec__.has_location type is bool (re-confirmed via loader table)"]
    - [spec_class_name_is_str,      __spec__.__class__.__name__.__class__.__name__.__eq__, ["str"], true, "hashlib.__spec__.__class__.__name__ is itself a str"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant hashlib_extra205.spec_name_eq:
  description: "hashlib.__spec__.name == 'hashlib'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra205.spec_has_location_true:
  description: "hashlib.__spec__.has_location == True — hashlib is a Python source file with a known disk location"
  category: identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant hashlib_extra205.spec_parent_empty:
  description: "hashlib.__spec__.parent == '' — hashlib is a top-level module, not a submodule"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant hashlib_extra205.spec_class_name_modulespec:
  description: "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant hashlib_extra205.spec_origin_class_name_str:
  description: "hashlib.__spec__.origin.__class__.__name__ == 'str' — origin is the path string to hashlib.py"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra205.spec_name_is_str:
  description: "hashlib.__spec__.name.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra205.spec_parent_is_str:
  description: "hashlib.__spec__.parent.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra205.spec_loader_class_name_eq:
  description: "hashlib.__spec__.loader.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __spec__.loader.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
