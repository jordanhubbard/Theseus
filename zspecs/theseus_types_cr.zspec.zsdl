spec: theseus_types_cr
version: ">=3.9"
backend: python_cleanroom(theseus_types_cr)
blocks: types

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html"
  notes:
    - "Clean-room type objects and dynamic class creation. Do NOT import types."
    - "FunctionType: type of Python functions."
    - "LambdaType: alias for FunctionType."
    - "new_class(name, bases, kwds, exec_body): dynamic class creation."
    - "SimpleNamespace(**kwargs): simple attribute-based namespace object."
    - "types_function_type(): isinstance(lambda: None, FunctionType) == True."
    - "types_simple_namespace(): SimpleNamespace(x=1).x == 1."
    - "types_new_class(): new_class('Foo', (object,), {}) is a class."
    - "Export: FunctionType, LambdaType, SimpleNamespace, new_class."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_types_cr.function_type:
  description: "isinstance(lambda: None, FunctionType) == True"
  category: types
  kind: python_call_eq
  function: types_function_type
  args: []
  expected: true

invariant theseus_types_cr.simple_namespace:
  description: "SimpleNamespace(x=1).x == 1"
  category: namespace
  kind: python_call_eq
  function: types_simple_namespace
  args: []
  expected: 1

invariant theseus_types_cr.new_class:
  description: "new_class('Foo', (object,)) creates a class"
  category: new_class
  kind: python_call_eq
  function: types_new_class
  args: []
  expected: true
