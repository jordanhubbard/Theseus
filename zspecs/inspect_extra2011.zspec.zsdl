# ---------------------------------------------------------------------------
# Table 4: cross-operator summary — full 9-dunder check for inspect.Signature
#
# Confirms all 9 arithmetic dunders absent from inspect.Signature as a
# consolidated cross-check.
# ---------------------------------------------------------------------------

table inspect_extra2011.signature_all_arithmetic:
  description: "inspect.Signature dict-presence for all 9 add/mul/sub dunders — all False — wave 581 _extra2011"
