spec: inspect_extra2011
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "inspect classes are introspection utilities — none define arithmetic operators."
    - "inspect.Parameter: Python class representing a callable parameter — arithmetic dunders absent from __dict__."
    - "inspect.Signature: Python class representing a callable signature — arithmetic dunders absent from __dict__."
    - "inspect.BoundArguments: Python class representing bound arguments — arithmetic dunders absent from __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __add__ / __radd__ / __iadd__ dict-presence for inspect classes
#
# inspect.Parameter, inspect.Signature, and inspect.BoundArguments are
# introspection utility types. They carry no numeric semantics and define
# no addition operators in their __dict__.
# All checks expected False.
# ---------------------------------------------------------------------------

table inspect_extra2011.add_protocol:
  description: "inspect classes __add__/__radd__/__iadd__ dict-presence checks — all False — wave 581 _extra2011"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2011

  columns: [id, function, args, expected]
  rows:
    - ["in2011001", "inspect.Parameter.__dict__.__contains__", ["__add__"], false]
    - ["in2011002", "inspect.Parameter.__dict__.__contains__", ["__radd__"], false]
    - ["in2011003", "inspect.Parameter.__dict__.__contains__", ["__iadd__"], false]
    - ["in2011004", "inspect.Signature.__dict__.__contains__", ["__add__"], false]
    - ["in2011005", "inspect.Signature.__dict__.__contains__", ["__radd__"], false]
    - ["in2011006", "inspect.Signature.__dict__.__contains__", ["__iadd__"], false]
    - ["in2011007", "inspect.BoundArguments.__dict__.__contains__", ["__add__"], false]
    - ["in2011008", "inspect.BoundArguments.__dict__.__contains__", ["__radd__"], false]
    - ["in2011009", "inspect.BoundArguments.__dict__.__contains__", ["__iadd__"], false]

