spec: socket_rust
version: ">=3.9"
backend: rust_module(socket_rust)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket documentation"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python socket constants, exposed via PyO3."
    - "AF_INET == 2 — IPv4 address family (POSIX universal)."
    - "AF_UNIX == 1 — Unix domain socket family."
    - "SOCK_STREAM == 1 — TCP-style stream socket."
    - "SOCK_DGRAM == 2 — UDP-style datagram socket."
    - "IPPROTO_TCP == 6 — TCP protocol number (IANA assigned)."
    - "IPPROTO_UDP == 17 — UDP protocol number (IANA assigned)."
    - "socket.gethostname() is system-dependent and not tested."
    - "All test vectors verified against Python 3.14.3 socket module on Linux/macOS."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Address family constants
table socket_rust.address_family.vectors:
  kind: python_call_eq
  category: constants
  id_prefix: sock_af

  columns: [id, function, args, expected]
  rows:
    - [af_inet,  AF_INET.__eq__,  [2], true]
    - [af_unix,  AF_UNIX.__eq__,  [1], true]

# Socket type constants
table socket_rust.socket_type.vectors:
  kind: python_call_eq
  category: constants
  id_prefix: sock_type

  columns: [id, function, args, expected]
  rows:
    - [sock_stream, SOCK_STREAM.__eq__, [1], true]
    - [sock_dgram,  SOCK_DGRAM.__eq__,  [2], true]

# Protocol constants
table socket_rust.protocol.vectors:
  kind: python_call_eq
  category: constants
  id_prefix: sock_proto

  columns: [id, function, args, expected]
  rows:
    - [ipproto_tcp, IPPROTO_TCP.__eq__, [6],  true]
    - [ipproto_udp, IPPROTO_UDP.__eq__, [17], true]

# htons / ntohs — byte order conversion (deterministic for known values)
table socket_rust.byte_order.vectors:
  kind: python_call_eq
  category: byte_order
  id_prefix: sock_bo

  columns: [id, function, args, expected]
  rows:
    - [htons_80,   htons,  [80],   20480]
    - [ntohs_20480, ntohs, [20480], 80]
    - [htons_0,    htons,  [0],    0]
    - [htons_443,  htons,  [443],  47873]

