spec: standard_deviation
version: ">=1.0.0"
backend: node(standard-deviation)

docs: https://www.npmjs.com/package/standard-deviation

provenance:
  derived_from:
    - "standard-deviation README — https://www.npmjs.com/package/standard-deviation"
    - "Test vectors verified with standard-deviation via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "standard-deviation source"
  notes:
    - "standard-deviation is an npm package. Install: npm install standard-deviation variance"
    - "Returns the population standard deviation of an array of numbers."
    - "Requires variance as an undeclared peer dependency (not listed in its package.json)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table standard_deviation.calculate:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: stddev

  columns: [id, args, expected]
  rows:
    - [classic,  [[2, 4, 4, 4, 5, 5, 7, 9]],  2]
    - [single,   [[42]],                       0]

