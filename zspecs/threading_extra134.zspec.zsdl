spec: threading_extra134
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread class identity and method qualnames (__init__, start, run, join, is_alive) plus code attributes (Wave 261)."
    - "threading.Thread.__name__ == 'Thread' (len 6) — Thread class defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.__class__.__name__ == 'type' — Thread is a Python class. Verified with Python 3.14.3."
    - "threading.Thread.__qualname__ == 'Thread' (len 6). Verified with Python 3.14.3."
    - "threading.Thread.__mro__ len == 2 — MRO is [Thread, object]. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_argcount == 6 — self, group, target, name, args, kwargs. Verified with Python 3.14.3."
    - "len(threading.Thread.__init__.__code__.co_varnames) == 9 — 9 local variables. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' (len 12). Verified with Python 3.14.3."
    - "threading.Thread.start.__code__.co_argcount == 1 — takes only self. Verified with Python 3.14.3."
    - "len(threading.Thread.start.__code__.co_varnames) == 1. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' (len 10). Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_argcount == 1 — takes only self. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' (len 11). Verified with Python 3.14.3."
    - "threading.Thread.join.__code__.co_argcount == 2 — self and timeout. Verified with Python 3.14.3."
    - "len(threading.Thread.join.__code__.co_varnames) == 2. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__code__.co_argcount == 1 — takes only self. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread class identity (__name__, __module__, __class__.__name__, __qualname__)
#
# Wave 261 theme: threading.Thread class identity.
#
# threading.Thread.__name__ == 'Thread' (len 6)
# threading.Thread.__module__ == 'threading'
# threading.Thread.__class__.__name__ == 'type'
# threading.Thread.__qualname__ == 'Thread' (len 6)
# len(threading.Thread.__mro__) == 2
# threading.Thread.__bases__[0].__name__ == 'object'
#
# Thread is a Python class defined in Lib/threading.py with no explicit base
# (inherits from object). New to extra134.
# ---------------------------------------------------------------------------

table threading_extra134.thread_class_identity:
  description: "threading.Thread class identity: __name__=='Thread' (len 6), __module__=='threading', __class__.__name__=='type', __qualname__ len 6, MRO len 2; wave 261; new to extra134"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread134

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq_thread,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is a Python class defined with 'class Thread:' in Lib/threading.py; the __name__ attribute of a class equals the identifier after 'class'; str.__eq__('Thread') returns True; new to extra134"]
    - [thread_name_len_eq_6,
       "Thread.__name__.__len__",
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — __name__ is 'Thread' which has 6 characters; len('Thread') == 6; new to extra134"]
    - [thread_module_eq_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra134"]
    - [thread_class_name_eq_type,
       "Thread.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Thread.__class__.__name__.__eq__('type') == True — Thread is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra134"]
    - [thread_qualname_eq_thread,
       "Thread.__qualname__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is defined at module scope in Lib/threading.py; __qualname__ equals the class name; str.__eq__('Thread') returns True; new to extra134"]
    - [thread_qualname_len_eq_6,
       "Thread.__qualname__.__len__",
       [],
       6,
       "threading.Thread.__qualname__.__len__() == 6 — __qualname__ is 'Thread' which has 6 characters; len('Thread') == 6; new to extra134"]
    - [thread_mro_len_eq_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread's MRO is [Thread, object]; it inherits only from object; len(__mro__) is 2; new to extra134"]
    - [thread_bases_first_eq_object,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread inherits only from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra134"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.__init__ qualname and code attributes
#
# Wave 261 theme: Thread.__init__ qualname and co_argcount.
#
# threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15)
# threading.Thread.__init__.__class__.__name__ == 'function'
# threading.Thread.__init__.__code__.co_argcount == 6
# len(threading.Thread.__init__.__code__.co_varnames) == 9
# threading.Thread.__init__.__code__.co_varnames[0] == 'self'
# threading.Thread.__init__.__code__.co_varnames[2] == 'target'
#
# Thread.__init__ takes (self, group, target, name, args, kwargs) plus
# 3 internal local variables (daemon, context, target_name). New to extra134.
# ---------------------------------------------------------------------------

table threading_extra134.thread_init_attrs:
  description: "threading.Thread.__init__ qualname len 15, co_argcount==6, co_varnames len 9, co_varnames[0]=='self', co_varnames[2]=='target'; wave 261; new to extra134"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinginit134

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_qualname_eq,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread.__init__ is a method defined inside the Thread class body in Lib/threading.py; its __qualname__ includes the enclosing class name; str.__eq__('Thread.__init__') returns True; new to extra134"]
    - [thread_init_qualname_len_eq_15,
       "Thread.__init__.__qualname__.__len__",
       [],
       15,
