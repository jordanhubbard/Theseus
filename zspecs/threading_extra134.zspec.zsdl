       "Thread.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.__init__.__class__.__name__.__eq__('function') == True — Thread.__init__ is a regular Python function defined inside the class body; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra134"]
    - [thread_init_co_argcount_eq_6,
       "Thread.__init__.__code__.co_argcount.__eq__",
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__ takes 6 positional arguments: self, group, target, name, args, kwargs; co_argcount is 6; int.__eq__(6) returns True; new to extra134"]
    - [thread_init_co_varnames_len_eq_9,
       "Thread.__init__.__code__.co_varnames.__len__",
       [],
       9,
       "threading.Thread.__init__.__code__.co_varnames.__len__() == 9 — Thread.__init__ has 9 local variables: self, group, target, name, args, kwargs, daemon, context, target_name; len(co_varnames) == 9; new to extra134"]
    - [thread_init_co_varnames_0_eq_self,
       "Thread.__init__.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Thread.__init__.__code__.co_varnames[0].__eq__('self') == True — the first local variable of Thread.__init__ is 'self'; str.__eq__('self') returns True; new to extra134"]
    - [thread_init_co_varnames_2_eq_target,
       "Thread.__init__.__code__.co_varnames[2].__eq__",
       ["target"],
       true,
       "threading.Thread.__init__.__code__.co_varnames[2].__eq__('target') == True — the third local variable of Thread.__init__ is 'target', the callable to run in the thread; str.__eq__('target') returns True; new to extra134"]

