spec: concurrent_futures_extra325
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers executor method identity via __qualname__ for ThreadPoolExecutor, Executor, and Future."
    - "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' — overrides Executor.submit."
    - "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — inherited from Executor without override."
    - "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' — overrides Executor.shutdown."
    - "Executor.submit.__qualname__ == 'Executor.submit' — abstract base method."
    - "Executor.map.__qualname__ == 'Executor.map' — concrete method on Executor."
    - "Executor.shutdown.__qualname__ == 'Executor.shutdown' — concrete method on Executor."
    - "Future.add_done_callback.__qualname__ == 'Future.add_done_callback'."
    - "Future.cancel.__qualname__ == 'Future.cancel'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __qualname__ values
#
# ThreadPoolExecutor overrides submit() and shutdown() from Executor, so those
# methods carry ThreadPoolExecutor-prefixed qualnames. The map() method is not
# overridden — it is inherited from Executor, so its qualname is 'Executor.map'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra325.ThreadPoolExecutor.submit_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'"
  category: thread_pool_executor_methods
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra325.ThreadPoolExecutor.map_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — inherited, not overridden"
  category: thread_pool_executor_methods
  kind: python_call_eq
  function: ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra325.ThreadPoolExecutor.shutdown_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'"
  category: thread_pool_executor_methods
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# Executor abstract base method __qualname__ values
#
# Executor defines submit() as an abstract method and map()/shutdown() as
# concrete methods. All three carry 'Executor.' prefixed qualnames.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra325.Executor.submit_qualname:
  description: "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit'"
  category: executor_methods
  kind: python_call_eq
  function: Executor.submit.__qualname__.__eq__
  args: ["Executor.submit"]
  expected: true

invariant concurrent_futures_extra325.Executor.map_qualname:
  description: "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'"
  category: executor_methods
  kind: python_call_eq
  function: Executor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra325.Executor.shutdown_qualname:
  description: "concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown'"
  category: executor_methods
  kind: python_call_eq
  function: Executor.shutdown.__qualname__.__eq__
  args: ["Executor.shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# Future method __qualname__ values
#
# concurrent.futures.Future defines its own methods; none are inherited from
# a custom base, so all qualnames carry 'Future.' as a prefix.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra325.Future.add_done_callback_qualname:
  description: "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback'"
  category: future_methods
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__eq__
  args: ["Future.add_done_callback"]
  expected: true

invariant concurrent_futures_extra325.Future.cancel_qualname:
  description: "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel'"
  category: future_methods
  kind: python_call_eq
  function: Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true
