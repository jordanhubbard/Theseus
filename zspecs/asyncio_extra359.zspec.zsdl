spec: asyncio_extra359
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-queue.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queue documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.Queue lives in module asyncio.queues and derives from _LoopBoundMixin"
    - "asyncio.LifoQueue and asyncio.PriorityQueue both live in asyncio.queues and derive from Queue"
    - "asyncio.QueueEmpty and asyncio.QueueFull both live in asyncio.queues and derive from Exception"
    - "_LoopBoundMixin is an internal asyncio mixin class"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra359.queue_names:
  description: "Verify __name__ attribute of asyncio Queue-related classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio359n

  columns: [id, function, args, expected]
  rows:
    - [aio359n001, asyncio.Queue.__name__.__eq__, ["Queue"], true]
    - [aio359n002, asyncio.LifoQueue.__name__.__eq__, ["LifoQueue"], true]
    - [aio359n003, asyncio.PriorityQueue.__name__.__eq__, ["PriorityQueue"], true]
    - [aio359n004, asyncio.QueueEmpty.__name__.__eq__, ["QueueEmpty"], true]
    - [aio359n005, asyncio.QueueFull.__name__.__eq__, ["QueueFull"], true]

table asyncio_extra359.queue_modules:
  description: "Verify __module__ attribute of asyncio Queue-related classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio359m

  columns: [id, function, args, expected]
  rows:
    - [aio359m001, asyncio.Queue.__module__.__eq__, ["asyncio.queues"], true]
    - [aio359m002, asyncio.LifoQueue.__module__.__eq__, ["asyncio.queues"], true]
    - [aio359m003, asyncio.PriorityQueue.__module__.__eq__, ["asyncio.queues"], true]
    - [aio359m004, asyncio.QueueEmpty.__module__.__eq__, ["asyncio.queues"], true]
    - [aio359m005, asyncio.QueueFull.__module__.__eq__, ["asyncio.queues"], true]

table asyncio_extra359.queue_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of asyncio Queue-related classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio359b

  columns: [id, function, args, expected]
  rows:
    - ["aio359b001", "asyncio.Queue.__bases__[0].__name__.__eq__", ["_LoopBoundMixin"], true]
    - ["aio359b002", "asyncio.LifoQueue.__bases__[0].__name__.__eq__", ["Queue"], true]
    - ["aio359b003", "asyncio.PriorityQueue.__bases__[0].__name__.__eq__", ["Queue"], true]
    - ["aio359b004", "asyncio.QueueEmpty.__bases__[0].__name__.__eq__", ["Exception"], true]
    - ["aio359b005", "asyncio.QueueFull.__bases__[0].__name__.__eq__", ["Exception"], true]
