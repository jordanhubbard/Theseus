spec: concurrent_futures_extra301
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "ThreadPoolExecutor(max_workers=0) raises ValueError — max_workers must be greater than 0."
    - "ProcessPoolExecutor(max_workers=0) raises ValueError — max_workers must be greater than 0."
    - "wait.__module__ and as_completed.__module__ both resolve to 'concurrent.futures._base'."
    - "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — BrokenExecutor extends RuntimeError."
    - "InvalidStateError.__bases__[0].__name__ == 'Error' — the concurrent.futures._base.Error base class."
    - "InvalidStateError MRO: InvalidStateError -> Error -> Exception -> BaseException -> object."
    - "All expected values verified by running Python 3.14.3 concurrent.futures module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor(max_workers=0) — raises ValueError
#
# max_workers must be > 0; passing 0 is rejected immediately on construction.
# ---------------------------------------------------------------------------

invariant concurrent_futures.error.threadpool_zero_workers:
  description: "ThreadPoolExecutor(max_workers=0) raises ValueError — max_workers must be greater than 0"
  category: error
  kind: python_call_raises
  function: ThreadPoolExecutor
  args: []
  kwargs: {max_workers: 0}
  raises: ValueError

# ---------------------------------------------------------------------------
# ProcessPoolExecutor(max_workers=0) — raises ValueError
#
# Same guard applies to ProcessPoolExecutor.
# ---------------------------------------------------------------------------

invariant concurrent_futures.error.processpool_zero_workers:
  description: "ProcessPoolExecutor(max_workers=0) raises ValueError — max_workers must be greater than 0"
  category: error
  kind: python_call_raises
  function: ProcessPoolExecutor
  args: []
  kwargs: {max_workers: 0}
  raises: ValueError

# ---------------------------------------------------------------------------
# wait — function module affiliation
# ---------------------------------------------------------------------------

invariant concurrent_futures.wait.module:
  description: "concurrent.futures.wait.__module__ == 'concurrent.futures._base'"
  category: wait
  kind: python_call_eq
  function: wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# as_completed — function module affiliation
# ---------------------------------------------------------------------------

invariant concurrent_futures.as_completed.module:
  description: "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'"
  category: as_completed
  kind: python_call_eq
  function: as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenExecutor — exception class identity
#
# BrokenExecutor extends RuntimeError (not Exception directly).
# ---------------------------------------------------------------------------

invariant concurrent_futures.brokenexecutor.name:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"
  category: brokenexecutor
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures.brokenexecutor.base_name:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: brokenexecutor
  kind: python_call_eq
  function: BrokenExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RuntimeError"

# ---------------------------------------------------------------------------
# InvalidStateError — exception class identity
#
# InvalidStateError inherits from concurrent.futures._base.Error.
# __bases__[0].__name__ == 'Error'.
# ---------------------------------------------------------------------------

invariant concurrent_futures.invalidstateerror.name:
  description: "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'"
  category: invalidstateerror
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures.invalidstateerror.base_name:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error' — inherits from cf._base.Error"
  category: invalidstateerror
  kind: python_call_eq
  function: InvalidStateError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"
