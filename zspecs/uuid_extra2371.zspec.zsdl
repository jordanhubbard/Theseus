spec: uuid_extra2371
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID is a plain Python class; __class__.__name__ == 'type'."
    - "uuid.SafeUUID is an IntEnum subclass defined via EnumMeta; __class__.__name__ == 'EnumType'."
    - "uuid.uuid1, uuid3, uuid4, uuid5, getnode are plain Python functions; __class__.__name__ == 'function'."
    - "uuid.NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500 are UUID instances; __class__.__name__ == 'UUID'."
  created_at: "2026-04-12"

table uuid_extra2371.object_types:
  description: "uuid module-level object type classification via __class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2371
  columns: [id, function, args, expected]
  rows:
    - ["uu2371001", "uuid.UUID.__class__.__name__", [], "type"]
    - ["uu2371002", "uuid.SafeUUID.__class__.__name__", [], "EnumType"]
    - ["uu2371003", "uuid.uuid1.__class__.__name__", [], "function"]
    - ["uu2371004", "uuid.uuid3.__class__.__name__", [], "function"]
    - ["uu2371005", "uuid.uuid4.__class__.__name__", [], "function"]
    - ["uu2371006", "uuid.uuid5.__class__.__name__", [], "function"]
    - ["uu2371007", "uuid.NAMESPACE_DNS.__class__.__name__", [], "UUID"]
    - ["uu2371008", "uuid.NAMESPACE_URL.__class__.__name__", [], "UUID"]
    - ["uu2371009", "uuid.NAMESPACE_OID.__class__.__name__", [], "UUID"]
    - ["uu2371010", "uuid.NAMESPACE_X500.__class__.__name__", [], "UUID"]
    - ["uu2371011", "uuid.getnode.__class__.__name__", [], "function"]

table uuid_extra2371.type_eq_checks:
  description: "uuid type and enum objects: confirm __class__.__name__ via equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2371
  columns: [id, function, args, expected]
  rows:
    - ["uu2371012", "uuid.UUID.__class__.__name__.__eq__", ["type"], true]
    - ["uu2371013", "uuid.SafeUUID.__class__.__name__.__eq__", ["EnumType"], true]

table uuid_extra2371.function_eq_checks:
  description: "uuid generator functions: confirm __class__.__name__ == 'function' via equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2371
  columns: [id, function, args, expected]
  rows:
    - ["uu2371014", "uuid.uuid1.__class__.__name__.__eq__", ["function"], true]
    - ["uu2371015", "uuid.uuid3.__class__.__name__.__eq__", ["function"], true]
    - ["uu2371016", "uuid.uuid4.__class__.__name__.__eq__", ["function"], true]
    - ["uu2371017", "uuid.uuid5.__class__.__name__.__eq__", ["function"], true]
    - ["uu2371018", "uuid.getnode.__class__.__name__.__eq__", ["function"], true]

table uuid_extra2371.namespace_eq_checks:
  description: "uuid NAMESPACE_* constants: confirm __class__.__name__ == 'UUID' via equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2371
  columns: [id, function, args, expected]
  rows:
    - ["uu2371019", "uuid.NAMESPACE_DNS.__class__.__name__.__eq__", ["UUID"], true]
    - ["uu2371020", "uuid.NAMESPACE_URL.__class__.__name__.__eq__", ["UUID"], true]
    - ["uu2371021", "uuid.NAMESPACE_OID.__class__.__name__.__eq__", ["UUID"], true]
    - ["uu2371022", "uuid.NAMESPACE_X500.__class__.__name__.__eq__", ["UUID"], true]
