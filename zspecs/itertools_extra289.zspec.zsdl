spec: itertools_extra289
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools C extension type identity attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "starmap, filterfalse, islice, count, dropwhile, takewhile are C types (class 'type')"
    - "tee is a builtin_function_or_method, not a type"
    - "All itertools objects have __module__ == 'itertools'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra289.names:
  description: "__name__ for itertools C extension types and functions"
  kind: python_call_eq
  category: identity
  id_prefix: ite289n

  columns: [id, function, args, expected, description]
  rows:
    - [ite289n001, itertools.starmap.__name__.__eq__, ["starmap"], true, "starmap __name__"]
    - [ite289n002, itertools.filterfalse.__name__.__eq__, ["filterfalse"], true, "filterfalse __name__"]
    - [ite289n003, itertools.islice.__name__.__eq__, ["islice"], true, "islice __name__"]
    - [ite289n004, itertools.tee.__name__.__eq__, ["tee"], true, "tee __name__"]
    - [ite289n005, itertools.count.__name__.__eq__, ["count"], true, "count __name__"]
    - [ite289n006, itertools.dropwhile.__name__.__eq__, ["dropwhile"], true, "dropwhile __name__"]
    - [ite289n007, itertools.takewhile.__name__.__eq__, ["takewhile"], true, "takewhile __name__"]

table itertools_extra289.class_names:
  description: "__class__.__name__ for itertools objects (type vs builtin_function_or_method)"
  kind: python_call_eq
  category: identity
  id_prefix: ite289c

  columns: [id, function, args, expected, description]
  rows:
    - [ite289c001, itertools.starmap.__class__.__name__.__eq__, ["type"], true, "starmap is a C type"]
    - [ite289c002, itertools.filterfalse.__class__.__name__.__eq__, ["type"], true, "filterfalse is a C type"]
    - [ite289c003, itertools.islice.__class__.__name__.__eq__, ["type"], true, "islice is a C type"]
    - [ite289c004, itertools.tee.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "tee is a builtin function"]
    - [ite289c005, itertools.count.__class__.__name__.__eq__, ["type"], true, "count is a C type"]
    - [ite289c006, itertools.dropwhile.__class__.__name__.__eq__, ["type"], true, "dropwhile is a C type"]
    - [ite289c007, itertools.takewhile.__class__.__name__.__eq__, ["type"], true, "takewhile is a C type"]

invariant itertools_extra289.starmap_module:
  description: "starmap __module__ is itertools"
  category: identity
  kind: python_call_eq
  function: itertools.starmap.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra289.filterfalse_module:
  description: "filterfalse __module__ is itertools"
  category: identity
  kind: python_call_eq
  function: itertools.filterfalse.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra289.islice_module:
  description: "islice __module__ is itertools"
  category: identity
  kind: python_call_eq
  function: itertools.islice.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra289.tee_module:
  description: "tee __module__ is itertools"
  category: identity
  kind: python_call_eq
  function: itertools.tee.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra289.starmap_qualname:
  description: "starmap __qualname__ matches its name"
  category: identity
  kind: python_call_eq
  function: itertools.starmap.__qualname__.__eq__
  args: ["starmap"]
  expected: true

invariant itertools_extra289.filterfalse_qualname:
  description: "filterfalse __qualname__ matches its name"
  category: identity
  kind: python_call_eq
  function: itertools.filterfalse.__qualname__.__eq__
  args: ["filterfalse"]
  expected: true

invariant itertools_extra289.tee_is_builtin:
  description: "tee is a builtin_function_or_method unlike other itertools iterators which are types"
  category: identity
  kind: python_call_eq
  function: itertools.tee.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
