spec: num2fraction
version: ">=1.2.2"
backend: node(num2fraction)

docs: https://www.npmjs.com/package/num2fraction

provenance:
  derived_from:
    - "num2fraction README — https://www.npmjs.com/package/num2fraction"
    - "Test vectors verified with num2fraction via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "num2fraction source"
  notes:
    - "num2fraction is an npm package. Install: npm install num2fraction"
    - "Converts a decimal number to a fraction string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a fraction string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table num2fraction.convert:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: n2f

  columns: [id, args, expected]
  rows:
    - [half,     [0.5],   "1/2"]
    - [quarter,  [0.25],  "1/4"]
    - [third,    [0.3333], "3333/10000"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:04:12Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
