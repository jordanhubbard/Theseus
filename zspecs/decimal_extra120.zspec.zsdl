  notes:
    - "This spec covers: decimal.Decimal dunder method __qualname__ values and lengths."
    - "Decimal is a C extension type from _decimal; its dunder methods are slot wrappers."
    - "decimal.Decimal.__str__.__qualname__ = 'Decimal.__str__' (length 15)."
    - "decimal.Decimal.__repr__.__qualname__ = 'Decimal.__repr__' (length 16)."
    - "decimal.Decimal.__int__.__qualname__ = 'Decimal.__int__' (length 15)."
    - "decimal.Decimal.__float__.__qualname__ = 'Decimal.__float__' (length 17)."
    - "decimal.Decimal.__bool__.__qualname__ = 'Decimal.__bool__' (length 16)."
    - "decimal.Decimal.__hash__.__qualname__ = 'Decimal.__hash__' (length 16)."
    - "decimal.Decimal.__format__.__qualname__ = 'Decimal.__format__' (length 18)."
    - "decimal.Decimal.__round__.__qualname__ = 'Decimal.__round__' (length 17)."
    - "decimal.Decimal.__abs__.__qualname__ = 'Decimal.__abs__' (length 15)."
    - "decimal.Decimal.__neg__.__qualname__ = 'Decimal.__neg__' (length 15)."
    - "decimal.Decimal.__trunc__.__qualname__ = 'Decimal.__trunc__' (length 17)."
    - "decimal.Decimal.__floor__.__qualname__ = 'Decimal.__floor__' (length 17)."
    - "decimal.Decimal.__ceil__.__qualname__ = 'Decimal.__ceil__' (length 16)."
    - "decimal.Decimal.__module__ = 'decimal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

