spec: decimal_extra97
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra96

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra96.zspec.zsdl."
    - "This spec covers: decimal.Context method __qualname__ values and lengths; decimal.Decimal additional method __qualname__ lengths."
    - "decimal.Context is a C extension type. Its methods are method_descriptors."
    - "decimal.Context.quantize.__qualname__ = 'Context.quantize' (length 16)."
    - "decimal.Context.sqrt.__qualname__ = 'Context.sqrt' (length 12)."
    - "decimal.Context.copy_abs.__qualname__ = 'Context.copy_abs' (length 16; same as quantize)."
    - "decimal.Context.create_decimal.__qualname__ = 'Context.create_decimal' (length 22; longest Context method qualname in this spec)."
    - "decimal.Context.clear_flags.__qualname__ = 'Context.clear_flags' (length 19)."
    - "decimal.Context.add.__qualname__ = 'Context.add' (length 11)."
    - "decimal.Context.subtract.__qualname__ = 'Context.subtract' (length 16; same as quantize and copy_abs)."
    - "decimal.Context.divide.__qualname__ = 'Context.divide' (length 14)."
    - "decimal.Context.power.__qualname__ = 'Context.power' (length 13)."
    - "decimal.Decimal.to_integral_value.__qualname__ = 'Decimal.to_integral_value' (length 25; longest Decimal method qualname in this spec)."
    - "decimal.Decimal.fma.__qualname__ = 'Decimal.fma' (length 11)."
    - "decimal.Decimal.ln.__qualname__ = 'Decimal.ln' (length 10)."
    - "decimal.Decimal.log10.__qualname__ = 'Decimal.log10' (length 13)."
    - "decimal.Decimal.exp.__qualname__ = 'Decimal.exp' (length 11; same as fma)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context method __qualname__ values and lengths
# Context is a C extension type from _decimal. Its methods are method_descriptors.
# __qualname__ uses the 'Context.method_name' pattern.
# ---------------------------------------------------------------------------

table decimal_extra97.Context_method_qualnames:
  description: "decimal.Context method __qualname__ values: quantize (16), sqrt (12), copy_abs (16), create_decimal (22), clear_flags (19) use 'Context.method_name' format"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decctxmeth97

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_q_qn,      Context.quantize.__qualname__.__eq__,        ["Context.quantize"],        true, "Context.quantize.__qualname__ == 'Context.quantize'"]
    - [ctx_q_len,     Context.quantize.__qualname__.__len__,        [],                          16,   "Context.quantize.__qualname__.__len__() == 16 ('Context.quantize' has 16 characters)"]
    - [ctx_sq_qn,     Context.sqrt.__qualname__.__eq__,             ["Context.sqrt"],            true, "Context.sqrt.__qualname__ == 'Context.sqrt'"]
    - [ctx_sq_len,    Context.sqrt.__qualname__.__len__,             [],                          12,   "Context.sqrt.__qualname__.__len__() == 12 ('Context.sqrt' has 12 characters)"]
    - [ctx_ca_qn,     Context.copy_abs.__qualname__.__eq__,         ["Context.copy_abs"],        true, "Context.copy_abs.__qualname__ == 'Context.copy_abs'"]
    - [ctx_ca_len,    Context.copy_abs.__qualname__.__len__,         [],                          16,   "Context.copy_abs.__qualname__.__len__() == 16 ('Context.copy_abs' has 16 characters; same as quantize)"]
    - [ctx_cd_qn,     Context.create_decimal.__qualname__.__eq__,   ["Context.create_decimal"],  true, "Context.create_decimal.__qualname__ == 'Context.create_decimal'"]
    - [ctx_cd_len,    Context.create_decimal.__qualname__.__len__,   [],                          22,   "Context.create_decimal.__qualname__.__len__() == 22 ('Context.create_decimal' has 22 characters; longest in this table)"]
    - [ctx_cf_qn,     Context.clear_flags.__qualname__.__eq__,      ["Context.clear_flags"],     true, "Context.clear_flags.__qualname__ == 'Context.clear_flags'"]
    - [ctx_cf_len,    Context.clear_flags.__qualname__.__len__,      [],                          19,   "Context.clear_flags.__qualname__.__len__() == 19 ('Context.clear_flags' has 19 characters)"]
    - [ctx_add_qn,    Context.add.__qualname__.__eq__,              ["Context.add"],             true, "Context.add.__qualname__ == 'Context.add'"]
    - [ctx_add_len,   Context.add.__qualname__.__len__,              [],                          11,   "Context.add.__qualname__.__len__() == 11 ('Context.add' has 11 characters)"]
    - [ctx_sub_qn,    Context.subtract.__qualname__.__eq__,         ["Context.subtract"],        true, "Context.subtract.__qualname__ == 'Context.subtract'"]
    - [ctx_sub_len,   Context.subtract.__qualname__.__len__,         [],                          16,   "Context.subtract.__qualname__.__len__() == 16 ('Context.subtract' has 16 characters; same as quantize and copy_abs)"]
    - [ctx_div_qn,    Context.divide.__qualname__.__eq__,           ["Context.divide"],          true, "Context.divide.__qualname__ == 'Context.divide'"]
    - [ctx_pow_qn,    Context.power.__qualname__.__eq__,            ["Context.power"],           true, "Context.power.__qualname__ == 'Context.power'"]

# ---------------------------------------------------------------------------
# decimal.Decimal additional method __qualname__ lengths
# to_integral_value, fma, ln, log10, exp are additional Decimal arithmetic
# methods not covered in decimal_extra96.
# ---------------------------------------------------------------------------

table decimal_extra97.Decimal_extra_method_qualnames:
  description: "decimal.Decimal additional method __qualname__ lengths: to_integral_value (25), fma (11), ln (10), log10 (13), exp (11)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decctxmeth97

  columns: [id, function, args, expected, description]
  rows:
    - [tiv_qn,      Decimal.to_integral_value.__qualname__.__eq__,  ["Decimal.to_integral_value"], true, "Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value'"]
    - [tiv_qn_len,  Decimal.to_integral_value.__qualname__.__len__, [],                            25,   "Decimal.to_integral_value.__qualname__.__len__() == 25 ('Decimal.to_integral_value' has 25 characters; longest Decimal method qualname in this spec)"]
    - [fma_qn,      Decimal.fma.__qualname__.__eq__,                ["Decimal.fma"],               true, "Decimal.fma.__qualname__ == 'Decimal.fma'"]
    - [fma_qn_len,  Decimal.fma.__qualname__.__len__,               [],                            11,   "Decimal.fma.__qualname__.__len__() == 11 ('Decimal.fma' has 11 characters)"]
    - [ln_qn,       Decimal.ln.__qualname__.__eq__,                 ["Decimal.ln"],                true, "Decimal.ln.__qualname__ == 'Decimal.ln'"]
    - [ln_qn_len,   Decimal.ln.__qualname__.__len__,                [],                            10,   "Decimal.ln.__qualname__.__len__() == 10 ('Decimal.ln' has 10 characters; shortest Decimal method qualname in this spec)"]
    - [log10_qn,    Decimal.log10.__qualname__.__eq__,              ["Decimal.log10"],             true, "Decimal.log10.__qualname__ == 'Decimal.log10'"]
    - [log10_qn_len, Decimal.log10.__qualname__.__len__,            [],                            13,   "Decimal.log10.__qualname__.__len__() == 13 ('Decimal.log10' has 13 characters)"]
    - [exp_qn,      Decimal.exp.__qualname__.__eq__,                ["Decimal.exp"],               true, "Decimal.exp.__qualname__ == 'Decimal.exp'"]
    - [exp_qn_len,  Decimal.exp.__qualname__.__len__,               [],                            11,   "Decimal.exp.__qualname__.__len__() == 11 ('Decimal.exp' has 11 characters; same length as fma)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra97.Context.quantize_qualname:
  description: "decimal.Context.quantize.__qualname__ == 'Context.quantize' (Context is a C extension type from _decimal; its method qualnames use the 'Context.method_name' pattern)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.quantize.__qualname__.__eq__
  args: ["Context.quantize"]
  expected: true

invariant decimal_extra97.Context.create_decimal_qualname_len:
  description: "decimal.Context.create_decimal.__qualname__.__len__() == 22 ('Context.create_decimal' is the longest Context method qualname in this spec at 22 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.create_decimal.__qualname__.__len__
  args: []
  expected: 22

invariant decimal_extra97.Decimal.to_integral_value_qualname_len:
  description: "decimal.Decimal.to_integral_value.__qualname__.__len__() == 25 ('Decimal.to_integral_value' has 25 characters; the longest Decimal method qualname in this spec)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_integral_value.__qualname__.__len__
  args: []
  expected: 25

invariant decimal_extra97.Decimal.ln_qualname_len:
  description: "decimal.Decimal.ln.__qualname__.__len__() == 10 ('Decimal.ln' is the shortest Decimal method qualname in this spec at 10 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.ln.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra97.Context.clear_flags_qualname_len:
  description: "decimal.Context.clear_flags.__qualname__.__len__() == 19 ('Context.clear_flags' has 19 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.clear_flags.__qualname__.__len__
  args: []
  expected: 19
