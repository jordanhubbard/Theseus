spec: ctypes_extra8
version: ">=3.9"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — Python ctypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
    - "CPython source: Modules/_ctypes/"
    - "ctypes.zspec.zsdl — baseline type names and instance value round-trips."
    - "ctypes_extra.zspec.zsdl through ctypes_extra7.zspec.zsdl — prior extras."
  notes:
    - "This spec extends ctypes.zspec.zsdl through ctypes_extra7.zspec.zsdl."
    - "ctypes_extra3 covers __qualname__ for: CDLL, Structure, Union, Array, c_int, c_long, c_char, c_char_p, c_void_p, c_double, c_float, c_bool, POINTER, cast, byref."
    - "ctypes_extra4 covers addressof.__qualname__; PyDLL.__qualname__; LibraryLoader.__qualname__."
    - "This spec adds NEW axes:"
    - "  (1) __qualname__ for utility functions not yet checked: string_at, sizeof, alignment."
    - "  (2) __qualname__ for numeric types not yet checked: c_uint, c_short, c_byte, c_ushort, c_wchar, c_wchar_p, c_ulong, c_ubyte."
    - "ctypes.string_at.__qualname__ == 'string_at' — C helper function. Verified Python 3.12 macOS."
    - "ctypes.sizeof.__qualname__ == 'sizeof' — C helper function. Verified."
    - "ctypes.alignment.__qualname__ == 'alignment' — C helper function. Verified."
    - "ctypes.c_uint.__qualname__ == 'c_uint' — unsigned int wrapper. Verified."
    - "ctypes.c_short.__qualname__ == 'c_short' — signed short wrapper. Verified."
    - "ctypes.c_byte.__qualname__ == 'c_byte' — signed byte wrapper. Verified."
    - "ctypes.c_ushort.__qualname__ == 'c_ushort' — unsigned short wrapper. Verified."
    - "ctypes.c_wchar.__qualname__ == 'c_wchar' — wide character wrapper. Verified."
    - "ctypes.c_wchar_p.__qualname__ == 'c_wchar_p' — wide char pointer wrapper. Verified."
    - "ctypes.c_ulong.__qualname__ == 'c_ulong' — unsigned long wrapper. Verified."
    - "ctypes.c_ubyte.__qualname__ == 'c_ubyte' — unsigned byte wrapper. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for ctypes utility/helper functions not yet covered
#
# ctypes_extra3 checked POINTER, cast, byref.
# ctypes_extra4 checked addressof.
# No prior ctypes spec checks string_at, sizeof, or alignment __qualname__.
# All three are C-level functions; their __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table ctypes_extra8.helper_qualnames:
  description: "ctypes utility function __qualname__ attributes not covered in any prior ctypes spec"
  kind: python_call_eq
  category: helper_qualnames
  id_prefix: ct8h

  columns: [id, function, args, expected]
  rows:
    - [string_at,  string_at.__qualname__.__eq__,  ["string_at"],  true]
    - [sizeof,     sizeof.__qualname__.__eq__,     ["sizeof"],     true]
    - [alignment,  alignment.__qualname__.__eq__,  ["alignment"],  true]

# ---------------------------------------------------------------------------
# __qualname__ for numeric ctypes type classes not yet covered
#
# ctypes_extra3 checked: c_int, c_long, c_char, c_char_p, c_void_p, c_double,
#   c_float, c_bool, CDLL, Structure, Union, Array.
# ctypes_extra5 checked __module__ (not __qualname__) for c_uint, c_short,
#   c_byte, c_ushort, c_wchar, c_wchar_p, c_ulong, c_ubyte.
# No prior ctypes spec checks __qualname__ for these eight types.
# For top-level classes, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table ctypes_extra8.numeric_type_qualnames:
  description: "Numeric ctypes type class __qualname__ attributes not covered in ctypes_extra3"
  kind: python_call_eq
  category: qualnames
  id_prefix: ct8q

  columns: [id, function, args, expected]
  rows:
    - [c_uint,    c_uint.__qualname__.__eq__,    ["c_uint"],    true]
    - [c_short,   c_short.__qualname__.__eq__,   ["c_short"],   true]
    - [c_byte,    c_byte.__qualname__.__eq__,     ["c_byte"],    true]
    - [c_ushort,  c_ushort.__qualname__.__eq__,  ["c_ushort"],  true]
    - [c_wchar,   c_wchar.__qualname__.__eq__,   ["c_wchar"],   true]
    - [c_wchar_p, c_wchar_p.__qualname__.__eq__, ["c_wchar_p"], true]
    - [c_ulong,   c_ulong.__qualname__.__eq__,   ["c_ulong"],   true]
    - [c_ubyte,   c_ubyte.__qualname__.__eq__,   ["c_ubyte"],   true]
