spec: uuid_extra661
backend: python_module(uuid)
description: "uuid.UUID __int__, __bytes__, and other slot wrapper method identity plus getnode function metadata"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid.UUID class and getnode function"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers slot_wrapper class names, qualnames for UUID dunder methods, and getnode function metadata"]
  created_at: "2026-04-12T00:00:00Z"

table uuid_extra661.uuid_int_bytes_qualnames:
  description: "Qualified names of UUID.__int__ and UUID.__bytes__ slot wrappers"
  kind: python_call_eq
  category: slot_qualname
  id_prefix: uu661ibq
  columns: [id, function, args, expected]
  rows:
    - [uu661ibq001, uuid.UUID.__int__.__qualname__.__eq__, ["UUID.__int__"], true]
    - [uu661ibq002, uuid.UUID.__bytes__.__qualname__.__eq__, ["UUID.__bytes__"], true]

table uuid_extra661.uuid_slot_class_names:
  description: "Class names of UUID dunder method slot wrappers"
  kind: python_call_eq
  category: slot_identity
  id_prefix: uu661slc
  columns: [id, function, args, expected]
  rows:
    - [uu661slc001, uuid.UUID.__int__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu661slc002, uuid.UUID.__bytes__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu661slc003, uuid.UUID.__str__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu661slc004, uuid.UUID.__repr__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu661slc005, uuid.UUID.__init__.__class__.__name__.__eq__, ["slot_wrapper"], true]

table uuid_extra661.uuid_setattr_identity:
  description: "UUID.__setattr__ qualname and class name"
  kind: python_call_eq
  category: slot_identity
  id_prefix: uu661sat
  columns: [id, function, args, expected]
  rows:
    - [uu661sat001, uuid.UUID.__setattr__.__qualname__.__eq__, ["UUID.__setattr__"], true]
    - [uu661sat002, uuid.UUID.__setattr__.__class__.__name__.__eq__, ["slot_wrapper"], true]

table uuid_extra661.getnode_metadata:
  description: "uuid.getnode function metadata: module, doc class, and class name"
  kind: python_call_eq
  category: function_metadata
  id_prefix: uu661gnm
  columns: [id, function, args, expected]
  rows:
    - [uu661gnm001, uuid.getnode.__module__.__eq__, ["uuid"], true]
    - [uu661gnm002, uuid.getnode.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu661gnm003, uuid.getnode.__class__.__name__.__eq__, ["function"], true]
