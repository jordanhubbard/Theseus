spec: itertools_extra288
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools C extension class identity and error behavior"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools has no __all__ as it is a C extension module"
    - "All itertools iterators are implemented as C types, so __class__.__name__ == 'type'"
    - "itertools.repeat(1, -1) does NOT raise — it returns an empty iterator (negative count treated as 0)"
    - "itertools.islice(range(10), -1) raises ValueError for negative stop argument"
    - "chain.from_iterable qualname is 'chain.from_iterable' confirming class method binding"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra288.class_names:
  description: "All major itertools iterator classes have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: identity
  id_prefix: itex288

  columns: [id, function, args, expected, description]
  rows:
    - [itex288_001, itertools.chain.__class__.__name__.__eq__, ["type"], true, "chain is a type"]
    - [itex288_002, itertools.count.__class__.__name__.__eq__, ["type"], true, "count is a type"]
    - [itex288_003, itertools.cycle.__class__.__name__.__eq__, ["type"], true, "cycle is a type"]
    - [itex288_004, itertools.repeat.__class__.__name__.__eq__, ["type"], true, "repeat is a type"]
    - [itex288_005, itertools.product.__class__.__name__.__eq__, ["type"], true, "product is a type"]
    - [itex288_006, itertools.combinations.__class__.__name__.__eq__, ["type"], true, "combinations is a type"]
    - [itex288_007, itertools.permutations.__class__.__name__.__eq__, ["type"], true, "permutations is a type"]
    - [itex288_008, itertools.accumulate.__class__.__name__.__eq__, ["type"], true, "accumulate is a type"]
    - [itex288_009, itertools.islice.__class__.__name__.__eq__, ["type"], true, "islice is a type"]
    - [itex288_010, itertools.zip_longest.__class__.__name__.__eq__, ["type"], true, "zip_longest is a type"]

table itertools_extra288.identity_checks:
  description: "Identity checks for itertools module attributes and chain.from_iterable"
  kind: python_call_eq
  category: identity
  id_prefix: itex288i

  columns: [id, function, args, expected, description]
  rows:
    - [itex288i_001, itertools.__doc__.__class__.__name__.__eq__, ["str"], true, "itertools.__doc__ is a str"]
    - [itex288i_002, itertools.chain.from_iterable.__qualname__.__eq__, ["chain.from_iterable"], true, "chain.from_iterable qualname is 'chain.from_iterable'"]
    - [itex288i_003, itertools.chain.__doc__.__class__.__name__.__eq__, ["str"], true, "chain.__doc__ is a str"]
    - [itex288i_004, itertools.count.__doc__.__class__.__name__.__eq__, ["str"], true, "count.__doc__ is a str"]

invariant itertools_extra288.inv_islice_negative_stop:
  description: "islice raises ValueError for negative stop argument"
  category: errors
  kind: python_call_raises
  function: itertools.islice
  args: ["range(10)", -1]
  raises: ValueError

invariant itertools_extra288.inv_chain_is_type:
  description: "itertools.chain is a type (C extension class)"
  category: identity
  kind: python_call_eq
  function: itertools.chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra288.inv_cycle_is_type:
  description: "itertools.cycle is a type (C extension class)"
  category: identity
  kind: python_call_eq
  function: itertools.cycle.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra288.inv_from_iterable_qualname:
  description: "chain.from_iterable has qualname 'chain.from_iterable'"
  category: identity
  kind: python_call_eq
  function: itertools.chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true
