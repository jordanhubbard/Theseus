spec: threading_extra216
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers exception-raising behavior for threading constructors on bad inputs."
    - "threading.Semaphore(-1) raises ValueError at construction — semaphore initial value must be >= 0. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore(-1) raises ValueError at construction — semaphore initial value must be >= 0. Verified with Python 3.14.3."
    - "threading.Barrier(0) raises ValueError at construction — parties must be >= 1. Verified with Python 3.14.3."
    - "threading.Barrier(-1) raises ValueError at construction — parties must be >= 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Semaphore — exception on negative initial value
#
# threading.Semaphore(value) requires value to be >= 0. Passing -1 raises
# ValueError immediately at construction time.
# Verified: Semaphore(-1) -> ValueError: semaphore initial value must be >= 0.
# ---------------------------------------------------------------------------

table threading_extra216.semaphore_negative_value:
  description: "Semaphore(-1) raises ValueError — initial value must be >= 0; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: threadingextra216

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_negative_raises_ValueError,
       Semaphore,
       [-1],
       ValueError,
       "threading.Semaphore(-1) raises ValueError — a semaphore's internal counter must be non-negative because it represents a count of available resources; -1 is negative so Python raises ValueError: semaphore initial value must be >= 0; exception fires at construction time before any acquire or release call; new to extra216"]

# ---------------------------------------------------------------------------
# threading.BoundedSemaphore — exception on negative initial value
#
# threading.BoundedSemaphore(value) requires value to be >= 0. Passing -1
# raises ValueError immediately at construction time.
# Verified: BoundedSemaphore(-1) -> ValueError: semaphore initial value must
# be >= 0.
# ---------------------------------------------------------------------------

table threading_extra216.bounded_semaphore_negative_value:
  description: "BoundedSemaphore(-1) raises ValueError — initial value must be >= 0; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: threadingextra216

  columns: [id, function, args, expected, description]
  rows:
    - [bounded_semaphore_negative_raises_ValueError,
       BoundedSemaphore,
       [-1],
       ValueError,
       "threading.BoundedSemaphore(-1) raises ValueError — a bounded semaphore adds an upper bound (the initial value) on top of a regular semaphore; the initial value must be >= 0; -1 is negative so Python raises ValueError: semaphore initial value must be >= 0; exception fires at construction time; new to extra216"]

# ---------------------------------------------------------------------------
# threading.Barrier — exception on parties < 1
#
# threading.Barrier(parties) requires parties to be >= 1 since a barrier
# requires at least one thread to wait at it. Passing 0 or -1 raises
# ValueError immediately at construction.
# Verified: Barrier(0) -> ValueError: parties must be >= 1.
# Verified: Barrier(-1) -> ValueError: parties must be >= 1.
# ---------------------------------------------------------------------------

table threading_extra216.barrier_bad_parties:
  description: "Barrier(0) and Barrier(-1) raise ValueError — parties must be >= 1; new to extra216"
  kind: python_call_raises
  category: errors
  id_prefix: threadingextra216

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_zero_parties_raises_ValueError,
       Barrier,
       [0],
       ValueError,
       "threading.Barrier(0) raises ValueError — a barrier synchronizes a fixed number of threads by blocking each one until the specified count of threads have arrived; parties must be at least 1; 0 means no threads can ever release the barrier so Python raises ValueError: parties must be >= 1; exception fires at construction time; new to extra216"]
    - [barrier_negative_parties_raises_ValueError,
       Barrier,
       [-1],
       ValueError,
       "threading.Barrier(-1) raises ValueError — parties specifies how many threads must call wait() before any are released; -1 is not a valid count so Python raises ValueError: parties must be >= 1; exception fires at construction time; new to extra216"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra216
# ---------------------------------------------------------------------------

invariant threading_extra216.semaphore_negative_ValueError:
  description: "threading.Semaphore(-1) raises ValueError — semaphore initial value must be >= 0; new to extra216"
  kind: python_call_raises
  category: errors
  function: Semaphore
  args: [-1]
  expected: ValueError

invariant threading_extra216.bounded_semaphore_negative_ValueError:
  description: "threading.BoundedSemaphore(-1) raises ValueError — semaphore initial value must be >= 0; new to extra216"
  kind: python_call_raises
  category: errors
  function: BoundedSemaphore
  args: [-1]
  expected: ValueError

invariant threading_extra216.barrier_zero_ValueError:
  description: "threading.Barrier(0) raises ValueError — parties must be >= 1; new to extra216"
  kind: python_call_raises
  category: errors
  function: Barrier
  args: [0]
  expected: ValueError

invariant threading_extra216.barrier_negative_ValueError:
  description: "threading.Barrier(-1) raises ValueError — parties must be >= 1; new to extra216"
  kind: python_call_raises
  category: errors
  function: Barrier
  args: [-1]
  expected: ValueError

