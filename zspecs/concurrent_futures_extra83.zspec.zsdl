    - [tpe_no_initializer, "ThreadPoolExecutor.__dict__.__contains__", ["_initializer"], false, "ThreadPoolExecutor.__dict__.__contains__('_initializer') == False — _initializer is an instance attr set in __init__, not a class-level dict entry; verified with Python 3.14.3"]
    - [tpe_no_work_queue,  "ThreadPoolExecutor.__dict__.__contains__", ["_work_queue"],  false, "ThreadPoolExecutor.__dict__.__contains__('_work_queue') == False — _work_queue is an instance attr set in __init__, not a class-level dict entry; verified with Python 3.14.3"]
    - [ppe_has_submit,     "ProcessPoolExecutor.__dict__.__contains__", ["submit"],       true, "ProcessPoolExecutor.__dict__.__contains__('submit') == True — submit is defined directly on ProcessPoolExecutor; verified with Python 3.14.3"]
    - [ppe_has_shutdown,   "ProcessPoolExecutor.__dict__.__contains__", ["shutdown"],     true, "ProcessPoolExecutor.__dict__.__contains__('shutdown') == True — shutdown is defined directly on ProcessPoolExecutor; verified with Python 3.14.3"]

