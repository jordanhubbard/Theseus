#
# ThreadPoolExecutor.__dict__.__contains__('submit') == True
# ThreadPoolExecutor.__dict__.__contains__('shutdown') == True
# ThreadPoolExecutor.__dict__.__contains__('__init__') == True
# ThreadPoolExecutor.__dict__.__contains__('_adjust_thread_count') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra83.ThreadPoolExecutor_dict_membership:
  description: "concurrent.futures ThreadPoolExecutor __dict__ membership checks in cfextra83 namespace — wave 246 theme: concurrent.futures ThreadPoolExecutor.__dict__ membership; ThreadPoolExecutor.__dict__.__contains__('submit')==True; ThreadPoolExecutor.__dict__.__contains__('shutdown')==True; ThreadPoolExecutor.__dict__.__contains__('__init__')==True; ThreadPoolExecutor.__dict__.__contains__('_adjust_thread_count')==True; all are class-level methods defined directly on ThreadPoolExecutor; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra83

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_has_submit,     "ThreadPoolExecutor.__dict__.__contains__", ["submit"],              true, "ThreadPoolExecutor.__dict__.__contains__('submit') == True — submit is defined directly on ThreadPoolExecutor; verified with Python 3.14.3"]
    - [tpe_has_shutdown,   "ThreadPoolExecutor.__dict__.__contains__", ["shutdown"],            true, "ThreadPoolExecutor.__dict__.__contains__('shutdown') == True — shutdown is defined directly on ThreadPoolExecutor; verified with Python 3.14.3"]
    - [tpe_has_init,       "ThreadPoolExecutor.__dict__.__contains__", ["__init__"],            true, "ThreadPoolExecutor.__dict__.__contains__('__init__') == True — __init__ is defined directly on ThreadPoolExecutor; verified with Python 3.14.3"]
    - [tpe_has_adjust,     "ThreadPoolExecutor.__dict__.__contains__", ["_adjust_thread_count"], true, "ThreadPoolExecutor.__dict__.__contains__('_adjust_thread_count') == True — _adjust_thread_count is a method defined directly on ThreadPoolExecutor; verified with Python 3.14.3"]

