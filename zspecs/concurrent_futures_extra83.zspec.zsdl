# ---------------------------------------------------------------------------
# Standalone invariants — extra83
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra83.ThreadPoolExecutor_has_submit:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') returns True — submit is a class-level method defined directly on ThreadPoolExecutor; NEW in extra83: first standalone __dict__.__contains__ invariant for ThreadPoolExecutor.submit in cfextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra83.ThreadPoolExecutor_no_initializer:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('_initializer') returns False — _initializer is an instance attribute set in __init__, not a class-level dict entry; demonstrates distinction between instance and class attributes; NEW in extra83: first standalone negative __dict__.__contains__ invariant for ThreadPoolExecutor in cfextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__dict__.__contains__
  args: ["_initializer"]
  expected: false

invariant concurrent_futures_extra83.Future_has_set_result:
  description: "concurrent.futures.Future.__dict__.__contains__('set_result') returns True — set_result is a class-level method defined directly on Future; NEW in extra83: first standalone __dict__.__contains__ invariant for Future.set_result in cfextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["set_result"]
  expected: true

invariant concurrent_futures_extra83.Future_has_done:
  description: "concurrent.futures.Future.__dict__.__contains__('done') returns True — done is a class-level method defined directly on Future; NEW in extra83: first standalone __dict__.__contains__ invariant for Future.done in cfextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["done"]
  expected: true

invariant concurrent_futures_extra83.Executor_has_enter:
  description: "concurrent.futures.Executor.__dict__.__contains__('__enter__') returns True — __enter__ is a class-level method defined directly on Executor; Executor implements the context manager protocol; NEW in extra83: first standalone __dict__.__contains__ invariant for Executor.__enter__ in cfextra83 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__dict__.__contains__
  args: ["__enter__"]
  expected: true
