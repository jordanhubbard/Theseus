spec: concurrent_futures_extra83
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra82.zspec.zsdl."
    - "This spec covers: wave 246 theme — concurrent.futures ThreadPoolExecutor.__dict__ membership. NEW in extra83: ThreadPoolExecutor.__dict__.__contains__('submit')==True; ThreadPoolExecutor.__dict__.__contains__('shutdown')==True; ThreadPoolExecutor.__dict__.__contains__('__init__')==True; ThreadPoolExecutor.__dict__.__contains__('_initializer')==False (not a class-level attr; it is an instance attr set in __init__); ThreadPoolExecutor.__dict__.__contains__('_work_queue')==False (instance attr set in __init__); ThreadPoolExecutor.__dict__.__contains__('_adjust_thread_count')==True; ProcessPoolExecutor.__dict__.__contains__('submit')==True; ProcessPoolExecutor.__dict__.__contains__('shutdown')==True; ProcessPoolExecutor.__dict__.__contains__('__init__')==True; Executor.__dict__.__contains__('__enter__')==True; Executor.__dict__.__contains__('__exit__')==True; Future.__dict__.__contains__('set_result')==True; Future.__dict__.__contains__('set_exception')==True; Future.__dict__.__contains__('done')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') == True. submit is defined directly on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') == True. shutdown is defined directly on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__init__') == True. __init__ is defined directly on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('_initializer') == False. _initializer is an instance attribute set in __init__, not a class-level dict entry. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('_work_queue') == False. _work_queue is an instance attribute set in __init__, not a class-level dict entry. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('_adjust_thread_count') == True. _adjust_thread_count is a method defined directly on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('set_result') == True. set_result is defined directly on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('set_exception') == True. set_exception is defined directly on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('done') == True. done is defined directly on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
