spec: p_retry
version: ">=8.0.0"
backend: node(p-retry)

docs: https://github.com/sindresorhus/p-retry#readme

provenance:
  derived_from:
    - "p-retry README — https://github.com/sindresorhus/p-retry#readme"
    - "Test vectors verified with p-retry via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "p-retry source"
  notes:
    - "Retry a promise-returning or async function with exponential backoff."
    - "Install: npm install p-retry"
    - "v8 ESM only; default export is pRetry; named export AbortError signals 'do not retry'."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws the last error if all retries fail; AbortError to short-circuit."
  stderr: "null"
  stickiness: "N/A — each pRetry call independent."
  codes: {}

invariant p_retry.default_export_arity:
  description: "Default export pRetry has function.length 1 (input fn; options optional)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 1

invariant p_retry.default_export_name:
  description: "Default export function has name 'pRetry'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "pRetry"

invariant p_retry.abort_error_name:
  description: "new AbortError(msg).name is 'AbortError'"
  category: AbortError
  kind: node_chain_eq
  entry: constructor
  class: AbortError
  entry_args: ["aborted"]
  chain:
    - {get: name}
  expected: "AbortError"

invariant p_retry.abort_error_message:
  description: "new AbortError(msg).message preserves the message"
  category: AbortError
  kind: node_chain_eq
  entry: constructor
  class: AbortError
  entry_args: ["stop now"]
  chain:
    - {get: message}
  expected: "stop now"

invariant p_retry.abort_error_is_error:
  description: "AbortError instances are Error subclasses (constructor.name)"
  category: AbortError
  kind: node_chain_eq
  entry: constructor
  class: AbortError
  entry_args: ["x"]
  chain:
    - {get: "constructor.name"}
  expected: "AbortError"

invariant p_retry.abort_error_class_name:
  description: "AbortError.name (the class name itself) is 'AbortError'"
  category: AbortError
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "AbortError.name"}
  expected: "AbortError"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:22:28Z
  iterations: 2
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 2 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
