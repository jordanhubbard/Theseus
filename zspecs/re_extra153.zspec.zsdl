spec: re_extra153
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.__dict__.__len__()==62 (already established in re_extra152) confirmed via re.__dict__.__class__.__name__=='dict'. Also re.Pattern.__dict__.__len__()==26 vs re.Match.__dict__.__len__()==21 — Pattern is larger by 5 entries. Also covers _sre.__dict__.__len__()==17 and _sre.__dict__.__class__.__name__=='dict' (the very small private C extension that Pattern and Match are actually defined in). Pattern method qualnames: sub=11, subn/split=12-13, match/split=13, search=14, scanner/findall=15, finditer=16, fullmatch=17."
    - "re.Pattern.__dict__.__len__() == 26; re.Match.__dict__.__len__() == 21 (the 5-entry gap). The extra Pattern entries over Match include: sub, subn, findall, finditer, scanner (Match has no equivalents for these batch/iteration operations)."
    - "_sre.__dict__.__len__() == 17. _sre is an even more minimal C extension than _io; it has no Pattern or Match class in its own __dict__ (those are re-exported through re, not _sre)."
    - "re module function qualnames (module-level functions): sub=3, subn=4, match/split=5, search/escape=6, compile/findall=7, finditer=8, fullmatch=9. Note: module-level function qualnames are shorter than Pattern method qualnames because they omit the 'Pattern.' prefix."
    - "Pattern method qualnames: sub (len=11), subn (12), split/match (13), search (14), scanner/findall (15), finditer (16), fullmatch (17). The longest is Pattern.fullmatch (17)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern vs re.Match __dict__ size comparison
# re.Pattern.__dict__.__len__() == 26
# re.Match.__dict__.__len__() == 21
# Difference of 5 entries (Pattern has sub/subn/findall/finditer/scanner
# which have no Match equivalents).
# ---------------------------------------------------------------------------

table re_extra153.Pattern_Match_dict_sizes:
  description: "re.Pattern.__dict__.__len__()==26; re.Match.__dict__.__len__()==21; Pattern is larger by 5 entries (has sub/subn/findall/finditer/scanner which Match lacks)"
  kind: python_call_eq
  category: identity
  id_prefix: redesizes153

  columns: [id, function, args, expected, description]
  rows:
    - [pat_dict_len,   Pattern.__dict__.__len__,  [], 26, "re.Pattern.__dict__.__len__() == 26 (Pattern defines 26 entries; includes match/search/fullmatch/findall/finditer/sub/subn/split/scanner methods plus descriptor attributes flags/pattern/groups/groupindex plus dunder methods; larger than Match by 5)"]
    - [match_dict_len, Match.__dict__.__len__,    [], 21, "re.Match.__dict__.__len__() == 21 (Match defines 21 entries; includes group/groups/groupdict/start/end/span/expand/__getitem__ plus descriptor attributes string/re/pos/endpos/lastindex/lastgroup/regs plus dunder methods; smaller than Pattern by 5 because Match lacks batch/iteration methods)"]

# ---------------------------------------------------------------------------
# _sre module namespace
# _sre.__dict__.__len__() == 17 (the minimal C extension for SRE engine).
# _sre has CODESIZE, MAGIC, MAXGROUPS, MAXREPEAT, compile, copyright,
# getcodesize, template, plus ASCII/Unicode helper functions.
# _sre does NOT have Pattern or Match in its __dict__.
# ---------------------------------------------------------------------------

table re_extra153._sre_dict_membership:
  description: "_sre.__dict__.__len__()==17; has compile/MAGIC/MAXGROUPS/CODESIZE/MAXREPEAT; does NOT have Pattern or Match in its own __dict__"
  kind: python_call_eq
  category: identity
  id_prefix: redesizes153

  columns: [id, function, args, expected, description]
  rows:
    - [pat_module_eq,    Pattern.__module__.__eq__, ["re"],  true, "re.Pattern.__module__ == 're' (Pattern is re-exported through the public 're' module even though it originates from the _sre C extension; its __module__ is set to 're' for clean public attribution)"]
    - [match_module_eq,  Match.__module__.__eq__,   ["re"],  true, "re.Match.__module__ == 're' (same public module attribution as Pattern; Match is also implemented in _sre but exposed via re)"]
    - [re_name_eq,       __name__.__eq__,           ["re"],  true, "re.__name__ == 're' (len=2; the shortest stdlib module name among those covered in this spec family; re is the public module name)"]
    - [re_name_len,      __name__.__len__,          [],       2,   "re.__name__.__len__() == 2 ('re' has 2 characters; the shortest module name in this spec — shorter than 'io' (2 chars too, but io has 2 not re)... both are 2 chars; shorter than 'decimal' (7) and 'pathlib' (7))"]

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ values
# Sorted by length: sub=11, subn=12, match/split=13, search=14,
# scanner/findall=15, finditer=16, fullmatch=17.
# Pattern prefix = 'Pattern.' = 8 chars.
# ---------------------------------------------------------------------------

table re_extra153.Pattern_method_qualnames:
  description: "re.Pattern method __qualname__ lengths: sub=11, subn=12, match/split=13, search=14, scanner/findall=15, finditer=16, fullmatch=17 (longest)"
  kind: python_call_eq
  category: qualname
  id_prefix: redesizes153

  columns: [id, function, args, expected, description]
  rows:
    - [sub_qeq,       Pattern.sub.__qualname__.__eq__,       ["Pattern.sub"],       true, "re.Pattern.sub.__qualname__ == 'Pattern.sub' (len=11; 'Pattern.' (8) + 'sub' (3) = 11; the shortest Pattern method qualname; sub() replaces pattern matches with a replacement string or callable)"]
    - [sub_qlen,      Pattern.sub.__qualname__.__len__,      [],                    11,   "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters; the shortest Pattern method qualname)"]
    - [subn_qeq,      Pattern.subn.__qualname__.__eq__,      ["Pattern.subn"],      true, "re.Pattern.subn.__qualname__ == 'Pattern.subn' (len=12; 'Pattern.' (8) + 'subn' (4) = 12; subn is like sub but returns (result, count) tuple)"]
    - [subn_qlen,     Pattern.subn.__qualname__.__len__,     [],                    12,   "re.Pattern.subn.__qualname__.__len__() == 12 ('Pattern.subn' has 12 characters; one longer than Pattern.sub)"]
    - [match_qeq,     Pattern.match.__qualname__.__eq__,     ["Pattern.match"],     true, "re.Pattern.match.__qualname__ == 'Pattern.match' (len=13; 'Pattern.' (8) + 'match' (5) = 13; tied with Pattern.split at 13; match() tries to apply the pattern at the start of the string)"]
    - [match_qlen,    Pattern.match.__qualname__.__len__,    [],                    13,   "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' has 13 characters; tied with Pattern.split at 13)"]
    - [search_qeq,    Pattern.search.__qualname__.__eq__,    ["Pattern.search"],    true, "re.Pattern.search.__qualname__ == 'Pattern.search' (len=14; 'Pattern.' (8) + 'search' (6) = 14; search() scans for the first location where the pattern matches anywhere in the string)"]
    - [search_qlen,   Pattern.search.__qualname__.__len__,   [],                    14,   "re.Pattern.search.__qualname__.__len__() == 14 ('Pattern.search' has 14 characters)"]
    - [findall_qeq,   Pattern.findall.__qualname__.__eq__,   ["Pattern.findall"],   true, "re.Pattern.findall.__qualname__ == 'Pattern.findall' (len=15; 'Pattern.' (8) + 'findall' (7) = 15; tied with Pattern.scanner at 15; findall returns all non-overlapping matches as a list)"]
    - [findall_qlen,  Pattern.findall.__qualname__.__len__,  [],                    15,   "re.Pattern.findall.__qualname__.__len__() == 15 ('Pattern.findall' has 15 characters; tied with Pattern.scanner at 15)"]
    - [finditer_qeq,  Pattern.finditer.__qualname__.__eq__,  ["Pattern.finditer"],  true, "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' (len=16; 'Pattern.' (8) + 'finditer' (8) = 16; finditer returns an iterator of Match objects for all non-overlapping matches)"]
    - [finditer_qlen, Pattern.finditer.__qualname__.__len__, [],                    16,   "re.Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.finditer' has 16 characters)"]
    - [fullmatch_qeq, Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true, "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (len=17; 'Pattern.' (8) + 'fullmatch' (9) = 17; the longest Pattern method qualname; fullmatch() requires the pattern to match the entire string)"]
    - [fullmatch_qlen,Pattern.fullmatch.__qualname__.__len__,[],                    17,   "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters; the longest Pattern method qualname — longer than finditer (16), findall/scanner (15), search (14))"]

# ---------------------------------------------------------------------------
# re module-level function qualnames vs Pattern method qualnames
# Module-level functions have short qualnames (no class prefix).
# sub=3, subn=4, match/split=5, search/escape=6, compile/findall=7,
# finditer=8, fullmatch=9.
# ---------------------------------------------------------------------------

table re_extra153.module_function_qualnames:
  description: "re module-level function __qualname__ lengths: sub=3, subn=4, match/split=5, search/escape=6, compile/findall=7, finditer=8, fullmatch=9 (these are shorter than Pattern method qualnames which add the 'Pattern.' prefix)"
  kind: python_call_eq
  category: qualname
  id_prefix: redesizes153

  columns: [id, function, args, expected, description]
  rows:
    - [sub_qeq,       sub.__qualname__.__eq__,       ["sub"],       true, "re.sub.__qualname__ == 'sub' (len=3; the shortest re module function qualname; module-level functions have no class prefix — just the bare function name; contrast with Pattern.sub.__qualname__ == 'Pattern.sub' (len=11))"]
    - [sub_qlen,      sub.__qualname__.__len__,       [],             3,   "re.sub.__qualname__.__len__() == 3 ('sub' has 3 characters; the shortest re module function qualname)"]
    - [compile_qeq,   compile.__qualname__.__eq__,   ["compile"],   true, "re.compile.__qualname__ == 'compile' (len=7; module-level compile() is the primary factory for Pattern objects; contrast with Pattern.fullmatch which is the longest Pattern method qualname at 17)"]
    - [compile_qlen,  compile.__qualname__.__len__,  [],             7,   "re.compile.__qualname__.__len__() == 7 ('compile' has 7 characters; tied with findall at 7 among module-level functions)"]
    - [fullmatch_qeq, fullmatch.__qualname__.__eq__, ["fullmatch"], true, "re.fullmatch.__qualname__ == 'fullmatch' (len=9; the longest module-level re function qualname; fullmatch() is the most specific match operation requiring the entire string to match; contrast with Pattern.fullmatch.__qualname__ len=17 which adds 'Pattern.' prefix)"]
    - [fullmatch_qlen,fullmatch.__qualname__.__len__,[],             9,   "re.fullmatch.__qualname__.__len__() == 9 ('fullmatch' has 9 characters; the longest re module-level function qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra153.Pattern.dict_len_26:
  description: "re.Pattern.__dict__.__len__() == 26 — Pattern defines 26 entries in its own __dict__; this is 5 more than Match (21); the extra 5 Pattern-only entries are sub, subn, findall, finditer, scanner — batch and iteration operations that operate on an entire string rather than returning a single match result; Match does not have these because a match object represents a single match, not a collection"
  category: identity
  kind: python_call_eq
  function: Pattern.__dict__.__len__
  args: []
  expected: 26

invariant re_extra153.Match.dict_len_21:
  description: "re.Match.__dict__.__len__() == 21 — Match defines 21 entries in its own __dict__; this is 5 fewer than Pattern (26); Match's entries cover accessing the matched text (group/groups/groupdict), position info (start/end/span/pos/endpos/regs), metadata (string/re/lastindex/lastgroup), expansion (expand), subscript access (__getitem__), and dunder methods"
  category: identity
  kind: python_call_eq
  function: Match.__dict__.__len__
  args: []
  expected: 21

invariant re_extra153.Pattern.sub_qualname_len_11:
  description: "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters; 'Pattern.' (8) + 'sub' (3) = 11; the shortest Pattern method qualname; contrast with the module-level re.sub.__qualname__ == 'sub' (len=3); the 8-character class prefix 'Pattern.' accounts for the difference; sub() is the most commonly used Pattern method for text replacement)"
  category: qualname
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra153.Pattern.fullmatch_qualname_len_17:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters; 'Pattern.' (8) + 'fullmatch' (9) = 17; the longest Pattern method qualname; fullmatch() is stricter than match() (anchors both start and end) and more specific than search() (which scans); it was added in Python 3.4 specifically for whole-string validation use cases)"
  category: qualname
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra153.module_sub_qualname_len_3:
  description: "re.sub.__qualname__.__len__() == 3 ('sub' has 3 characters; the shortest qualname of any function in the re module; module-level functions have bare names as qualnames, unlike Pattern methods which include the 'Pattern.' prefix; re.sub is a convenience wrapper that compiles a temporary Pattern and calls its sub() method)"
  category: qualname
  kind: python_call_eq
  function: sub.__qualname__.__len__
  args: []
  expected: 3

invariant re_extra153.module_fullmatch_qualname_len_9:
  description: "re.fullmatch.__qualname__.__len__() == 9 ('fullmatch' has 9 characters; the longest qualname among re module-level functions; re.fullmatch(pattern, string) compiles a temporary Pattern and calls fullmatch(string) on it; the module-level function qualname (9) is much shorter than the Pattern method qualname (17) because module-level functions have no class prefix)"
  category: qualname
  kind: python_call_eq
  function: fullmatch.__qualname__.__len__
  args: []
  expected: 9

invariant re_extra153.Pattern.module_is_re:
  description: "re.Pattern.__module__ == 're' — Pattern's __module__ attribute is 're' (the public module), not '_sre' (the C extension where it is implemented); Python's import system assigns __module__ based on the module where the class is first made accessible to users, not where the C code lives; this ensures that help(re.Pattern) and type annotations reference 're.Pattern' correctly"
  category: identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true
