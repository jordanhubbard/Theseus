spec: re_extra2746
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "re_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 630 (re_extra2746) theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __round__, __divmod__, or __pow__ in its own __dict__."
    - "__round__ supports the built-in round(); regex objects are pattern-matching types, not numeric types."
    - "__divmod__ supports divmod(); regex objects do not implement quotient-remainder numeric semantics."
    - "__pow__ supports the ** operator; regex objects do not implement exponentiation semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2746.no_round_in_re_classes:
  description: "__round__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the round() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2746

  columns: [id, function, args, expected]
  rows:
    - ["re2746001", "re.Pattern.__dict__.__contains__", ["__round__"], false]
    - ["re2746002", "re.Match.__dict__.__contains__",   ["__round__"], false]

# ---------------------------------------------------------------------------
# __divmod__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2746.no_divmod_in_re_classes:
  description: "__divmod__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the divmod() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2746

  columns: [id, function, args, expected]
  rows:
    - ["re2746003", "re.Pattern.__dict__.__contains__", ["__divmod__"], false]
    - ["re2746004", "re.Match.__dict__.__contains__",   ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2746.no_pow_in_re_classes:
  description: "__pow__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the ** exponentiation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2746

  columns: [id, function, args, expected]
  rows:
    - ["re2746005", "re.Pattern.__dict__.__contains__", ["__pow__"], false]
    - ["re2746006", "re.Match.__dict__.__contains__",   ["__pow__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not arithmetic numeric hooks
# Confirms that regex objects are pattern-matching types, not numeric types
# ---------------------------------------------------------------------------

table re_extra2746.re_has_regex_methods_not_arithmetic_numeric_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __round__/__divmod__/__pow__; re.Match defines group/groups/start/end but NOT __round__/__divmod__/__pow__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2746

  columns: [id, function, args, expected]
  rows:
    - ["re2746007", "re.Pattern.__dict__.__contains__", ["match"],      true]
    - ["re2746008", "re.Pattern.__dict__.__contains__", ["search"],     true]
    - ["re2746009", "re.Pattern.__dict__.__contains__", ["sub"],        true]
    - ["re2746010", "re.Pattern.__dict__.__contains__", ["findall"],    true]
    - ["re2746011", "re.Pattern.__dict__.__contains__", ["__round__"],  false]
    - ["re2746012", "re.Pattern.__dict__.__contains__", ["__divmod__"], false]
    - ["re2746013", "re.Pattern.__dict__.__contains__", ["__pow__"],    false]
    - ["re2746014", "re.Match.__dict__.__contains__",   ["group"],      true]
    - ["re2746015", "re.Match.__dict__.__contains__",   ["groups"],     true]
    - ["re2746016", "re.Match.__dict__.__contains__",   ["start"],      true]
    - ["re2746017", "re.Match.__dict__.__contains__",   ["end"],        true]
    - ["re2746018", "re.Match.__dict__.__contains__",   ["__round__"],  false]
    - ["re2746019", "re.Match.__dict__.__contains__",   ["__divmod__"], false]
    - ["re2746020", "re.Match.__dict__.__contains__",   ["__pow__"],    false]
