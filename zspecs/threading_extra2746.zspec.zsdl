spec: threading_extra2746
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks (numeric arithmetic protocol — used by round(), divmod(), and the ** operator)."
    - "threading.Thread is a runnable object; it does not define numeric arithmetic protocols."
    - "threading.Lock (accessed as threading.Lock, actual type is _thread.lock) is a synchronization primitive; it defines acquire/release but not __round__, __divmod__, or __pow__."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore are synchronization primitives; none define __round__, __divmod__, or __pow__."
    - "threading.Timer is a Thread subclass for deferred execution; it defines none of these numeric arithmetic protocols."
    - "threading.Barrier is a synchronization barrier; it does not define __round__, __divmod__, or __pow__."
    - "threading.local is a thread-local storage object; it does not define numeric arithmetic protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all threading synchronization types
# ---------------------------------------------------------------------------

table threading_extra2746.round_protocol:
  description: "__round__ is absent from all threading type __dict__s — synchronization primitives do not implement the round() numeric protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2746

  columns: [id, function, args, expected]
  rows:
    - ["th2746001", "threading.Thread.__dict__.__contains__",           ["__round__"], false]
    - ["th2746002", "threading.Lock.__dict__.__contains__",             ["__round__"], false]
    - ["th2746003", "threading.Event.__dict__.__contains__",            ["__round__"], false]
    - ["th2746004", "threading.Condition.__dict__.__contains__",        ["__round__"], false]
    - ["th2746005", "threading.Semaphore.__dict__.__contains__",        ["__round__"], false]
    - ["th2746006", "threading.BoundedSemaphore.__dict__.__contains__", ["__round__"], false]
    - ["th2746007", "threading.Timer.__dict__.__contains__",            ["__round__"], false]
    - ["th2746008", "threading.Barrier.__dict__.__contains__",          ["__round__"], false]
    - ["th2746009", "threading.local.__dict__.__contains__",            ["__round__"], false]

