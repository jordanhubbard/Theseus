spec: re3511
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module compiled pattern and match objects"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (re3511): __get__, __set__, __delete__ dict-presence checks for re types."
    - "All values false — re.Pattern, re.Match, and re.RegexFlag do not implement the descriptor protocol."
    - "re.Pattern is a compiled regex object; not a descriptor."
    - "re.Match holds match results; not a descriptor."
    - "re.RegexFlag is an IntFlag enum subclass; not a descriptor."
    - "None define __get__, __set__, or __delete__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table re3511.get:
  description: "re types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3511
  columns: [id, function, args, expected]
  rows:
    - ["re3511001", operator.contains, [re.Pattern.__dict__,   "__get__"], false]
    - ["re3511002", operator.contains, [re.Match.__dict__,     "__get__"], false]
    - ["re3511003", operator.contains, [re.RegexFlag.__dict__, "__get__"], false]

