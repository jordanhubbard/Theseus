spec: asyncio_extra2386
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec classifies __str__ and __repr__ implementation types for core asyncio classes."
    - "asyncio.Task and asyncio.Future are C-accelerated types; __str__ and __repr__ are both 'wrapper_descriptor'."
    - "asyncio.Event.__str__ is 'wrapper_descriptor' (inherited from object); __repr__ is 'function' (custom Python def)."
    - "asyncio.Lock.__str__ is 'wrapper_descriptor' (inherited from object); __repr__ is 'function' (custom Python def)."
    - "asyncio.Queue defines both __str__ and __repr__ in Python; both are 'function'."
    - "asyncio.Semaphore.__str__ is 'wrapper_descriptor'; __repr__ is 'function' (custom Python def)."
    - "asyncio.Condition.__str__ is 'wrapper_descriptor'; __repr__ is 'function' (custom Python def)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: asyncio.Task __str__ and __repr__ implementation type
#
# Task is a C-accelerated type. Both __str__ and __repr__ resolve to
# 'wrapper_descriptor' — they are slot wrappers defined in C, not Python
# functions. This contrasts with pure-Python asyncio classes.
# ---------------------------------------------------------------------------

table asyncio_extra2386.task_str_repr:
  description: "asyncio.Task __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: as2386

  columns: [id, function, args, expected]
  rows:
    - ["as2386001",
       Task.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386002",
       Task.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386003",
       Task.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["as2386004",
       Task.__repr__.__class__.__name__.__len__,
       [],
       18]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Future __str__ and __repr__ implementation type
#
# Future is also a C-accelerated type. Both __str__ and __repr__ are
# 'wrapper_descriptor', matching the Task pattern.
# ---------------------------------------------------------------------------

table asyncio_extra2386.future_str_repr:
  description: "asyncio.Future __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: as2386

  columns: [id, function, args, expected]
  rows:
    - ["as2386005",
       Future.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386006",
       Future.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386007",
       Future.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["as2386008",
       Future.__repr__.__class__.__name__.__len__,
       [],
       18]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Event __str__ and __repr__ implementation type
#
# Event is a pure-Python class. __str__ is inherited from object
# ('wrapper_descriptor') but __repr__ is a custom Python method ('function').
# ---------------------------------------------------------------------------

table asyncio_extra2386.event_str_repr:
  description: "asyncio.Event __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: as2386

  columns: [id, function, args, expected]
  rows:
    - ["as2386009",
       Event.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386010",
       Event.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["as2386011",
       Event.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["as2386012",
       Event.__repr__.__class__.__name__.__len__,
       [],
       8]

# ---------------------------------------------------------------------------
# Table 4: asyncio.Lock __str__ and __repr__ implementation type
#
# Lock is a pure-Python class. __str__ is 'wrapper_descriptor' (inherited);
# __repr__ is 'function' (custom Python definition on Lock).
# ---------------------------------------------------------------------------

table asyncio_extra2386.lock_str_repr:
  description: "asyncio.Lock __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: as2386

  columns: [id, function, args, expected]
  rows:
    - ["as2386013",
       Lock.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386014",
       Lock.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["as2386015",
       Lock.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["as2386016",
       Lock.__repr__.__class__.__name__.__len__,
       [],
       8]

# ---------------------------------------------------------------------------
# Table 5: asyncio.Queue, asyncio.Semaphore, asyncio.Condition — str/repr types
#
# Queue defines both __str__ and __repr__ in Python ('function' for both).
# Semaphore and Condition inherit __str__ from object but define __repr__ in Python.
# ---------------------------------------------------------------------------

table asyncio_extra2386.queue_semaphore_condition_str_repr:
  description: "asyncio.Queue, Semaphore, Condition __str__ and __repr__ type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: as2386

  columns: [id, function, args, expected]
  rows:
    - ["as2386017",
       Queue.__str__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["as2386018",
       Queue.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["as2386019",
       Semaphore.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386020",
       Semaphore.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["as2386021",
       Condition.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["as2386022",
       Condition.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
