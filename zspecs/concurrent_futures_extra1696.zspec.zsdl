spec: concurrent_futures_extra1696
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "concurrent.futures types are not picklable — Future holds a threading.Lock; ThreadPoolExecutor and ProcessPoolExecutor manage OS threads/processes."
    - "concurrent.futures.Future.__dict__ does not contain __reduce__, __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__."
    - "ThreadPoolExecutor and ProcessPoolExecutor likewise define none of the pickle protocol dunders in their own __dict__."
    - "concurrent.futures types also do not define __copy__ or __deepcopy__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods absent from concurrent.futures class __dict__
#
# concurrent.futures.Future wraps a threading.Condition and cannot be pickled.
# ThreadPoolExecutor and ProcessPoolExecutor manage OS-level thread and process
# pools and are likewise not picklable.  None define the pickle dunders in
# their own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1696.pickling_protocol:
  description: "concurrent.futures types pickling protocol dict-presence checks — Future, ThreadPoolExecutor, ProcessPoolExecutor define none of the pickle protocol dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1696

  columns: [id, function, args, expected]
  rows:
    - ["cf1696001", "Future.__dict__.__contains__",              ["__reduce__"],        false]
    - ["cf1696002", "Future.__dict__.__contains__",              ["__getstate__"],      false]
    - ["cf1696003", "Future.__dict__.__contains__",              ["__setstate__"],      false]
    - ["cf1696004", "Future.__dict__.__contains__",              ["__getnewargs__"],    false]
    - ["cf1696005", "Future.__dict__.__contains__",              ["__getnewargs_ex__"], false]
    - ["cf1696006", "ThreadPoolExecutor.__dict__.__contains__",  ["__reduce__"],        false]
    - ["cf1696007", "ThreadPoolExecutor.__dict__.__contains__",  ["__getstate__"],      false]
    - ["cf1696008", "ThreadPoolExecutor.__dict__.__contains__",  ["__setstate__"],      false]
    - ["cf1696009", "ThreadPoolExecutor.__dict__.__contains__",  ["__getnewargs__"],    false]
    - ["cf1696010", "ThreadPoolExecutor.__dict__.__contains__",  ["__getnewargs_ex__"], false]
    - ["cf1696011", "ProcessPoolExecutor.__dict__.__contains__", ["__reduce__"],        false]
    - ["cf1696012", "ProcessPoolExecutor.__dict__.__contains__", ["__getstate__"],      false]
    - ["cf1696013", "ProcessPoolExecutor.__dict__.__contains__", ["__setstate__"],      false]
    - ["cf1696014", "ProcessPoolExecutor.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["cf1696015", "ProcessPoolExecutor.__dict__.__contains__", ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: Copy protocol and Executor base class dict checks
#
# __copy__ and __deepcopy__ are likewise absent from concurrent.futures types.
# The abstract Executor base class also defines none of the pickle or copy
# protocol dunders in its own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1696.copy_protocol:
  description: "concurrent.futures types copy protocol and Executor base class dict-presence checks — Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor define no __copy__ or __deepcopy__; Executor defines no pickle dunders either"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1696

  columns: [id, function, args, expected]
  rows:
    - ["cf1696016", "Future.__dict__.__contains__",              ["__copy__"],      false]
    - ["cf1696017", "Future.__dict__.__contains__",              ["__deepcopy__"],  false]
    - ["cf1696018", "ThreadPoolExecutor.__dict__.__contains__",  ["__copy__"],      false]
    - ["cf1696019", "ThreadPoolExecutor.__dict__.__contains__",  ["__deepcopy__"],  false]
    - ["cf1696020", "ProcessPoolExecutor.__dict__.__contains__", ["__copy__"],      false]
    - ["cf1696021", "ProcessPoolExecutor.__dict__.__contains__", ["__deepcopy__"],  false]
    - ["cf1696022", "Executor.__dict__.__contains__",            ["__reduce__"],    false]
    - ["cf1696023", "Executor.__dict__.__contains__",            ["__getstate__"],  false]
    - ["cf1696024", "Executor.__dict__.__contains__",            ["__copy__"],      false]
    - ["cf1696025", "Executor.__dict__.__contains__",            ["__deepcopy__"],  false]
