  columns: [id, function, args, expected]
  rows:
    - ["lh_ABC",                  operator.contains, [ABC.__dict__,                  "__length_hint__"], false]
    - ["lh_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__length_hint__"], false]
    - ["lh_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__length_hint__"], false]
    - ["lh_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__length_hint__"], false]
    - ["lh_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__length_hint__"], false]
    - ["lh_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__length_hint__"], false]

# ---------------------------------------------------------------------------
# __contains__ dict-presence — operator.contains(Cls.__dict__, '__contains__')
#
# No abc class defines __contains__; all results are false.
# ---------------------------------------------------------------------------

table ab2986.contains:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_contains
  id_prefix: con

  columns: [id, function, args, expected]
  rows:
    - ["con_ABC",                  operator.contains, [ABC.__dict__,                  "__contains__"], false]
    - ["con_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__contains__"], false]
    - ["con_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__contains__"], false]
    - ["con_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__contains__"], false]
    - ["con_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__contains__"], false]
    - ["con_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__contains__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Core cross-product: 6 subjects x 3 operators = 18 rows.  Padded with
# additional lookups on ABCMeta (as metaclass of ABC), object, and type
# to bring the table to 24 rows for consistency with the wave 646 target.
# All rows confirm the absence of container protocol dunder slots.
# ---------------------------------------------------------------------------

table ab2986.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_ABC_len",                   operator.contains, [ABC.__dict__,                  "__len__"],         false]
    - ["comb_ABC_lh",                    operator.contains, [ABC.__dict__,                  "__length_hint__"], false]
    - ["comb_ABC_con",                   operator.contains, [ABC.__dict__,                  "__contains__"],    false]
    - ["comb_ABCMeta_len",               operator.contains, [ABCMeta.__dict__,              "__len__"],         false]
    - ["comb_ABCMeta_lh",                operator.contains, [ABCMeta.__dict__,              "__length_hint__"], false]
    - ["comb_ABCMeta_con",               operator.contains, [ABCMeta.__dict__,              "__contains__"],    false]
    - ["comb_abstractmethod_len",        operator.contains, [abstractmethod.__dict__,       "__len__"],         false]
    - ["comb_abstractmethod_lh",         operator.contains, [abstractmethod.__dict__,       "__length_hint__"], false]
    - ["comb_abstractmethod_con",        operator.contains, [abstractmethod.__dict__,       "__contains__"],    false]
    - ["comb_abstractproperty_len",      operator.contains, [abstractproperty.__dict__,     "__len__"],         false]
    - ["comb_abstractproperty_lh",       operator.contains, [abstractproperty.__dict__,     "__length_hint__"], false]
    - ["comb_abstractproperty_con",      operator.contains, [abstractproperty.__dict__,     "__contains__"],    false]
    - ["comb_abstractclassmethod_len",   operator.contains, [abstractclassmethod.__dict__,  "__len__"],         false]
    - ["comb_abstractclassmethod_lh",    operator.contains, [abstractclassmethod.__dict__,  "__length_hint__"], false]
    - ["comb_abstractclassmethod_con",   operator.contains, [abstractclassmethod.__dict__,  "__contains__"],    false]
    - ["comb_abstractstaticmethod_len",  operator.contains, [abstractstaticmethod.__dict__, "__len__"],         false]
    - ["comb_abstractstaticmethod_lh",   operator.contains, [abstractstaticmethod.__dict__, "__length_hint__"], false]
    - ["comb_abstractstaticmethod_con",  operator.contains, [abstractstaticmethod.__dict__, "__contains__"],    false]
    - ["comb_ABC_class_len",             operator.contains, [ABC.__class__.__dict__,        "__len__"],         false]
    - ["comb_ABC_class_lh",              operator.contains, [ABC.__class__.__dict__,        "__length_hint__"], false]
    - ["comb_ABC_class_con",             operator.contains, [ABC.__class__.__dict__,        "__contains__"],    false]
    - ["comb_object_len",                operator.contains, [object.__dict__,               "__len__"],         false]
    - ["comb_object_lh",                 operator.contains, [object.__dict__,               "__length_hint__"], false]
    - ["comb_object_con",                operator.contains, [object.__dict__,               "__contains__"],    false]
