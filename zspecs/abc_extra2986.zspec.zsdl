spec: ab2986
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 646 — theme: __len__, __length_hint__, __contains__ dict-presence (container/sequence protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__len__') etc. for abc module classes."
    - "Classes covered: ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod."
    - "None of these abc classes define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "abc.abstractmethod is a plain function (type 'function'); its __dict__ has no container protocol slots."
    - "ABC uses ABCMeta as its metaclass; ABCMeta.__dict__ also defines no container protocol slots."
    - "abstractproperty, abstractclassmethod, abstractstaticmethod are deprecated since Python 3.3 but still present in CPython 3.14."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# No abc class defines __len__; all results are false.
# ---------------------------------------------------------------------------

table ab2986.len:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_len
  id_prefix: len

  columns: [id, function, args, expected]
  rows:
    - ["len_ABC",                  operator.contains, [ABC.__dict__,                  "__len__"], false]
    - ["len_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__len__"], false]
    - ["len_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__len__"], false]
    - ["len_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__len__"], false]
    - ["len_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__len__"], false]
    - ["len_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__len__"], false]

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — operator.contains(Cls.__dict__, '__length_hint__')
#
# No abc class defines __length_hint__; all results are false.
# ---------------------------------------------------------------------------

table ab2986.length_hint:
  kind: python_call_eq
