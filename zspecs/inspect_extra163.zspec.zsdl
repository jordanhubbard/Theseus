spec: inspect_extra163
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getfile.__code__.co_argcount 1; inspect.getfile.__code__.co_name 'getfile'; inspect.getmodule.__code__.co_argcount 2; inspect.getmodule.__code__.co_name 'getmodule'; inspect.getdoc.__code__.co_argcount 1; inspect.getfile.__module__ 'inspect'; inspect.getmodule.__module__ 'inspect' (Wave 292)."
    - "inspect.getfile.__code__.co_argcount == 1 — getfile(object) takes 1 positional-or-keyword argument (the object whose source file is sought); co_argcount is 1. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_name == 'getfile' — getfile is a Python function defined in Lib/inspect.py; its code object co_name is 'getfile'. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_argcount == 2 — getmodule(object, _filename=None) takes 2 positional-or-keyword arguments; co_argcount is 2. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_name == 'getmodule' — getmodule is a Python function defined in Lib/inspect.py; its code object co_name is 'getmodule'. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_argcount == 1 — getdoc(object) takes 1 positional-or-keyword argument (the object whose docstring is retrieved); co_argcount is 1. Verified with Python 3.14.3."
    - "inspect.getfile.__module__ == 'inspect' — getfile is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getmodule.__module__ == 'inspect' — getmodule is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getfile code object attributes
#
# Wave 292 theme: inspect.getfile function code attributes — argument count,
# code name, and module.
#
# inspect.getfile.__code__.co_argcount == 1
# inspect.getfile.__code__.co_name == 'getfile'
# inspect.getfile.__module__ == 'inspect'
# inspect.getmodule.__code__.co_argcount == 2
#
# inspect.getfile(object) returns the name of the Python source file in which
# an object was defined. It works for modules, classes, methods, functions, and
# code objects. It raises OSError if the source cannot be determined. It is a
# Python function defined in Lib/inspect.py that takes 1 positional-or-keyword
# argument (the object), so co_argcount is 1. New to extra163.
# ---------------------------------------------------------------------------

table inspect_extra163.getfile_code_attributes:
  description: "inspect.getfile: co_argcount 1, co_name 'getfile', __module__ 'inspect'; getmodule co_argcount 2; wave 292; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgfca163

  columns: [id, function, args, expected, description]
  rows:
    - [gf_argc_eq_1,
       "getfile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile(object) takes 1 positional-or-keyword argument (the object whose source file is sought); it raises OSError if the file cannot be determined; co_argcount is 1; int.__eq__(1) returns True; new to extra163"]
    - [gf_co_name_eq_getfile,
       "getfile.__code__.co_name.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__code__.co_name.__eq__('getfile') == True — getfile is a Python function in Lib/inspect.py that returns the name of the Python source file in which an object was defined; its code object co_name is 'getfile'; str.__eq__('getfile') returns True; new to extra163"]
    - [gf_module_eq_inspect,
       "getfile.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra163"]
    - [gm_argc_eq_2,
       "getmodule.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule(object, _filename=None) takes 2 positional-or-keyword arguments: object and the optional _filename hint; co_argcount is 2; int.__eq__(2) returns True; new to extra163"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmodule and inspect.getdoc code attributes
#
# Wave 292 theme: inspect.getmodule and inspect.getdoc function code attributes
# — code name, module, and argument count.
#
# inspect.getmodule.__code__.co_name == 'getmodule'
# inspect.getmodule.__module__ == 'inspect'
# inspect.getdoc.__code__.co_argcount == 1
# inspect.getdoc.__code__.co_name == 'getdoc'
#
# inspect.getmodule(object, _filename=None) attempts to return the module that
# an object was defined in. It inspects sys.modules and uses the source file
# path heuristic when module lookup fails. It takes 2 arguments (object plus
# optional _filename for path disambiguation), so co_argcount is 2.
# inspect.getdoc(object) returns the documentation string for an object,
# cleaned up with cleandoc; it takes 1 argument; co_argcount is 1.
# Both are Python functions in Lib/inspect.py. New to extra163.
# ---------------------------------------------------------------------------

table inspect_extra163.getmodule_and_getdoc_code_attributes:
  description: "inspect: getmodule co_name 'getmodule', getmodule __module__ 'inspect', getdoc co_argcount 1, getdoc co_name 'getdoc'; wave 292; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgmgdca163

  columns: [id, function, args, expected, description]
  rows:
    - [gm_co_name_eq_getmodule,
       "getmodule.__code__.co_name.__eq__",
       ["getmodule"],
       true,
       "inspect.getmodule.__code__.co_name.__eq__('getmodule') == True — getmodule is a Python function in Lib/inspect.py that attempts to return the module an object was defined in; its code object co_name is 'getmodule'; str.__eq__('getmodule') returns True; new to extra163"]
    - [gm_module_eq_inspect,
       "getmodule.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmodule.__module__.__eq__('inspect') == True — getmodule is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra163"]
    - [gd_argc_eq_1,
       "getdoc.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc(object) takes 1 positional-or-keyword argument (the object whose cleaned-up docstring is retrieved); co_argcount is 1; int.__eq__(1) returns True; new to extra163"]
    - [gd_co_name_eq_getdoc,
       "getdoc.__code__.co_name.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — getdoc is a Python function in Lib/inspect.py that retrieves and cleans the documentation string for an object; its code object co_name is 'getdoc'; str.__eq__('getdoc') returns True; new to extra163"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra163
# ---------------------------------------------------------------------------

invariant inspect_extra163.getfile_co_argcount_1:
  description: "inspect.getfile.__code__.co_argcount == 1 — getfile(object) takes 1 argument; raises OSError if source not found; wave 292; new to extra163"
  kind: python_call_eq
  function: getfile.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra163.getfile_co_name:
  description: "inspect.getfile.__code__.co_name == 'getfile' — code object name for getfile in Lib/inspect.py; wave 292; new to extra163"
  kind: python_call_eq
  function: getfile.__code__.co_name.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra163.getfile_module_inspect:
  description: "inspect.getfile.__module__ == 'inspect' — getfile is defined in Lib/inspect.py; wave 292; new to extra163"
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra163.getmodule_co_argcount_2:
  description: "inspect.getmodule.__code__.co_argcount == 2 — getmodule(object, _filename=None) takes 2 arguments; wave 292; new to extra163"
  kind: python_call_eq
  function: getmodule.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra163.getmodule_co_name:
  description: "inspect.getmodule.__code__.co_name == 'getmodule' — code object name for getmodule in Lib/inspect.py; wave 292; new to extra163"
  kind: python_call_eq
  function: getmodule.__code__.co_name.__eq__
  args: ["getmodule"]
  expected: true

invariant inspect_extra163.getmodule_module_inspect:
  description: "inspect.getmodule.__module__ == 'inspect' — getmodule is defined in Lib/inspect.py; wave 292; new to extra163"
  kind: python_call_eq
  function: getmodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra163.getdoc_co_argcount_1:
  description: "inspect.getdoc.__code__.co_argcount == 1 — getdoc(object) takes 1 argument; returns cleaned docstring; wave 292; new to extra163"
  kind: python_call_eq
  function: getdoc.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra163.getdoc_co_name:
  description: "inspect.getdoc.__code__.co_name == 'getdoc' — code object name for getdoc in Lib/inspect.py; wave 292; new to extra163"
  kind: python_call_eq
  function: getdoc.__code__.co_name.__eq__
  args: ["getdoc"]
  expected: true
