spec: uuid_extra1246
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid __doc__ class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that uuid module, UUID class, SafeUUID enum, and uuid generator functions have str __doc__ attributes; verifies __doc__.__class__.__name__ eq str is true and eq NoneType is false"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1246.module_doc_class:
  description: "uuid module, UUID class, SafeUUID, and generator functions __doc__ is a str"
  kind: python_call_eq
  category: doc_class
  id_prefix: uu1246md
  columns: [id, function, args, expected]
  rows:
    - [uu1246md001, uuid.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [uu1246md002, uuid.UUID.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [uu1246md003, uuid.uuid1.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246md004, uuid.uuid3.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246md005, uuid.uuid4.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246md006, uuid.uuid5.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246md007, uuid.SafeUUID.__doc__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra1246.module_doc_not_nonetype:
  description: "uuid module, UUID class, SafeUUID, and generator functions __doc__ is not NoneType"
  kind: python_call_eq
  category: doc_not_nonetype
  id_prefix: uu1246mn
  columns: [id, function, args, expected]
  rows:
    - [uu1246mn001, uuid.__doc__.__class__.__name__.__eq__,          ["NoneType"], false]
    - [uu1246mn002, uuid.UUID.__doc__.__class__.__name__.__eq__,     ["NoneType"], false]
    - [uu1246mn003, uuid.uuid1.__doc__.__class__.__name__.__eq__,    ["NoneType"], false]
    - [uu1246mn004, uuid.uuid3.__doc__.__class__.__name__.__eq__,    ["NoneType"], false]
    - [uu1246mn005, uuid.uuid4.__doc__.__class__.__name__.__eq__,    ["NoneType"], false]
    - [uu1246mn006, uuid.uuid5.__doc__.__class__.__name__.__eq__,    ["NoneType"], false]
    - [uu1246mn007, uuid.SafeUUID.__doc__.__class__.__name__.__eq__, ["NoneType"], false]

table uuid_extra1246.doc_class_name_is_str:
  description: "uuid __doc__ class name is itself a str (meta-level check)"
  kind: python_call_eq
  category: doc_class_name_is_str
  id_prefix: uu1246ds
  columns: [id, function, args, expected]
  rows:
    - [uu1246ds001, uuid.__doc__.__class__.__name__.__class__.__name__.__eq__,          ["str"], true]
    - [uu1246ds002, uuid.UUID.__doc__.__class__.__name__.__class__.__name__.__eq__,     ["str"], true]
    - [uu1246ds003, uuid.uuid1.__doc__.__class__.__name__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246ds004, uuid.uuid3.__doc__.__class__.__name__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246ds005, uuid.uuid4.__doc__.__class__.__name__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246ds006, uuid.uuid5.__doc__.__class__.__name__.__class__.__name__.__eq__,    ["str"], true]
    - [uu1246ds007, uuid.SafeUUID.__doc__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
