spec: socket_extra1111
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.__name__ and class attrs, socket.__spec__.name, socket.socket.__doc__ class attrs, socket.AF_INET/AF_INET6 AddressFamily class attrs, socket.SOCK_STREAM/SOCK_DGRAM SocketKind class attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1111.module_name_and_spec:
  description: "socket.__name__ and socket.__spec__.name identity and class attributes"
  kind: python_call_eq
  category: module_name_spec
  id_prefix: sk1111mn
  columns: [id, function, args, expected]
  rows:
    - [sk1111mn001, socket.__name__.__eq__,                              ["socket"],   true]
    - [sk1111mn002, socket.__name__.__class__.__name__.__eq__,           ["str"],      true]
    - [sk1111mn003, socket.__name__.__class__.__qualname__.__eq__,       ["str"],      true]
    - [sk1111mn004, socket.__name__.__class__.__module__.__eq__,         ["builtins"], true]
    - [sk1111mn005, socket.__spec__.name.__eq__,                         ["socket"],   true]
    - [sk1111mn006, socket.__spec__.name.__class__.__name__.__eq__,      ["str"],      true]
    - [sk1111mn007, socket.socket.__doc__.__class__.__name__.__eq__,     ["str"],      true]
    - [sk1111mn008, socket.socket.__doc__.__class__.__qualname__.__eq__, ["str"],      true]
    - [sk1111mn009, socket.socket.__doc__.__class__.__module__.__eq__,   ["builtins"], true]

