spec: functools_extra84
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra83.zspec.zsdl."
    - "This spec covers: functools reduce/cmp_to_key C-type identity + lru_cache wrapper attributes + update_wrapper/wraps code attrs (Wave 244)."
    - "reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin. Verified with Python 3.14.3."
    - "reduce.__module__ == '_functools' — reduce lives in the _functools C extension, not the Python functools wrapper. Verified with Python 3.14.3."
    - "cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin. Verified with Python 3.14.3."
    - "cmp_to_key.__module__ == '_functools' — cmp_to_key lives in the _functools C extension. Verified with Python 3.14.3."
    - "lru_cache.__class__.__name__ == 'function' — lru_cache itself (the decorator factory) is a pure-Python function. Verified with Python 3.14.3."
    - "lru_cache.__module__ == 'functools' — lru_cache is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "lru_cache has no __wrapped__ attribute — lru_cache is not itself a wrapped function; accessing __wrapped__ raises AttributeError. Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_name == 'update_wrapper' — code object name matches function name. Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_argcount == 4 — wrapper, wrapped, assigned, updated. Verified with Python 3.14.3."
    - "wraps.__code__.co_name == 'wraps' — code object name matches function name. Verified with Python 3.14.3."
    - "wraps.__code__.co_argcount == 3 — wrapped, assigned, updated. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reduce C-type identity — extra84
#
# Wave 244 theme: reduce is a C builtin in the _functools extension.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__module__         == '_functools'
#
# No prior functools spec checks reduce.__class__.__name__ via functoolsextra84. New to extra84.
# ---------------------------------------------------------------------------

table functools_extra84.reduce_identity:
  description: "reduce.__class__.__name__=='builtin_function_or_method', __module__=='_functools'; wave 244 reduce C-type identity; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra84

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin_function_or_method,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C extension function defined in Modules/_functoolsmodule.c; it is exposed as a builtin_function_or_method, the same class as functions like len and sorted; __class__.__name__ == 'builtin_function_or_method' (26 chars); str.__eq__('builtin_function_or_method') returns True; no prior functools spec checks reduce.__class__.__name__ via functoolsextra84; new to extra84"]
    - [reduce_module_eq__functools,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in the _functools C extension module (Modules/_functoolsmodule.c) and its __module__ attribute records '_functools' (10 chars), not 'functools'; the Python functools module re-exports it via 'from _functools import reduce'; str.__eq__('_functools') returns True; no prior functools spec checks reduce.__module__ via functoolsextra84; new to extra84"]

# ---------------------------------------------------------------------------
# cmp_to_key C-type identity — extra84
#
# Wave 244 theme: cmp_to_key is a C builtin in the _functools extension.
#
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__module__         == '_functools'
#
# No prior functools spec checks cmp_to_key.__class__.__name__ via functoolsextra84. New to extra84.
# ---------------------------------------------------------------------------

table functools_extra84.cmp_to_key_identity:
  description: "cmp_to_key.__class__.__name__=='builtin_function_or_method', __module__=='_functools'; wave 244 cmp_to_key C-type identity; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra84

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_class_name_eq_builtin_function_or_method,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C extension function defined in Modules/_functoolsmodule.c; it is exposed as a builtin_function_or_method; __class__.__name__ == 'builtin_function_or_method' (26 chars); str.__eq__('builtin_function_or_method') returns True; no prior functools spec checks cmp_to_key.__class__.__name__ via functoolsextra84; new to extra84"]
    - [cmp_to_key_module_eq__functools,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in the _functools C extension module (Modules/_functoolsmodule.c) and its __module__ attribute records '_functools' (10 chars); the Python functools module re-exports it via 'from _functools import cmp_to_key'; str.__eq__('_functools') returns True; no prior functools spec checks cmp_to_key.__module__ via functoolsextra84; new to extra84"]

# ---------------------------------------------------------------------------
# lru_cache function identity and __wrapped__ absence — extra84
#
# Wave 244 theme: lru_cache is a pure-Python function; it has no __wrapped__ attr.
#
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__module__         == 'functools'
# accessing functools.lru_cache.__wrapped__ raises AttributeError
#
# No prior functools spec checks lru_cache identity via functoolsextra84. New to extra84.
# ---------------------------------------------------------------------------

table functools_extra84.lru_cache_identity:
  description: "lru_cache.__class__.__name__=='function', __module__=='functools'; __wrapped__ raises AttributeError; wave 244 lru_cache identity; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra84

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_class_name_eq_function,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache (the decorator factory) is a pure-Python function defined in Lib/functools.py; unlike the result of calling lru_cache(), lru_cache itself is a plain function object; __class__.__name__ == 'function' (8 chars); str.__eq__('function') returns True; no prior functools spec checks lru_cache.__class__.__name__ via functoolsextra84; new to extra84"]
    - [lru_cache_module_eq_functools,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py and its __module__ attribute records 'functools' (9 chars); str.__eq__('functools') returns True; no prior functools spec checks lru_cache.__module__ via functoolsextra84; new to extra84"]

invariant functools_extra84.lru_cache_no_wrapped:
  description: "functools.lru_cache.__wrapped__ raises AttributeError — lru_cache has no __wrapped__ attribute; wave 244 lru_cache identity; new to extra84"
  kind: python_call_raises
  function: lru_cache.__getattribute__
  args: ["__wrapped__"]
  expected_exception: AttributeError

# ---------------------------------------------------------------------------
# update_wrapper and wraps code objects — extra84
#
# Wave 244 theme: update_wrapper/wraps code object attributes.
#
# functools.update_wrapper.__code__.co_name     == 'update_wrapper'
# functools.update_wrapper.__code__.co_argcount == 4
# functools.wraps.__code__.co_name              == 'wraps'
# functools.wraps.__code__.co_argcount          == 3
#
# No prior functools spec checks update_wrapper/wraps code objects via functoolsextra84. New to extra84.
# ---------------------------------------------------------------------------

table functools_extra84.update_wrapper_wraps_code:
  description: "update_wrapper.__code__.co_name=='update_wrapper', co_argcount==4; wraps co_name=='wraps', co_argcount==3; wave 244 update_wrapper/wraps code attrs; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra84

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_code_co_name_eq_update_wrapper,
       update_wrapper.__code__.co_name.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function defined in Lib/functools.py; its code object's co_name attribute records the function name 'update_wrapper' (14 chars); str.__eq__('update_wrapper') returns True; no prior functools spec checks update_wrapper.__code__.co_name via functoolsextra84; new to extra84"]
    - [update_wrapper_code_co_argcount_eq_4,
       update_wrapper.__code__.co_argcount.__eq__,
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) takes four positional-or-keyword arguments: wrapper, wrapped, assigned, and updated (the last two have defaults); the code object's co_argcount is 4; int.__eq__(4) returns True; no prior functools spec checks update_wrapper.__code__.co_argcount via functoolsextra84; new to extra84"]
    - [wraps_code_co_name_eq_wraps,
       wraps.__code__.co_name.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__code__.co_name.__eq__('wraps') == True — wraps is a pure-Python function defined in Lib/functools.py that is a convenience wrapper around update_wrapper; its code object's co_name attribute records the function name 'wraps' (5 chars); str.__eq__('wraps') returns True; no prior functools spec checks wraps.__code__.co_name via functoolsextra84; new to extra84"]
    - [wraps_code_co_argcount_eq_3,
       wraps.__code__.co_argcount.__eq__,
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) takes three positional-or-keyword arguments: wrapped, assigned, and updated (assigned and updated have defaults); the code object's co_argcount is 3; int.__eq__(3) returns True; no prior functools spec checks wraps.__code__.co_argcount via functoolsextra84; new to extra84"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra84
# ---------------------------------------------------------------------------

invariant functools_extra84.reduce_class_name:
  description: "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin; wave 244 reduce C-type identity; new to extra84"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra84.reduce_module:
  description: "functools.reduce.__module__.__eq__('_functools') == True — reduce lives in the _functools C extension; wave 244 reduce identity; new to extra84"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra84.cmp_to_key_module:
  description: "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key lives in the _functools C extension; wave 244 cmp_to_key identity; new to extra84"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra84.update_wrapper_code_co_argcount:
  description: "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper(wrapper, wrapped, assigned, updated) has 4 positional-or-keyword args; wave 244 update_wrapper code attrs; new to extra84"
  kind: python_call_eq
  function: update_wrapper.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant functools_extra84.wraps_code_co_argcount:
  description: "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps(wrapped, assigned, updated) has 3 positional-or-keyword args; wave 244 wraps code attrs; new to extra84"
  kind: python_call_eq
  function: wraps.__code__.co_argcount.__eq__
  args: [3]
  expected: true
