spec: inspect_extra2086
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__, __release_buffer__ dict-presence checks for inspect module types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.BufferFlags is an IntFlag enum; it defines __format__ in its own __dict__ (True) because IntFlag/IntEnum overrides __format__ to control flag rendering. Verified: '__format__' in inspect.BufferFlags.__dict__ == True."
    - "inspect.Format is an IntEnum; it also defines __format__ in its own __dict__ (True) for the same reason — enum integer types override __format__."
    - "inspect._ParameterKind is an IntEnum; it defines __format__ in its own __dict__ (True)."
    - "All other inspect types (FullArgSpec, Parameter, Signature, BoundArguments, FrameInfo, ArgInfo, Attribute, Traceback, ClosureVars, Arguments) are namedtuples or plain Python classes; they define none of the 5 dunders in their own __dict__."
    - "No inspect type defines __bytes__, __fspath__, __buffer__, or __release_buffer__ in its own __dict__."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __format__ dict-presence for inspect types
#
# inspect.BufferFlags (IntFlag), inspect.Format (IntEnum), and
# inspect._ParameterKind (IntEnum) each define __format__ in their own
# __dict__ because IntEnum/IntFlag overrides __format__ to render flag
# and enum values correctly.
#
# Namedtuple-based types (FullArgSpec, ArgInfo, FrameInfo, Traceback,
# ClosureVars, Arguments, Attribute) do NOT define __format__ in their
# own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2086.format_protocol:
  description: "inspect types __format__ dict-presence — True for IntEnum/IntFlag subclasses, False for all others"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2086

  columns: [id, function, args, expected]
  rows:
    - ["in2086001", "inspect.BufferFlags.__dict__.__contains__", ["__format__"], true]
    - ["in2086002", "inspect.Format.__dict__.__contains__", ["__format__"], true]
    - ["in2086003", "inspect._ParameterKind.__dict__.__contains__", ["__format__"], true]
    - ["in2086004", "inspect.FullArgSpec.__dict__.__contains__", ["__format__"], false]
    - ["in2086005", "inspect.Parameter.__dict__.__contains__", ["__format__"], false]
    - ["in2086006", "inspect.Signature.__dict__.__contains__", ["__format__"], false]
    - ["in2086007", "inspect.BoundArguments.__dict__.__contains__", ["__format__"], false]
    - ["in2086008", "inspect.FrameInfo.__dict__.__contains__", ["__format__"], false]
    - ["in2086009", "inspect.ArgInfo.__dict__.__contains__", ["__format__"], false]
    - ["in2086010", "inspect.Attribute.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# Table 2: __bytes__ dict-presence for inspect types
#
# No inspect type defines __bytes__ in its own __dict__. Inspection
# types represent code structure metadata, not binary data.
# ---------------------------------------------------------------------------

table inspect_extra2086.bytes_protocol:
  description: "inspect types __bytes__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2086

  columns: [id, function, args, expected]
  rows:
    - ["in2086011", "inspect.BufferFlags.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086012", "inspect.Format.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086013", "inspect._ParameterKind.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086014", "inspect.Parameter.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086015", "inspect.Signature.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086016", "inspect.BoundArguments.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086017", "inspect.Traceback.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086018", "inspect.ClosureVars.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# Table 3: __fspath__ dict-presence for inspect types
#
# Inspect types represent introspection data structures, not filesystem
# paths. None define __fspath__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2086.fspath_protocol:
  description: "inspect types __fspath__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2086

  columns: [id, function, args, expected]
  rows:
    - ["in2086019", "inspect.BufferFlags.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086020", "inspect.Format.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086021", "inspect._ParameterKind.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086022", "inspect.FullArgSpec.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086023", "inspect.Parameter.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086024", "inspect.Signature.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086025", "inspect.FrameInfo.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086026", "inspect.ArgInfo.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 4: __buffer__ / __release_buffer__ dict-presence for inspect types
#
# Despite inspect.BufferFlags being named after the C buffer protocol,
# it is an IntFlag enum representing buffer flag bitmasks — it is NOT
# itself a buffer provider. Neither __buffer__ nor __release_buffer__
# appear in any inspect type's own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2086.buffer_protocol:
  description: "inspect types __buffer__/__release_buffer__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2086

  columns: [id, function, args, expected]
  rows:
    - ["in2086027", "inspect.BufferFlags.__dict__.__contains__", ["__buffer__"], false]
    - ["in2086028", "inspect.BufferFlags.__dict__.__contains__", ["__release_buffer__"], false]
    - ["in2086029", "inspect.Format.__dict__.__contains__", ["__buffer__"], false]
    - ["in2086030", "inspect.Format.__dict__.__contains__", ["__release_buffer__"], false]
    - ["in2086031", "inspect._ParameterKind.__dict__.__contains__", ["__buffer__"], false]
    - ["in2086032", "inspect._ParameterKind.__dict__.__contains__", ["__release_buffer__"], false]
    - ["in2086033", "inspect.Parameter.__dict__.__contains__", ["__buffer__"], false]
    - ["in2086034", "inspect.Parameter.__dict__.__contains__", ["__release_buffer__"], false]
    - ["in2086035", "inspect.Signature.__dict__.__contains__", ["__buffer__"], false]
    - ["in2086036", "inspect.Signature.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# Table 5: Cross-check — BufferFlags __format__ True, all others False
#
# Confirms the distinguishing result: BufferFlags, Format, and _ParameterKind
# each define __format__ (IntEnum/IntFlag characteristic) but define none
# of the other 4 protocol dunders in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2086.enum_protocol_cross_check:
  description: "inspect enum types: __format__ True, __bytes__/__fspath__/__buffer__/__release_buffer__ all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2086

  columns: [id, function, args, expected]
  rows:
    - ["in2086037", "inspect.BufferFlags.__dict__.__contains__", ["__format__"], true]
    - ["in2086038", "inspect.BufferFlags.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086039", "inspect.BufferFlags.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086040", "inspect.BufferFlags.__dict__.__contains__", ["__buffer__"], false]
    - ["in2086041", "inspect.BufferFlags.__dict__.__contains__", ["__release_buffer__"], false]
    - ["in2086042", "inspect.Format.__dict__.__contains__", ["__format__"], true]
    - ["in2086043", "inspect.Format.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086044", "inspect.Format.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086045", "inspect._ParameterKind.__dict__.__contains__", ["__format__"], true]
    - ["in2086046", "inspect._ParameterKind.__dict__.__contains__", ["__bytes__"], false]
    - ["in2086047", "inspect._ParameterKind.__dict__.__contains__", ["__fspath__"], false]
    - ["in2086048", "inspect.Attribute.__dict__.__contains__", ["__format__"], false]
    - ["in2086049", "inspect.Traceback.__dict__.__contains__", ["__format__"], false]
    - ["in2086050", "inspect.ClosureVars.__dict__.__contains__", ["__format__"], false]
