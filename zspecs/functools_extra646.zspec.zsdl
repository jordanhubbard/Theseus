spec: functools_extra646
version: ">=3.9"
backend: python_module(functools)
docs: "Behavioral spec for functools.partial attribute descriptors and lru_cache/cache identity checks."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers descriptor __class__.__name__ and __qualname__ for functools.partial attributes, and function identity checks for lru_cache and cache."
  created_at: "2026-04-12T00:00:00Z"

table functools_extra646.partial_attr_descriptors:
  description: "Check that functools.partial attribute descriptors report correct __class__.__name__"
  kind: python_call_eq
  category: attribute_descriptor
  id_prefix: ft646pa
  columns: [id, function, args, expected]
  rows:
    - [ft646pa001, functools.partial.func.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ft646pa002, functools.partial.args.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ft646pa003, functools.partial.keywords.__class__.__name__.__eq__, ["getset_descriptor"], true]

table functools_extra646.partial_attr_qualnames:
  description: "Check that functools.partial attribute descriptors report correct __qualname__"
  kind: python_call_eq
  category: attribute_qualname
  id_prefix: ft646qn
  columns: [id, function, args, expected]
  rows:
    - [ft646qn001, functools.partial.func.__qualname__.__eq__, ["partial.func"], true]
    - [ft646qn002, functools.partial.args.__qualname__.__eq__, ["partial.args"], true]
    - [ft646qn003, functools.partial.keywords.__qualname__.__eq__, ["partial.keywords"], true]

table functools_extra646.lru_cache_identity:
  description: "Check __class__.__name__ and __qualname__ for functools.lru_cache and functools.cache"
  kind: python_call_eq
  category: function_identity
  id_prefix: ft646lo
  columns: [id, function, args, expected]
  rows:
    - [ft646lo001, functools.lru_cache.__class__.__name__.__eq__, ["function"], true]
    - [ft646lo002, functools.lru_cache.__qualname__.__eq__, ["lru_cache"], true]
    - [ft646lo003, functools.cache.__class__.__name__.__eq__, ["function"], true]
    - [ft646lo004, functools.cache.__qualname__.__eq__, ["cache"], true]
    - [ft646lo005, functools.cache.__module__.__eq__, ["functools"], true]
    - [ft646lo006, functools.cache.__doc__.__class__.__name__.__eq__, ["str"], true]
