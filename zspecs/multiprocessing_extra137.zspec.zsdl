invariant multiprocessing_extra137.client_co_argcount_3:
  description: "multiprocessing.connection.Client.__code__.co_argcount == 3 — Client takes ('address','family','authkey') as positional params (co_argcount==3); co_varnames.__len__()==4 (adds local 'c'); contrast with Pipe (co_argcount==1) and connection bound method multiprocessing.Pipe.__func__ (co_argcount==2, self+duplex); NEW in extra137: first standalone Client co_argcount invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Client.__code__.co_argcount
