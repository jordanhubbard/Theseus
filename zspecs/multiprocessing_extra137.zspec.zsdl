invariant multiprocessing_extra137.conn_pipe_module_len_26:
  description: "multiprocessing.connection.Pipe.__module__.__len__() == 26 — Pipe.__module__ is 'multiprocessing.connection' (26 chars: 'multiprocessing'=15+'.'=1+'connection'=10=26); same module length as Connection.__module__ (also 'multiprocessing.connection', len=26, covered in extra136); all three connection module public callables (Pipe, Client, Listener) share this module; NEW in extra137: first standalone connection.Pipe module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
