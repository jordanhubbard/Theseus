spec: multiprocessing_extra137
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.connection.html — multiprocessing.connection documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "This spec covers: multiprocessing.connection.Pipe (the module-level function, NOT the bound method multiprocessing.Pipe), multiprocessing.connection.Client (a function), and multiprocessing.connection.Listener (a class). multiprocessing.connection.Pipe is a plain function (type.__name__=='function'), distinct from multiprocessing.Pipe which is a bound method (type.__name__=='method', covered in extra136). Pipe.__qualname__=='Pipe' (len=4); Pipe.__module__=='multiprocessing.connection' (len=26); Pipe.__code__.co_argcount==1 ('duplex'); Pipe.__code__.co_varnames.__len__()==7. Client.__qualname__=='Client' (len=6); Client.__code__.co_argcount==3 ('address','family','authkey'); Client.__code__.co_varnames.__len__()==4. Listener.__name__=='Listener' (len=8); Listener.__module__=='multiprocessing.connection' (len=26); Listener.__bases__[0].__name__=='object'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.connection.Pipe is a standalone function (co_argcount==1, only 'duplex' is positional) with 7 local variables ('duplex','s1','s2','c1','c2','fd1','fd2'). multiprocessing.Pipe (accessed via multiprocessing module directly) is a bound method with __qualname__=='BaseContext.Pipe' and is covered in extra136. These are two distinct objects. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

