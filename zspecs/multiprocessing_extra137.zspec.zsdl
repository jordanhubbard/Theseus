  expected: 3

invariant multiprocessing_extra137.listener_name_len_8:
  description: "multiprocessing.connection.Listener.__name__.__len__() == 8 — Listener.__name__ is 'Listener' (8 chars); Listener.__module__=='multiprocessing.connection' (len=26); Listener.__bases__[0].__name__=='object' (direct subclass of object); Listener name len (8) is 2 more than Client qualname len (6) and 4 more than Pipe qualname len (4); NEW in extra137: first standalone Listener name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
