spec: socket_extra1936
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__.__name__ checks."
    - "socket.socket is a Python class but does NOT define descriptor protocol methods (__get__/__set__/__delete__) in its own __dict__."
    - "socket.error, socket.timeout, and socket.gaierror are exception subclasses; none define descriptor protocol methods in their own __dict__."
    - "None of the socket types define __set_name__ in their __dict__."
    - "socket.__class__.__name__ is 'module'; socket.socket.__class__.__name__ is 'type'; socket.error/timeout/gaierror.__class__.__name__ are 'type'."
    - "socket.AF_INET.__class__.__name__ is 'AddressFamily' (an IntEnum-based enum); socket.SOCK_STREAM.__class__.__name__ is 'SocketKind'."
    - "socket.socket.__dict__ does contain __init__ and close, but NOT bind/connect/send/recv (those are inherited from the C layer)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra1936.socket_type_descriptor_protocol:
  description: "socket.socket __get__/__set__/__delete__ dict-presence checks (not a descriptor)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1936

  columns: [id, function, args, expected]
  rows:
    - ["sk1936001", "socket.socket.__dict__.__contains__", ["__get__"], false]
    - ["sk1936002", "socket.socket.__dict__.__contains__", ["__set__"], false]
    - ["sk1936003", "socket.socket.__dict__.__contains__", ["__delete__"], false]

