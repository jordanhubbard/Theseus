spec: re_extra252
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re module function identity — __name__, __module__, and __class__.__name__ for the nine major public functions: compile, match, search, findall, sub, fullmatch, split, finditer, subn."
    - "All nine functions are plain Python function objects defined in Lib/re/__init__.py; their __class__.__name__ is 'function' and __module__ is 're'."
    - "re.compile wraps _sre.compile with a caching layer; its __name__ is 'compile' and __module__ is 're'."
    - "re.match, re.search, re.findall, re.sub, re.fullmatch, re.split, re.finditer, re.subn are thin wrapper functions in Lib/re/__init__.py that call Pattern methods on a compile()-cached object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re module function __name__ values
#
# All nine major re functions have __name__ equal to their unqualified
# function name. Covers: compile, match, search, findall, sub, fullmatch,
# split, finditer, subn.
# ---------------------------------------------------------------------------

table re_extra252.function_names:
  description: "re module function __name__ values — compile, match, search, findall, sub, fullmatch, split, finditer, subn; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: rexfn252

  columns: [id, function, args, expected, description]
  rows:
    - [compile_name,
       "compile.__name__.__eq__",
       ["compile"],
       true,
       "re.compile.__name__.__eq__('compile') == True — re.compile is the primary function for creating compiled Pattern objects from regex strings, with an internal LRU cache; its __name__ is 'compile'; str.__eq__('compile') returns True; new to extra252"]
    - [match_name,
       "match.__name__.__eq__",
       ["match"],
       true,
       "re.match.__name__.__eq__('match') == True — re.match attempts to match the pattern at the beginning of the string; its __name__ is 'match'; str.__eq__('match') returns True; new to extra252"]
    - [search_name,
       "search.__name__.__eq__",
       ["search"],
       true,
       "re.search.__name__.__eq__('search') == True — re.search scans through the string looking for the first location where the pattern produces a match; its __name__ is 'search'; str.__eq__('search') returns True; new to extra252"]
    - [findall_name,
       "findall.__name__.__eq__",
       ["findall"],
       true,
       "re.findall.__name__.__eq__('findall') == True — re.findall returns all non-overlapping matches of the pattern in the string as a list of strings; its __name__ is 'findall'; str.__eq__('findall') returns True; new to extra252"]
    - [sub_name,
       "sub.__name__.__eq__",
       ["sub"],
       true,
       "re.sub.__name__.__eq__('sub') == True — re.sub returns the string obtained by replacing the leftmost non-overlapping occurrences of the pattern with the replacement; its __name__ is 'sub'; str.__eq__('sub') returns True; new to extra252"]
    - [fullmatch_name,
       "fullmatch.__name__.__eq__",
       ["fullmatch"],
       true,
       "re.fullmatch.__name__.__eq__('fullmatch') == True — re.fullmatch checks if the entire string matches the pattern (added in Python 3.4); its __name__ is 'fullmatch'; str.__eq__('fullmatch') returns True; new to extra252"]
    - [split_name,
       "split.__name__.__eq__",
       ["split"],
       true,
       "re.split.__name__.__eq__('split') == True — re.split splits the string by the occurrences of the pattern; its __name__ is 'split'; str.__eq__('split') returns True; new to extra252"]
    - [finditer_name,
       "finditer.__name__.__eq__",
       ["finditer"],
       true,
       "re.finditer.__name__.__eq__('finditer') == True — re.finditer returns an iterator yielding Match objects for all non-overlapping matches; its __name__ is 'finditer'; str.__eq__('finditer') returns True; new to extra252"]
    - [subn_name,
       "subn.__name__.__eq__",
       ["subn"],
       true,
       "re.subn.__name__.__eq__('subn') == True — re.subn performs the same operation as re.sub but also returns the number of substitutions made as a tuple (new_string, count); its __name__ is 'subn'; str.__eq__('subn') returns True; new to extra252"]

# ---------------------------------------------------------------------------
# Table 2: re module function __module__ values
#
# All nine major re functions are defined in the re module (Lib/re/__init__.py);
# their __module__ is 're'. None are defined in _sre or _re.
# ---------------------------------------------------------------------------

table re_extra252.function_modules:
  description: "re module function __module__ values — all nine functions have __module__ == 're'; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: rexfm252

  columns: [id, function, args, expected, description]
  rows:
    - [compile_module,
       "compile.__module__.__eq__",
       ["re"],
       true,
       "re.compile.__module__.__eq__('re') == True — re.compile is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [match_module,
       "match.__module__.__eq__",
       ["re"],
       true,
       "re.match.__module__.__eq__('re') == True — re.match is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [search_module,
       "search.__module__.__eq__",
       ["re"],
       true,
       "re.search.__module__.__eq__('re') == True — re.search is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [findall_module,
       "findall.__module__.__eq__",
       ["re"],
       true,
       "re.findall.__module__.__eq__('re') == True — re.findall is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [sub_module,
       "sub.__module__.__eq__",
       ["re"],
       true,
       "re.sub.__module__.__eq__('re') == True — re.sub is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [fullmatch_module,
       "fullmatch.__module__.__eq__",
       ["re"],
       true,
       "re.fullmatch.__module__.__eq__('re') == True — re.fullmatch is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [split_module,
       "split.__module__.__eq__",
       ["re"],
       true,
       "re.split.__module__.__eq__('re') == True — re.split is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [finditer_module,
       "finditer.__module__.__eq__",
       ["re"],
       true,
       "re.finditer.__module__.__eq__('re') == True — re.finditer is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]
    - [subn_module,
       "subn.__module__.__eq__",
       ["re"],
       true,
       "re.subn.__module__.__eq__('re') == True — re.subn is defined in Lib/re/__init__.py; its __module__ is 're'; str.__eq__('re') returns True; new to extra252"]

# ---------------------------------------------------------------------------
# Table 3: re module function __class__.__name__ values
#
# All nine major re functions are plain Python function objects (not C
# builtins, not bound methods). Their __class__.__name__ is 'function'.
# ---------------------------------------------------------------------------

table re_extra252.function_class_names:
  description: "re module function __class__.__name__ values — all nine are plain Python 'function' objects; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: rexfcn252

  columns: [id, function, args, expected, description]
  rows:
    - [compile_class,
       "compile.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.compile.__class__.__name__.__eq__('function') == True — re.compile is a plain Python function defined in Lib/re/__init__.py (not a C builtin); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [match_class,
       "match.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.match.__class__.__name__.__eq__('function') == True — re.match is a plain Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [search_class,
       "search.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.search.__class__.__name__.__eq__('function') == True — re.search is a plain Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [findall_class,
       "findall.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.findall.__class__.__name__.__eq__('function') == True — re.findall is a plain Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [sub_class,
       "sub.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.sub.__class__.__name__.__eq__('function') == True — re.sub is a plain Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [fullmatch_class,
       "fullmatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.fullmatch.__class__.__name__.__eq__('function') == True — re.fullmatch is a plain Python function (added in 3.4); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [split_class,
       "split.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.split.__class__.__name__.__eq__('function') == True — re.split is a plain Python function; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [finditer_class,
       "finditer.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.finditer.__class__.__name__.__eq__('function') == True — re.finditer is a plain Python function that returns an iterator; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]
    - [subn_class,
       "subn.__class__.__name__.__eq__",
       ["function"],
       true,
       "re.subn.__class__.__name__.__eq__('function') == True — re.subn is a plain Python function that returns a (new_string, count) tuple; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra252"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra252
# ---------------------------------------------------------------------------

invariant re_extra252.compile_name:
  description: "re.compile.__name__ == 'compile' — compile is the primary regex pattern factory; new to extra252"
  kind: python_call_eq
  function: compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra252.compile_module:
  description: "re.compile.__module__ == 're' — compile is defined in Lib/re/__init__.py; new to extra252"
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra252.compile_is_function:
  description: "re.compile.__class__.__name__ == 'function' — compile is a plain Python function, not a C builtin; new to extra252"
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra252.sub_name:
  description: "re.sub.__name__ == 'sub' — sub performs regex substitution; new to extra252"
  kind: python_call_eq
  function: sub.__name__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra252.fullmatch_module:
  description: "re.fullmatch.__module__ == 're' — fullmatch is defined in Lib/re/__init__.py; new to extra252"
  kind: python_call_eq
  function: fullmatch.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra252.finditer_is_function:
  description: "re.finditer.__class__.__name__ == 'function' — finditer is a plain Python function returning an iterator; new to extra252"
  kind: python_call_eq
  function: finditer.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra252.subn_name:
  description: "re.subn.__name__ == 'subn' — subn performs substitution and returns the substitution count; new to extra252"
  kind: python_call_eq
  function: subn.__name__.__eq__
  args: ["subn"]
  expected: true
