spec: sk3181
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (sk3181): __truediv__, __floordiv__, __mod__ dict-presence checks for socket types."
    - "socket.socket is a Python class; it does not define __truediv__, __floordiv__, or __mod__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "Neither socket.AddressFamily nor socket.SocketKind defines __truediv__, __floordiv__, or __mod__ in its own __dict__; arithmetic dunder methods are not part of the enum or int protocol at the class level."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3181.truediv:
