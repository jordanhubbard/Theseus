spec: asyncio_extra231
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.Queue.put.__name__ == 'put' — 3 characters; module is asyncio.queues; verified with Python 3.14.3."
    - "asyncio.Queue.get.__name__ == 'get' — 3 characters; verified with Python 3.14.3."
    - "asyncio.Queue.put.__qualname__ == 'Queue.put' — method belongs to Queue; verified with Python 3.14.3."
    - "asyncio.Queue.put_nowait.__name__ == 'put_nowait' — 10 characters; verified with Python 3.14.3."
    - "asyncio.Queue.get_nowait.__name__ == 'get_nowait' — 10 characters; verified with Python 3.14.3."
    - "asyncio.Queue.empty.__name__ == 'empty' — 5 characters; verified with Python 3.14.3."
    - "asyncio.Queue.full.__name__ == 'full' — 4 characters; verified with Python 3.14.3."
    - "asyncio.Queue.qsize.__name__ == 'qsize' — 5 characters; verified with Python 3.14.3."
    - "asyncio.Queue.join.__name__ == 'join' — 4 characters; verified with Python 3.14.3."
    - "asyncio.Queue.task_done.__name__ == 'task_done' — 9 characters; verified with Python 3.14.3."
    - "asyncio.LifoQueue.__name__ == 'LifoQueue' — 9 characters; module is asyncio.queues; verified with Python 3.14.3."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue' — 13 characters; module is asyncio.queues; verified with Python 3.14.3."
    - "LifoQueue.put.__qualname__ == 'Queue.put' — inherited from Queue; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue method name contracts — extra231 namespace
#
# Queue.put, get, put_nowait, get_nowait, empty, full, qsize, join, task_done
# all live in asyncio.queues module. Qualnames use 'Queue.' prefix.
# ---------------------------------------------------------------------------

table asyncio_extra231.queue_method_names:
  description: "asyncio.Queue method __name__ and __qualname__ contracts in aio231qmn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio231qmn

  columns: [id, function, args, expected, description]
  rows:
    - [queue_put_name_eq,         Queue.put.__name__.__eq__,           ["put"],            true, "asyncio.Queue.put.__name__ == 'put'; verified with Python 3.14.3"]
    - [queue_put_qualname_eq,     Queue.put.__qualname__.__eq__,       ["Queue.put"],      true, "asyncio.Queue.put.__qualname__ == 'Queue.put'; verified with Python 3.14.3"]
    - [queue_get_name_eq,         Queue.get.__name__.__eq__,           ["get"],            true, "asyncio.Queue.get.__name__ == 'get'; verified with Python 3.14.3"]
    - [queue_get_qualname_eq,     Queue.get.__qualname__.__eq__,       ["Queue.get"],      true, "asyncio.Queue.get.__qualname__ == 'Queue.get'; verified with Python 3.14.3"]
    - [queue_put_nowait_name_eq,  Queue.put_nowait.__name__.__eq__,    ["put_nowait"],     true, "asyncio.Queue.put_nowait.__name__ == 'put_nowait'; verified with Python 3.14.3"]
    - [queue_get_nowait_name_eq,  Queue.get_nowait.__name__.__eq__,    ["get_nowait"],     true, "asyncio.Queue.get_nowait.__name__ == 'get_nowait'; verified with Python 3.14.3"]
    - [queue_empty_name_eq,       Queue.empty.__name__.__eq__,         ["empty"],          true, "asyncio.Queue.empty.__name__ == 'empty'; verified with Python 3.14.3"]
    - [queue_full_name_eq,        Queue.full.__name__.__eq__,          ["full"],           true, "asyncio.Queue.full.__name__ == 'full'; verified with Python 3.14.3"]
    - [queue_qsize_name_eq,       Queue.qsize.__name__.__eq__,         ["qsize"],          true, "asyncio.Queue.qsize.__name__ == 'qsize'; verified with Python 3.14.3"]
    - [queue_join_name_eq,        Queue.join.__name__.__eq__,          ["join"],           true, "asyncio.Queue.join.__name__ == 'join'; verified with Python 3.14.3"]
    - [queue_task_done_name_eq,   Queue.task_done.__name__.__eq__,     ["task_done"],      true, "asyncio.Queue.task_done.__name__ == 'task_done'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio LifoQueue and PriorityQueue class name contracts — extra231 namespace
#
# LifoQueue.__name__ == 'LifoQueue' (9 chars); PriorityQueue.__name__ == 'PriorityQueue' (13 chars).
# Both live in asyncio.queues module.
# ---------------------------------------------------------------------------

table asyncio_extra231.queue_subclass_names:
  description: "asyncio LifoQueue and PriorityQueue __name__ and __module__ contracts in aio231qsc namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio231qsc

  columns: [id, function, args, expected, description]
  rows:
    - [lifoqueue_name_eq,      LifoQueue.__name__.__eq__,       ["LifoQueue"],       true, "asyncio.LifoQueue.__name__ == 'LifoQueue'; verified with Python 3.14.3"]
    - [lifoqueue_name_len_9,   LifoQueue.__name__.__len__,      [],                  9,    "asyncio.LifoQueue.__name__.__len__() == 9 — 'LifoQueue' has 9 characters; verified with Python 3.14.3"]
    - [lifoqueue_module_eq,    LifoQueue.__module__.__eq__,     ["asyncio.queues"],  true, "asyncio.LifoQueue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [prioqueue_name_eq,      PriorityQueue.__name__.__eq__,   ["PriorityQueue"],   true, "asyncio.PriorityQueue.__name__ == 'PriorityQueue'; verified with Python 3.14.3"]
    - [prioqueue_name_len_13,  PriorityQueue.__name__.__len__,  [],                  13,   "asyncio.PriorityQueue.__name__.__len__() == 13 — 'PriorityQueue' has 13 characters; verified with Python 3.14.3"]
    - [prioqueue_module_eq,    PriorityQueue.__module__.__eq__, ["asyncio.queues"],  true, "asyncio.PriorityQueue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
