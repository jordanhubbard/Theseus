spec: hashlib_extra131
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra130.zspec.zsdl — covers hashlib.pbkdf2_hmac/__class__.__name__/__module__/__qualname__/__name__ equality / scrypt/__class__.__name__/__module__/__qualname__/__name__ equality / pbkdf2_hmac and scrypt name/qualname lengths (table + invariants)."
    - "hashlib_extra129.zspec.zsdl — covers sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/shake_128/shake_256 constructor __qualname__.__len__() values (table + invariants)."
    - "hashlib_extra126.zspec.zsdl — covers md5().digest/__qualname__.__len__()==11 / hexdigest/__qualname__.__len__()==14 / copy/__qualname__.__len__()==9 / md5().digest_size/__class__.__name__=='int' / md5().block_size/__class__.__name__=='int' / md5().name/__class__.__name__=='str' / md5().digest_size==16 / sha256().digest_size==32 (table + invariants)."
    - "hashlib_extra125.zspec.zsdl — covers md5()/sha256()/sha1().__class__.__name__.__eq__('HASH') / md5().__class__.__module__.__eq__('_hashlib') / md5().__class__.__qualname__.__eq__('HASH') / md5().update/digest/hexdigest/copy __class__.__name__.__eq__('builtin_function_or_method') / md5().update/digest/hexdigest/copy __qualname__.__eq__ / md5().update.__qualname__.__len__()==11 (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__/__qualname__ / new __class__.__name__ / algorithms_guaranteed __len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra130."
    - "Wave 300 theme: hashlib._hashlib.HASH class-level method_descriptor identity — update/digest/hexdigest/copy __name__ equality, __objclass__.__name__ equality, __class__.__name__ equality via md5().__class__ traversal."
    - "hashlib.md5().__class__.update.__name__ == 'update'. Accessed via md5().__class__ (the HASH type); at class level update is a method_descriptor, not a bound builtin_function_or_method. extra125 anchors md5().update.__qualname__.__eq__('HASH.update') on the instance. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.digest.__name__ == 'digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.hexdigest.__name__ == 'hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.copy.__name__ == 'copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.update.__objclass__.__name__ == 'HASH'. The __objclass__ on a method_descriptor identifies the owning class; for HASH methods it is the HASH C extension class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.digest.__objclass__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.hexdigest.__objclass__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.copy.__objclass__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.update.__class__.__name__ == 'method_descriptor'. At class level, HASH.update is a method_descriptor (not builtin_function_or_method). extra125 anchors the instance-level __class__.__name__=='builtin_function_or_method'; this spec anchors the class-level __class__.__name__=='method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: accessing HASH methods at the class level (md5().__class__.update) yields a method_descriptor object, while accessing at the instance level (md5().update) yields a bound builtin_function_or_method. extra125 covers the instance-level class name; this spec covers the class-level class name ('method_descriptor'). Both perspectives are valid and complementary."
    - "Note: __objclass__ on a method_descriptor is the class that defines the method. For all four HASH methods (update, digest, hexdigest, copy), __objclass__ is the _hashlib.HASH C extension type. __objclass__.__name__=='HASH' for all four. No prior hashlib spec anchors HASH method __objclass__.__name__ as an equality call."
    - "Note: __name__ on the class-level method_descriptor is the simple method name (without the 'HASH.' prefix). This matches the __name__ for instance-level methods. extra125 anchors __qualname__.__eq__('HASH.update') on the instance; this spec anchors __name__.__eq__('update') at the class level."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.update.__name__.__eq__('update')
# hashlib.md5().__class__.digest.__name__.__eq__('digest')
# hashlib.md5().__class__.hexdigest.__name__.__eq__('hexdigest')
# hashlib.md5().__class__.copy.__name__.__eq__('copy')
#
# Wave 300 theme: HASH class-level method_descriptor __name__ equality.
#
# At class level, md5().__class__.update is a method_descriptor. Its __name__
# is 'update' (the simple method name, no 'HASH.' prefix). Same for digest,
# hexdigest, and copy. extra125 anchors __qualname__.__eq__('HASH.update') on
# md5() instances (where update is a builtin_function_or_method); this spec
# first anchors __name__.__eq__('update') at class level via method_descriptor.
# No prior hashlib spec anchors HASH method __name__ equality at class level.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra131.HASH_method_names:
  description: "md5().__class__.update/__name__.__eq__('update')==True / md5().__class__.digest/__name__.__eq__('digest')==True / md5().__class__.hexdigest/__name__.__eq__('hexdigest')==True / md5().__class__.copy/__name__.__eq__('copy')==True — all four HASH class-level method_descriptor objects have __name__ equal to their simple method name; no prior hashlib spec anchors HASH method __name__ at class level via method_descriptor; extra125 anchors instance-level qualname eq; first hashHASH131 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: hashHASH131

  columns: [id, function, args, expected, description]
  rows:
    - [update_name_eq,    "md5().__class__.update.__name__.__eq__",    ["update"],    true, "md5().__class__.update.__name__ is 'update' (class-level method_descriptor; simple name without 'HASH.' prefix)"]
    - [digest_name_eq,    "md5().__class__.digest.__name__.__eq__",    ["digest"],    true, "md5().__class__.digest.__name__ is 'digest' (class-level method_descriptor; returns raw bytes of the hash state)"]
    - [hexdigest_name_eq, "md5().__class__.hexdigest.__name__.__eq__", ["hexdigest"], true, "md5().__class__.hexdigest.__name__ is 'hexdigest' (class-level method_descriptor; returns hex-encoded string of the digest)"]
    - [copy_name_eq,      "md5().__class__.copy.__name__.__eq__",      ["copy"],      true, "md5().__class__.copy.__name__ is 'copy' (class-level method_descriptor; duplicates hash state for forked computation)"]

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.update.__objclass__.__name__.__eq__('HASH')
# hashlib.md5().__class__.digest.__objclass__.__name__.__eq__('HASH')
# hashlib.md5().__class__.hexdigest.__objclass__.__name__.__eq__('HASH')
# hashlib.md5().__class__.copy.__objclass__.__name__.__eq__('HASH')
#
# Wave 300 theme: HASH class-level method_descriptor __objclass__.__name__.
#
# __objclass__ on a method_descriptor identifies the class that defines the
# method. For all four HASH methods, __objclass__ is the _hashlib.HASH C
# extension type, whose __name__ is 'HASH'. This confirms that update, digest,
# hexdigest, and copy are all defined on the HASH class (not inherited).
# No prior hashlib spec anchors HASH method __objclass__.__name__ equality.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra131.HASH_method_objclass:
  description: "md5().__class__.update/__objclass__/__name__.__eq__('HASH')==True / md5().__class__.digest/__objclass__/__name__.__eq__('HASH')==True / md5().__class__.hexdigest/__objclass__/__name__.__eq__('HASH')==True / md5().__class__.copy/__objclass__/__name__.__eq__('HASH')==True — all four HASH method_descriptor objects have __objclass__.__name__=='HASH'; confirms all four methods are defined on the HASH C extension class; no prior hashlib spec anchors __objclass__.__name__ for HASH methods; first hashHASH131 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: hashHASH131

  columns: [id, function, args, expected, description]
  rows:
    - [update_objclass,    "md5().__class__.update.__objclass__.__name__.__eq__",    ["HASH"], true, "md5().__class__.update.__objclass__.__name__ is 'HASH' (owning class is the _hashlib.HASH C extension type)"]
    - [digest_objclass,    "md5().__class__.digest.__objclass__.__name__.__eq__",    ["HASH"], true, "md5().__class__.digest.__objclass__.__name__ is 'HASH' (all four methods defined on the same HASH C class)"]
    - [hexdigest_objclass, "md5().__class__.hexdigest.__objclass__.__name__.__eq__", ["HASH"], true, "md5().__class__.hexdigest.__objclass__.__name__ is 'HASH' (hexdigest is defined on HASH, not inherited from object)"]
    - [copy_objclass,      "md5().__class__.copy.__objclass__.__name__.__eq__",      ["HASH"], true, "md5().__class__.copy.__objclass__.__name__ is 'HASH' (copy is defined on HASH; creates a duplicate of the hash state)"]

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.update.__class__.__name__.__eq__('method_descriptor')
# hashlib.md5().__class__.digest.__class__.__name__.__eq__('method_descriptor')
# hashlib.md5().__class__.hexdigest.__class__.__name__.__eq__('method_descriptor')
# hashlib.md5().__class__.copy.__class__.__name__.__eq__('method_descriptor')
# (cross-check)
#
# Wave 300 theme: HASH class-level method __class__.__name__ == 'method_descriptor'.
#
# At class level, HASH methods are method_descriptor objects (CPython's C-level
# descriptor type for methods). At instance level they are builtin_function_or_method.
# extra125 anchors instance-level __class__.__name__=='builtin_function_or_method'.
# This cross-check table confirms class-level __class__.__name__=='method_descriptor'
# for all four HASH methods. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra131.HASH_method_class_names:
  description: "md5().__class__.update/__class__/__name__.__eq__('method_descriptor')==True / digest/__class__/__name__.__eq__('method_descriptor')==True / hexdigest/__class__/__name__.__eq__('method_descriptor')==True / copy/__class__/__name__.__eq__('method_descriptor')==True — at class level HASH methods are method_descriptor (CPython C-level descriptor type); at instance level they are builtin_function_or_method (extra125 anchors instance-level); this table anchors class-level class names; first hashHASH131 class-level class name anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: hashHASH131

  columns: [id, function, args, expected, description]
  rows:
    - [update_cls_name,    "md5().__class__.update.__class__.__name__.__eq__",    ["method_descriptor"], true, "md5().__class__.update.__class__.__name__ is 'method_descriptor' (class-level; distinct from 'builtin_function_or_method' at instance level anchored in extra125)"]
    - [digest_cls_name,    "md5().__class__.digest.__class__.__name__.__eq__",    ["method_descriptor"], true, "md5().__class__.digest.__class__.__name__ is 'method_descriptor' (class-level C descriptor; same type as Struct.pack from _struct)"]
    - [hexdigest_cls_name, "md5().__class__.hexdigest.__class__.__name__.__eq__", ["method_descriptor"], true, "md5().__class__.hexdigest.__class__.__name__ is 'method_descriptor' (class-level C descriptor; hexdigest returns hex string representation)"]
    - [copy_cls_name,      "md5().__class__.copy.__class__.__name__.__eq__",      ["method_descriptor"], true, "md5().__class__.copy.__class__.__name__ is 'method_descriptor' (class-level C descriptor; copy returns a snapshot of the current hash state)"]

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.update.__name__.__eq__('update') — standalone
#
# hashlib.md5().__class__.update.__name__ is 'update'. At class level, the
# update attribute on the HASH type is a method_descriptor. Its __name__ is
# 'update' (the simple method name). extra125 anchors md5().update.__qualname__
# __eq__('HASH.update') — the instance-level qualname which includes the 'HASH.'
# prefix. The class-level __name__ is just 'update' without the 'HASH.' prefix.
# No prior hashlib spec anchors update.__name__.__eq__('update') at class level.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra131.HASH_update_name_eq:
  description: "hashlib.md5().__class__.update.__name__.__eq__('update') == True — class-level method_descriptor __name__ is 'update' (no 'HASH.' prefix; distinct from instance-level __qualname__=='HASH.update' anchored in extra125); first standalone for HASH.update __name__ at class level under hashHASH131"
  category: method_identity
  kind: python_call_eq
  function: "md5().__class__.update.__name__.__eq__"
  args: ["update"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.digest.__objclass__.__name__.__eq__('HASH') — standalone
#
# hashlib.md5().__class__.digest.__objclass__.__name__ is 'HASH'. The __objclass__
# attribute on a method_descriptor identifies the class that owns the method.
# For HASH.digest, __objclass__ is the _hashlib.HASH C extension type. Its
# __name__ is 'HASH' (4 chars). digest computes and returns the raw binary
# message digest. The __objclass__.__name__ confirms that digest is defined
# directly on the HASH class, not inherited from object or any mixin.
# No prior hashlib spec anchors digest.__objclass__.__name__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra131.HASH_digest_objclass_name_eq:
  description: "hashlib.md5().__class__.digest.__objclass__.__name__.__eq__('HASH') == True — digest.__objclass__ is the _hashlib.HASH C type; __objclass__.__name__=='HASH' (4 chars); confirms digest is defined on HASH not inherited; no prior hashlib spec anchors digest.__objclass__.__name__ as standalone; first standalone under hashHASH131"
  category: method_identity
  kind: python_call_eq
  function: "md5().__class__.digest.__objclass__.__name__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.hexdigest.__name__.__eq__('hexdigest') — standalone
#
# hashlib.md5().__class__.hexdigest.__name__ is 'hexdigest'. At class level,
# hexdigest is a method_descriptor with __name__=='hexdigest' (9 chars). The
# class-level __name__ is just 'hexdigest' while the instance-level __qualname__
# is 'HASH.hexdigest' (14 chars, anchored in extra125). hexdigest returns the
# digest as a lowercase hexadecimal string (useful for human-readable output
# and comparison). No prior hashlib spec anchors hexdigest.__name__.__eq__
# at class level as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra131.HASH_hexdigest_name_eq:
  description: "hashlib.md5().__class__.hexdigest.__name__.__eq__('hexdigest') == True — class-level method_descriptor __name__ is 'hexdigest' (9 chars); instance-level __qualname__ is 'HASH.hexdigest' (14 chars, anchored in extra125); no prior hashlib spec anchors hexdigest.__name__ at class level as standalone; first standalone under hashHASH131"
  category: method_identity
  kind: python_call_eq
  function: "md5().__class__.hexdigest.__name__.__eq__"
  args: ["hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.copy.__objclass__.__name__.__eq__('HASH') — standalone
#
# hashlib.md5().__class__.copy.__objclass__.__name__ is 'HASH'. copy is the
# method that duplicates the current hash state, allowing multiple diverging
# computations from a common prefix (e.g., computing both md5(b'abc') and
# md5(b'abcd') by copying after absorbing b'abc'). Its __objclass__.__name__
# is 'HASH', confirming that copy is defined on the HASH C class. copy is
# distinct from the Python builtin copy module. No prior hashlib spec anchors
# copy.__objclass__.__name__ as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra131.HASH_copy_objclass_name_eq:
  description: "hashlib.md5().__class__.copy.__objclass__.__name__.__eq__('HASH') == True — copy.__objclass__ is the _hashlib.HASH C type; copy creates a snapshot of hash state for forked computation; __objclass__.__name__=='HASH' (4 chars); no prior hashlib spec anchors copy.__objclass__.__name__ as standalone; first standalone under hashHASH131"
  category: method_identity
  kind: python_call_eq
  function: "md5().__class__.copy.__objclass__.__name__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.update.__class__.__name__.__eq__('method_descriptor') — standalone
#
# hashlib.md5().__class__.update.__class__.__name__ is 'method_descriptor'.
# At class level, update is a method_descriptor — the C-level descriptor type
# for methods defined in C extension classes. At instance level, md5().update
# is a builtin_function_or_method (a bound version). extra125 anchors the
# instance-level __class__.__name__=='builtin_function_or_method' for update.
# This standalone first anchors the class-level __class__.__name__=='method_descriptor'
# for update as a standalone under hashHASH131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra131.HASH_update_class_method_descriptor:
  description: "hashlib.md5().__class__.update.__class__.__name__.__eq__('method_descriptor') == True — at class level update is a method_descriptor (CPython C-level descriptor type); at instance level it is a builtin_function_or_method (extra125 anchors that); complementary class-level perspective; first standalone for update class-level class name under hashHASH131"
  category: method_identity
  kind: python_call_eq
  function: "md5().__class__.update.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

