spec: numbers_rust
version: ">=3.9"
backend: rust_module(numbers_rust)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers documentation"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "Clean-room Rust reimplementation of Python numbers abstract base classes, exposed via PyO3."
    - "Exposes: Number, Complex, Real, Rational, Integral abstract classes."
    - "Integral.__instancecheck__(42) == True — int is an Integral."
    - "Integral.__instancecheck__(3.14) == False — float is not an Integral."
    - "Real.__instancecheck__(42) == True — int is a Real (Integral ⊂ Real)."
    - "Real.__instancecheck__(3.14) == True — float is a Real."
    - "Complex.__instancecheck__(42) == True — int is a Complex (Real ⊂ Complex)."
    - "Complex.__instancecheck__(3.14) == True — float is a Complex."
    - "Number.__instancecheck__(42) == True — int is a Number."
    - "Number.__instancecheck__('x') == False — str is not a Number."
    - "All test vectors verified against Python 3.14.3 numbers module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Integral — integers satisfy Integral ABC
table numbers_rust.Integral.checks:
  kind: python_call_eq
  category: Integral
  id_prefix: integral
  function: Integral.__instancecheck__

  columns: [id, args, expected]
  rows:
    - [int_42,   [42],    true]
    - [int_0,    [0],     true]
    - [int_neg,  [-7],    true]
    - [float,    [3.14],  false]
    - [bool_t,   [true],  true]

# Real — ints and floats satisfy Real ABC
table numbers_rust.Real.checks:
  kind: python_call_eq
  category: Real
  id_prefix: real
  function: Real.__instancecheck__

  columns: [id, args, expected]
  rows:
    - [int_42,  [42],   true]
    - [float,   [3.14], true]
    - [neg_f,   [-2.5], true]
    - [bool_t,  [true], true]

# Complex — ints and floats satisfy Complex ABC
table numbers_rust.Complex.checks:
  kind: python_call_eq
  category: Complex
  id_prefix: complex
  function: Complex.__instancecheck__

  columns: [id, args, expected]
  rows:
    - [int_42, [42],   true]
    - [float,  [3.14], true]

# Number — top-level numeric ABC
table numbers_rust.Number.checks:
  kind: python_call_eq
  category: Number
  id_prefix: number
  function: Number.__instancecheck__

  columns: [id, args, expected]
  rows:
    - [int_42, [42],   true]
    - [float,  [3.14], true]

