table decimal_extra177.getcontext_rounding_and_constant:
  description: "decimal.getcontext() rounding and ROUND_HALF_EVEN constant: rounding.__class__.__name__=='str'; rounding.__eq__('ROUND_HALF_EVEN')==True; ROUND_HALF_EVEN.__class__.__name__=='str'; ROUND_HALF_EVEN is the default rounding mode"
  kind: python_call_eq
  category: identity
  id_prefix: decimalctx177

  columns: [id, function, args, expected, description]
  rows:
    - [rounding_cls,       getcontext().rounding.__class__.__name__.__eq__,     ["str"],              true, "decimal.getcontext().rounding.__class__.__name__ == 'str' — the rounding attribute is a plain Python str; confirmed Python 3.14.3 macOS"]
    - [rounding_val,       getcontext().rounding.__eq__,                        ["ROUND_HALF_EVEN"],  true, "decimal.getcontext().rounding.__eq__('ROUND_HALF_EVEN') == True — the default rounding mode is ROUND_HALF_EVEN; confirmed Python 3.14.3 macOS"]
    - [const_cls,          ROUND_HALF_EVEN.__class__.__name__.__eq__,           ["str"],              true, "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — the ROUND_HALF_EVEN constant is a str; confirmed Python 3.14.3 macOS"]
    - [const_val,          ROUND_HALF_EVEN.__eq__,                              ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — the constant value is the string 'ROUND_HALF_EVEN'; confirmed Python 3.14.3 macOS"]
    - [rounding_eq_const,  getcontext().rounding.__eq__,                        ["ROUND_HALF_EVEN"],  true, "decimal.getcontext().rounding.__eq__(decimal.ROUND_HALF_EVEN) — the default context rounding matches the ROUND_HALF_EVEN constant; confirmed Python 3.14.3 macOS"]

