# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra177.context_name_is_context:
  description: "decimal.Context.__name__ == 'Context' — the arithmetic context class has name 'Context'; len('Context')==7: C(1)o(2)n(3)t(4)e(5)x(6)t(7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra177.context_name_len_is_7:
  description: "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra177.context_module_is_decimal:
  description: "decimal.Context.__module__ == 'decimal' — the Context class belongs to the decimal module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra177.context_qualname_is_context:
  description: "decimal.Context.__qualname__ == 'Context' — top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.__qualname__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra177.getcontext_class_name_is_context:
  description: "decimal.getcontext().__class__.__name__ == 'Context' — getcontext() returns a Context instance; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: getcontext().__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra177.getcontext_prec_class_is_int:
  description: "decimal.getcontext().prec.__class__.__name__ == 'int' — the prec attribute is a plain Python int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: getcontext().prec.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra177.getcontext_prec_eq_28:
  description: "decimal.getcontext().prec.__eq__(28) == True — the default context precision is 28 (IEEE 754 decimal128); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: getcontext().prec.__eq__
  args: [28]
  expected: true

invariant decimal_extra177.getcontext_rounding_class_is_str:
  description: "decimal.getcontext().rounding.__class__.__name__ == 'str' — the rounding mode is stored as a plain Python str; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: getcontext().rounding.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra177.round_half_even_class_is_str:
  description: "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — the ROUND_HALF_EVEN rounding constant is a str; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra177.round_half_even_eq_string:
  description: "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — the constant value is the string 'ROUND_HALF_EVEN'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

