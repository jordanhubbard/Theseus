spec: decimal_extra177
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.Context.__name__=='Context' (len=7); decimal.Context.__module__=='decimal'; decimal.Context.__qualname__=='Context'."
    - "decimal.getcontext().__class__.__name__=='Context' — getcontext() returns a Context instance."
    - "decimal.getcontext().prec==28 (default precision); prec.__class__.__name__=='int'; decimal.getcontext().prec.__eq__(28)==True."
    - "decimal.getcontext().rounding=='ROUND_HALF_EVEN' (default rounding); rounding.__class__.__name__=='str'; decimal.ROUND_HALF_EVEN=='ROUND_HALF_EVEN' and ROUND_HALF_EVEN.__class__.__name__=='str'."
    - "len('Context')==7: C(1)o(2)n(3)t(4)e(5)x(6)t(7); default prec==28 is the IEEE 754 decimal128 precision."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Context class identity
# __name__=='Context' (len=7); __module__=='decimal'; __qualname__=='Context'
# ---------------------------------------------------------------------------

table decimal_extra177.context_class_identity:
  description: "decimal.Context class identity: __name__=='Context' (len=7); __module__=='decimal'; __qualname__=='Context'; len('Context')==7: C(1)o(2)n(3)t(4)e(5)x(6)t(7)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalctx177

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_name,      Context.__name__.__eq__,      ["Context"], true,  "decimal.Context.__name__ == 'Context' — the arithmetic context class has the expected name; len('Context')==7: C(1)o(2)n(3)t(4)e(5)x(6)t(7); confirmed Python 3.14.3 macOS"]
    - [ctx_name_len,  Context.__name__.__len__,     [],          7,     "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters; confirmed Python 3.14.3 macOS"]
    - [ctx_module,    Context.__module__.__eq__,    ["decimal"], true,  "decimal.Context.__module__ == 'decimal' — the Context class belongs to the decimal module; confirmed Python 3.14.3 macOS"]
    - [ctx_qualname,  Context.__qualname__.__eq__,  ["Context"], true,  "decimal.Context.__qualname__ == 'Context' — Context is a top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"]
    - [ctx_name_ne,   Context.__name__.__eq__,      ["decimal"], false, "decimal.Context.__name__.__eq__('decimal') == False — the class name is 'Context', not 'decimal'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.getcontext() class identity and prec attribute
# getcontext().__class__.__name__=='Context'; prec==28 (int)
# ---------------------------------------------------------------------------

table decimal_extra177.getcontext_class_and_prec:
  description: "decimal.getcontext() class and prec: getcontext().__class__.__name__=='Context'; prec.__class__.__name__=='int'; prec.__eq__(28)==True — default precision is 28 (IEEE 754 decimal128)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalctx177

  columns: [id, function, args, expected, description]
  rows:
    - [getctx_cls_name,  getcontext().__class__.__name__.__eq__,      ["Context"], true, "decimal.getcontext().__class__.__name__ == 'Context' — getcontext() returns a Context instance; confirmed Python 3.14.3 macOS"]
    - [prec_cls,         getcontext().prec.__class__.__name__.__eq__,  ["int"],     true, "decimal.getcontext().prec.__class__.__name__ == 'int' — the prec attribute of the default context is a plain Python int; confirmed Python 3.14.3 macOS"]
    - [prec_eq_28,       getcontext().prec.__eq__,                     [28],        true, "decimal.getcontext().prec.__eq__(28) == True — the default context precision is 28, matching IEEE 754 decimal128; confirmed Python 3.14.3 macOS"]
    - [prec_ne_0,        getcontext().prec.__eq__,                     [0],         false, "decimal.getcontext().prec.__eq__(0) == False — prec (28) != 0; the default precision is 28, not 0; confirmed Python 3.14.3 macOS"]
    - [getctx_cls_ne,    getcontext().__class__.__name__.__eq__,      ["decimal"], false, "decimal.getcontext().__class__.__name__.__eq__('decimal') == False — the class name is 'Context', not 'decimal'; confirmed Python 3.14.3 macOS"]

