spec: lodash_tail
version: ">=4.0.0"
backend: node(lodash.tail)

docs: https://lodash.com/docs/#tail

provenance:
  derived_from:
    - "lodash.tail README — https://www.npmjs.com/package/lodash.tail"
    - "Test vectors verified with lodash.tail@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.tail exports the _.tail function directly as module.exports."
    - "tail(array) returns all elements after the first."
    - "Returns [] for a single-element array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array. Returns [] for empty or single-element array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_tail.tail:
  kind: node_module_call_eq
  function: ~
  category: tail
  id_prefix: ltail

  columns: [id, args, expected]
  rows:
    - [three_ints,  [[1, 2, 3]],     [2, 3]]
    - [single,      [[42]],          []]
    - [strings,     [["a", "b", "c"]], ["b", "c"]]
