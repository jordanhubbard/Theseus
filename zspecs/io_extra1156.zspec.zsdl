spec: io_extra1156
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module __package__.__class__.__name__, __loader__.__class__.__name__, __all__.__class__.__name__, and IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO __module__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.__package__.__class__.__name__, io.__loader__.__class__.__name__, io.__all__.__class__.__name__, io.IOBase.__module__, io.RawIOBase.__module__, io.BufferedIOBase.__module__, io.TextIOBase.__module__, io.FileIO.__module__; none of these were covered in _extra1126 or _extra1141"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1156.module_dunder_class_names:
  description: "io module __package__, __loader__, and __all__ __class__.__name__ checks"
  kind: python_call_eq
  category: module_dunder_class_names
  id_prefix: io1156mc
  columns: [id, function, args, expected]
  rows:
    - [io1156mc001, io.__package__.__class__.__name__.__eq__,  ["str"],   true]
    - [io1156mc002, io.__loader__.__class__.__name__.__eq__,   ["BuiltinImporter"], true]
    - [io1156mc003, io.__all__.__class__.__name__.__eq__,      ["list"],  true]
    - [io1156mc004, io.__package__.__class__.__name__.__eq__,  ["bytes"], false]
    - [io1156mc005, io.__package__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [io1156mc006, io.__all__.__class__.__name__.__eq__,      ["tuple"], false]
    - [io1156mc007, io.__package__.__eq__,                     ["io"],    true]
    - [io1156mc008, io.__package__.__class__.__name__.__eq__,  ["str"],   true]

table io_extra1156.abstract_class_modules:
  description: "io abstract base class __module__ checks — IOBase, RawIOBase, BufferedIOBase, TextIOBase all resolve to 'io'"
  kind: python_call_eq
  category: abstract_class_modules
  id_prefix: io1156am
  columns: [id, function, args, expected]
  rows:
    - [io1156am001, io.IOBase.__module__.__eq__,       ["io"],  true]
    - [io1156am002, io.RawIOBase.__module__.__eq__,    ["io"],  true]
    - [io1156am003, io.BufferedIOBase.__module__.__eq__, ["io"], true]
    - [io1156am004, io.TextIOBase.__module__.__eq__,   ["io"],  true]
    - [io1156am005, io.IOBase.__module__.__eq__,       ["_io"], false]
    - [io1156am006, io.RawIOBase.__module__.__eq__,    ["_io"], false]
    - [io1156am007, io.BufferedIOBase.__module__.__eq__, ["builtins"], false]
    - [io1156am008, io.IOBase.__module__.__class__.__name__.__eq__, ["str"], true]
    - [io1156am009, io.TextIOBase.__module__.__class__.__name__.__eq__, ["str"], true]

table io_extra1156.concrete_class_modules:
  description: "io concrete class __module__ checks for FileIO, BytesIO, StringIO, TextIOWrapper, BufferedReader, BufferedWriter"
  kind: python_call_eq
  category: concrete_class_modules
  id_prefix: io1156cm
  columns: [id, function, args, expected]
  rows:
    - [io1156cm001, io.FileIO.__module__.__eq__,         ["io"],  true]
    - [io1156cm002, io.BytesIO.__module__.__eq__,        ["io"],  true]
    - [io1156cm003, io.StringIO.__module__.__eq__,       ["io"],  true]
    - [io1156cm004, io.TextIOWrapper.__module__.__eq__,  ["io"],  true]
    - [io1156cm005, io.BufferedReader.__module__.__eq__,  ["io"], true]
    - [io1156cm006, io.BufferedWriter.__module__.__eq__,  ["io"], true]
    - [io1156cm007, io.FileIO.__module__.__eq__,         ["_io"], false]
    - [io1156cm008, io.BytesIO.__module__.__eq__,        ["builtins"], false]
    - [io1156cm009, io.FileIO.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [io1156cm010, io.BufferedReader.__module__.__class__.__name__.__eq__, ["str"], true]
