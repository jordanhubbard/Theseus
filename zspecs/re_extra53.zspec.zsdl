spec: re_extra53
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra52.zspec.zsdl — covers __doc__.__class__.__name__/qualname for search/compile/sub/findall/fullmatch/match/split/subn/finditer/error/Pattern and module."
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __name__.__len__(); split.__name__.__len__()==5; findall.__name__.__len__()==7; finditer.__name__.__len__()==8."
    - "re_extra30.zspec.zsdl — covers compile/match/search/fullmatch/sub __name__.__len__(); compile.__name__.__len__()==7; match.__name__.__len__()==5; search.__name__.__len__()==6; fullmatch.__name__.__len__()==9; sub.__name__.__len__()==3."
    - "re_extra22.zspec.zsdl — covers compile/match/search/findall/sub/split/fullmatch __name__.__eq__() in re_extra22 namespace."
    - "re_extra19.zspec.zsdl — covers sub/__name__.__eq__ and subn/__name__.__eq__ in re_extra19 namespace."
    - "re_extra20.zspec.zsdl — covers fullmatch/__name__.__eq__ and compile/__name__.__eq__ in re_extra20 namespace."
    - "re_extra5.zspec.zsdl — covers search/compile/findall/match/fullmatch/split/finditer __name__.__eq__ in re_extra5 namespace."
    - "re_extra4.zspec.zsdl — covers sub/__name__.__eq__; subn/__name__.__eq__ in re_extra4 namespace."
    - "re_extra2.zspec.zsdl — covers fullmatch/__name__.__eq__ in re_extra2 namespace."
  notes:
    - "This spec extends re_extra52.zspec.zsdl."
    - "Prior specs collectively covered: re.search/compile/sub/findall/fullmatch/match/split/subn/finditer __name__.__eq__() (re_extra2/re_extra4/re_extra5/re_extra19/re_extra20/re_extra22); __name__.__len__() for compile/match/search/fullmatch/sub (re_extra30) and split/findall/finditer (re_extra31). subn.__name__.__len__() has NOT been covered in any prior re spec. NO prior re spec checks subn.__name__.__len__()."
    - "This spec covers: re.search.__name__.__eq__('search') (namespace anchor in re_extra53; functionally covered in re_extra5/re_extra22); re.compile.__name__.__eq__('compile') (namespace anchor; covered in re_extra6/re_extra20/re_extra22); re.sub.__name__.__eq__('sub') (namespace anchor; covered in re_extra4/re_extra19/re_extra22); re.findall.__name__.__eq__('findall') (namespace anchor; covered in re_extra5/re_extra22); re.fullmatch.__name__.__eq__('fullmatch') (namespace anchor; covered in re_extra2/re_extra20/re_extra22); re.match.__name__.__eq__('match') (namespace anchor; covered in re_extra5/re_extra22); re.split.__name__.__eq__('split') (namespace anchor; covered in re_extra5/re_extra22); re.subn.__name__.__eq__('subn') (namespace anchor; covered in re_extra4/re_extra19); re.finditer.__name__.__eq__('finditer') (namespace anchor; covered in re_extra5); re.subn.__name__.__len__()==4 (NOVEL — no prior re spec checks subn.__name__.__len__(); novel length anchor; 'subn' has 4 characters)."
    - "re.search.__name__ == 'search'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile.__name__ == 'compile'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.sub.__name__ == 'sub'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.findall.__name__ == 'findall'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.fullmatch.__name__ == 'fullmatch'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.match.__name__ == 'match'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.split.__name__ == 'split'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.subn.__name__ == 'subn'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.finditer.__name__ == 'finditer'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.subn.__name__ == 'subn' (len 4). re_extra30 covers sub.__name__.__len__()==3 and re_extra31 covers findall/split/finditer/purge/escape __name__.__len__(). 'subn' has 4 characters and no prior re spec records subn.__name__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __name__ string equality (re_extra53 namespace anchors)
#
# Every re module function has a __name__ attribute equal to the bare function
# name. These equality checks were established in earlier namespaces (re_extra2,
# re_extra4, re_extra5, re_extra19, re_extra20, re_extra22). This table
# consolidates them as re_extra53 namespace anchors, following the pattern of
# multi-namespace coverage established across the re_extra series:
#
#   re.search.__name__   == 'search'
#   re.compile.__name__  == 'compile'
#   re.sub.__name__      == 'sub'
#   re.findall.__name__  == 'findall'
#   re.fullmatch.__name__ == 'fullmatch'
#   re.match.__name__    == 'match'
#   re.split.__name__    == 'split'
#   re.subn.__name__     == 'subn'
#   re.finditer.__name__ == 'finditer'
#
# All nine equality anchors are re-established in the re_extra53 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra53.function_name_eq:
  description: "re module function __name__.__eq__() for search/compile/sub/findall/fullmatch/match/split/subn/finditer — every re function __name__ equals its bare name; re_extra2/4/5/19/20/22 cover these in earlier namespaces; consolidated re_extra53 namespace anchors; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: rename53

  columns: [id, function, args, expected]
  rows:
    - [search_name_eq,   search.__name__.__eq__,   ["search"],   true]
    - [compile_name_eq,  compile.__name__.__eq__,  ["compile"],  true]
    - [sub_name_eq,      sub.__name__.__eq__,      ["sub"],      true]
    - [findall_name_eq,  findall.__name__.__eq__,  ["findall"],  true]
    - [fullmatch_name_eq, fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [match_name_eq,    match.__name__.__eq__,    ["match"],    true]
    - [split_name_eq,    split.__name__.__eq__,    ["split"],    true]
    - [subn_name_eq,     subn.__name__.__eq__,     ["subn"],     true]
    - [finditer_name_eq, finditer.__name__.__eq__,  ["finditer"], true]

# ---------------------------------------------------------------------------
# re module function __name__ lengths (selected, complementing extra30/extra31)
#
# re_extra30 covers __name__.__len__() for compile(7)/match(5)/search(6)/
# fullmatch(9)/sub(3). re_extra31 covers split(5)/findall(7)/finditer(8)/
# purge(5)/escape(6). NO prior re spec checks subn.__name__.__len__().
#
# 'subn' has 4 characters. This is the single novel length anchor in this spec.
# For completeness this table also re-anchors the five lengths from re_extra30
# in the re_extra53 namespace:
#
#   re.search.__name__.__len__()   == 6   (re_extra30 namespace anchor)
#   re.compile.__name__.__len__()  == 7   (re_extra30 namespace anchor)
#   re.sub.__name__.__len__()      == 3   (re_extra30 namespace anchor)
#   re.findall.__name__.__len__()  == 7   (re_extra31 namespace anchor)
#   re.match.__name__.__len__()    == 5   (re_extra30 namespace anchor)
#   re.subn.__name__.__len__()     == 4   (NOVEL — no prior re spec)
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra53.function_name_len:
  description: "re module function __name__.__len__() for search(6)/compile(7)/sub(3)/findall(7)/match(5)/subn(4) — re_extra30 covers search/compile/sub/match lengths; re_extra31 covers findall length; subn.__name__.__len__()==4 is novel (no prior re spec checks subn.__name__.__len__()); re_extra53 namespace anchors; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: rename53len

  columns: [id, function, args, expected]
  rows:
    - [search_name_len,  search.__name__.__len__,  [], 6]
    - [compile_name_len, compile.__name__.__len__, [], 7]
    - [sub_name_len,     sub.__name__.__len__,     [], 3]
    - [findall_name_len, findall.__name__.__len__, [], 7]
    - [match_name_len,   match.__name__.__len__,   [], 5]
    - [subn_name_len,    subn.__name__.__len__,    [], 4]
