spec: is_xml
version: ">=0.1.0"
backend: node(is-xml)

docs: https://www.npmjs.com/package/is-xml

provenance:
  derived_from:
    - "is-xml README — https://www.npmjs.com/package/is-xml"
    - "Test vectors verified with is-xml via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-xml source"
  notes:
    - "is-xml is an npm package. Install: npm install is-xml"
    - "Returns true if the string looks like XML (starts with a tag or XML declaration)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_xml.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: isxml

  columns: [id, args, expected]
  rows:
    - [self_closing,   ["<root/>"],              true]
    - [nested,         ["<a><b>text</b></a>"],   true]
    - [plain_text,     ["just text"],             false]
    - [empty,          [""],                      false]
