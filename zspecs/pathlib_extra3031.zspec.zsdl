spec: pp3031
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (pp3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for pathlib types."
    - "pathlib path objects represent filesystem paths; they are not mappings and do not define __missing__."
    - "None of the pathlib path classes override __init_subclass__ in their own __dict__."
    - "None of the pathlib path classes define __class_getitem__; they are not generic aliases."
    - "pathlib.PosixPath and pathlib.WindowsPath are both available on macOS/Darwin 25.4.0."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# pathlib path types are path objects, not mappings; none define __missing__; all false.
# ---------------------------------------------------------------------------

table pp3031.missing:
  description: "pathlib types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp3031
  columns: [id, function, args, expected]
  rows:
    - ["pp3031001", operator.contains, [pathlib.PurePath.__dict__,        "__missing__"], false]
    - ["pp3031002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__missing__"], false]
    - ["pp3031003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__missing__"], false]
    - ["pp3031004", operator.contains, [pathlib.Path.__dict__,            "__missing__"], false]
    - ["pp3031005", operator.contains, [pathlib.PosixPath.__dict__,       "__missing__"], false]
    - ["pp3031006", operator.contains, [pathlib.WindowsPath.__dict__,     "__missing__"], false]

