spec: multiprocessing_extra257
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier are bound context methods (factories), not classes."
    - "All synchronization primitive factories have __class__.__name__ == 'method' (bound method of BaseContext)."
    - "All factory __qualname__ values carry the 'BaseContext.' prefix (e.g. 'BaseContext.Lock')."
    - "multiprocessing.cpu_count is also a bound context method; __qualname__ == 'BaseContext.cpu_count'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Synchronization primitive factory __name__ — table
#
# Seven synchronization primitive factories: Lock, RLock, Semaphore,
# BoundedSemaphore, Event, Condition, Barrier. All are bound methods of
# BaseContext and their __name__ equals the factory name.
# ---------------------------------------------------------------------------

table multiprocessing_extra257.sync_primitive_names:
  description: "multiprocessing synchronization primitive factories report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: sname

  columns: [id, function, args, expected, description]
  rows:
    - [Lock,            Lock.__name__.__eq__,            ["Lock"],            true, "multiprocessing.Lock.__name__ == 'Lock'"]
    - [RLock,           RLock.__name__.__eq__,           ["RLock"],           true, "multiprocessing.RLock.__name__ == 'RLock'"]
    - [Semaphore,       Semaphore.__name__.__eq__,       ["Semaphore"],       true, "multiprocessing.Semaphore.__name__ == 'Semaphore'"]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "multiprocessing.BoundedSemaphore.__name__ == 'BoundedSemaphore'"]
    - [Event,           Event.__name__.__eq__,           ["Event"],           true, "multiprocessing.Event.__name__ == 'Event'"]
    - [Condition,       Condition.__name__.__eq__,       ["Condition"],       true, "multiprocessing.Condition.__name__ == 'Condition'"]
    - [Barrier,         Barrier.__name__.__eq__,         ["Barrier"],         true, "multiprocessing.Barrier.__name__ == 'Barrier'"]

# ---------------------------------------------------------------------------
# Synchronization primitive factory __qualname__ — table
#
# All seven factories carry the 'BaseContext.' prefix in their __qualname__
# because they are bound methods of the BaseContext class.
# ---------------------------------------------------------------------------

table multiprocessing_extra257.sync_primitive_qualnames:
  description: "multiprocessing synchronization primitive factories report 'BaseContext.'-prefixed __qualname__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: squalname

  columns: [id, function, args, expected, description]
  rows:
    - [Lock,            Lock.__qualname__.__eq__,            ["BaseContext.Lock"],            true, "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock'"]
    - [RLock,           RLock.__qualname__.__eq__,           ["BaseContext.RLock"],           true, "multiprocessing.RLock.__qualname__ == 'BaseContext.RLock'"]
    - [Semaphore,       Semaphore.__qualname__.__eq__,       ["BaseContext.Semaphore"],       true, "multiprocessing.Semaphore.__qualname__ == 'BaseContext.Semaphore'"]
    - [BoundedSemaphore, BoundedSemaphore.__qualname__.__eq__, ["BaseContext.BoundedSemaphore"], true, "multiprocessing.BoundedSemaphore.__qualname__ == 'BaseContext.BoundedSemaphore'"]
    - [Event,           Event.__qualname__.__eq__,           ["BaseContext.Event"],           true, "multiprocessing.Event.__qualname__ == 'BaseContext.Event'"]
    - [Condition,       Condition.__qualname__.__eq__,       ["BaseContext.Condition"],       true, "multiprocessing.Condition.__qualname__ == 'BaseContext.Condition'"]
    - [Barrier,         Barrier.__qualname__.__eq__,         ["BaseContext.Barrier"],         true, "multiprocessing.Barrier.__qualname__ == 'BaseContext.Barrier'"]

# ---------------------------------------------------------------------------
# Factory __class__.__name__ — standalone invariants
#
# All synchronization primitive factories are bound methods of BaseContext.
# __class__.__name__ == 'method'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra257.Lock.class_name:
  description: "multiprocessing.Lock.__class__.__name__ == 'method'"
  category: identity
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra257.Event.class_name:
  description: "multiprocessing.Event.__class__.__name__ == 'method'"
  category: identity
  kind: python_call_eq
  function: Event.__class__.__name__.__eq__
  args: ["method"]
  expected: true

# ---------------------------------------------------------------------------
# Manager factory — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra257.Manager.name:
  description: "multiprocessing.Manager.__name__ == 'Manager'"
  category: identity
  kind: python_call_eq
  function: Manager.__name__.__eq__
  args: ["Manager"]
  expected: true

invariant multiprocessing_extra257.Manager.qualname:
  description: "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager'"
  category: identity
  kind: python_call_eq
  function: Manager.__qualname__.__eq__
  args: ["BaseContext.Manager"]
  expected: true

# ---------------------------------------------------------------------------
# cpu_count factory — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra257.cpu_count.name:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count'"
  category: identity
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra257.cpu_count.qualname:
  description: "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count'"
  category: identity
  kind: python_call_eq
  function: cpu_count.__qualname__.__eq__
  args: ["BaseContext.cpu_count"]
  expected: true
