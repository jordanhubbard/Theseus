spec: number_abbreviate
version: ">=1.0.0"
backend: node(number-abbreviate)

docs: https://www.npmjs.com/package/number-abbreviate

provenance:
  derived_from:
    - "number-abbreviate README — https://www.npmjs.com/package/number-abbreviate"
    - "Test vectors verified with number-abbreviate via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "number-abbreviate source"
  notes:
    - "number-abbreviate is an npm package. Install: npm install number-abbreviate"
    - "abbreviate(n) abbreviates large numbers to short strings (e.g. 1000 → '1k')."
    - "Numbers below 1000 are returned as-is (as a number, not a string)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns abbreviated string or original number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table number_abbreviate.abbreviate:
  kind: node_module_call_eq
  function: ~
  category: format
  id_prefix: nabbr

  columns: [id, args, expected]
  rows:
    - [thousands,  [1000],    "1k"]
    - [millions,   [1500000], "2m"]
