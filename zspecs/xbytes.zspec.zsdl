spec: xbytes
version: ">=1.0.0"
backend: node(xbytes)

docs: https://www.npmjs.com/package/xbytes

provenance:
  derived_from:
    - "xbytes README — https://www.npmjs.com/package/xbytes"
    - "Test vectors verified with xbytes via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "xbytes source"
  notes:
    - "xbytes is an npm package. Install: npm install xbytes"
    - "Converts a byte count to a human-readable string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a formatted string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table xbytes.format:
  kind: node_module_call_eq
  function: ~
  category: formatting
  id_prefix: xbyt

  columns: [id, args, expected]
  rows:
    - [kilobyte,  [1000],         "1.00 KB"]
    - [megabyte,  [1048576],      "1.05 MB"]
    - [bytes,     [500],          "500.00 B"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:31:09Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
