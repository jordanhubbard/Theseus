spec: io_extra76
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra7."
    - "Prior specs covered: class names/modules/bases for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; io class __qualname__ checks."
    - "This spec covers: IOBase C method descriptor identity via __class__.__name__ and __qualname__ for close, flush, readable, writable, seekable, tell."
    - "io.IOBase.close is a method_descriptor (C slot); its __class__.__name__ == 'method_descriptor'."
    - "io.IOBase.flush.__class__.__name__ == 'method_descriptor'."
    - "io.IOBase.readable.__class__.__name__ == 'method_descriptor'."
    - "io.IOBase.writable.__class__.__name__ == 'method_descriptor'."
    - "io.IOBase.seekable.__class__.__name__ == 'method_descriptor'."
    - "io.IOBase.tell.__class__.__name__ == 'method_descriptor'."
    - "io.IOBase.close.__qualname__ == 'IOBase.close'."
    - "io.IOBase.flush.__qualname__ == 'IOBase.flush'."
    - "io.IOBase.readable.__qualname__ == 'IOBase.readable'."
    - "io.IOBase.writable.__qualname__ == 'IOBase.writable'."
    - "io.IOBase.seekable.__qualname__ == 'IOBase.seekable'."
    - "io.IOBase.tell.__qualname__ == 'IOBase.tell'."
    - "Qualname length: 'IOBase.close' == 12, 'IOBase.flush' == 12, 'IOBase.readable' == 15, 'IOBase.writable' == 15, 'IOBase.seekable' == 15, 'IOBase.tell' == 11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase method descriptor class checks — close, flush, readable, writable
# These are C-implemented methods; accessed from the class object they are
# method_descriptor instances. Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra76.IOBase_method_classes:
  description: "IOBase C methods have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: iometh76

  columns: [id, function, args, expected]
  rows:
    - [close,    IOBase.close.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [flush,    IOBase.flush.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [readable, IOBase.readable.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [writable, IOBase.writable.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# IOBase method descriptor class checks — seekable, tell
# ---------------------------------------------------------------------------

table io_extra76.IOBase_method_classes_2:
  description: "IOBase C methods seekable and tell also have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: iometh76

  columns: [id, function, args, expected]
  rows:
    - [seekable, IOBase.seekable.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [tell,     IOBase.tell.__class__.__name__.__eq__,     ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# IOBase method __qualname__ equality checks — close, flush, readable, writable
# __qualname__ for methods on a C class is 'ClassName.method_name'.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra76.IOBase_method_qualnames:
  description: "IOBase C methods carry the qualified name 'IOBase.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iometh76

  columns: [id, function, args, expected]
  rows:
    - [close,    IOBase.close.__qualname__.__eq__,    ["IOBase.close"],    true]
    - [flush,    IOBase.flush.__qualname__.__eq__,    ["IOBase.flush"],    true]
    - [readable, IOBase.readable.__qualname__.__eq__, ["IOBase.readable"], true]
    - [writable, IOBase.writable.__qualname__.__eq__, ["IOBase.writable"], true]

# ---------------------------------------------------------------------------
# IOBase method __qualname__ length checks
# 'IOBase.close'    == 12 chars
# 'IOBase.flush'    == 12 chars
# 'IOBase.readable' == 15 chars
# 'IOBase.writable' == 15 chars
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra76.IOBase_method_qualname_lengths:
  description: "IOBase method __qualname__ string lengths"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: iometh76

  columns: [id, function, args, expected]
  rows:
    - [close,    IOBase.close.__qualname__.__len__,    [], 12]
    - [flush,    IOBase.flush.__qualname__.__len__,    [], 12]
    - [readable, IOBase.readable.__qualname__.__len__, [], 15]
    - [writable, IOBase.writable.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra76.IOBase_close.method_descriptor:
  description: "io.IOBase.close.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: IOBase.close.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra76.IOBase_close.qualname:
  description: "io.IOBase.close.__qualname__ == 'IOBase.close'"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.close.__qualname__.__eq__
  args: ["IOBase.close"]
  expected: true

invariant io_extra76.IOBase_readable.method_descriptor:
  description: "io.IOBase.readable.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: IOBase.readable.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra76.IOBase_readable.qualname_len_15:
  description: "len('IOBase.readable') == 15 — verified via __qualname__.__len__"
  category: method_qualname_lengths
  kind: python_call_eq
  function: IOBase.readable.__qualname__.__len__
  args: []
  expected: 15

invariant io_extra76.IOBase_seekable.method_descriptor:
  description: "io.IOBase.seekable.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: IOBase.seekable.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
