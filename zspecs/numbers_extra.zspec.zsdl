spec: numbers_extra
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/numbers.html"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "numbers source: internal C extension implementation details"
  notes:
    - "Complements numbers.zspec.zsdl with inheritance hierarchy and isinstance checks."
    - "The numeric tower is: Number > Complex > Real > Rational > Integral."
    - "numbers.Number.__bases__[0].__name__ is 'object' — Number inherits directly from object."
    - "numbers.Complex.__bases__[0].__name__ is 'Number' — Complex extends Number."
    - "numbers.Real.__bases__[0].__name__ is 'Complex' — Real extends Complex."
    - "numbers.Rational.__bases__[0].__name__ is 'Real' — Rational extends Real."
    - "numbers.Integral.__bases__[0].__name__ is 'Rational' — Integral extends Rational."
    - "isinstance(1, numbers.Integral) is True because int is registered as Integral."
    - "isinstance(1.0, numbers.Real) is True because float is registered as Real."
    - "isinstance(1+2j, numbers.Complex) is True because complex is registered as Complex."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Inheritance hierarchy — __bases__[0] for each class in the numeric tower
#
# The numeric tower is a strict linear hierarchy. Each class's first (and only)
# base is the class immediately above it in the tower.
# Number's base is object (the universal root).
# ---------------------------------------------------------------------------

invariant numbers_extra.hierarchy.Number_base:
  description: "numbers.Number.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Number.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant numbers_extra.hierarchy.Complex_base:
  description: "numbers.Complex.__bases__[0].__name__ == 'Number'"
  category: hierarchy
  kind: python_call_eq
  function: Complex.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Number"

invariant numbers_extra.hierarchy.Real_base:
  description: "numbers.Real.__bases__[0].__name__ == 'Complex'"
  category: hierarchy
  kind: python_call_eq
  function: Real.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Complex"

invariant numbers_extra.hierarchy.Rational_base:
  description: "numbers.Rational.__bases__[0].__name__ == 'Real'"
  category: hierarchy
  kind: python_call_eq
  function: Rational.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Real"

invariant numbers_extra.hierarchy.Integral_base:
  description: "numbers.Integral.__bases__[0].__name__ == 'Rational'"
  category: hierarchy
  kind: python_call_eq
  function: Integral.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Rational"

# ---------------------------------------------------------------------------
# isinstance registration — concrete types are registered in the tower
#
# CPython registers int, float, and complex with the numeric ABC machinery.
# isinstance() checks use the ABC __subclasshook__ to detect these.
# We test using __abstractmethods__ count as a proxy because isinstance
# with class objects cannot be expressed in JSON; instead we verify that
# Integral.__abstractmethods__ contains '__int__' (a well-known Integral method)
# confirming int satisfies it, and test the tower membership indirectly via
# the known abstract method memberships.
#
# For direct isinstance-style checks we use __instancecheck__ on the ABC:
#   Integral.__instancecheck__(1) == True
# ---------------------------------------------------------------------------

invariant numbers_extra.isinstance.int_is_Integral:
  description: "numbers.Integral.__instancecheck__(1) == True — int is an Integral"
  category: isinstance
  kind: python_call_eq
  function: Integral.__instancecheck__
  args: [1]
  expected: true

invariant numbers_extra.isinstance.float_is_Real:
  description: "numbers.Real.__instancecheck__(1.0) == True — float is a Real"
  category: isinstance
  kind: python_call_eq
  function: Real.__instancecheck__
  args: [1.0]
  expected: true

invariant numbers_extra.isinstance.complex_is_Complex:
  description: "numbers.Complex.__instancecheck__(1) == True — int (as a complex) satisfies Complex"
  category: isinstance
  kind: python_call_eq
  function: Complex.__instancecheck__
  args: [1]
  expected: true

invariant numbers_extra.isinstance.int_is_Number:
  description: "numbers.Number.__instancecheck__(1) == True — int satisfies Number"
  category: isinstance
  kind: python_call_eq
  function: Number.__instancecheck__
  args: [1]
  expected: true

invariant numbers_extra.isinstance.float_is_Number:
  description: "numbers.Number.__instancecheck__(1.0) == True — float satisfies Number"
  category: isinstance
  kind: python_call_eq
  function: Number.__instancecheck__
  args: [1.0]
  expected: true

invariant numbers_extra.isinstance.str_not_Integral:
  description: "numbers.Integral.__instancecheck__('x') == False — str is not an Integral"
  category: isinstance
  kind: python_call_eq
  function: Integral.__instancecheck__
  args: ["x"]
  expected: false

# ---------------------------------------------------------------------------
# Abstract method presence — Integral-specific bitwise ops
#
# Integral is the only level in the tower that requires bitwise operations.
# These spot-checks confirm that Integral (not Real/Rational/Complex) declares them.
# ---------------------------------------------------------------------------

invariant numbers_extra.abstract_methods.Integral_has_or:
  description: "numbers.Integral.__abstractmethods__.__contains__('__or__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__or__"]
  expected: true

invariant numbers_extra.abstract_methods.Integral_has_xor:
  description: "numbers.Integral.__abstractmethods__.__contains__('__xor__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__xor__"]
  expected: true

invariant numbers_extra.abstract_methods.Integral_has_lshift:
  description: "numbers.Integral.__abstractmethods__.__contains__('__lshift__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__lshift__"]
  expected: true

invariant numbers_extra.abstract_methods.Real_has_trunc:
  description: "numbers.Real.__abstractmethods__.__contains__('__trunc__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Real.__abstractmethods__.__contains__
  args: ["__trunc__"]
  expected: true

invariant numbers_extra.abstract_methods.Real_has_floor:
  description: "numbers.Real.__abstractmethods__.__contains__('__floor__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Real.__abstractmethods__.__contains__
  args: ["__floor__"]
  expected: true

invariant numbers_extra.abstract_methods.Complex_has_real:
  description: "numbers.Complex.__abstractmethods__.__contains__('real') == True — real part property"
  category: abstract_methods
  kind: python_call_eq
  function: Complex.__abstractmethods__.__contains__
  args: ["real"]
  expected: true

invariant numbers_extra.abstract_methods.Complex_has_imag:
  description: "numbers.Complex.__abstractmethods__.__contains__('imag') == True — imaginary part property"
  category: abstract_methods
  kind: python_call_eq
  function: Complex.__abstractmethods__.__contains__
  args: ["imag"]
  expected: true
