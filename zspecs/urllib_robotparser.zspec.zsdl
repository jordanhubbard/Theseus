spec: urllib_robotparser
version: ">=3.0"
backend: python_module(urllib.robotparser)

docs: https://docs.python.org/3/library/urllib.robotparser.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.robotparser.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "urllib.robotparser source: Lib/urllib/robotparser.py (PSF; source inspection permitted)"
  not_derived_from:
    - "urllib.robotparser source: internal line-parsing and path-matching details"
  notes:
    - "urllib.robotparser exposes one public class: RobotFileParser."
    - "RobotFileParser().url is '' (empty string) before set_url() is called."
    - "set_url(url) stores the URL and returns None."
    - "parse(lines) accepts an iterable of strings (robots.txt lines) and returns None."
    - "can_fetch(useragent, url) returns True if the agent is allowed to fetch the URL."
    - "crawl_delay(useragent) returns None if no Crawl-delay directive is present."
    - "request_rate(useragent) returns None if no Request-rate directive is present."
    - "disallow_all and allow_all are bool attributes set during parse(); both False initially."
    - "RobotFileParser.__module__ == 'urllib.robotparser'."
    - "All expected values verified by running Python 3.12 urllib.robotparser module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name check
# ---------------------------------------------------------------------------

invariant urllib_robotparser.class_name:
  description: "urllib.robotparser.RobotFileParser.__name__ == 'RobotFileParser'"
  category: classes
  kind: python_call_eq
  function: RobotFileParser.__name__.__eq__
  args: ["RobotFileParser"]
  expected: true

invariant urllib_robotparser.class_module:
  description: "urllib.robotparser.RobotFileParser.__module__ == 'urllib.robotparser'"
  category: classes
  kind: python_call_eq
  function: RobotFileParser.__module__.__eq__
  args: ["urllib.robotparser"]
  expected: true

# ---------------------------------------------------------------------------
# Method name checks
# ---------------------------------------------------------------------------

table urllib_robotparser.method_names:
  kind: python_call_eq
  category: functions
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [set_url,      RobotFileParser.set_url.__name__.__eq__,      ["set_url"],      true]
    - [read,         RobotFileParser.read.__name__.__eq__,         ["read"],         true]
    - [parse,        RobotFileParser.parse.__name__.__eq__,        ["parse"],        true]
    - [can_fetch,    RobotFileParser.can_fetch.__name__.__eq__,    ["can_fetch"],    true]
    - [crawl_delay,  RobotFileParser.crawl_delay.__name__.__eq__,  ["crawl_delay"],  true]
    - [request_rate, RobotFileParser.request_rate.__name__.__eq__,  ["request_rate"], true]

# ---------------------------------------------------------------------------
# Initial state — url is empty string before set_url()
# ---------------------------------------------------------------------------

invariant urllib_robotparser.initial_url:
  description: "RobotFileParser().url == '' (empty string before set_url is called)"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: url
  method_args: []
  expected: ""

# ---------------------------------------------------------------------------
# Initial state — disallow_all and allow_all are False
# ---------------------------------------------------------------------------

invariant urllib_robotparser.initial_disallow_all:
  description: "RobotFileParser().disallow_all == False initially"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: disallow_all
  method_args: []
  expected: false

invariant urllib_robotparser.initial_allow_all:
  description: "RobotFileParser().allow_all == False initially"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: allow_all
  method_args: []
  expected: false

# ---------------------------------------------------------------------------
# set_url() returns None
# ---------------------------------------------------------------------------

invariant urllib_robotparser.set_url_returns_none:
  description: "RobotFileParser().set_url('http://example.com/robots.txt') == None"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: set_url
  method_args: ["http://example.com/robots.txt"]
  expected: null

# ---------------------------------------------------------------------------
# crawl_delay and request_rate return None on an empty (unparsed) parser
# ---------------------------------------------------------------------------

invariant urllib_robotparser.crawl_delay_empty:
  description: "RobotFileParser().crawl_delay('*') == None (no Crawl-delay directive)"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: crawl_delay
  method_args: ["*"]
  expected: null

invariant urllib_robotparser.request_rate_empty:
  description: "RobotFileParser().request_rate('*') == None (no Request-rate directive)"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: request_rate
  method_args: ["*"]
  expected: null

# ---------------------------------------------------------------------------
# entries list is empty initially
# ---------------------------------------------------------------------------

invariant urllib_robotparser.initial_entries_empty:
  description: "RobotFileParser().entries == [] (no rules parsed yet)"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: entries
  method_args: []
  expected: []

# ---------------------------------------------------------------------------
# default_entry is None initially
# ---------------------------------------------------------------------------

invariant urllib_robotparser.initial_default_entry:
  description: "RobotFileParser().default_entry == None (no default rule set yet)"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: default_entry
  method_args: []
  expected: null
