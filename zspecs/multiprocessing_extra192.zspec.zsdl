invariant multiprocessing_extra192.mp_Value_name_eq:
  description: "multiprocessing.Value.__name__.__eq__('Value') returns True — multiprocessing.Value.__name__=='Value' (len=5: V(1)a(2)l(3)u(4)e(5)); multiprocessing.Value creates a ctypes object in shared memory, allowing a scalar value to be safely read and written by multiple processes; it is exposed as a bound method on the default multiprocessing context (not a raw function or class); multiprocessing.Value.__name__ (5) == multiprocessing.Array.__name__ (5) — both are 5-character names; NEW in mpsharedctypes192: first standalone multiprocessing.Value.__name__.__eq__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__name__.__eq__
  args: ["Value"]
  expected: true

invariant multiprocessing_extra192.mp_Value_class_is_method:
  description: "multiprocessing.Value.__class__.__name__.__eq__('method') returns True — multiprocessing.Value.__class__.__name__=='method' (len=6: m(1)e(2)t(3)h(4)o(5)d(6)); multiprocessing.Value is a bound method on the default multiprocessing context object (BaseContext); the context pattern allows multiprocessing to switch between 'fork', 'spawn', and 'forkserver' start methods; the underlying function is multiprocessing.sharedctypes.Value (a plain function with __class__.__name__=='function'); multiprocessing.Value (method) vs multiprocessing.sharedctypes.Value (function) — top-level is bound method, submodule is bare function; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra192.mp_Array_name_eq:
  description: "multiprocessing.Array.__name__.__eq__('Array') returns True — multiprocessing.Array.__name__=='Array' (len=5: A(1)r(2)r(3)a(4)y(5)); multiprocessing.Array creates a ctypes array in shared memory with a process-safe lock; like Value, it is a bound method on the default context object; multiprocessing.Array.__name__ (5) == multiprocessing.Value.__name__ (5) — both Value and Array have 5-character names; NEW in mpsharedctypes192: first standalone multiprocessing.Array.__name__.__eq__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Array.__name__.__eq__
  args: ["Array"]
  expected: true

invariant multiprocessing_extra192.mp_Array_class_is_method:
  description: "multiprocessing.Array.__class__.__name__.__eq__('method') returns True — multiprocessing.Array.__class__.__name__=='method'; multiprocessing.Array is a bound method on the default multiprocessing context, just like multiprocessing.Value; both are dispatched through the same BaseContext mechanism; multiprocessing.Array (method) delegates to multiprocessing.sharedctypes.Array (function) at runtime; multiprocessing.Array.__class__.__name__ (6) == multiprocessing.Value.__class__.__name__ (6) — same 'method' class; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Array.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra192.mp_sharedctypes_Value_name_eq:
  description: "multiprocessing.sharedctypes.Value.__name__.__eq__('Value') returns True — multiprocessing.sharedctypes.Value.__name__=='Value' (len=5); this is the bare module-level function in multiprocessing.sharedctypes, as opposed to the bound-method version at multiprocessing.Value; sharedctypes.Value is what actually implements shared ctypes scalars — it allocates a RawValue or a synchronized Value with a Lock; sharedctypes.Value.__class__.__name__=='function' (plain function) vs multiprocessing.Value.__class__.__name__=='method' (bound method); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.Value.__name__.__eq__
  args: ["Value"]
  expected: true

invariant multiprocessing_extra192.mp_sharedctypes_Value_module_eq:
  description: "multiprocessing.sharedctypes.Value.__module__.__eq__('multiprocessing.sharedctypes') returns True — sharedctypes.Value.__module__=='multiprocessing.sharedctypes' (len=28: 'multiprocessing'=15+'.'=1+'sharedctypes'=12=28); this confirms Value is defined in the sharedctypes submodule of multiprocessing, not in the top-level __init__; sharedctypes.Value.__module__ (28) == sharedctypes.Array.__module__ (28) — both live in the same submodule; multiprocessing.sharedctypes module name (28) is substantially longer than 'multiprocessing' alone (15); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.Value.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true

invariant multiprocessing_extra192.mp_sharedctypes_Array_name_eq:
  description: "multiprocessing.sharedctypes.Array.__name__.__eq__('Array') returns True — multiprocessing.sharedctypes.Array.__name__=='Array' (len=5: A(1)r(2)r(3)a(4)y(5)); sharedctypes.Array is the bare module-level function that creates a shared ctypes array; it is distinct from multiprocessing.Array (a bound method); sharedctypes.Array.__name__ (5) == sharedctypes.Value.__name__ (5) — both underlying functions have 5-character names matching their bound-method counterparts; NEW in mpsharedctypes192: first standalone sharedctypes.Array.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.Array.__name__.__eq__
  args: ["Array"]
  expected: true

invariant multiprocessing_extra192.mp_sharedctypes_Array_module_eq:
  description: "multiprocessing.sharedctypes.Array.__module__.__eq__('multiprocessing.sharedctypes') returns True — sharedctypes.Array.__module__=='multiprocessing.sharedctypes' (len=28); Array is defined alongside Value in the sharedctypes submodule; sharedctypes.Array.__module__ (28) == sharedctypes.Value.__module__ (28) — both functions share the same source module; the sharedctypes submodule is responsible for the entire RawValue, RawArray, Value, and Array API; NEW in mpsharedctypes192: completing 8-invariant coverage for multiprocessing Value and Array identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.Array.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true

