spec: multiprocessing_extra192
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/sharedctypes.py"
  notes:
    - "multiprocessing.Value is a bound method on the default context object, not a bare function or class; multiprocessing.Value.__class__.__name__ == 'method'."
    - "multiprocessing.Value.__name__ == 'Value' (len=5) — the bound method's __name__ reflects the underlying function name."
    - "multiprocessing.Array is likewise a bound method; multiprocessing.Array.__class__.__name__ == 'method'."
    - "multiprocessing.Array.__name__ == 'Array' (len=5)."
    - "multiprocessing.sharedctypes.Value is the underlying module-level function; __class__.__name__ == 'function'."
    - "multiprocessing.sharedctypes.Value.__name__ == 'Value' (len=5); __module__ == 'multiprocessing.sharedctypes' (len=28)."
    - "multiprocessing.sharedctypes.Array.__name__ == 'Array' (len=5); __module__ == 'multiprocessing.sharedctypes' (len=28)."
    - "Length ordering: Value.__name__ (5) == Array.__name__ (5); sharedctypes.__module__ (28) for both."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

