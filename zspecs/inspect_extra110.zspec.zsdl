spec: inspect_extra110
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra109.zspec.zsdl."
    - "This spec covers: inspect.isgeneratorfunction, inspect.iscoroutinefunction, inspect.isasyncgenfunction, inspect.isasyncgen, inspect.isgenerator, inspect.iscoroutine, inspect.isawaitable, inspect.isbuiltin __code__.co_name and __code__.co_argcount values; wave 262."
    - "inspect.isgeneratorfunction.__code__.co_name == 'isgeneratorfunction'. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__code__.co_name == 'iscoroutinefunction'. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_name == 'isasyncgenfunction'. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isgenerator.__code__.co_name == 'isgenerator'. Verified with Python 3.14.3."
    - "inspect.isgenerator.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__code__.co_name == 'iscoroutine'. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__code__.co_name == 'isasyncgen'. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isawaitable.__code__.co_name == 'isawaitable'. Verified with Python 3.14.3."
    - "inspect.isawaitable.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_name == 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "All inspect.is* predicate functions have co_argcount == 1 (single 'object' parameter). Verified with Python 3.14.3."
    - "All inspect.is* predicate functions have co_name equal to their __name__/__qualname__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect async/generator predicate co_name values
#
# Wave 262 theme: inspect.isgeneratorfunction, inspect.iscoroutinefunction,
# inspect.isasyncgenfunction, inspect.isasyncgen, inspect.isgenerator, and
# inspect.iscoroutine are pure-Python predicate functions defined in
# Lib/inspect.py. Each takes exactly one argument (the object to test). For
# pure-Python functions, __code__.co_name equals the function name string —
# identical to __qualname__ for these top-level functions. All have
# co_argcount == 1.
#
# inspect.isgeneratorfunction.__code__.co_name == 'isgeneratorfunction'
# inspect.iscoroutinefunction.__code__.co_name == 'iscoroutinefunction'
# inspect.isasyncgenfunction.__code__.co_name == 'isasyncgenfunction'
# inspect.isasyncgen.__code__.co_name == 'isasyncgen'
# inspect.isgenerator.__code__.co_name == 'isgenerator'
# inspect.iscoroutine.__code__.co_name == 'iscoroutine'
#
# New to extra110.
# ---------------------------------------------------------------------------

table inspect_extra110.async_gen_co_names:
  description: "inspect async/generator predicate co_name values: isgeneratorfunction, iscoroutinefunction, isasyncgenfunction, isasyncgen, isgenerator, iscoroutine; all co_name equals function name; wave 262; new to extra110"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectcn110

  columns: [id, function, args, expected, description]
  rows:
    - [isgeneratorfunction_co_name,
       "isgeneratorfunction.__code__.co_name.__eq__",
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__code__.co_name.__eq__('isgeneratorfunction') == True — inspect.isgeneratorfunction is a pure-Python function in Lib/inspect.py; for pure-Python functions __code__.co_name is the name of the function as written in the def statement; since this is a top-level function it equals the __qualname__; str.__eq__('isgeneratorfunction') returns True; new to extra110"]
    - [iscoroutinefunction_co_name,
       "iscoroutinefunction.__code__.co_name.__eq__",
       ["iscoroutinefunction"],
       true,
       "inspect.iscoroutinefunction.__code__.co_name.__eq__('iscoroutinefunction') == True — inspect.iscoroutinefunction is a pure-Python predicate function; its __code__.co_name is 'iscoroutinefunction' (the def-statement name); str.__eq__('iscoroutinefunction') returns True; new to extra110"]
    - [isasyncgenfunction_co_name,
       "isasyncgenfunction.__code__.co_name.__eq__",
       ["isasyncgenfunction"],
       true,
       "inspect.isasyncgenfunction.__code__.co_name.__eq__('isasyncgenfunction') == True — inspect.isasyncgenfunction is a pure-Python predicate function; its __code__.co_name is 'isasyncgenfunction'; str.__eq__('isasyncgenfunction') returns True; new to extra110"]
    - [isasyncgen_co_name,
       "isasyncgen.__code__.co_name.__eq__",
       ["isasyncgen"],
       true,
       "inspect.isasyncgen.__code__.co_name.__eq__('isasyncgen') == True — inspect.isasyncgen is a pure-Python predicate that checks if an object is an asynchronous generator; its __code__.co_name is 'isasyncgen'; str.__eq__('isasyncgen') returns True; new to extra110"]
    - [isgenerator_co_name,
       "isgenerator.__code__.co_name.__eq__",
       ["isgenerator"],
       true,
       "inspect.isgenerator.__code__.co_name.__eq__('isgenerator') == True — inspect.isgenerator is a pure-Python predicate that checks if an object is a generator; its __code__.co_name is 'isgenerator'; str.__eq__('isgenerator') returns True; new to extra110"]
    - [iscoroutine_co_name,
       "iscoroutine.__code__.co_name.__eq__",
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__code__.co_name.__eq__('iscoroutine') == True — inspect.iscoroutine is a pure-Python predicate that checks if an object is a coroutine; its __code__.co_name is 'iscoroutine'; str.__eq__('iscoroutine') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Table 2: inspect predicate co_argcount values
#
# Wave 262 theme: all inspect.is* predicate functions take exactly one
# positional argument — the object being tested. Therefore __code__.co_argcount
# is 1 for all of them. This applies to isgeneratorfunction, iscoroutinefunction,
# isasyncgenfunction, isgenerator, iscoroutine, isasyncgen, isawaitable, and
# isbuiltin. co_argcount counts only positional-or-keyword parameters (not
# *args, **kwargs, or keyword-only parameters).
#
# inspect.isgeneratorfunction.__code__.co_argcount == 1
# inspect.iscoroutinefunction.__code__.co_argcount == 1
# inspect.isasyncgenfunction.__code__.co_argcount == 1
# inspect.isgenerator.__code__.co_argcount == 1
# inspect.iscoroutine.__code__.co_argcount == 1
# inspect.isasyncgen.__code__.co_argcount == 1
# inspect.isawaitable.__code__.co_argcount == 1
# inspect.isbuiltin.__code__.co_argcount == 1
#
# New to extra110.
# ---------------------------------------------------------------------------

table inspect_extra110.predicate_co_argcount:
  description: "inspect predicate co_argcount values: all inspect.is* predicates have co_argcount == 1 (single object argument); isgeneratorfunction/iscoroutinefunction/isasyncgenfunction/isgenerator/iscoroutine/isasyncgen/isawaitable/isbuiltin; wave 262; new to extra110"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectca110

  columns: [id, function, args, expected, description]
  rows:
    - [isgeneratorfunction_co_argcount_1,
       "isgeneratorfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isgeneratorfunction.__code__.co_argcount.__eq__(1) == True — isgeneratorfunction takes exactly one positional argument: the object to test; co_argcount counts only positional-or-keyword parameters; int.__eq__(1) returns True; new to extra110"]
    - [iscoroutinefunction_co_argcount_1,
       "iscoroutinefunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutinefunction.__code__.co_argcount.__eq__(1) == True — iscoroutinefunction takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra110"]
    - [isasyncgenfunction_co_argcount_1,
       "isasyncgenfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgenfunction.__code__.co_argcount.__eq__(1) == True — isasyncgenfunction takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra110"]
    - [isgenerator_co_argcount_1,
       "isgenerator.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isgenerator.__code__.co_argcount.__eq__(1) == True — isgenerator takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra110"]
    - [iscoroutine_co_argcount_1,
       "iscoroutine.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutine.__code__.co_argcount.__eq__(1) == True — iscoroutine takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra110"]
    - [isasyncgen_co_argcount_1,
       "isasyncgen.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgen.__code__.co_argcount.__eq__(1) == True — isasyncgen takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra110"]
    - [isawaitable_co_argcount_1,
       "isawaitable.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isawaitable.__code__.co_argcount.__eq__(1) == True — isawaitable takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra110"]
    - [isbuiltin_co_argcount_1,
       "isbuiltin.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Table 3: inspect predicate co_name for isawaitable and isbuiltin
#
# Wave 262 theme: inspect.isawaitable tests if an object can be used in an
# await expression. inspect.isbuiltin tests if an object is a built-in function
# or bound built-in method. Both are pure-Python predicate functions with
# co_name matching their function name and co_argcount == 1. Their qualnames
# also match co_name (top-level functions).
#
# inspect.isawaitable.__code__.co_name == 'isawaitable'
# inspect.isbuiltin.__code__.co_name == 'isbuiltin'
# inspect.isawaitable.__qualname__ == 'isawaitable'
# inspect.isbuiltin.__qualname__ == 'isbuiltin'
#
# New to extra110.
# ---------------------------------------------------------------------------

table inspect_extra110.awaitable_builtin_co_names:
  description: "inspect.isawaitable and isbuiltin: co_name and qualname both match function name; co_argcount 1; wave 262; new to extra110"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectab110

  columns: [id, function, args, expected, description]
  rows:
    - [isawaitable_co_name,
       "isawaitable.__code__.co_name.__eq__",
       ["isawaitable"],
       true,
       "inspect.isawaitable.__code__.co_name.__eq__('isawaitable') == True — inspect.isawaitable is a pure-Python predicate that returns True if the object can be used in an await expression (coroutines and objects with __await__); its __code__.co_name is 'isawaitable'; str.__eq__('isawaitable') returns True; new to extra110"]
    - [isbuiltin_co_name,
       "isbuiltin.__code__.co_name.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__code__.co_name.__eq__('isbuiltin') == True — inspect.isbuiltin is a pure-Python predicate that tests if an object is a built-in function or bound built-in method; its __code__.co_name is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra110"]
    - [isawaitable_qualname_eq,
       "isawaitable.__qualname__.__eq__",
       ["isawaitable"],
       true,
       "inspect.isawaitable.__qualname__.__eq__('isawaitable') == True — inspect.isawaitable is a top-level function in Lib/inspect.py; its __qualname__ is 'isawaitable' (no dotted prefix); for top-level functions __qualname__ == co_name == __name__; str.__eq__('isawaitable') returns True; new to extra110"]
    - [isbuiltin_qualname_eq,
       "isbuiltin.__qualname__.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__qualname__.__eq__('isbuiltin') == True — inspect.isbuiltin is a top-level function in Lib/inspect.py; its __qualname__ is 'isbuiltin'; for top-level functions __qualname__ == co_name == __name__; str.__eq__('isbuiltin') returns True; new to extra110"]
    - [isgeneratorfunction_qualname_eq,
       "isgeneratorfunction.__qualname__.__eq__",
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__qualname__.__eq__('isgeneratorfunction') == True — inspect.isgeneratorfunction is a top-level function; its __qualname__ is 'isgeneratorfunction'; equal to co_name; str.__eq__('isgeneratorfunction') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra110
# ---------------------------------------------------------------------------

invariant inspect_extra110.isgeneratorfunction_co_argcount:
  description: "inspect.isgeneratorfunction.__code__.co_argcount == 1 — single object argument; all inspect.is* predicates share this; wave 262; new to extra110"
  kind: python_call_eq
  function: isgeneratorfunction.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra110.iscoroutinefunction_co_name:
  description: "inspect.iscoroutinefunction.__code__.co_name == 'iscoroutinefunction' — co_name matches function name for top-level pure-Python functions; wave 262; new to extra110"
  kind: python_call_eq
  function: iscoroutinefunction.__code__.co_name.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant inspect_extra110.isasyncgen_co_name:
  description: "inspect.isasyncgen.__code__.co_name == 'isasyncgen' — co_name matches function def name; wave 262; new to extra110"
  kind: python_call_eq
  function: isasyncgen.__code__.co_name.__eq__
  args: ["isasyncgen"]
  expected: true

invariant inspect_extra110.isbuiltin_co_argcount:
  description: "inspect.isbuiltin.__code__.co_argcount == 1 — single positional argument; same as all inspect.is* predicates; wave 262; new to extra110"
  kind: python_call_eq
  function: isbuiltin.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra110.isawaitable_co_argcount:
  description: "inspect.isawaitable.__code__.co_argcount == 1 — single positional argument; wave 262; new to extra110"
  kind: python_call_eq
  function: isawaitable.__code__.co_argcount.__eq__
  args: [1]
  expected: true
