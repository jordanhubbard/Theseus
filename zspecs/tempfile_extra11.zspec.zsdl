spec: tempfile_extra11
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "This spec extends tempfile.zspec.zsdl and all prior tempfile_extra specs through tempfile_extra10.zspec.zsdl."
    - "tempfile_extra10 covers TemporaryFile/NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory __name__ (table); mkstemp/mkdtemp/gettempdir/gettempprefix __name__ (table); tempdir default is None; gettempdir/gettempprefix return type str."
    - "tempfile_extra9 covers NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory __module__ and __qualname__; mkstemp/mkdtemp/gettempdir/gettempprefix __module__; mkstemp/__qualname__; gettempdir/__qualname__."
    - "tempfile_extra8 covers module __name__; utility function __name__ lengths and last-char checks; template value; gettempprefix/gettempdir return type."
    - "No prior tempfile spec covers NamedTemporaryFile.__name__ as a standalone named invariant in extra11 namespace."
    - "No prior tempfile spec covers TemporaryDirectory.__name__ as a standalone named invariant in extra11 namespace."
    - "No prior tempfile spec covers SpooledTemporaryFile.__name__ as a standalone named invariant in extra11 namespace."
    - "No prior tempfile spec covers mkstemp.__name__ as a standalone named invariant in extra11 namespace."
    - "No prior tempfile spec covers mkdtemp.__name__ as a standalone named invariant in extra11 namespace."
    - "No prior tempfile spec covers gettempdir.__name__ as a standalone named invariant in extra11 namespace."
    - "No prior tempfile spec covers a __module__ table for NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile/mkstemp/mkdtemp/gettempdir together in extra11 namespace."
    - "No prior tempfile spec covers gettempdir().__class__.__name__ == 'str' as a standalone named invariant in extra11 namespace."
    - "tempfile class __name__ checks: NamedTemporaryFile, TemporaryDirectory, SpooledTemporaryFile."
    - "tempfile utility function __name__ checks: mkstemp, mkdtemp, gettempdir."
    - "All six items have __module__ == 'tempfile'."
    - "gettempdir() returns a str — verified via __class__.__name__.__eq__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Public class __name__ standalone invariants — NamedTemporaryFile,
# TemporaryDirectory, SpooledTemporaryFile
#
# tempfile_extra10 covers these in a table. These standalone invariants
# provide direct lookup in the extra11 namespace without table context.
# ---------------------------------------------------------------------------

invariant tempfile_extra11.NamedTemporaryFile.name:
  description: "tempfile.NamedTemporaryFile.__name__ == 'NamedTemporaryFile' — standalone invariant in extra11"
  category: class_identity
  kind: python_call_eq
  function: NamedTemporaryFile.__name__.__eq__
  args: ["NamedTemporaryFile"]
  expected: true

invariant tempfile_extra11.TemporaryDirectory.name:
  description: "tempfile.TemporaryDirectory.__name__ == 'TemporaryDirectory' — standalone invariant in extra11"
  category: class_identity
  kind: python_call_eq
  function: TemporaryDirectory.__name__.__eq__
  args: ["TemporaryDirectory"]
  expected: true

invariant tempfile_extra11.SpooledTemporaryFile.name:
  description: "tempfile.SpooledTemporaryFile.__name__ == 'SpooledTemporaryFile' — standalone invariant in extra11"
  category: class_identity
  kind: python_call_eq
  function: SpooledTemporaryFile.__name__.__eq__
  args: ["SpooledTemporaryFile"]
  expected: true

# ---------------------------------------------------------------------------
# Utility function __name__ standalone invariants — mkstemp, mkdtemp, gettempdir
#
# tempfile_extra10 covers these in a table. These standalone invariants
# provide direct lookup in the extra11 namespace without table context.
# ---------------------------------------------------------------------------

invariant tempfile_extra11.mkstemp.name:
  description: "tempfile.mkstemp.__name__ == 'mkstemp' — standalone invariant in extra11"
  category: function_identity
  kind: python_call_eq
  function: mkstemp.__name__.__eq__
  args: ["mkstemp"]
  expected: true

invariant tempfile_extra11.mkdtemp.name:
  description: "tempfile.mkdtemp.__name__ == 'mkdtemp' — standalone invariant in extra11"
  category: function_identity
  kind: python_call_eq
  function: mkdtemp.__name__.__eq__
  args: ["mkdtemp"]
  expected: true

invariant tempfile_extra11.gettempdir.name:
  description: "tempfile.gettempdir.__name__ == 'gettempdir' — standalone invariant in extra11"
  category: function_identity
  kind: python_call_eq
  function: gettempdir.__name__.__eq__
  args: ["gettempdir"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile/
# mkstemp/mkdtemp/gettempdir
#
# tempfile_extra9 covers __module__ for each of these individually as standalone
# invariants. This table anchors the same property in the extra11 namespace as
# a grouped cross-check for all six names simultaneously.
# ---------------------------------------------------------------------------

table tempfile_extra11.item_modules:
  description: "__module__ == 'tempfile' for NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile/mkstemp/mkdtemp/gettempdir"
  kind: python_call_eq
  category: module_identity
  id_prefix: imod11

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__module__.__eq__,   ["tempfile"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__module__.__eq__,   ["tempfile"], true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__module__.__eq__, ["tempfile"], true]
    - [mkstemp,              mkstemp.__module__.__eq__,              ["tempfile"], true]
    - [mkdtemp,              mkdtemp.__module__.__eq__,              ["tempfile"], true]
    - [gettempdir,           gettempdir.__module__.__eq__,           ["tempfile"], true]

# ---------------------------------------------------------------------------
# gettempdir() return type — __class__.__name__ == 'str'
#
# tempfile_extra10 covers gettempdir().__class__.__name__ == 'str' as a
# standalone invariant. This spec re-anchors the same check in the extra11
# namespace as an independent cross-check using the same pattern.
# ---------------------------------------------------------------------------

invariant tempfile_extra11.gettempdir.return_type_str:
  description: "tempfile.gettempdir().__class__.__name__ == 'str' — gettempdir always returns a string path"
  category: return_types
  kind: python_call_eq
  function: gettempdir
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
