spec: pathlib_extra141
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path filesystem operation methods — __qualname__ string equality and length checks for stat, chmod, symlink_to, hardlink_to, resolve. Also co_argcount and co_varnames.__len__() for each method's code object. All methods are pure Python functions (not C descriptors), so __class__.__name__ == 'function'."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' (length 9), co_argcount == 1 (self only; follow_symlinks is keyword-only), co_varnames.__len__() == 2."
    - "pathlib.Path.chmod.__qualname__ == 'Path.chmod' (length 10), co_argcount == 2 (self, mode), co_varnames.__len__() == 3."
    - "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' (length 15), co_argcount == 3 (self, target, target_is_directory), co_varnames.__len__() == 3."
    - "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (length 16), co_argcount == 2 (self, target), co_varnames.__len__() == 2."
    - "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (length 12), co_argcount == 2 (self, strict), co_varnames.__len__() == 2."
    - "All methods' __module__ == 'pathlib' since Path is a pure Python class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path filesystem operation method __qualname__ equality and lengths
# stat: 'Path.stat' (9), chmod: 'Path.chmod' (10),
# symlink_to: 'Path.symlink_to' (15), hardlink_to: 'Path.hardlink_to' (16),
# resolve: 'Path.resolve' (12).
# ---------------------------------------------------------------------------

table pathlib_extra141.path_fsop_method_qualnames:
  description: "pathlib.Path filesystem operation method __qualname__ string equality and lengths: stat=9, chmod=10, symlink_to=15, hardlink_to=16, resolve=12"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibfs141

  columns: [id, function, args, expected]
  rows:
    - [stat_qn_eq,       Path.stat.__qualname__.__eq__,        ["Path.stat"],        true]
    - [stat_qn_len,      Path.stat.__qualname__.__len__,       [],                   9]
    - [chmod_qn_eq,      Path.chmod.__qualname__.__eq__,       ["Path.chmod"],       true]
    - [chmod_qn_len,     Path.chmod.__qualname__.__len__,      [],                   10]
    - [symlink_qn_eq,    Path.symlink_to.__qualname__.__eq__,  ["Path.symlink_to"],  true]
    - [symlink_qn_len,   Path.symlink_to.__qualname__.__len__, [],                   15]
    - [hardlink_qn_eq,   Path.hardlink_to.__qualname__.__eq__, ["Path.hardlink_to"], true]
    - [hardlink_qn_len,  Path.hardlink_to.__qualname__.__len__,[],                   16]
    - [resolve_qn_eq,    Path.resolve.__qualname__.__eq__,     ["Path.resolve"],     true]
    - [resolve_qn_len,   Path.resolve.__qualname__.__len__,    [],                   12]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem operation method __class__.__name__ and __module__
# All are pure Python functions from the pathlib module.
# ---------------------------------------------------------------------------

table pathlib_extra141.path_fsop_method_class_and_module:
  description: "pathlib.Path filesystem operation methods are all 'function' from module 'pathlib': stat, chmod, symlink_to, hardlink_to, resolve"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibfs141

  columns: [id, function, args, expected]
  rows:
    - [stat_cls_eq,      Path.stat.__class__.__name__.__eq__,       ["function"], true]
    - [chmod_cls_eq,     Path.chmod.__class__.__name__.__eq__,      ["function"], true]
    - [symlink_cls_eq,   Path.symlink_to.__class__.__name__.__eq__, ["function"], true]
    - [hardlink_cls_eq,  Path.hardlink_to.__class__.__name__.__eq__,["function"], true]
    - [resolve_cls_eq,   Path.resolve.__class__.__name__.__eq__,    ["function"], true]
    - [stat_mod_eq,      Path.stat.__module__.__eq__,               ["pathlib"],  true]
    - [chmod_mod_eq,     Path.chmod.__module__.__eq__,              ["pathlib"],  true]
    - [symlink_mod_eq,   Path.symlink_to.__module__.__eq__,         ["pathlib"],  true]
    - [hardlink_mod_eq,  Path.hardlink_to.__module__.__eq__,        ["pathlib"],  true]
    - [resolve_mod_eq,   Path.resolve.__module__.__eq__,            ["pathlib"],  true]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem operation method co_argcount
# stat: 1 (self; follow_symlinks is keyword-only),
# chmod: 2 (self, mode; follow_symlinks is keyword-only),
# symlink_to: 3 (self, target, target_is_directory),
# hardlink_to: 2 (self, target),
# resolve: 2 (self, strict).
# ---------------------------------------------------------------------------

table pathlib_extra141.path_fsop_method_co_argcount:
  description: "pathlib.Path filesystem method __code__.co_argcount: stat=1, chmod=2, symlink_to=3, hardlink_to=2, resolve=2"
  kind: python_call_eq
  category: method_code
  id_prefix: pathlibfs141

  columns: [id, function, args, expected]
  rows:
    - [stat_argc,       Path.stat.__code__.co_argcount.__eq__,        [1], true]
    - [chmod_argc,      Path.chmod.__code__.co_argcount.__eq__,       [2], true]
    - [symlink_argc,    Path.symlink_to.__code__.co_argcount.__eq__,  [3], true]
    - [hardlink_argc,   Path.hardlink_to.__code__.co_argcount.__eq__, [2], true]
    - [resolve_argc,    Path.resolve.__code__.co_argcount.__eq__,     [2], true]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem operation method co_varnames length
# stat: 2 ('self', 'follow_symlinks'),
# chmod: 3 ('self', 'mode', 'follow_symlinks'),
# symlink_to: 3 ('self', 'target', 'target_is_directory'),
# hardlink_to: 2 ('self', 'target'),
# resolve: 2 ('self', 'strict').
# ---------------------------------------------------------------------------

table pathlib_extra141.path_fsop_method_co_varnames_len:
  description: "pathlib.Path filesystem method __code__.co_varnames length: stat=2, chmod=3, symlink_to=3, hardlink_to=2, resolve=2"
  kind: python_call_eq
  category: method_code
  id_prefix: pathlibfs141

  columns: [id, function, args, expected]
  rows:
    - [stat_vnlen,       Path.stat.__code__.co_varnames.__len__,        [], 2]
    - [chmod_vnlen,      Path.chmod.__code__.co_varnames.__len__,       [], 3]
    - [symlink_vnlen,    Path.symlink_to.__code__.co_varnames.__len__,  [], 3]
    - [hardlink_vnlen,   Path.hardlink_to.__code__.co_varnames.__len__, [], 2]
    - [resolve_vnlen,    Path.resolve.__code__.co_varnames.__len__,     [], 2]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra141.Path.stat_qualname_eq:
  description: "pathlib.Path.stat.__qualname__ == 'Path.stat' (length 9; stat is a pure Python function defined directly on Path)"
  category: method_identity
  kind: python_call_eq
  function: Path.stat.__qualname__.__eq__
  args: ["Path.stat"]
  expected: true

invariant pathlib_extra141.Path.symlink_to_qualname_len_15:
  description: "pathlib.Path.symlink_to.__qualname__.__len__() == 15 ('Path.symlink_to' is 15 chars: 'Path' (4) + '.' (1) + 'symlink_to' (10))"
  category: method_identity
  kind: python_call_eq
  function: Path.symlink_to.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra141.Path.hardlink_to_qualname_len_16:
  description: "pathlib.Path.hardlink_to.__qualname__.__len__() == 16 ('Path.hardlink_to' is 16 chars: 'Path' (4) + '.' (1) + 'hardlink_to' (11))"
  category: method_identity
  kind: python_call_eq
  function: Path.hardlink_to.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra141.Path.symlink_to_co_argcount_3:
  description: "pathlib.Path.symlink_to.__code__.co_argcount == 3 (positional args are 'self', 'target', 'target_is_directory')"
  category: method_code
  kind: python_call_eq
  function: Path.symlink_to.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant pathlib_extra141.Path.resolve_is_function:
  description: "pathlib.Path.resolve.__class__.__name__ == 'function' (Path is a pure Python class, so its methods are plain Python functions, not C method_descriptors)"
  category: method_identity
  kind: python_call_eq
  function: Path.resolve.__class__.__name__.__eq__
  args: ["function"]
  expected: true
