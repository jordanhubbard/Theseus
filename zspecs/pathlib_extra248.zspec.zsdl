spec: pathlib_extra248
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra247.zspec.zsdl — covers Path.read_text, write_text, read_bytes, write_bytes method identity"
  notes:
    - "This spec covers: pathlib.Path directory management method identity — iterdir, mkdir, rmdir, unlink."
    - "pathlib.Path.iterdir.__name__ == 'iterdir' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' — length 12; verified Python 3.14.3 macOS."
    - "pathlib.Path.iterdir.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.mkdir.__name__ == 'mkdir' — length 5; verified Python 3.14.3 macOS."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' — length 10; verified Python 3.14.3 macOS."
    - "pathlib.Path.mkdir.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.rmdir.__name__ == 'rmdir' — length 5; verified Python 3.14.3 macOS."
    - "pathlib.Path.rmdir.__qualname__ == 'Path.rmdir' — length 10; verified Python 3.14.3 macOS."
    - "pathlib.Path.rmdir.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.unlink.__name__ == 'unlink' — length 6; verified Python 3.14.3 macOS."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink' — length 11; verified Python 3.14.3 macOS."
    - "pathlib.Path.unlink.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "All these methods are regular Python instance methods defined in pathlib, so __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.iterdir method identity contracts
# iterdir.__name__ == 'iterdir' (len=7), __qualname__ == 'Path.iterdir' (len=12),
# __module__ == 'pathlib'. All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table pathlib_extra248.iterdir_identity:
  description: "pathlib.Path.iterdir method identity: __name__, __qualname__, __module__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibdir248

  columns: [id, function, args, expected]
  rows:
    - [iterdir_name_eq,      Path.iterdir.__name__.__eq__,      ["iterdir"],      true]
    - [iterdir_name_not,     Path.iterdir.__name__.__eq__,      ["mkdir"],        false]
    - [iterdir_qualname_eq,  Path.iterdir.__qualname__.__eq__,  ["Path.iterdir"], true]
    - [iterdir_module_eq,    Path.iterdir.__module__.__eq__,    ["pathlib"],      true]
    - [iterdir_name_len,     Path.iterdir.__name__.__len__,     [],               7]

# ---------------------------------------------------------------------------
# pathlib.Path.mkdir method identity contracts
# mkdir.__name__ == 'mkdir' (len=5), __qualname__ == 'Path.mkdir' (len=10),
# __module__ == 'pathlib'. All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table pathlib_extra248.mkdir_identity:
