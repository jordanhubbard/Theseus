# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra248.iterdir.name_eq:
  description: "pathlib.Path.iterdir.__name__ == 'iterdir' — the unbound method's __name__ attribute; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.iterdir.__name__.__eq__
  args: ["iterdir"]
  expected: true

invariant pathlib_extra248.iterdir.qualname_eq:
  description: "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' — the class-qualified name for the method; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__eq__
  args: ["Path.iterdir"]
  expected: true

invariant pathlib_extra248.iterdir.qualname_len:
  description: "len(pathlib.Path.iterdir.__qualname__) == 12 — 'Path.iterdir' has 12 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__len__
  args: []
  expected: 12

