  rows:
    - [mkdir_name_eq,      Path.mkdir.__name__.__eq__,      ["mkdir"],      true]
    - [mkdir_name_not,     Path.mkdir.__name__.__eq__,      ["rmdir"],      false]
    - [mkdir_qualname_eq,  Path.mkdir.__qualname__.__eq__,  ["Path.mkdir"], true]
    - [mkdir_module_eq,    Path.mkdir.__module__.__eq__,    ["pathlib"],    true]
    - [mkdir_name_len,     Path.mkdir.__name__.__len__,     [],             5]

