spec: io_extra961
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class and constant documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.UnsupportedOperation, io.BlockingIOError, module constants, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra961.exception_identity:
  description: "io.UnsupportedOperation and io.BlockingIOError class name/module identity"
  kind: python_call_eq
  category: exception_identity
  id_prefix: io961x
  columns: [id, function, args, expected]
  rows:
    - [io961x001, io.UnsupportedOperation.__name__.__eq__,              ["UnsupportedOperation"], true]
    - [io961x002, io.UnsupportedOperation.__module__.__eq__,            ["io"],                   true]
    - [io961x003, io.UnsupportedOperation.__qualname__.__eq__,          ["UnsupportedOperation"], true]
    - [io961x004, io.BlockingIOError.__name__.__eq__,                   ["BlockingIOError"],      true]
    - [io961x005, io.BlockingIOError.__module__.__eq__,                 ["builtins"],             true]
    - [io961x006, io.UnsupportedOperation.__class__.__name__.__eq__,    ["type"],                 true]
    - [io961x007, io.BlockingIOError.__class__.__name__.__eq__,         ["type"],                 true]

table io_extra961.module_constants:
  description: "io module integer constants class identity"
  kind: python_call_eq
  category: module_constants
  id_prefix: io961c
  columns: [id, function, args, expected]
  rows:
    - [io961c001, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true]
    - [io961c002, io.SEEK_SET.__class__.__name__.__eq__,            ["int"], true]
    - [io961c003, io.SEEK_CUR.__class__.__name__.__eq__,            ["int"], true]
    - [io961c004, io.SEEK_END.__class__.__name__.__eq__,            ["int"], true]
    - [io961c005, io.DEFAULT_BUFFER_SIZE.__gt__,                    [0],    true]
    - [io961c006, io.SEEK_SET.__eq__,                               [0],    true]
    - [io961c007, io.SEEK_CUR.__eq__,                               [1],    true]
    - [io961c008, io.SEEK_END.__eq__,                               [2],    true]

table io_extra961.module_identity:
  description: "io module __name__ and __spec__.name identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: io961m
  columns: [id, function, args, expected]
  rows:
    - [io961m001, io.__name__.__eq__,       ["io"], true]
    - [io961m002, io.__spec__.name.__eq__,  ["io"], true]
    - [io961m003, io.__package__.__eq__,    [""],   true]
    - [io961m004, io.__loader__.__class__.__name__.__eq__, ["BuiltinImporter"], true]
