spec: theseus_http_client_cr
version: ">=3.0"
backend: python_cleanroom(theseus_http_client_cr)
blocks: http.client

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.client.html"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
  notes:
    - "Clean-room http.client module. Do NOT import http.client."

error_model: python_exceptions

invariant theseus_http_client_cr.httpclient2_constants:
  description: "HTTP status constants exist (OK=200, NOT_FOUND=404)"
  category: behavior
  kind: python_call_eq
  function: httpclient2_constants
  args: []
  expected: true

invariant theseus_http_client_cr.httpclient2_responses:
  description: "responses dict maps status codes to descriptions"
  category: behavior
  kind: python_call_eq
  function: httpclient2_responses
  args: []
  expected: true

invariant theseus_http_client_cr.httpclient2_classes:
  description: "HTTPConnection and HTTPResponse classes exist"
  category: behavior
  kind: python_call_eq
  function: httpclient2_classes
  args: []
  expected: true
