spec: lodash_dropright
version: ">=4.0.0"
backend: node(lodash.dropright)

docs: https://lodash.com/docs/#dropRight

provenance:
  derived_from:
    - "lodash.dropright README — https://www.npmjs.com/package/lodash.dropright"
    - "Test vectors verified with lodash.dropright@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.dropright exports the _.dropRight function directly as module.exports."
    - "dropRight(array, n) drops n elements from the end of array."
    - "Defaults to n=1 if omitted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array with n elements removed from the right."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_dropright.dropright:
  kind: node_module_call_eq
  function: ~
  category: dropright
  id_prefix: ldr

  columns: [id, args, expected]
  rows:
    - [drop2,  [[1, 2, 3, 4, 5], 2],  [1, 2, 3]]
    - [drop1,  [[1, 2, 3], 1],        [1, 2]]
    - [drop0,  [[1, 2, 3], 0],        [1, 2, 3]]
    - [all,    [[1, 2, 3], 3],        []]
