spec: concurrent_futures_extra78
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra77.zspec.zsdl."
    - "This spec covers: wave 245 theme — concurrent.futures FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED string values and wait/as_completed code attrs. NEW in extra78: FIRST_COMPLETED.__class__.__name__=='str' (plain string constant, not an enum); FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True; FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True; ALL_COMPLETED.__eq__('ALL_COMPLETED')==True; wait.__code__.co_name=='wait'; wait.__code__.co_argcount==3 (fs + timeout + return_when); as_completed.__code__.co_name=='as_completed'; as_completed.__code__.co_argcount==2 (fs + timeout); wait.__module__=='concurrent.futures._base'; as_completed.__module__=='concurrent.futures._base'; wait.__qualname__=='wait'; as_completed.__qualname__=='as_completed'; FIRST_COMPLETED.__len__()==15; FIRST_EXCEPTION.__len__()==15; ALL_COMPLETED.__len__()==13; wait.__qualname__.__len__()==4; as_completed.__qualname__.__len__()==12. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'. FIRST_COMPLETED is a plain string constant, not an enum value. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True. The constant value equals the string 'FIRST_COMPLETED'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') == True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_name == 'wait'. wait is a pure Python function in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_argcount == 3. fs, timeout, and return_when are positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_name == 'as_completed'. as_completed is a pure Python function in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_argcount == 2. fs and timeout are positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__module__ == 'concurrent.futures._base'. wait is defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'. as_completed is defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__qualname__ == 'wait'. Simple top-level function qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__qualname__ == 'as_completed'. Simple top-level function qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "len(FIRST_COMPLETED) == 15. len('FIRST_COMPLETED') == 15. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "len(FIRST_EXCEPTION) == 15. len('FIRST_EXCEPTION') == 15. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "len(ALL_COMPLETED) == 13. len('ALL_COMPLETED') == 13. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "len(wait.__qualname__) == 4. len('wait') == 4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "len(as_completed.__qualname__) == 12. len('as_completed') == 12. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED string checks — extra78
#
# Wave 245 theme: FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED string values and
# wait/as_completed code attrs.
#
# FIRST_COMPLETED.__class__.__name__ == 'str'
# FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True
# FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True
# ALL_COMPLETED.__eq__('ALL_COMPLETED') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra78.wait_constants_class_and_equality:
  description: "concurrent.futures wait constants class name and equality checks in cfextra78 namespace — wave 245 theme: FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED string values; FIRST_COMPLETED.__class__.__name__=='str' (plain string constant, not an enum); FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True; FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True; ALL_COMPLETED.__eq__('ALL_COMPLETED')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra78

  columns: [id, function, args, expected, description]
  rows:
    - [fc_class_name,    FIRST_COMPLETED.__class__.__name__.__eq__, ["str"],             true, "FIRST_COMPLETED.__class__.__name__ == 'str' — plain string constant, not an enum; verified with Python 3.14.3"]
    - [fc_eq,            FIRST_COMPLETED.__eq__,                    ["FIRST_COMPLETED"], true, "FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True — string value equals its own name; verified with Python 3.14.3"]
    - [fe_eq,            FIRST_EXCEPTION.__eq__,                    ["FIRST_EXCEPTION"], true, "FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True — string value equals its own name; verified with Python 3.14.3"]
    - [ac_eq,            ALL_COMPLETED.__eq__,                      ["ALL_COMPLETED"],   true, "ALL_COMPLETED.__eq__('ALL_COMPLETED') == True — string value equals its own name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait constants length checks — extra78
#
# FIRST_COMPLETED.__len__() == 15
# FIRST_EXCEPTION.__len__() == 15
# ALL_COMPLETED.__len__() == 13
# ---------------------------------------------------------------------------

table concurrent_futures_extra78.wait_constants_lengths:
  description: "concurrent.futures wait constants length checks in cfextra78 namespace — wave 245 theme: FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED string lengths; FIRST_COMPLETED.__len__()==15 (len('FIRST_COMPLETED')==15); FIRST_EXCEPTION.__len__()==15 (len('FIRST_EXCEPTION')==15); ALL_COMPLETED.__len__()==13 (len('ALL_COMPLETED')==13); wait.__qualname__.__len__()==4 (len('wait')==4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra78a

  columns: [id, function, args, expected, description]
  rows:
    - [fc_len,           FIRST_COMPLETED.__len__,        [], 15, "FIRST_COMPLETED.__len__() == 15 — len('FIRST_COMPLETED') == 15; verified with Python 3.14.3"]
    - [fe_len,           FIRST_EXCEPTION.__len__,        [], 15, "FIRST_EXCEPTION.__len__() == 15 — len('FIRST_EXCEPTION') == 15; verified with Python 3.14.3"]
    - [ac_len,           ALL_COMPLETED.__len__,          [], 13, "ALL_COMPLETED.__len__() == 13 — len('ALL_COMPLETED') == 13; verified with Python 3.14.3"]
    - [wait_qname_len,   wait.__qualname__.__len__,      [], 4,  "wait.__qualname__.__len__() == 4 — len('wait') == 4; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait and as_completed code attributes — extra78
#
# wait.__code__.co_name == 'wait'
# wait.__code__.co_argcount == 3
# as_completed.__code__.co_name == 'as_completed'
# as_completed.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra78.wait_and_as_completed_code_attrs:
  description: "concurrent.futures wait and as_completed code attribute checks in cfextra78 namespace — wave 245 theme: wait/as_completed code attributes; wait.__code__.co_name=='wait'; wait.__code__.co_argcount==3 (fs + timeout + return_when); as_completed.__code__.co_name=='as_completed'; as_completed.__code__.co_argcount==2 (fs + timeout); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfextra78b

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_name,          wait.__code__.co_name.__eq__,          ["wait"],         true, "wait.__code__.co_name == 'wait' — pure Python function in concurrent.futures._base; verified with Python 3.14.3"]
    - [wait_co_argcount,      wait.__code__.co_argcount.__eq__,      [3],              true, "wait.__code__.co_argcount == 3 — fs, timeout, and return_when are positional parameters; verified with Python 3.14.3"]
    - [as_comp_co_name,       as_completed.__code__.co_name.__eq__,  ["as_completed"], true, "as_completed.__code__.co_name == 'as_completed' — pure Python function in concurrent.futures._base; verified with Python 3.14.3"]
    - [as_comp_co_argcount,   as_completed.__code__.co_argcount.__eq__, [2],           true, "as_completed.__code__.co_argcount == 2 — fs and timeout are positional parameters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait and as_completed module, qualname, and cross-check — extra78
#
# wait.__module__ == 'concurrent.futures._base'
# as_completed.__module__ == 'concurrent.futures._base'
# wait.__qualname__ == 'wait'
# as_completed.__qualname__.__len__() == 12
# ---------------------------------------------------------------------------

table concurrent_futures_extra78.wait_and_as_completed_module_and_qualname:
  description: "concurrent.futures wait and as_completed module and qualname checks plus cross-check in cfextra78 namespace — wave 245 theme: wait/as_completed module + qualname; wait.__module__=='concurrent.futures._base' (defined in _base submodule, not top-level concurrent.futures); as_completed.__module__=='concurrent.futures._base'; wait.__qualname__=='wait'; as_completed.__qualname__.__len__()==12 (len('as_completed')==12); FIRST_COMPLETED.__len__()==15 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra78c

  columns: [id, function, args, expected, description]
  rows:
    - [wait_module,         wait.__module__.__eq__,                ["concurrent.futures._base"], true, "wait.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]
    - [as_comp_module,      as_completed.__module__.__eq__,        ["concurrent.futures._base"], true, "as_completed.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]
    - [wait_qualname,       wait.__qualname__.__eq__,              ["wait"],                     true, "wait.__qualname__ == 'wait' — simple top-level function qualname; verified with Python 3.14.3"]
    - [as_comp_qname_len,   as_completed.__qualname__.__len__,     [],                           12,   "as_completed.__qualname__.__len__() == 12 — len('as_completed') == 12; verified with Python 3.14.3"]
    - [fc_len_cross,        FIRST_COMPLETED.__len__,               [],                           15,   "FIRST_COMPLETED.__len__() == 15 — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra78
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra78.FIRST_COMPLETED_class_name:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') returns True — FIRST_COMPLETED is a plain string constant in concurrent.futures, not an enum value; NEW in extra78: first standalone __class__.__name__ invariant for FIRST_COMPLETED in cfextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra78.FIRST_COMPLETED_eq:
  description: "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') returns True — the constant value equals the string 'FIRST_COMPLETED'; NEW in extra78: first standalone equality invariant for FIRST_COMPLETED in cfextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra78.wait_co_argcount:
  description: "concurrent.futures.wait.__code__.co_argcount.__eq__(3) returns True — fs, timeout, and return_when are the three positional parameters; wait is a pure Python function in concurrent.futures._base; NEW in extra78: first standalone co_argcount invariant for wait in cfextra78 namespace; wave 245; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant concurrent_futures_extra78.ALL_COMPLETED_len:
  description: "concurrent.futures.ALL_COMPLETED.__len__() == 13 — len('ALL_COMPLETED') == 13; NEW in extra78: first standalone __len__ invariant for ALL_COMPLETED in cfextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ALL_COMPLETED.__len__
  args: []
  expected: 13

invariant concurrent_futures_extra78.as_completed_qualname:
  description: "concurrent.futures.as_completed.__qualname__.__eq__('as_completed') returns True — simple top-level function qualname; as_completed is a pure Python function in concurrent.futures._base; NEW in extra78: first standalone __qualname__ invariant for as_completed in cfextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: as_completed.__qualname__.__eq__
  args: ["as_completed"]
  expected: true
