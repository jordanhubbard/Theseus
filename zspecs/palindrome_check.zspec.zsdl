spec: palindrome_check
version: ">=1.0.1"
backend: node(palindrome-check)

docs: https://www.npmjs.com/package/palindrome-check

provenance:
  derived_from:
    - "palindrome-check README — https://www.npmjs.com/package/palindrome-check"
    - "Test vectors verified with palindrome-check via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "palindrome-check source"
  notes:
    - "palindrome-check is an npm package. Install: npm install palindrome-check"
    - "Returns true if the string is a palindrome."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table palindrome_check.check:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: palchk

  columns: [id, args, expected]
  rows:
    - [yes,    ["racecar"],  true]
    - [no,     ["hello"],    false]
    - [civic,  ["civic"],    true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:28:19Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
