spec: fast_json_stable_stringify
version: ">=2.0.0"
backend: node(fast-json-stable-stringify)

docs: https://github.com/nicolo-ribaudo/fast-json-stable-stringify#readme

provenance:
  derived_from:
    - "fast-json-stable-stringify README — https://github.com/nicolo-ribaudo/fast-json-stable-stringify#readme"
    - "Test vectors verified with fast-json-stable-stringify@2.1.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fast-json-stable-stringify source"
  notes:
    - "fast-json-stable-stringify exports the stringify function as module.exports."
    - "stringify(obj) serializes an object to JSON with keys sorted alphabetically."
    - "Sorting is deterministic: same input always produces same output."
    - "Array elements are not reordered — only object keys are sorted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a JSON string. No errors for plain object/array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fast_json_stable_stringify.stringify:
  kind: node_module_call_eq
  function: ~
  category: stringify
  id_prefix: fjss

  columns: [id, args, expected]
  rows:
    - [sorted_keys,    [{"b": 2, "a": 1}],              '{"a":1,"b":2}']
    - [already_sorted, [{"a": 1, "b": 2}],              '{"a":1,"b":2}']
    - [nested,         [{"z": 1, "a": {"y": 2, "x": 3}}], '{"a":{"x":3,"y":2},"z":1}']
    - [array,          [[3, 1, 2]],                     '[3,1,2]']
    - [empty_obj,      [{}],                            '{}']
    - [string_val,     [{"b": "foo", "a": "bar"}],      '{"a":"bar","b":"foo"}']

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:53:29Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
