spec: decimal_extra209
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra208.zspec.zsdl — covers decimal class __qualname__ attribute checks"
  notes:
    - "decimal.Decimal.__doc__ starts with \"Construct a new Decimal object. 'value' can be an integer, string, tuple\"; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__doc__ starts with 'The context affects almost all operations and controls rounding'; confirmed Python 3.14.3 macOS."
    - "decimal.DecimalException.__doc__ is None; no docstring on the C-implemented exception class; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__doc__ is None; no docstring on the C-implemented exception class; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__doc__.__contains__('arithmetic') == False; the word 'arithmetic' does not appear in Decimal's doc; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for decimal.Decimal class
# Decimal __doc__ string substring membership checks
# ---------------------------------------------------------------------------

table decimal_extra209.decimal_class_doc_contains:
  description: "decimal.Decimal __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldoccontains209

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_doc_contains_Decimal,   decimal.Decimal.__doc__.__contains__,  ["Decimal"],  true,  "decimal.Decimal.__doc__.__contains__('Decimal') == True; doc says 'Construct a new Decimal object'; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_integer,   decimal.Decimal.__doc__.__contains__,  ["integer"],  true,  "decimal.Decimal.__doc__.__contains__('integer') == True; doc says value can be an integer; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_string,    decimal.Decimal.__doc__.__contains__,  ["string"],   true,  "decimal.Decimal.__doc__.__contains__('string') == True; doc says value can be a string; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_tuple,     decimal.Decimal.__doc__.__contains__,  ["tuple"],    true,  "decimal.Decimal.__doc__.__contains__('tuple') == True; doc says value can be a tuple; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_value,     decimal.Decimal.__doc__.__contains__,  ["value"],    true,  "decimal.Decimal.__doc__.__contains__('value') == True; doc says 'value can be an integer'; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_Construct, decimal.Decimal.__doc__.__contains__,  ["Construct"], true, "decimal.Decimal.__doc__.__contains__('Construct') == True; doc starts with 'Construct a new Decimal object'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for decimal.Context class
# Context __doc__ string substring membership checks
# ---------------------------------------------------------------------------

table decimal_extra209.context_doc_contains:
  description: "decimal.Context __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldoccontains209

  columns: [id, function, args, expected, description]
  rows:
    - [context_doc_contains_context,    decimal.Context.__doc__.__contains__,  ["context"],     true,  "decimal.Context.__doc__.__contains__('context') == True; doc says 'A new context can be constructed'; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_Context,    decimal.Context.__doc__.__contains__,  ["Context"],     true,  "decimal.Context.__doc__.__contains__('Context') == True; doc mentions 'Context(prec=28)' in example; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_rounding,   decimal.Context.__doc__.__contains__,  ["rounding"],    true,  "decimal.Context.__doc__.__contains__('rounding') == True; doc says 'controls rounding'; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_operations, decimal.Context.__doc__.__contains__,  ["operations"],  true,  "decimal.Context.__doc__.__contains__('operations') == True; doc says 'affects almost all operations'; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_exceptions, decimal.Context.__doc__.__contains__,  ["exceptions"],  true,  "decimal.Context.__doc__.__contains__('exceptions') == True; doc mentions raising of exceptions; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_Over,       decimal.Context.__doc__.__contains__,  ["Over"],        true,  "decimal.Context.__doc__.__contains__('Over') == True; doc mentions 'Over/Underflow'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks — additional Decimal substrings
# Further Decimal doc membership checks for constructor keywords
# ---------------------------------------------------------------------------

table decimal_extra209.decimal_constructor_doc_contains:
  description: "decimal.Decimal __doc__ contains constructor-related substrings"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldoccontains209

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_doc_contains_Decimal2,        decimal.Decimal.__doc__.__contains__,  ["Decimal"],   true,   "decimal.Decimal.__doc__.__contains__('Decimal') == True; doc refers to Decimal object in constructor; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_rounding2,       decimal.Context.__doc__.__contains__,  ["rounding"],  true,   "decimal.Context.__doc__.__contains__('rounding') == True; Context doc describes rounding control; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_object,          decimal.Decimal.__doc__.__contains__,  ["object"],    true,   "decimal.Decimal.__doc__.__contains__('object') == True; doc says 'Construct a new Decimal object'; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_no_arithmetic,   decimal.Decimal.__doc__.__contains__,  ["arithmetic"], false, "decimal.Decimal.__doc__.__contains__('arithmetic') == False; the word 'arithmetic' does not appear in Decimal's doc text; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_no_precision,    decimal.Context.__doc__.__contains__,  ["precision"],  false, "decimal.Context.__doc__.__contains__('precision') == False; the word 'precision' does not appear in Context's doc (uses 'prec'); confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_no_precision,    decimal.Decimal.__doc__.__contains__,  ["precision"],  false, "decimal.Decimal.__doc__.__contains__('precision') == False; the word 'precision' does not appear in Decimal's constructor doc; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra209.decimal_doc_contains_Decimal:
  description: "decimal.Decimal.__doc__.__contains__('Decimal') == True — Decimal doc says 'Construct a new Decimal object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__contains__
  args: ["Decimal"]
  expected: true

invariant decimal_extra209.decimal_doc_contains_integer:
  description: "decimal.Decimal.__doc__.__contains__('integer') == True — Decimal doc says value can be an integer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__contains__
  args: ["integer"]
  expected: true

invariant decimal_extra209.decimal_doc_contains_tuple:
  description: "decimal.Decimal.__doc__.__contains__('tuple') == True — Decimal doc says value can be a tuple; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__contains__
  args: ["tuple"]
  expected: true

invariant decimal_extra209.context_doc_contains_rounding:
  description: "decimal.Context.__doc__.__contains__('rounding') == True — Context doc says 'controls rounding'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__doc__.__contains__
  args: ["rounding"]
  expected: true

invariant decimal_extra209.context_doc_contains_operations:
  description: "decimal.Context.__doc__.__contains__('operations') == True — Context doc says 'affects almost all operations'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__doc__.__contains__
  args: ["operations"]
  expected: true

invariant decimal_extra209.context_doc_contains_exceptions:
  description: "decimal.Context.__doc__.__contains__('exceptions') == True — Context doc mentions raising of exceptions; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__doc__.__contains__
  args: ["exceptions"]
  expected: true

invariant decimal_extra209.decimal_doc_no_arithmetic:
  description: "decimal.Decimal.__doc__.__contains__('arithmetic') == False — the word 'arithmetic' does not appear in Decimal's constructor doc; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__contains__
  args: ["arithmetic"]
  expected: false
