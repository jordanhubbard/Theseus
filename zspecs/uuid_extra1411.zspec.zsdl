spec: uuid_extra1411
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code: Lib/uuid.py"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ and __reduce_ex__ method type checks for uuid.UUID and uuid.SafeUUID."
    - "uuid.UUID.__sizeof__.__class__.__name__ == 'method_descriptor' — __sizeof__ is inherited from object/C layer; '__sizeof__' is NOT in uuid.UUID.__dict__."
    - "uuid.UUID.__reduce_ex__.__class__.__name__ == 'method_descriptor' — inherited; '__reduce_ex__' is NOT in uuid.UUID.__dict__."
    - "uuid.SafeUUID.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited; '__sizeof__' is NOT in uuid.SafeUUID.__dict__."
    - "uuid.SafeUUID.__reduce_ex__.__class__.__name__ == 'function' — SafeUUID is an IntEnum subclass; enum machinery defines a custom __reduce_ex__ as a plain function, but it is NOT stored directly in SafeUUID.__dict__ (it is in EnumType machinery)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1411.uuid_sizeof_type_checks:
  description: "uuid.UUID and uuid.SafeUUID __sizeof__ method type and dict-presence checks — __sizeof__ is a method_descriptor inherited from object and absent from both class __dict__s"
  kind: python_call_eq
  category: sizeof_checks
  id_prefix: uu1411sw
  columns: [id, function, args, expected]
  rows:
    - [uu1411sw001, uuid.UUID.__sizeof__.__class__.__name__.__eq__,          ["method_descriptor"], true]
    - [uu1411sw002, uuid.SafeUUID.__sizeof__.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [uu1411sw003, uuid.UUID.__dict__.__contains__,                          ["__sizeof__"],        false]
    - [uu1411sw004, uuid.SafeUUID.__dict__.__contains__,                      ["__sizeof__"],        false]
    - [uu1411sw005, uuid.UUID.__sizeof__.__class__.__name__.__class__.__name__.__eq__, ["str"],       true]
    - [uu1411sw006, uuid.SafeUUID.__sizeof__.__class__.__name__.__class__.__name__.__eq__, ["str"],   true]

table uuid_extra1411.uuid_reduce_ex_type_checks:
  description: "uuid.UUID and uuid.SafeUUID __reduce_ex__ method type and dict-presence checks — UUID inherits method_descriptor from object; SafeUUID yields a function via enum machinery but neither class stores __reduce_ex__ in its own __dict__"
  kind: python_call_eq
  category: reduce_ex_checks
  id_prefix: uu1411rx
  columns: [id, function, args, expected]
  rows:
    - [uu1411rx001, uuid.UUID.__reduce_ex__.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [uu1411rx002, uuid.SafeUUID.__reduce_ex__.__class__.__name__.__eq__,  ["function"],           true]
    - [uu1411rx003, uuid.UUID.__dict__.__contains__,                         ["__reduce_ex__"],      false]
    - [uu1411rx004, uuid.SafeUUID.__dict__.__contains__,                     ["__reduce_ex__"],      false]
    - [uu1411rx005, uuid.UUID.__reduce_ex__.__class__.__name__.__class__.__name__.__eq__, ["str"],   true]
    - [uu1411rx006, uuid.SafeUUID.__reduce_ex__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra1411.uuid_class_identity_checks:
  description: "uuid.UUID and uuid.SafeUUID class-level identity checks — UUID is a plain type, SafeUUID metaclass is EnumType; both report standard __name__ strings"
  kind: python_call_eq
  category: class_identity_checks
  id_prefix: uu1411ci
  columns: [id, function, args, expected]
  rows:
    - [uu1411ci001, uuid.UUID.__name__.__eq__,                   ["UUID"],      true]
    - [uu1411ci002, uuid.SafeUUID.__name__.__eq__,               ["SafeUUID"],  true]
    - [uu1411ci003, uuid.UUID.__class__.__name__.__eq__,         ["type"],      true]
    - [uu1411ci004, uuid.SafeUUID.__class__.__name__.__eq__,     ["EnumType"],  true]
    - [uu1411ci005, uuid.UUID.__module__.__eq__,                 ["uuid"],      true]
    - [uu1411ci006, uuid.SafeUUID.__module__.__eq__,             ["uuid"],      true]
