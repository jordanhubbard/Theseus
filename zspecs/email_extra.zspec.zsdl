spec: email_extra
version: ">=3.0"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/__init__.py"
    - "email_message.zspec.zsdl — covers email.message.Message and EmailMessage class behavior"
    - "email_mime.zspec.zsdl — covers email.mime subpackage classes"
    - "email_mime_extra.zspec.zsdl — covers additional email.mime subpackage classes"
    - "email_charset.zspec.zsdl — covers email.charset module"
    - "email_encoders.zspec.zsdl — covers email.encoders module"
    - "email_errors.zspec.zsdl — covers email.errors module"
    - "email_header.zspec.zsdl — covers email.header module"
    - "email_policy.zspec.zsdl — covers email.policy module"
    - "email_utils.zspec.zsdl — covers email.utils module"
  notes:
    - "The email top-level package exports four convenience functions: message_from_string, message_from_bytes, message_from_file, message_from_binary_file."
    - "All four return a Message (or subclass) object after parsing the input."
    - "message_from_string parses a string; message_from_bytes parses a bytes object."
    - "message_from_file and message_from_binary_file parse from file-like objects."
    - "email.__name__ == 'email' — the package's own __name__ attribute."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Package identity — email.__name__
# ---------------------------------------------------------------------------

invariant email_extra.package.name:
  description: "email.__name__ == 'email'"
  category: package
  kind: python_call_eq
  function: __name__.__eq__
  args: ["email"]
  expected: true

# ---------------------------------------------------------------------------
# Convenience function name checks
# ---------------------------------------------------------------------------

table email_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fnname

  columns: [id, function, args, expected]
  rows:
    - [message_from_string,      message_from_string.__name__.__eq__,      ["message_from_string"],      true]
    - [message_from_bytes,       message_from_bytes.__name__.__eq__,       ["message_from_bytes"],       true]
    - [message_from_file,        message_from_file.__name__.__eq__,        ["message_from_file"],        true]
    - [message_from_binary_file, message_from_binary_file.__name__.__eq__, ["message_from_binary_file"], true]

# ---------------------------------------------------------------------------
# message_from_string — basic parsing returns a Message-like object
#
# Parsing a minimal RFC 2822 message returns an object whose content type
# defaults to 'text/plain'.
# ---------------------------------------------------------------------------

invariant email_extra.message_from_string.content_type:
  description: "message_from_string('Subject: hi\\n\\nbody').get_content_type() == 'text/plain'"
  category: parsing
  kind: python_call_eq
  function: message_from_string
  args: ["Subject: hi\n\nbody"]
  method: get_content_type
  method_args: []
  expected: "text/plain"

invariant email_extra.message_from_string.subject_header:
  description: "message_from_string('Subject: hi\\n\\nbody')['Subject'] == 'hi'"
  category: parsing
  kind: python_call_eq
  function: message_from_string
  args: ["Subject: hi\n\nbody"]
  method: __getitem__
  method_args: ["Subject"]
  expected: "hi"

# ---------------------------------------------------------------------------
# message_from_bytes — parse from bytes input
# ---------------------------------------------------------------------------

invariant email_extra.message_from_bytes.content_type:
  description: "message_from_bytes(b'Subject: test\\n\\nbody').get_content_type() == 'text/plain'"
  category: parsing
  kind: python_call_eq
  function: message_from_bytes
  args: [!b64 "U3ViamVjdDogdGVzdAoKYm9keQ=="]
  method: get_content_type
  method_args: []
  expected: "text/plain"
