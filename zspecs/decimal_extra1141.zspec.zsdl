    - [dc1141wk002, decimal.Context.__weakref__.__class__.__name__.__eq__,          ["getset_descriptor"], true]
    - [dc1141wk003, decimal.DecimalException.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [dc1141wk004, decimal.Overflow.__weakref__.__class__.__name__.__eq__,         ["getset_descriptor"], true]
