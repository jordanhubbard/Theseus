spec: decimal_extra1141
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal/Context/DecimalException/Overflow __weakref__.__class__.__name__ and getcontext/setcontext/localcontext __qualname__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Decimal/__weakref__/__class__.__name__, decimal.Context/__weakref__/__class__.__name__, decimal.DecimalException/__weakref__/__class__.__name__, decimal.Overflow/__weakref__/__class__.__name__, decimal.getcontext/__qualname__, decimal.setcontext/__qualname__, decimal.localcontext/__qualname__; none of these were covered in _extra1111 or _extra1126"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1141.class_weakref_class_names:
