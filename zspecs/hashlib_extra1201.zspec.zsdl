spec: hashlib_extra1201
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.algorithms_guaranteed class name/qualname/module (set type identity), hashlib.algorithms_available class name/qualname/module, HASH instance hexdigest/update method class names and qualnames, and md5/sha256 hexdigest __class__.__module__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1201.algorithms_guaranteed_class_attrs:
  description: "hashlib.algorithms_guaranteed __class__.__name__/__qualname__/__module__ confirming it is a set"
  kind: python_call_eq
  category: algorithms_guaranteed_class_attrs
  id_prefix: hl1201ag
  columns: [id, function, args, expected]
  rows:
    - [hl1201ag001, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,              ["set"],      true]
    - [hl1201ag002, hashlib.algorithms_guaranteed.__class__.__qualname__.__eq__,          ["set"],      true]
    - [hl1201ag003, hashlib.algorithms_guaranteed.__class__.__module__.__eq__,            ["builtins"], true]
    - [hl1201ag004, hashlib.algorithms_available.__class__.__name__.__eq__,               ["set"],      true]
    - [hl1201ag005, hashlib.algorithms_available.__class__.__qualname__.__eq__,           ["set"],      true]
    - [hl1201ag006, hashlib.algorithms_available.__class__.__module__.__eq__,             ["builtins"], true]
    - [hl1201ag007, hashlib.algorithms_guaranteed.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [hl1201ag008, hashlib.algorithms_available.__contains__,                            ["md5"],      true]
    - [hl1201ag009, hashlib.algorithms_available.__contains__,                            ["sha256"],   true]

table hashlib_extra1201.hash_instance_method_class_names:
  description: "HASH instance hexdigest and update method __class__.__name__ and qualname for md5 and sha256"
  kind: python_call_eq
  category: hash_instance_method_class_names
  id_prefix: hl1201hm
  columns: [id, function, args, expected]
  rows:
    - [hl1201hm001, hashlib.md5().hexdigest.__class__.__name__.__eq__,               ["builtin_function_or_method"], true]
    - [hl1201hm002, hashlib.sha256().hexdigest.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [hl1201hm003, hashlib.md5().update.__class__.__name__.__eq__,                   ["builtin_function_or_method"], true]
    - [hl1201hm004, hashlib.sha256().update.__class__.__name__.__eq__,                ["builtin_function_or_method"], true]
    - [hl1201hm005, hashlib.md5().hexdigest.__qualname__.__eq__,                      ["HASH.hexdigest"],             true]
    - [hl1201hm006, hashlib.sha256().hexdigest.__qualname__.__eq__,                   ["HASH.hexdigest"],             true]
    - [hl1201hm007, hashlib.md5().update.__qualname__.__eq__,                         ["HASH.update"],                true]
    - [hl1201hm008, hashlib.md5().hexdigest.__class__.__module__.__eq__,              ["builtins"],                   true]
    - [hl1201hm009, hashlib.sha256().hexdigest.__class__.__module__.__eq__,           ["builtins"],                   true]
    - [hl1201hm010, hashlib.md5().hexdigest.__qualname__.__class__.__name__.__eq__,   ["str"],                        true]

table hashlib_extra1201.algorithms_guaranteed_len_and_membership:
  description: "hashlib.algorithms_guaranteed __len__ count and membership checks for sha1/sha224/sha384/md5"
  kind: python_call_eq
  category: algorithms_guaranteed_len_membership
  id_prefix: hl1201gl
  columns: [id, function, args, expected]
  rows:
    - [hl1201gl001, hashlib.algorithms_guaranteed.__len__,                            [],            14]
    - [hl1201gl002, hashlib.algorithms_guaranteed.__contains__,                       ["md5"],       true]
    - [hl1201gl003, hashlib.algorithms_guaranteed.__contains__,                       ["sha1"],      true]
    - [hl1201gl004, hashlib.algorithms_guaranteed.__contains__,                       ["sha224"],    true]
    - [hl1201gl005, hashlib.algorithms_guaranteed.__contains__,                       ["sha384"],    true]
    - [hl1201gl006, hashlib.algorithms_guaranteed.__contains__,                       ["sha512"],    true]
    - [hl1201gl007, hashlib.algorithms_guaranteed.__len__().__class__.__name__.__eq__, ["int"],      true]
    - [hl1201gl008, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,          ["set"],      true]
    - [hl1201gl009, hashlib.algorithms_available.__class__.__name__.__eq__,           ["set"],      true]
