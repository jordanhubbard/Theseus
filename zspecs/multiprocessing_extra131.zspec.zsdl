invariant multiprocessing_extra131.Pool_mro_len_2:
  description: "multiprocessing.pool.Pool.__mro__.__len__() == 2 — Pool's MRO is [Pool, object] (length=2); this minimal 2-element chain means Pool inherits directly from object with no abstract base class or mixin; contrast with multiprocessing.reduction.ForkingPickler (MRO len=3, inherits from Pickler) and multiprocessing.reduction.AbstractReducer (MRO len=2, also inherits from object); Pool is the primary worker pool class in multiprocessing, providing apply, map, starmap, imap, and async variants; Pool.__module__ is 'multiprocessing.pool'; NEW in extra131: first standalone Pool MRO length invariant in mppoolqn131 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra131.Pool_terminate_qualname_len_14:
  description: "multiprocessing.pool.Pool.terminate.__qualname__.__len__() == 14 — Pool.terminate.__qualname__ is 'Pool.terminate' (14 chars: 'Pool'=4 + '.'=1 + 'terminate'=9 = 14); among the single-word Pool methods this is the longest qualname: terminate=14 > apply=10 > close=10 > starmap=12 > imap=9 > join=9 > map=8; Pool.terminate immediately stops the worker processes without waiting for pending work to complete; terminate.__qualname__ length 14 equals Pool.map_async qualname length 14 (though via different word structure); Pool.__init__.__qualname__.__len__() is 13 (shorter by 1); NEW in extra131: first standalone Pool.terminate qualname length invariant in mppoolqn131 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.terminate.__qualname__.__len__
  args: []
  expected: 14

invariant multiprocessing_extra131.Pool_starmap_async_qualname_len_18:
  description: "multiprocessing.pool.Pool.starmap_async.__qualname__.__len__() == 18 — Pool.starmap_async.__qualname__ is 'Pool.starmap_async' (18 chars: 'Pool'=4 + '.'=1 + 'starmap_async'=13 = 18); this is the longest qualname among all Pool method qualnames: starmap_async=18 > apply_async=16 > map_async=14 > terminate=14 > starmap=12 > __init__=13 > close=10 > apply=10 > imap=9 > join=9 > map=8; starmap_async is the asynchronous version of starmap (which applies a function to each element of an iterable, unpacking arguments); Pool.__module__ is 'multiprocessing.pool'; Pool.__bases__[0].__name__ is 'object'; NEW in extra131: first standalone Pool.starmap_async qualname length invariant in mppoolqn131 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.starmap_async.__qualname__.__len__
  args: []
  expected: 18

invariant multiprocessing_extra131.pool_submodule_name_len_20:
  description: "multiprocessing.pool.__name__.__len__() == 20 — multiprocessing.pool.__name__ is 'multiprocessing.pool' (20 chars: 'multiprocessing'=15 + '.'=1 + 'pool'=4 = 20); this contrasts with the parent package multiprocessing.pool.__package__ which is 'multiprocessing' (15 chars); the submodule's own __name__ is the full dotted path while __package__ is just the parent; compare multiprocessing submodule name lengths: multiprocessing.pool=20 < multiprocessing.context=23 < multiprocessing.reduction=25; Pool.__module__ is also 'multiprocessing.pool' (same value as the submodule __name__); NEW in extra131: first standalone multiprocessing.pool submodule name length invariant in mppoolqn131 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.__name__.__len__
  args: []
  expected: 20

invariant multiprocessing_extra131.Pool_map_qualname_len_8:
  description: "multiprocessing.pool.Pool.map.__qualname__.__len__() == 8 — Pool.map.__qualname__ is 'Pool.map' (8 chars: 'Pool'=4 + '.'=1 + 'map'=3 = 8); this is the shortest Pool method qualname: map=8 < join=9 == imap=9 < apply=10 == close=10 < starmap=12 < __init__=13 == map_async=14 == terminate=14 < apply_async=16 < starmap_async=18; Pool.map applies a function to every item of an iterable and returns a list of results; Pool.map.__code__.co_argcount is 4 (self, func, iterable, chunksize=None); multiprocessing.pool.Pool.__mro__.__len__() is 2 ([Pool, object]); NEW in extra131: first standalone Pool.map qualname length invariant in mppoolqn131 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
