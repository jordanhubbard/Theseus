spec: dc3181
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (dc3181): __truediv__, __floordiv__, __mod__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "decimal.Decimal defines __truediv__, __floordiv__, and __mod__ in its own __dict__ (all true): it is a full IEEE 754 numeric type implementing the complete arithmetic protocol."
    - "decimal.Context does NOT define __truediv__, __floordiv__, or __mod__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — operator.contains(Cls.__dict__, '__truediv__')
#
# decimal.Decimal defines __truediv__ in its own __dict__ (true): full numeric type.
# All other decimal classes are false: Context is a configuration object;
# exception subclasses do not define arithmetic.
# ---------------------------------------------------------------------------

table dc3181.truediv:
  description: "decimal types __truediv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3181

  columns: [id, function, args, expected]
  rows:
    - ["dc3181001", operator.contains, [decimal.Decimal.__dict__,          "__truediv__"], true]
    - ["dc3181002", operator.contains, [decimal.Context.__dict__,           "__truediv__"], false]
    - ["dc3181003", operator.contains, [decimal.DecimalException.__dict__,  "__truediv__"], false]
    - ["dc3181004", operator.contains, [decimal.InvalidOperation.__dict__,  "__truediv__"], false]
    - ["dc3181005", operator.contains, [decimal.Overflow.__dict__,          "__truediv__"], false]
    - ["dc3181006", operator.contains, [decimal.Underflow.__dict__,         "__truediv__"], false]

