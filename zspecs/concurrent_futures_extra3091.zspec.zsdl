    - ["cf3091007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__eq__"], false]
    - ["cf3091008", operator.contains, [concurrent.futures.Executor.__dict__,            "__eq__"], false]

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# All 4 concurrent.futures classes return false for __bool__.
# No class defines custom boolean coercion; they always evaluate as truthy
# by inheriting the default from object.
# ---------------------------------------------------------------------------

