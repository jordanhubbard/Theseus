spec: cf3091
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (cf3091): __hash__, __eq__, __bool__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor, concurrent.futures.Executor."
    - "All 4 concurrent.futures classes return false for __hash__, __eq__, and __bool__ in their own __dict__."
    - "concurrent.futures.Future does not define __hash__ = None in its own __dict__ on Python 3.14 — it inherits identity-based hashing from object rather than explicitly suppressing it."
    - "concurrent.futures.Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor are concrete subclasses that add no custom hash/equality/bool."
    - "__bool__ is false for all 4 classes — executor and future objects always evaluate as truthy via the object default."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# All 4 concurrent.futures classes return false for __hash__.
# None define __hash__ in their own __dict__; they inherit identity-based
# hashing from object. concurrent.futures.Future in particular does not set
# __hash__ = None (unlike some other future-like objects), so it remains
# hashable by identity.
# ---------------------------------------------------------------------------

table cf3091.hash:
  description: "concurrent.futures types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3091

  columns: [id, function, args, expected]
  rows:
    - ["cf3091001", operator.contains, [concurrent.futures.Future.__dict__,              "__hash__"], false]
    - ["cf3091002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__hash__"], false]
    - ["cf3091003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__hash__"], false]
    - ["cf3091004", operator.contains, [concurrent.futures.Executor.__dict__,            "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# All 4 concurrent.futures classes return false for __eq__.
# None define custom equality; they rely on identity comparison inherited
# from object. Futures are identified by their object identity, not by value.
# ---------------------------------------------------------------------------

table cf3091.eq:
  description: "concurrent.futures types __eq__ dict-presence checks; wave 653"
  kind: python_call_eq
