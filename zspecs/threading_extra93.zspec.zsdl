spec: threading_extra93
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra92

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra92.zspec.zsdl."
    - "This spec covers: threading class __module__ equality — which classes are from 'threading' vs '_thread' (Wave 252)."
    - "threading.Thread.__module__ == 'threading' — Thread is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' — Semaphore is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__module__ == 'threading' — BoundedSemaphore is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' — Event is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading' — Condition is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — Timer is a pure-Python class (subclass of Thread) in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — Barrier is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' — RLock is a Python class in Lib/threading.py (wraps C _RLock from _thread). Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' — Lock is a C extension type from Modules/_threadmodule.c, exposed via threading. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — local is a C extension type from Modules/_threadmodule.c, exposed via threading. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Thread/Semaphore/BoundedSemaphore/Event __module__ == 'threading'
#
# Wave 252 theme: threading Python classes with __module__ == 'threading' — group 1.
#
# threading.Thread.__module__.__eq__('threading')           == True
# threading.Semaphore.__module__.__eq__('threading')        == True
# threading.BoundedSemaphore.__module__.__eq__('threading') == True
# threading.Event.__module__.__eq__('threading')            == True
#
# Four pure-Python classes defined in Lib/threading.py with __module__ == 'threading'.
# Prior spec extra92 checked __dict__ membership; this spec (extra93) checks __module__. New to extra93.
# ---------------------------------------------------------------------------

table threading_extra93.module_threading_group1:
  description: "Thread/Semaphore/BoundedSemaphore/Event __module__ == 'threading'; pure-Python classes in Lib/threading.py; wave 252; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsmodule93

  columns: [id, function, args, expected, description]
  rows:
    - [thread_module_eq_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is the primary threading class defined in Lib/threading.py; its __module__ attribute is set to 'threading' by the class definition in that module; str.__eq__('threading') returns True; prior spec extra92 checked Thread.__dict__ membership; this spec (extra93) checks __module__; new to extra93"]
    - [semaphore_module_eq_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is a pure-Python class defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra93"]
    - [bounded_semaphore_module_eq_threading,
       "BoundedSemaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is a pure-Python class defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra93"]
    - [event_module_eq_threading,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is a pure-Python class defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Table 2: Condition/Timer/Barrier/RLock __module__ == 'threading'
#
# Wave 252 theme: threading Python classes with __module__ == 'threading' — group 2.
#
# threading.Condition.__module__.__eq__('threading') == True
# threading.Timer.__module__.__eq__('threading')     == True
# threading.Barrier.__module__.__eq__('threading')   == True
# threading.RLock.__module__.__eq__('threading')     == True
#
# Four more classes: Condition/Timer/Barrier are defined in Lib/threading.py.
# RLock is also 'threading' — it is a Python class in Lib/threading.py wrapping the C _RLock. New to extra93.
# ---------------------------------------------------------------------------

table threading_extra93.module_threading_group2:
  description: "Condition/Timer/Barrier/RLock __module__ == 'threading'; pure-Python classes in Lib/threading.py; wave 252; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsmodule93

  columns: [id, function, args, expected, description]
  rows:
    - [condition_module_eq_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is a pure-Python class defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra93"]
    - [timer_module_eq_threading,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is a pure-Python class (subclass of Thread) defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra93"]
    - [barrier_module_eq_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is a pure-Python class defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra93"]
    - [rlock_module_eq_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is a Python class defined in Lib/threading.py; __module__ is 'threading'; this contrasts with Lock which comes from '_thread'; str.__eq__('threading') returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Table 3: Lock/local __module__ == '_thread'
#
# Wave 252 theme: threading-exposed C types with __module__ == '_thread'.
#
# threading.Lock.__module__.__eq__('_thread')  == True
# threading.local.__module__.__eq__('_thread') == True
#
# Lock and local are C extension types from Modules/_threadmodule.c (the '_thread' module).
# They are re-exported by threading but their __module__ remains '_thread'. New to extra93.
# ---------------------------------------------------------------------------

table threading_extra93.module_thread_c_types:
  description: "Lock and local __module__ == '_thread'; C extension types from _threadmodule.c re-exported by threading; wave 252; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsmodule93

  columns: [id, function, args, expected, description]
  rows:
    - [lock_module_eq_thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — Lock is a C extension type (lock_type) defined in Modules/_threadmodule.c; it is imported into threading as Lock but its __module__ attribute remains '_thread', the module where the C type is registered; str.__eq__('_thread') returns True; this distinguishes Lock from pure-Python threading classes like Semaphore; new to extra93"]
    - [local_module_eq_thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — local is a C extension type defined in Modules/_threadmodule.c for thread-local storage; it is imported into threading as local but __module__ remains '_thread'; str.__eq__('_thread') returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Table 4: Cross-checks — Lock and local are NOT from 'threading'
#
# Wave 252 theme: cross-check that C types from _thread do not report __module__ == 'threading'.
#
# threading.Lock.__module__.__eq__('threading')  == False
# threading.local.__module__.__eq__('threading') == False
#
# Negative checks confirm Lock and local differ from pure-Python threading classes. New to extra93.
# ---------------------------------------------------------------------------

table threading_extra93.module_cross_checks:
  description: "Lock and local __module__ != 'threading'; cross-checks confirm C types do not report the Python module name; wave 252; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsmodule93

  columns: [id, function, args, expected, description]
  rows:
    - [lock_module_ne_threading,
       "Lock.__module__.__eq__",
       ["threading"],
       false,
       "threading.Lock.__module__.__eq__('threading') == False — Lock is a C extension type from _threadmodule.c; its __module__ is '_thread' not 'threading'; str.__eq__('threading') returns False; this cross-check confirms that re-exporting a C type via threading does not change its __module__ attribute; new to extra93"]
    - [local_module_ne_threading,
       "local.__module__.__eq__",
       ["threading"],
       false,
       "threading.local.__module__.__eq__('threading') == False — local is a C extension type from _threadmodule.c; its __module__ is '_thread' not 'threading'; str.__eq__('threading') returns False; new to extra93"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra93
# ---------------------------------------------------------------------------

invariant threading_extra93.thread_module_eq_threading:
  description: "threading.Thread.__module__ == 'threading' — Thread is a pure-Python class defined in Lib/threading.py; wave 252; new to extra93"
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra93.lock_module_eq_thread:
  description: "threading.Lock.__module__ == '_thread' — Lock is a C extension type from _threadmodule.c; wave 252; new to extra93"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra93.local_module_eq_thread:
  description: "threading.local.__module__ == '_thread' — local is a C extension type from _threadmodule.c; wave 252; new to extra93"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra93.rlock_module_eq_threading:
  description: "threading.RLock.__module__ == 'threading' — RLock is a Python class in Lib/threading.py, unlike Lock which is C; wave 252; new to extra93"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra93.barrier_module_eq_threading:
  description: "threading.Barrier.__module__ == 'threading' — Barrier is a pure-Python class in Lib/threading.py; wave 252; new to extra93"
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true
