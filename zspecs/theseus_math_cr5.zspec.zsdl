spec: theseus_math_cr5
version: ">=3.9"
backend: python_cleanroom(theseus_math_cr5)
blocks: math

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html"
    - "https://en.wikipedia.org/wiki/Taylor_series"
  notes:
    - "Clean-room extended math utilities. Do NOT import math."
    - "comb(n, k): binomial coefficient n-choose-k."
    - "perm(n, k): number of k-permutations of n."
    - "isclose(a, b, rel_tol=1e-9, abs_tol=0.0): True if a and b are close."
    - "math5_comb(): comb(5, 2) == 10."
    - "math5_perm(): perm(5, 2) == 20."
    - "math5_isclose(): isclose(0.1 + 0.2, 0.3) == True (within default tolerance)."
    - "Zero-arg invariant signatures — def math5_comb(): return hardcoded_result"
    - "comb(n,k) = n! / (k! * (n-k)!) for 0 <= k <= n; comb(5,2) = 120/(2*6) = 10."
    - "perm(n,k) = n! / (n-k)! for 0 <= k <= n; perm(5,2) = 120/6 = 20."
    - "isclose: abs(a-b) <= max(rel_tol * max(abs(a), abs(b)), abs_tol)."
    - "Export: comb(n,k), perm(n,k=None), isclose(a,b,...), prod(iterable), dist(p,q)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_math_cr5.comb:
  description: "comb(5, 2) == 10"
  category: comb
  kind: python_call_eq
  function: math5_comb
  args: []
  expected: 10

invariant theseus_math_cr5.perm:
  description: "perm(5, 2) == 20"
  category: perm
  kind: python_call_eq
  function: math5_perm
  args: []
  expected: 20

invariant theseus_math_cr5.isclose:
  description: "isclose(0.1 + 0.2, 0.3) == True"
  category: isclose
  kind: python_call_eq
  function: math5_isclose
  args: []
  expected: true
