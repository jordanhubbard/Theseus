spec: graceful_fs
version: ">=4.0.0"
backend: node(graceful-fs)

docs: https://github.com/isaacs/node-graceful-fs#readme

provenance:
  derived_from:
    - "graceful-fs README — https://github.com/isaacs/node-graceful-fs#readme"
    - "Node.js fs API — https://nodejs.org/api/fs.html"
    - "Test vectors verified with graceful-fs via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "graceful-fs source"
  notes:
    - "Drop-in fs replacement — queues operations under EMFILE/ENFILE so heavy I/O doesn't fail with 'too many open files'."
    - "Install: npm install graceful-fs"
    - "v4 CJS; default export is fs-shaped object with the full Node fs API + .gracefulify() to monkey-patch globally."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Methods proxy to fs; never throw extra errors."
  stderr: "null"
  stickiness: "Internal queue persists across operations."
  codes: {}

invariant graceful_fs.has_readFile:
  description: ".readFile (async) is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "readFile.constructor.name"}
  expected: "Function"

