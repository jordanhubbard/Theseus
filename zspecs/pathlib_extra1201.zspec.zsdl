spec: pathlib_extra1201
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class __bases__.__len__ checks for PurePath, Path, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath; __mro__.__len__ checks for PurePath, Path, PurePosixPath, PureWindowsPath, PosixPath"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.PurePath.__bases__.__len__, pathlib.Path.__bases__.__len__, pathlib.PurePosixPath.__bases__.__len__, pathlib.PureWindowsPath.__bases__.__len__, pathlib.PosixPath.__bases__.__len__, pathlib.WindowsPath.__bases__.__len__; pathlib.PurePath.__mro__.__len__, pathlib.Path.__mro__.__len__, pathlib.PurePosixPath.__mro__.__len__, pathlib.PureWindowsPath.__mro__.__len__, pathlib.PosixPath.__mro__.__len__; none of these __bases__.__len__ or __mro__.__len__ value checks were covered in _extra1171 or _extra1186"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1201.bases_len_pure_path_family:
  description: "pathlib pure path class __bases__.__len__ checks — PurePath from object (1); PurePosixPath, PureWindowsPath each from PurePath (1)"
  kind: python_call_eq
  category: bases_len_pure_path_family
  id_prefix: pl1201pp
  columns: [id, function, args, expected]
  rows:
    - [pl1201pp001, pathlib.PurePath.__bases__.__len__,        [], 1]
    - [pl1201pp002, pathlib.PurePosixPath.__bases__.__len__,   [], 1]
    - [pl1201pp003, pathlib.PureWindowsPath.__bases__.__len__, [], 1]
    - [pl1201pp004, pathlib.Path.__bases__.__len__,            [], 1]
    - [pl1201pp005, pathlib.PurePath.__bases__.__len__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [pl1201pp006, pathlib.PurePosixPath.__bases__.__len__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [pl1201pp007, pathlib.PureWindowsPath.__bases__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [pl1201pp008, pathlib.PurePath.__bases__.__len__.__class__.__name__.__eq__,        ["function"], false]

