spec: lcm
version: ">=0.0.3"
backend: node(lcm)

docs: https://www.npmjs.com/package/lcm

provenance:
  derived_from:
    - "lcm README — https://www.npmjs.com/package/lcm"
    - "Test vectors verified with lcm via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lcm source"
  notes:
    - "lcm is an npm package. Install: npm install lcm"
    - "Returns the least common multiple of two integers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lcm.lcm:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: lcm

  columns: [id, args, expected]
  rows:
    - [four_six,   [4, 6],   12]
    - [three_five, [3, 5],   15]
    - [same,       [6, 6],   6]

