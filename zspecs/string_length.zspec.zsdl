spec: string_length
version: ">=7.0.1"
backend: node(string-length)

docs: https://www.npmjs.com/package/string-length

provenance:
  derived_from:
    - "string-length README — https://www.npmjs.com/package/string-length"
    - "Test vectors verified with string-length via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "string-length source"
  notes:
    - "string-length is an npm package. Install: npm install string-length"
    - "Returns the length of a string in characters (not bytes), correctly handling Unicode."
    - "ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_length.stringLength:
  kind: node_module_call_eq
  function: "default"
  category: string
  id_prefix: strlen

  columns: [id, args, expected]
  rows:
    - [hello,   ["hello"],  5]
    - [abc,     ["abc"],    3]
    - [empty,   [""],       0]
