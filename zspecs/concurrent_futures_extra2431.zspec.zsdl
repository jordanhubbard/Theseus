  rows:
    - ["cf2431005", concurrent.futures.Executor.__dict__.__contains__, ["__aiter__"], false]
    - ["cf2431006", concurrent.futures.Executor.__dict__.__contains__, ["__anext__"], false]
    - ["cf2431007", concurrent.futures.Executor.__dict__.__contains__, ["__iter__"],  false]
    - ["cf2431008", concurrent.futures.Executor.__dict__.__contains__, ["__next__"],  false]

# ---------------------------------------------------------------------------
# Table 3: ThreadPoolExecutor — no async or sync iteration protocol
