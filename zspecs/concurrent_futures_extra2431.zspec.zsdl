spec: concurrent_futures_extra2431
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures: Launching parallel tasks"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for concurrent.futures classes."
    - "concurrent.futures is a synchronous thread/process pool library with NO async iteration protocol."
    - "Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor: none define __aiter__ or __anext__."
    - "These classes are sync-only; asyncio.Future is the async counterpart, not concurrent.futures.Future."
    - "concurrent.futures.Future.__iter__ is also absent — it is not yield-from compatible either."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future — no async or sync iteration protocol
#
# concurrent.futures.Future is a sync future; no __aiter__, __anext__, __iter__
# This contrasts with asyncio.Future which defines __iter__ for yield-from
# ---------------------------------------------------------------------------

table concurrent_futures_extra2431.Future_async_iter_protocol:
  description: "concurrent.futures.Future __aiter__ and __anext__ dict-presence checks — concurrent.futures.Future is a synchronous future with no iteration protocol of any kind; it differs from asyncio.Future which defines __iter__ for yield-from"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: cf2431

  columns: [id, function, args, expected]
  rows:
    - ["cf2431001", concurrent.futures.Future.__dict__.__contains__, ["__aiter__"], false]
    - ["cf2431002", concurrent.futures.Future.__dict__.__contains__, ["__anext__"], false]
    - ["cf2431003", concurrent.futures.Future.__dict__.__contains__, ["__iter__"],  false]
    - ["cf2431004", concurrent.futures.Future.__dict__.__contains__, ["__next__"],  false]

# ---------------------------------------------------------------------------
# Table 2: Executor — no async or sync iteration protocol
#
# Executor is the abstract base class; no __aiter__, __anext__, __iter__
# ---------------------------------------------------------------------------

table concurrent_futures_extra2431.Executor_async_iter_protocol:
  description: "concurrent.futures.Executor __aiter__ and __anext__ dict-presence checks — Executor is the abstract base class for thread and process pool executors; it defines no iteration protocol of any kind"
