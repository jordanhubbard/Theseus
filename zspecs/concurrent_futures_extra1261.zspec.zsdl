spec: concurrent_futures_extra1261
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures.__all__ membership checks via __contains__; __all__ type verification"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 531 (_extra1261): __all__ membership checks — concurrent.futures.__all__ is a list; verified Python 3.14.3."
    - "concurrent.futures.__all__ contains: ALL_COMPLETED, BrokenExecutor, CancelledError, Executor, FIRST_COMPLETED, FIRST_EXCEPTION, Future, InterpreterPoolExecutor, InvalidStateError, ProcessPoolExecutor, ThreadPoolExecutor, TimeoutError, as_completed, wait; verified Python 3.14.3."
    - "Thread, Process, Queue, Lock, run, sleep, gather are NOT in concurrent.futures.__all__; verified Python 3.14.3."
    - "Distinct from prior waves: extra1246 (__doc__ class checks), extra1231 (__dict__.__contains__), extra1216 (__mro__.__len__), extra1201 (__bases__/__mro__ lengths)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1261.all_contains_in:
  description: "concurrent.futures.__all__.__contains__ returns true for names IN __all__: Future, Executor, wait, as_completed, FIRST_COMPLETED, ALL_COMPLETED, FIRST_EXCEPTION, CancelledError, TimeoutError, BrokenExecutor, ThreadPoolExecutor, ProcessPoolExecutor"
  kind: python_call_eq
  category: all_membership
  id_prefix: cf1261in
  columns: [id, function, args, expected]
  rows:
    - [cf1261in001, concurrent.futures.__all__.__contains__, ["Future"],               true]
    - [cf1261in002, concurrent.futures.__all__.__contains__, ["Executor"],             true]
    - [cf1261in003, concurrent.futures.__all__.__contains__, ["wait"],                 true]
    - [cf1261in004, concurrent.futures.__all__.__contains__, ["as_completed"],         true]
    - [cf1261in005, concurrent.futures.__all__.__contains__, ["FIRST_COMPLETED"],      true]
    - [cf1261in006, concurrent.futures.__all__.__contains__, ["ALL_COMPLETED"],        true]
    - [cf1261in007, concurrent.futures.__all__.__contains__, ["FIRST_EXCEPTION"],      true]
    - [cf1261in008, concurrent.futures.__all__.__contains__, ["CancelledError"],       true]
    - [cf1261in009, concurrent.futures.__all__.__contains__, ["TimeoutError"],         true]
    - [cf1261in010, concurrent.futures.__all__.__contains__, ["BrokenExecutor"],       true]
    - [cf1261in011, concurrent.futures.__all__.__contains__, ["ThreadPoolExecutor"],   true]
    - [cf1261in012, concurrent.futures.__all__.__contains__, ["ProcessPoolExecutor"],  true]
    - [cf1261in013, concurrent.futures.__all__.__contains__, ["InvalidStateError"],    true]

table concurrent_futures_extra1261.all_contains_not_in:
  description: "concurrent.futures.__all__.__contains__ returns false for names NOT in __all__: Thread, Process, Queue, Lock, run, sleep, gather"
  kind: python_call_eq
  category: all_membership
  id_prefix: cf1261ni
  columns: [id, function, args, expected]
  rows:
    - [cf1261ni001, concurrent.futures.__all__.__contains__, ["Thread"],  false]
    - [cf1261ni002, concurrent.futures.__all__.__contains__, ["Process"], false]
    - [cf1261ni003, concurrent.futures.__all__.__contains__, ["Queue"],   false]
    - [cf1261ni004, concurrent.futures.__all__.__contains__, ["Lock"],    false]
    - [cf1261ni005, concurrent.futures.__all__.__contains__, ["run"],     false]
    - [cf1261ni006, concurrent.futures.__all__.__contains__, ["sleep"],   false]
    - [cf1261ni007, concurrent.futures.__all__.__contains__, ["gather"],  false]

table concurrent_futures_extra1261.all_type_is_list:
  description: "concurrent.futures.__all__.__class__.__name__ is 'list' — concurrent.futures uses a list for __all__; cross-checks against 'tuple', 'set', 'dict'"
  kind: python_call_eq
  category: all_type
  id_prefix: cf1261ty
  columns: [id, function, args, expected]
  rows:
    - [cf1261ty001, concurrent.futures.__all__.__class__.__name__.__eq__, ["list"],  true]
    - [cf1261ty002, concurrent.futures.__all__.__class__.__name__.__eq__, ["tuple"], false]
    - [cf1261ty003, concurrent.futures.__all__.__class__.__name__.__eq__, ["set"],   false]
    - [cf1261ty004, concurrent.futures.__all__.__class__.__name__.__eq__, ["dict"],  false]
    - [cf1261ty005, concurrent.futures.__all__.__class__.__name__.__eq__, ["str"],   false]
    - [cf1261ty006, concurrent.futures.__all__.__class__.__name__.__eq__, ["int"],   false]
