spec: inspect_extra237
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.isclass/isfunction/isbuiltin with builtin types contracts."
    - "inspect.isclass.__name__ == 'isclass' (len=7) — the function name. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect' (len=7) — isclass is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isclass(int) == True — int is a builtin class. Verified with Python 3.14.3."
    - "inspect.isclass(str) == True — str is a builtin class. Verified with Python 3.14.3."
    - "inspect.isclass(list) == True — list is a builtin class. Verified with Python 3.14.3."
    - "inspect.isclass(type) == True — type is a builtin metaclass. Verified with Python 3.14.3."
    - "inspect.isfunction(len) == False — len is a builtin function, not a user-defined function. Verified with Python 3.14.3."
    - "inspect.isbuiltin(len) == True — len is a builtin function. Verified with Python 3.14.3."
    - "inspect.isbuiltin(print) == True — print is a builtin function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isclass function identity contracts
#
# inspect.isclass.__name__ == 'isclass' (len=7)
# inspect.isclass.__module__ == 'inspect' (len=7)
# inspect.isclass.__qualname__ == 'isclass' (len=7)
# inspect.isclass.__class__.__name__ == 'function'
# inspect.isclass.__doc__.__contains__('class') == True
#
# isclass is a Python function in Lib/inspect.py. New to extra237.
# ---------------------------------------------------------------------------

table inspect_extra237.isclass_function_identity:
  description: "inspect.isclass function identity: name, module, qualname, class, doc; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra237isclassid

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a Python function in Lib/inspect.py that checks if an object is a class; __name__ is 'isclass' (len=7); new to extra237"]
    - [isclass_name_len_7,
       isclass.__name__.__len__,
       [],
       7,
       "inspect.isclass.__name__.__len__() == 7 — 'isclass' has exactly 7 characters (i-s-c-l-a-s-s); str.__len__() returns 7; new to extra237"]
    - [isclass_module_eq,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra237"]
    - [isclass_qualname_eq,
       isclass.__qualname__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__qualname__.__eq__('isclass') == True — isclass is a top-level function with unqualified qualname 'isclass'; new to extra237"]
    - [isclass_class_is_function,
       isclass.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isclass.__class__.__name__.__eq__('function') == True — isclass is a Python function; its __class__ is the built-in function type; new to extra237"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isfunction and isbuiltin function identity contracts
#
# inspect.isfunction.__name__ == 'isfunction' (len=10)
# inspect.isfunction.__module__ == 'inspect' (len=7)
# inspect.isbuiltin.__name__ == 'isbuiltin' (len=9)
# inspect.isbuiltin.__module__ == 'inspect' (len=7)
# inspect.isfunction.__class__.__name__ == 'function'
#
# isfunction and isbuiltin are Python functions in Lib/inspect.py. New to extra237.
# ---------------------------------------------------------------------------

table inspect_extra237.isfunction_isbuiltin_identity:
  description: "inspect.isfunction and isbuiltin function identity: name, module, class; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra237isfuncisbltid

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — isfunction is a Python function in Lib/inspect.py that checks for user-defined functions; __name__ is 'isfunction' (len=10); new to extra237"]
    - [isfunction_name_len_10,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has exactly 10 characters (i-s-f-u-n-c-t-i-o-n); str.__len__() returns 10; new to extra237"]
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — isbuiltin is a Python function in Lib/inspect.py that checks for C-implemented functions; __name__ is 'isbuiltin' (len=9); new to extra237"]
    - [isbuiltin_name_len_9,
       isbuiltin.__name__.__len__,
       [],
       9,
       "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has exactly 9 characters (i-s-b-u-i-l-t-i-n); str.__len__() returns 9; new to extra237"]
    - [isfunction_class_is_function,
       isfunction.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isfunction.__class__.__name__.__eq__('function') == True — isfunction is a Python function; its __class__ is the built-in function type; new to extra237"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isclass/isfunction/isbuiltin behavioral contracts with builtins
#
# inspect.isclass(int) == True
# inspect.isclass(str) == True
# inspect.isclass(list) == True
# inspect.isclass(type) == True
# inspect.isclass(object) == True
#
# isclass returns True for all builtin types/classes. New to extra237.
# ---------------------------------------------------------------------------

table inspect_extra237.isclass_module_and_builtin_identity:
  description: "inspect.isclass module identity and isbuiltin/isfunction module contracts; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra237isclassmodid

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_module_len_7,
       isclass.__module__.__len__,
       [],
       7,
       "inspect.isclass.__module__.__len__() == 7 — 'inspect' has exactly 7 characters (i-n-s-p-e-c-t); str.__len__() returns 7; new to extra237"]
    - [isfunction_module_eq,
       isfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra237"]
    - [isbuiltin_module_eq,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra237"]
    - [isclass_doc_contains_class,
       isclass.__doc__.__contains__,
       ["class"],
       true,
       "inspect.isclass.__doc__.__contains__('class') == True — docstring describes checking whether an object is a class; str.__contains__('class') returns True; new to extra237"]
    - [isbuiltin_doc_contains_builtin,
       isbuiltin.__doc__.__contains__,
       ["built-in"],
       true,
       "inspect.isbuiltin.__doc__.__contains__('built-in') == True — docstring describes checking for built-in function or method; str.__contains__('built-in') returns True; new to extra237"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra237
# ---------------------------------------------------------------------------

invariant inspect_extra237.isclass_name_eq:
  description: "inspect.isclass.__name__ == 'isclass' (len=7); new to extra237"
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra237.isclass_name_len_7:
  description: "inspect.isclass.__name__.__len__() == 7 — 'isclass' has 7 characters; new to extra237"
  kind: python_call_eq
  function: isclass.__name__.__len__
  args: []
  expected: 7

invariant inspect_extra237.isclass_module_eq:
  description: "inspect.isclass.__module__ == 'inspect'; new to extra237"
  kind: python_call_eq
  function: isclass.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra237.isclass_module_len_7:
  description: "inspect.isclass.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra237"
  kind: python_call_eq
  function: isclass.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra237.isclass_qualname_eq:
  description: "inspect.isclass.__qualname__ == 'isclass'; new to extra237"
  kind: python_call_eq
  function: isclass.__qualname__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra237.isclass_class_is_function:
  description: "inspect.isclass.__class__.__name__ == 'function'; new to extra237"
  kind: python_call_eq
  function: isclass.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra237.isfunction_name_eq:
  description: "inspect.isfunction.__name__ == 'isfunction' (len=10); new to extra237"
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra237.isfunction_name_len_10:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra237"
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra237.isfunction_module_eq:
  description: "inspect.isfunction.__module__ == 'inspect'; new to extra237"
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra237.isbuiltin_name_eq:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' (len=9); new to extra237"
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra237.isbuiltin_name_len_9:
  description: "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has 9 characters; new to extra237"
  kind: python_call_eq
  function: isbuiltin.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra237.isbuiltin_module_eq:
  description: "inspect.isbuiltin.__module__ == 'inspect'; new to extra237"
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra237.isclass_doc_contains_class:
  description: "inspect.isclass.__doc__.__contains__('class') == True; new to extra237"
  kind: python_call_eq
  function: isclass.__doc__.__contains__
  args: ["class"]
  expected: true

invariant inspect_extra237.isbuiltin_doc_contains_builtin:
  description: "inspect.isbuiltin.__doc__.__contains__('built-in') == True; new to extra237"
  kind: python_call_eq
  function: isbuiltin.__doc__.__contains__
  args: ["built-in"]
  expected: true
