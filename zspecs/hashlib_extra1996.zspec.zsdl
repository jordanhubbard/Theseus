spec: hashlib_extra1996
version: ">=3.9"
backend: python_module(_hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "_hashlib.HASH is not a numeric type; it defines no integer or floating-point conversion protocols."
    - "hashlib.blake2b and hashlib.blake2s are real type objects; they are also non-numeric."
    - "All five numeric dunder methods are absent from all three hashlib hash type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra1996.hash_index_protocol:
  description: "_hashlib.HASH __index__ dict-presence checks (HASH is not an integer type)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1996

  columns: [id, function, args, expected]
  rows:
    - ["hl1996001", "_hashlib.HASH.__dict__.__contains__", ["__index__"], false]
    - ["hl1996002", "_hashlib.HASH.__dict__.__contains__", ["__complex__"], false]
    - ["hl1996003", "_hashlib.HASH.__dict__.__contains__", ["__float__"], false]
    - ["hl1996004", "_hashlib.HASH.__dict__.__contains__", ["__round__"], false]
    - ["hl1996005", "_hashlib.HASH.__dict__.__contains__", ["__abs__"], false]

table hashlib_extra1996.blake2b_numeric_protocol:
  description: "hashlib.blake2b numeric conversion protocol absence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1996
  backend: python_module(hashlib)

  columns: [id, function, args, expected]
  rows:
    - ["hl1996006", "hashlib.blake2b.__dict__.__contains__", ["__index__"], false]
    - ["hl1996007", "hashlib.blake2b.__dict__.__contains__", ["__complex__"], false]
    - ["hl1996008", "hashlib.blake2b.__dict__.__contains__", ["__float__"], false]
    - ["hl1996009", "hashlib.blake2b.__dict__.__contains__", ["__round__"], false]
    - ["hl1996010", "hashlib.blake2b.__dict__.__contains__", ["__abs__"], false]

