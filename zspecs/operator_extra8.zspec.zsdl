spec: operator_extra8
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra7.zspec.zsdl."
    - "operator.zspec covers: __name__ for core arithmetic, bitwise, comparison, and sequence operators."
    - "operator_extra3 covers: __module__ for add/sub/mul/truediv/eq/ne/lt/le/gt/ge/and_/or_/xor/not_/inv/neg/pos/abs/floordiv/mod/pow."
    - "operator_extra6 covers: __module__ for iadd/isub/imul/itruediv/iand/ior/ixor/ifloordiv/imod/ilshift/irshift/truth/is_/is_not/concat/length_hint/index/pos; __module__ for attrgetter/itemgetter/methodcaller."
    - "operator_extra7 covers: imatmul/__module__, ipow/__module__."
    - "NOT yet covered: add/__module__ as a standalone invariant (extra3 used a table row)."
    - "NOT yet covered: sub/__module__ as a standalone invariant."
    - "NOT yet covered: mul/__module__ as a standalone invariant."
    - "NOT yet covered: truediv/__module__ as a standalone invariant."
    - "NOT yet covered: floordiv/__module__ as a standalone invariant."
    - "NOT yet covered: mod/__module__ as a standalone invariant."
    - "NOT yet covered: pow/__module__ as a standalone invariant."
    - "NOT yet covered: neg/__module__ as a standalone invariant."
    - "NOT yet covered: pos/__module__ as a standalone invariant."
    - "NOT yet covered: abs/__module__ as a standalone invariant."
    - "NOT yet covered: eq/__module__ as a standalone invariant."
    - "NOT yet covered: ne/__module__ as a standalone invariant."
    - "NOT yet covered: lt/__module__ as a standalone invariant."
    - "All operator functions that wrap C builtins in _operator report __module__ == '_operator'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ == '_operator' — core arithmetic operators, invariant style
#
# operator_extra3 covers these via table rows. This spec provides the same
# __module__ == '_operator' assertions expressed as individual invariants
# using the function: X.__module__.__eq__ pattern, a distinct expression axis.
# All these functions are implemented as C builtins in _operator.
# ---------------------------------------------------------------------------

invariant operator_extra8.add.module:
  description: "operator.add.__module__ == '_operator' — add is a C builtin from _operator"
  category: module_checks
  kind: python_call_eq
  function: add.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra8.sub.module:
  description: "operator.sub.__module__ == '_operator' — sub is a C builtin from _operator"
  category: module_checks
  kind: python_call_eq
  function: sub.__module__.__eq__
  args: ["_operator"]
  expected: true

