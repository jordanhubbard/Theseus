spec: asyncio_extra1831
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "asyncio stdlib documentation"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/tasks.py"
  not_derived_from:
    - "third-party asyncio extensions"
  notes:
    - "Future defines __await__ and __iter__ for yield-from compatibility"
    - "Task inherits __await__ and __iter__ from Future, so they are absent from Task.__dict__"
    - "None of the asyncio classes are descriptors (no __get__/__set__)"
  created_at: "2026-04-12"

table asyncio_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["as1831-dp-001", "asyncio.Future.__dict__.__contains__", ["__get__"], false]
    - ["as1831-dp-002", "asyncio.Future.__dict__.__contains__", ["__set__"], false]
    - ["as1831-dp-003", "asyncio.Task.__dict__.__contains__", ["__get__"], false]
    - ["as1831-dp-004", "asyncio.Queue.__dict__.__contains__", ["__get__"], false]
    - ["as1831-dp-005", "asyncio.Lock.__dict__.__contains__", ["__get__"], false]
    - ["as1831-dp-006", "asyncio.Event.__dict__.__contains__", ["__get__"], false]
    - ["as1831-dp-007", "asyncio.Semaphore.__dict__.__contains__", ["__get__"], false]
    - ["as1831-dp-008", "asyncio.Condition.__dict__.__contains__", ["__get__"], false]

table asyncio_extra1831.callable_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["as1831-cp-001", "asyncio.Future.__dict__.__contains__", ["__call__"], false]
    - ["as1831-cp-002", "asyncio.Task.__dict__.__contains__", ["__call__"], false]
    - ["as1831-cp-003", "asyncio.Queue.__dict__.__contains__", ["__call__"], false]
    - ["as1831-cp-004", "asyncio.Lock.__dict__.__contains__", ["__call__"], false]
    - ["as1831-cp-005", "asyncio.Future.__dict__.__contains__", ["__await__"], true]
    - ["as1831-cp-006", "asyncio.Task.__dict__.__contains__", ["__await__"], false]
    - ["as1831-cp-007", "asyncio.Future.__dict__.__contains__", ["__iter__"], true]
    - ["as1831-cp-008", "asyncio.Task.__dict__.__contains__", ["__iter__"], false]

table asyncio_extra1831.asyncio_module_functions:
  columns: [id, function, args, expected]
  rows:
    - ["as1831-mf-001", "asyncio.__dict__.__contains__", ["run"], true]
    - ["as1831-mf-002", "asyncio.__dict__.__contains__", ["create_task"], true]
    - ["as1831-mf-003", "asyncio.__dict__.__contains__", ["sleep"], true]
    - ["as1831-mf-004", "asyncio.__dict__.__contains__", ["gather"], true]
    - ["as1831-mf-005", "asyncio.__dict__.__contains__", ["wait"], true]
    - ["as1831-mf-006", "asyncio.__dict__.__contains__", ["wait_for"], true]
    - ["as1831-mf-007", "asyncio.__dict__.__contains__", ["shield"], true]
    - ["as1831-mf-008", "asyncio.__dict__.__contains__", ["ensure_future"], true]
    - ["as1831-mf-009", "asyncio.__dict__.__contains__", ["get_event_loop"], true]
    - ["as1831-mf-010", "asyncio.__dict__.__contains__", ["new_event_loop"], true]
