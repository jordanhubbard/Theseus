spec: multiprocessing_extra64
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_consts, co_nlocals, and co_stacksize documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra63.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55), mp.__all__.__contains__ membership checks (extra56), mp.__package__.__eq__('multiprocessing') (extra56), Queue/Pool __doc__.__class__.__name__.__eq__('str') (extra56), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra57), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra58), Process method __qualname__ string equality for start/run/join/terminate/kill/is_alive/close/interrupt (extra59), Process.__init__/__annotations__/__globals__ class identity + current_process __annotations__ class identity and len (extra60), Process.__init__/__defaults__/__code__/__class__.__name__ checks, current_process/__defaults__/__code__/__class__.__name__ checks (extra61), Process.__init__/Process.start/current_process __code__.co_name equality and co_argcount values (extra62), Process.__init__/Process.start/current_process co_varnames/co_filename/co_flags attribute chains (extra63)."
    - "This spec covers (mpcode4_64 namespace): wave 232 theme — __code__.co_consts, co_nlocals, co_stacksize attribute chains, plus Process class __doc__ content checks. NEW in extra64: Process.__init__.__code__.co_consts.__class__.__name__=='tuple' — co_consts is always a tuple; Process.start.__code__.co_consts.__class__.__name__=='tuple'; current_process.__code__.co_consts.__class__.__name__=='tuple'; all three functions co_nlocals.__class__.__name__=='int'; all three functions co_stacksize.__class__.__name__=='int'; Process.__doc__.__class__.__name__=='str'; Process.__doc__.__contains__('process')==True."
    - "multiprocessing.Process.__init__.__code__.co_consts.__class__.__name__ == 'tuple'. co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_nlocals.__class__.__name__ == 'int'. co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_stacksize.__class__.__name__ == 'int'. co_stacksize is the required stack size (the maximum number of stack entries needed during execution), stored as a plain Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__doc__.__contains__('process') == True. Process.__doc__ is a non-empty string; the docstring mentions 'process' (lowercase) describing the process abstraction. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_consts.__class__.__name__ checks — extra64
#
# Wave 232 theme: co_consts type identity.
#
# co_consts is always a tuple of constants (literals, nested code objects,
# None, etc.) used by the code object.
# tuple.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table multiprocessing_extra64.co_consts_class_name:
  description: "multiprocessing __code__.co_consts.__class__.__name__.__eq__('tuple') checks in mpcode4_64 namespace — wave 232 theme: co_consts type identity; co_consts is always a tuple on all code objects; Process.__init__/Process.start/current_process all have co_consts.__class__.__name__=='tuple'; NEW in extra64: no prior mp spec has checked __code__.co_consts.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode4_64

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_consts_class,    Process.__init__.__code__.co_consts.__class__.__name__.__eq__,    ["tuple"], true, "Process.__init__.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object; Process.__init__.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first co_consts.__class__.__name__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_consts_class,   Process.start.__code__.co_consts.__class__.__name__.__eq__,       ["tuple"], true, "Process.start.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple; Process.start.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first co_consts.__class__.__name__ check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_consts_class, current_process.__code__.co_consts.__class__.__name__.__eq__,     ["tuple"], true, "current_process.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple; current_process.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first co_consts.__class__.__name__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_nlocals.__class__.__name__ checks — extra64
#
# Wave 232 theme: co_nlocals type identity.
#
# co_nlocals is the count of local variables (including parameters) used by
# the function. It is always a plain Python int.
# int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table multiprocessing_extra64.co_nlocals_class_name:
  description: "multiprocessing __code__.co_nlocals.__class__.__name__.__eq__('int') checks in mpcode4_64 namespace — wave 232 theme: co_nlocals type identity; co_nlocals is the count of local variables (including parameters); Process.__init__/Process.start/current_process all have co_nlocals.__class__.__name__=='int'; NEW in extra64: no prior mp spec has checked __code__.co_nlocals.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode4_64a

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_nlocals_class,    Process.__init__.__code__.co_nlocals.__class__.__name__.__eq__,    ["int"], true, "Process.__init__.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int; Process.__init__.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra64: first co_nlocals.__class__.__name__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_nlocals_class,   Process.start.__code__.co_nlocals.__class__.__name__.__eq__,       ["int"], true, "Process.start.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is always an int; Process.start.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra64: first co_nlocals.__class__.__name__ check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_nlocals_class, current_process.__code__.co_nlocals.__class__.__name__.__eq__,     ["int"], true, "current_process.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is always an int; current_process.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra64: first co_nlocals.__class__.__name__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_stacksize.__class__.__name__ checks — extra64
#
# Wave 232 theme: co_stacksize type identity.
#
# co_stacksize is the required stack size (the maximum number of stack
# entries needed during execution). It is always a plain Python int.
# int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table multiprocessing_extra64.co_stacksize_class_name:
  description: "multiprocessing __code__.co_stacksize.__class__.__name__.__eq__('int') checks in mpcode4_64 namespace — wave 232 theme: co_stacksize type identity; co_stacksize is the required stack size for code execution; Process.__init__/Process.start/current_process all have co_stacksize.__class__.__name__=='int'; NEW in extra64: no prior mp spec has checked __code__.co_stacksize.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode4_64b

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_stacksize_class,    Process.__init__.__code__.co_stacksize.__class__.__name__.__eq__,    ["int"], true, "Process.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack size (maximum number of stack entries needed during execution), stored as a plain Python int; Process.__init__.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra64: first co_stacksize.__class__.__name__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_stacksize_class,   Process.start.__code__.co_stacksize.__class__.__name__.__eq__,       ["int"], true, "Process.start.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is always an int; Process.start.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra64: first co_stacksize.__class__.__name__ check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_stacksize_class, current_process.__code__.co_stacksize.__class__.__name__.__eq__,     ["int"], true, "current_process.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is always an int; current_process.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra64: first co_stacksize.__class__.__name__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process class __doc__ content checks — extra64
#
# Wave 232 theme: class docstring type and content.
#
# multiprocessing.Process has a non-empty docstring. The docstring text
# mentions 'process' (lowercase) describing the process abstraction.
# ---------------------------------------------------------------------------

table multiprocessing_extra64.Process_doc:
  description: "multiprocessing Process __doc__.__class__.__name__ and __doc__.__contains__ checks in mpcode4_64 namespace — wave 232 theme: class docstring type and content; Process.__doc__ is a str containing 'process'; NEW in extra64: these specific __doc__ content checks have not appeared in prior mp code-attribute specs; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode4_64c

  columns: [id, function, args, expected, description]
  rows:
    - [process_doc_class,    Process.__doc__.__class__.__name__.__eq__, ["str"],     true, "Process.__doc__.__class__.__name__ == 'str' — Process has a docstring; the docstring is a plain Python str; str.__class__.__name__ is 'str'; NEW in extra64: first __doc__.__class__.__name__ check for Process in mpcode4_64 namespace; verified with Python 3.14.3"]
    - [process_doc_contains, Process.__doc__.__contains__,              ["process"], true, "Process.__doc__.__contains__('process') == True — Process.__doc__ is a non-empty string describing the multiprocessing Process class; the docstring mentions 'process' (lowercase) in its text; __contains__('process') returns True; NEW in extra64: first __doc__.__contains__ check for Process in mpcode4_64 namespace; verified with Python 3.14.3"]

