invariant multiprocessing_extra64.Process_init_co_consts_tuple:
  description: "multiprocessing.Process.__init__.__code__.co_consts.__class__.__name__.__eq__('tuple') returns True — co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object; Process.__init__.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: no prior mp spec has checked Process.__init__.__code__.co_consts.__class__.__name__ via __eq__; wave 232 first co_consts type identity invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

