spec: functools_extra75
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra74.zspec.zsdl."
    - "Wave 236 theme: functools module spec/loader identity, WRAPPER_ASSIGNMENTS extended membership, and reduce.__doc__ 'iterable' content."
    - "functools.__name__ == 'functools' — every module has a __name__ attribute equal to its fully-qualified module name. Verified with Python 3.14.3."
    - "functools.__spec__.name == 'functools' — ModuleSpec.name is the fully-qualified name used by the import system. Verified with Python 3.14.3."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — functools is a pure-Python module (Lib/functools.py), so its loader is importlib._bootstrap_external.SourceFileLoader. Verified with Python 3.14.3."
    - "functools.__file__.__contains__('functools') == True — the file path for the functools source ends with 'functools.py', so the string 'functools' appears in it. Verified with Python 3.14.3."
    - "functools.__file__.__contains__('.py') == True — functools is a .py source file, so its __file__ path ends with '.py'. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == True — '__annotations__' is the fourth element of WRAPPER_ASSIGNMENTS; update_wrapper copies __annotations__ from the wrapped function to the wrapper. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element of WRAPPER_ASSIGNMENTS; update_wrapper copies __qualname__ so that the wrapper reports the correct qualified name. Verified with Python 3.14.3."
    - "reduce.__doc__.__contains__('iterable') == True — reduce applies a function cumulatively to the items of an iterable; the word 'iterable' appears in the docstring. Verified with Python 3.14.3."
    - "Prior functools_extra74 covered WRAPPER_ASSIGNMENTS.__contains__ for '__name__', '__doc__', and '__module__'. This spec covers '__annotations__' and '__qualname__' which are novel. reduce.__doc__.__contains__('function') was covered in extra71; 'iterable' is novel. Module spec/loader checks (__name__, __spec__, __loader__, __file__) are novel in the functoolsmod75 id_prefix namespace. All checks in this spec are new to extra75."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools module spec identity — extra75
#
# Wave 236 theme: functools module __name__, __spec__, and __loader__ checks.
#
# Every Python module has a __name__ equal to its fully-qualified name and a
# __spec__ attribute of type importlib.machinery.ModuleSpec. Pure-Python
# modules loaded from a .py source file use a SourceFileLoader as their
# loader, which is accessible via __loader__.
#
# functools.__name__                         == 'functools'
# functools.__spec__.name                    == 'functools'
# functools.__spec__.__class__.__name__      == 'ModuleSpec'
# functools.__loader__.__class__.__name__    == 'SourceFileLoader'
#
# No prior functools spec checks these module-spec attributes via the
# functoolsmod75 id_prefix. New to extra75.
# ---------------------------------------------------------------------------

table functools_extra75.functools_module_spec:
  description: "functools module spec identity: __name__=='functools', __spec__.name=='functools', __spec__.__class__.__name__=='ModuleSpec', __loader__.__class__.__name__=='SourceFileLoader'; wave 236 module spec identity; new to extra75"
  kind: python_call_eq
  category: module_identity
  id_prefix: functoolsmod75

  columns: [id, function, args, expected, description]
  rows:
    - [functools_name_eq_functools,
       __name__.__eq__,
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — every Python module has a __name__ attribute equal to its fully-qualified module name as registered in sys.modules; for the top-level functools module this is simply 'functools' (8 chars) with no package prefix; str.__eq__('functools') returns True; no prior functools spec checks __name__.__eq__ via the functoolsmod75 id_prefix; new to extra75"]
    - [functools_spec_name_eq_functools,
       __spec__.name.__eq__,
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — __spec__ is an importlib.machinery.ModuleSpec object that carries the metadata the import system uses to find and load the module; ModuleSpec.name is the fully-qualified module name 'functools' (8 chars); __eq__ returns True; no prior functools spec checks __spec__.name via the functoolsmod75 id_prefix; new to extra75"]
    - [functools_spec_class_name_eq_ModuleSpec,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the __spec__ attribute of every importable module is an instance of importlib.machinery.ModuleSpec; ModuleSpec.__name__ == 'ModuleSpec' (10 chars); __eq__ returns True; no prior functools spec checks __spec__.__class__.__name__ via the functoolsmod75 id_prefix; new to extra75"]
    - [functools_loader_class_name_eq_SourceFileLoader,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — functools is a pure-Python module stored in Lib/functools.py; the import system uses importlib._bootstrap_external.SourceFileLoader to read and compile the source; SourceFileLoader.__name__ == 'SourceFileLoader' (16 chars); __eq__ returns True; no prior functools spec checks __loader__.__class__.__name__ via the functoolsmod75 id_prefix; new to extra75"]

# ---------------------------------------------------------------------------
# functools.__file__ path content — extra75
#
# Wave 236 theme: functools.__file__ path contains 'functools' and '.py'.
#
# functools is a pure-Python module; its __file__ attribute is the absolute
# path to Lib/functools.py (or its .pyc cache in some deployments, but the
# canonical path contains 'functools'). Both substrings are always present.
#
# functools.__file__.__contains__('functools') == True
# functools.__file__.__contains__('.py')       == True
#
# No prior functools spec checks __file__ content via functoolsmod75. New to extra75.
# ---------------------------------------------------------------------------

table functools_extra75.functools_file:
  description: "functools.__file__ path contains 'functools' and '.py'; wave 236 module file path checks; new to extra75"
  kind: python_call_eq
  category: module_identity
  id_prefix: functoolsmod75

  columns: [id, function, args, expected, description]
  rows:
    - [functools_file_contains_functools,
       __file__.__contains__,
       ["functools"],
       true,
       "functools.__file__.__contains__('functools') == True — functools.__file__ is the absolute filesystem path to the functools source file (e.g., '/usr/lib/python3.x/functools.py'); the filename component 'functools' appears in that path; str.__contains__('functools') returns True; no prior functools spec checks __file__.__contains__('functools') via the functoolsmod75 id_prefix; new to extra75"]
    - [functools_file_contains_py,
       __file__.__contains__,
       [".py"],
       true,
       "functools.__file__.__contains__('.py') == True — functools is a pure-Python source module; its __file__ path ends with '.py' (the source) or contains '.py' before the cache extension; str.__contains__('.py') returns True; no prior functools spec checks __file__.__contains__('.py') via the functoolsmod75 id_prefix; new to extra75"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS extended membership — extra75
#
# Wave 236 theme: novel membership checks for WRAPPER_ASSIGNMENTS.
#
# functools.WRAPPER_ASSIGNMENTS is a 5-element tuple:
#   ('__module__', '__name__', '__qualname__', '__annotations__', '__doc__')
#
# extra74 covered '__name__', '__doc__', and '__module__'. This spec adds the
# remaining two: '__qualname__' and '__annotations__'.
#
# WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__qualname__')    == True
#
# No prior functools spec checks these two elements. New to extra75.
# ---------------------------------------------------------------------------

table functools_extra75.WRAPPER_ASSIGNMENTS_extended:
  description: "WRAPPER_ASSIGNMENTS contains '__annotations__' and '__qualname__' — novel items not covered by extra74; wave 236 WRAPPER_ASSIGNMENTS membership; new to extra75"
  kind: python_call_eq
  category: constant_identity
  id_prefix: functoolsmod75

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_contains_annotations,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__annotations__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == True — '__annotations__' is the fourth element of the WRAPPER_ASSIGNMENTS tuple ('__module__', '__name__', '__qualname__', '__annotations__', '__doc__'); update_wrapper copies __annotations__ from the wrapped function to the wrapper so that type checkers and runtime introspection tools see the correct parameter/return annotations; tuple.__contains__('__annotations__') returns True; prior extra74 covered '__name__', '__doc__', '__module__' but not '__annotations__'; new to extra75"]
    - [WRAPPER_ASSIGNMENTS_contains_qualname,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element of the WRAPPER_ASSIGNMENTS tuple; update_wrapper copies __qualname__ from the wrapped function to the wrapper so that the wrapper reports the correct fully-qualified name in tracebacks and repr output; tuple.__contains__('__qualname__') returns True; prior extra74 covered '__name__', '__doc__', '__module__' but not '__qualname__'; new to extra75"]

# ---------------------------------------------------------------------------
# reduce.__doc__ extended content — extra75
#
# Wave 236 theme: novel keyword in reduce docstring.
#
# functools.reduce (C builtin from _functools) applies a function of two
# arguments cumulatively to the items of an iterable, reducing it to a single
# value. The docstring describes this with the word 'iterable'.
#
# reduce.__doc__.__contains__('function') was already covered in extra71.
# reduce.__doc__.__contains__('iterable') is novel.
#
# No prior functools spec checks reduce.__doc__.__contains__('iterable'). New to extra75.
# ---------------------------------------------------------------------------

table functools_extra75.reduce_doc_extended:
  description: "reduce.__doc__.__contains__('iterable') == True — docstring mentions the iterable argument; wave 236 reduce doc extended; new to extra75"
  kind: python_call_eq
  category: reduce_doc
  id_prefix: functoolsmod75

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_contains_iterable,
       reduce.__doc__.__contains__,
       ["iterable"],
       true,
       "functools.reduce.__doc__.__contains__('iterable') == True — reduce is implemented in C (_functools) and applies a two-argument function cumulatively to the items of an iterable, reducing the sequence to a single value; the word 'iterable' appears in the C docstring that describes the second argument; str.__contains__('iterable') returns True; extra71 covered 'function' in reduce.__doc__ but not 'iterable'; new to extra75"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra75
# ---------------------------------------------------------------------------

invariant functools_extra75.functools_name_functools:
  description: "functools.__name__.__eq__('functools') == True — module __name__ equals its registered fully-qualified name; wave 236 module spec identity; new to extra75"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra75.functools_spec_ModuleSpec:
  description: "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every importable module's __spec__ is an importlib.machinery.ModuleSpec; wave 236 module spec identity; new to extra75"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant functools_extra75.functools_loader_SourceFileLoader:
  description: "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — functools is a pure-Python .py module loaded by SourceFileLoader; wave 236 module loader identity; new to extra75"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant functools_extra75.WRAPPER_ASSIGNMENTS_annotations:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == True — '__annotations__' is the fourth element of the WRAPPER_ASSIGNMENTS tuple; wave 236 WRAPPER_ASSIGNMENTS membership; new to extra75"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__annotations__"]
  expected: true

invariant functools_extra75.reduce_doc_iterable:
  description: "functools.reduce.__doc__.__contains__('iterable') == True — 'iterable' appears in the reduce C docstring; wave 236 reduce doc extended; new to extra75"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["iterable"]
  expected: true
