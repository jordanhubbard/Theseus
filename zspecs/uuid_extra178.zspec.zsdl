spec: uuid_extra178
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.UUID.__init__.__name__ == '__init__' — len=8; pure Python method in Lib/uuid.py."
    - "uuid.UUID.__init__.__module__ == 'uuid' — defined in the uuid Python module."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' — len=13."
    - "uuid.UUID.__init__.__code__.co_argcount == 7 — self + hex, bytes, bytes_le, fields, int, version (is_safe is keyword-only)."
    - "uuid.UUID.__str__.__name__ == '__str__' — len=7."
    - "uuid.UUID.__repr__.__name__ == '__repr__' — len=8."
    - "uuid.UUID.__eq__.__name__ == '__eq__' — len=6."
    - "uuid.UUID.__hash__.__name__ == '__hash__' — len=8."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID.__init__ name, module, and qualname identity
#
# uuid.UUID.__init__.__name__     == '__init__'      (len=8)
# uuid.UUID.__init__.__module__   == 'uuid'
# uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (len=13)
#
# UUID.__init__ is a pure Python method; its module is 'uuid' and its
# qualname is the dotted class.method form.
# ---------------------------------------------------------------------------

table uuid_extra178.uuid_init_name_identity:
  description: "uuid.UUID.__init__ name, module, and qualname identity; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinit178

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,
       uuid.UUID.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "uuid.UUID.__init__.__name__.__eq__('__init__') == True — method is named '__init__'; len=8; new to extra178"]
    - [init_name_len,
       uuid.UUID.__init__.__name__.__len__,
       [],
       8,
       "uuid.UUID.__init__.__name__.__len__() == 8 — '__init__' has 8 characters; new to extra178"]
    - [init_module_eq,
       uuid.UUID.__init__.__module__.__eq__,
       ["uuid"],
       true,
       "uuid.UUID.__init__.__module__.__eq__('uuid') == True — defined in the uuid Python module; new to extra178"]
    - [init_qualname_eq,
       uuid.UUID.__init__.__qualname__.__eq__,
       ["UUID.__init__"],
       true,
       "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') == True — qualified name is 'UUID.__init__'; len=13; new to extra178"]
    - [init_qualname_len,
       uuid.UUID.__init__.__qualname__.__len__,
       [],
       13,
       "uuid.UUID.__init__.__qualname__.__len__() == 13 — 'UUID.__init__' has 13 characters; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID.__init__ code attributes
#
# uuid.UUID.__init__.__code__.co_argcount == 7
#
# co_argcount counts positional-or-keyword arguments only (excludes keyword-only).
# Signature: (self, hex=None, bytes=None, bytes_le=None, fields=None, int=None, version=None, *, is_safe=...)
# self, hex, bytes, bytes_le, fields, int, version = 7 positional-or-keyword args.
# is_safe is keyword-only and not counted.
# ---------------------------------------------------------------------------

table uuid_extra178.uuid_init_code_attrs:
  description: "uuid.UUID.__init__ code object attributes; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinit178

  columns: [id, function, args, expected, description]
  rows:
    - [init_argcount,
       uuid.UUID.__init__.__code__.co_argcount.__eq__,
       [7],
       true,
       "uuid.UUID.__init__.__code__.co_argcount.__eq__(7) == True — 7 positional-or-keyword args: self + hex, bytes, bytes_le, fields, int, version; new to extra178"]
    - [init_name_from_code,
       uuid.UUID.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "uuid.UUID.__init__.__code__.co_name.__eq__('__init__') == True — code object name matches method name; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID dunder method names — __str__, __repr__, __eq__, __hash__
#
# uuid.UUID.__str__.__name__   == '__str__'   (len=7)
# uuid.UUID.__repr__.__name__  == '__repr__'  (len=8)
# uuid.UUID.__eq__.__name__    == '__eq__'    (len=6)
# uuid.UUID.__hash__.__name__  == '__hash__'  (len=8)
#
# All are pure Python methods defined in Lib/uuid.py.
# ---------------------------------------------------------------------------

table uuid_extra178.uuid_dunder_method_names:
  description: "uuid.UUID dunder method name identity for __str__, __repr__, __eq__, __hash__; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinit178

  columns: [id, function, args, expected, description]
  rows:
    - [str_name_eq,
       uuid.UUID.__str__.__name__.__eq__,
       ["__str__"],
       true,
       "uuid.UUID.__str__.__name__.__eq__('__str__') == True — method is named '__str__'; len=7; new to extra178"]
    - [str_name_len,
       uuid.UUID.__str__.__name__.__len__,
       [],
       7,
       "uuid.UUID.__str__.__name__.__len__() == 7 — '__str__' has 7 characters; new to extra178"]
    - [repr_name_eq,
       uuid.UUID.__repr__.__name__.__eq__,
       ["__repr__"],
       true,
       "uuid.UUID.__repr__.__name__.__eq__('__repr__') == True — method is named '__repr__'; len=8; new to extra178"]
    - [eq_name_eq,
       uuid.UUID.__eq__.__name__.__eq__,
       ["__eq__"],
       true,
       "uuid.UUID.__eq__.__name__.__eq__('__eq__') == True — method is named '__eq__'; len=6; new to extra178"]
    - [hash_name_eq,
       uuid.UUID.__hash__.__name__.__eq__,
       ["__hash__"],
       true,
       "uuid.UUID.__hash__.__name__.__eq__('__hash__') == True — method is named '__hash__'; len=8; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant uuid_extra178.init_name_is_init:
  description: "uuid.UUID.__init__.__name__ == '__init__' — method identity; len=8; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant uuid_extra178.init_module_is_uuid:
  description: "uuid.UUID.__init__.__module__ == 'uuid' — defined in the uuid Python module; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__init__.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra178.init_qualname_is_uuid_init:
  description: "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' — qualified name; len=13; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

invariant uuid_extra178.init_argcount_is_7:
  description: "uuid.UUID.__init__.__code__.co_argcount == 7 — self plus six optional positional-or-keyword parameters; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true

invariant uuid_extra178.str_name_is_str:
  description: "uuid.UUID.__str__.__name__ == '__str__' — method identity; len=7; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true

invariant uuid_extra178.repr_name_is_repr:
  description: "uuid.UUID.__repr__.__name__ == '__repr__' — method identity; len=8; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true

invariant uuid_extra178.eq_name_is_eq:
  description: "uuid.UUID.__eq__.__name__ == '__eq__' — method identity; len=6; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__eq__.__name__.__eq__
  args: ["__eq__"]
  expected: true

invariant uuid_extra178.hash_name_is_hash:
  description: "uuid.UUID.__hash__.__name__ == '__hash__' — method identity; len=8; new to extra178"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__hash__.__name__.__eq__
  args: ["__hash__"]
  expected: true
