  notes:
    - "concurrent.futures.Future.result.__qualname__ == 'Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); returns the value set by set_result()."
    - "concurrent.futures.Future.exception.__qualname__ == 'Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16); returns the exception set by set_exception()."
    - "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13); attempts to cancel the Future."
    - "concurrent.futures.Future.cancelled.__qualname__ == 'Future.cancelled' (len=16: 'Future'=6+'.'=1+'cancelled'=9=16); returns True if the Future was cancelled."
    - "concurrent.futures.Future.running.__qualname__ == 'Future.running' (len=14: 'Future'=6+'.'=1+'running'=7=14); returns True if the Future is currently executing."
    - "concurrent.futures.Future.done.__qualname__ == 'Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11); returns True if the Future is done."
    - "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24: 'Future'=6+'.'=1+'add_done_callback'=17=24); registers a callback to be called when the Future completes."
    - "Length ordering: done (11) < result (13) == cancel (13) < running (14) < exception (16) == cancelled (16) < add_done_callback (24)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

