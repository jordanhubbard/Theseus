invariant concurrent_futures_extra194.cf_Future_result_qualname_eq:
  description: "concurrent.futures.Future.result.__qualname__.__eq__('Future.result') returns True — Future.result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); result(timeout=None) blocks until the future completes, then returns its value; if the future was cancelled it raises CancelledError; if an exception was raised during computation it is re-raised; Future.result.__qualname__ (13) == Future.cancel.__qualname__ (13) — result and cancel are both 6-char method names; Future.result.__qualname__ (13) > Future.done.__qualname__ (11) by 2; NEW in cffuturemethods194: first standalone result.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods_result_exception_cancel
  kind: python_call_eq
  function: concurrent.futures.Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra194.cf_Future_exception_qualname_eq:
  description: "concurrent.futures.Future.exception.__qualname__.__eq__('Future.exception') returns True — Future.exception.__qualname__=='Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16); exception(timeout=None) returns the exception raised by the call, or None if the call completed without raising; Future.exception.__qualname__ (16) == Future.cancelled.__qualname__ (16) — exception and cancelled both have 9-char method names giving the same qualname length; Future.exception.__qualname__ (16) < Future.add_done_callback.__qualname__ (24) by 8; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods_result_exception_cancel
  kind: python_call_eq
  function: concurrent.futures.Future.exception.__qualname__.__eq__
  args: ["Future.exception"]
  expected: true

invariant concurrent_futures_extra194.cf_Future_cancel_qualname_eq:
