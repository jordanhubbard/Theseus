spec: asyncio_extra267
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutine/task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "asyncio.run.__module__ == 'asyncio.runners' (defined in runners submodule, not tasks)."
    - "asyncio.create_task, sleep, gather, wait, wait_for, shield all have __module__ == 'asyncio.tasks'."
    - "All seven coroutine/task functions are plain Python functions; __class__.__name__ == 'function'."
    - "All __qualname__ values are the simple function name (no class prefix) — top-level module functions."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — table
#
# Seven asyncio coroutine/task functions: run, create_task, sleep, gather,
# wait, wait_for, shield. All are plain functions accessible directly on
# the asyncio namespace.
# ---------------------------------------------------------------------------

table asyncio_extra267.function_names:
  description: "asyncio coroutine/task functions report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected, description]
  rows:
    - [run,         run.__name__.__eq__,         ["run"],         true, "asyncio.run.__name__ == 'run'"]
    - [create_task, create_task.__name__.__eq__,  ["create_task"], true, "asyncio.create_task.__name__ == 'create_task'"]
    - [sleep,       sleep.__name__.__eq__,        ["sleep"],       true, "asyncio.sleep.__name__ == 'sleep'"]
    - [gather,      gather.__name__.__eq__,       ["gather"],      true, "asyncio.gather.__name__ == 'gather'"]
    - [wait,        wait.__name__.__eq__,         ["wait"],        true, "asyncio.wait.__name__ == 'wait'"]
    - [wait_for,    wait_for.__name__.__eq__,     ["wait_for"],    true, "asyncio.wait_for.__name__ == 'wait_for'"]
    - [shield,      shield.__name__.__eq__,       ["shield"],      true, "asyncio.shield.__name__ == 'shield'"]

# ---------------------------------------------------------------------------
# Function __module__ — table
#
# asyncio.run lives in asyncio.runners; the remaining six live in asyncio.tasks.
# ---------------------------------------------------------------------------

table asyncio_extra267.function_modules:
  description: "asyncio coroutine/task functions report the expected __module__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected, description]
  rows:
    - [run,         run.__module__.__eq__,         ["asyncio.runners"], true, "asyncio.run.__module__ == 'asyncio.runners'"]
    - [create_task, create_task.__module__.__eq__,  ["asyncio.tasks"],  true, "asyncio.create_task.__module__ == 'asyncio.tasks'"]
    - [sleep,       sleep.__module__.__eq__,        ["asyncio.tasks"],  true, "asyncio.sleep.__module__ == 'asyncio.tasks'"]
    - [gather,      gather.__module__.__eq__,       ["asyncio.tasks"],  true, "asyncio.gather.__module__ == 'asyncio.tasks'"]
    - [wait,        wait.__module__.__eq__,         ["asyncio.tasks"],  true, "asyncio.wait.__module__ == 'asyncio.tasks'"]
    - [wait_for,    wait_for.__module__.__eq__,     ["asyncio.tasks"],  true, "asyncio.wait_for.__module__ == 'asyncio.tasks'"]
    - [shield,      shield.__module__.__eq__,       ["asyncio.tasks"],  true, "asyncio.shield.__module__ == 'asyncio.tasks'"]

# ---------------------------------------------------------------------------
# Function __qualname__ — standalone invariants
#
# All seven functions have simple (unqualified) __qualname__ values equal
# to the function name — they are top-level module functions, not nested.
# ---------------------------------------------------------------------------

invariant asyncio_extra267.run.qualname:
  description: "asyncio.run.__qualname__ == 'run'"
  category: identity
  kind: python_call_eq
  function: run.__qualname__.__eq__
  args: ["run"]
  expected: true

invariant asyncio_extra267.create_task.qualname:
  description: "asyncio.create_task.__qualname__ == 'create_task'"
  category: identity
  kind: python_call_eq
  function: create_task.__qualname__.__eq__
  args: ["create_task"]
  expected: true

invariant asyncio_extra267.gather.qualname:
  description: "asyncio.gather.__qualname__ == 'gather'"
  category: identity
  kind: python_call_eq
  function: gather.__qualname__.__eq__
  args: ["gather"]
  expected: true

invariant asyncio_extra267.wait.qualname:
  description: "asyncio.wait.__qualname__ == 'wait'"
  category: identity
  kind: python_call_eq
  function: wait.__qualname__.__eq__
  args: ["wait"]
  expected: true

invariant asyncio_extra267.wait_for.qualname:
  description: "asyncio.wait_for.__qualname__ == 'wait_for'"
  category: identity
  kind: python_call_eq
  function: wait_for.__qualname__.__eq__
  args: ["wait_for"]
  expected: true

invariant asyncio_extra267.shield.qualname:
  description: "asyncio.shield.__qualname__ == 'shield'"
  category: identity
  kind: python_call_eq
  function: shield.__qualname__.__eq__
  args: ["shield"]
  expected: true

# ---------------------------------------------------------------------------
# Function __class__.__name__ — standalone invariant
#
# All seven functions are plain Python functions; their __class__.__name__
# is 'function'.
# ---------------------------------------------------------------------------

invariant asyncio_extra267.run.class_name:
  description: "asyncio.run.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: run.__class__.__name__.__eq__
  args: ["function"]
  expected: true
