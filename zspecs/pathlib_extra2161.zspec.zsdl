spec: pathlib_extra2161
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Theme: descriptor protocol dict-presence — checks for __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__ in class __dict__."
    - "pathlib.Path does not define any descriptor protocol methods (__get__, __set__, __delete__, fget, etc.) in its own __dict__."
    - "pathlib.PurePath does not define __get__, __set__, __delete__, fget, fset, fdel, __objclass__, or __func__ in its own __dict__."
    - "pathlib.PurePath does define property objects for drive, root, anchor, name, stem, suffix, suffixes, parent, and parents. These property instances have fget set (non-None) but fset and fdel are None — however fget/fset/fdel are attributes of the property *instance*, not keys in PurePath.__dict__."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath contain only 'parser' in their public __dict__ and do not define any descriptor protocol keys."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path — descriptor protocol dict-presence
# ---------------------------------------------------------------------------

table pathlib_extra2161.Path_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
    - ["pl2161001", "pathlib.Path.__dict__.__contains__", ["__get__"], false]
    - ["pl2161002", "pathlib.Path.__dict__.__contains__", ["__set__"], false]
    - ["pl2161003", "pathlib.Path.__dict__.__contains__", ["__delete__"], false]
    - ["pl2161004", "pathlib.Path.__dict__.__contains__", ["__set_name__"], false]
    - ["pl2161005", "pathlib.Path.__dict__.__contains__", ["fget"], false]
    - ["pl2161006", "pathlib.Path.__dict__.__contains__", ["fset"], false]
    - ["pl2161007", "pathlib.Path.__dict__.__contains__", ["fdel"], false]
    - ["pl2161008", "pathlib.Path.__dict__.__contains__", ["__objclass__"], false]
    - ["pl2161009", "pathlib.Path.__dict__.__contains__", ["__func__"], false]
    - ["pl2161010", "pathlib.Path.__dict__.__contains__", ["stat"], true]
    - ["pl2161011", "pathlib.Path.__dict__.__contains__", ["exists"], true]
    - ["pl2161012", "pathlib.Path.__dict__.__contains__", ["open"], true]
    - ["pl2161013", "pathlib.Path.__dict__.__contains__", ["info"], true]

# ---------------------------------------------------------------------------
# pathlib.PurePath — descriptor protocol dict-presence
#
# PurePath stores property objects for drive, root, anchor, name, stem,
# suffix, suffixes, parent, parents in its __dict__. These are instances of
# the builtin property type. The property class itself defines __get__,
# __set__, __delete__, __set_name__, fget, fset, and fdel — but those keys
# are on the property TYPE, not on PurePath itself. PurePath.__dict__ does
# not contain '__get__', 'fget', etc. as keys.
# ---------------------------------------------------------------------------

table pathlib_extra2161.PurePath_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
    - ["pl2161014", "pathlib.PurePath.__dict__.__contains__", ["__get__"], false]
    - ["pl2161015", "pathlib.PurePath.__dict__.__contains__", ["__set__"], false]
    - ["pl2161016", "pathlib.PurePath.__dict__.__contains__", ["__delete__"], false]
    - ["pl2161017", "pathlib.PurePath.__dict__.__contains__", ["__set_name__"], false]
    - ["pl2161018", "pathlib.PurePath.__dict__.__contains__", ["fget"], false]
    - ["pl2161019", "pathlib.PurePath.__dict__.__contains__", ["fset"], false]
    - ["pl2161020", "pathlib.PurePath.__dict__.__contains__", ["fdel"], false]
    - ["pl2161021", "pathlib.PurePath.__dict__.__contains__", ["__objclass__"], false]
    - ["pl2161022", "pathlib.PurePath.__dict__.__contains__", ["__func__"], false]
    - ["pl2161023", "pathlib.PurePath.__dict__.__contains__", ["drive"], true]
    - ["pl2161024", "pathlib.PurePath.__dict__.__contains__", ["root"], true]
    - ["pl2161025", "pathlib.PurePath.__dict__.__contains__", ["anchor"], true]
    - ["pl2161026", "pathlib.PurePath.__dict__.__contains__", ["name"], true]
    - ["pl2161027", "pathlib.PurePath.__dict__.__contains__", ["stem"], true]
    - ["pl2161028", "pathlib.PurePath.__dict__.__contains__", ["suffix"], true]
    - ["pl2161029", "pathlib.PurePath.__dict__.__contains__", ["suffixes"], true]
    - ["pl2161030", "pathlib.PurePath.__dict__.__contains__", ["parent"], true]
    - ["pl2161031", "pathlib.PurePath.__dict__.__contains__", ["parents"], true]
    - ["pl2161032", "pathlib.PurePath.__dict__.__contains__", ["parts"], true]

