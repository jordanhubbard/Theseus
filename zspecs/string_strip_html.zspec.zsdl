spec: string_strip_html
version: ">=13.0.0"
backend: node(string-strip-html)

docs: https://codsen.com/os/string-strip-html/

provenance:
  derived_from:
    - "string-strip-html documentation — https://codsen.com/os/string-strip-html/"
    - "Test vectors verified with string-strip-html via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "string-strip-html source"
  notes:
    - "Removes HTML tags from a string. Used by markdown processors, sanitizers, search-index pipelines."
    - "Install: npm install string-strip-html"
    - "Module exports {stripHtml}; .stripHtml(s) returns {result, ranges, allTagLocations, ...}; we read .result for the cleaned text."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table string_strip_html.result:
  kind: node_chain_eq
  category: result
  entry: named
  function: stripHtml
  id_prefix: result

  columns: [id, entry_args, chain, expected]
  rows:
    - [paragraph_only,
       ["<p>hello world</p>"],
       [{get: result}],
       "hello world"]

    - [nested_tags,
       ["<p>hello <b>world</b></p>"],
       [{get: result}],
       "hello world"]

    - [no_html_passthrough,
       ["plain text"],
       [{get: result}],
       "plain text"]

    - [empty_input,
       [""],
       [{get: result}],
       ""]

    - [self_closing_tag,
       ["before<br/>after"],
       [{get: result}],
       "before after"]

    - [tag_with_attributes,
       ["<a href=\"x\">link</a>"],
       [{get: result}],
       "link"]

    - [multiple_paragraphs,
       ["<p>one</p><p>two</p>"],
       [{get: result}],
       "one two"]

    - [script_tag_removed,
       ["<script>alert(1)</script>plain"],
       [{get: result}],
       "plain"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:15:41Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
