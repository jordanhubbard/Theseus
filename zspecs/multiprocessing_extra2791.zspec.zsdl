spec: multiprocessing_extra2791
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "multiprocessing_extra.zspec.zsdl — covers Process.__module__, base class, factory __name__ checks"
    - "multiprocessing_extra2.zspec.zsdl — covers factory __module__ checks, extra primitive names"
    - "multiprocessing_extra2776.zspec.zsdl — covers __isub__, __imul__, __itruediv__ dict-presence checks"
  notes:
    - "Wave 633 theme: __iand__, __ior__, and __ixor__ dict-presence checks (in-place bitwise operators)."
    - "None of the multiprocessing public classes define __iand__, __ior__, or __ixor__ in their __dict__."
    - "multiprocessing.Process is a real class (Lib/multiprocessing/process.py); Pool and ApplyResult are in Lib/multiprocessing/pool.py."
    - "multiprocessing.pool.AsyncResult is an alias for multiprocessing.pool.ApplyResult; __name__ is 'ApplyResult' in Python 3.14.4."
    - "Process, Pool, and ApplyResult are process-management/coordination classes, not bitwise-set types."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — __iand__/__ior__/__ixor__ dict-presence checks
#
# Process is the core class for spawning new OS processes. It manages process
# lifecycle (start, join, terminate) and does not implement in-place bitwise dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2791.process_operator_dict:
  description: "multiprocessing.Process __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2791p

  columns: [id, function, args, expected]
  rows:
    - ["mp2791p_iand",  multiprocessing.Process.__dict__.__contains__, ["__iand__"],  false]
    - ["mp2791p_ior",   multiprocessing.Process.__dict__.__contains__, ["__ior__"],   false]
    - ["mp2791p_ixor",  multiprocessing.Process.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool — __iand__/__ior__/__ixor__ dict-presence checks
#
# Pool is a process pool manager providing map/apply/starmap/imap interfaces.
# It coordinates worker processes and does not define in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2791.pool_operator_dict:
  description: "multiprocessing.pool.Pool __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2791pl

  columns: [id, function, args, expected]
  rows:
    - ["mp2791pl_iand",  multiprocessing.pool.Pool.__dict__.__contains__, ["__iand__"],  false]
    - ["mp2791pl_ior",   multiprocessing.pool.Pool.__dict__.__contains__, ["__ior__"],   false]
    - ["mp2791pl_ixor",  multiprocessing.pool.Pool.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.ApplyResult — __iand__/__ior__/__ixor__ dict-presence checks
#
# ApplyResult (also exported as AsyncResult) is the result object returned by
# Pool.apply_async(). It wraps a pending result and provides get()/ready()/wait().
# It does not implement in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2791.applyresult_operator_dict:
  description: "multiprocessing.pool.ApplyResult __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2791ar

  columns: [id, function, args, expected]
  rows:
    - ["mp2791ar_iand",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__iand__"],  false]
    - ["mp2791ar_ior",   multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ior__"],   false]
    - ["mp2791ar_ixor",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — Process, Pool, ApplyResult × three in-place bitwise operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Process, Pool, and ApplyResult do not define &=, |=, or ^=
# operator dunders in their respective __dict__ attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra2791.all_types_iand_ior_ixor_matrix:
  description: "Full 3×3 dict-presence matrix for multiprocessing types vs __iand__/__ior__/__ixor__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2791mx

  columns: [id, function, args, expected]
  rows:
    - ["mp2791mx_p_ia",   multiprocessing.Process.__dict__.__contains__,          ["__iand__"],  false]
    - ["mp2791mx_p_io",   multiprocessing.Process.__dict__.__contains__,          ["__ior__"],   false]
    - ["mp2791mx_p_ix",   multiprocessing.Process.__dict__.__contains__,          ["__ixor__"],  false]
    - ["mp2791mx_pl_ia",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__iand__"],  false]
    - ["mp2791mx_pl_io",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__ior__"],   false]
    - ["mp2791mx_pl_ix",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__ixor__"],  false]
    - ["mp2791mx_ar_ia",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__iand__"],  false]
    - ["mp2791mx_ar_io",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ior__"],   false]
    - ["mp2791mx_ar_ix",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ixor__"],  false]
