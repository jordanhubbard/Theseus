spec: weakref_extra22
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
    - "weakref_extra21.zspec.zsdl — covers ref.__call__/WeakValueDictionary.setdefault/update/pop/WeakKeyDictionary.get/keys/WeakSet.discard/remove method qualnames."
    - "weakref_extra20.zspec.zsdl — covers ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __qualname__ standalones; WeakValueDictionary.get/__qualname__; WeakSet.add/__qualname__; finalize.__call__/__qualname__; combined table."
    - "weakref_extra19.zspec.zsdl — covers ReferenceType/CallableProxyType/ProxyType/WeakMethod __qualname__ and WeakValueDictionary/WeakKeyDictionary __module__."
    - "weakref_extra18.zspec.zsdl — covers ref.__qualname__ == 'ReferenceType' as standalone."
    - "weakref_extra15.zspec.zsdl — covers ref/__qualname__/WeakValueDictionary/__qualname__/WeakKeyDictionary/__qualname__ in combined table."
  notes:
    - "This spec extends weakref_extra21.zspec.zsdl."
    - "Focus: novel combined tables in the extra22 namespace — (1) __module__ values for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; (2) __bases__[0].__name__ for ref/WeakSet/WeakValueDictionary/WeakKeyDictionary/finalize; (3) module-level function qualnames for proxy/getweakrefcount/getweakrefs; (4) finalize.detach/peek method qualnames."
    - "weakref.ref.__module__ == 'weakref' — the ref type's __module__ attribute."
    - "weakref.ref.__bases__[0].__name__ == 'object' — ref (ReferenceType) directly inherits from object."
    - "weakref.WeakSet.__module__ == '_weakrefset' — WeakSet is defined in the private _weakrefset module."
    - "weakref.WeakSet.__bases__[0].__name__ == 'object' — WeakSet directly inherits from object."
    - "weakref.WeakValueDictionary.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "weakref.WeakKeyDictionary.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "weakref.finalize.__module__ == 'weakref' — finalize is defined in Lib/weakref.py."
    - "weakref.finalize.__bases__[0].__name__ == 'object' — finalize directly inherits from object."
    - "weakref.proxy.__qualname__ == 'proxy' — module-level C function; __qualname__ equals __name__."
    - "weakref.proxy.__module__ == '_weakref' — implemented in the C extension _weakref."
    - "weakref.getweakrefcount.__qualname__ == 'getweakrefcount' — module-level C function."
    - "weakref.getweakrefcount.__module__ == '_weakref' — implemented in the C extension _weakref."
    - "weakref.getweakrefs.__qualname__ == 'getweakrefs' — module-level C function."
    - "weakref.getweakrefs.__module__ == '_weakref' — implemented in the C extension _weakref."
    - "weakref.finalize.detach.__qualname__ == 'finalize.detach' — method qualname includes enclosing class."
    - "weakref.finalize.peek.__qualname__ == 'finalize.peek' — method qualname includes enclosing class."
    - "weakref.WeakKeyDictionary.setdefault.__qualname__ == 'WeakKeyDictionary.setdefault' — not covered in extra21."
    - "weakref.WeakKeyDictionary.pop.__qualname__ == 'WeakKeyDictionary.pop' — not covered in extra21."
    - "weakref.WeakKeyDictionary.update.__qualname__ == 'WeakKeyDictionary.update' — not covered in extra21."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ combined table for weakref types (extra22 namespace)
#
# weakref_extra19 covers WeakValueDictionary/__module__ and WeakKeyDictionary/__module__
# as a combined table. This extra22 table groups ref/WeakValueDictionary/WeakKeyDictionary/
# finalize (all 'weakref') together with WeakSet ('_weakrefset') — not previously
# combined in a single table in the extra22 namespace.
# ---------------------------------------------------------------------------

table weakref_extra22.modules:
  description: "__module__.__eq__ for weakref types in the extra22 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [ref,                    ref.__module__.__eq__,                    ["weakref"],      true]
    - [WeakValueDictionary,    WeakValueDictionary.__module__.__eq__,    ["weakref"],      true]
    - [WeakKeyDictionary,      WeakKeyDictionary.__module__.__eq__,      ["weakref"],      true]
    - [finalize,               finalize.__module__.__eq__,               ["weakref"],      true]
    - [WeakSet,                WeakSet.__module__.__eq__,                ["_weakrefset"],  true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ combined table for weakref types (extra22 namespace)
#
# No prior weakref spec combines ref/WeakSet/WeakValueDictionary/WeakKeyDictionary/
# finalize __bases__[0].__name__ values into a single table in the extra22 namespace.
# WeakValueDictionary and WeakKeyDictionary inherit from MutableMapping (ABC).
# All others (ref, WeakSet, finalize) directly subclass object.
# ---------------------------------------------------------------------------

table weakref_extra22.bases:
  description: "__bases__[0].__name__.__eq__ for weakref types in the extra22 namespace"
  kind: python_call_eq
  category: bases
  id_prefix: bases

  columns: [id, function, args, expected]
  rows:
    - [ref,                    "ref.__bases__[0].__name__.__eq__",                    ["object"],         true]
    - [WeakSet,                "WeakSet.__bases__[0].__name__.__eq__",                ["object"],         true]
    - [finalize,               "finalize.__bases__[0].__name__.__eq__",               ["object"],         true]
    - [WeakValueDictionary,    "WeakValueDictionary.__bases__[0].__name__.__eq__",    ["MutableMapping"], true]
    - [WeakKeyDictionary,      "WeakKeyDictionary.__bases__[0].__name__.__eq__",      ["MutableMapping"], true]

# ---------------------------------------------------------------------------
# Module-level C function qualnames (extra22 namespace)
#
# proxy, getweakrefcount, getweakrefs are all implemented in the _weakref C
# extension. Their __qualname__ equals their simple name and their __module__
# is '_weakref'. No prior weakref spec combines these three in a single table.
# ---------------------------------------------------------------------------

table weakref_extra22.cfunc_qualnames:
  description: "__qualname__.__eq__ for weakref C-level module functions in the extra22 namespace"
  kind: python_call_eq
  category: func_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [proxy,             proxy.__qualname__.__eq__,             ["proxy"],             true]
    - [getweakrefcount,   getweakrefcount.__qualname__.__eq__,   ["getweakrefcount"],   true]
    - [getweakrefs,       getweakrefs.__qualname__.__eq__,       ["getweakrefs"],       true]

# ---------------------------------------------------------------------------
# C-level module function __module__ combined table (extra22 namespace)
#
# proxy, getweakrefcount, getweakrefs all have __module__ == '_weakref'.
# No prior spec combines these three __module__ values in a single table.
# ---------------------------------------------------------------------------

table weakref_extra22.cfunc_modules:
  description: "__module__.__eq__ for weakref C-level module functions in the extra22 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: cfunc_module

  columns: [id, function, args, expected]
  rows:
    - [proxy,             proxy.__module__.__eq__,             ["_weakref"], true]
    - [getweakrefcount,   getweakrefcount.__module__.__eq__,   ["_weakref"], true]
    - [getweakrefs,       getweakrefs.__module__.__eq__,       ["_weakref"], true]

# ---------------------------------------------------------------------------
# finalize method qualnames (extra22 namespace)
#
# finalize.detach and finalize.peek are regular Python methods on the finalize
# class. Their __qualname__ includes the enclosing class name as a prefix.
# No prior weakref spec records finalize.detach or finalize.peek __qualname__.
# ---------------------------------------------------------------------------

table weakref_extra22.finalize_method_qualnames:
  description: "method __qualname__.__eq__ for weakref.finalize methods in the extra22 namespace"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [finalize_detach, "finalize.detach.__qualname__.__eq__", ["finalize.detach"], true]
    - [finalize_peek,   "finalize.peek.__qualname__.__eq__",   ["finalize.peek"],   true]

# ---------------------------------------------------------------------------
# WeakKeyDictionary method qualnames (extra22 namespace)
#
# weakref_extra21 covers WeakKeyDictionary.get and WeakKeyDictionary.keys.
# This table adds setdefault/pop/update/values/items — method qualnames not
# yet recorded in any prior weakref spec.
# ---------------------------------------------------------------------------

table weakref_extra22.WeakKeyDictionary_method_qualnames:
  description: "WeakKeyDictionary method __qualname__.__eq__ in the extra22 namespace"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [setdefault, "WeakKeyDictionary.setdefault.__qualname__.__eq__", ["WeakKeyDictionary.setdefault"], true]
    - [pop,        "WeakKeyDictionary.pop.__qualname__.__eq__",        ["WeakKeyDictionary.pop"],        true]
    - [update,     "WeakKeyDictionary.update.__qualname__.__eq__",     ["WeakKeyDictionary.update"],     true]
    - [values,     "WeakKeyDictionary.values.__qualname__.__eq__",     ["WeakKeyDictionary.values"],     true]
    - [items,      "WeakKeyDictionary.items.__qualname__.__eq__",      ["WeakKeyDictionary.items"],      true]

# ---------------------------------------------------------------------------
# weakref.WeakSet.__module__ == '_weakrefset' — standalone invariant
#
# WeakSet is defined in the private _weakrefset module, not in weakref itself.
# Its __module__ is therefore '_weakrefset'. weakref_extra19 covers WeakValueDictionary
# and WeakKeyDictionary __module__, but not WeakSet. No prior spec records
# WeakSet.__module__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant weakref_extra22.WeakSet.module:
  description: "weakref.WeakSet.__module__ == '_weakrefset' — WeakSet is defined in the private _weakrefset module"
  category: module_attrs
  kind: python_call_eq
  function: WeakSet.__module__.__eq__
  args: ["_weakrefset"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.ref.__bases__[0].__name__ == 'object' — standalone (extra22 namespace)
#
# The C-level ReferenceType (exposed as weakref.ref) directly subclasses object.
# No prior weakref spec records ref.__bases__[0].__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant weakref_extra22.ref.bases0.name:
  description: "weakref.ref.__bases__[0].__name__ == 'object' — ReferenceType directly subclasses object"
  category: bases
  kind: python_call_eq
  function: "ref.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
