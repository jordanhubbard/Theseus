  kind: python_call_eq
  category: isfuture_identity
  id_prefix: aioisfns247

  columns: [id, function, args, expected, description]
  rows:
    - [isf_name_eq,   isfuture.__name__.__eq__,           ["isfuture"],              true, "asyncio.isfuture.__name__ == 'isfuture'; verified with Python 3.14.3"]
    - [isf_name_len,  isfuture.__name__.__len__,          [],                        8,    "asyncio.isfuture.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [isf_mod_eq,    isfuture.__module__.__eq__,         ["asyncio.base_futures"],  true, "asyncio.isfuture.__module__ == 'asyncio.base_futures'; verified with Python 3.14.3"]
    - [isf_mod_len,   isfuture.__module__.__len__,        [],                        20,   "asyncio.isfuture.__module__.__len__() == 20; verified with Python 3.14.3"]
    - [isf_qname_eq,  isfuture.__qualname__.__eq__,       ["isfuture"],              true, "asyncio.isfuture.__qualname__ == 'isfuture'; verified with Python 3.14.3"]
    - [isf_cls_eq,    isfuture.__class__.__name__.__eq__, ["function"],              true, "asyncio.isfuture.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra247
# ---------------------------------------------------------------------------

invariant asyncio_extra247.iscoroutine_name_eq:
  description: "asyncio.iscoroutine.__name__.__eq__('iscoroutine') returns True — the function is named 'iscoroutine' (len=11); it lives in asyncio.coroutines (len=18); it is a plain function (__class__.__name__ == 'function'); iscoroutinefunction.__name__.__len__()==19 (longer); isfuture.__name__.__len__()==8 (shorter); among the three inspection functions iscoroutine has the middle-length name (8 < 11 < 19); NEW in extra247: first standalone iscoroutine name equality invariant in aioisfns247 namespace; verified with Python 3.14.3"
  category: iscoroutine_identity
  kind: python_call_eq
  function: iscoroutine.__name__.__eq__
  args: ["iscoroutine"]
  expected: true

invariant asyncio_extra247.iscoroutine_module_eq:
  description: "asyncio.iscoroutine.__module__.__eq__('asyncio.coroutines') returns True — iscoroutine is defined in Lib/asyncio/coroutines.py; __module__ == 'asyncio.coroutines' (len=18); iscoroutinefunction shares this module (also 'asyncio.coroutines'); isfuture.__module__ == 'asyncio.base_futures' (len=20, different module); iscoroutine.__name__ == 'iscoroutine' (len=11); iscoroutine.__class__.__name__ == 'function'; NEW in extra247: first standalone iscoroutine module invariant; verified with Python 3.14.3"
  category: iscoroutine_identity
  kind: python_call_eq
  function: iscoroutine.__module__.__eq__
  args: ["asyncio.coroutines"]
  expected: true

invariant asyncio_extra247.iscoroutinefunction_module_eq:
  description: "asyncio.iscoroutinefunction.__module__.__eq__('asyncio.coroutines') returns True — iscoroutinefunction shares the 'asyncio.coroutines' module with iscoroutine (both len=18 for __module__); __name__ == 'iscoroutinefunction' (len=19); __class__.__name__ == 'function'; iscoroutinefunction.__name__.__len__()==19 is the longest name among the three inspection functions; NEW in extra247: first standalone iscoroutinefunction module invariant; verified with Python 3.14.3"
  category: iscoroutinefunction_identity
  kind: python_call_eq
  function: iscoroutinefunction.__module__.__eq__
  args: ["asyncio.coroutines"]
  expected: true

invariant asyncio_extra247.isfuture_module_eq:
  description: "asyncio.isfuture.__module__.__eq__('asyncio.base_futures') returns True — isfuture is defined in Lib/asyncio/base_futures.py; __module__ == 'asyncio.base_futures' (len=20); contrast with iscoroutine.__module__ == 'asyncio.coroutines' (len=18); isfuture.__name__ == 'isfuture' (len=8, shortest of the three); isfuture.__class__.__name__ == 'function'; NEW in extra247: first standalone isfuture module invariant; verified with Python 3.14.3"
  category: isfuture_identity
  kind: python_call_eq
  function: isfuture.__module__.__eq__
  args: ["asyncio.base_futures"]
  expected: true
