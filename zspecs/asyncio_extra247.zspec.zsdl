spec: asyncio_extra247
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio tasks documentation"
    - "https://docs.python.org/3/library/asyncio-future.html — asyncio futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/coroutines.py (internal C-level accelerators)"
    - "CPython source: Lib/asyncio/base_futures.py (internal C-level accelerators)"
  notes:
    - "This spec covers asyncio.iscoroutine, asyncio.iscoroutinefunction, asyncio.isfuture function identity."
    - "iscoroutine.__module__ == 'asyncio.coroutines' (len=18) — defined in Lib/asyncio/coroutines.py."
    - "iscoroutinefunction.__module__ == 'asyncio.coroutines' (len=18) — same module as iscoroutine."
    - "isfuture.__module__ == 'asyncio.base_futures' (len=20) — defined in Lib/asyncio/base_futures.py."
    - "All three are plain functions: __class__.__name__ == 'function'."
    - "iscoroutine.__name__ == 'iscoroutine' (len=11); iscoroutinefunction.__name__ == 'iscoroutinefunction' (len=19); isfuture.__name__ == 'isfuture' (len=8)."
    - "iscoroutine(coro_object) returns True; iscoroutine(42) returns False — return type is bool."
    - "iscoroutinefunction(async_fn) returns True; iscoroutinefunction(len) returns False."
    - "isfuture(asyncio.Future) returns True; isfuture(42) returns False."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.iscoroutine function identity
#
# iscoroutine.__name__ == 'iscoroutine' (len=11)
# iscoroutine.__module__ == 'asyncio.coroutines' (len=18)
# iscoroutine.__qualname__ == 'iscoroutine' (len=11)
# iscoroutine.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra247.iscoroutine_identity:
  description: "asyncio.iscoroutine function identity — iscoroutine.__name__.__eq__('iscoroutine')==True (len=11); iscoroutine.__module__.__eq__('asyncio.coroutines')==True (len=18); iscoroutine.__qualname__.__eq__('iscoroutine')==True (same as __name__, len=11); iscoroutine.__class__.__name__.__eq__('function')==True (plain function, not a method or class); iscoroutine.__name__.__len__()==11; iscoroutine.__module__.__len__()==18; verified with Python 3.14.3"
  kind: python_call_eq
  category: iscoroutine_identity
  id_prefix: aioisfns247

  columns: [id, function, args, expected, description]
  rows:
    - [isc_name_eq,   iscoroutine.__name__.__eq__,           ["iscoroutine"],          true, "asyncio.iscoroutine.__name__ == 'iscoroutine'; verified with Python 3.14.3"]
    - [isc_name_len,  iscoroutine.__name__.__len__,          [],                       11,   "asyncio.iscoroutine.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [isc_mod_eq,    iscoroutine.__module__.__eq__,         ["asyncio.coroutines"],   true, "asyncio.iscoroutine.__module__ == 'asyncio.coroutines'; verified with Python 3.14.3"]
    - [isc_mod_len,   iscoroutine.__module__.__len__,        [],                       18,   "asyncio.iscoroutine.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [isc_qname_eq,  iscoroutine.__qualname__.__eq__,       ["iscoroutine"],          true, "asyncio.iscoroutine.__qualname__ == 'iscoroutine'; verified with Python 3.14.3"]
    - [isc_cls_eq,    iscoroutine.__class__.__name__.__eq__, ["function"],             true, "asyncio.iscoroutine.__class__.__name__ == 'function'; verified with Python 3.14.3"]

