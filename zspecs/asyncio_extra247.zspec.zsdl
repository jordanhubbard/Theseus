  kind: python_call_eq
  category: iscoroutinefunction_identity
  id_prefix: aioisfns247

  columns: [id, function, args, expected, description]
  rows:
    - [iscfn_name_eq,  iscoroutinefunction.__name__.__eq__,           ["iscoroutinefunction"], true, "asyncio.iscoroutinefunction.__name__ == 'iscoroutinefunction'; verified with Python 3.14.3"]
    - [iscfn_name_len, iscoroutinefunction.__name__.__len__,          [],                      19,   "asyncio.iscoroutinefunction.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [iscfn_mod_eq,   iscoroutinefunction.__module__.__eq__,         ["asyncio.coroutines"],  true, "asyncio.iscoroutinefunction.__module__ == 'asyncio.coroutines'; verified with Python 3.14.3"]
    - [iscfn_mod_len,  iscoroutinefunction.__module__.__len__,        [],                      18,   "asyncio.iscoroutinefunction.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [iscfn_cls_eq,   iscoroutinefunction.__class__.__name__.__eq__, ["function"],            true, "asyncio.iscoroutinefunction.__class__.__name__ == 'function'; verified with Python 3.14.3"]

