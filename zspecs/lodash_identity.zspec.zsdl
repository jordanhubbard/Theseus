spec: lodash_identity
version: ">=3.0.0"
backend: node(lodash.identity)

docs: https://lodash.com/docs/#identity

provenance:
  derived_from:
    - "lodash.identity README — https://www.npmjs.com/package/lodash.identity"
    - "Test vectors verified with lodash.identity@3.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.identity exports the _.identity function directly as module.exports."
    - "identity(value) returns the first argument it receives."
    - "Used as the default iteratee in many lodash methods."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the input value unchanged."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_identity.identity:
  kind: node_module_call_eq
  function: ~
  category: identity
  id_prefix: lid

  columns: [id, args, expected]
  rows:
    - [number,  [42],              42]
    - [string,  ["hello"],         "hello"]
    - [object,  [{"a": 1}],        {"a": 1}]
    - [array,   [[1, 2, 3]],       [1, 2, 3]]
    - [null_v,  [null],            null]
