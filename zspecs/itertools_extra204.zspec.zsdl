spec: itertools_extra204
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra.zspec.zsdl — covers filterfalse.__name__, chain.__length_hint__, repeat length hint and first element, islice length hint and first element"
  notes:
    - "itertools does NOT have __all__; confirmed with Python 3.14.3."
    - "itertools.__dict__.__len__() == 28 — the module dict has exactly 28 entries in Python 3.14.3."
    - "itertools.__dict__.__contains__('chain') == True — chain is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('cycle') == True — cycle is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('count') == True — count is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('repeat') == True — repeat is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('islice') == True — islice is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('product') == True — product is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('combinations') == True — combinations is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('permutations') == True — permutations is present in itertools.__dict__."
    - "itertools.__dict__.__contains__('missing_xyz') == False — a nonexistent name is not in itertools.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__dict__ size and core combinator membership
#
# itertools has no __all__; __dict__ is used to verify symbol presence.
# itertools.__dict__.__len__() == 28 in Python 3.14.3.
# chain, cycle, count, repeat are all present.
# ---------------------------------------------------------------------------

table itertools_extra204.dict_size_and_core:
  description: "itertools.__dict__ has 28 entries; chain, cycle, count, repeat are present; itertools has no __all__ so __dict__ is used; new to extra204"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iterall204

  columns: [id, function, args, expected, description]
  rows:
    - [dict_len_28,
       "__dict__.__len__",
       [],
       28,
       "itertools.__dict__.__len__() == 28 — the module namespace dict has exactly 28 entries in Python 3.14.3; itertools has no __all__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_chain,
       "__dict__.__contains__",
       ["chain"],
       true,
       "itertools.__dict__.__contains__('chain') == True — 'chain' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_cycle,
       "__dict__.__contains__",
       ["cycle"],
       true,
       "itertools.__dict__.__contains__('cycle') == True — 'cycle' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_count,
       "__dict__.__contains__",
       ["count"],
       true,
       "itertools.__dict__.__contains__('count') == True — 'count' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__dict__ — repeat, islice, product membership
# ---------------------------------------------------------------------------

table itertools_extra204.dict_repeat_islice_product:
  description: "itertools.__dict__ contains repeat, islice, and product; new to extra204"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iterall204

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_repeat,
       "__dict__.__contains__",
       ["repeat"],
       true,
       "itertools.__dict__.__contains__('repeat') == True — 'repeat' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_islice,
       "__dict__.__contains__",
       ["islice"],
       true,
       "itertools.__dict__.__contains__('islice') == True — 'islice' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_product,
       "__dict__.__contains__",
       ["product"],
       true,
       "itertools.__dict__.__contains__('product') == True — 'product' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_combinations,
       "__dict__.__contains__",
       ["combinations"],
       true,
       "itertools.__dict__.__contains__('combinations') == True — 'combinations' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]

# ---------------------------------------------------------------------------
# Table 3: itertools.__dict__ — permutations, negation check
# ---------------------------------------------------------------------------

table itertools_extra204.dict_permutations_and_negation:
  description: "itertools.__dict__ contains permutations; missing_xyz is absent; new to extra204"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iterall204

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_permutations,
       "__dict__.__contains__",
       ["permutations"],
       true,
       "itertools.__dict__.__contains__('permutations') == True — 'permutations' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_not_has_missing,
       "__dict__.__contains__",
       ["missing_xyz"],
       false,
       "itertools.__dict__.__contains__('missing_xyz') == False — 'missing_xyz' does not exist in itertools and is absent from __dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_accumulate,
       "__dict__.__contains__",
       ["accumulate"],
       true,
       "itertools.__dict__.__contains__('accumulate') == True — 'accumulate' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]
    - [dict_has_compress,
       "__dict__.__contains__",
       ["compress"],
       true,
       "itertools.__dict__.__contains__('compress') == True — 'compress' is present in itertools.__dict__; verified with Python 3.14.3; new to extra204"]

