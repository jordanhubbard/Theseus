spec: itertools_extra2101
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2101 (_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks for itertools types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "itertools.chain defines __class_getitem__ in its own __dict__ (True) — chain is the only public itertools type that was given explicit generic alias support."
    - "All other public itertools types (cycle, count, zip_longest, groupby, islice, product, combinations, permutations, accumulate, compress, dropwhile, takewhile, filterfalse, starmap, repeat, combinations_with_replacement, pairwise, batched) do NOT define __class_getitem__ in their own __dict__."
    - "None of the itertools types define __init_subclass__ in their own __dict__ — all are C extension types that inherit from object."
    - "None of the itertools types define __subclasshook__ in their own __dict__ — itertools types are not ABC-based."
    - "None of the itertools types define __mro_entries__ in their own __dict__ — itertools types are not generic alias proxy types."
    - "The internal types _grouper, _tee, _tee_dataobject also do not define any of the four protocol dunders."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ dict-presence for itertools types
#
# chain: True (the only public itertools type with explicit generic alias support)
# all others: False
# ---------------------------------------------------------------------------

table itertools_extra2101.class_getitem_protocol:
  description: "itertools types __class_getitem__ dict-presence checks — chain True, all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2101

  columns: [id, function, args, expected]
  rows:
    - ["it2101001", "itertools.chain.__dict__.__contains__", ["__class_getitem__"], true]
    - ["it2101002", "itertools.cycle.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101003", "itertools.count.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101004", "itertools.zip_longest.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101005", "itertools.groupby.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101006", "itertools.islice.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101007", "itertools.product.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101008", "itertools.combinations.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101009", "itertools.permutations.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101010", "itertools.accumulate.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101011", "itertools.compress.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101012", "itertools.dropwhile.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101013", "itertools.takewhile.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101014", "itertools.filterfalse.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101015", "itertools.starmap.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101016", "itertools.repeat.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101017", "itertools.combinations_with_replacement.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101018", "itertools.pairwise.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it2101019", "itertools.batched.__dict__.__contains__", ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 2: __init_subclass__ dict-presence for itertools types
#
# All itertools types are C extension types. None define __init_subclass__
# in their own __dict__; they inherit it from object.
# ---------------------------------------------------------------------------

table itertools_extra2101.init_subclass_protocol:
  description: "itertools types __init_subclass__ dict-presence checks — all False (C extension types inherit from object)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2101

  columns: [id, function, args, expected]
  rows:
    - ["it2101020", "itertools.chain.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101021", "itertools.cycle.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101022", "itertools.count.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101023", "itertools.zip_longest.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101024", "itertools.groupby.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101025", "itertools.islice.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101026", "itertools.product.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101027", "itertools.accumulate.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it2101028", "itertools.starmap.__dict__.__contains__", ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 3: __subclasshook__ dict-presence for itertools types
#
# __subclasshook__ is an ABCMeta protocol hook. No itertools type uses ABC
# machinery; none define __subclasshook__ in their own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra2101.subclasshook_protocol:
  description: "itertools types __subclasshook__ dict-presence checks — all False (itertools types are not ABC-based)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2101

  columns: [id, function, args, expected]
  rows:
    - ["it2101029", "itertools.chain.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101030", "itertools.cycle.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101031", "itertools.count.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101032", "itertools.zip_longest.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101033", "itertools.groupby.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101034", "itertools.islice.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101035", "itertools.combinations.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101036", "itertools.permutations.__dict__.__contains__", ["__subclasshook__"], false]
    - ["it2101037", "itertools.accumulate.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 4: __mro_entries__ dict-presence for itertools types
#
# __mro_entries__ is used by generic alias proxy objects placed in a class
# bases tuple. None of the itertools iterator types define it in their
# own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra2101.mro_entries_protocol:
  description: "itertools types __mro_entries__ dict-presence checks — all False (not MRO-entry proxy types)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2101

  columns: [id, function, args, expected]
  rows:
    - ["it2101038", "itertools.chain.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101039", "itertools.cycle.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101040", "itertools.count.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101041", "itertools.zip_longest.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101042", "itertools.groupby.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101043", "itertools.islice.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101044", "itertools.product.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101045", "itertools.combinations.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101046", "itertools.permutations.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101047", "itertools.starmap.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101048", "itertools.repeat.__dict__.__contains__", ["__mro_entries__"], false]
    - ["it2101049", "itertools.filterfalse.__dict__.__contains__", ["__mro_entries__"], false]
