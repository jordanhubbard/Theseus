spec: struct_extra2521
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra161.zspec.zsdl — covers struct.error/__name__/__module__/__bases__; struct.Struct.__name__/__module__/__bases__; module and base name lengths (tables + standalones)."
    - "struct_extra160.zspec.zsdl — covers struct.Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/size/format) and meta-attrs (__len__()==16/__class__.__name__=='mappingproxy')."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct.zspec.zsdl or struct_extra*.zspec.zsdl through struct_extra161."
    - "Theme: __bool__, __index__, and __int__ dict-presence for struct.Struct and struct.error."
    - "struct.Struct.__dict__.__contains__('__bool__') == False — Struct is a C extension type (binary pack/unpack); it does not define truthiness; bool(Struct('>I')) is always True via object default."
    - "struct.Struct.__dict__.__contains__('__int__') == False — Struct objects are not integer-coercible; they represent format strings for binary data layout, not numeric values."
    - "struct.Struct.__dict__.__contains__('__index__') == False — Struct objects cannot serve as sequence indices."
    - "struct.error.__dict__.__contains__('__bool__') == False — struct.error is an Exception subclass; exceptions do not define truthiness."
    - "struct.error.__dict__.__contains__('__int__') == False — struct.error is not integer-coercible."
    - "struct.error.__dict__.__contains__('__index__') == False — struct.error instances cannot serve as sequence indices."
    - "Both struct.Struct and struct.error are C extension types (Modules/_struct.c); neither defines any numeric coercion protocol."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct __bool__ / __int__ / __index__ dict-presence
#
# struct.Struct is a C extension type for binary data packing/unpacking.
# It defines methods for binary layout (pack, unpack, pack_into, unpack_from,
# iter_unpack) and attributes (size, format), but no numeric coercion dunders.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table struct_extra2521.Struct_bool_int_index:
  description: "struct.Struct.__dict__.__contains__('__bool__')==False / Struct.__dict__.__contains__('__int__')==False / Struct.__dict__.__contains__('__index__')==False — Struct is a C extension type (Modules/_struct.c) for binary packing and unpacking; Struct does not define __bool__ (no truthiness override; bool(Struct('>I')) is always True via object default; struct_extra160 anchors Struct.__dict__ members pack/unpack/size/format — no numeric dunders are present); Struct does not define __int__ (Struct objects represent format specifications for binary data, not numeric values; int(Struct('>I')) would raise TypeError); Struct does not define __index__ (Struct objects cannot be used as sequence indices or slice arguments); all three numeric coercion dunders absent from Struct.__dict__; struct.Struct.__module__=='_struct' (C extension); struct.Struct.__bases__[0].__name__=='object'; first st2521 anchor for Struct coercion-dunder absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2521

  columns: [id, function, args, expected]
  rows:
    - ["st2521_struct_no_bool",  "Struct.__dict__.__contains__", ["__bool__"],  false]
    - ["st2521_struct_no_int",   "Struct.__dict__.__contains__", ["__int__"],   false]
    - ["st2521_struct_no_index", "Struct.__dict__.__contains__", ["__index__"], false]

# ---------------------------------------------------------------------------
# struct.error __bool__ / __int__ / __index__ dict-presence
#
# struct.error is the exception class raised by struct pack/unpack operations.
# It is a subclass of Exception (defined in _struct.c). Like all exception
# classes, it defines no numeric coercion dunders.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table struct_extra2521.error_bool_int_index:
  description: "struct.error.__dict__.__contains__('__bool__')==False / error.__dict__.__contains__('__int__')==False / error.__dict__.__contains__('__index__')==False — struct.error is the exception class raised when struct pack/unpack operations encounter invalid format strings or data; error is a subclass of Exception (error.__bases__[0].__name__=='Exception'; struct_extra161 anchors this); error does not define __bool__ (__bool__ not in error.__dict__; exception instances are always truthy via object default); error does not define __int__ (__int__ not in error.__dict__; exceptions are not integer-coercible; int(struct.error()) would raise TypeError); error does not define __index__ (__index__ not in error.__dict__; exceptions cannot serve as sequence indices); all three coercion dunders absent from error.__dict__; error.__name__=='error' (5 chars; lowercase; old Python naming convention); struct_extra161 anchors error identity — this spec anchors coercion-dunder absence; first st2521 anchor for error coercion-dunder absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2521

  columns: [id, function, args, expected]
  rows:
    - ["st2521_error_no_bool",  "error.__dict__.__contains__", ["__bool__"],  false]
    - ["st2521_error_no_int",   "error.__dict__.__contains__", ["__int__"],   false]
    - ["st2521_error_no_index", "error.__dict__.__contains__", ["__index__"], false]

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__dict__.__contains__('__bool__') == False
#
# struct.Struct is a C extension type for binary data layout.
# It provides pack/unpack/size/format but no truthiness protocol.
# bool(Struct('>I')) delegates to object.__bool__ (always True).
# struct_extra160 anchors the presence of pack/unpack in Struct.__dict__;
# this spec anchors the absence of numeric coercion dunders.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

invariant struct_extra2521.Struct_no_bool_standalone:
  description: "struct.Struct.__dict__.__contains__('__bool__') == False — Struct C extension type has no own __bool__; bool(Struct('>I')) delegates to object.__bool__ (always True for any Struct instance); Struct objects represent binary format specifications (e.g. '>I' for big-endian unsigned int), not boolean values; '__bool__'=8 chars = '__'=2 + 'bool'=4 + '__'=2; struct_extra160 anchors pack/unpack/size/format in Struct.__dict__ — none of the three numeric coercion dunders are present; first st2521 standalone for Struct no-__bool__"
  category: dict_presence
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__bool__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__dict__.__contains__('__int__') == False
# ---------------------------------------------------------------------------

invariant struct_extra2521.Struct_no_int_standalone:
  description: "struct.Struct.__dict__.__contains__('__int__') == False — Struct C extension type has no own __int__; Struct objects represent binary format specifications, not numeric values; int(Struct('>I')) raises TypeError; '__int__'=7 chars = '__'=2 + 'int'=3 + '__'=2; Struct.__module__=='_struct' (C extension); Struct.__dict__ contains pack/unpack/size/format but no __int__; contrasts with uuid.UUID which DOES define __int__ in its __dict__; first st2521 standalone for Struct no-__int__"
  category: dict_presence
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__int__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__dict__.__contains__('__index__') == False
# ---------------------------------------------------------------------------

invariant struct_extra2521.Struct_no_index_standalone:
  description: "struct.Struct.__dict__.__contains__('__index__') == False — Struct C extension type has no own __index__; Struct objects cannot be used as sequence indices; __index__ is the integer-indexing protocol for use in list[x] and slice operations; its absence from Struct.__dict__ is expected — Struct objects are binary layout specifications with no integer-index semantics; '__index__'=9 chars = '__'=2 + 'index'=5 + '__'=2; dunder length ordering: '__int__'(7) < '__bool__'(8) < '__index__'(9); first st2521 standalone for Struct no-__index__"
  category: dict_presence
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__index__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: struct.error.__dict__.__contains__('__bool__') == False
# ---------------------------------------------------------------------------

invariant struct_extra2521.error_no_bool_standalone:
  description: "struct.error.__dict__.__contains__('__bool__') == False — struct.error exception class has no own __bool__; exception instances are always truthy via object.__bool__; struct.error is raised when pack/unpack operations encounter invalid format strings or data (e.g. struct.pack('>I', -1) raises struct.error); '__bool__'=8 chars; error.__name__=='error' (5 chars; struct_extra161 anchors); first st2521 standalone for error no-__bool__"
  category: dict_presence
  kind: python_call_eq
  function: error.__dict__.__contains__
  args: ["__bool__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: struct.error.__dict__.__contains__('__int__') == False
# ---------------------------------------------------------------------------

invariant struct_extra2521.error_no_int_standalone:
  description: "struct.error.__dict__.__contains__('__int__') == False — struct.error exception class has no own __int__; exceptions are not integer-coercible; int(struct.error()) would raise TypeError; exception classes generally do not define numeric coercion protocols; error.__bases__[0].__name__=='Exception' (struct_extra161 anchors); '__int__'=7 chars; first st2521 standalone for error no-__int__"
  category: dict_presence
  kind: python_call_eq
  function: error.__dict__.__contains__
  args: ["__int__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: struct.error.__dict__.__contains__('__index__') == False
# ---------------------------------------------------------------------------

invariant struct_extra2521.error_no_index_standalone:
  description: "struct.error.__dict__.__contains__('__index__') == False — struct.error exception class has no own __index__; exception instances cannot be used as sequence indices; '__index__'=9 chars is the longest coercion dunder in this spec; dunder length ordering for the three coercion dunders: '__int__'(7) < '__bool__'(8) < '__index__'(9); both Struct and error lack all three coercion dunders — neither struct class defines any numeric coercion protocol; first st2521 standalone for error no-__index__"
  category: dict_presence
  kind: python_call_eq
  function: error.__dict__.__contains__
  args: ["__index__"]
  expected: false

# ---------------------------------------------------------------------------
# struct module-level function class __bool__ / __int__ / __index__ dict-presence
#
# struct.pack, struct.unpack, and struct.calcsize are module-level
# builtin_function_or_method objects (C functions from Modules/_struct.c).
# Their class (builtin_function_or_method) also lacks __bool__, __int__, __index__
# in its own __dict__. This table tests three of the struct functions to
# confirm the pattern holds across the module's callable interface.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table struct_extra2521.pack_unpack_calcsize_class_bool_int_index:
  description: "struct.pack.__class__.__dict__.__contains__('__bool__')==False / unpack.__class__.__dict__.__contains__('__int__')==False / calcsize.__class__.__dict__.__contains__('__index__')==False / pack.__class__.__dict__.__contains__('__int__')==False — struct.pack/unpack/calcsize are module-level builtin_function_or_method objects (C functions from Modules/_struct.c); pack.__class__.__name__=='builtin_function_or_method'; the builtin_function_or_method type's __dict__ does not contain __bool__ (function objects have no custom truthiness — all are truthy via object default); does not contain __int__ (functions are not integer-coercible); does not contain __index__ (functions cannot serve as sequence indices); pack/unpack/calcsize all share the same builtin_function_or_method type; contrasts with Struct and error which are custom C extension types — but all three (Struct/error/builtin_function_or_method) lack coercion dunders in their own __dict__; first st2521 anchor for struct module function class coercion-dunder absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2521

  columns: [id, function, args, expected]
  rows:
    - ["st2521_pack_cls_no_bool",   "pack.__class__.__dict__.__contains__",     ["__bool__"],  false]
    - ["st2521_unpack_cls_no_int",  "unpack.__class__.__dict__.__contains__",   ["__int__"],   false]
    - ["st2521_calc_cls_no_index",  "calcsize.__class__.__dict__.__contains__", ["__index__"], false]
    - ["st2521_pack_cls_no_int",    "pack.__class__.__dict__.__contains__",     ["__int__"],   false]
