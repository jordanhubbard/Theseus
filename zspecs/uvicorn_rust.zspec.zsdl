spec: uvicorn_rust
version: ">=3.9"
backend: rust_module(uvicorn_rust)

docs: https://www.uvicorn.org/

provenance:
  derived_from:
    - "https://www.uvicorn.org/ — Uvicorn documentation"
  not_derived_from:
    - "uvicorn source: uvicorn/__init__.py"
  notes:
    - "Uvicorn is a lightning-fast ASGI server."
    - "uvicorn.config.Config is available."
    - "uvicorn.__version__ is a non-empty string."
    - "uvicorn.config.Config(app='app:app').app == 'app:app'."
    - "uvicorn.config.Config(app='app:app', host='0.0.0.0').host == '0.0.0.0'."
    - "Expose uvicorn_config_host(app, host) -> str: uvicorn.config.Config(app=app, host=host).host."
    - "Expose uvicorn_version_nonempty() -> bool: len(uvicorn.__version__) > 0."
    - "Expose uvicorn_has_config() -> bool: hasattr(uvicorn, 'config')."
    - "All test vectors verified against uvicorn 0.34.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# uvicorn_config_host — host parameter
table uvicorn_rust.config.host:
  kind: python_call_eq
  category: host
  id_prefix: uvi_h
  function: uvicorn_config_host

  columns: [id, args, expected]
  rows:
    - [localhost, ["app:app", "127.0.0.1"], "127.0.0.1"]
    - [any,       ["app:app", "0.0.0.0"],   "0.0.0.0"]

# uvicorn_version_nonempty — version non-empty
invariant uvicorn_rust.version.nonempty:
  description: "uvicorn.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: uvicorn_version_nonempty
  args: []
  expected: true

# uvicorn_has_config — config module present
invariant uvicorn_rust.module.has_config:
  description: "uvicorn.config is available"
  category: module
  kind: python_call_eq
  function: uvicorn_has_config
  args: []
  expected: true

