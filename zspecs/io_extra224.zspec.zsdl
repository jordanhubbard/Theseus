spec: io_extra224
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: class __name__ values for io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.TextIOWrapper; abstract base class __name__ values for io.BufferedIOBase, io.RawIOBase, io.TextIOBase, io.IOBase; SEEK_SET/SEEK_CUR/SEEK_END constant integer values; io.DEFAULT_BUFFER_SIZE value; module __name__ constant."
    - "io.BytesIO.__name__ == 'BytesIO' — concrete class name."
    - "io.StringIO.__name__ == 'StringIO' — concrete class name."
    - "io.FileIO.__name__ == 'FileIO' — concrete class name."
    - "io.BufferedReader.__name__ == 'BufferedReader' — concrete class name."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' — concrete class name."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — concrete class name."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' — abstract base class name."
    - "io.RawIOBase.__name__ == 'RawIOBase' — abstract base class name."
    - "io.TextIOBase.__name__ == 'TextIOBase' — abstract base class name."
    - "io.IOBase.__name__ == 'IOBase' — root abstract base class name."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — standard seek mode constants."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB) — default buffer allocation size."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Concrete class __name__ attributes
# BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper are
# the six primary concrete I/O classes exposed by the io module.
# ---------------------------------------------------------------------------

table io_extra224.concrete_class_names:
  description: "Class __name__ values for the six primary concrete io classes"
  kind: python_call_eq
  category: class_names
  id_prefix: iocnames224

  columns: [id, function, args, expected]
  rows:
    - [bytesio_name,   BytesIO.__name__.__eq__,       ["BytesIO"],       true]
    - [stringio_name,  StringIO.__name__.__eq__,      ["StringIO"],      true]
    - [fileio_name,    FileIO.__name__.__eq__,         ["FileIO"],        true]
    - [bufrd_name,     BufferedReader.__name__.__eq__, ["BufferedReader"], true]
    - [bufwr_name,     BufferedWriter.__name__.__eq__, ["BufferedWriter"], true]
    - [textiow_name,   TextIOWrapper.__name__.__eq__,  ["TextIOWrapper"],  true]

# ---------------------------------------------------------------------------
# Abstract base class __name__ attributes
# io.BufferedIOBase, io.RawIOBase, io.TextIOBase, io.IOBase are the four
# abstract base classes in the io hierarchy. Their __name__ values are the
# unmangled public names even though the C implementations are in _io.
# ---------------------------------------------------------------------------

table io_extra224.abstract_base_class_names:
  description: "Class __name__ values for the four io abstract base classes"
  kind: python_call_eq
  category: class_names
  id_prefix: ioabcnames224

  columns: [id, function, args, expected]
  rows:
    - [bufiobase_name,  BufferedIOBase.__name__.__eq__, ["BufferedIOBase"], true]
    - [rawiobase_name,  RawIOBase.__name__.__eq__,      ["RawIOBase"],      true]
    - [textiobase_name, TextIOBase.__name__.__eq__,     ["TextIOBase"],     true]
    - [iobase_name,     IOBase.__name__.__eq__,         ["IOBase"],         true]

# ---------------------------------------------------------------------------
# SEEK mode constants
# io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 match POSIX lseek(2)
# whence values. They are plain int objects.
# ---------------------------------------------------------------------------

table io_extra224.seek_constants:
  description: "SEEK_SET, SEEK_CUR, SEEK_END constant integer values"
  kind: python_call_eq
  category: constants
  id_prefix: ioseek224

  columns: [id, function, args, expected]
  rows:
    - [seek_set_val,  SEEK_SET.__eq__, [0], true]
    - [seek_cur_val,  SEEK_CUR.__eq__, [1], true]
    - [seek_end_val,  SEEK_END.__eq__, [2], true]

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE and module __name__
# DEFAULT_BUFFER_SIZE == 131072 (128 KiB). The io module __name__ is 'io'.
# ---------------------------------------------------------------------------

invariant io_extra224.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer allocation size is 128 KiB"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra224.module_name:
  description: "io.__name__ == 'io' — the module's own name attribute"
  category: constants
  kind: python_call_eq
  function: __name__.__eq__
  args: ["io"]
  expected: true

invariant io_extra224.BytesIO.class_name:
  description: "io.BytesIO.__name__ == 'BytesIO'"
  category: class_names
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra224.IOBase.class_name:
  description: "io.IOBase.__name__ == 'IOBase' — the root abstract base class of the io hierarchy"
  category: class_names
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra224.SEEK_SET.is_zero:
  description: "io.SEEK_SET == 0 — seek from beginning of stream"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra224.SEEK_END.is_two:
  description: "io.SEEK_END == 2 — seek from end of stream"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true
