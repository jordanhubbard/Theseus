spec: retry_rust
version: ">=3.9"
backend: rust_module(retry_rust)

docs: https://github.com/invl/retry

provenance:
  derived_from:
    - "https://github.com/invl/retry — retry decorator library"
  notes:
    - "retry provides @retry decorator."
    - "retry.api.retry is callable."
    - "retry has retry_call function."
    - "retry.__version__ is non-empty string."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant retry_rust.has_retry:
  description: "retry module has retry decorator"
  category: presence
  kind: python_call_eq
  function: retry_has_retry
  args: []
  expected: true

invariant retry_rust.has_retry_call:
  description: "retry module has retry_call function"
  category: presence
  kind: python_call_eq
  function: retry_has_retry_call
  args: []
  expected: true

invariant retry_rust.version_nonempty:
  description: "retry version is non-empty"
  category: version
  kind: python_call_eq
  function: retry_version_nonempty
  args: []
  expected: true

