spec: asyncio_extra108
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec extends asyncio_extra107.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio.Handle and asyncio.TimerHandle class identity, and asyncio.AbstractEventLoop and asyncio.AbstractServer class identity. NEW in extra108: asyncio.Handle.__name__=='Handle', __module__=='asyncio.events', __bases__[0].__name__=='object', __mro__.__len__()==2 (inherits directly from object); type(asyncio.Handle).__name__=='type' (metaclass is type); asyncio.Handle.__qualname__=='Handle' (len=6); asyncio.TimerHandle.__name__=='TimerHandle', __bases__[0].__name__=='Handle' (mro len=3); asyncio.TimerHandle.__qualname__=='TimerHandle' (len=11); asyncio.AbstractEventLoop.__name__=='AbstractEventLoop', __bases__[0].__name__=='object', __mro__.__len__()==2; asyncio.AbstractEventLoop.__qualname__.__len__()==17; asyncio.AbstractServer.__name__=='AbstractServer', __bases__[0].__name__=='object', __mro__.__len__()==2; asyncio.AbstractServer.__qualname__.__len__()==14. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Handle.__bases__[0].__name__ == 'object'. Handle is the concrete class representing a scheduled callback; it inherits directly from object with MRO [Handle, object] (length=2). TimerHandle subclasses Handle (MRO length=3). type(asyncio.Handle).__name__=='type' (plain metaclass). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle'. TimerHandle extends Handle to represent a time-scheduled callback; MRO=[TimerHandle, Handle, object] (length=3). TimerHandle.__qualname__.__len__()==11 ('TimerHandle'=11). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object'. AbstractEventLoop inherits directly from object (MRO length=2). AbstractEventLoop.__qualname__.__len__()==17 ('AbstractEventLoop'=17). asyncio.AbstractServer.__bases__[0].__name__=='object' (MRO length=2). AbstractServer.__qualname__.__len__()==14 ('AbstractServer'=14). Both are in asyncio.events module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Handle and asyncio.TimerHandle class identity — extra108
#
# Wave 254 theme: Handle and TimerHandle class identity.
#
# asyncio.Handle.__name__                    == 'Handle'       (mro len=2, base=object)
# asyncio.Handle.__module__                  == 'asyncio.events'
# asyncio.TimerHandle.__bases__[0].__name__  == 'Handle'       (mro len=3)
# type(asyncio.Handle).__name__              == 'type'
# ---------------------------------------------------------------------------

table asyncio_extra108.asyncio_handle_identity:
  description: "asyncio.Handle and asyncio.TimerHandle class identity checks in asynciohandle108 namespace — wave 254 theme: asyncio.Handle.__name__.__eq__('Handle')==True (len=6); asyncio.Handle.__module__.__eq__('asyncio.events')==True; asyncio.Handle.__bases__[0].__name__.__eq__('object')==True (Handle inherits directly from object, MRO=[Handle, object], length=2 — shortest in spec); asyncio.Handle.__qualname__.__eq__('Handle')==True (len=6, shortest qualname in spec); type(asyncio.Handle).__name__.__eq__('type')==True (metaclass is plain 'type', not ABCMeta or any custom metaclass); asyncio.TimerHandle.__name__.__eq__('TimerHandle')==True (len=11); asyncio.TimerHandle.__module__.__eq__('asyncio.events')==True; asyncio.TimerHandle.__bases__[0].__name__.__eq__('Handle')==True (TimerHandle inherits from Handle, MRO=[TimerHandle, Handle, object], length=3); asyncio.TimerHandle.__qualname__.__eq__('TimerHandle')==True (len=11); Handle.__mro__.__len__()==2; TimerHandle.__mro__.__len__()==3; verified with Python 3.14.3"
