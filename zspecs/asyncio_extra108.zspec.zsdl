    - [th_qn_len,      asyncio.TimerHandle.__qualname__.__len__,                 [],                   11,   "asyncio.TimerHandle.__qualname__.__len__() == 11 ('TimerHandle'=11); verified with Python 3.14.3"]
    - [as_qn_len2,     asyncio.AbstractServer.__qualname__.__len__,              [],                   14,   "asyncio.AbstractServer.__qualname__.__len__() == 14 ('AbstractServer'=14); verified with Python 3.14.3"]
    - [ael_qn_len2,    asyncio.AbstractEventLoop.__qualname__.__len__,           [],                   17,   "asyncio.AbstractEventLoop.__qualname__.__len__() == 17 ('AbstractEventLoop'=17, longest in spec); verified with Python 3.14.3"]
    - [h_name_len,     asyncio.Handle.__name__.__len__,                          [],                   6,    "asyncio.Handle.__name__.__len__() == 6 ('Handle'=6); verified with Python 3.14.3"]
    - [th_name_len,    asyncio.TimerHandle.__name__.__len__,                     [],                   11,   "asyncio.TimerHandle.__name__.__len__() == 11 ('TimerHandle'=11); verified with Python 3.14.3"]
