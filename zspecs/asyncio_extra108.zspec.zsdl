# ---------------------------------------------------------------------------
# Standalone invariants — extra108
# ---------------------------------------------------------------------------

invariant asyncio_extra108.Handle_base_is_object:
  description: "asyncio.Handle.__bases__[0].__name__.__eq__('object') returns True — Handle inherits directly from object with MRO [Handle, object] (length=2 — tied with AbstractEventLoop and AbstractServer for shortest MRO in spec); Handle.__module__=='asyncio.events'; Handle.__qualname__=='Handle' (len=6, shortest qualname in spec); type(asyncio.Handle).__name__=='type' (plain metaclass, not ABCMeta); Handle is the concrete class representing a scheduled callback in the event loop; TimerHandle subclasses Handle (MRO length=3); NEW in extra108: first standalone Handle base invariant in asynciohandle108 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.Handle.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra108.TimerHandle_base_is_Handle:
  description: "asyncio.TimerHandle.__bases__[0].__name__.__eq__('Handle') returns True — TimerHandle inherits from Handle giving MRO [TimerHandle, Handle, object] (length=3 — the only class in this spec with mro length=3); TimerHandle.__module__=='asyncio.events'; TimerHandle.__qualname__=='TimerHandle' (len=11); Handle.__mro__.__len__()==2 (shorter — Handle is the base); AbstractEventLoop and AbstractServer both also have mro len=2 (like Handle); TimerHandle is used for time-based scheduled callbacks (created by call_later/call_at); the mro length difference: Handle=2 vs TimerHandle=3 reflects the inheritance relationship; NEW in extra108: first standalone TimerHandle base invariant in asynciohandle108 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.TimerHandle.__bases__[0].__name__.__eq__"
  args: ["Handle"]
  expected: true

invariant asyncio_extra108.AbstractEventLoop_mro_len_2:
  description: "asyncio.AbstractEventLoop.__mro__.__len__() == 2 — AbstractEventLoop inherits directly from object: MRO=[AbstractEventLoop, object] (length=2); AbstractEventLoop.__module__=='asyncio.events'; AbstractEventLoop.__qualname__.__len__()==17 ('AbstractEventLoop'=17, longest qualname in spec); AbstractEventLoop is the abstract base class defining the full event loop interface (run_forever, run_until_complete, stop, etc.); compare mro lengths: Handle=2 (tied), AbstractEventLoop=2 (tied), AbstractServer=2 (tied), TimerHandle=3 (only one with mro len=3); AbstractEventLoop has mro len=2 despite being the most complex class in the spec because it uses no inheritance-based abstraction; NEW in extra108: first standalone AbstractEventLoop mro length invariant in asynciohandle108 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra108.AbstractEventLoop_qualname_len_17:
  description: "asyncio.AbstractEventLoop.__qualname__.__len__() == 17 — 'AbstractEventLoop' = 'Abstract'=8 + 'EventLoop'=9 = 17; this is the longest class qualname in this spec; compare qualname lengths: Handle=6 (shortest), TimerHandle=11, AbstractServer=14, AbstractEventLoop=17 (longest); AbstractEventLoop.__module__=='asyncio.events'; AbstractEventLoop.__bases__[0].__name__=='object' (mro len=2); qualname length 17 > AbstractServer=14 by 3 chars ('EventLoop'=9 vs 'Server'=6); AbstractEventLoop defines the abstract interface for all asyncio event loop implementations; NEW in extra108: first standalone AbstractEventLoop qualname length invariant in asynciohandle108 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__qualname__.__len__
  args: []
  expected: 17

invariant asyncio_extra108.Handle_metaclass_is_type:
  description: "type(asyncio.Handle).__name__.__eq__('type') returns True — asyncio.Handle uses the plain 'type' metaclass (not ABCMeta or any custom metaclass); compare: asyncio.AbstractEventLoop and asyncio.AbstractServer also use plain 'type' metaclass despite being named 'Abstract*'; this is because asyncio abstract classes use duck typing rather than ABCMeta-based abstraction for their abstract interfaces; Handle.__name__=='Handle' (len=6); Handle.__module__=='asyncio.events'; Handle.__mro__.__len__()==2; Handle is the class returned by loop.call_soon(), loop.call_later() etc. and represents a scheduled callback that can be cancelled; NEW in extra108: first standalone Handle metaclass invariant in asynciohandle108 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(asyncio.Handle).__name__.__eq__
  args: ["type"]
  expected: true

