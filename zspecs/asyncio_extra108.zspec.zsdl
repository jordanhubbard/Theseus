# ---------------------------------------------------------------------------
# asyncio Handle/AbstractEventLoop qualname length comparisons — extra108
#
# Wave 254 theme: qualname length ordering across the four classes.
#
# Handle.__qualname__.__len__()             == 6   (shortest)
# TimerHandle.__qualname__.__len__()        == 11
# AbstractServer.__qualname__.__len__()     == 14
# AbstractEventLoop.__qualname__.__len__()  == 17  (longest)
# ---------------------------------------------------------------------------

table asyncio_extra108.asyncio_handle_ael_qualname_lengths:
  description: "asyncio Handle/AbstractEventLoop qualname length comparison checks in asynciohandle108 namespace — wave 254 theme: comparing qualname lengths across Handle, TimerHandle, AbstractServer, and AbstractEventLoop; asyncio.Handle.__qualname__.__len__()==6 (shortest — 'Handle'=6); asyncio.TimerHandle.__qualname__.__len__()==11 ('TimerHandle'=11); asyncio.AbstractServer.__qualname__.__len__()==14 ('AbstractServer'=14); asyncio.AbstractEventLoop.__qualname__.__len__()==17 (longest — 'AbstractEventLoop'=17); length ordering: Handle=6 < TimerHandle=11 < AbstractServer=14 < AbstractEventLoop=17; all four classes have __module__=='asyncio.events'; Handle and AbstractEventLoop each have mro len=2 (shortest); TimerHandle has mro len=3 (inherits from Handle); AbstractServer has mro len=2; Handle.__name__.__eq__('Handle')==True (len=6 matches qualname len since top-level); TimerHandle.__name__.__eq__('TimerHandle')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciohandle108b

  columns: [id, function, args, expected, description]
  rows:
