spec: random_extra6
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl, random_extra.zspec.zsdl, random_extra2.zspec.zsdl, random_extra3.zspec.zsdl, random_extra4.zspec.zsdl, and random_extra5.zspec.zsdl."
    - "random_extra5 covers __qualname__ for Random/SystemRandom (as invariants) and gauss/expovariate/betavariate."
    - "random_extra3/4 cover __module__ for Random and SystemRandom."
    - "This spec adds __qualname__ for the remaining module-level functions: random/randint/randrange/choice/choices/shuffle/sample/uniform/seed/getstate/setstate."
    - "For pure-Python methods defined at module level, __qualname__ equals __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — core sampling / selection functions
# random_extra5 covers gauss/expovariate/betavariate __qualname__ as invariants
# and Random/SystemRandom __qualname__ as invariants.
# This table adds the remaining module-level functions.
# ---------------------------------------------------------------------------

table random_extra6.qualnames_sampling:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [random,   random.__qualname__.__eq__,   ["random"],   true]
    - [randint,  randint.__qualname__.__eq__,  ["randint"],  true]
    - [randrange, randrange.__qualname__.__eq__, ["randrange"], true]
    - [choice,   choice.__qualname__.__eq__,   ["choice"],   true]
    - [choices,  choices.__qualname__.__eq__,  ["choices"],  true]
    - [shuffle,  shuffle.__qualname__.__eq__,  ["shuffle"],  true]
    - [sample,   sample.__qualname__.__eq__,   ["sample"],   true]
    - [uniform,  uniform.__qualname__.__eq__,  ["uniform"],  true]

# ---------------------------------------------------------------------------
# __qualname__ checks — state management functions
# seed/getstate/setstate __name__ is covered in prior specs;
# __qualname__ for these three is new.
# ---------------------------------------------------------------------------

table random_extra6.qualnames_state:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [seed,     seed.__qualname__.__eq__,     ["seed"],     true]
    - [getstate, getstate.__qualname__.__eq__, ["getstate"], true]
    - [setstate, setstate.__qualname__.__eq__, ["setstate"], true]
