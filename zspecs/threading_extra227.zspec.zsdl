invariant threading_extra227.dict_contains_lock:
  description: "threading.__dict__.__contains__('Lock') == True — Lock is in module dict; new to extra227"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra227.dict_contains_rlock:
  description: "threading.__dict__.__contains__('RLock') == True — RLock is in module dict; new to extra227"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["RLock"]
  expected: true

invariant threading_extra227.dict_contains_local:
  description: "threading.__dict__.__contains__('local') == True — local is in module dict; new to extra227"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["local"]
  expected: true

invariant threading_extra227.dict_contains_current_thread:
  description: "threading.__dict__.__contains__('current_thread') == True — current_thread is in module dict; new to extra227"
