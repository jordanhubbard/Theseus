spec: threading_extra227
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading module __dict__ membership checks for all major public names including synchronization primitives and module-level functions."
    - "threading.__dict__.__contains__('Thread') == True — Thread is a public class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Semaphore') == True — Semaphore is a public class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('BoundedSemaphore') == True — BoundedSemaphore is a public class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Condition') == True — Condition is a public class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Event') == True — Event is a public class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Timer') == True — Timer is a public class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Barrier') == True — Barrier is a public class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Lock') == True — Lock is a factory function returning a lock object in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('RLock') == True — RLock is a class in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('local') == True — local is a class for thread-local data in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('current_thread') == True — current_thread is a module-level function in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('active_count') == True — active_count is a module-level function in threading. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('enumerate') == True — enumerate is a module-level function in threading. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__dict__.__contains__ — thread and lock primitives
#
# threading.__dict__.__contains__('Thread') == True
# threading.__dict__.__contains__('Lock') == True
# threading.__dict__.__contains__('RLock') == True
# threading.__dict__.__contains__('local') == True
# threading.__dict__.__contains__('Semaphore') == True
#
# These are the primary thread and lock primitives. New to extra227.
# ---------------------------------------------------------------------------

table threading_extra227.module_dict_contains_primitives:
  description: "threading.__dict__.__contains__: Thread True, Lock True, RLock True, local True, Semaphore True; thread/lock primitives; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra227dictprim

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_thread,
       __dict__.__contains__,
       ["Thread"],
       true,
       "threading.__dict__.__contains__('Thread') == True — Thread is a public class registered in the threading module dict; it represents a thread of control; dict.__contains__('Thread') returns True; new to extra227"]
    - [dict_contains_lock,
       __dict__.__contains__,
       ["Lock"],
       true,
       "threading.__dict__.__contains__('Lock') == True — Lock is a factory function registered in the threading module dict; it returns a primitive lock object; dict.__contains__('Lock') returns True; new to extra227"]
    - [dict_contains_rlock,
       __dict__.__contains__,
       ["RLock"],
       true,
       "threading.__dict__.__contains__('RLock') == True — RLock is a class registered in the threading module dict; it represents a reentrant lock that can be acquired multiple times by the same thread; dict.__contains__('RLock') returns True; new to extra227"]
    - [dict_contains_local,
       __dict__.__contains__,
       ["local"],
       true,
       "threading.__dict__.__contains__('local') == True — local is a class registered in the threading module dict; it provides thread-local data storage with a separate instance per thread; dict.__contains__('local') returns True; new to extra227"]
    - [dict_contains_semaphore,
       __dict__.__contains__,
       ["Semaphore"],
       true,
       "threading.__dict__.__contains__('Semaphore') == True — Semaphore is a public class registered in the threading module dict; it manages a counter representing the number of available resources; dict.__contains__('Semaphore') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Table 2: threading.__dict__.__contains__ — higher-level synchronization
#
# threading.__dict__.__contains__('BoundedSemaphore') == True
# threading.__dict__.__contains__('Condition') == True
# threading.__dict__.__contains__('Event') == True
# threading.__dict__.__contains__('Timer') == True
# threading.__dict__.__contains__('Barrier') == True
#
# These are higher-level synchronization primitives. New to extra227.
# ---------------------------------------------------------------------------

table threading_extra227.module_dict_contains_sync:
  description: "threading.__dict__.__contains__: BoundedSemaphore True, Condition True, Event True, Timer True, Barrier True; synchronization; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra227dictsync

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_bounded_semaphore,
       __dict__.__contains__,
       ["BoundedSemaphore"],
       true,
       "threading.__dict__.__contains__('BoundedSemaphore') == True — BoundedSemaphore is a public class registered in the threading module dict; it is a semaphore that raises ValueError if released more times than acquired; dict.__contains__('BoundedSemaphore') returns True; new to extra227"]
    - [dict_contains_condition,
       __dict__.__contains__,
       ["Condition"],
       true,
       "threading.__dict__.__contains__('Condition') == True — Condition is a public class registered in the threading module dict; it implements a condition variable for thread coordination; dict.__contains__('Condition') returns True; new to extra227"]
    - [dict_contains_event,
       __dict__.__contains__,
       ["Event"],
       true,
       "threading.__dict__.__contains__('Event') == True — Event is a public class registered in the threading module dict; it implements a flag that threads can wait on or set; dict.__contains__('Event') returns True; new to extra227"]
    - [dict_contains_timer,
       __dict__.__contains__,
       ["Timer"],
       true,
       "threading.__dict__.__contains__('Timer') == True — Timer is a public class registered in the threading module dict; it represents an action that runs after a delay; dict.__contains__('Timer') returns True; new to extra227"]
    - [dict_contains_barrier,
       __dict__.__contains__,
       ["Barrier"],
       true,
       "threading.__dict__.__contains__('Barrier') == True — Barrier is a public class registered in the threading module dict; it allows a fixed number of threads to synchronize at a barrier point; dict.__contains__('Barrier') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Table 3: threading.__dict__.__contains__ — module-level functions
#
# threading.__dict__.__contains__('current_thread') == True
# threading.__dict__.__contains__('active_count') == True
# threading.__dict__.__contains__('enumerate') == True
#
# These are module-level utility functions. New to extra227.
# ---------------------------------------------------------------------------

table threading_extra227.module_dict_contains_functions:
  description: "threading.__dict__.__contains__: current_thread True, active_count True, enumerate True; module-level functions; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra227dictfn

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_current_thread,
       __dict__.__contains__,
       ["current_thread"],
       true,
       "threading.__dict__.__contains__('current_thread') == True — current_thread is a module-level function registered in the threading module dict; it returns the Thread object for the calling thread; dict.__contains__('current_thread') returns True; new to extra227"]
    - [dict_contains_active_count,
       __dict__.__contains__,
       ["active_count"],
       true,
       "threading.__dict__.__contains__('active_count') == True — active_count is a module-level function registered in the threading module dict; it returns the number of Thread objects currently alive; dict.__contains__('active_count') returns True; new to extra227"]
    - [dict_contains_enumerate,
       __dict__.__contains__,
       ["enumerate"],
       true,
       "threading.__dict__.__contains__('enumerate') == True — enumerate is a module-level function registered in the threading module dict; it returns a list of all currently alive Thread objects; dict.__contains__('enumerate') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra227
# ---------------------------------------------------------------------------

invariant threading_extra227.dict_contains_thread:
  description: "threading.__dict__.__contains__('Thread') == True — Thread is in module dict; new to extra227"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra227.dict_contains_semaphore:
  description: "threading.__dict__.__contains__('Semaphore') == True — Semaphore is in module dict; new to extra227"
