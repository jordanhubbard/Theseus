spec: struct_extra267
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/struct.py"
    - "struct_extra266.zspec.zsdl — covers struct module __spec__/__loader__ identity and _struct C extension identity."
    - "struct_extra263.zspec.zsdl — covers struct.error class identity and pack/unpack error cases."
  notes:
    - "hasattr(struct, '__all__') == True — struct exposes __all__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(struct.__all__).__name__ == 'list' — struct.__all__ is a list. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(struct.__all__) == 8 — struct.__all__ has 8 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "issubclass(struct.error, Exception) == True — struct.error is a subclass of Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(struct.error.__mro__) == 4 — struct.error MRO is [error, Exception, BaseException, object]. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!I', 'string') raises struct.error — wrong argument type. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack('!II', b'\\x00\\x00\\x00\\x01') raises struct.error — buffer too short (4 bytes provided, 8 required). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!Z') raises struct.error — 'Z' is an invalid format character. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error MRO length and class hierarchy
# struct.error inherits from Exception directly.
# MRO: [struct.error, Exception, BaseException, object] — length 4.
# struct.__all__ is a list of 8 public names.
# ---------------------------------------------------------------------------

table struct_extra267.error_mro_and_all:
  description: "struct.error MRO length and struct.__all__ identity — error.__mro__ has length 4; error inherits from Exception; struct.__all__.__class__.__name__/'list'; len(struct.__all__) == 8; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structmro267

  columns: [id, function, args, expected, description]
  rows:
    - [mro_len,      error.__mro__.__len__,                    [],             4,    "len(struct.error.__mro__) == 4 — MRO is [error, Exception, BaseException, object]"]
    - [base_name,    "error.__bases__[0].__name__.__eq__",     ["Exception"],  true, "struct.error.__bases__[0].__name__ == 'Exception' — directly inherits from Exception"]
    - [all_type,     __all__.__class__.__name__.__eq__,        ["list"],       true, "type(struct.__all__).__name__ == 'list' — struct.__all__ is a list"]
    - [all_len,      __all__.__len__,                          [],             8,    "len(struct.__all__) == 8 — struct.__all__ has 8 entries"]
    - [error_cls,    error.__class__.__name__.__eq__,          ["type"],       true, "struct.error.__class__.__name__ == 'type' — struct.error is a class (metaclass is type)"]

# ---------------------------------------------------------------------------
# Standalone invariants — struct.error hierarchy and error cases
# ---------------------------------------------------------------------------

invariant struct_extra267.error_mro_len_eq:
  description: "len(struct.error.__mro__) == 4 — struct.error MRO is [struct.error, Exception, BaseException, object]; four entries in the chain; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant struct_extra267.error_base_name_eq:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error directly subclasses Exception; not ValueError or TypeError; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant struct_extra267.all_type_eq:
  description: "type(struct.__all__).__name__ == 'list' — struct.__all__ is a plain Python list of public API name strings; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant struct_extra267.all_len_eq:
  description: "len(struct.__all__) == 8 — struct.__all__ contains 8 names: calcsize, pack, pack_into, unpack, unpack_from, iter_unpack, Struct, error; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 8

invariant struct_extra267.pack_wrong_type_raises:
  description: "struct.pack('!I', 'string') raises struct.error — format '!I' expects an integer but received a string; struct.error is raised for type mismatches; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["!I", "string"]
  raises: error

invariant struct_extra267.unpack_too_short_raises:
  description: "struct.unpack('!II', b'\\x00\\x00\\x00\\x01') raises struct.error — format '!II' requires 8 bytes but buffer has only 4 bytes; struct.error is raised for size mismatch; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: unpack
  args: ["!II", "b'\\x00\\x00\\x00\\x01'"]
  raises: error

invariant struct_extra267.calcsize_invalid_fmt_raises:
  description: "struct.calcsize('!Z') raises struct.error — 'Z' is not a valid struct format character; struct.error is raised for unrecognized format chars; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: calcsize
  args: ["!Z"]
  raises: error
