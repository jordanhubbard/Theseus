spec: theseus_path_node
version: ">=18"
backend: node_cleanroom(theseus_path_node)
blocks: path

docs: https://en.wikipedia.org/wiki/Path_(computing)

provenance:
  derived_from:
    - "https://en.wikipedia.org/wiki/Path_(computing) — filesystem path concepts"
  notes:
    - "Clean-room Node.js path module subset. Do NOT require('path') or any path library."
    - "Implement using pure JavaScript string operations only."
    - "path_join: join('a', 'b', 'c') returns 'a/b/c' — join with '/' separator."
    - "path_basename: basename('/foo/bar.txt') returns 'bar.txt'."
    - "path_dirname: dirname('/foo/bar.txt') returns '/foo'."
    - "Export all functions via module.exports."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_path_node.join_abc:
  description: "join('a', 'b', 'c') == 'a/b/c'"
  category: join
  kind: python_call_eq
  function: path_join
  args: ["a", "b", "c"]
  expected: "a/b/c"

invariant theseus_path_node.basename:
  description: "basename('/foo/bar.txt') == 'bar.txt'"
  category: basename
  kind: python_call_eq
  function: path_basename
  args: ["/foo/bar.txt"]
  expected: "bar.txt"

invariant theseus_path_node.dirname:
  description: "dirname('/foo/bar.txt') == '/foo'"
  category: dirname
  kind: python_call_eq
  function: path_dirname
  args: ["/foo/bar.txt"]
  expected: "/foo"
