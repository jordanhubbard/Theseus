spec: logging_extra23
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends prior logging specs through logging_extra22.zspec.zsdl."
    - "logging_extra21 covers: debug/info/warning/error/critical/exception/log __qualname__ as standalone invariants and table (module-level functions)."
    - "logging_extra22 covers: logging.__name__/__package__ and __mro__[-1].__name__ for all nine major logging classes."
    - "Focus: __qualname__ values of bound methods on logging.Logger, logging.Handler, and logging.Formatter classes."
    - "These are class-level method objects — their __qualname__ encodes the defining class name."
    - "logging.Logger.debug.__qualname__ == 'Logger.debug' — class-defined method."
    - "logging.Handler.emit.__qualname__ == 'Handler.emit' — abstract emit method on the base Handler class."
    - "logging.Formatter.format.__qualname__ == 'Formatter.format' — format method on the Formatter class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# logging.Logger method __qualname__ values
#
# Class-level method objects expose __qualname__ as '<ClassName>.<method>'.
# logging_extra21 recorded __qualname__ for module-level logging.debug etc.
# No prior logging spec records __qualname__ for the class-bound method
# objects Logger.debug, Logger.info, Logger.warning, Logger.error,
# Logger.critical, or Logger.exception.
# ---------------------------------------------------------------------------

invariant logging_extra23.Logger.debug.qualname:
  description: "logging.Logger.debug.__qualname__ == 'Logger.debug'"
  category: method_qualname
  kind: python_call_eq
  function: "Logger.debug.__qualname__.__eq__"
  args: ["Logger.debug"]
  expected: true

invariant logging_extra23.Logger.info.qualname:
  description: "logging.Logger.info.__qualname__ == 'Logger.info'"
  category: method_qualname
  kind: python_call_eq
  function: "Logger.info.__qualname__.__eq__"
  args: ["Logger.info"]
  expected: true

invariant logging_extra23.Logger.warning.qualname:
  description: "logging.Logger.warning.__qualname__ == 'Logger.warning'"
  category: method_qualname
  kind: python_call_eq
  function: "Logger.warning.__qualname__.__eq__"
  args: ["Logger.warning"]
  expected: true

invariant logging_extra23.Logger.error.qualname:
  description: "logging.Logger.error.__qualname__ == 'Logger.error'"
  category: method_qualname
  kind: python_call_eq
  function: "Logger.error.__qualname__.__eq__"
  args: ["Logger.error"]
  expected: true

invariant logging_extra23.Logger.critical.qualname:
  description: "logging.Logger.critical.__qualname__ == 'Logger.critical'"
  category: method_qualname
  kind: python_call_eq
  function: "Logger.critical.__qualname__.__eq__"
  args: ["Logger.critical"]
  expected: true

invariant logging_extra23.Logger.exception.qualname:
  description: "logging.Logger.exception.__qualname__ == 'Logger.exception'"
  category: method_qualname
  kind: python_call_eq
  function: "Logger.exception.__qualname__.__eq__"
  args: ["Logger.exception"]
  expected: true

# ---------------------------------------------------------------------------
# logging.Handler method __qualname__ values
#
# Handler.emit and Handler.handle are the two fundamental Handler methods.
# emit is abstract on the base class; handle wraps acquire/emit/release.
# No prior logging spec records __qualname__ for these class-bound methods.
# ---------------------------------------------------------------------------

invariant logging_extra23.Handler.emit.qualname:
  description: "logging.Handler.emit.__qualname__ == 'Handler.emit'"
  category: method_qualname
  kind: python_call_eq
  function: "Handler.emit.__qualname__.__eq__"
  args: ["Handler.emit"]
  expected: true

invariant logging_extra23.Handler.handle.qualname:
  description: "logging.Handler.handle.__qualname__ == 'Handler.handle'"
  category: method_qualname
  kind: python_call_eq
  function: "Handler.handle.__qualname__.__eq__"
  args: ["Handler.handle"]
  expected: true

# ---------------------------------------------------------------------------
# logging.Formatter method __qualname__ value
#
# Formatter.format is the primary formatting method.
# No prior logging spec records __qualname__ for this class-bound method.
# ---------------------------------------------------------------------------

invariant logging_extra23.Formatter.format.qualname:
  description: "logging.Formatter.format.__qualname__ == 'Formatter.format'"
  category: method_qualname
  kind: python_call_eq
  function: "Formatter.format.__qualname__.__eq__"
  args: ["Formatter.format"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all nine __qualname__ checks
#
# Covers Logger.debug/info/warning/error/critical/exception,
# Handler.emit/handle, and Formatter.format in a single table.
# ---------------------------------------------------------------------------

table logging_extra23.method_qualnames:
  description: "__qualname__ values for class-bound methods on Logger, Handler, Formatter"
  kind: python_call_eq
  category: method_qualname

  columns: [id, function, args, expected]
  rows:
    - [Logger.debug,      "Logger.debug.__qualname__.__eq__",      ["Logger.debug"],      true]
    - [Logger.info,       "Logger.info.__qualname__.__eq__",       ["Logger.info"],       true]
    - [Logger.warning,    "Logger.warning.__qualname__.__eq__",    ["Logger.warning"],    true]
    - [Logger.error,      "Logger.error.__qualname__.__eq__",      ["Logger.error"],      true]
    - [Logger.critical,   "Logger.critical.__qualname__.__eq__",   ["Logger.critical"],   true]
    - [Logger.exception,  "Logger.exception.__qualname__.__eq__",  ["Logger.exception"],  true]
    - [Handler.emit,      "Handler.emit.__qualname__.__eq__",      ["Handler.emit"],      true]
    - [Handler.handle,    "Handler.handle.__qualname__.__eq__",    ["Handler.handle"],    true]
    - [Formatter.format,  "Formatter.format.__qualname__.__eq__",  ["Formatter.format"],  true]
