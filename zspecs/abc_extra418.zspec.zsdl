spec: abc_extra418
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abc.ABC.__class__.__name__ == 'ABCMeta' (ABC is an instance of ABCMeta)"
    - "abc.ABCMeta.__subclasshook__.__name__ == '__subclasshook__'"
    - "abc.abstractmethod.__class__.__name__ == 'function' (abstractmethod is a plain function/decorator)"
    - "type.__subclasses__.__name__ == '__subclasses__' (ABCMeta inherits __subclasses__ from type)"
    - "abc.ABCMeta.__subclasshook__.__module__ is None (defined in C extension)"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra418.abc_metaclass_identity:
  description: "Verify that abc.ABC is an instance of ABCMeta (its __class__.__name__ is 'ABCMeta')"
  kind: python_call_eq
  category: identity
  id_prefix: abc418mi

  columns: [id, function, args, expected]
  rows:
    - [abc418mi001, abc.ABC.__class__.__name__.__eq__, ["ABCMeta"], true]

table abc_extra418.subclasshook_identity:
  description: "Verify __name__ of abc.ABCMeta.__subclasshook__"
  kind: python_call_eq
  category: identity
  id_prefix: abc418sh

  columns: [id, function, args, expected]
  rows:
    - [abc418sh001, abc.ABCMeta.__subclasshook__.__name__.__eq__, ["__subclasshook__"], true]

table abc_extra418.abstractmethod_class:
  description: "Verify that abc.abstractmethod is a plain function (its __class__.__name__ is 'function')"
  kind: python_call_eq
  category: identity
  id_prefix: abc418am

  columns: [id, function, args, expected]
  rows:
    - [abc418am001, abc.abstractmethod.__class__.__name__.__eq__, ["function"], true]

table abc_extra418.subclasses_builtin:
  description: "Verify __name__ of type.__subclasses__ (inherited by ABCMeta from type)"
  kind: python_call_eq
  category: identity
  id_prefix: abc418sc

  columns: [id, function, args, expected]
  rows:
    - [abc418sc001, type.__subclasses__.__name__.__eq__, ["__subclasses__"], true]
