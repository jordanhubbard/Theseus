spec: socket_extra255
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 255 theme: socket MSG_* flag constants — integer values and class identity."
    - "socket.MSG_OOB == 1. MSG_OOB is the out-of-band data flag. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_PEEK == 2. MSG_PEEK peeks at incoming data without consuming it. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_DONTROUTE == 4. MSG_DONTROUTE bypasses normal routing. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_EOR == 8. MSG_EOR marks end of record on macOS/BSD. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_TRUNC == 16. MSG_TRUNC indicates a datagram was truncated. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_CTRUNC == 32. MSG_CTRUNC indicates control message was truncated. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_WAITALL == 64. MSG_WAITALL requests blocking until full request satisfied. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_DONTWAIT == 128. MSG_DONTWAIT enables non-blocking operation on this call. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_EOF == 256. MSG_EOF is macOS/BSD-specific: fetch data, then close socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_NOSIGNAL == 524288. MSG_NOSIGNAL requests no SIGPIPE on send errors (macOS). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.MSG_OOB.__class__.__name__ == 'MsgFlag'. All MSG_* constants are MsgFlag IntFlag enum members. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.MsgFlag is an IntFlag enum in Python's socket module. Each MSG_* constant is a MsgFlag member with an integer value equal to the underlying OS constant. MsgFlag members support bitwise OR for combining flags."
    - "Note: These MSG_* constant values are macOS/BSD-specific. MSG_OOB, MSG_PEEK, MSG_DONTROUTE, MSG_TRUNC, MSG_CTRUNC, MSG_WAITALL are POSIX-defined. MSG_EOR, MSG_EOF are BSD extensions. MSG_DONTWAIT and MSG_NOSIGNAL are Linux-originated but also available on macOS."
    - "Note: MSG_NOSIGNAL value is 524288 (0x80000) on macOS/Darwin; this differs from Linux where it is typically 16384 (0x4000). The macOS value was verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.MSG_OOB.__eq__(1)
# socket.MSG_PEEK.__eq__(2)
# socket.MSG_DONTROUTE.__eq__(4)
# socket.MSG_EOR.__eq__(8)
# socket.MSG_TRUNC.__eq__(16)
#
# Wave 255 theme: socket MSG_* flag integer values (low range: 1-16).
#
# socket.MSG_OOB (1): out-of-band data, received on the urgent channel.
# socket.MSG_PEEK (2): peek at incoming data without removing it from the queue.
# socket.MSG_DONTROUTE (4): send without routing (direct interface delivery).
# socket.MSG_EOR (8): end-of-record marker (BSD/macOS extension).
# socket.MSG_TRUNC (16): datagram was truncated on receive because buffer too small.
# All are MsgFlag IntFlag enum members. Values match underlying macOS constants.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra255.MSG_flags_low:
  description: "socket MSG_* flag values (low range 1-16) — MSG_OOB==1/MSG_PEEK==2/MSG_DONTROUTE==4/MSG_EOR==8/MSG_TRUNC==16 — all MsgFlag IntFlag enum members; MSG_OOB receives out-of-band urgent data; MSG_PEEK peeks without consuming; MSG_DONTROUTE bypasses routing; MSG_EOR marks end-of-record (BSD); MSG_TRUNC indicates receive truncation; wave 255 theme; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: constant_identity
  id_prefix: sockmsg255a

  columns: [id, function, args, expected, description]
  rows:
    - [oob_val,       MSG_OOB.__eq__,       [1],  true, "socket.MSG_OOB == 1; out-of-band data flag; MsgFlag IntFlag member"]
    - [peek_val,      MSG_PEEK.__eq__,      [2],  true, "socket.MSG_PEEK == 2; peek at data without consuming; MsgFlag IntFlag member"]
    - [dontroute_val, MSG_DONTROUTE.__eq__, [4],  true, "socket.MSG_DONTROUTE == 4; bypass routing for send; MsgFlag IntFlag member"]
    - [eor_val,       MSG_EOR.__eq__,       [8],  true, "socket.MSG_EOR == 8; end-of-record marker (macOS/BSD extension); MsgFlag IntFlag member"]
    - [trunc_val,     MSG_TRUNC.__eq__,     [16], true, "socket.MSG_TRUNC == 16; datagram was truncated on receive; MsgFlag IntFlag member"]

# ---------------------------------------------------------------------------
# socket.MSG_CTRUNC.__eq__(32)
# socket.MSG_WAITALL.__eq__(64)
# socket.MSG_DONTWAIT.__eq__(128)
# socket.MSG_EOF.__eq__(256)
#
# Wave 255 theme: socket MSG_* flag integer values (mid range: 32-256).
#
# socket.MSG_CTRUNC (32): ancillary/control data was truncated on receive.
# socket.MSG_WAITALL (64): block until full request is satisfied (POSIX).
# socket.MSG_DONTWAIT (128): non-blocking for this call only (don't wait).
# socket.MSG_EOF (256): fetch data and then atomically close (BSD/macOS only).
# All are MsgFlag IntFlag enum members with macOS integer values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra255.MSG_flags_mid:
  description: "socket MSG_* flag values (mid range 32-256) — MSG_CTRUNC==32/MSG_WAITALL==64/MSG_DONTWAIT==128/MSG_EOF==256 — all MsgFlag IntFlag members; MSG_CTRUNC indicates truncated control message; MSG_WAITALL blocks until full data received (POSIX); MSG_DONTWAIT makes single call non-blocking; MSG_EOF fetches data and closes (BSD/macOS); wave 255 theme; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: constant_identity
  id_prefix: sockmsg255b

  columns: [id, function, args, expected, description]
  rows:
    - [ctrunc_val,    MSG_CTRUNC.__eq__,    [32],  true, "socket.MSG_CTRUNC == 32; ancillary/control data was truncated; MsgFlag IntFlag member"]
    - [waitall_val,   MSG_WAITALL.__eq__,   [64],  true, "socket.MSG_WAITALL == 64; block until full request satisfied (POSIX); MsgFlag IntFlag member"]
    - [dontwait_val,  MSG_DONTWAIT.__eq__,  [128], true, "socket.MSG_DONTWAIT == 128; non-blocking for this call only; MsgFlag IntFlag member"]
    - [eof_val,       MSG_EOF.__eq__,       [256], true, "socket.MSG_EOF == 256; fetch data then close socket (BSD/macOS only); MsgFlag IntFlag member"]

# ---------------------------------------------------------------------------
# socket.MSG_NOSIGNAL.__eq__(524288)
# socket.MSG_OOB.__class__.__name__.__eq__('MsgFlag')
# socket.MSG_PEEK.__class__.__name__.__eq__('MsgFlag')
# socket.MSG_WAITALL.__class__.__name__.__eq__('MsgFlag')
#
# Wave 255 theme: MSG_NOSIGNAL value and MSG_* class identity.
#
# socket.MSG_NOSIGNAL (524288 == 0x80000 on macOS): suppresses SIGPIPE signal
# on send errors when the peer has closed the connection. On Linux, MSG_NOSIGNAL
# is 16384; on macOS/Darwin it is 524288. The __class__.__name__ of all MSG_*
# constants is 'MsgFlag' — the Python IntFlag enum type for socket message flags.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra255.MSG_nosignal_and_class:
  description: "socket.MSG_NOSIGNAL==524288 (macOS) and MSG_* class identity — MSG_NOSIGNAL.__eq__(524288)==True / MSG_OOB/__class__/__name__.__eq__('MsgFlag')==True / MSG_PEEK/__class__/__name__.__eq__('MsgFlag')==True / MSG_WAITALL/__class__/__name__.__eq__('MsgFlag')==True — MSG_NOSIGNAL is 0x80000 on macOS (differs from Linux 0x4000); all MSG_* are MsgFlag IntFlag members; MsgFlag supports bitwise OR; wave 255 theme; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: constant_identity
  id_prefix: sockmsg255c

  columns: [id, function, args, expected, description]
  rows:
    - [nosignal_val,   MSG_NOSIGNAL.__eq__,                [524288],    true, "socket.MSG_NOSIGNAL == 524288 (0x80000 on macOS); suppresses SIGPIPE on broken pipe"]
    - [oob_class,      MSG_OOB.__class__.__name__.__eq__,  ["MsgFlag"], true, "socket.MSG_OOB.__class__.__name__ == 'MsgFlag'; IntFlag enum type for socket message flags"]
    - [peek_class,     MSG_PEEK.__class__.__name__.__eq__,  ["MsgFlag"], true, "socket.MSG_PEEK.__class__.__name__ == 'MsgFlag'; IntFlag enum type for socket message flags"]
    - [waitall_class,  MSG_WAITALL.__class__.__name__.__eq__, ["MsgFlag"], true, "socket.MSG_WAITALL.__class__.__name__ == 'MsgFlag'; IntFlag enum type for socket message flags"]

# ---------------------------------------------------------------------------
# socket.MSG_OOB.__eq__(1) — standalone
#
# socket.MSG_OOB == 1. MSG_OOB is the out-of-band data flag for recv() and
# send(). Out-of-band data (also called "urgent data") is a TCP mechanism that
# allows a single byte of high-priority data to be sent ahead of the normal
# data stream. The sender marks it with MSG_OOB in send() and the receiver
# reads it with MSG_OOB in recv(). OOB data is rarely used in modern protocols
# but is preserved for historical compatibility. MSG_OOB is a MsgFlag IntFlag
# member with integer value 1 (the lowest-order bit). This is the first
# standalone anchor for MSG_OOB value under sockmsg255a.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra255.MSG_OOB_value:
  description: "socket.MSG_OOB.__eq__(1) == True — MSG_OOB is the out-of-band urgent data flag; TCP OOB allows a single high-priority byte ahead of normal stream (rarely used in modern protocols); used in both send(data, MSG_OOB) and recv(bufsize, MSG_OOB); MsgFlag IntFlag member with value 1 (lowest-order bit); first standalone for MSG_OOB value under sockmsg255a; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_identity
  kind: python_call_eq
  function: MSG_OOB.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.MSG_PEEK.__eq__(2) — standalone
#
# socket.MSG_PEEK == 2. MSG_PEEK causes recv() to peek at the incoming data
# without removing it from the socket receive queue. The same data will be
# returned again on the next recv() call (with or without MSG_PEEK). This is
# useful for determining how many bytes are available or for inspecting data
# before committing to read it. MSG_PEEK does not consume the data — it is
# still in the buffer after the call. MSG_PEEK is a MsgFlag IntFlag member
# with integer value 2 (bit 1). This is the first standalone anchor for
# MSG_PEEK value under sockmsg255a. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra255.MSG_PEEK_value:
  description: "socket.MSG_PEEK.__eq__(2) == True — MSG_PEEK peeks at incoming data without removing it from the receive queue; same data is returned on next recv() call; useful for inspecting available data before consuming; MSG_PEEK does not consume buffered data; MsgFlag IntFlag member with value 2 (bit 1); first standalone for MSG_PEEK value under sockmsg255a; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_identity
  kind: python_call_eq
  function: MSG_PEEK.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.MSG_WAITALL.__eq__(64) — standalone
#
# socket.MSG_WAITALL == 64. MSG_WAITALL is a POSIX flag for recv() that
# requests that the call block until the full number of bytes requested are
# available. Without MSG_WAITALL, recv() may return fewer bytes than requested
# even if more are available (short reads). With MSG_WAITALL, recv() continues
# reading until the full bufsize bytes have been received or an error occurs.
# MSG_WAITALL is commonly used in protocol implementations to guarantee that
# fixed-size header or message structures are received completely. It is a
# MsgFlag IntFlag member with value 64 (bit 6). This is the first standalone
# anchor for MSG_WAITALL value under sockmsg255b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra255.MSG_WAITALL_value:
  description: "socket.MSG_WAITALL.__eq__(64) == True — MSG_WAITALL requests recv() to block until full requested bytes are available; without it, recv() may return short reads; with it, recv() loops until bufsize bytes received or error; POSIX-defined; commonly used for fixed-size protocol message framing; MsgFlag IntFlag member with value 64 (bit 6); first standalone for MSG_WAITALL value under sockmsg255b; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_identity
  kind: python_call_eq
  function: MSG_WAITALL.__eq__
  args: [64]
  expected: true
