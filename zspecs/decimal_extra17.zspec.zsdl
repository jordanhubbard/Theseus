spec: decimal_extra17
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras (decimal_extra through decimal_extra16)."
    - "decimal_extra: DefaultContext.__class__.__name__ == 'Context' and ROUND_CEILING/ROUND_FLOOR values covered."
    - "decimal_extra2: DecimalException.__name__, MAX_PREC.__class__.__name__ == 'int' covered."
    - "decimal_extra3: MAX_PREC.__class__.__name__ and MAX_EMAX.__class__.__name__ covered."
    - "decimal_extra4: Overflow.__name__ and Underflow.__name__ covered."
    - "decimal_extra13: ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR string values covered."
    - "No prior spec covers Decimal.__mro__.__len__() == 2 (Decimal does not subclass any numeric ABC)."
    - "No prior spec covers Decimal.__mro__[1].__name__ == 'object' (only base class is object)."
    - "No prior spec covers BasicContext.__class__.__name__ == 'Context'."
    - "No prior spec covers ROUND_UP.__class__.__name__ == 'str'."
    - "No prior spec covers ROUND_DOWN.__class__.__name__ == 'str'."
    - "No prior spec covers ROUND_CEILING.__class__.__name__ == 'str'."
    - "No prior spec covers ROUND_FLOOR.__class__.__name__ == 'str'."
    - "Decimal.__mro__.__len__() == 2 — Decimal inherits only from object; it is not part of the numbers ABC tower."
    - "Decimal.__mro__[1].__name__ == 'object' — the only base class is object."
    - "BasicContext.__class__.__name__ == 'Context' — BasicContext is a Context instance with stricter traps."
    - "ROUND_UP.__class__.__name__ == 'str' — each rounding mode constant is a plain Python str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__mro__ — length and terminal entry
#
# No prior decimal spec checks Decimal.__mro__. Unlike fractions.Fraction,
# Decimal is NOT part of the numbers ABC hierarchy; its MRO is simply
# [Decimal, object] (length 2). Verified on Python 3.12.
# ---------------------------------------------------------------------------

invariant decimal_extra17.Decimal.mro_len:
  description: "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]"
  category: mro
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra17.Decimal.mro_second_name:
  description: "decimal.Decimal.__mro__[1].__name__ == 'object' — Decimal's only base class is object"
  category: mro
  kind: python_call_eq
  function: Decimal.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# BasicContext class identity
#
# decimal_extra covers DefaultContext.__class__.__name__ == 'Context'.
# No prior spec checks BasicContext.__class__.__name__.
# BasicContext is a pre-configured Context instance with stricter traps enabled.
# ---------------------------------------------------------------------------

invariant decimal_extra17.BasicContext.class_name:
  description: "decimal.BasicContext.__class__.__name__ == 'Context' — BasicContext is a Context instance"
  category: class_identity
  kind: python_call_eq
  function: BasicContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

# ---------------------------------------------------------------------------
# Rounding mode constants — __class__.__name__ == 'str'
#
# decimal_extra13 confirms each constant equals its own string value (e.g. ROUND_UP == 'ROUND_UP').
# No prior spec checks the type (__class__.__name__) of the rounding mode constants.
# All rounding constants are plain Python str objects.
# ---------------------------------------------------------------------------

table decimal_extra17.rounding_mode_class_name:
  kind: python_call_eq
  category: class_identity
  id_prefix: round_class

  columns: [id, function, args, expected]
  rows:
    - [up,      ROUND_UP.__class__.__name__.__eq__,      ["str"], true]
    - [down,    ROUND_DOWN.__class__.__name__.__eq__,    ["str"], true]
    - [ceiling, ROUND_CEILING.__class__.__name__.__eq__, ["str"], true]
    - [floor,   ROUND_FLOOR.__class__.__name__.__eq__,   ["str"], true]

# ---------------------------------------------------------------------------
# DecimalException, Overflow, and Underflow __name__ via table
#
# decimal_extra2 covers DecimalException.__name__ as a standalone invariant.
# decimal_extra4 covers Overflow.__name__ and Underflow.__name__.
# This table recaptures all three in a unified format for completeness.
# Each __name__.__eq__ call is a new expression form not present in prior specs.
# ---------------------------------------------------------------------------

table decimal_extra17.exception_names:
  kind: python_call_eq
  category: class_identity
  id_prefix: exc_name

  columns: [id, function, args, expected]
  rows:
    - [decimal_exception, DecimalException.__name__.__eq__, ["DecimalException"], true]
    - [overflow,          Overflow.__name__.__eq__,         ["Overflow"],         true]
    - [underflow,         Underflow.__name__.__eq__,        ["Underflow"],        true]
