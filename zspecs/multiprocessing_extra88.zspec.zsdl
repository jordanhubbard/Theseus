# ---------------------------------------------------------------------------
# Standalone invariants — extra88
# ---------------------------------------------------------------------------

invariant multiprocessing_extra88.Pool_has_map:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('map') returns True — map() is defined directly on the Pool class in Lib/multiprocessing/pool.py; it applies a function to each item in an iterable using the worker processes; NEW in extra88: first standalone __dict__ map membership invariant for Pool in mpooldictmem88 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "pool.Pool.__dict__.__contains__"
  args: ["map"]
  expected: true

invariant multiprocessing_extra88.Pool_has_imap:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('imap') returns True — imap() is defined directly on the Pool class; it is a lazy iterator version of map that yields results as they are computed; NEW in extra88: first standalone __dict__ imap membership invariant for Pool in mpooldictmem88 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "pool.Pool.__dict__.__contains__"
  args: ["imap"]
  expected: true

invariant multiprocessing_extra88.Pool_has_close:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('close') returns True — close() is defined directly on the Pool class; it prevents any more tasks from being submitted to the pool; NEW in extra88: first standalone __dict__ close membership invariant for Pool in mpooldictmem88 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "pool.Pool.__dict__.__contains__"
  args: ["close"]
  expected: true

invariant multiprocessing_extra88.Pool_dict_is_mappingproxy:
  description: "multiprocessing.pool.Pool.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — the class __dict__ is a mappingproxy instance; this is the standard CPython implementation of class namespace objects, which are read-only views of the underlying dict; NEW in extra88: first standalone __dict__ class name invariant for Pool in mpooldictmem88 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: pool.Pool.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant multiprocessing_extra88.Pool_has_starmap:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('starmap') returns True — starmap() is defined directly on the Pool class; it is like map() but unpacks argument tuples from an iterable before passing them to the worker function; NEW in extra88: first standalone __dict__ starmap membership invariant for Pool in mpooldictmem88 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "pool.Pool.__dict__.__contains__"
  args: ["starmap"]
  expected: true
