spec: itertools_extra73
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra72.zspec.zsdl."
    - "Wave 239 theme: itertools module identity and __spec__ attributes."
    - "itertools.__name__ == 'itertools' — the itertools module's __name__ attribute. Verified with Python 3.14.3."
    - "itertools.__package__ == '' — C extension modules have __package__ as empty string. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec class name. Verified with Python 3.14.3."
    - "itertools.__spec__.name == 'itertools' — the spec name attribute equals the module name. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — itertools is a built-in C extension; its loader's class name is 'type'. Verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' — itertools has a str module docstring. Verified with Python 3.14.3."
    - "itertools.__doc__.__contains__('tools') == True — the itertools docstring reads 'Functional tools for creating and using iterators.' and contains 'tools'. Verified with Python 3.14.3."
    - "chain.__module__ == 'itertools' — chain is a C type whose __module__ is 'itertools'. Verified with Python 3.14.3."
    - "islice.__module__ == 'itertools' — islice is a C type whose __module__ is 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools module name and package — extra73
#
# Wave 239 theme: itertools module __name__ and __package__.
#
# itertools.__name__    == 'itertools'
# itertools.__package__ == ''  (C extension modules have empty string for __package__)
#
# No prior itertools spec checks module __name__ or __package__ via itertmod73. New to extra73.
# ---------------------------------------------------------------------------

table itertools_extra73.module_name_package:
  description: "itertools.__name__=='itertools', __package__==''; wave 239 module identity; new to extra73"
  kind: python_call_eq
  category: module_identity
  id_prefix: itertmod73

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq_itertools,
       __name__.__eq__,
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the itertools module's __name__ attribute stores the fully qualified module name as the str 'itertools' (9 chars); for a top-level module this equals the module's simple name; str.__eq__('itertools') returns True; no prior itertools spec checks __name__ via itertmod73; new to extra73"]
    - [module_package_eq_empty,
       __package__.__eq__,
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a C extension module (not a package); C extension modules that are not sub-packages have __package__ set to the empty string ''; str.__eq__('') returns True; no prior itertools spec checks __package__ via itertmod73; new to extra73"]

# ---------------------------------------------------------------------------
# itertools __spec__ attributes — extra73
#
# Wave 239 theme: itertools.__spec__.__class__.__name__ and spec.name.
#
# itertools.__spec__.__class__.__name__  == 'ModuleSpec'
# itertools.__spec__.name                == 'itertools'
# itertools.__loader__.__class__.__name__ == 'type'
#
# No prior itertools spec checks __spec__ attributes via itertmod73. New to extra73.
# ---------------------------------------------------------------------------

table itertools_extra73.module_spec:
  description: "itertools.__spec__.__class__.__name__=='ModuleSpec', __spec__.name=='itertools', __loader__.__class__.__name__=='type'; wave 239 module __spec__; new to extra73"
  kind: python_call_eq
  category: module_identity
  id_prefix: itertmod73

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every importable module has a __spec__ attribute that is an importlib.machinery.ModuleSpec instance; __class__.__name__ for ModuleSpec is 'ModuleSpec' (10 chars); str.__eq__('ModuleSpec') returns True; no prior itertools spec checks __spec__.__class__.__name__ via itertmod73; new to extra73"]
    - [spec_name_eq_itertools,
       __spec__.name.__eq__,
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec.name attribute stores the fully qualified module name; for the top-level itertools module this is 'itertools' (9 chars); str.__eq__('itertools') returns True; no prior itertools spec checks __spec__.name via itertmod73; new to extra73"]
    - [loader_class_name_eq_type,
       __loader__.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools is a built-in C extension module; its __loader__ is the built-in module loader whose __class__.__name__ is 'type' (4 chars); str.__eq__('type') returns True; no prior itertools spec checks __loader__.__class__.__name__ via itertmod73; new to extra73"]

# ---------------------------------------------------------------------------
# itertools __doc__ content — extra73
#
# Wave 239 theme: itertools module docstring is a str containing 'tools'.
#
# itertools.__doc__.__class__.__name__ == 'str'
# itertools.__doc__.__contains__('tools') == True
#   The docstring reads: 'Functional tools for creating and using iterators.'
#   NOTE: 'itertools' itself does NOT appear in the module docstring.
#
# No prior itertools spec checks module __doc__ via itertmod73. New to extra73.
# ---------------------------------------------------------------------------

table itertools_extra73.module_doc:
  description: "itertools.__doc__.__class__.__name__=='str', __contains__('tools')==True; wave 239 module __doc__; new to extra73"
  kind: python_call_eq
  category: module_doc
  id_prefix: itertmod73

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class_name_eq_str,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — the itertools module has a module-level docstring that is a Python str object; __class__.__name__ for str is 'str' (3 chars); str.__eq__('str') returns True; no prior itertools spec checks __doc__.__class__.__name__ via itertmod73; new to extra73"]
    - [module_doc_contains_tools,
       __doc__.__contains__,
       ["tools"],
       true,
       "itertools.__doc__.__contains__('tools') == True — the itertools module docstring reads 'Functional tools for creating and using iterators.' and contains the word 'tools' (5 chars); NOTE: 'itertools' itself does NOT appear in the module docstring; str.__contains__('tools') returns True; no prior itertools spec checks __doc__.__contains__ via itertmod73; new to extra73"]

# ---------------------------------------------------------------------------
# chain and islice __module__ — extra73
#
# Wave 239 theme: chain.__module__ and islice.__module__ are 'itertools'.
#
# chain.__module__  == 'itertools'
# islice.__module__ == 'itertools'
#
# No prior itertools spec checks chain/islice __module__ via itertmod73. New to extra73.
# ---------------------------------------------------------------------------

table itertools_extra73.chain_islice_module:
  description: "chain.__module__=='itertools', islice.__module__=='itertools'; wave 239 C type __module__; new to extra73"
  kind: python_call_eq
  category: module_identity
  id_prefix: itertmod73

  columns: [id, function, args, expected, description]
  rows:
    - [chain_module_eq_itertools,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute records the owning module as the str 'itertools' (9 chars); str.__eq__('itertools') returns True; no prior itertools spec checks chain.__module__ via itertmod73; new to extra73"]
    - [islice_module_eq_itertools,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute records the owning module as the str 'itertools' (9 chars); str.__eq__('itertools') returns True; no prior itertools spec checks islice.__module__ via itertmod73; new to extra73"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra73
# ---------------------------------------------------------------------------

invariant itertools_extra73.module_name:
  description: "itertools.__name__.__eq__('itertools') == True — module __name__ is 'itertools'; wave 239 module identity; new to extra73"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra73.module_package_empty:
  description: "itertools.__package__.__eq__('') == True — C extension module __package__ is empty string; wave 239 module identity; new to extra73"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra73.spec_name:
  description: "itertools.__spec__.name.__eq__('itertools') == True — __spec__.name is 'itertools'; wave 239 module __spec__; new to extra73"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra73.chain_module:
  description: "itertools.chain.__module__.__eq__('itertools') == True — chain.__module__ is 'itertools'; wave 239 C type __module__; new to extra73"
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra73.islice_module:
  description: "itertools.islice.__module__.__eq__('itertools') == True — islice.__module__ is 'itertools'; wave 239 C type __module__; new to extra73"
  kind: python_call_eq
  function: islice.__module__.__eq__
  args: ["itertools"]
  expected: true
