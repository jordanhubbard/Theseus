spec: functools_extra1366
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for functools classes."
    - "functools.partial is a C extension type; __flags__, __basicsize__, and __itemsize__ are all ints (platform-specific values not checked)."
    - "functools.cached_property is a pure Python class; __flags__, __basicsize__, and __itemsize__ are all ints."
    - "functools.singledispatchmethod is a pure Python class; __flags__, __basicsize__, and __itemsize__ are all ints."
    - "functools.partialmethod is a pure Python class; __flags__, __basicsize__, and __itemsize__ are all ints."
    - "All type objects in CPython carry __flags__, __basicsize__, and __itemsize__ as C-level int attributes regardless of whether the class is defined in C or Python."
    - "Only the type (int) is checked — exact integer values are platform-specific and not portable."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra1366.partial_flags_basicsize_itemsize:
  description: "functools.partial __flags__, __basicsize__, __itemsize__ type checks; partial is a C extension type and all three C-level attributes are ints"
  kind: python_call_eq
  category: flags_basicsize_itemsize_checks
  id_prefix: fu1366pa
  columns: [id, function, args, expected]
  rows:
    - [fu1366pa001, functools.partial.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [fu1366pa002, functools.partial.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [fu1366pa003, functools.partial.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]
    - [fu1366pa004, functools.cached_property.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [fu1366pa005, functools.cached_property.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [fu1366pa006, functools.cached_property.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]

