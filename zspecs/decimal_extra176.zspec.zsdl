spec: decimal_extra176
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal special values — Decimal('Infinity').__class__.__name__=='Decimal'; Decimal('NaN').__class__.__name__=='Decimal'; Decimal('Infinity').is_infinite().__eq__(True)==True; Decimal('NaN').is_nan().__eq__(True)==True; Decimal('0').is_zero().__eq__(True)==True; Decimal('1').is_finite().__eq__(True)==True; Decimal('Infinity').is_signed().__eq__(False)==True; Decimal('-1').is_signed().__eq__(True)==True."
    - "Decimal('Infinity'), Decimal('NaN'), Decimal('0'), Decimal('1'), Decimal('-1') all have __class__.__name__ == 'Decimal'."
    - "Decimal('Infinity').is_infinite() == True; Decimal('NaN').is_nan() == True; Decimal('0').is_zero() == True."
    - "Decimal('1').is_finite() == True; Decimal('Infinity').is_finite() == False."
    - "Decimal('Infinity').is_signed() == False — positive infinity is unsigned; Decimal('-1').is_signed() == True — negative numbers are signed."
    - "is_infinite, is_nan, is_zero, is_finite, is_signed all return plain Python bool values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal special value class identity
# Infinity, NaN, 0, 1, -1 all have __class__.__name__ == 'Decimal'
# ---------------------------------------------------------------------------

table decimal_extra176.special_value_class_identity:
  description: "decimal.Decimal special value class identity: Decimal('Infinity').__class__.__name__=='Decimal'; Decimal('NaN').__class__.__name__=='Decimal'; Decimal('0').__class__.__name__=='Decimal'; all special values are Decimal instances"
  kind: python_call_eq
  category: identity
  id_prefix: decimalspecial176

  columns: [id, function, args, expected, description]
  rows:
    - [inf_cls,    "Decimal('Infinity').__class__.__name__.__eq__",  ["Decimal"], true, "decimal.Decimal('Infinity').__class__.__name__ == 'Decimal' — positive infinity is a Decimal instance; 'Decimal' has 7 characters: D(1)e(2)c(3)i(4)m(5)a(6)l(7); all Decimal special values share __class__.__name__ == 'Decimal'; confirmed Python 3.14.3 macOS"]
    - [nan_cls,    "Decimal('NaN').__class__.__name__.__eq__",       ["Decimal"], true, "decimal.Decimal('NaN').__class__.__name__ == 'Decimal' — NaN (Not a Number) is a Decimal instance; NaN is a special value representing an undefined or unrepresentable result; confirmed Python 3.14.3 macOS"]
    - [zero_cls,   "Decimal('0').__class__.__name__.__eq__",         ["Decimal"], true, "decimal.Decimal('0').__class__.__name__ == 'Decimal' — zero is a Decimal instance; zero is a regular finite Decimal value; confirmed Python 3.14.3 macOS"]
    - [one_cls,    "Decimal('1').__class__.__name__.__eq__",         ["Decimal"], true, "decimal.Decimal('1').__class__.__name__ == 'Decimal' — the value 1 is a Decimal instance; all Decimal instances, whether special or finite, share __class__.__name__ == 'Decimal'; confirmed Python 3.14.3 macOS"]
    - [neg1_cls,   "Decimal('-1').__class__.__name__.__eq__",        ["Decimal"], true, "decimal.Decimal('-1').__class__.__name__ == 'Decimal' — negative 1 is a Decimal instance; Decimal('-1') is a finite, signed, non-zero Decimal value; confirmed Python 3.14.3 macOS"]
    - [cls_len,    "Decimal('Infinity').__class__.__name__.__len__", [],          7,    "decimal.Decimal('Infinity').__class__.__name__.__len__() == 7 — 'Decimal' has 7 characters: D(1)e(2)c(3)i(4)m(5)a(6)l(7); all Decimal values share this class name length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal infinity and NaN predicates
# is_infinite, is_nan, is_finite: testing Infinity and NaN special values
# ---------------------------------------------------------------------------

table decimal_extra176.infinity_nan_predicates:
  description: "decimal.Decimal infinity and NaN predicates: Decimal('Infinity').is_infinite()==True; Decimal('NaN').is_nan()==True; Decimal('1').is_finite()==True; Decimal('Infinity').is_finite()==False; Decimal('NaN').is_finite()==False"
  kind: python_call_eq
  category: identity
  id_prefix: decimalspecial176

  columns: [id, function, args, expected, description]
  rows:
    - [inf_is_inf,      "Decimal('Infinity').is_infinite().__eq__",  [true],  true,  "decimal.Decimal('Infinity').is_infinite().__eq__(True) == True — positive infinity is infinite; is_infinite() returns True for Infinity and -Infinity, False for all finite values and NaN; confirmed Python 3.14.3 macOS"]
    - [nan_is_nan,      "Decimal('NaN').is_nan().__eq__",            [true],  true,  "decimal.Decimal('NaN').is_nan().__eq__(True) == True — NaN is a not-a-number value; is_nan() returns True for NaN and sNaN (signaling NaN), False for all other Decimal values; confirmed Python 3.14.3 macOS"]
    - [one_is_finite,   "Decimal('1').is_finite().__eq__",           [true],  true,  "decimal.Decimal('1').is_finite().__eq__(True) == True — the value 1 is a finite Decimal; is_finite() returns True for normal finite values (including zero) and False for Infinity and NaN; confirmed Python 3.14.3 macOS"]
    - [inf_not_finite,  "Decimal('Infinity').is_finite().__eq__",    [false], true,  "decimal.Decimal('Infinity').is_finite().__eq__(False) == True — positive Infinity is not finite; is_finite() returns False for Infinity; is_infinite() and is_finite() are complementary for non-NaN values; confirmed Python 3.14.3 macOS"]
    - [nan_not_finite,  "Decimal('NaN').is_finite().__eq__",         [false], true,  "decimal.Decimal('NaN').is_finite().__eq__(False) == True — NaN is not finite; is_finite() returns False for NaN as well as for Infinity; confirmed Python 3.14.3 macOS"]
    - [zero_not_inf,    "Decimal('0').is_infinite().__eq__",         [false], true,  "decimal.Decimal('0').is_infinite().__eq__(False) == True — zero is not infinite; is_infinite() returns False for all finite values including zero; Decimal('0').is_finite() == True (zero is finite); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal zero and sign predicates
# is_zero: zero vs. non-zero; is_signed: positive vs. negative
# ---------------------------------------------------------------------------

table decimal_extra176.zero_and_sign_predicates:
  description: "decimal.Decimal zero and sign predicates: Decimal('0').is_zero()==True; Decimal('1').is_zero()==False; Decimal('Infinity').is_signed()==False; Decimal('-1').is_signed()==True; Decimal('1').is_signed()==False"
  kind: python_call_eq
  category: identity
  id_prefix: decimalspecial176

  columns: [id, function, args, expected, description]
  rows:
    - [zero_is_zero,      "Decimal('0').is_zero().__eq__",      [true],  true, "decimal.Decimal('0').is_zero().__eq__(True) == True — zero is a zero value; is_zero() returns True only for Decimal values with coefficient 0; confirmed Python 3.14.3 macOS"]
    - [one_not_zero,      "Decimal('1').is_zero().__eq__",      [false], true, "decimal.Decimal('1').is_zero().__eq__(False) == True — the value 1 is not zero; is_zero() returns False for all non-zero values including Infinity and NaN; confirmed Python 3.14.3 macOS"]
    - [inf_not_signed,    "Decimal('Infinity').is_signed().__eq__",  [false], true, "decimal.Decimal('Infinity').is_signed().__eq__(False) == True — positive Infinity is not signed (sign bit == 0); is_signed() inspects the sign bit directly, not the arithmetic sign; Decimal('Infinity').is_signed() == False; confirmed Python 3.14.3 macOS"]
    - [neg1_is_signed,    "Decimal('-1').is_signed().__eq__",        [true],  true, "decimal.Decimal('-1').is_signed().__eq__(True) == True — negative 1 is signed (sign bit == 1); is_signed() returns True for any Decimal with the sign bit set, including negative zero and negative NaN; confirmed Python 3.14.3 macOS"]
    - [one_not_signed,    "Decimal('1').is_signed().__eq__",         [false], true, "decimal.Decimal('1').is_signed().__eq__(False) == True — positive 1 is not signed; is_signed() returns False for positive finite values; Decimal('1').is_signed() == False; Decimal('-1').is_signed() == True: the two values differ only in sign; confirmed Python 3.14.3 macOS"]
    - [zero_is_zero_cls,  "Decimal('0').is_zero().__class__.__name__.__eq__", ["bool"], true, "decimal.Decimal('0').is_zero().__class__.__name__ == 'bool' — is_zero() returns a plain Python bool; all Decimal predicate methods (is_zero, is_finite, is_nan, is_infinite, is_signed) return bool; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra176.infinity_class_name_is_decimal:
  description: "decimal.Decimal('Infinity').__class__.__name__ == 'Decimal' — positive infinity is a Decimal instance; 'Decimal' has 7 characters; all Decimal special values share this class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('Infinity').__class__.__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra176.nan_class_name_is_decimal:
  description: "decimal.Decimal('NaN').__class__.__name__ == 'Decimal' — NaN is a Decimal instance; Decimal('Infinity') and Decimal('NaN') share __class__.__name__ == 'Decimal'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('NaN').__class__.__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra176.infinity_is_infinite_true:
  description: "decimal.Decimal('Infinity').is_infinite().__eq__(True) == True — is_infinite() returns True for positive Infinity; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('Infinity').is_infinite().__eq__"
  args: [true]
  expected: true

invariant decimal_extra176.nan_is_nan_true:
  description: "decimal.Decimal('NaN').is_nan().__eq__(True) == True — is_nan() returns True for NaN; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('NaN').is_nan().__eq__"
  args: [true]
  expected: true

invariant decimal_extra176.zero_is_zero_true:
  description: "decimal.Decimal('0').is_zero().__eq__(True) == True — is_zero() returns True for the zero value; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('0').is_zero().__eq__"
  args: [true]
  expected: true

invariant decimal_extra176.one_is_finite_true:
  description: "decimal.Decimal('1').is_finite().__eq__(True) == True — is_finite() returns True for normal finite Decimal values; Decimal('1') is finite; Decimal('Infinity').is_finite() == False; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('1').is_finite().__eq__"
  args: [true]
  expected: true

invariant decimal_extra176.infinity_is_signed_false:
  description: "decimal.Decimal('Infinity').is_signed().__eq__(False) == True — positive Infinity has sign bit 0, so is_signed() returns False; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('Infinity').is_signed().__eq__"
  args: [false]
  expected: true

invariant decimal_extra176.neg1_is_signed_true:
  description: "decimal.Decimal('-1').is_signed().__eq__(True) == True — negative 1 has sign bit 1, so is_signed() returns True; Decimal('-1').is_signed() == True while Decimal('1').is_signed() == False; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal('-1').is_signed().__eq__"
  args: [true]
  expected: true
