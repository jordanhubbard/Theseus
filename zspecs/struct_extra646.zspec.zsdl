spec: struct_extra646
version: ">=3.9"
backend: python_module(struct)
docs: "Behavioral spec for struct module top-level and Struct class function __name__ identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct: Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __name__ identity for top-level struct functions (pack, unpack, pack_into, unpack_from, calcsize, iter_unpack) and corresponding Struct class methods."
  created_at: "2026-04-12T00:00:00Z"

table struct_extra646.toplevel_function_names:
  description: "Verifies __name__ identity for top-level struct module functions."
  kind: python_call_eq
  category: name_identity
  id_prefix: st646fn
  columns: [id, function, args, expected]
  rows:
    - [st646fn001, struct.pack.__name__.__eq__, ["pack"], true]
    - [st646fn002, struct.unpack.__name__.__eq__, ["unpack"], true]
    - [st646fn003, struct.pack_into.__name__.__eq__, ["pack_into"], true]
    - [st646fn004, struct.unpack_from.__name__.__eq__, ["unpack_from"], true]
    - [st646fn005, struct.calcsize.__name__.__eq__, ["calcsize"], true]
    - [st646fn006, struct.iter_unpack.__name__.__eq__, ["iter_unpack"], true]

table struct_extra646.struct_class_method_names:
  description: "Verifies __name__ identity for Struct class methods."
  kind: python_call_eq
  category: name_identity
  id_prefix: st646dc
  columns: [id, function, args, expected]
  rows:
    - [st646dc001, struct.Struct.pack.__name__.__eq__, ["pack"], true]
    - [st646dc002, struct.Struct.unpack.__name__.__eq__, ["unpack"], true]
    - [st646dc003, struct.Struct.pack_into.__name__.__eq__, ["pack_into"], true]
    - [st646dc004, struct.Struct.unpack_from.__name__.__eq__, ["unpack_from"], true]
    - [st646dc005, struct.Struct.iter_unpack.__name__.__eq__, ["iter_unpack"], true]
    - [st646dc006, struct.Struct.calcsize.__name__.__eq__, ["calcsize"], true]
