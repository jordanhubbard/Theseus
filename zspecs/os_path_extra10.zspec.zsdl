spec: os_path_extra10
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
  notes:
    - "This spec extends os_path.zspec.zsdl through os_path_extra9.zspec.zsdl."
    - "os_path_extra9 covers __name__/__qualname__ for getatime/getmtime/getctime/lexists/sameopenfile/samestat/relpath; commonprefix single element; commonpath shared parent; splitext no extension."
    - "os_path_extra8 covers normpath('/a/b/') == '/a/b' (trailing slash stripped)."
    - "os_path_extra6 covers normpath('a/./b/../c') == 'a/c' (relative . and ..)."
    - "os_path_extra.zspec covers normpath('/a//b/../c') == '/a/c' and normpath('a/./b') == 'a/b'."
    - "os_path.zspec covers normpath('/foo/../bar'), normpath('a/./b'), normpath('a//b'), normpath(''), normpath('.'), normpath('..')."
    - "NOT yet covered: normpath('/a/b/../c') == '/a/c' — single dotdot from a three-deep path."
    - "NOT yet covered: normpath('/a/b/./c') == '/a/b/c' — dot segment in an absolute path."
    - "NOT yet covered: normpath('/a//b') == '/a/b' — double slash in absolute path (without dotdot)."
    - "NOT yet covered: normpath('/a/b/c/../..') == '/a' — two consecutive dotdots."
    - "NOT yet covered: os.path.expandvars return-type is str."
    - "NOT yet covered: os.path.expandvars on a string with no variable reference leaves it unchanged."
    - "normpath('/a/b/../c') == '/a/c' — resolve a dotdot two levels deep then a component."
    - "normpath('/a/b/./c') == '/a/b/c' — dot segment is removed from absolute path."
    - "normpath('/a//b') == '/a/b' — double separator in absolute path collapses to single."
    - "normpath('/a/b/c/../..') == '/a' — two consecutive dotdots ascend two levels."
    - "os.path.expandvars('no_dollar_here') == 'no_dollar_here' — passthrough when no variable."
    - "os.path.expandvars().__class__.__name__ == 'str' — return type is always str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# normpath — new absolute-path vectors
#
# os_path.zspec covers normpath('/foo/../bar') and normpath('a//b').
# os_path_extra covers normpath('/a//b/../c') (both double-slash and dotdot).
# os_path_extra8 covers normpath('/a/b/') (trailing slash only).
# os_path_extra6 covers normpath('a/./b/../c') (relative path).
#
# This table adds four strictly new absolute-path vectors:
#   '/a/b/../c'   — single dotdot at depth 3 yields '/a/c'
#   '/a/b/./c'    — dot segment in absolute path is removed
#   '/a//b'       — double slash (no dotdot) collapses to '/a/b'
#   '/a/b/c/../..' — two consecutive dotdots ascend two levels to '/a'
# ---------------------------------------------------------------------------

table os_path_extra10.normpath_absolute_vectors:
  description: "os.path.normpath absolute-path normalisation: dotdot, dot, double-slash, two-level dotdot"
  kind: python_call_eq
  category: normpath_values
  id_prefix: np10

  columns: [id, function, args, expected]
  rows:
    - [dotdot_mid,     normpath, ["/a/b/../c"],    "/a/c"]
    - [dot_seg_abs,    normpath, ["/a/b/./c"],     "/a/b/c"]
    - [double_slash,   normpath, ["/a//b"],        "/a/b"]
    - [two_dotdots,    normpath, ["/a/b/c/../.."], "/a"]

# ---------------------------------------------------------------------------
# os.path.expandvars — return type and passthrough behaviour
#
# os_path_extra.zspec and os_path_extra4 cover expandvars.__name__ identity.
# os_path_extra2 covers expandvars('no_dollar') passthrough value.
# os_path_extra8 covers expandvars.__name__ and expandvars.__qualname__.
# No prior spec verifies the return type of expandvars() as str via
# __class__.__name__. This is a new metadata axis.
# ---------------------------------------------------------------------------

invariant os_path_extra10.expandvars.return_type:
  description: "os.path.expandvars() return type is str — __class__.__name__ == 'str'"
  category: expandvars
  kind: python_call_eq
  function: expandvars
  args: ["no_dollar_here"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant os_path_extra10.expandvars.passthrough_no_var:
  description: "os.path.expandvars('no_dollar_here') == 'no_dollar_here' — string without $ is unchanged"
  category: expandvars
  kind: python_call_eq
  function: expandvars
  args: ["no_dollar_here"]
  expected: "no_dollar_here"

# ---------------------------------------------------------------------------
# os.path.splitdrive on an empty string
#
# os_path.zspec covers splitdrive('/a/b') and splitdrive('C:/a').
# os_path_extra2 covers splitdrive('') returning ('', '').
# This spec re-anchors the empty-string case in a new namespace and also
# verifies the tuple length — a dimension not covered by any prior spec.
# ---------------------------------------------------------------------------

invariant os_path_extra10.splitdrive.empty_len:
  description: "os.path.splitdrive('') returns a 2-tuple — __len__ == 2"
  category: splitdrive
  kind: python_call_eq
  function: splitdrive
  args: [""]
  method: __len__
  expected: 2

invariant os_path_extra10.splitdrive.posix_path_len:
  description: "os.path.splitdrive('/a/b') returns a 2-tuple — __len__ == 2"
  category: splitdrive
  kind: python_call_eq
  function: splitdrive
  args: ["/a/b"]
  method: __len__
  expected: 2
