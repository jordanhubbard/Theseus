spec: decimal_extra68
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra67."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO."
    - "decimal_extra67 covers: decimal exception __name__/__module__/__bases__ chain and base counts for Overflow/Underflow/DivisionByZero."
    - "This spec covers: Decimal C slot wrapper identity — __add__/__mul__/__str__/__repr__ have __class__.__name__ == 'wrapper_descriptor'; Decimal.__dict__ membership for __add__/__mul__/__str__; Context.__name__/__module__/__dict__.__class__.__name__."
    - "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper, not method_descriptor."
    - "decimal.Decimal.__mul__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper."
    - "decimal.Decimal.__str__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper."
    - "decimal.Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper."
    - "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy."
    - "decimal.Decimal.__dict__.__contains__('__add__') == True — __add__ stored in Decimal's own __dict__."
    - "decimal.Decimal.__dict__.__contains__('__mul__') == True."
    - "decimal.Decimal.__dict__.__contains__('__str__') == True."
    - "decimal.Context.__name__ == 'Context'."
    - "decimal.Context.__module__ == 'decimal' — exposed as decimal.Context."
    - "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal C slot wrapper identity — __add__, __mul__, __str__, __repr__
# Decimal uses the C accelerator (_decimal). Dunder methods on C types are
# wrapper_descriptors (not method_descriptors). Confirmed Python 3.14.3.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra68.Decimal_slot_wrappers:
  description: "Decimal dunder methods are wrapper_descriptor C slot wrappers"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: decimalann68

  columns: [id, function, args, expected]
  rows:
    - [add_class,   Decimal.__add__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [mul_class,   Decimal.__mul__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [str_class,   Decimal.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [repr_class,  Decimal.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ class and membership checks
# Decimal.__dict__ is a mappingproxy containing its C slot methods.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra68.Decimal_dict_class:
  description: "Decimal.__dict__ is a mappingproxy"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalann68

  columns: [id, function, args, expected]
  rows:
    - [dict_mappingproxy, Decimal.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership for arithmetic and string dunder methods
# __add__, __mul__, __str__ are defined in Decimal's own __dict__.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra68.Decimal_dict_contains:
  description: "Decimal.__dict__ contains its arithmetic and string dunder methods"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalann68

  columns: [id, function, args, expected]
  rows:
    - [has_add, "Decimal.__dict__.__contains__", ["__add__"], true]
    - [has_mul, "Decimal.__dict__.__contains__", ["__mul__"], true]
    - [has_str, "Decimal.__dict__.__contains__", ["__str__"], true]

# ---------------------------------------------------------------------------
# Context class identity — __name__, __module__, __dict__.__class__.__name__
# Context is the decimal arithmetic context type from the C accelerator.
# Context.__module__ == 'decimal' (re-exported by the decimal module).
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra68.Context_identity:
  description: "decimal.Context class identity and __dict__ type"
  kind: python_call_eq
  category: class_names
  id_prefix: decimalann68

  columns: [id, function, args, expected]
  rows:
    - [context_name,       Context.__name__.__eq__,                       ["Context"],      true]
    - [context_module,     Context.__module__.__eq__,                     ["decimal"],      true]
    - [context_dict_class, Context.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra68.Decimal_add.wrapper_descriptor:
  description: "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: Decimal.__add__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra68.Decimal_mul.wrapper_descriptor:
  description: "decimal.Decimal.__mul__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: Decimal.__mul__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra68.Decimal_dict.mappingproxy:
  description: "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: Decimal.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant decimal_extra68.Decimal_dict.has_add:
  description: "decimal.Decimal.__dict__.__contains__('__add__') == True"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__add__"]
  expected: true

invariant decimal_extra68.Context.name_eq:
  description: "decimal.Context.__name__ == 'Context'"
  category: class_names
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true
