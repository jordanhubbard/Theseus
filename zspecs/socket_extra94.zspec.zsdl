spec: socket_extra94
version: ">=3.9"
extends: socket_extra93
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/connect_ex/listen/recv/recv_into/getsockopt/setsockopt/gettimeout/settimeout/fileno/shutdown/send/sendall/recvfrom/recvfrom_into/sendto/recvmsg/sendmsg/setblocking/getblocking/getsockname/getpeername (table + invariants)."
    - "socket_extra92.zspec.zsdl — covers socket.socket class string identity / socket.socket class hierarchy / socket exception hierarchy / AddressFamily/SocketKind class identity (table + invariants)."
    - "socket_extra91.zspec.zsdl — covers socket module string identity cross-checks / socket.socket dunder method class names / socket constant class names and values (table + invariants)."
    - "socket_extra90.zspec.zsdl — covers socket.socket Python-level method __class__.__name__ identity (accept/close/makefile/sendfile/detach/dup/__init__/__enter__/__exit__/__repr__/create_connection/create_server/getfqdn all 'function') (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra93; it does NOT duplicate invariants present in those files."
    - "Wave 257 theme: socket module-level function __qualname__ and __module__ values — pure-Python functions vs C builtins."
    - "socket.create_connection.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.has_dualstack_ipv6.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.has_dualstack_ipv6.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyaddr.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getservbyname.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.htons.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.htonl.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.ntohs.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.ntohl.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__qualname__ == 'create_connection'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__qualname__ == 'create_server'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__qualname__ == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.has_dualstack_ipv6.__qualname__ == 'has_dualstack_ipv6'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__qualname__ == 'getaddrinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: getaddrinfo is a Python-level wrapper in Lib/socket.py (resolves address info); getnameinfo is a C builtin from _socket."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.create_connection.__class__.__name__.__eq__('function')
# socket.create_server.__class__.__name__.__eq__('function')
# socket.getfqdn.__class__.__name__.__eq__('function')
# socket.has_dualstack_ipv6.__class__.__name__.__eq__('function')
# socket.getaddrinfo.__class__.__name__.__eq__('function')
# socket.create_connection.__module__.__eq__('socket')
# socket.create_server.__module__.__eq__('socket')
#
# Wave 257 theme: pure-Python socket module functions — class name and __module__.
#
# create_connection, create_server, getfqdn, has_dualstack_ipv6, and getaddrinfo
# are pure-Python functions defined in Lib/socket.py; they are 'function' class
# objects with __module__ == 'socket'. No prior socket spec anchors these
# class name and __module__ checks together under socketmodulefns94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra94.socket_python_fns_class_and_module:
  description: "socket.create_connection/__class__.__name__.__eq__('function')==True / create_server/__class__.__name__.__eq__('function')==True / getfqdn/__class__.__name__.__eq__('function')==True / has_dualstack_ipv6/__class__.__name__.__eq__('function')==True / getaddrinfo/__class__.__name__.__eq__('function')==True / create_connection/__module__.__eq__('socket')==True / create_server/__module__.__eq__('socket')==True — all five are pure-Python functions in Lib/socket.py with __module__=='socket'; no prior socket spec anchors these together under socketmodulefns94; first socketmodulefns94 anchor for pure-Python socket function class names and __module__"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketmodulefns94

  columns: [id, function, args, expected]
  rows:
    - [create_conn_fn,     create_connection.__class__.__name__.__eq__,  ["function"], true]
    - [create_srv_fn,      create_server.__class__.__name__.__eq__,      ["function"], true]
    - [getfqdn_fn,         getfqdn.__class__.__name__.__eq__,            ["function"], true]
    - [has_dual_fn,        has_dualstack_ipv6.__class__.__name__.__eq__, ["function"], true]
    - [getaddrinfo_fn,     getaddrinfo.__class__.__name__.__eq__,        ["function"], true]
    - [create_conn_mod,    create_connection.__module__.__eq__,          ["socket"],   true]
    - [create_srv_mod,     create_server.__module__.__eq__,              ["socket"],   true]

# ---------------------------------------------------------------------------
# socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method')
# socket.gethostbyname.__class__.__name__.__eq__('builtin_function_or_method')
# socket.gethostbyaddr.__class__.__name__.__eq__('builtin_function_or_method')
# socket.getnameinfo.__class__.__name__.__eq__('builtin_function_or_method')
# socket.getservbyname.__class__.__name__.__eq__('builtin_function_or_method')
# socket.getservbyport.__class__.__name__.__eq__('builtin_function_or_method')
# socket.getprotobyname.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 257 theme: C builtin socket module functions — class name.
#
# gethostname, gethostbyname, gethostbyaddr, getnameinfo, getservbyname,
# getservbyport, and getprotobyname are all C builtin functions from the
# _socket C extension; their __class__.__name__ is 'builtin_function_or_method'.
# No prior socket spec anchors these module-level C builtin class names together
# under socketmodulefns94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra94.socket_c_builtin_fns_class_names:
  description: "socket.gethostname/__class__.__name__.__eq__('builtin_function_or_method')==True / gethostbyname/__class__.__name__.__eq__('builtin_function_or_method')==True / gethostbyaddr/__class__.__name__.__eq__('builtin_function_or_method')==True / getnameinfo/__class__.__name__.__eq__('builtin_function_or_method')==True / getservbyname/__class__.__name__.__eq__('builtin_function_or_method')==True / getservbyport/__class__.__name__.__eq__('builtin_function_or_method')==True / getprotobyname/__class__.__name__.__eq__('builtin_function_or_method')==True — all seven are C builtin functions from _socket; no prior socket spec anchors these together under socketmodulefns94; first socketmodulefns94 anchor for C builtin socket function class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketmodulefns94

  columns: [id, function, args, expected]
  rows:
    - [gethostname_builtin,   gethostname.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [gethostbyname_builtin, gethostbyname.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [gethostbyaddr_builtin, gethostbyaddr.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [getnameinfo_builtin,   getnameinfo.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [getservbyname_builtin, getservbyname.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [getservbyport_builtin, getservbyport.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [getprotobyname_builtin, getprotobyname.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# socket.htons.__class__.__name__.__eq__('builtin_function_or_method')
# socket.htonl.__class__.__name__.__eq__('builtin_function_or_method')
# socket.ntohs.__class__.__name__.__eq__('builtin_function_or_method')
# socket.ntohl.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 257 theme: byte-order conversion functions class names.
#
# htons (host-to-network short), htonl (host-to-network long), ntohs
# (network-to-host short), and ntohl (network-to-host long) are all C builtin
# functions from _socket. Their __class__.__name__ is 'builtin_function_or_method'.
# They convert integers between host and network (big-endian) byte order.
# No prior socket spec anchors these four byte-order functions together under
# socketmodulefns94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra94.socket_byte_order_fns_class_names:
  description: "socket.htons/__class__.__name__.__eq__('builtin_function_or_method')==True / htonl/__class__.__name__.__eq__('builtin_function_or_method')==True / ntohs/__class__.__name__.__eq__('builtin_function_or_method')==True / ntohl/__class__.__name__.__eq__('builtin_function_or_method')==True — htons/htonl/ntohs/ntohl convert integers between host and network byte order; all four are C builtins from _socket; no prior socket spec anchors these together under socketmodulefns94; first socketmodulefns94 anchor for byte-order conversion function class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketmodulefns94

  columns: [id, function, args, expected]
  rows:
    - [htons_builtin, htons.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [htonl_builtin, htonl.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ntohs_builtin, ntohs.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ntohl_builtin, ntohl.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# socket.create_connection.__qualname__.__eq__('create_connection')
# socket.create_server.__qualname__.__eq__('create_server')
# socket.getfqdn.__qualname__.__eq__('getfqdn')
# socket.has_dualstack_ipv6.__qualname__.__eq__('has_dualstack_ipv6')
# socket.getaddrinfo.__qualname__.__eq__('getaddrinfo')
#
# Wave 257 theme: pure-Python socket function __qualname__ equality.
#
# The five pure-Python socket functions (create_connection, create_server,
# getfqdn, has_dualstack_ipv6, getaddrinfo) each have a __qualname__ equal to
# their own function name (no enclosing scope prefix). No prior socket spec
# anchors these five __qualname__ equality checks together under socketmodulefns94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra94.socket_python_fns_qualname_eq:
  description: "socket.create_connection/__qualname__.__eq__('create_connection')==True / create_server/__qualname__.__eq__('create_server')==True / getfqdn/__qualname__.__eq__('getfqdn')==True / has_dualstack_ipv6/__qualname__.__eq__('has_dualstack_ipv6')==True / getaddrinfo/__qualname__.__eq__('getaddrinfo')==True — all five pure-Python functions in Lib/socket.py have __qualname__ equal to their own name (module-level, no enclosing scope); no prior socket spec anchors these together under socketmodulefns94; first socketmodulefns94 anchor for pure-Python socket function __qualname__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketmodulefns94

  columns: [id, function, args, expected]
  rows:
    - [create_conn_qn,  create_connection.__qualname__.__eq__,  ["create_connection"],  true]
    - [create_srv_qn,   create_server.__qualname__.__eq__,      ["create_server"],      true]
    - [getfqdn_qn,      getfqdn.__qualname__.__eq__,            ["getfqdn"],            true]
    - [has_dual_qn,     has_dualstack_ipv6.__qualname__.__eq__, ["has_dualstack_ipv6"], true]
    - [getaddrinfo_qn,  getaddrinfo.__qualname__.__eq__,        ["getaddrinfo"],         true]

# ---------------------------------------------------------------------------
# socket.create_connection.__class__.__name__.__eq__('function') — standalone
#
# socket.create_connection is a pure-Python function defined in Lib/socket.py.
# It is the high-level convenience function for creating a connected TCP socket
# with optional timeout and source address. Its __class__.__name__ is 'function'.
# No prior socket spec anchors create_connection.__class__.__name__.__eq__ as
# a standalone under socketmodulefns94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra94.create_connection_fn:
  description: "socket.create_connection.__class__.__name__.__eq__('function') == True — create_connection is a pure-Python function in Lib/socket.py providing a high-level convenience API for creating connected TCP sockets; __class__.__name__ is 'function'; no prior socket spec anchors this as a standalone; first standalone for create_connection class name under socketmodulefns94"
  category: type_identity
  kind: python_call_eq
  function: create_connection.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# socket.gethostname is a C builtin function from _socket. It returns the
# hostname of the machine where the interpreter is running. Its __class__.__name__
# is 'builtin_function_or_method'. No prior socket spec anchors
# gethostname.__class__.__name__.__eq__ as a standalone under socketmodulefns94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra94.gethostname_builtin:
  description: "socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') == True — socket.gethostname is a C builtin from _socket returning the machine hostname; __class__.__name__ is 'builtin_function_or_method'; no prior socket spec anchors this as a standalone; first standalone for gethostname class name under socketmodulefns94"
  category: type_identity
  kind: python_call_eq
  function: gethostname.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# socket.htons.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# socket.htons is a C builtin function from _socket. It converts a 16-bit
# integer from host to network (big-endian) byte order. Its __class__.__name__
# is 'builtin_function_or_method'. No prior socket spec anchors
# htons.__class__.__name__.__eq__ as a standalone under socketmodulefns94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra94.htons_builtin:
  description: "socket.htons.__class__.__name__.__eq__('builtin_function_or_method') == True — socket.htons converts a 16-bit integer from host to network (big-endian) byte order; it is a C builtin from _socket; __class__.__name__ is 'builtin_function_or_method'; no prior socket spec anchors this as a standalone; first standalone for htons class name under socketmodulefns94"
  category: type_identity
  kind: python_call_eq
  function: htons.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__qualname__.__eq__('getfqdn') — standalone
#
# socket.getfqdn.__qualname__ is 'getfqdn'. getfqdn() returns the fully
# qualified domain name for the local host (or a given hostname). It is a
# pure-Python function in Lib/socket.py with __qualname__ equal to its name.
# No prior socket spec anchors getfqdn.__qualname__.__eq__ as a standalone
# under socketmodulefns94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra94.getfqdn_qualname:
  description: "socket.getfqdn.__qualname__.__eq__('getfqdn') == True — getfqdn() is a pure-Python function in Lib/socket.py returning the fully qualified domain name; its __qualname__ is 'getfqdn' (module-level, no enclosing scope); no prior socket spec anchors this as a standalone; first standalone for getfqdn __qualname__ under socketmodulefns94"
  category: type_identity
  kind: python_call_eq
  function: getfqdn.__qualname__.__eq__
  args: ["getfqdn"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_server.__module__.__eq__('socket') — standalone
#
# socket.create_server.__module__ is 'socket'. create_server() is a pure-Python
# convenience function added in Python 3.8 for creating a listening TCP server
# socket. It lives in Lib/socket.py and has __module__ == 'socket'. No prior
# socket spec anchors create_server.__module__.__eq__ as a standalone under
# socketmodulefns94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra94.create_server_module:
  description: "socket.create_server.__module__.__eq__('socket') == True — create_server() is a pure-Python convenience function (Python 3.8+) for creating a listening TCP socket; it is defined in Lib/socket.py with __module__=='socket'; no prior socket spec anchors this as a standalone; first standalone for create_server __module__ under socketmodulefns94"
  category: type_identity
  kind: python_call_eq
  function: create_server.__module__.__eq__
  args: ["socket"]
  expected: true
