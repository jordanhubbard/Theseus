spec: twitter_text
version: ">=3.0.0"
backend: node(twitter-text)

docs: https://www.npmjs.com/package/twitter-text

provenance:
  derived_from:
    - "twitter-text README — https://www.npmjs.com/package/twitter-text"
    - "Test vectors verified with twitter-text via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "twitter-text source"
  notes:
    - "twitter-text is an npm package. Install: npm install twitter-text"
    - "extractUrls(text) returns an array of URLs found in the text."
    - "extractHashtags(text) returns an array of hashtag strings (without #)."
    - "extractMentions(text) returns an array of mentioned usernames (without @)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of extracted strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table twitter_text.extractUrls:
  kind: node_module_call_eq
  function: extractUrls
  category: extract
  id_prefix: twurl

  columns: [id, args, expected]
  rows:
    - [basic,  ["Visit https://example.com today"], ["https://example.com"]]
    - [none,   ["No links here"],                   []]

table twitter_text.extractHashtags:
  kind: node_module_call_eq
  function: extractHashtags
  category: extract
  id_prefix: twht

  columns: [id, args, expected]
  rows:
    - [two,  ["Hello #world and #coding"], ["world", "coding"]]
    - [none, ["No hashtags here"],         []]

table twitter_text.extractMentions:
  kind: node_module_call_eq
  function: extractMentions
  category: extract
  id_prefix: twmt

  columns: [id, args, expected]
  rows:
    - [two,  ["Hey @alice and @bob"], ["alice", "bob"]]
    - [none, ["No mentions here"],    []]
