spec: decimal_extra129
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal class identity (__name__, __module__, __qualname__, __mro__.__len__()) and method descriptor __class__.__name__ and __qualname__ strings and lengths for __new__, __add__, __sub__, __mul__, __truediv__, __str__, __repr__, __neg__, sqrt, ln, log10, exp, normalize, quantize."
    - "decimal.Decimal.__name__ == 'Decimal' (length 7)."
    - "decimal.Decimal.__module__ == 'decimal' (length 7) — the C-accelerated Decimal reports 'decimal' as its module, not '_decimal'."
    - "decimal.Decimal.__qualname__ == 'Decimal' (length 7)."
    - "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]; Decimal has no intermediate base."
    - "decimal.Decimal.__new__.__class__.__name__ == 'builtin_function_or_method' — __new__ is a builtin, unlike most other Decimal slots which are wrapper_descriptor."
    - "decimal.Decimal.__new__.__qualname__ == 'Decimal.__new__' (length 15)."
    - "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' — arithmetic dunder methods are slot wrappers."
    - "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (length 15)."
    - "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (length 15)."
    - "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (length 16)."
    - "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (length 19)."
    - "decimal.Decimal.sqrt.__class__.__name__ == 'method_descriptor' — math methods (sqrt, ln, log10, exp) are method_descriptors."
    - "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (length 12)."
    - "decimal.Decimal.ln.__qualname__ == 'Decimal.ln' (length 10)."
    - "decimal.Decimal.log10.__qualname__ == 'Decimal.log10' (length 13)."
    - "decimal.Decimal.exp.__qualname__ == 'Decimal.exp' (length 11)."
    - "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (length 17)."
    - "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' (length 16)."
    - "decimal.Decimal.to_eng_string.__qualname__ == 'Decimal.to_eng_string' (length 21)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal class identity
# Decimal.__name__ == 'Decimal' (7), __module__ == 'decimal' (7),
# __qualname__ == 'Decimal' (7), __mro__.__len__() == 2.
# ---------------------------------------------------------------------------

table decimal_extra129.Decimal_class_identity:
  description: "decimal.Decimal class identity: __name__='Decimal' (7), __module__='decimal' (7), __qualname__='Decimal' (7), __mro__.__len__()==2"
  kind: python_call_eq
  category: class_identity
  id_prefix: decdec129

  columns: [id, function, args, expected]
  rows:
    - [dec_name_eq,      Decimal.__name__.__eq__,     ["Decimal"],  true]
    - [dec_name_len,     Decimal.__name__.__len__,    [],           7]
    - [dec_module_eq,    Decimal.__module__.__eq__,   ["decimal"],  true]
    - [dec_module_len,   Decimal.__module__.__len__,  [],           7]
    - [dec_module_not,   Decimal.__module__.__eq__,   ["_decimal"], false]
    - [dec_qualname_eq,  Decimal.__qualname__.__eq__, ["Decimal"],  true]
    - [dec_qualname_len, Decimal.__qualname__.__len__, [],          7]
    - [dec_mro_len,      Decimal.__mro__.__len__,     [],           2]
    - [dec_name_not_ctx, Decimal.__name__.__eq__,     ["Context"],  false]

# ---------------------------------------------------------------------------
# decimal.Decimal __new__ and dunder arithmetic method descriptor types
# __new__ is 'builtin_function_or_method'; __add__, __sub__, __mul__,
# __truediv__, __str__, __repr__, __neg__, __eq__, __lt__ are 'wrapper_descriptor'.
# ---------------------------------------------------------------------------

table decimal_extra129.Decimal_method_descriptor_classes:
  description: "decimal.Decimal method descriptor __class__.__name__: __new__='builtin_function_or_method', __add__/__str__/__repr__ etc.='wrapper_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: decdec129

  columns: [id, function, args, expected]
  rows:
    - [new_cls_eq,     Decimal.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [new_cls_not_wd, Decimal.__new__.__class__.__name__.__eq__,     ["wrapper_descriptor"],         false]
    - [add_cls_eq,     Decimal.__add__.__class__.__name__.__eq__,     ["wrapper_descriptor"],         true]
    - [sub_cls_eq,     Decimal.__sub__.__class__.__name__.__eq__,     ["wrapper_descriptor"],         true]
    - [mul_cls_eq,     Decimal.__mul__.__class__.__name__.__eq__,     ["wrapper_descriptor"],         true]
    - [tdiv_cls_eq,    Decimal.__truediv__.__class__.__name__.__eq__, ["wrapper_descriptor"],         true]
    - [str_cls_eq,     Decimal.__str__.__class__.__name__.__eq__,     ["wrapper_descriptor"],         true]
    - [repr_cls_eq,    Decimal.__repr__.__class__.__name__.__eq__,    ["wrapper_descriptor"],         true]
    - [neg_cls_eq,     Decimal.__neg__.__class__.__name__.__eq__,     ["wrapper_descriptor"],         true]
    - [sqrt_cls_eq,    Decimal.sqrt.__class__.__name__.__eq__,        ["method_descriptor"],          true]

# ---------------------------------------------------------------------------
# decimal.Decimal dunder method __qualname__ equality and lengths
# __new__: 'Decimal.__new__' (15), __add__: 'Decimal.__add__' (15),
# __str__: 'Decimal.__str__' (15), __repr__: 'Decimal.__repr__' (16),
# __truediv__: 'Decimal.__truediv__' (19), __neg__: 'Decimal.__neg__' (15).
# ---------------------------------------------------------------------------

table decimal_extra129.Decimal_dunder_qualnames:
  description: "decimal.Decimal dunder method __qualname__ equality and lengths: __new__=15, __add__=15, __str__=15, __repr__=16, __truediv__=19, __neg__=15"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: decdec129

  columns: [id, function, args, expected]
  rows:
    - [new_qn_eq,    Decimal.__new__.__qualname__.__eq__,     ["Decimal.__new__"],     true]
    - [new_qn_len,   Decimal.__new__.__qualname__.__len__,    [],                      15]
    - [add_qn_eq,    Decimal.__add__.__qualname__.__eq__,     ["Decimal.__add__"],     true]
    - [add_qn_len,   Decimal.__add__.__qualname__.__len__,    [],                      15]
    - [str_qn_eq,    Decimal.__str__.__qualname__.__eq__,     ["Decimal.__str__"],     true]
    - [str_qn_len,   Decimal.__str__.__qualname__.__len__,    [],                      15]
    - [repr_qn_eq,   Decimal.__repr__.__qualname__.__eq__,    ["Decimal.__repr__"],    true]
    - [repr_qn_len,  Decimal.__repr__.__qualname__.__len__,   [],                      16]
    - [tdiv_qn_eq,   Decimal.__truediv__.__qualname__.__eq__, ["Decimal.__truediv__"], true]
    - [tdiv_qn_len,  Decimal.__truediv__.__qualname__.__len__, [],                     19]
    - [neg_qn_eq,    Decimal.__neg__.__qualname__.__eq__,     ["Decimal.__neg__"],     true]
    - [neg_qn_len,   Decimal.__neg__.__qualname__.__len__,    [],                      15]

# ---------------------------------------------------------------------------
# decimal.Decimal math method __qualname__ equality and lengths
# sqrt (12), ln (10), log10 (13), exp (11), normalize (17), quantize (16),
# to_eng_string (21). All are method_descriptor instances.
# ---------------------------------------------------------------------------

table decimal_extra129.Decimal_math_method_qualnames:
  description: "decimal.Decimal math method __qualname__ equality and lengths: sqrt=12, ln=10, log10=13, exp=11, normalize=17, quantize=16, to_eng_string=21"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: decdec129

  columns: [id, function, args, expected]
  rows:
    - [sqrt_qn_eq,     Decimal.sqrt.__qualname__.__eq__,          ["Decimal.sqrt"],          true]
    - [sqrt_qn_len,    Decimal.sqrt.__qualname__.__len__,         [],                        12]
    - [ln_qn_eq,       Decimal.ln.__qualname__.__eq__,            ["Decimal.ln"],            true]
    - [ln_qn_len,      Decimal.ln.__qualname__.__len__,           [],                        10]
    - [log10_qn_eq,    Decimal.log10.__qualname__.__eq__,         ["Decimal.log10"],         true]
    - [log10_qn_len,   Decimal.log10.__qualname__.__len__,        [],                        13]
    - [exp_qn_eq,      Decimal.exp.__qualname__.__eq__,           ["Decimal.exp"],           true]
    - [exp_qn_len,     Decimal.exp.__qualname__.__len__,          [],                        11]
    - [norm_qn_eq,     Decimal.normalize.__qualname__.__eq__,     ["Decimal.normalize"],     true]
    - [norm_qn_len,    Decimal.normalize.__qualname__.__len__,    [],                        17]
    - [quant_qn_eq,    Decimal.quantize.__qualname__.__eq__,      ["Decimal.quantize"],      true]
    - [quant_qn_len,   Decimal.quantize.__qualname__.__len__,     [],                        16]
    - [eng_qn_eq,      Decimal.to_eng_string.__qualname__.__eq__, ["Decimal.to_eng_string"], true]
    - [eng_qn_len,     Decimal.to_eng_string.__qualname__.__len__, [],                       21]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra129.Decimal.name_is_Decimal:
  description: "decimal.Decimal.__name__ == 'Decimal' (length 7; the class name as defined in the C extension; __module__ is 'decimal', not '_decimal')"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra129.Decimal.module_is_decimal:
  description: "decimal.Decimal.__module__ == 'decimal' (length 7; the C-accelerated Decimal reports 'decimal' as its module, not '_decimal')"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra129.Decimal.mro_len_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 (MRO is [Decimal, object]; unlike exception subclasses, Decimal has no intermediate base)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra129.Decimal.new_is_builtin_function:
  description: "decimal.Decimal.__new__.__class__.__name__ == 'builtin_function_or_method' (__new__ differs from other Decimal slots which are wrapper_descriptor)"
  category: method_descriptor
  kind: python_call_eq
  function: Decimal.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra129.Decimal.truediv_qualname_len_19:
  description: "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 ('Decimal.__truediv__' is 19 chars: 'Decimal' (7) + '.' (1) + '__truediv__' (11))"
  category: method_descriptor
  kind: python_call_eq
  function: Decimal.__truediv__.__qualname__.__len__
  args: []
  expected: 19
