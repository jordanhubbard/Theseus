spec: asyncio_extra520
backend: python_module(asyncio)

table:
  id: queue_method_names
  columns: [id, function, expected]
  rows:
    - [put_name,        asyncio.Queue.put.__name__,        put]
    - [put_nowait_name, asyncio.Queue.put_nowait.__name__,  put_nowait]
    - [get_name,        asyncio.Queue.get.__name__,        get]
    - [get_nowait_name, asyncio.Queue.get_nowait.__name__,  get_nowait]
    - [empty_name,      asyncio.Queue.empty.__name__,      empty]
    - [full_name,       asyncio.Queue.full.__name__,       full]
    - [qsize_name,      asyncio.Queue.qsize.__name__,      qsize]
    - [join_name,       asyncio.Queue.join.__name__,       join]
    - [task_done_name,  asyncio.Queue.task_done.__name__,  task_done]
  invariant:
    kind: python_call_eq

invariants:
  - id: lifoqueue_name
    kind: python_call_eq
    function: asyncio.LifoQueue.__name__
    expected: LifoQueue

  - id: lifoqueue_module
    kind: python_call_eq
    function: asyncio.LifoQueue.__module__
    expected: asyncio.queues

  - id: lifoqueue_base
    kind: python_call_eq
    function: "asyncio.LifoQueue.__bases__[0].__name__"
    expected: Queue

  - id: priorityqueue_name
    kind: python_call_eq
    function: asyncio.PriorityQueue.__name__
    expected: PriorityQueue

  - id: priorityqueue_base
    kind: python_call_eq
    function: "asyncio.PriorityQueue.__bases__[0].__name__"
    expected: Queue
