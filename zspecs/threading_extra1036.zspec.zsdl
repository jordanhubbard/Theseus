spec: threading_extra1036
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Thread and threading.Barrier property descriptor class names and method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1036.thread_property_descriptors:
  description: "threading.Thread class-level property attribute __class__.__name__ checks"
  kind: python_call_eq
  category: thread_properties
  id_prefix: th1036tp
  columns: [id, function, args, expected]
  rows:
    - [th1036tp001, threading.Thread.daemon.__class__.__name__.__eq__,    ["property"], true]
    - [th1036tp002, threading.Thread.name.__class__.__name__.__eq__,      ["property"], true]
    - [th1036tp003, threading.Thread.ident.__class__.__name__.__eq__,     ["property"], true]
    - [th1036tp004, threading.Thread.native_id.__class__.__name__.__eq__, ["property"], true]
    - [th1036tp005, threading.Thread.__class__.__name__.__eq__,           ["type"],     true]
    - [th1036tp006, threading.Thread.__module__.__eq__,                   ["threading"], true]

table threading_extra1036.barrier_property_descriptors:
  description: "threading.Barrier class-level property attribute __class__.__name__ checks"
  kind: python_call_eq
  category: barrier_properties
  id_prefix: th1036bp
  columns: [id, function, args, expected]
  rows:
    - [th1036bp001, threading.Barrier.parties.__class__.__name__.__eq__,   ["property"], true]
    - [th1036bp002, threading.Barrier.n_waiting.__class__.__name__.__eq__, ["property"], true]
    - [th1036bp003, threading.Barrier.broken.__class__.__name__.__eq__,    ["property"], true]
    - [th1036bp004, threading.Barrier.__class__.__name__.__eq__,           ["type"],     true]
    - [th1036bp005, threading.Barrier.__module__.__eq__,                   ["threading"], true]

table threading_extra1036.thread_method_qualnames:
  description: "threading.Thread method __qualname__ identity checks"
  kind: python_call_eq
  category: thread_method_qualnames
  id_prefix: th1036mq
  columns: [id, function, args, expected]
  rows:
    - [th1036mq001, threading.Thread.is_alive.__qualname__.__eq__,  ["Thread.is_alive"],  true]
    - [th1036mq002, threading.Thread.start.__qualname__.__eq__,     ["Thread.start"],     true]
    - [th1036mq003, threading.Thread.join.__qualname__.__eq__,      ["Thread.join"],      true]
    - [th1036mq004, threading.Thread.run.__qualname__.__eq__,       ["Thread.run"],       true]
    - [th1036mq005, threading.Thread.__init__.__qualname__.__eq__,  ["Thread.__init__"],  true]
    - [th1036mq006, threading.__name__.__eq__,                      ["threading"],        true]
