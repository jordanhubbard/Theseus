spec: asyncore
version: ">=3.3,<3.12"
backend: python_module(asyncore)

docs: https://docs.python.org/3.11/library/asyncore.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3.11/library/asyncore.html"
    - "Test vectors verified with Python 3.11 on macOS/Darwin 25.4.0, 2026-04-09"
    - "asyncore source: Lib/asyncore.py (PSF; structural inspection only)"
  not_derived_from:
    - "asyncore source: select/poll/epoll polling internals"
  notes:
    - "asyncore was deprecated in Python 3.6 and removed in Python 3.12."
    - "asyncore.dispatcher is the base class for all async socket handlers."
    - "dispatcher_with_send extends dispatcher with a buffered send queue."
    - "file_dispatcher wraps a file descriptor as an async dispatcher."
    - "file_wrapper wraps a numeric file descriptor to expose a socket-like interface."
    - "loop() drives the event loop by calling poll() (or poll2/poll3) repeatedly."
    - "poll(), poll2(), poll3() are the low-level polling primitives (select, poll, epoll)."
    - "compact_traceback() formats the current exception as (type, value, traceback_string)."
    - "dispatcher.__bases__[0].__name__ == 'object' — dispatcher has no non-trivial base."
    - "dispatcher_with_send.__bases__[0].__name__ == 'dispatcher'."
    - "All expected values verified by running Python 3.11 asyncore module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "asyncore raises no module-specific exception class; socket and OS errors propagate normally."
  stderr: "null"
  stickiness: "N/A — class-level structural checks only."
  codes: {}

# ---------------------------------------------------------------------------
# dispatcher class — name, module, base
# ---------------------------------------------------------------------------

invariant asyncore.dispatcher_name:
  description: "dispatcher.__name__ == 'dispatcher'"
  category: classnames
  kind: python_call_eq
  function: dispatcher.__name__.__eq__
  args: ["dispatcher"]
  expected: true

invariant asyncore.dispatcher_module:
  description: "dispatcher.__module__ == 'asyncore'"
  category: classnames
  kind: python_call_eq
  function: dispatcher.__module__.__eq__
  args: ["asyncore"]
  expected: true

invariant asyncore.dispatcher_base:
  description: "dispatcher.__bases__[0].__name__ == 'object'"
  category: classnames
  kind: python_call_eq
  function: dispatcher.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# dispatcher_with_send class — name and base
# ---------------------------------------------------------------------------

invariant asyncore.dispatcher_with_send_name:
  description: "dispatcher_with_send.__name__ == 'dispatcher_with_send'"
  category: classnames
  kind: python_call_eq
  function: dispatcher_with_send.__name__.__eq__
  args: ["dispatcher_with_send"]
  expected: true

invariant asyncore.dispatcher_with_send_base:
  description: "dispatcher_with_send.__bases__[0].__name__ == 'dispatcher'"
  category: classnames
  kind: python_call_eq
  function: dispatcher_with_send.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "dispatcher"

# ---------------------------------------------------------------------------
# file_dispatcher and file_wrapper classes
# ---------------------------------------------------------------------------

invariant asyncore.file_dispatcher_name:
  description: "file_dispatcher.__name__ == 'file_dispatcher'"
  category: classnames
  kind: python_call_eq
  function: file_dispatcher.__name__.__eq__
  args: ["file_dispatcher"]
  expected: true

invariant asyncore.file_wrapper_name:
  description: "file_wrapper.__name__ == 'file_wrapper'"
  category: classnames
  kind: python_call_eq
  function: file_wrapper.__name__.__eq__
  args: ["file_wrapper"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level functions — name checks
# ---------------------------------------------------------------------------

invariant asyncore.loop_name:
  description: "loop.__name__ == 'loop'"
  category: functions
  kind: python_call_eq
  function: loop.__name__.__eq__
  args: ["loop"]
  expected: true

invariant asyncore.poll_name:
  description: "poll.__name__ == 'poll'"
  category: functions
  kind: python_call_eq
  function: poll.__name__.__eq__
  args: ["poll"]
  expected: true

invariant asyncore.compact_traceback_name:
  description: "compact_traceback.__name__ == 'compact_traceback'"
  category: functions
  kind: python_call_eq
  function: compact_traceback.__name__.__eq__
  args: ["compact_traceback"]
  expected: true
