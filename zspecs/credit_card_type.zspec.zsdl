spec: credit_card_type
version: ">=10.0.0"
backend: node(credit-card-type)

docs: https://www.npmjs.com/package/credit-card-type

provenance:
  derived_from:
    - "credit-card-type README — https://www.npmjs.com/package/credit-card-type"
    - "Test vectors verified with credit-card-type via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "credit-card-type source"
  notes:
    - "credit-card-type is an npm package. Install: npm install credit-card-type"
    - "creditCardType(prefix) returns an array of matching card type objects."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of card type objects."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table credit_card_type.detect:
  kind: node_module_call_eq
  function: ~
  category: detect
  id_prefix: cct

  columns: [id, args, expected]
  rows:
    - [visa, ["4111"],
       [{"niceType": "Visa", "type": "visa", "patterns": [4],
         "gaps": [4, 8, 12], "lengths": [16, 18, 19],
         "code": {"name": "CVV", "size": 3}, "matchStrength": 1}]]
    - [amex, ["3714"],
       [{"niceType": "American Express", "type": "american-express",
         "patterns": [34, 37], "gaps": [4, 10], "lengths": [15],
         "code": {"name": "CID", "size": 4}, "matchStrength": 2}]]
