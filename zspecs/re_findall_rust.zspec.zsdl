spec: re_findall_rust
version: ">=3.9"
backend: rust_module(re_findall_rust)

docs: https://docs.python.org/3/library/re.html#re.findall

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "Clean-room Rust reimplementation of re.findall and re.split, exposed via PyO3."
    - "findall(pattern, string) returns list of all non-overlapping matches."
    - "findall(r'\\d+', 'abc 123 def 456') == ['123', '456']."
    - "findall(r'\\w+', 'hello world foo') == ['hello', 'world', 'foo']."
    - "findall returns [] when there are no matches."
    - "split(pattern, string) splits string at pattern matches."
    - "All test vectors verified against Python 3.14.3 re module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# re.findall — return all matches as list of strings
table re_findall_rust.findall.vectors:
  kind: python_call_eq
  category: findall
  id_prefix: ref_fa
  function: findall

  columns: [id, args, expected]
  rows:
    - [digits_two,   ["\\d+",    "abc 123 def 456"],  ["123", "456"]]
    - [words_three,  ["\\w+",    "hello world foo"],   ["hello", "world", "foo"]]
    - [vowels,       ["[aeiou]", "hello world"],        ["e", "o", "o"]]
    - [no_match,     ["\\d+",    "no numbers"],         []]
    - [three_letter, ["\\b\\w{3}\\b", "the cat sat"],  ["the", "cat", "sat"]]
    - [split_comma,  ["[^,]+",   "a,b,c"],              ["a", "b", "c"]]

# re.split — split string at pattern
table re_findall_rust.split.vectors:
  kind: python_call_eq
  category: split
  id_prefix: ref_sp
  function: split

  columns: [id, args, expected]
  rows:
    - [by_comma,  [",",    "a,b,c"],       ["a", "b", "c"]]
    - [by_space,  ["\\s+", "hello world"], ["hello", "world"]]
    - [by_pipe,   ["\\|",  "x|y|z"],       ["x", "y", "z"]]
    - [no_match,  [",",    "abc"],          ["abc"]]

