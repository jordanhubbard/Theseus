spec: io_extra1441
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 543 (_extra1441): ABC machinery focus — __subclasshook__ and __instancecheck__ checks."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are ABCs (metaclass=ABCMeta)."
    - "For ABCMeta-backed classes, __instancecheck__.__class__.__name__ == 'method' (bound to ABCMeta instance)."
    - "For plain-type classes (BytesIO, StringIO, UnsupportedOperation), both resolve as 'builtin_function_or_method'."
    - "__subclasshook__ is inherited from object.__dict__ — not present in any io class __dict__."
    - "__instancecheck__ is on the metaclass (ABCMeta or type) — not in the class __dict__ itself."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1441.subclasshook_class_name:
  description: "io class __subclasshook__.__class__.__name__ identity — all resolve as builtin_function_or_method"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: io1441sh
  columns: [id, function, args, expected]
  rows:
    - [io1441sh001, io.IOBase.__subclasshook__.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]
    - [io1441sh002, io.RawIOBase.__subclasshook__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [io1441sh003, io.BufferedIOBase.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [io1441sh004, io.TextIOBase.__subclasshook__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [io1441sh005, io.BytesIO.__subclasshook__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [io1441sh006, io.StringIO.__subclasshook__.__class__.__name__.__eq__,         ["builtin_function_or_method"], true]
    - [io1441sh007, io.UnsupportedOperation.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table io_extra1441.instancecheck_class_name:
  description: "io class __instancecheck__.__class__.__name__ — ABCMeta classes yield 'method', plain type classes yield 'builtin_function_or_method'"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: io1441ic
  columns: [id, function, args, expected]
  rows:
    - [io1441ic001, io.IOBase.__instancecheck__.__class__.__name__.__eq__,              ["method"], true]
    - [io1441ic002, io.RawIOBase.__instancecheck__.__class__.__name__.__eq__,           ["method"], true]
    - [io1441ic003, io.BufferedIOBase.__instancecheck__.__class__.__name__.__eq__,      ["method"], true]
    - [io1441ic004, io.TextIOBase.__instancecheck__.__class__.__name__.__eq__,          ["method"], true]
    - [io1441ic005, io.BytesIO.__instancecheck__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [io1441ic006, io.StringIO.__instancecheck__.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
    - [io1441ic007, io.UnsupportedOperation.__instancecheck__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table io_extra1441.subclasshook_not_in_dict:
  description: "io class __dict__ does NOT contain __subclasshook__ — it is inherited from object"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: io1441sd
  columns: [id, function, args, expected]
  rows:
    - [io1441sd001, io.IOBase.__dict__.__contains__,           ["__subclasshook__"], false]
    - [io1441sd002, io.RawIOBase.__dict__.__contains__,        ["__subclasshook__"], false]
    - [io1441sd003, io.BufferedIOBase.__dict__.__contains__,   ["__subclasshook__"], false]
    - [io1441sd004, io.TextIOBase.__dict__.__contains__,       ["__subclasshook__"], false]
    - [io1441sd005, io.BytesIO.__dict__.__contains__,          ["__subclasshook__"], false]
    - [io1441sd006, io.StringIO.__dict__.__contains__,         ["__subclasshook__"], false]
    - [io1441sd007, io.UnsupportedOperation.__dict__.__contains__, ["__subclasshook__"], false]

table io_extra1441.instancecheck_not_in_dict:
