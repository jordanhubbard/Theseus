    - [io1441id007, io.UnsupportedOperation.__dict__.__contains__, ["__instancecheck__"], false]

table io_extra1441.abc_metaclass_identity:
  description: "io ABC classes use ABCMeta metaclass; concrete IO classes use plain type"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: io1441mc
  columns: [id, function, args, expected]
  rows:
    - [io1441mc001, io.IOBase.__class__.__name__.__eq__,              ["ABCMeta"], true]
    - [io1441mc002, io.RawIOBase.__class__.__name__.__eq__,           ["ABCMeta"], true]
    - [io1441mc003, io.BufferedIOBase.__class__.__name__.__eq__,      ["ABCMeta"], true]
    - [io1441mc004, io.TextIOBase.__class__.__name__.__eq__,          ["ABCMeta"], true]
    - [io1441mc005, io.BytesIO.__class__.__name__.__eq__,             ["type"], true]
    - [io1441mc006, io.StringIO.__class__.__name__.__eq__,            ["type"], true]
    - [io1441mc007, io.UnsupportedOperation.__class__.__name__.__eq__, ["type"], true]

table io_extra1441.abstractmethods_in_abc_dict:
  description: "io ABC classes carry __abstractmethods__ in their __dict__; concrete IO classes do not"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: io1441am
  columns: [id, function, args, expected]
  rows:
    - [io1441am001, io.IOBase.__dict__.__contains__,         ["__abstractmethods__"], true]
    - [io1441am002, io.RawIOBase.__dict__.__contains__,      ["__abstractmethods__"], true]
    - [io1441am003, io.BufferedIOBase.__dict__.__contains__,  ["__abstractmethods__"], true]
    - [io1441am004, io.TextIOBase.__dict__.__contains__,     ["__abstractmethods__"], true]
    - [io1441am005, io.BytesIO.__dict__.__contains__,         ["__abstractmethods__"], false]
    - [io1441am006, io.StringIO.__dict__.__contains__,        ["__abstractmethods__"], false]
    - [io1441am007, io.UnsupportedOperation.__dict__.__contains__, ["__abstractmethods__"], false]
