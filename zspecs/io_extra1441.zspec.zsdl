    - [io1441id002, io.RawIOBase.__dict__.__contains__,        ["__instancecheck__"], false]
    - [io1441id003, io.BufferedIOBase.__dict__.__contains__,   ["__instancecheck__"], false]
    - [io1441id004, io.TextIOBase.__dict__.__contains__,       ["__instancecheck__"], false]
    - [io1441id005, io.BytesIO.__dict__.__contains__,          ["__instancecheck__"], false]
