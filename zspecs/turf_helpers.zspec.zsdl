spec: turf_helpers
version: ">=7.0.0"
backend: node(@turf/helpers)

docs: https://turfjs.org/docs/api/helpers

provenance:
  derived_from:
    - "Turf.js helpers documentation — https://turfjs.org/docs/api/helpers"
    - "GeoJSON specification (RFC 7946)"
    - "Test vectors verified with @turf/helpers via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "@turf/helpers source"
  notes:
    - "Turf.js geometry-construction helpers — point()/lineString()/polygon()/feature()/featureCollection()."
    - "Install: npm install @turf/helpers"
    - "All builders emit valid GeoJSON Features per RFC 7946."
    - "Spec name underscored per ZSDL convention; npm package is @turf/helpers."
    - "Plus unit-conversion helpers: degreesToRadians, radiansToDegrees, lengthToDegrees, convertLength."
  rfcs:
    - "RFC 7946 — The GeoJSON Format — https://www.rfc-editor.org/rfc/rfc7946"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throws on malformed coordinates."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# point() — emits valid GeoJSON Point Feature
invariant turf_helpers.point_emits_feature_type:
  description: "point() returns a GeoJSON Feature"
  category: point
  kind: node_chain_eq
  entry: named
  function: point
  entry_args: [[1, 2]]
  chain:
    - {get: type}
  expected: "Feature"

invariant turf_helpers.point_geometry_type:
  description: "point() Feature has geometry of type 'Point'"
  category: point
  kind: node_chain_eq
  entry: named
  function: point
  entry_args: [[1, 2]]
  chain:
    - {get: geometry}
    - {get: type}
  expected: "Point"

invariant turf_helpers.point_coordinates:
  description: "point([1,2]) preserves coordinates"
  category: point
  kind: node_chain_eq
  entry: named
  function: point
  entry_args: [[1, 2]]
  chain:
    - {get: geometry}
    - {get: coordinates}
  expected: [1, 2]

invariant turf_helpers.point_with_properties:
  description: "point() second arg becomes Feature.properties"
  category: point
  kind: node_chain_eq
  entry: named
  function: point
  entry_args: [[1, 2], {name: "A"}]
  chain:
    - {get: properties}
    - {get: name}
  expected: "A"

# Unit conversions — pure math
invariant turf_helpers.degrees_to_radians_pi:
  description: "degreesToRadians(180) == π"
  category: unit_conversions
  kind: node_chain_eq
  entry: named
  function: degreesToRadians
  entry_args: [180]
  chain:
    - {method: toFixed, args: [9]}
  expected: "3.141592654"

invariant turf_helpers.radians_to_degrees_pi:
  description: "radiansToDegrees(π) == 180"
  category: unit_conversions
  kind: node_chain_eq
  entry: named
  function: radiansToDegrees
  entry_args: [3.141592653589793]
  chain: []
  expected: 180

invariant turf_helpers.degrees_zero:
  description: "degreesToRadians(0) == 0"
  category: unit_conversions
  kind: node_module_call_eq
  function: degreesToRadians
  args: [0]
  expected: 0

invariant turf_helpers.bearing_to_azimuth:
  description: "bearingToAzimuth(-90) wraps to 270"
  category: bearing
  kind: node_module_call_eq
  function: bearingToAzimuth
  args: [-90]
  expected: 270

invariant turf_helpers.bearing_to_azimuth_passthrough:
  description: "bearingToAzimuth(45) is 45 (already in [0,360))"
  category: bearing
  kind: node_module_call_eq
  function: bearingToAzimuth
  args: [45]
  expected: 45

# featureCollection — packs an array of features
invariant turf_helpers.feature_collection_type:
  description: "featureCollection() returns 'FeatureCollection' type"
  category: featureCollection
  kind: node_chain_eq
  entry: named
  function: featureCollection
  entry_args: [[]]
  chain:
    - {get: type}
  expected: "FeatureCollection"

invariant turf_helpers.feature_collection_features_length:
  description: "featureCollection() preserves the input feature array length"
  category: featureCollection
  kind: node_chain_eq
  entry: named
  function: featureCollection
  entry_args: [[]]
  chain:
    - {get: features}
    - {get: length}
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:54:22Z
  iterations: 1
  pass_count: 11
  fail_count: 0
  total_invariants: 11
  notes: Synthesis succeeded in 1 iteration(s). 11 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
