spec: pathlib_extra2821
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "pathlib path classes are filesystem path objects, not numeric types."
    - "pathlib.PurePath defines __truediv__ and __rtruediv__ for the / operator (path joining), but NOT __radd__, __rsub__, or __rmul__."
    - "None of PurePath, PurePosixPath, PureWindowsPath, or Path define any of the three reflected arithmetic operators."
    - "Absence is consistent across all four tested pathlib classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __radd__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2821.radd_protocol:
  description: "__radd__ is absent from all pathlib path class __dict__s — path objects have no addition semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2821

  columns: [id, function, args, expected]
  rows:
    - ["pp2821001", "pathlib.PurePath.__dict__.__contains__",        ["__radd__"], false]
    - ["pp2821002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__radd__"], false]
    - ["pp2821003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__radd__"], false]
    - ["pp2821004", "pathlib.Path.__dict__.__contains__",            ["__radd__"], false]

# ---------------------------------------------------------------------------
# Table: __rsub__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2821.rsub_protocol:
  description: "__rsub__ is absent from all pathlib path class __dict__s — path objects have no subtraction semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2821

  columns: [id, function, args, expected]
  rows:
    - ["pp2821005", "pathlib.PurePath.__dict__.__contains__",        ["__rsub__"], false]
    - ["pp2821006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rsub__"], false]
    - ["pp2821007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rsub__"], false]
    - ["pp2821008", "pathlib.Path.__dict__.__contains__",            ["__rsub__"], false]

# ---------------------------------------------------------------------------
# Table: __rmul__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2821.rmul_protocol:
  description: "__rmul__ is absent from all pathlib path class __dict__s — path objects have no multiplication semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2821

  columns: [id, function, args, expected]
  rows:
    - ["pp2821009", "pathlib.PurePath.__dict__.__contains__",        ["__rmul__"], false]
    - ["pp2821010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rmul__"], false]
    - ["pp2821011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rmul__"], false]
    - ["pp2821012", "pathlib.Path.__dict__.__contains__",            ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table: path division operator — PurePath defines __truediv__ and __rtruediv__
# but NOT the other reflected arithmetic operators
# This table confirms the / operator is the only arithmetic-like operator present
# ---------------------------------------------------------------------------

table pathlib_extra2821.division_vs_reflected_arithmetic:
  description: "pathlib.PurePath defines __truediv__ and __rtruediv__ for path joining, but NOT __radd__/__rsub__/__rmul__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2821

  columns: [id, function, args, expected]
  rows:
    - ["pp2821013", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2821014", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pp2821015", "pathlib.PurePath.__dict__.__contains__", ["__radd__"],     false]
    - ["pp2821016", "pathlib.PurePath.__dict__.__contains__", ["__rsub__"],     false]
    - ["pp2821017", "pathlib.PurePath.__dict__.__contains__", ["__rmul__"],     false]
