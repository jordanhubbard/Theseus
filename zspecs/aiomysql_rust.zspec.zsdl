spec: aiomysql_rust
version: ">=3.9"
backend: rust_module(aiomysql_rust)

docs: https://aiomysql.readthedocs.io/

provenance:
  derived_from:
    - "https://aiomysql.readthedocs.io/ — aiomysql library"
  notes:
    - "aiomysql provides async MySQL driver."
    - "aiomysql.Connection is a class."
    - "aiomysql.connect is callable."
    - "aiomysql.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant aiomysql_rust.has_connect:
  description: "aiomysql.connect is callable"
  category: presence
  kind: python_call_eq
  function: aiomysql_has_connect
  args: []
  expected: true

invariant aiomysql_rust.has_connection_class:
  description: "aiomysql.Connection is a class"
  category: presence
  kind: python_call_eq
  function: aiomysql_has_connection_class
  args: []
  expected: true

invariant aiomysql_rust.version_nonempty:
  description: "aiomysql.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: aiomysql_version_nonempty
  args: []
  expected: true

