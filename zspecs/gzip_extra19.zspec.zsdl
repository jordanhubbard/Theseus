spec: gzip_extra19
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
  notes:
    - "This spec extends gzip_extra18.zspec.zsdl."
    - "Prior specs covered: GzipFile/__name__/__module__/__qualname__, BadGzipFile/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, GzipFile/__init__.__name__, BadGzipFile/__init__.__name__, open/__qualname__, compress/__qualname__, decompress/__qualname__, module/__len__() for all five identifiers, __name__.__len__() for all five identifiers, __qualname__.__len__() for GzipFile and BadGzipFile."
    - "This spec covers: gzip.GzipFile.__mro__.__len__(), gzip.BadGzipFile.__mro__.__len__(), gzip.GzipFile.__bases__[0].__name__.__len__(), gzip.BadGzipFile.__bases__[0].__name__.__len__(), gzip.GzipFile.__init__.__qualname__.__len__(), gzip.GzipFile.read.__qualname__.__len__(), gzip.GzipFile.write.__qualname__.__len__(), gzip.GzipFile.close.__qualname__.__len__()."
    - "gzip.GzipFile.__mro__.__len__() == 7: MRO is [GzipFile, BaseStream, BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]. Verified 2026-04-10."
    - "gzip.BadGzipFile.__mro__.__len__() == 5: MRO is [BadGzipFile, OSError, Exception, BaseException, object]. Verified 2026-04-10."
    - "gzip.GzipFile.__bases__[0].__name__ == 'BaseStream' (len 10): GzipFile directly inherits from the internal BaseStream mixin. Verified 2026-04-10."
    - "gzip.BadGzipFile.__bases__[0].__name__ == 'OSError' (len 7): BadGzipFile directly inherits from OSError. Verified 2026-04-10."
    - "gzip.GzipFile.__init__.__qualname__ == 'GzipFile.__init__' (len 17). Verified 2026-04-10."
    - "gzip.GzipFile.read.__qualname__ == 'GzipFile.read' (len 13). Verified 2026-04-10."
    - "gzip.GzipFile.write.__qualname__ == 'GzipFile.write' (len 14). Verified 2026-04-10."
    - "gzip.GzipFile.close.__qualname__ == 'GzipFile.close' (len 14). Verified 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile.__mro__.__len__() == 7 — novel, extra19 anchor
#
# gzip.GzipFile.__mro__ is [GzipFile, BaseStream, BufferedIOBase,
# _BufferedIOBase, IOBase, _IOBase, object] — seven entries. No prior gzip
# spec checks __mro__.__len__() for GzipFile. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.GzipFile.mro_len:
  description: "gzip.GzipFile.__mro__.__len__() == 7 — GzipFile MRO has seven entries (extra19)"
  category: class_hierarchy
  kind: python_call_eq
  function: GzipFile.__mro__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# BadGzipFile.__mro__.__len__() == 5 — novel, extra19 anchor
#
# gzip.BadGzipFile.__mro__ is [BadGzipFile, OSError, Exception,
# BaseException, object] — five entries. No prior gzip spec checks
# __mro__.__len__() for BadGzipFile. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.BadGzipFile.mro_len:
  description: "gzip.BadGzipFile.__mro__.__len__() == 5 — BadGzipFile MRO has five entries (extra19)"
  category: class_hierarchy
  kind: python_call_eq
  function: BadGzipFile.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# GzipFile.__bases__[0].__name__.__len__() == 10 — novel, extra19 anchor
#
# gzip.GzipFile.__bases__[0].__name__ == 'BaseStream' which has 10
# characters. GzipFile inherits directly from the internal BaseStream mixin.
# No prior gzip spec checks __bases__[0].__name__.__len__(). Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.GzipFile.bases0_name_len:
  description: "gzip.GzipFile.__bases__[0].__name__.__len__() == 10 — 'BaseStream' has ten characters (extra19)"
  category: class_hierarchy
  kind: python_call_eq
  function: "GzipFile.__bases__[0].__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# BadGzipFile.__bases__[0].__name__.__len__() == 7 — novel, extra19 anchor
#
# gzip.BadGzipFile.__bases__[0].__name__ == 'OSError' which has 7
# characters. BadGzipFile inherits directly from OSError. No prior gzip spec
# checks __bases__[0].__name__.__len__() for BadGzipFile. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.BadGzipFile.bases0_name_len:
  description: "gzip.BadGzipFile.__bases__[0].__name__.__len__() == 7 — 'OSError' has seven characters (extra19)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BadGzipFile.__bases__[0].__name__.__len__"
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# GzipFile.__init__.__qualname__.__len__() == 17 — novel, extra19 anchor
#
# gzip.GzipFile.__init__.__qualname__ == 'GzipFile.__init__' which has 17
# characters. No prior gzip spec checks __qualname__.__len__() for
# GzipFile.__init__. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.GzipFile.init_qualname_len:
  description: "gzip.GzipFile.__init__.__qualname__.__len__() == 17 — 'GzipFile.__init__' has seventeen characters (extra19)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.__init__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# GzipFile.read.__qualname__.__len__() == 13 — novel, extra19 anchor
#
# gzip.GzipFile.read.__qualname__ == 'GzipFile.read' which has 13
# characters. No prior gzip spec checks __qualname__.__len__() for
# GzipFile.read. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.GzipFile.read_qualname_len:
  description: "gzip.GzipFile.read.__qualname__.__len__() == 13 — 'GzipFile.read' has thirteen characters (extra19)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.read.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# GzipFile.write.__qualname__.__len__() == 14 — novel, extra19 anchor
#
# gzip.GzipFile.write.__qualname__ == 'GzipFile.write' which has 14
# characters. No prior gzip spec checks __qualname__.__len__() for
# GzipFile.write. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.GzipFile.write_qualname_len:
  description: "gzip.GzipFile.write.__qualname__.__len__() == 14 — 'GzipFile.write' has fourteen characters (extra19)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.write.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# GzipFile.close.__qualname__.__len__() == 14 — novel, extra19 anchor
#
# gzip.GzipFile.close.__qualname__ == 'GzipFile.close' which has 14
# characters. No prior gzip spec checks __qualname__.__len__() for
# GzipFile.close. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra19.GzipFile.close_qualname_len:
  description: "gzip.GzipFile.close.__qualname__.__len__() == 14 — 'GzipFile.close' has fourteen characters (extra19)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.close.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# __mro__.__len__() table — GzipFile, BadGzipFile (extra19)
#
# GzipFile has a 7-entry MRO (inherits through BaseStream into the io
# hierarchy); BadGzipFile has a 5-entry MRO (inherits through OSError).
# This table anchors both MRO depths from the extra19 namespace.
# ---------------------------------------------------------------------------

table gzip_extra19.mro_depths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mrodepth19

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__mro__.__len__,    [], 7]
    - [BadGzipFile, BadGzipFile.__mro__.__len__, [], 5]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() table — GzipFile, BadGzipFile (extra19)
#
# GzipFile.__bases__[0].__name__ == 'BaseStream' (len 10);
# BadGzipFile.__bases__[0].__name__ == 'OSError' (len 7).
# This table anchors the direct-base name lengths from the extra19 namespace.
# ---------------------------------------------------------------------------

table gzip_extra19.bases0_name_lengths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases0nlen19

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    "GzipFile.__bases__[0].__name__.__len__",    [], 10]
    - [BadGzipFile, "BadGzipFile.__bases__[0].__name__.__len__", [], 7]

# ---------------------------------------------------------------------------
# GzipFile method __qualname__.__len__() table — __init__, read, write,
#                                                 close (extra19)
#
# No prior gzip spec presents method __qualname__.__len__() checks in a
# table. __init__=17, read=13, write=14, close=14. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table gzip_extra19.GzipFile_method_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: methqnlen19

  columns: [id, function, args, expected]
  rows:
    - [init,  GzipFile.__init__.__qualname__.__len__,  [], 17]
    - [read,  GzipFile.read.__qualname__.__len__,      [], 13]
    - [write, GzipFile.write.__qualname__.__len__,     [], 14]
    - [close, GzipFile.close.__qualname__.__len__,     [], 14]
