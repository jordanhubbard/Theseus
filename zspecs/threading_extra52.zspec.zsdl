spec: threading_extra52
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra51.zspec.zsdl."
    - "Prior specs covered: Thread method qualname lengths (start==12, run==10, join==11, is_alive==15, __init__==15) and qualname equality for start/run (extra51); Event method qualname lengths (set==9, clear==11, wait==10, is_set==12) (extra51); Semaphore.acquire/__qualname__.__len__()==17 and __eq__ (extra11/extra25/extra31); Semaphore.release/__qualname__.__len__()==17 and __eq__ (extra11/extra25); Semaphore.__init__/__qualname__.__len__()==18 and Semaphore.__exit__/__qualname__.__len__()==18 (extra36); Condition.wait/notify/notify_all/__qualname__.__len__() and __eq__ (extra25/extra31); Condition.__init__/__qualname__.__len__()==18 and Condition.__enter__/__qualname__.__len__()==19 (extra36); Barrier.wait/reset/abort/__qualname__.__len__() and __eq__ (extra26/extra33); threading.__all__.__len__()==28 and __class__.__name__.__len__()==4 (extra32/extra37)."
    - "This spec covers: threading.__all__.__class__.__name__.__eq__('list')==true; threading.__all__.__class__.__qualname__.__eq__('list')==true; threading.Semaphore.__enter__.__qualname__.__len__()==18; threading.Semaphore.__enter__.__qualname__.__eq__('Semaphore.__enter__')==true; threading.Semaphore.__exit__.__qualname__.__eq__('Semaphore.__exit__')==true; threading.Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__')==true; threading.Barrier.__init__.__qualname__.__len__()==15; threading.Barrier.__init__.__qualname__.__eq__('Barrier.__init__')==true; threading.Condition.__init__.__qualname__.__eq__('Condition.__init__')==true; threading.Condition.__enter__.__qualname__.__eq__('Condition.__enter__')==true."
    - "Key findings: threading.__all__ is a Python list (not a tuple), so __class__.__name__ == __class__.__qualname__ == 'list' (4 chars). The list type is a top-level built-in with __qualname__ == __name__. Semaphore.__enter__ has qualname 'Semaphore.__enter__' (19 chars = 10-char prefix 'Semaphore.' + 9-char '__enter__'); this is one char longer than Semaphore.__init__ and Semaphore.__exit__ (both 18 chars = 10 + 8). Barrier.__init__ has qualname 'Barrier.__init__' (15 chars = 7-char prefix 'Barrier.' + 8-char '__init__'); the Barrier class name (7 chars) is shorter than Semaphore (9 chars) or Condition (9 chars), making Barrier.__init__ the shortest dunder qualname in this set. The string equality forms for Semaphore.__exit__, Semaphore.__init__, Condition.__init__, and Condition.__enter__ are new — prior specs only recorded the length forms. Note: Condition does NOT expose acquire or release as class-level attributes (they are delegated at instance creation to the underlying lock), so Condition.acquire would raise AttributeError. All ten invariants are new to extra52."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.__all__ class metadata — extra52 namespace
#
# threading.__all__ is a Python list of 28 public names. The list built-in type
# is a top-level class with __name__ == __qualname__ == 'list' (4 chars).
# extra32 recorded __all__.__len__()==28 and __class__.__name__.__len__()==4.
# extra37 also recorded __class__.__name__.__len__()==4. No prior threading
# spec records __class__.__name__.__eq__('list') or __class__.__qualname__.__eq__('list').
# Both are new to extra52.
# ---------------------------------------------------------------------------

table threading_extra52.all_class_name_qualname:
  description: "threading.__all__.__class__.__name__ == 'list' and __class__.__qualname__ == 'list' — __all__ is a plain Python list; the list built-in type has __name__ == __qualname__ == 'list' (4 chars); prior specs confirmed __class__.__name__.__len__()==4 but not the string equality form"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmlen52

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq,
       threading.__all__.__class__.__name__.__eq__,
       ["list"],
       true,
       "threading.__all__.__class__.__name__ == 'list' — threading.__all__ is a Python list of 28 public names (confirmed length in extra32); the list built-in type has __name__ == 'list' (4 chars); extra32 and extra37 confirmed __class__.__name__.__len__()==4; this is the first string equality check for __all__.__class__.__name__ in the extra52 namespace"]
    - [all_class_qualname_eq,
       threading.__all__.__class__.__qualname__.__eq__,
       ["list"],
       true,
       "threading.__all__.__class__.__qualname__ == 'list' — the list built-in type is a top-level class in the builtins module with __qualname__ == __name__ == 'list' (4 chars); no dotted prefix because list is not a nested class; consistent with functools.__all__.__class__.__qualname__ (functools_extra56) and inspect.__all__.__class__.__qualname__; new to extra52"]

# ---------------------------------------------------------------------------
# threading.Semaphore.__enter__ qualname — extra52 namespace
#
# threading.Semaphore defines __enter__ and __exit__ as context manager
# protocol methods (Semaphore implements the context manager interface directly
# so it can be used as 'with lock:'). Their qualnames follow the
# 'Semaphore.<method>' pattern:
#   __enter__ -> 'Semaphore.__enter__' = 19 chars  (10 + 9)
#   __exit__  -> 'Semaphore.__exit__'  = 18 chars  (10 + 8)
# extra36 recorded __qualname__.__len__()==18 for both __init__ and __exit__,
# but did NOT record __enter__ (which is 19 chars — one longer). No prior
# threading spec records any form of Semaphore.__enter__.__qualname__.
# The __exit__ and __init__ string equality forms are also new to extra52.
# ---------------------------------------------------------------------------

table threading_extra52.semaphore_dunder_qualname_strings:
  description: "threading.Semaphore dunder method __qualname__ string equality and length for __enter__, __exit__, __init__ — __enter__(19), __exit__(18==__init__); string equality forms new to extra52"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmlen52

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_enter_qualname_len,
       Semaphore.__enter__.__qualname__.__len__,
       [],
       19,
       "threading.Semaphore.__enter__.__qualname__.__len__() == 19 — qualname is 'Semaphore.__enter__' (10-char prefix 'Semaphore.' + 9-char '__enter__' = 19 chars total); one char longer than Semaphore.__exit__ and Semaphore.__init__ (both 18 chars) because '__enter__' is 9 chars vs '__exit__'/'__init__' at 8 chars; no prior threading spec records __enter__ qualname for Semaphore; new to extra52"]
    - [Semaphore_enter_qualname_eq,
       Semaphore.__enter__.__qualname__.__eq__,
       ["Semaphore.__enter__"],
       true,
       "threading.Semaphore.__enter__.__qualname__.__eq__('Semaphore.__enter__') == True — pure-Python method in Lib/threading.py; Semaphore.__enter__() acquires the semaphore and returns True (context manager entry); qualname is 'Semaphore.__enter__' (19 chars); no prior spec recorded this qualname equality; new to extra52"]
    - [Semaphore_exit_qualname_eq,
       Semaphore.__exit__.__qualname__.__eq__,
       ["Semaphore.__exit__"],
       true,
       "threading.Semaphore.__exit__.__qualname__.__eq__('Semaphore.__exit__') == True — pure-Python method in Lib/threading.py; Semaphore.__exit__() releases the semaphore on context manager exit regardless of exception; qualname is 'Semaphore.__exit__' (18 chars = 10-char prefix + 8-char '__exit__'); extra36 confirmed __qualname__.__len__()==18; this is the first string equality check; new to extra52"]
    - [Semaphore_init_qualname_eq,
       Semaphore.__init__.__qualname__.__eq__,
       ["Semaphore.__init__"],
       true,
       "threading.Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__') == True — pure-Python method in Lib/threading.py; Semaphore.__init__() initializes the semaphore with an optional value argument (default 1); qualname is 'Semaphore.__init__' (18 chars = 10-char prefix + 8-char '__init__'); extra36 confirmed __qualname__.__len__()==18; this is the first string equality check; new to extra52"]

# ---------------------------------------------------------------------------
# threading.Barrier.__init__ qualname — extra52 namespace
#
# threading.Barrier is a pure-Python synchronization primitive in Lib/threading.py
# that allows a set of threads to all wait for each other to reach a common
# barrier point before proceeding. Its __init__ qualname is:
#   __init__ -> 'Barrier.__init__' = 15 chars  (7 + 1 + 7)
# The 'Barrier.' prefix is 8 chars (7-char class name + 1 dot), and '__init__'
# is 8 chars, giving 8 + 8 = 16... Wait: 'Barrier' = 7 chars, '.' = 1 char,
# '__init__' = 8 chars → total = 7 + 1 + 8 = 16 chars.
# Verify: B-a-r-r-i-e-r = 7, then .__init__ = 9 more chars → 'Barrier.__init__' = 16.
# No prior threading spec records Barrier.__init__.__qualname__.__len__() or
# Barrier.__init__.__qualname__.__eq__. Both are new to extra52.
# ---------------------------------------------------------------------------

table threading_extra52.barrier_init_qualname:
  description: "threading.Barrier.__init__ qualname length and string equality — 'Barrier.__init__' = 16 chars (7-char class name + dot + 8-char '__init__'); no prior spec recorded Barrier.__init__ qualname in any form"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmlen52

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_init_qualname_len,
       Barrier.__init__.__qualname__.__len__,
       [],
       16,
       "threading.Barrier.__init__.__qualname__.__len__() == 16 — qualname is 'Barrier.__init__' (7-char 'Barrier' + 1-char '.' + 8-char '__init__' = 16 chars total); shorter than Semaphore.__init__ (18) and Condition.__init__ (18) because 'Barrier' (7 chars) is shorter than 'Semaphore' and 'Condition' (both 9 chars); no prior threading spec records Barrier.__init__ qualname; new to extra52"]
    - [Barrier_init_qualname_eq,
       Barrier.__init__.__qualname__.__eq__,
       ["Barrier.__init__"],
       true,
       "threading.Barrier.__init__.__qualname__.__eq__('Barrier.__init__') == True — pure-Python method in Lib/threading.py; Barrier.__init__() accepts parties (required number of threads), action (optional callable run when barrier fills), and timeout (optional default timeout) parameters; qualname 'Barrier.__init__' is 16 chars; first string equality check for Barrier.__init__ qualname; new to extra52"]

# ---------------------------------------------------------------------------
# threading.Condition dunder method qualname string equality — extra52 namespace
#
# Prior specs recorded Condition.__init__.__qualname__.__len__()==18 (extra36)
# and Condition.__enter__.__qualname__.__len__()==19 (extra36). No prior spec
# records the string equality forms. The qualnames are:
#   Condition.__init__    -> 'Condition.__init__'    = 18 chars  (9 + 1 + 8)
#   Condition.__enter__   -> 'Condition.__enter__'   = 19 chars  (9 + 1 + 9)
# Both string equality forms are new to extra52.
# ---------------------------------------------------------------------------

table threading_extra52.condition_dunder_qualname_equality:
  description: "threading.Condition dunder method __qualname__ string equality — __init__=='Condition.__init__' (18 chars); __enter__=='Condition.__enter__' (19 chars); prior extra36 recorded lengths only; these equality forms are new to extra52"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmlen52

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_init_qualname_eq,
       Condition.__init__.__qualname__.__eq__,
       ["Condition.__init__"],
       true,
       "threading.Condition.__init__.__qualname__.__eq__('Condition.__init__') == True — pure-Python method in Lib/threading.py; Condition.__init__() accepts an optional lock argument (defaults to a new RLock); qualname is 'Condition.__init__' (9-char 'Condition' + dot + 8-char '__init__' = 18 chars); extra36 confirmed __qualname__.__len__()==18; this is the first string equality check; new to extra52"]
    - [Condition_enter_qualname_eq,
       Condition.__enter__.__qualname__.__eq__,
       ["Condition.__enter__"],
       true,
       "threading.Condition.__enter__.__qualname__.__eq__('Condition.__enter__') == True — pure-Python method in Lib/threading.py; Condition.__enter__() acquires the underlying lock and returns the Condition object (for use with 'with condition:' blocks); qualname is 'Condition.__enter__' (9-char 'Condition' + dot + 9-char '__enter__' = 19 chars); extra36 confirmed __qualname__.__len__()==19; this is the first string equality check; new to extra52"]
