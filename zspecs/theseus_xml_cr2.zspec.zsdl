spec: theseus_xml_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_xml_cr2)
blocks: xml

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "https://www.w3.org/TR/xml/"
  notes:
    - "Clean-room extended XML/ElementTree utilities. Do NOT import xml or xml.etree."
    - "Element.findall(match): return list of child elements matching tag."
    - "Element.iter(tag=None): iterate over all elements in subtree."
    - "SubElement(parent, tag, attrib={}, **extra): create child element and attach to parent."
    - "xml2_findall(): root with 2 'child' elements; root.findall('child') has length 2."
    - "xml2_iter(): list(root.iter()) includes root and all children — length > 1."
    - "xml2_subelement(): SubElement(root, 'new') appends child; root[-1].tag == 'new'."
    - "Zero-arg invariant signatures — def xml2_findall(): return hardcoded_result"
    - "findall: scan children for matching tag; return list (empty if none found)."
    - "iter: breadth/depth-first traversal of element tree starting from self."
    - "SubElement: create new Element, append to parent.children, return new element."
    - "Export: Element, SubElement, ElementTree, parse, fromstring, tostring, iterparse."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_xml_cr2.findall:
  description: "root.findall('child') returns list of matching children"
  category: findall
  kind: python_call_eq
  function: xml2_findall
  args: []
  expected: 2

invariant theseus_xml_cr2.iter:
  description: "list(root.iter()) includes root and all descendants"
  category: iter
  kind: python_call_eq
  function: xml2_iter
  args: []
  expected: true

invariant theseus_xml_cr2.subelement:
  description: "SubElement appends new child; last child has correct tag"
  category: SubElement
  kind: python_call_eq
  function: xml2_subelement
  args: []
  expected: "new"
