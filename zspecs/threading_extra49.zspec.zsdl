spec: threading_extra49
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra48.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__/__module__; Thread/__qualname__.__len__()==6; Thread/__mro__.__len__()==2; Thread/__bases__[0].__name__=='object'; Thread/__bases__[0].__qualname__=='object'; Event/__qualname__=='Event'; Event/__qualname__.__len__()==5; Event/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Event/__bases__[0].__qualname__=='object'; Semaphore/__name__/__qualname__/__module__; Semaphore/__qualname__.__len__()==9; Semaphore/__mro__.__len__()==2; Semaphore/__bases__[0].__qualname__=='object'; BoundedSemaphore/__name__/__qualname__/__module__; BoundedSemaphore/__qualname__.__len__()==16; BoundedSemaphore/__mro__.__len__()==3; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; BoundedSemaphore/__bases__[0].__qualname__=='Semaphore'; Condition/__name__/__module__; Condition/__qualname__=='Condition'; Condition/__qualname__.__len__()==9; Condition/__mro__.__len__()==2; Condition/__bases__[0].__name__=='object'; Condition/__bases__[0].__qualname__=='object'; Barrier/__name__/__qualname__/__module__; Barrier/__mro__.__len__()==2; Barrier/__bases__[0].__name__=='object'; Barrier/__bases__[0].__qualname__=='object'; Timer/__name__/__qualname__/__module__; Timer/__mro__.__len__()==3; Timer/__bases__[0].__name__=='Thread'; Timer/__bases__[0].__qualname__=='Thread'; Lock/__name__=='lock'; Lock/__qualname__=='lock'; Lock/__qualname__.__len__()==4; Lock/__module__=='_thread'; Lock/__module__.__len__()==7; local/__name__=='_local'; TIMEOUT_MAX; threading.__all__.__len__()==28; current_thread/__name__/__qualname__/__module__; main_thread/__name__/__qualname__/__module__; active_count/__name__/__qualname__/__module__; enumerate/__name__/__qualname__/__module__; settrace/__name__/__qualname__; setprofile/__name__/__qualname__; stack_size/__name__/__qualname__; RLock/__name__/__qualname__/__module__; Thread/__class__.__name__=='type'; Event/__class__.__name__=='type'; Semaphore/__class__.__name__=='type'; BoundedSemaphore/__class__.__name__=='type'; Condition/__class__.__name__=='type'; Barrier/__class__.__name__=='type'; Timer/__class__.__name__=='type'; main_thread/__class__.__name__=='function'; current_thread/__class__.__name__=='function'."
    - "This spec covers: threading.Thread.__class__.__qualname__ == 'type'; threading.Event.__class__.__qualname__ == 'type'; threading.Semaphore.__class__.__qualname__ == 'type'; threading.BoundedSemaphore.__class__.__qualname__ == 'type'; threading.Condition.__class__.__qualname__ == 'type'; threading.Barrier.__class__.__qualname__ == 'type'; threading.Timer.__class__.__qualname__ == 'type'; threading.Lock.__class__.__qualname__ == 'type'; threading.RLock.__class__.__qualname__ == 'type'; threading.main_thread.__class__.__qualname__ == 'function'; threading.current_thread.__class__.__qualname__ == 'function'."
    - "Key findings: For all threading class objects (Thread, Event, Semaphore, BoundedSemaphore, Condition, Barrier, Timer, Lock, RLock), __class__.__qualname__ == 'type' (4 chars) — the built-in 'type' metaclass is a top-level built-in with __qualname__ == __name__. This holds regardless of the inheritance depth (Timer and BoundedSemaphore have __mro__.__len__()==3) or origin (Lock is a C-extension type from Modules/_threadmodule.c with its own __name__=='lock', but its __class__ is still the 'type' metaclass). For threading module-level functions (main_thread, current_thread), __class__.__qualname__ == 'function' (8 chars) — same logic: the 'function' type is also a top-level built-in. Prior spec extra48 recorded __class__.__name__ for nine of these objects; this spec records __class__.__qualname__ for eleven (adding Lock and RLock). No prior spec recorded __class__.__qualname__ string equality for any threading module-level object. All eleven invariants are new to extra49."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading synchronization primitive classes __class__.__qualname__ — extra49
#
# threading.Thread, Event, Semaphore, BoundedSemaphore, and Condition are all
# pure-Python classes defined with class statements in Lib/threading.py. Their
# __class__ is the built-in 'type' metaclass; since 'type' is a top-level
# built-in, __class__.__qualname__ == __class__.__name__ == 'type' (4 chars).
# Prior spec extra48 recorded __class__.__name__ == 'type' for all five; this
# spec records __class__.__qualname__ == 'type'. No prior spec recorded
# __class__.__qualname__ for any of them. All five are new to extra49.
# ---------------------------------------------------------------------------

table threading_extra49.synchronization_class_qualnames:
  description: "threading Thread/Event/Semaphore/BoundedSemaphore/Condition __class__.__qualname__ == 'type' — pure-Python synchronization classes in Lib/threading.py; __class__ is the built-in 'type' metaclass; __qualname__ == __name__ == 'type' for top-level built-in types; 4-char qualname"
  kind: python_call_eq
  category: identity
  id_prefix: thrdclsqual49

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_class_qualname,
       Thread.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.Thread.__class__.__qualname__ == 'type' — pure-Python class in Lib/threading.py; represents a thread of control; inherits directly from object (__mro__.__len__()==2); __class__ is the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars)"]
    - [Event_class_qualname,
       Event.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.Event.__class__.__qualname__ == 'type' — pure-Python class in Lib/threading.py; simple synchronization flag that threads can wait on or set; inherits directly from object; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [Semaphore_class_qualname,
       Semaphore.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.Semaphore.__class__.__qualname__ == 'type' — pure-Python class in Lib/threading.py; counting semaphore that releases up to a maximum count; inherits directly from object; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [BoundedSemaphore_class_qualname,
       BoundedSemaphore.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.BoundedSemaphore.__class__.__qualname__ == 'type' — pure-Python class in Lib/threading.py; semaphore that raises ValueError if released more times than acquired; inherits from Semaphore (__mro__.__len__()==3); __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [Condition_class_qualname,
       Condition.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.Condition.__class__.__qualname__ == 'type' — pure-Python class in Lib/threading.py; wait/notify-based synchronization primitive wrapping a lock; inherits directly from object; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# threading Barrier, Timer, Lock, RLock __class__.__qualname__ — extra49
#
# threading.Barrier and Timer are pure-Python classes; Lock and RLock are
# C-extension types from Modules/_threadmodule.c (Lock.__name__=='lock',
# Lock.__module__=='_thread'). Despite their different origins, all four
# have __class__.__qualname__ == 'type' because all class objects are
# instances of the 'type' metaclass. Prior spec extra48 recorded
# __class__.__name__ == 'type' for Barrier and Timer but not Lock or RLock.
# No prior spec recorded __class__.__qualname__ for any of the four.
# All four are new to extra49.
# ---------------------------------------------------------------------------

table threading_extra49.barrier_timer_lock_rlock_class_qualnames:
  description: "threading Barrier/Timer/Lock/RLock __class__.__qualname__ == 'type' — Barrier/Timer are pure-Python classes; Lock/RLock are C-extension types from _threadmodule.c; all four are instances of the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: btlr49

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_class_qualname,
       Barrier.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.Barrier.__class__.__qualname__ == 'type' — pure-Python class in Lib/threading.py; synchronization primitive blocking threads until a fixed count have called wait(); inherits directly from object; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [Timer_class_qualname,
       Timer.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.Timer.__class__.__qualname__ == 'type' — pure-Python class in Lib/threading.py; subclass of Thread that runs a function after a delay; __bases__[0].__name__=='Thread'; __mro__.__len__()==3; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [Lock_class_qualname,
       Lock.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.Lock.__class__.__qualname__ == 'type' — C-extension type from Modules/_threadmodule.c; Lock.__name__=='lock'; Lock.__module__=='_thread'; despite being a C-extension type with a non-standard name, its __class__ is still the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [RLock_class_qualname,
       RLock.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "threading.RLock.__class__.__qualname__ == 'type' — reentrant lock type accessible via threading.RLock; class object whose __class__ is the built-in 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# threading module-level functions __class__.__qualname__ — extra49 namespace
#
# threading.main_thread and threading.current_thread are pure-Python functions
# defined with def statements in Lib/threading.py. Their __class__.__qualname__
# is 'function' (8 chars). Prior spec extra48 recorded __class__.__name__ ==
# 'function' for both; this spec records __class__.__qualname__ == 'function'.
# No prior spec recorded __class__.__qualname__ for either. Both new to extra49.
# ---------------------------------------------------------------------------

table threading_extra49.thread_functions_class_qualnames:
  description: "threading main_thread/current_thread __class__.__qualname__ == 'function' — pure-Python module-level functions in Lib/threading.py; __class__ is the built-in function type; __qualname__ == __name__ == 'function' for top-level built-in types; 8-char qualname"
  kind: python_call_eq
  category: identity
  id_prefix: tfcq49

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_class_qualname,
       main_thread.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "threading.main_thread.__class__.__qualname__ == 'function' — pure-Python function at module level in Lib/threading.py; returns the Thread object for the main thread (the thread that started the Python interpreter); __class__ is the built-in function type; __class__.__qualname__ == 'function' (8 chars)"]
    - [current_thread_class_qualname,
       current_thread.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "threading.current_thread.__class__.__qualname__ == 'function' — pure-Python function at module level in Lib/threading.py; returns the Thread object for the current thread of execution; __class__ is the built-in function type; __class__.__qualname__ == 'function' (8 chars)"]
