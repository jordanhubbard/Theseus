spec: pprint_extra17
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl through pprint_extra16.zspec.zsdl."
    - "pprint_extra15 covers: PrettyPrinter.__init__.__qualname__=='PrettyPrinter.__init__'; PrettyPrinter.__init__.__name__=='__init__'."
    - "pprint_extra16 covers: PrettyPrinter.pprint/pformat/isreadable/isrecursive.__qualname__ as standalone invariants."
    - "No prior spec verifies PrettyPrinter.__repr__.__qualname__, PrettyPrinter._pprint_dict.__qualname__, PrettyPrinter._pprint_list.__qualname__, PrettyPrinter._pprint_tuple.__qualname__, PrettyPrinter._pprint_set.__qualname__, or PrettyPrinter._format.__qualname__ as standalone invariants."
    - "This spec covers: PrettyPrinter.__repr__.__qualname__=='object.__repr__' (inherited from object); PrettyPrinter._pprint_dict/__qualname__=='PrettyPrinter._pprint_dict'; PrettyPrinter._pprint_list/__qualname__=='PrettyPrinter._pprint_list'; PrettyPrinter._pprint_tuple/__qualname__=='PrettyPrinter._pprint_tuple'; PrettyPrinter._pprint_set/__qualname__=='PrettyPrinter._pprint_set'; PrettyPrinter._format/__qualname__=='PrettyPrinter._format'."
    - "PrettyPrinter.__repr__ is inherited from object, so its __qualname__ is 'object.__repr__', not 'PrettyPrinter.__repr__'. Verified at runtime."
    - "PrettyPrinter._pprint_dict.__qualname__ == 'PrettyPrinter._pprint_dict' — private dispatch method. Verified at runtime."
    - "PrettyPrinter._pprint_list.__qualname__ == 'PrettyPrinter._pprint_list' — private dispatch method. Verified at runtime."
    - "PrettyPrinter._pprint_tuple.__qualname__ == 'PrettyPrinter._pprint_tuple' — private dispatch method. Verified at runtime."
    - "PrettyPrinter._pprint_set.__qualname__ == 'PrettyPrinter._pprint_set' — private dispatch method. Verified at runtime."
    - "PrettyPrinter._format.__qualname__ == 'PrettyPrinter._format' — private recursive formatting method. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PrettyPrinter.__repr__ method __qualname__
#
# PrettyPrinter does not define __repr__ itself; it inherits it from object.
# Therefore __qualname__ is 'object.__repr__', not 'PrettyPrinter.__repr__'.
# No prior spec verifies this inherited-qualname property as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra17.PrettyPrinter.__repr__qualname:
  description: "pprint.PrettyPrinter.__repr__.__qualname__ == 'object.__repr__' — inherited from object"
  category: function_identity
  kind: python_call_eq
  function: "PrettyPrinter.__repr__.__qualname__.__eq__"
  args: ["object.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._pprint_dict method __qualname__
#
# No prior spec verifies PrettyPrinter._pprint_dict.__qualname__ as a standalone
# invariant. This is a private dispatch method for dict types.
# Verified: PrettyPrinter._pprint_dict.__qualname__ == 'PrettyPrinter._pprint_dict'.
# ---------------------------------------------------------------------------

invariant pprint_extra17.PrettyPrinter._pprint_dict_qualname:
  description: "pprint.PrettyPrinter._pprint_dict.__qualname__ == 'PrettyPrinter._pprint_dict' — private dispatch method qualname"
  category: function_identity
  kind: python_call_eq
  function: "PrettyPrinter._pprint_dict.__qualname__.__eq__"
  args: ["PrettyPrinter._pprint_dict"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._pprint_list method __qualname__
#
# No prior spec verifies PrettyPrinter._pprint_list.__qualname__ as a standalone
# invariant. This is a private dispatch method for list types.
# Verified: PrettyPrinter._pprint_list.__qualname__ == 'PrettyPrinter._pprint_list'.
# ---------------------------------------------------------------------------

invariant pprint_extra17.PrettyPrinter._pprint_list_qualname:
  description: "pprint.PrettyPrinter._pprint_list.__qualname__ == 'PrettyPrinter._pprint_list' — private dispatch method qualname"
  category: function_identity
  kind: python_call_eq
  function: "PrettyPrinter._pprint_list.__qualname__.__eq__"
  args: ["PrettyPrinter._pprint_list"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._pprint_tuple method __qualname__
#
# No prior spec verifies PrettyPrinter._pprint_tuple.__qualname__ as a standalone
# invariant. This is a private dispatch method for tuple types.
# Verified: PrettyPrinter._pprint_tuple.__qualname__ == 'PrettyPrinter._pprint_tuple'.
# ---------------------------------------------------------------------------

invariant pprint_extra17.PrettyPrinter._pprint_tuple_qualname:
  description: "pprint.PrettyPrinter._pprint_tuple.__qualname__ == 'PrettyPrinter._pprint_tuple' — private dispatch method qualname"
  category: function_identity
  kind: python_call_eq
  function: "PrettyPrinter._pprint_tuple.__qualname__.__eq__"
  args: ["PrettyPrinter._pprint_tuple"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._pprint_set method __qualname__
#
# No prior spec verifies PrettyPrinter._pprint_set.__qualname__ as a standalone
# invariant. This is a private dispatch method for set and frozenset types.
# Verified: PrettyPrinter._pprint_set.__qualname__ == 'PrettyPrinter._pprint_set'.
# ---------------------------------------------------------------------------

invariant pprint_extra17.PrettyPrinter._pprint_set_qualname:
  description: "pprint.PrettyPrinter._pprint_set.__qualname__ == 'PrettyPrinter._pprint_set' — private dispatch method qualname"
  category: function_identity
  kind: python_call_eq
  function: "PrettyPrinter._pprint_set.__qualname__.__eq__"
  args: ["PrettyPrinter._pprint_set"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._format method __qualname__
#
# No prior spec verifies PrettyPrinter._format.__qualname__ as a standalone
# invariant. This is the private recursive formatting workhorse of the class.
# Verified: PrettyPrinter._format.__qualname__ == 'PrettyPrinter._format'.
# ---------------------------------------------------------------------------

invariant pprint_extra17.PrettyPrinter._format_qualname:
  description: "pprint.PrettyPrinter._format.__qualname__ == 'PrettyPrinter._format' — private recursive format method qualname"
  category: function_identity
  kind: python_call_eq
  function: "PrettyPrinter._format.__qualname__.__eq__"
  args: ["PrettyPrinter._format"]
  expected: true

# ---------------------------------------------------------------------------
# Table: PrettyPrinter private method __qualname__ attributes
#
# Groups the five private-method qualname checks in one indexed table.
# No prior table covers PrettyPrinter private method __qualname__ values.
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra17.PrettyPrinter_private_method_qualnames:
  description: "pprint.PrettyPrinter private method __qualname__ attributes — all include owning class prefix"
  kind: python_call_eq
  category: function_identity
  id_prefix: pp17pmq

  columns: [id, function, args, expected]
  rows:
    - [_pprint_dict,  "PrettyPrinter._pprint_dict.__qualname__.__eq__",  ["PrettyPrinter._pprint_dict"],  true]
    - [_pprint_list,  "PrettyPrinter._pprint_list.__qualname__.__eq__",  ["PrettyPrinter._pprint_list"],  true]
    - [_pprint_tuple, "PrettyPrinter._pprint_tuple.__qualname__.__eq__", ["PrettyPrinter._pprint_tuple"], true]
    - [_pprint_set,   "PrettyPrinter._pprint_set.__qualname__.__eq__",   ["PrettyPrinter._pprint_set"],   true]
    - [_format,       "PrettyPrinter._format.__qualname__.__eq__",       ["PrettyPrinter._format"],       true]
