spec: bz2_extra19
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2_extra18.zspec.zsdl."
    - "Prior specs covered: bz2.__name__/__package__, BZ2File.__name__/__module__/__qualname__, BZ2Compressor.__name__/__module__, BZ2Decompressor.__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, BZ2File.__bases__[0].__name__, BZ2Compressor.__bases__[0].__name__, BZ2Decompressor.__bases__[0].__name__, various __qualname__ checks."
    - "This spec covers: bz2.BZ2File.__init__.__name__, bz2.BZ2Compressor.__init__.__name__, bz2.BZ2Decompressor.__init__.__name__, bz2.open.__qualname__, bz2.compress.__qualname__, bz2.decompress.__qualname__, bz2.open.__module__.__len__(), bz2.compress.__module__.__len__(), bz2.decompress.__module__.__len__(), bz2.BZ2File.__module__.__len__()."
    - "bz2.BZ2File.__init__.__name__ == '__init__': the constructor method name. Verified 2026-04-09."
    - "bz2.BZ2Compressor.__init__.__name__ == '__init__': the constructor method name. Verified 2026-04-09."
    - "bz2.BZ2Decompressor.__init__.__name__ == '__init__': the constructor method name. Verified 2026-04-09."
    - "bz2.open.__qualname__ == 'open': module-level function qualname. Verified 2026-04-09."
    - "bz2.compress.__qualname__ == 'compress': function qualname equals function name. Verified 2026-04-09."
    - "bz2.decompress.__qualname__ == 'decompress': function qualname equals function name. Verified 2026-04-09."
    - "bz2.open.__module__ == 'bz2' (len 3): open lives in the bz2 module. Verified 2026-04-09."
    - "bz2.compress.__module__ == 'bz2' (len 3): compress lives in bz2. Verified 2026-04-09."
    - "bz2.decompress.__module__ == 'bz2' (len 3): decompress lives in bz2. Verified 2026-04-09."
    - "bz2.BZ2File.__module__ == 'bz2' (len 3): BZ2File is defined in bz2. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File.__init__.__name__ == '__init__' — novel, extra19 anchor
#
# No prior bz2 spec checks BZ2File.__init__.__name__. The constructor method
# name is '__init__'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.BZ2File.init_name:
  description: "bz2.BZ2File.__init__.__name__ == '__init__' — constructor method name (extra19)"
  category: method_names
  kind: python_call_eq
  function: BZ2File.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Compressor.__init__.__name__ == '__init__' — novel, extra19 anchor
#
# No prior bz2 spec checks BZ2Compressor.__init__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.BZ2Compressor.init_name:
  description: "bz2.BZ2Compressor.__init__.__name__ == '__init__' — constructor method name (extra19)"
  category: method_names
  kind: python_call_eq
  function: BZ2Compressor.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor.__init__.__name__ == '__init__' — novel, extra19 anchor
#
# No prior bz2 spec checks BZ2Decompressor.__init__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.BZ2Decompressor.init_name:
  description: "bz2.BZ2Decompressor.__init__.__name__ == '__init__' — constructor method name (extra19)"
  category: method_names
  kind: python_call_eq
  function: BZ2Decompressor.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# open.__qualname__ == 'open' — novel, extra19 anchor
#
# No prior bz2 spec checks open.__qualname__ from the extra19 namespace.
# bz2.open is a module-level function; its __qualname__ equals its __name__.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.open.qualname:
  description: "bz2.open.__qualname__ == 'open' — module-level function qualname (extra19)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# compress.__qualname__ == 'compress' — novel, extra19 anchor
#
# No prior bz2 spec checks compress.__qualname__ from the extra19 namespace.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.compress.qualname:
  description: "bz2.compress.__qualname__ == 'compress' — module-level function qualname (extra19)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__qualname__ == 'decompress' — novel, extra19 anchor
#
# No prior bz2 spec checks decompress.__qualname__ from the extra19 namespace.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.decompress.qualname:
  description: "bz2.decompress.__qualname__ == 'decompress' — module-level function qualname (extra19)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# open.__module__.__len__() == 3 — novel, extra19 anchor
#
# bz2.open.__module__ == 'bz2' which has length 3. No prior bz2 spec checks
# __module__.__len__() for the open function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.open.module_len:
  description: "bz2.open.__module__.__len__() == 3 — 'bz2' module name has three characters (extra19)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 3 — novel, extra19 anchor
#
# bz2.compress.__module__ == 'bz2' (len 3). No prior bz2 spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.compress.module_len:
  description: "bz2.compress.__module__.__len__() == 3 — 'bz2' module name has three characters (extra19)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 3 — novel, extra19 anchor
#
# bz2.decompress.__module__ == 'bz2' (len 3). No prior bz2 spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.decompress.module_len:
  description: "bz2.decompress.__module__.__len__() == 3 — 'bz2' module name has three characters (extra19)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# BZ2File.__module__.__len__() == 3 — novel, extra19 anchor
#
# bz2.BZ2File.__module__ == 'bz2' (len 3). No prior bz2 spec checks
# __module__.__len__() for BZ2File. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra19.BZ2File.module_len:
  description: "bz2.BZ2File.__module__.__len__() == 3 — 'bz2' module name has three characters (extra19)"
  category: module_affiliation
  kind: python_call_eq
  function: BZ2File.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# __init__.__name__ table — BZ2File, BZ2Compressor, BZ2Decompressor (extra19)
#
# No prior bz2 spec presents __init__.__name__ checks in a table.
# This table anchors all three from the extra19 namespace.
# ---------------------------------------------------------------------------

table bz2_extra19.init_names:
  kind: python_call_eq
  category: method_names
  id_prefix: init19

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__init__.__name__.__eq__,         ["__init__"], true]
    - [BZ2Compressor,   BZ2Compressor.__init__.__name__.__eq__,   ["__init__"], true]
    - [BZ2Decompressor, BZ2Decompressor.__init__.__name__.__eq__, ["__init__"], true]

# ---------------------------------------------------------------------------
# __module__.__len__() table — open, compress, decompress, BZ2File (extra19)
#
# No prior bz2 spec presents __module__.__len__() checks in a table.
# All four identifiers have module name 'bz2' (length 3). This table
# anchors all four from the extra19 namespace.
# ---------------------------------------------------------------------------

table bz2_extra19.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen19

  columns: [id, function, args, expected]
  rows:
    - [open,       open.__module__.__len__,       [], 3]
    - [compress,   compress.__module__.__len__,   [], 3]
    - [decompress, decompress.__module__.__len__, [], 3]
    - [BZ2File,    BZ2File.__module__.__len__,    [], 3]
