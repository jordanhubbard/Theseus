spec: io_extra183
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.IOBase method names — readline, readlines, writelines, seek, tell, flush, close, readable, writable, seekable (all method_descriptor instances on the C-implemented IOBase type)."
    - "io.IOBase does NOT have read or write — those live on RawIOBase/BufferedIOBase; IOBase provides the common base methods."
    - "Name length groupings: seek==tell (4); flush==close (5); readline==readable==writable==seekable==truncate (8); readlines (9); writelines (10)."
    - "io.IOBase.readline.__class__.__name__ == 'method_descriptor' — IOBase is implemented in C so its methods are method_descriptor objects."
    - "io.IOBase.seek.__name__ == 'seek' (len=4); io.IOBase.tell.__name__ == 'tell' (len=4): a 2-way tie at length 4."
    - "io.IOBase.flush.__name__ == 'flush' (len=5); io.IOBase.close.__name__ == 'close' (len=5): a 2-way tie at length 5."
    - "io.IOBase.readline (8) == io.IOBase.readable (8) == io.IOBase.writable (8) == io.IOBase.seekable (8): a 4-way tie at length 8."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.IOBase read-side method names (readline, readlines)
# IOBase does not have read; readline (8) < readlines (9)
# ---------------------------------------------------------------------------

table io_extra183.read_method_names:
  description: "io.IOBase read-side method names: readline.__name__=='readline' (len=8); readlines.__name__=='readlines' (len=9); readline (8) < readlines (9)"
  kind: python_call_eq
  category: identity
  id_prefix: ioiobasemethods183

  columns: [id, function, args, expected, description]
  rows:
    - [readline_name,      IOBase.readline.__name__.__eq__,      ["readline"],  true, "io.IOBase.readline.__name__ == 'readline' — readline is the method for reading one line from the stream; 'readline' has 8 characters: r(1)e(2)a(3)d(4)l(5)i(6)n(7)e(8); confirmed Python 3.14.3 macOS"]
    - [readline_name_len,  IOBase.readline.__name__.__len__,     [],            8,    "io.IOBase.readline.__name__.__len__() == 8 — 'readline' has 8 characters; readline (8) < readlines (9): readline is shorter than readlines by 1 character (the trailing 's'); confirmed Python 3.14.3 macOS"]
    - [readlines_name,     IOBase.readlines.__name__.__eq__,     ["readlines"], true, "io.IOBase.readlines.__name__ == 'readlines' — readlines is the method for reading all lines as a list; 'readlines' has 9 characters: r(1)e(2)a(3)d(4)l(5)i(6)n(7)e(8)s(9); confirmed Python 3.14.3 macOS"]
    - [readlines_name_len, IOBase.readlines.__name__.__len__,    [],            9,    "io.IOBase.readlines.__name__.__len__() == 9 — 'readlines' has 9 characters; readlines (9) > readline (8) by 1: the plural 's' adds one character; confirmed Python 3.14.3 macOS"]
    - [readline_class,     IOBase.readline.__class__.__name__.__eq__, ["method_descriptor"], true, "io.IOBase.readline.__class__.__name__ == 'method_descriptor' — IOBase is a C-implemented type so its methods are method_descriptor objects, not Python functions; confirmed Python 3.14.3 macOS"]
    - [readlines_class,    IOBase.readlines.__class__.__name__.__eq__, ["method_descriptor"], true, "io.IOBase.readlines.__class__.__name__ == 'method_descriptor' — readlines is also a C method_descriptor; all IOBase methods share this descriptor type; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.IOBase write-side method names (writelines) and seek/tell/flush/close
# seek==tell (4); flush==close (5); writelines (10)
# ---------------------------------------------------------------------------

table io_extra183.write_and_position_method_names:
  description: "io.IOBase write-side and positioning method names: writelines.__name__=='writelines' (len=10); seek.__name__=='seek' (len=4); tell.__name__=='tell' (len=4); flush.__name__=='flush' (len=5); close.__name__=='close' (len=5)"
  kind: python_call_eq
  category: identity
  id_prefix: ioiobasemethods183

  columns: [id, function, args, expected, description]
  rows:
    - [writelines_name,     IOBase.writelines.__name__.__eq__,  ["writelines"], true, "io.IOBase.writelines.__name__ == 'writelines' — writelines is the method for writing a sequence of strings to the stream; 'writelines' has 10 characters: w(1)r(2)i(3)t(4)e(5)l(6)i(7)n(8)e(9)s(10); writelines (10) is the longest IOBase method name; confirmed Python 3.14.3 macOS"]
    - [writelines_name_len, IOBase.writelines.__name__.__len__, [],             10,   "io.IOBase.writelines.__name__.__len__() == 10 — 'writelines' has 10 characters; writelines (10) > readlines (9) > readline (8): the write-side plural name is the longest; confirmed Python 3.14.3 macOS"]
    - [seek_name,           IOBase.seek.__name__.__eq__,        ["seek"],       true, "io.IOBase.seek.__name__ == 'seek' — seek is the method for repositioning the stream; 'seek' has 4 characters: s(1)e(2)e(3)k(4); seek (4) == tell (4): a 2-way tie at length 4 among positioning methods; confirmed Python 3.14.3 macOS"]
    - [seek_name_len,       IOBase.seek.__name__.__len__,       [],             4,    "io.IOBase.seek.__name__.__len__() == 4 — 'seek' has 4 characters; seek (4) == tell (4): both positioning methods share length 4; confirmed Python 3.14.3 macOS"]
    - [tell_name,           IOBase.tell.__name__.__eq__,        ["tell"],       true, "io.IOBase.tell.__name__ == 'tell' — tell is the method for returning the current stream position; 'tell' has 4 characters: t(1)e(2)l(3)l(4); tell (4) == seek (4): a 2-way tie at length 4; confirmed Python 3.14.3 macOS"]
    - [tell_name_len,       IOBase.tell.__name__.__len__,       [],             4,    "io.IOBase.tell.__name__.__len__() == 4 — 'tell' has 4 characters; tell (4) == seek (4): both share length 4; confirmed Python 3.14.3 macOS"]
    - [flush_name,          IOBase.flush.__name__.__eq__,       ["flush"],      true, "io.IOBase.flush.__name__ == 'flush' — flush is the method for flushing the write buffer; 'flush' has 5 characters: f(1)l(2)u(3)s(4)h(5); flush (5) == close (5): a 2-way tie at length 5; confirmed Python 3.14.3 macOS"]
    - [flush_name_len,      IOBase.flush.__name__.__len__,      [],             5,    "io.IOBase.flush.__name__.__len__() == 5 — 'flush' has 5 characters; flush (5) == close (5): both stream lifecycle methods share length 5; confirmed Python 3.14.3 macOS"]
    - [close_name,          IOBase.close.__name__.__eq__,       ["close"],      true, "io.IOBase.close.__name__ == 'close' — close is the method for closing the stream and releasing resources; 'close' has 5 characters: c(1)l(2)o(3)s(4)e(5); close (5) == flush (5): a 2-way tie at length 5; confirmed Python 3.14.3 macOS"]
    - [close_name_len,      IOBase.close.__name__.__len__,      [],             5,    "io.IOBase.close.__name__.__len__() == 5 — 'close' has 5 characters; close (5) == flush (5): both share length 5; seek (4) < flush==close (5) < readline (8): the lifecycle methods are between the positioning and line-oriented methods in name length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.IOBase capability query method names (readable, writable, seekable)
# All three have len==8, matching readline — a 4-way tie at 8
# ---------------------------------------------------------------------------

table io_extra183.capability_method_names:
  description: "io.IOBase capability query method names: readable.__name__=='readable' (len=8); writable.__name__=='writable' (len=8); seekable.__name__=='seekable' (len=8); all three are method_descriptor; readline also has len==8 — a 4-way tie"
  kind: python_call_eq
  category: identity
  id_prefix: ioiobasemethods183

  columns: [id, function, args, expected, description]
  rows:
    - [readable_name,     IOBase.readable.__name__.__eq__,       ["readable"],  true, "io.IOBase.readable.__name__ == 'readable' — readable returns True if the stream can be read; 'readable' has 8 characters: r(1)e(2)a(3)d(4)a(5)b(6)l(7)e(8); readable (8) == writable (8) == seekable (8) == readline (8): a 4-way tie at length 8; confirmed Python 3.14.3 macOS"]
    - [readable_name_len, IOBase.readable.__name__.__len__,      [],            8,    "io.IOBase.readable.__name__.__len__() == 8 — 'readable' has 8 characters; readable (8) == writable (8) == seekable (8): all three capability query methods share length 8, also matching readline (8); confirmed Python 3.14.3 macOS"]
    - [writable_name,     IOBase.writable.__name__.__eq__,       ["writable"],  true, "io.IOBase.writable.__name__ == 'writable' — writable returns True if the stream can be written to; 'writable' has 8 characters: w(1)r(2)i(3)t(4)a(5)b(6)l(7)e(8); writable (8) == readable (8) == seekable (8): a 3-way tie among capability queries, 4-way with readline; confirmed Python 3.14.3 macOS"]
    - [writable_name_len, IOBase.writable.__name__.__len__,      [],            8,    "io.IOBase.writable.__name__.__len__() == 8 — 'writable' has 8 characters; writable (8) == readable (8) == seekable (8): all capability query method names have length 8; confirmed Python 3.14.3 macOS"]
    - [seekable_name,     IOBase.seekable.__name__.__eq__,       ["seekable"],  true, "io.IOBase.seekable.__name__ == 'seekable' — seekable returns True if the stream supports random access; 'seekable' has 8 characters: s(1)e(2)e(3)k(4)a(5)b(6)l(7)e(8); seekable (8) == readable (8) == writable (8): a 3-way tie among capability queries; confirmed Python 3.14.3 macOS"]
    - [seekable_name_len, IOBase.seekable.__name__.__len__,      [],            8,    "io.IOBase.seekable.__name__.__len__() == 8 — 'seekable' has 8 characters; the length ordering is: seek==tell (4) < flush==close (5) < readline==readable==writable==seekable (8) < readlines (9) < writelines (10); confirmed Python 3.14.3 macOS"]
    - [seekable_class,    IOBase.seekable.__class__.__name__.__eq__, ["method_descriptor"], true, "io.IOBase.seekable.__class__.__name__ == 'method_descriptor' — seekable, like all IOBase methods, is a C method_descriptor; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra183.readline_name_is_readline:
  description: "io.IOBase.readline.__name__ == 'readline' — readline reads one line from the stream; 'readline' has 8 characters; readline (8) < readlines (9): shorter than its plural form by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.readline.__name__.__eq__
  args: ["readline"]
  expected: true

invariant io_extra183.readlines_name_len_is_9:
  description: "io.IOBase.readlines.__name__.__len__() == 9 — 'readlines' has 9 characters; readlines (9) > readline (8) by 1: the plural suffix 's' adds one character; readlines (9) < writelines (10); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.readlines.__name__.__len__
  args: []
  expected: 9

invariant io_extra183.writelines_name_len_is_10:
  description: "io.IOBase.writelines.__name__.__len__() == 10 — 'writelines' has 10 characters; writelines (10) is the longest IOBase method name; writelines (10) > readlines (9) > readline (8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.writelines.__name__.__len__
  args: []
  expected: 10

invariant io_extra183.seek_and_tell_len_equal:
  description: "io.IOBase.seek.__name__.__len__() == 4 and io.IOBase.tell.__name__.__len__() == 4 — seek and tell both have 4-character names; they form a 2-way tie at length 4 as the shortest IOBase method names; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.seek.__name__.__len__
  args: []
  expected: 4

invariant io_extra183.flush_name_is_flush:
  description: "io.IOBase.flush.__name__ == 'flush' — flush flushes the write buffer to the underlying raw stream; 'flush' has 5 characters; flush (5) == close (5): a 2-way tie at length 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.flush.__name__.__eq__
  args: ["flush"]
  expected: true

invariant io_extra183.close_name_len_is_5:
  description: "io.IOBase.close.__name__.__len__() == 5 — 'close' has 5 characters; close (5) == flush (5): both lifecycle methods share length 5; seek==tell (4) < flush==close (5) in the length ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.close.__name__.__len__
  args: []
  expected: 5

invariant io_extra183.readable_name_len_is_8:
  description: "io.IOBase.readable.__name__.__len__() == 8 — 'readable' has 8 characters; readable (8) == writable (8) == seekable (8) == readline (8): a 4-way tie at length 8; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.readable.__name__.__len__
  args: []
  expected: 8

invariant io_extra183.seekable_class_is_method_descriptor:
  description: "io.IOBase.seekable.__class__.__name__ == 'method_descriptor' — all IOBase methods are C-implemented method_descriptor objects; this holds for readline, readlines, writelines, seek, tell, flush, close, readable, writable, seekable; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.seekable.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

