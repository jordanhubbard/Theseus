spec: shutil_extra13
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends shutil.zspec.zsdl through shutil_extra12.zspec.zsdl."
    - "shutil_extra12 covers chown.__name__, copyfileobj.__qualname__, shutil.__name__/__package__, disk_usage return class name, get_archive_formats/get_unpack_formats length, function __module__ table."
    - "shutil_extra11 covers which return type; get_terminal_size return class and field types; which/get_terminal_size __qualname__; copy.__qualname__ standalone."
    - "shutil_extra10 covers SameFileError/ReadError/Error MRO entries; disk_usage _fields by index; get_archive_formats/get_unpack_formats return type."
    - "shutil_extra7 covers copy/rmtree/move/which __class__.__name__; copymode/copystat/chown/get_unpack_formats qualnames."
    - "shutil_extra5 covers __qualname__ table for copy/copy2/copyfile/copytree/rmtree/move/make_archive/unpack_archive/disk_usage/which/get_terminal_size."
    - "NOT yet covered: shutil.get_archive_formats().__class__.__name__ == 'list' — standalone invariant."
    - "NOT yet covered: shutil.get_unpack_formats().__class__.__name__ == 'list' — standalone invariant."
    - "NOT yet covered: shutil.copy.__module__ == 'shutil' — standalone invariant."
    - "NOT yet covered: shutil.copy2.__module__ == 'shutil' — standalone invariant."
    - "NOT yet covered: shutil.copytree.__module__ == 'shutil' — standalone invariant."
    - "NOT yet covered: shutil.rmtree.__module__ == 'shutil' — standalone invariant."
    - "NOT yet covered: shutil.move.__module__ == 'shutil' — standalone invariant."
    - "NOT yet covered: shutil.copy.__name__ == 'copy' — standalone invariant."
    - "NOT yet covered: shutil.copy2.__name__ == 'copy2' — standalone invariant."
    - "NOT yet covered: shutil.copytree.__name__ == 'copytree' — standalone invariant."
    - "NOT yet covered: shutil.rmtree.__name__ == 'rmtree' — standalone invariant."
    - "NOT yet covered: shutil.move.__name__ == 'move' — standalone invariant."
    - "NOT yet covered: shutil.get_terminal_size.__module__ == 'shutil' — standalone invariant."
    - "NOT yet covered: shutil.disk_usage.__module__ == 'shutil' — standalone invariant."
    - "NOT yet covered: shutil.which.__module__ == 'shutil' — standalone invariant."
    - "shutil.get_archive_formats().__class__.__name__ == 'list'."
    - "shutil.get_unpack_formats().__class__.__name__ == 'list'."
    - "shutil.copy/copy2/copytree/rmtree/move.__module__ == 'shutil' as standalone invariants."
    - "shutil.copy/copy2/copytree/rmtree/move.__name__ matches function name."
    - "shutil.get_terminal_size/disk_usage/which.__module__ == 'shutil'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_archive_formats and get_unpack_formats return type — standalone invariants
#
# shutil_extra10 covers these in a table (return type == 'list').
# shutil_extra12 checks __len__ for both.
# These standalone invariants anchor the return-type check in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant shutil_extra13.get_archive_formats.return_is_list:
  description: "shutil.get_archive_formats().__class__.__name__ == 'list' — standalone invariant"
  category: archive_formats
  kind: python_call_eq
  function: get_archive_formats
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

invariant shutil_extra13.get_unpack_formats.return_is_list:
  description: "shutil.get_unpack_formats().__class__.__name__ == 'list' — standalone invariant"
  category: archive_formats
  kind: python_call_eq
  function: get_unpack_formats
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — standalone invariants for copy/copy2/copytree/rmtree/move
#
# shutil_extra5 covers __qualname__ in a table for these functions.
# shutil_extra12 function_modules table covers copyfile/copy2/copystat/copyfileobj.
# These standalone invariants verify __module__ == 'shutil' for the five primary
# file-operation functions individually in the extra13 namespace.
# ---------------------------------------------------------------------------

table shutil_extra13.primary_function_modules:
  description: "shutil primary function __module__ attributes: copy/copy2/copytree/rmtree/move"
  kind: python_call_eq
  category: function_identity
  id_prefix: pfmod13

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__module__.__eq__,     ["shutil"], true]
    - [copy2,    copy2.__module__.__eq__,    ["shutil"], true]
    - [copytree, copytree.__module__.__eq__, ["shutil"], true]
    - [rmtree,   rmtree.__module__.__eq__,   ["shutil"], true]
    - [move,     move.__module__.__eq__,     ["shutil"], true]

# ---------------------------------------------------------------------------
# Function __name__ attributes — standalone invariants
#
# shutil_extra5 covers __qualname__ (which equals __name__ for top-level functions).
# shutil_extra12 covers chown.__name__.
# These standalone invariants verify __name__ for the five primary functions
# individually in the extra13 namespace.
# ---------------------------------------------------------------------------

table shutil_extra13.primary_function_names:
  description: "shutil primary function __name__ attributes: copy/copy2/copytree/rmtree/move"
  kind: python_call_eq
  category: function_identity
  id_prefix: pfname13

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__name__.__eq__,     ["copy"],     true]
    - [copy2,    copy2.__name__.__eq__,    ["copy2"],    true]
    - [copytree, copytree.__name__.__eq__, ["copytree"], true]
    - [rmtree,   rmtree.__name__.__eq__,   ["rmtree"],   true]
    - [move,     move.__name__.__eq__,     ["move"],     true]

# ---------------------------------------------------------------------------
# Module membership — get_terminal_size, disk_usage, which
#
# shutil_extra11 covers get_terminal_size/__qualname__ and which/__qualname__.
# shutil_extra12 covers which/__module__ in a table with copyfile/copy2/copystat/copyfileobj.
# These standalone invariants confirm __module__ == 'shutil' for the three
# utility functions in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant shutil_extra13.get_terminal_size.module:
  description: "shutil.get_terminal_size.__module__ == 'shutil'"
  category: function_identity
  kind: python_call_eq
  function: get_terminal_size.__module__.__eq__
  args: ["shutil"]
  expected: true

invariant shutil_extra13.disk_usage.module:
  description: "shutil.disk_usage.__module__ == 'shutil'"
  category: function_identity
  kind: python_call_eq
  function: disk_usage.__module__.__eq__
  args: ["shutil"]
  expected: true

invariant shutil_extra13.which.module:
  description: "shutil.which.__module__ == 'shutil'"
  category: function_identity
  kind: python_call_eq
  function: which.__module__.__eq__
  args: ["shutil"]
  expected: true
