spec: itertools_extra65
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra64.zspec.zsdl."
    - "Wave 231 theme: docstring content for chain/islice/dropwhile/takewhile/groupby/starmap/zip_longest (all C types, no __code__)."
    - "All itertools types are C extension types (Modules/itertoolsmodule.c) and have no __code__ attribute. This spec extends __doc__ content checks to chain, islice, dropwhile, takewhile, groupby, starmap, and zip_longest."
    - "chain.__doc__.__contains__('chain') == True — the type name appears in the chain docstring. Verified with Python 3.14.3."
    - "chain.__doc__.__contains__('iterable') == True — chain(p, q, ...) takes iterables; 'iterable' appears in the docstring. Verified with Python 3.14.3."
    - "islice.__doc__.__contains__('stop') == True — islice(iterable, stop) has 'stop' in its signature line in the docstring. Verified with Python 3.14.3."
    - "islice.__doc__.__contains__('iterable') == True — 'iterable' appears in the islice docstring. Verified with Python 3.14.3."
    - "dropwhile.__doc__.__contains__('predicate') == True — dropwhile(predicate, iterable); 'predicate' appears in the signature. Verified with Python 3.14.3."
    - "takewhile.__doc__.__contains__('predicate') == True — takewhile(predicate, iterable); 'predicate' appears in the signature. Verified with Python 3.14.3."
    - "groupby.__doc__.__contains__('key') == True — groupby(iterable, key=None); 'key' appears in the signature. Verified with Python 3.14.3."
    - "groupby.__doc__.__contains__('iterable') == True — 'iterable' appears in the groupby docstring signature. Verified with Python 3.14.3."
    - "starmap.__doc__.__contains__('func') == True — starmap(func, sequence); 'func' appears in the signature. Verified with Python 3.14.3."
    - "starmap.__doc__.__contains__('sequence') == True — starmap(func, sequence); 'sequence' appears in the signature. Verified with Python 3.14.3."
    - "zip_longest.__doc__.__contains__('fillvalue') == True — fillvalue=None appears in the zip_longest signature in the docstring. Verified with Python 3.14.3."
    - "Prior itertools_extra64 covered combinations/permutations/product/compress docstring content."
    - "No prior itertools spec checks chain.__doc__, islice.__doc__, dropwhile.__doc__, takewhile.__doc__, groupby.__doc__, starmap.__doc__, or zip_longest.__doc__ content. All checks in this spec are new to extra65."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain.__doc__.__contains__ and islice.__doc__.__contains__ — extra65
#
# Wave 231 theme: __doc__ content checks for itertools C extension types.
#
# itertools.chain is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'chain(*iterables) --> chain object\n\n
#    Return a chain object whose .next() method ...'
#
# Key findings for chain:
#   chain.__doc__.__contains__('chain') == True
#     (the type name 'chain' appears in the signature line)
#   chain.__doc__.__contains__('iterable') == True
#     ('iterables' in the signature line; 'iterables' contains 'iterable')
#
# itertools.islice is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'islice(iterable, stop) --> islice object\n
#    islice(iterable, start, stop[, step]) --> islice object\n\n
#    Return an iterator ...'
#
# Key findings for islice:
#   islice.__doc__.__contains__('stop') == True
#     ('stop' appears explicitly in the signature lines)
#   islice.__doc__.__contains__('iterable') == True
#     ('iterable' appears in the signature lines)
#
# No prior itertools spec checks chain.__doc__ or islice.__doc__. New to extra65.
# ---------------------------------------------------------------------------

table itertools_extra65.chain_islice_doc_contains:
  description: "chain/islice __doc__.__contains__ checks — key parameter words in docstrings; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc4_65

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_contains_chain,
       chain.__doc__.__contains__,
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — chain is a C extension type (Modules/itertoolsmodule.c) that chains multiple iterables together; its docstring opens with 'chain(*iterables) --> chain object' followed by a description; the word 'chain' appears in the very first line of the docstring as both the type name in the call signature and as part of 'chain object'; __contains__ returns True at the first occurrence; no prior itertools spec checks chain.__doc__.__contains__('chain'); new to extra65"]
    - [chain_doc_contains_iterable,
       chain.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.chain.__doc__.__contains__('iterable') == True — chain.__doc__ opens with 'chain(*iterables) --> chain object'; the word 'iterables' (the parameter name) contains the substring 'iterable'; str.__contains__ finds 'iterable' as a substring of 'iterables' and returns True; no prior itertools spec checks chain.__doc__.__contains__('iterable'); new to extra65"]
    - [islice_doc_contains_stop,
       islice.__doc__.__contains__,
       ["stop"],
       true,
       "itertools.islice.__doc__.__contains__('stop') == True — islice is a C extension type (Modules/itertoolsmodule.c) that returns selected elements from an iterable; its docstring opens with 'islice(iterable, stop) --> islice object\\nislice(iterable, start, stop[, step]) --> islice object'; the word 'stop' appears explicitly as a parameter name in both signature lines of the docstring; __contains__ returns True at the first occurrence in 'islice(iterable, stop)'; no prior itertools spec checks islice.__doc__.__contains__('stop'); new to extra65"]
    - [islice_doc_contains_iterable,
       islice.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.islice.__doc__.__contains__('iterable') == True — islice.__doc__ opens with 'islice(iterable, stop) --> islice object'; the word 'iterable' appears explicitly as the first parameter name in the signature line; __contains__ returns True at the first occurrence; no prior itertools spec checks islice.__doc__.__contains__('iterable'); new to extra65"]

# ---------------------------------------------------------------------------
# dropwhile.__doc__.__contains__ and takewhile.__doc__.__contains__ — extra65
#
# Wave 231 theme: __doc__ content checks for itertools C extension types.
#
# itertools.dropwhile is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'dropwhile(predicate, iterable) --> dropwhile object\n\n
#    Drop items from the iterable while predicate(item) is true.\n
#    Afterwards, return every element until the iterable is exhausted.'
#
# itertools.takewhile is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'takewhile(predicate, iterable) --> takewhile object\n\n
#    Return successive entries from an iterable as long as the
#    predicate evaluates to true for each entry.'
#
# Key findings:
#   dropwhile.__doc__.__contains__('predicate') == True
#   takewhile.__doc__.__contains__('predicate') == True
#
# No prior itertools spec checks dropwhile.__doc__ or takewhile.__doc__. New to extra65.
# ---------------------------------------------------------------------------

table itertools_extra65.dropwhile_takewhile_doc_contains:
  description: "dropwhile/takewhile __doc__.__contains__('predicate')==true — 'predicate' is the first parameter in both signatures; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc4_65

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_doc_contains_predicate,
       dropwhile.__doc__.__contains__,
       ["predicate"],
       true,
       "itertools.dropwhile.__doc__.__contains__('predicate') == True — dropwhile is a C extension type (Modules/itertoolsmodule.c) that drops items from an iterable while a predicate is true; its docstring opens with 'dropwhile(predicate, iterable) --> dropwhile object'; the word 'predicate' appears as the first parameter name in the signature line and again in the body ('while predicate(item) is true'); __contains__ returns True at the first occurrence; no prior itertools spec checks dropwhile.__doc__.__contains__('predicate'); new to extra65"]
    - [takewhile_doc_contains_predicate,
       takewhile.__doc__.__contains__,
       ["predicate"],
       true,
       "itertools.takewhile.__doc__.__contains__('predicate') == True — takewhile is a C extension type (Modules/itertoolsmodule.c) that returns elements from an iterable as long as a predicate is true; its docstring opens with 'takewhile(predicate, iterable) --> takewhile object'; the word 'predicate' appears as the first parameter name in the signature line and again in the body ('as long as the predicate evaluates to true'); __contains__ returns True at the first occurrence; no prior itertools spec checks takewhile.__doc__.__contains__('predicate'); new to extra65"]

# ---------------------------------------------------------------------------
# groupby.__doc__.__contains__ and starmap.__doc__.__contains__ — extra65
#
# Wave 231 theme: __doc__ content checks for itertools C extension types.
#
# itertools.groupby is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'groupby(iterable, key=None) --> groupby object\n\n
#    Consecutive keys and groups from the iterable.\n
#    key is a function computing a key value for each element;\n
#    if not supplied or is None, it defaults to an identity function\n
#    and returns the element unchanged. Generally, the iterable needs\n
#    to already be sorted on the same key value.'
#
# Key findings for groupby:
#   groupby.__doc__.__contains__('key') == True
#   groupby.__doc__.__contains__('iterable') == True
#
# itertools.starmap is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'starmap(func, sequence) --> starmap object\n\n
#    Return an iterator whose values are returned from the function evaluated
#    with an argument tuple taken from the given sequence.'
#
# Key findings for starmap:
#   starmap.__doc__.__contains__('func') == True
#   starmap.__doc__.__contains__('sequence') == True
#
# No prior itertools spec checks groupby.__doc__ or starmap.__doc__. New to extra65.
# ---------------------------------------------------------------------------

table itertools_extra65.groupby_starmap_doc_contains:
  description: "groupby/starmap __doc__.__contains__ checks — key parameter words in docstrings; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc4_65

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_contains_key,
       groupby.__doc__.__contains__,
       ["key"],
       true,
       "itertools.groupby.__doc__.__contains__('key') == True — groupby is a C extension type (Modules/itertoolsmodule.c) that groups consecutive elements of an iterable by a key function; its docstring opens with 'groupby(iterable, key=None) --> groupby object'; the word 'key' appears as the second parameter name in the signature line and multiple times in the body description; __contains__ returns True at the first occurrence; no prior itertools spec checks groupby.__doc__.__contains__('key'); new to extra65"]
    - [groupby_doc_contains_iterable,
       groupby.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.groupby.__doc__.__contains__('iterable') == True — groupby.__doc__ opens with 'groupby(iterable, key=None) --> groupby object'; the word 'iterable' appears as the first parameter name in the signature line and later in the body; __contains__ returns True at the first occurrence; no prior itertools spec checks groupby.__doc__.__contains__('iterable'); new to extra65"]
    - [starmap_doc_contains_func,
       starmap.__doc__.__contains__,
       ["func"],
       true,
       "itertools.starmap.__doc__.__contains__('func') == True — starmap is a C extension type (Modules/itertoolsmodule.c) that applies a function to each tuple from a sequence; its docstring opens with 'starmap(func, sequence) --> starmap object'; the word 'func' appears as the first parameter name in the signature line and as 'function' in the body (which contains 'func' as a substring); __contains__ returns True at the first occurrence in the signature line; no prior itertools spec checks starmap.__doc__.__contains__('func'); new to extra65"]
    - [starmap_doc_contains_sequence,
       starmap.__doc__.__contains__,
       ["sequence"],
       true,
       "itertools.starmap.__doc__.__contains__('sequence') == True — starmap.__doc__ opens with 'starmap(func, sequence) --> starmap object'; the word 'sequence' appears as the second parameter name in the signature line and again in the body ('from the given sequence'); __contains__ returns True at the first occurrence; no prior itertools spec checks starmap.__doc__.__contains__('sequence'); new to extra65"]

# ---------------------------------------------------------------------------
# zip_longest.__doc__.__contains__ — extra65
#
# Wave 231 theme: __doc__ content checks for itertools C extension types.
#
# itertools.zip_longest is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'zip_longest(iter1 [,iter2 [...]], [fillvalue=None]) --> zip_longest object\n\n
#    Return a zip_longest object whose .__next__() method returns a tuple where
#    the i-th element comes from the i-th iterable argument. The .__next__()
#    method continues until the longest iterable in the argument sequence is
#    exhausted and then it raises StopIteration. When the shorter iterables are
#    exhausted, the fillvalue is returned.'
#
# Key finding:
#   zip_longest.__doc__.__contains__('fillvalue') == True
#     ('fillvalue=None' in the signature and 'the fillvalue is returned' in body)
#
# No prior itertools spec checks zip_longest.__doc__. New to extra65.
# ---------------------------------------------------------------------------

table itertools_extra65.zip_longest_doc_contains:
  description: "zip_longest.__doc__.__contains__('fillvalue')==true — 'fillvalue' is the keyword param and appears in docstring body; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc4_65

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_doc_contains_fillvalue,
       zip_longest.__doc__.__contains__,
       ["fillvalue"],
       true,
       "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — zip_longest is a C extension type (Modules/itertoolsmodule.c) that zips iterables to the length of the longest, padding shorter ones with a fill value; its docstring signature includes '[fillvalue=None]' and the body states 'the fillvalue is returned'; the word 'fillvalue' appears in both the signature line and the body; __contains__ returns True at the first occurrence in the signature; no prior itertools spec checks zip_longest.__doc__.__contains__('fillvalue'); new to extra65"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant itertools_extra65.chain_doc_chain:
  description: "itertools.chain.__doc__.__contains__('chain') == True — type name appears in chain docstring signature; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  function: chain.__doc__.__contains__
  args: ["chain"]
  expected: true

invariant itertools_extra65.islice_doc_stop:
  description: "itertools.islice.__doc__.__contains__('stop') == True — 'stop' is an explicit parameter name in islice docstring; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  function: islice.__doc__.__contains__
  args: ["stop"]
  expected: true

invariant itertools_extra65.dropwhile_doc_predicate:
  description: "itertools.dropwhile.__doc__.__contains__('predicate') == True — 'predicate' is the first parameter in dropwhile docstring; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  function: dropwhile.__doc__.__contains__
  args: ["predicate"]
  expected: true

invariant itertools_extra65.zip_longest_doc_fillvalue:
  description: "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — 'fillvalue' is the keyword parameter in zip_longest docstring; wave 231 __doc__ content; new to extra65"
  kind: python_call_eq
  function: zip_longest.__doc__.__contains__
  args: ["fillvalue"]
  expected: true
