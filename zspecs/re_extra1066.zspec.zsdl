spec: re_extra1066
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Match and Pattern method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Match and re.Pattern method __qualname__ and __class__.__name__ values, and re module function __module__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1066.match_method_qualnames:
  description: "re.Match method __qualname__ checks"
  kind: python_call_eq
  category: match_method_qualnames
  id_prefix: re1066mm
  columns: [id, function, args, expected]
  rows:
    - [re1066mm001, re.Match.group.__qualname__.__eq__,     ["Match.group"],     true]
    - [re1066mm002, re.Match.groups.__qualname__.__eq__,    ["Match.groups"],    true]
    - [re1066mm003, re.Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true]
    - [re1066mm004, re.Match.start.__qualname__.__eq__,     ["Match.start"],     true]
    - [re1066mm005, re.Match.end.__qualname__.__eq__,       ["Match.end"],       true]
    - [re1066mm006, re.Match.span.__qualname__.__eq__,      ["Match.span"],      true]
    - [re1066mm007, re.Match.expand.__qualname__.__eq__,    ["Match.expand"],    true]
    - [re1066mm008, re.Match.group.__class__.__name__.__eq__, ["method_descriptor"], true]

table re_extra1066.pattern_method_qualnames:
  description: "re.Pattern method __qualname__ checks"
  kind: python_call_eq
  category: pattern_method_qualnames
  id_prefix: re1066pm
  columns: [id, function, args, expected]
  rows:
    - [re1066pm001, re.Pattern.match.__qualname__.__eq__,     ["Pattern.match"],     true]
    - [re1066pm002, re.Pattern.search.__qualname__.__eq__,    ["Pattern.search"],    true]
    - [re1066pm003, re.Pattern.findall.__qualname__.__eq__,   ["Pattern.findall"],   true]
    - [re1066pm004, re.Pattern.finditer.__qualname__.__eq__,  ["Pattern.finditer"],  true]
    - [re1066pm005, re.Pattern.sub.__qualname__.__eq__,       ["Pattern.sub"],       true]
    - [re1066pm006, re.Pattern.subn.__qualname__.__eq__,      ["Pattern.subn"],      true]
    - [re1066pm007, re.Pattern.split.__qualname__.__eq__,     ["Pattern.split"],     true]
    - [re1066pm008, re.Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true]

table re_extra1066.module_function_identity:
  description: "re module-level function __qualname__ and __module__ identity checks"
  kind: python_call_eq
  category: module_function_identity
  id_prefix: re1066fi
  columns: [id, function, args, expected]
  rows:
    - [re1066fi001, re.compile.__qualname__.__eq__,   ["compile"],  true]
    - [re1066fi002, re.match.__qualname__.__eq__,     ["match"],    true]
    - [re1066fi003, re.search.__qualname__.__eq__,    ["search"],   true]
    - [re1066fi004, re.findall.__qualname__.__eq__,   ["findall"],  true]
    - [re1066fi005, re.sub.__qualname__.__eq__,       ["sub"],      true]
    - [re1066fi006, re.split.__qualname__.__eq__,     ["split"],    true]
    - [re1066fi007, re.compile.__module__.__eq__,     ["re"],       true]
    - [re1066fi008, re.match.__module__.__eq__,       ["re"],       true]
