spec: pathlib_extra173
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.Path, pathlib.PosixPath, and pathlib.WindowsPath class identity (__name__, __module__, __bases__[0].__name__) and name length comparisons across all six pathlib classes."
    - "pathlib.Path.__name__ == 'Path' (len=4) — the concrete filesystem path class."
    - "pathlib.Path.__module__ == 'pathlib' (len=7) — all pathlib classes share the 'pathlib' module."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' (len=8) — Path inherits from PurePath."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (len=9: 'Posix'(5)+'Path'(4)=9)."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' (len=4) — PosixPath inherits from Path."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (len=11: 'Windows'(7)+'Path'(4)=11)."
    - "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' (len=4) — WindowsPath inherits from Path."
    - "Name length comparisons across all six pathlib classes: PurePath(8), PurePosixPath(13), PureWindowsPath(15), Path(4), PosixPath(9), WindowsPath(11)."
    - "Path (4) is the shortest of all six pathlib class names — just 4 characters."
    - "The concrete classes (Path=4, PosixPath=9, WindowsPath=11) are all shorter than their pure counterparts (PurePath=8, PurePosixPath=13, PureWindowsPath=15) by exactly 4 characters each (the 'Pure' prefix length)."
    - "PosixPath (9) = PurePosixPath (13) - 4 = len('PurePosixPath') - len('Pure'); WindowsPath (11) = PureWindowsPath (15) - 4."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path class identity
# __name__ == 'Path' (len=4), __module__ == 'pathlib' (len=7)
# __bases__[0].__name__ == 'PurePath' (len=8)
# Path is the shortest name in the pathlib class family (4 chars)
# ---------------------------------------------------------------------------

table pathlib_extra173.Path_class_identity:
  description: "pathlib.Path class identity: __name__=='Path' (len=4), __module__=='pathlib' (len=7), __bases__[0].__name__=='PurePath' (len=8); Path (4) is the shortest pathlib class name; Path inherits from PurePath (8) adding filesystem I/O capability"
  kind: python_call_eq
  category: identity
  id_prefix: plpath173

  columns: [id, function, args, expected, description]
  rows:
    - [path_name,     Path.__name__.__eq__,                ["Path"],     true, "pathlib.Path.__name__ == 'Path' — Path is the concrete filesystem path class that performs actual I/O; 'Path' has 4 characters: 'P-a-t-h'; Path (4 chars) is the shortest name among all six pathlib path classes: Path (4) < PurePath (8) < PosixPath (9) < WindowsPath (11) < PurePosixPath (13) < PureWindowsPath (15); the brevity of 'Path' (4 chars) reflects it being the most commonly used pathlib class — the primary entry point; Path.__name__ (4 chars) == len('Pure') == 4: the 'Pure' prefix dropped from the pure path hierarchy has the same length as the entire 'Path' class name; confirmed Python 3.14.3 macOS"]
    - [path_module,   Path.__module__.__eq__,              ["pathlib"],  true, "pathlib.Path.__module__ == 'pathlib' — Path is defined in the public 'pathlib' module; 'pathlib' has 7 characters; Path.__module__ (7 chars) > Path.__name__ (4 chars) by 3 — unusually, the module name is longer than the class name; all six pathlib classes share __module__ == 'pathlib' (7 chars): PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath all report 'pathlib' as their module; 'pathlib' (7 chars) is the same length as 'Decimal' (7), 'decimal' (7), and 'Pattern' (7) — a common 7-character string length across standard library names; confirmed Python 3.14.3 macOS"]
    - [path_base0,    "Path.__bases__[0].__name__.__eq__", ["PurePath"], true, "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits directly from PurePath; 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; the inheritance chain for Path is: Path -> PurePath -> object; Path.__bases__[0].__name__ (8: 'PurePath') is 4 characters longer than Path.__name__ (4: 'Path') — the base class name is double the length of the derived class name in this case; Path extends PurePath by adding filesystem I/O operations (stat(), mkdir(), open(), read_text(), etc.) to the pure string-manipulation capabilities of PurePath; PosixPath and WindowsPath both inherit from Path (not from PurePath directly); confirmed Python 3.14.3 macOS"]
    - [path_name_len, Path.__name__.__len__,               [],           4,   "pathlib.Path.__name__.__len__() == 4 — 'Path' has exactly 4 characters; Path (4) is the minimum name length in the entire pathlib class family: Path (4) < PurePath (8) < PosixPath (9) < WindowsPath (11) < PurePosixPath (13) < PureWindowsPath (15); 4 is also len('Pure') — the prefix that distinguishes pure path classes from concrete ones; Path (4 chars) is exactly half the length of PurePath (8 chars): 'Path' (4) is the literal suffix of 'PurePath' (8) — the base class name ends with the derived class name; the ascending sequence has gaps: 4, 8(+4), 9(+1), 11(+2), 13(+2), 15(+2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.PosixPath class identity
# __name__ == 'PosixPath' (len=9), __module__ == 'pathlib' (len=7)
# __bases__[0].__name__ == 'Path' (len=4)
# PosixPath (9) = PurePosixPath (13) - 4 (no 'Pure' prefix)
# ---------------------------------------------------------------------------

table pathlib_extra173.PosixPath_class_identity:
  description: "pathlib.PosixPath class identity: __name__=='PosixPath' (len=9), __module__=='pathlib' (len=7), __bases__[0].__name__=='Path' (len=4); PosixPath (9) = 'Posix'(5)+'Path'(4)=9; PosixPath inherits from Path and adds POSIX-specific I/O"
  kind: python_call_eq
  category: identity
  id_prefix: plposix173

  columns: [id, function, args, expected, description]
  rows:
    - [posix_name,     PosixPath.__name__.__eq__,                ["PosixPath"],  true, "pathlib.PosixPath.__name__ == 'PosixPath' — PosixPath is the concrete POSIX filesystem path class used on Unix/Linux/macOS; 'PosixPath' has 9 characters: 'Posix' (5) + 'Path' (4) = 9; PosixPath.__name__ (9 chars) is 4 characters shorter than PurePosixPath.__name__ (13 chars) — the 4-character 'Pure' prefix is absent; PosixPath (9) is the second-shortest pathlib class name after Path (4); the 'Posix' infix (5 chars) appears in both PurePosixPath (13) and PosixPath (9) — 'Pure'+'Posix'+'Path' vs 'Posix'+'Path'; PosixPath can only be instantiated on POSIX systems — attempting to instantiate it on Windows raises NotImplementedError; confirmed Python 3.14.3 macOS"]
    - [posix_module,   PosixPath.__module__.__eq__,              ["pathlib"],    true, "pathlib.PosixPath.__module__ == 'pathlib' — PosixPath is defined in the public 'pathlib' module; 'pathlib' has 7 characters; PosixPath.__module__ (7 chars) > PosixPath.__name__ (9 chars)? No: 7 < 9 — the module name is shorter than the class name; PosixPath.__module__ (7) == Path.__module__ (7) == PurePath.__module__ (7) — all pathlib classes share the same 7-character module name 'pathlib'; 'pathlib' (7 chars) is 2 characters shorter than PosixPath (9 chars); confirmed Python 3.14.3 macOS"]
    - [posix_base0,    "PosixPath.__bases__[0].__name__.__eq__",  ["Path"],      true, "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits directly from Path; 'Path' has 4 characters; the inheritance chain is: PosixPath -> Path -> PurePath -> object; PosixPath.__bases__[0].__name__ (4: 'Path') == WindowsPath.__bases__[0].__name__ (4: 'Path'): both PosixPath and WindowsPath inherit from Path (not from PurePath directly); the 4-character base name 'Path' matches the 4-character 'Pure' prefix — coincidentally the same length; PosixPath (9) inherits from Path (4): the derived class name (9 chars) is more than twice the base class name (4 chars) in length; confirmed Python 3.14.3 macOS"]
    - [posix_name_len, PosixPath.__name__.__len__,               [],            9,    "pathlib.PosixPath.__name__.__len__() == 9 — 'PosixPath' has 9 characters: 'Posix' (5) + 'Path' (4) = 9; PosixPath (9) == PurePosixPath (13) - 4: removing the 'Pure' prefix (4 chars) from PurePosixPath (13) gives PosixPath (9); the name length relationship PosixPath(9) = PurePosixPath(13) - len('Pure')(4) holds: 13 - 4 = 9; similarly WindowsPath (11) = PureWindowsPath (15) - 4; the concrete classes are exactly 4 characters shorter than their pure counterparts; PosixPath (9) and WindowsPath (11) differ by 2 because 'Posix' (5) < 'Windows' (7) by 2; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.WindowsPath class identity
# __name__ == 'WindowsPath' (len=11), __module__ == 'pathlib' (len=7)
# __bases__[0].__name__ == 'Path' (len=4)
# WindowsPath (11) = PureWindowsPath (15) - 4 (no 'Pure' prefix)
# ---------------------------------------------------------------------------

table pathlib_extra173.WindowsPath_class_identity:
  description: "pathlib.WindowsPath class identity: __name__=='WindowsPath' (len=11), __module__=='pathlib' (len=7), __bases__[0].__name__=='Path' (len=4); WindowsPath (11) = 'Windows'(7)+'Path'(4)=11; WindowsPath (11) = PureWindowsPath (15) - 4"
  kind: python_call_eq
  category: identity
  id_prefix: plwin173

  columns: [id, function, args, expected, description]
  rows:
    - [win_name,     WindowsPath.__name__.__eq__,                ["WindowsPath"],  true, "pathlib.WindowsPath.__name__ == 'WindowsPath' — WindowsPath is the concrete Windows filesystem path class; 'WindowsPath' has 11 characters: 'Windows' (7) + 'Path' (4) = 11; WindowsPath (11) is the second-longest concrete path class name after WindowsPath — in the concrete class family: Path (4) < PosixPath (9) < WindowsPath (11); WindowsPath (11) == PureWindowsPath (15) - 4: the 'Pure' prefix removal reduces the name by exactly 4 characters; 'Windows' (7 chars) > 'Posix' (5 chars) by 2, so WindowsPath (11) > PosixPath (9) by 2; WindowsPath can only be instantiated on Windows — attempting to instantiate it on POSIX raises NotImplementedError; confirmed Python 3.14.3 macOS"]
    - [win_module,   WindowsPath.__module__.__eq__,              ["pathlib"],      true, "pathlib.WindowsPath.__module__ == 'pathlib' — WindowsPath is defined in the public 'pathlib' module; 'pathlib' has 7 characters; WindowsPath.__module__ (7 chars) < WindowsPath.__name__ (11 chars) by 4 — the module name is 4 characters shorter than the class name; WindowsPath.__module__ (7) == PosixPath.__module__ (7) == Path.__module__ (7): all concrete path classes share the 7-character 'pathlib' module name; 'pathlib' (7 chars) is the same for all six pathlib classes: PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath; confirmed Python 3.14.3 macOS"]
    - [win_base0,    "WindowsPath.__bases__[0].__name__.__eq__",  ["Path"],        true, "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath inherits directly from Path; 'Path' has 4 characters; WindowsPath.__bases__[0].__name__ (4: 'Path') == PosixPath.__bases__[0].__name__ (4: 'Path'): both concrete OS-specific path classes inherit from Path; the inheritance chain is: WindowsPath -> Path -> PurePath -> object; WindowsPath and PosixPath are sibling classes (both children of Path), mirroring the pure hierarchy where PureWindowsPath and PurePosixPath are siblings (both children of PurePath); WindowsPath (11) inherits from Path (4): the child name is 7 characters longer than the parent name; confirmed Python 3.14.3 macOS"]
    - [win_name_len, WindowsPath.__name__.__len__,               [],              11,   "pathlib.WindowsPath.__name__.__len__() == 11 — 'WindowsPath' has 11 characters: 'Windows' (7) + 'Path' (4) = 11; WindowsPath (11) = PureWindowsPath (15) - 4 = 15 - len('Pure') = 15 - 4 = 11; WindowsPath (11) > PosixPath (9) by 2: the 'Windows' infix (7 chars) > 'Posix' infix (5 chars) by 2, so WindowsPath exceeds PosixPath by 2; in the full six-class length ordering: Path(4) < PurePath(8) < PosixPath(9) < WindowsPath(11) < PurePosixPath(13) < PureWindowsPath(15); WindowsPath (11) sits between PosixPath (9) and PurePosixPath (13); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Cross-hierarchy name length comparisons
# All six pathlib class name lengths: Path(4), PurePath(8), PosixPath(9),
# WindowsPath(11), PurePosixPath(13), PureWindowsPath(15)
# Concrete classes are 4 chars shorter than their pure counterparts.
# ---------------------------------------------------------------------------

table pathlib_extra173.six_class_name_length_ordering:
  description: "All six pathlib class name lengths: Path(4) < PurePath(8) < PosixPath(9) < WindowsPath(11) < PurePosixPath(13) < PureWindowsPath(15); concrete classes are 4 chars shorter than their pure counterparts (PosixPath=PurePosixPath-4, WindowsPath=PureWindowsPath-4, Path=PurePath-4)"
  kind: python_call_eq
  category: identity
  id_prefix: pl6173

  columns: [id, function, args, expected, description]
  rows:
    - [path_len_4,    Path.__name__.__len__,           [],  4,  "pathlib.Path.__name__.__len__() == 4 — 'Path' is the shortest of all six pathlib class names; Path (4) is the minimum in the ascending sequence: Path(4) < PurePath(8) < PosixPath(9) < WindowsPath(11) < PurePosixPath(13) < PureWindowsPath(15); 4 == len('Pure') — the 'Pure' prefix length equals the length of the shortest class name 'Path'; Path (4) < PurePath (8) by 4 — the gap from Path to its base PurePath equals len('Pure'); confirmed Python 3.14.3 macOS"]
    - [posix_len_9,   PosixPath.__name__.__len__,      [],  9,  "pathlib.PosixPath.__name__.__len__() == 9 — 'PosixPath' = 'Posix'(5)+'Path'(4) = 9; PosixPath (9) = PurePosixPath (13) - 4 = PurePosixPath - len('Pure'); removing the 'Pure' prefix from PurePosixPath (13) gives PosixPath (9); PosixPath (9) sits between PurePath (8) and WindowsPath (11) in the six-class ordering; gap: PurePath(8) to PosixPath(9) is 1; gap: PosixPath(9) to WindowsPath(11) is 2; confirmed Python 3.14.3 macOS"]
    - [win_len_11,    WindowsPath.__name__.__len__,    [],  11, "pathlib.WindowsPath.__name__.__len__() == 11 — 'WindowsPath' = 'Windows'(7)+'Path'(4) = 11; WindowsPath (11) = PureWindowsPath (15) - 4 = PureWindowsPath - len('Pure'); the 'Pure' prefix reduction is uniform: Path = PurePath - 4, PosixPath = PurePosixPath - 4, WindowsPath = PureWindowsPath - 4; WindowsPath (11) sits between PosixPath (9) and PurePosixPath (13) in the six-class ordering; confirmed Python 3.14.3 macOS"]
    - [pure_pure_gap, PurePath.__name__.__len__,       [],  8,  "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' = 'Pure'(4)+'Path'(4) = 8; PurePath (8) == Path (4) + 4 == Path + len('Pure'): the base pure class is exactly 4 characters longer than the concrete Path class; PurePath (8) sits between Path (4) and PosixPath (9) in the six-class ordering; gap: Path(4) to PurePath(8) is 4; gap: PurePath(8) to PosixPath(9) is 1; PurePath (8) is the only class whose name length equals the sum of two equal parts: 'Pure'(4)+'Path'(4)=8; confirmed Python 3.14.3 macOS"]
    - [pure_diff_4,   PosixPath.__name__.__len__,      [],  9,  "pathlib.PosixPath.__name__.__len__() == 9 == PurePosixPath.__name__.__len__() - 4 == 13 - 4; the concrete-to-pure reduction of 4 characters (len('Pure')) is a structural constant across all three OS-specific path class pairs: Path(4)=PurePath(8)-4, PosixPath(9)=PurePosixPath(13)-4, WindowsPath(11)=PureWindowsPath(15)-4; this uniform 4-character reduction means the 'Pure' prefix contributes exactly len('Pure')==4 characters to each pure class name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra173.Path_name_is_Path:
  description: "pathlib.Path.__name__ == 'Path' — Path is the main concrete filesystem path class; 'Path' has 4 characters — the minimum among all six pathlib class names: Path(4) < PurePath(8) < PosixPath(9) < WindowsPath(11) < PurePosixPath(13) < PureWindowsPath(15); Path (4 chars) == len('Pure') == 4 — the 'Pure' prefix length equals the entire 'Path' class name length; Path.__bases__[0].__name__ == 'PurePath' (8 chars), making the base class name exactly double the derived class name in length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra173.Path_module_is_pathlib:
  description: "pathlib.Path.__module__ == 'pathlib' — Path is defined in the public 'pathlib' module; 'pathlib' has 7 characters; Path.__module__ (7 chars) > Path.__name__ (4 chars) by 3 — the module name is longer than the class name; all six pathlib classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath) share __module__ == 'pathlib' (7 chars); this uniform module attribution is unlike the io module where some classes report __module__ == '_io' (3 chars) and others report 'io' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra173.Path_base_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits directly from PurePath; 'PurePath' has 8 characters; Path.__bases__[0].__name__ (8: 'PurePath') is double Path.__name__.__len__() (4: 'Path') in length; the inheritance chain Path -> PurePath -> object places Path at the second level; PosixPath and WindowsPath inherit from Path (not from PurePath directly) — forming two levels: pure abstract, concrete base (Path), and OS-specific concrete (PosixPath/WindowsPath); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra173.PosixPath_name_is_PosixPath:
  description: "pathlib.PosixPath.__name__ == 'PosixPath' — PosixPath is the concrete POSIX filesystem path class; 'PosixPath' has 9 characters: 'Posix' (5) + 'Path' (4) = 9; PosixPath (9) == PurePosixPath (13) - 4: the 4-character 'Pure' prefix is the only difference; PosixPath (9) > Path (4) by 5 — the 'Posix' infix adds 5 characters; PosixPath and WindowsPath both inherit from Path and cannot be instantiated cross-platform; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PosixPath.__name__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra173.PosixPath_base_is_Path:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits directly from Path; 'Path' has 4 characters; PosixPath.__bases__[0].__name__ (4: 'Path') == WindowsPath.__bases__[0].__name__ (4: 'Path') — both OS-specific concrete path classes share Path as their immediate parent; the concrete path hierarchy mirrors the pure path hierarchy: PosixPath->Path mirrors PurePosixPath->PurePath, WindowsPath->Path mirrors PureWindowsPath->PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PosixPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra173.WindowsPath_name_is_WindowsPath:
  description: "pathlib.WindowsPath.__name__ == 'WindowsPath' — WindowsPath is the concrete Windows filesystem path class; 'WindowsPath' has 11 characters: 'Windows' (7) + 'Path' (4) = 11; WindowsPath (11) == PureWindowsPath (15) - 4: removing the 'Pure' prefix (4 chars) gives the concrete class name; WindowsPath (11) > PosixPath (9) by 2, because 'Windows' (7) > 'Posix' (5) by 2; the ascending six-class name length sequence: Path(4), PurePath(8), PosixPath(9), WindowsPath(11), PurePosixPath(13), PureWindowsPath(15); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: WindowsPath.__name__.__eq__
  args: ["WindowsPath"]
  expected: true

invariant pathlib_extra173.WindowsPath_base_is_Path:
  description: "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath inherits directly from Path; 'Path' has 4 characters; WindowsPath.__bases__[0].__name__ (4) == PosixPath.__bases__[0].__name__ (4) == 'Path': both OS-specific concrete path classes share Path as their direct parent; the concrete inheritance tree: Path (base) -> PosixPath (POSIX), Path (base) -> WindowsPath (Windows); the pure inheritance tree: PurePath (base) -> PurePosixPath, PurePath (base) -> PureWindowsPath; the two hierarchies are structurally parallel with Path playing the role that PurePath plays in the pure subtree; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "WindowsPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra173.WindowsPath_len_11:
  description: "pathlib.WindowsPath.__name__.__len__() == 11 — 'WindowsPath' has 11 characters: 'Windows' (7) + 'Path' (4) = 11; WindowsPath (11) is 2 longer than PosixPath (9) because 'Windows' (7) is 2 longer than 'Posix' (5); WindowsPath (11) = PureWindowsPath (15) - 4 — the concrete-to-pure reduction of 4 is uniform: Path(4)=PurePath(8)-4, PosixPath(9)=PurePosixPath(13)-4, WindowsPath(11)=PureWindowsPath(15)-4; the full six-class ascending sequence: Path(4), PurePath(8), PosixPath(9), WindowsPath(11), PurePosixPath(13), PureWindowsPath(15); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: WindowsPath.__name__.__len__
  args: []
  expected: 11

