spec: gc_extra9
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra8.zspec.zsdl."
    - "gc_extra7 covers __class__.__name__ == 'builtin_function_or_method' for collect/enable/is_finalized/get_freeze_count."
    - "NOT yet covered: __class__.__name__ for disable/isenabled/get_count/get_threshold/set_threshold/get_objects/get_referrers/get_referents/is_tracked/freeze/unfreeze."
    - "NOT yet covered: collect(1) and collect(2) return int and are non-negative."
    - "NOT yet covered: is_tracked for set() — empty set is GC-tracked (unlike frozenset which is not)."
    - "NOT yet covered: is_tracked(()) == False — empty tuple is not GC-tracked."
    - "NOT yet covered: get_threshold()[2] == 10 — CPython default gen-2 threshold."
    - "NOT yet covered: get_count() tuple class name check (separate from length)."
    - "gc.is_tracked(0) == False — zero is a small int and not GC-tracked."
    - "gc.is_tracked(-1) == False — negative small integers are not GC-tracked."
    - "gc.collect(1) returns int — generation-1 collection works and returns unreachable count."
    - "gc.collect(2) returns int — generation-2 collection works and returns unreachable count."
    - "gc.get_threshold()[2] == 10 — CPython default gen-2 threshold is 10."
    - "All gc functions have __class__.__name__ == 'builtin_function_or_method'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function class type checks — remaining gc functions not in gc_extra7
#
# gc_extra7 covers collect/enable/is_finalized/get_freeze_count.
# This spec adds the remaining gc functions: disable, isenabled, get_count,
# get_threshold, set_threshold, get_objects, get_referrers, get_referents,
# is_tracked, freeze, unfreeze.
# ---------------------------------------------------------------------------

table gc_extra9.function_class_types:
  kind: python_call_eq
  category: function_types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [disable,       disable.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [isenabled,     isenabled.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [get_count,     get_count.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [get_threshold, get_threshold.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [set_threshold, set_threshold.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [get_objects,   get_objects.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [get_referrers, get_referrers.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [get_referents, get_referents.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [is_tracked,    is_tracked.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [freeze,        freeze.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [unfreeze,      unfreeze.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# is_tracked — integer zero and negative small integer
#
# gc_extra8 covers non-empty tuple, str, bytes, float, bool True.
# Prior specs cover [] and {} (True), and 1 (False).
# NOT yet covered: 0 (False) and -1 (False) — all small integers, including
# zero and negative values, are not GC-tracked in CPython.
# ---------------------------------------------------------------------------

invariant gc_extra9.is_tracked.zero:
  description: "gc.is_tracked(0) == False — zero is a small integer, not GC-tracked"
  category: is_tracked
  kind: python_call_eq
  function: is_tracked
  args: [0]
  expected: false

invariant gc_extra9.is_tracked.negative_one:
  description: "gc.is_tracked(-1) == False — negative small integers are not GC-tracked"
  category: is_tracked
  kind: python_call_eq
  function: is_tracked
  args: [-1]
  expected: false

# ---------------------------------------------------------------------------
# collect — generation 1 and 2 return int and are non-negative
#
# gc_extra8 adds collect(0) returns int and >= 0.
# No prior spec tests collect(1) or collect(2).
# ---------------------------------------------------------------------------

invariant gc_extra9.collect.gen1_returns_int:
  description: "gc.collect(1).__class__.__name__ == 'int' — collect(generation=1) returns int"
  category: collect
  kind: python_call_eq
  function: collect(1).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra9.collect.gen1_nonneg:
  description: "gc.collect(1) >= 0 — generation-1 collection returns non-negative count"
  category: collect
  kind: python_call_eq
  function: collect(1).__ge__
  args: [0]
  expected: true

invariant gc_extra9.collect.gen2_returns_int:
  description: "gc.collect(2).__class__.__name__ == 'int' — collect(generation=2) returns int"
  category: collect
  kind: python_call_eq
  function: collect(2).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra9.collect.gen2_nonneg:
  description: "gc.collect(2) >= 0 — generation-2 collection returns non-negative count"
  category: collect
  kind: python_call_eq
  function: collect(2).__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold — gen-2 default value
#
# gc_extra8 checks get_threshold()[1] == 10 (gen-1 default).
# No prior spec checks get_threshold()[2] == 10 (gen-2 default value).
# NOTE: The value is the documented CPython default; may differ if modified.
# ---------------------------------------------------------------------------

invariant gc_extra9.get_threshold.gen2_default:
  description: "gc.get_threshold()[2] == 10 — CPython default generation-2 threshold is 10"
  category: threshold
  kind: python_call_eq
  function: get_threshold().__getitem__(2).__eq__
  args: [10]
  expected: true
