spec: ft3436
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 676 (ft3436): __le__, __gt__, __ge__ dict-presence checks for functools types."
    - "Theme: __le__/__gt__/__ge__ dict-presence (x<=y, x>y, x>=y)."
    - "All values False — functools.partial defines __eq__ (wave 675) but does NOT define __le__, __gt__, or __ge__: partial objects only support equality comparison, not ordering."
    - "All other functools types (partialmethod, cached_property, lru_cache wrapper) do not define __le__, __gt__, or __ge__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3436.le:
  description: "functools types __le__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3436
  columns: [id, function, args, expected]
  rows:
    - ["ft3436001", operator.contains, [functools.partial.__dict__,                          "__le__"], false]
    - ["ft3436002", operator.contains, [functools.partialmethod.__dict__,                    "__le__"], false]
    - ["ft3436003", operator.contains, [functools.cached_property.__dict__,                  "__le__"], false]
    - ["ft3436004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,    "__le__"], false]

