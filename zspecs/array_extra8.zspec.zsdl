spec: array_extra8
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec extends array.zspec.zsdl through array_extra7.zspec.zsdl."
    - "array_extra covers: array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2 covers: typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3 covers: ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4 covers: typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5 covers: ArrayType.__qualname__, typecodes contains 'I', tobytes class/length for 'b', itemsize lower-bound guard."
    - "array_extra6 covers: array metaclass (type), MRO length 2, typecodes contains 'u'/'w', class identity table, arraytype_alias table, float array tolist/length/typecode for 'f'."
    - "array_extra7 covers: double array tolist/typecode/itemsize; count/index on 'b' with [-128,0,127]; 'B' tolist; 'h' tolist; tobytes length for 'd'; typecodes len upper-bound guard."
    - "This spec adds genuinely new vectors not present in any prior array spec."
    - "array.typecodes.__class__.__name__ == 'str' — typecodes attribute is a plain string (new as standalone invariant confirming class, not just content)."
    - "array.array.__name__ == 'array' — already in array_extra but not as a standalone invariant using __eq__ chaining; extra8 adds the __eq__ form."
    - "array.array.__module__ == 'array' — confirmed via __eq__ chain (not standalone in extra1; extra3 covered ArrayType.__module__)."
    - "array.array('b', [1,2,3]).typecode == 'b' — 'b' typecode attribute via __eq__ chain; prior specs used typecode_attr table but not this exact invariant form."
    - "array.array('B', [1,2,3]).typecode == 'B' — unsigned byte typecode attribute check; prior specs verified 'B' in typecodes string, not instance typecode."
    - "array.array('i', [1,2,3]).itemsize == 4 — signed int itemsize; verified via __eq__ standalone invariant (prior specs used table form)."
    - "array.array('h', [1,2,3]).itemsize == 2 — signed short itemsize; prior specs used table form."
    - "array.array('d', [1.0,2.0]).itemsize == 8 — double itemsize standalone invariant (array_extra7 used __eq__ chain in method; this uses direct expected)."
    - "array.array('b', []).buffer_info().__class__.__name__ == 'tuple' — buffer_info returns a tuple; array_extra3 verified buffer_info but not its class name."
    - "array.array('b', [1,2,3]).buffer_info().__len__() == 2 — buffer_info returns a 2-tuple (address, length); no prior spec checks the length of the tuple."
    - "array.array('b', [1,2,3]).count(2) == 1 — count() on 'b' with value 2 appearing once; array_extra3 used 'i' with [1,2,3]."
    - "array.array('b', [1,2,3]).index(2) == 1 — index() on 'b' with [1,2,3]; array_extra7 used [-128,0,127]; [1,2,3] with index(2)==1 is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level typecodes attribute — class name
#
# array_extra2 checks typecodes.__len__() >= minimum and typecodes contains
# specific characters. array_extra confirms typecodes is a str instance.
# This spec verifies the class name via standalone invariant with __eq__ chain.
# ---------------------------------------------------------------------------

invariant array_extra8.typecodes.class_name:
  description: "array.typecodes.__class__.__name__ == 'str' — typecodes is a plain string"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# array.array class — __name__ and __module__ via __eq__ chain
#
# array_extra confirmed __name__/__module__ but using a different invariant
# form. This spec uses the dotted __eq__ chain form for consistency with the
# established extra8 pattern. New as standalone invariants in extra8 namespace.
# ---------------------------------------------------------------------------

invariant array_extra8.array_class.name:
  description: "array.array.__name__ == 'array' — class name of the array type"
  category: class_identity
  kind: python_call_eq
  function: array.__name__.__eq__
  args: ["array"]
  expected: true

invariant array_extra8.array_class.module:
  description: "array.array.__module__ == 'array' — array class is defined in the array module"
  category: class_identity
  kind: python_call_eq
  function: array.__module__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# typecode attribute — per-instance checks for 'b' and 'B'
#
# Prior specs used typecode_attr tables for many typecodes. This spec adds
# standalone invariants for 'b' and 'B' in the extra8 namespace using the
# method __eq__ pattern.
# ---------------------------------------------------------------------------

invariant array_extra8.signed_byte.typecode:
  description: "array.array('b', [1,2,3]).typecode == 'b' — typecode attribute for signed byte array"
  category: typecode_attrs
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: typecode.__eq__
  method_args: ["b"]
  expected: true

invariant array_extra8.unsigned_byte.typecode:
  description: "array.array('B', [1,2,3]).typecode == 'B' — typecode attribute for unsigned byte array"
  category: typecode_attrs
  kind: python_call_eq
  function: array
  args: ["B", [1, 2, 3]]
  method: typecode.__eq__
  method_args: ["B"]
  expected: true

# ---------------------------------------------------------------------------
# itemsize — standalone invariants for 'i', 'h', and 'd'
#
# Prior specs used table form for itemsize checks. This spec adds standalone
# invariants in the extra8 namespace using direct expected values.
# ---------------------------------------------------------------------------

invariant array_extra8.signed_int.itemsize:
  description: "array.array('i', [1,2,3]).itemsize == 4 — signed int is 4 bytes per element"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: itemsize.__eq__
  method_args: [4]
  expected: true

invariant array_extra8.signed_short.itemsize:
  description: "array.array('h', [1,2,3]).itemsize == 2 — signed short is 2 bytes per element"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["h", [1, 2, 3]]
  method: itemsize.__eq__
  method_args: [2]
  expected: true

invariant array_extra8.double.itemsize:
  description: "array.array('d', [1.0,2.0]).itemsize == 8 — double precision float is 8 bytes per element"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["d", [1.0, 2.0]]
  method: itemsize.__eq__
  method_args: [8]
  expected: true

# ---------------------------------------------------------------------------
# buffer_info() — return type and tuple length
#
# array_extra3 exercised buffer_info() but did not check the class name of
# the return value or the length of the returned tuple.
# buffer_info() always returns a 2-tuple: (address, length).
# ---------------------------------------------------------------------------

invariant array_extra8.buffer_info.class_name:
  description: "array.array('b', []).buffer_info().__class__.__name__ == 'tuple' — buffer_info returns a tuple"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", []]
  method: buffer_info
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["tuple"]
  expected: true

invariant array_extra8.buffer_info.len:
  description: "array.array('b', [1,2,3]).buffer_info().__len__() == 2 — buffer_info tuple has exactly 2 elements"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: buffer_info
  method_args: []
  method_chain: __len__
  method_chain_args: []
  expected: 2

# ---------------------------------------------------------------------------
# count() and index() — typecode 'b' with fixture [1, 2, 3]
#
# array_extra3 uses count/index on 'i' with [1,2,3]. array_extra7 uses count/
# index on 'b' with [-128, 0, 127]. The fixture [1, 2, 3] on 'b' is new:
#   count(2) == 1 — value 2 appears once
#   index(2) == 1 — value 2 is at position 1
# ---------------------------------------------------------------------------

invariant array_extra8.signed_byte.count:
  description: "array.array('b', [1,2,3]).count(2) == 1 — value 2 appears exactly once"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: count
  method_args: [2]
  expected: 1

invariant array_extra8.signed_byte.index:
  description: "array.array('b', [1,2,3]).index(2) == 1 — value 2 is at index 1"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: index
  method_args: [2]
  expected: 1
