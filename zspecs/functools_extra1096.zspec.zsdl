    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks cmp_to_key class identity (module/qualname/name/__new__ qualname), reduce.__doc__.__class__.__name__, partial.__new__ qualname, lru_cache/__doc__/__class__/__name__, singledispatch/__doc__/__class__/__name__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1096.cmp_to_key_identity:
  description: "functools.cmp_to_key class identity: module, qualname, name, and __new__ qualname"
  kind: python_call_eq
  category: cmp_to_key_identity
  id_prefix: fn1096ck
  columns: [id, function, args, expected]
  rows:
    - [fn1096ck001, functools.cmp_to_key.__name__.__eq__,                     ["cmp_to_key"],                   true]
    - [fn1096ck002, functools.cmp_to_key.__qualname__.__eq__,                  ["cmp_to_key"],                   true]
    - [fn1096ck003, functools.cmp_to_key.__module__.__eq__,                    ["functools"],                    true]
    - [fn1096ck004, functools.cmp_to_key.__class__.__name__.__eq__,            ["builtin_function_or_method"],   true]
    - [fn1096ck005, functools.cmp_to_key.__doc__.__class__.__name__.__eq__,    ["str"],                          true]
    - [fn1096ck006, functools.reduce.__qualname__.__eq__,                       ["reduce"],                       true]
    - [fn1096ck007, functools.reduce.__doc__.__class__.__name__.__eq__,         ["str"],                          true]
    - [fn1096ck008, functools.reduce.__class__.__name__.__eq__,                 ["builtin_function_or_method"],   true]

table functools_extra1096.partial_new_and_lru_doc:
  description: "functools.partial.__new__ qualname, partial module, lru_cache doc class name"
  kind: python_call_eq
  category: partial_new_lru_doc
  id_prefix: fn1096pl
  columns: [id, function, args, expected]
  rows:
    - [fn1096pl001, functools.partial.__new__.__qualname__.__eq__,             ["partial.__new__"],              true]
    - [fn1096pl002, functools.partial.__new__.__class__.__name__.__eq__,       ["wrapper_descriptor"],           true]
    - [fn1096pl003, functools.partial.__module__.__eq__,                       ["functools"],                    true]
    - [fn1096pl004, functools.lru_cache.__name__.__eq__,                       ["lru_cache"],                    true]
    - [fn1096pl005, functools.lru_cache.__doc__.__class__.__name__.__eq__,     ["str"],                          true]
    - [fn1096pl006, functools.lru_cache.__module__.__eq__,                     ["functools"],                    true]
    - [fn1096pl007, functools.lru_cache.__class__.__name__.__eq__,             ["function"],                     true]
    - [fn1096pl008, functools.lru_cache.__qualname__.__eq__,                   ["lru_cache"],                    true]

table functools_extra1096.singledispatch_doc_and_total_ordering:
  description: "functools.singledispatch doc class name and total_ordering identity"
  kind: python_call_eq
  category: singledispatch_doc_total_ordering
  id_prefix: fn1096st
  columns: [id, function, args, expected]
  rows:
    - [fn1096st001, functools.singledispatch.__doc__.__class__.__name__.__eq__, ["str"],                         true]
    - [fn1096st002, functools.singledispatch.__name__.__eq__,                   ["singledispatch"],              true]
    - [fn1096st003, functools.total_ordering.__qualname__.__eq__,               ["total_ordering"],              true]
    - [fn1096st004, functools.total_ordering.__module__.__eq__,                 ["functools"],                   true]
    - [fn1096st005, functools.total_ordering.__class__.__name__.__eq__,         ["function"],                    true]
    - [fn1096st006, functools.total_ordering.__doc__.__class__.__name__.__eq__, ["str"],                         true]
    - [fn1096st007, functools.wraps.__class__.__name__.__eq__,                  ["function"],                    true]
    - [fn1096st008, functools.wraps.__doc__.__class__.__name__.__eq__,          ["str"],                         true]
