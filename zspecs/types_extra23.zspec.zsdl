spec: types_extra23
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types_extra22.zspec.zsdl — covers combined __qualname__.__eq__ table for FunctionType/MethodType/GeneratorType/CoroutineType/AsyncGeneratorType/ModuleType/NoneType/SimpleNamespace/MappingProxyType/UnionType in the extra22 namespace; standalone invariants for AsyncGeneratorType/NoneType/UnionType qualnames."
    - "types_extra19.zspec.zsdl — covers FunctionType/GeneratorType/ModuleType/CodeType/MethodType/BuiltinFunctionType __bases__[0].__name__ table; __bases__.__len__ standalone invariants."
    - "types_extra17.zspec.zsdl — covers combined __qualname__ table for FunctionType/LambdaType/CodeType/MappingProxyType/SimpleNamespace/GeneratorType/CoroutineType; combined __module__ table for FunctionType/LambdaType/CodeType/MappingProxyType/SimpleNamespace."
    - "types_extra8.zspec.zsdl — covers descriptor types __module__/__bases__[0]; CapsuleType/__name__/__qualname__/__module__; DynamicClassAttribute/__name__/__module__; SimpleNamespace/__bases__[0]; UnionType/__bases__[0]."
    - "types_extra2.zspec.zsdl — covers __module__ for major types; __bases__[0].__name__ for FunctionType/GeneratorType/CoroutineType/AsyncGeneratorType/CodeType/FrameType/TracebackType/ModuleType/MethodType/SimpleNamespace."
  notes:
    - "This spec extends types_extra22.zspec.zsdl."
    - "Focus: novel combined tables in the extra23 namespace — (1) combined __module__ table for ModuleType/FunctionType/MethodType/BuiltinFunctionType/GeneratorType/CoroutineType/NoneType/MappingProxyType/LambdaType (all 'builtins') plus SimpleNamespace ('types'); (2) combined __bases__[0].__name__ table for SimpleNamespace/MappingProxyType/NoneType/LambdaType/GeneratorType/CoroutineType/BuiltinMethodType/MethodWrapperType (all 'object'); (3) standalone for CapsuleType.__qualname__ == 'PyCapsule'."
    - "types.ModuleType.__module__ == 'builtins' — C-level module type."
    - "types.FunctionType.__module__ == 'builtins' — C-level function type."
    - "types.MethodType.__module__ == 'builtins' — C-level method type."
    - "types.BuiltinFunctionType.__module__ == 'builtins' — C-level builtin function type."
    - "types.GeneratorType.__module__ == 'builtins' — C-level generator type."
    - "types.CoroutineType.__module__ == 'builtins' — C-level coroutine type."
    - "types.NoneType.__module__ == 'builtins' — C-level NoneType."
    - "types.MappingProxyType.__module__ == 'builtins' — C-level mappingproxy type."
    - "types.LambdaType.__module__ == 'builtins' — alias for FunctionType; same C-level type."
    - "types.SimpleNamespace.__module__ == 'types' — SimpleNamespace is defined in Lib/types.py."
    - "types.SimpleNamespace.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "types.MappingProxyType.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "types.NoneType.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "types.LambdaType.__bases__[0].__name__ == 'object' — same as FunctionType, direct subclass of object."
    - "types.GeneratorType.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "types.CoroutineType.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "types.BuiltinMethodType.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "types.MethodWrapperType.__bases__[0].__name__ == 'object' — direct subclass of object."
    - "types.CapsuleType.__qualname__ == 'PyCapsule' — C-level PyCapsule type; types_extra8 covers __name__/__qualname__/__module__ in a notes entry. Re-anchored here as standalone in extra23 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ combined table for core types in the extra23 namespace
#
# types_extra17 covers FunctionType/LambdaType/CodeType/MappingProxyType/SimpleNamespace.
# types_extra2 covers many more. This extra23 table groups ten types together
# including ModuleType/MethodType/BuiltinFunctionType/GeneratorType/CoroutineType/NoneType
# not previously combined in a single table in the extra23 namespace.
# ---------------------------------------------------------------------------

table types_extra23.modules:
  description: "__module__.__eq__ for core types module class types in the extra23 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [ModuleType,           ModuleType.__module__.__eq__,           ["builtins"], true]
    - [FunctionType,         FunctionType.__module__.__eq__,         ["builtins"], true]
    - [MethodType,           MethodType.__module__.__eq__,           ["builtins"], true]
    - [BuiltinFunctionType,  BuiltinFunctionType.__module__.__eq__,  ["builtins"], true]
    - [GeneratorType,        GeneratorType.__module__.__eq__,        ["builtins"], true]
    - [CoroutineType,        CoroutineType.__module__.__eq__,        ["builtins"], true]
    - [NoneType,             NoneType.__module__.__eq__,             ["builtins"], true]
    - [MappingProxyType,     MappingProxyType.__module__.__eq__,     ["builtins"], true]
    - [LambdaType,           LambdaType.__module__.__eq__,           ["builtins"], true]
    - [SimpleNamespace,      SimpleNamespace.__module__.__eq__,      ["types"],    true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ combined table for selected types (extra23 namespace)
#
# types_extra2 covers FunctionType/GeneratorType/CoroutineType/AsyncGeneratorType/
# CodeType/FrameType/TracebackType/ModuleType/MethodType/SimpleNamespace.
# types_extra8 covers SimpleNamespace/__bases__[0] and descriptor types.
# This extra23 table groups SimpleNamespace/MappingProxyType/NoneType/LambdaType/
# GeneratorType/CoroutineType/BuiltinMethodType/MethodWrapperType into a single
# table in the extra23 namespace — all with __bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

table types_extra23.bases:
  description: "__bases__[0].__name__.__eq__ for selected types module class types in the extra23 namespace"
  kind: python_call_eq
  category: bases
  id_prefix: bases

  columns: [id, function, args, expected]
  rows:
    - [SimpleNamespace,    "SimpleNamespace.__bases__[0].__name__.__eq__",    ["object"], true]
    - [MappingProxyType,   "MappingProxyType.__bases__[0].__name__.__eq__",   ["object"], true]
    - [NoneType,           "NoneType.__bases__[0].__name__.__eq__",           ["object"], true]
    - [LambdaType,         "LambdaType.__bases__[0].__name__.__eq__",         ["object"], true]
    - [GeneratorType,      "GeneratorType.__bases__[0].__name__.__eq__",      ["object"], true]
    - [CoroutineType,      "CoroutineType.__bases__[0].__name__.__eq__",      ["object"], true]
    - [BuiltinMethodType,  "BuiltinMethodType.__bases__[0].__name__.__eq__",  ["object"], true]
    - [MethodWrapperType,  "MethodWrapperType.__bases__[0].__name__.__eq__",  ["object"], true]

# ---------------------------------------------------------------------------
# types.CapsuleType.__qualname__ == 'PyCapsule' — standalone (extra23 namespace)
#
# CapsuleType is the C-level capsule object type. Its __qualname__ is 'PyCapsule'
# (the C struct name) rather than 'CapsuleType'. types_extra8 mentions CapsuleType
# in its notes. Re-anchored here as a standalone invariant in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant types_extra23.CapsuleType.qualname:
  description: "types.CapsuleType.__qualname__ == 'PyCapsule' — C-level capsule type uses PyCapsule as qualname"
  category: type_qualnames
  kind: python_call_eq
  function: CapsuleType.__qualname__.__eq__
  args: ["PyCapsule"]
  expected: true

# ---------------------------------------------------------------------------
# types.SimpleNamespace.__module__ == 'types' — standalone (extra23 namespace)
#
# Unlike the other C-level types in the types module whose __module__ is 'builtins',
# SimpleNamespace is defined in Lib/types.py and has __module__ == 'types'.
# This property distinguishes it from all other types module class types.
# Re-anchored here as a standalone in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant types_extra23.SimpleNamespace.module:
  description: "types.SimpleNamespace.__module__ == 'types' — unlike C-level types, SimpleNamespace is defined in Lib/types.py"
  category: module_attrs
  kind: python_call_eq
  function: SimpleNamespace.__module__.__eq__
  args: ["types"]
  expected: true

# ---------------------------------------------------------------------------
# types.BuiltinMethodType.__module__ == 'builtins' — standalone (extra23 namespace)
#
# BuiltinMethodType is an alias for builtin_function_or_method (same C-level type
# as BuiltinFunctionType). Its __module__ is 'builtins'. types_extra7 covers
# __name__ and __qualname__; types_extra8 covers __module__ in a table with
# descriptor types. Re-anchored here as a standalone in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant types_extra23.BuiltinMethodType.module:
  description: "types.BuiltinMethodType.__module__ == 'builtins' — C-level builtin_function_or_method type"
  category: module_attrs
  kind: python_call_eq
  function: BuiltinMethodType.__module__.__eq__
  args: ["builtins"]
  expected: true
