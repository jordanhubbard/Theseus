spec: crc_32
version: ">=1.0.0"
backend: node(crc-32)

docs: https://github.com/SheetJS/js-crc32#readme

provenance:
  derived_from:
    - "crc-32 README — https://github.com/SheetJS/js-crc32#readme"
    - "Test vectors verified with crc-32@1.2.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "crc-32 source"
  notes:
    - "crc-32 exports an object with str() and buf() methods."
    - "str(s) computes the CRC-32 of a UTF-8 string, returning a signed 32-bit integer."
    - "crc-32 uses the module name 'crc-32', accessed as require('crc-32')."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "str returns signed int32. No errors for valid string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table crc_32.str:
  kind: node_module_call_eq
  function: str
  category: str
  id_prefix: crc32_str

  columns: [id, args, expected]
  rows:
    - [hello,    ["hello"],   907060870]
    - [abc,      ["abc"],     891568578]
    - [empty,    [""],        0]
