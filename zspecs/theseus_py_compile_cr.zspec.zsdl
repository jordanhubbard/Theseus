spec: theseus_py_compile_cr
version: ">=3.8"
backend: python_cleanroom(theseus_py_compile_cr)
blocks: py_compile

docs: https://docs.python.org/3/library/py_compile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/py_compile.html"
  not_derived_from:
    - "CPython source: Lib/py_compile.py"
  notes:
    - "Clean-room py_compile module. Do NOT import py_compile."

error_model: python_exceptions

invariant theseus_py_compile_cr.pycompile2_compile:
  description: "compile() creates a .pyc file from a .py file"
  category: behavior
  kind: python_call_eq
  function: pycompile2_compile
  args: []
  expected: true

invariant theseus_py_compile_cr.pycompile2_error:
  description: "PyCompileError exception class exists"
  category: behavior
  kind: python_call_eq
  function: pycompile2_error
  args: []
  expected: true

invariant theseus_py_compile_cr.pycompile2_syntax_error:
  description: "compile() raises PyCompileError on syntax error"
  category: behavior
  kind: python_call_eq
  function: pycompile2_syntax_error
  args: []
  expected: true
