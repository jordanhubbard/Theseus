spec: locale_extra5
version: ">=3.9"
backend: python_module(locale)

docs: https://docs.python.org/3/library/locale.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/locale.html — Python locale documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/locale.py"
  notes:
    - "This spec extends locale.zspec.zsdl and locale_extra through locale_extra4.zspec.zsdl."
    - "locale.zspec.zsdl covers: LC_ALL/CTYPE/NUMERIC/TIME/COLLATE/MONETARY is_int; setlocale/getlocale/getpreferredencoding/format_string/atoi/atof __name__."
    - "locale_extra covers: Error.__name__/__bases__; func_names table; LC_ALL/COLLATE is_int."
    - "locale_extra2 covers: LC_MESSAGES is_int; LC_CTYPE/NUMERIC/TIME/MONETARY is_int; Error.__module__; normalize passthrough; currency __name__."
    - "locale_extra3 covers: func_modules table (setlocale/getlocale/normalize/format_string/atoi/atof/currency __module__); resetlocale/__module__; getpreferredencoding/__module__."
    - "locale_extra4 covers: __qualname__ checks for module-level functions; Error.__qualname__; CODESET is_int."
    - "This spec adds: __class__.__name__ == 'function' checks for pure-Python locale functions (setlocale, getlocale, normalize, format_string, atoi, atof, currency); Error.__class__.__name__ == 'type'; getdefaultlocale.__class__.__name__; normalize('utf-8') passthrough; normalize('ascii') passthrough."
    - "Python module-level functions defined in pure Python report __class__.__name__ == 'function'."
    - "locale.Error is a class (type), so Error.__class__.__name__ == 'type'."
    - "locale.normalize('utf-8') returns 'utf-8' unchanged — already-canonical lowercase encoding alias."
    - "locale.normalize('ascii') returns 'ascii' unchanged — 'ascii' is the identity locale in the normalize table."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "locale functions raise locale.Error (a subclass of Exception) when an unsupported locale is requested."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# __class__.__name__ == 'function' for pure-Python locale functions
# Not covered in any prior locale spec.
# locale.setlocale, getlocale, normalize, format_string, atoi, atof, currency
# are all defined in pure Python and therefore report __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table locale_extra5.func_class_names:
  kind: python_call_eq
  category: functions
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [setlocale,    "setlocale.__class__.__name__.__eq__",    ["function"], true]
    - [getlocale,    "getlocale.__class__.__name__.__eq__",    ["function"], true]
    - [normalize,    "normalize.__class__.__name__.__eq__",    ["function"], true]
    - [format_string,"format_string.__class__.__name__.__eq__",["function"], true]
    - [atoi,         "atoi.__class__.__name__.__eq__",         ["function"], true]
    - [atof,         "atof.__class__.__name__.__eq__",         ["function"], true]
    - [currency,     "currency.__class__.__name__.__eq__",     ["function"], true]

# ---------------------------------------------------------------------------
# Error.__class__.__name__ — locale.Error is a class (type object)
# Not covered in any prior locale spec; prior specs check __name__ and __bases__.
# ---------------------------------------------------------------------------

invariant locale_extra5.Error.class_is_type:
  description: "locale.Error.__class__.__name__ == 'type' — Error is a class object"
  category: classnames
  kind: python_call_eq
  function: "Error.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# getdefaultlocale.__class__.__name__ — deprecated but present in Python 3.9-3.12
# Not covered in any prior locale spec.
# ---------------------------------------------------------------------------

invariant locale_extra5.getdefaultlocale.class_name:
  description: "locale.getdefaultlocale.__class__.__name__ == 'function' — getdefaultlocale is a pure-Python function"
  category: functions
  kind: python_call_eq
  function: "getdefaultlocale.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# normalize() — additional passthrough vectors
# locale_extra2 covers: normalize('C') and normalize('en_US.UTF-8').
# locale_extra3 covers: normalize('english') returns a str.
# New vectors: 'utf-8' and 'ascii' (both should pass through unchanged).
# ---------------------------------------------------------------------------

invariant locale_extra5.normalize.utf8_passthrough:
  description: "locale.normalize('utf-8') == 'utf-8' — lowercase encoding alias passes through unchanged"
  category: normalize
  kind: python_call_eq
  function: normalize
  args: ["utf-8"]
  expected: "utf-8"

invariant locale_extra5.normalize.ascii_passthrough:
  description: "locale.normalize('ascii') == 'ascii' — 'ascii' is a recognized locale alias that normalizes to itself"
  category: normalize
  kind: python_call_eq
  function: normalize
  args: ["ascii"]
  expected: "ascii"
