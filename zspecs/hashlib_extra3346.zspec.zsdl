spec: hl3346
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (hl3346): __neg__, __pos__, __abs__ dict-presence checks for hashlib types."
    - "Theme: __neg__/__pos__/__abs__ dict-presence (unary operators: -x, +x, abs(x))."
    - "All values False — hash objects do not define unary arithmetic protocol methods in their own __dict__."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __neg__, __pos__, or __abs__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3346.neg:
  description: "hashlib types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3346
  columns: [id, function, args, expected]
  rows:
    - ["hl3346001", operator.contains, [type(hashlib.md5()).__dict__,        "__neg__"], false]
    - ["hl3346002", operator.contains, [type(hashlib.sha1()).__dict__,       "__neg__"], false]
    - ["hl3346003", operator.contains, [type(hashlib.sha256()).__dict__,     "__neg__"], false]
    - ["hl3346004", operator.contains, [type(hashlib.sha512()).__dict__,     "__neg__"], false]
    - ["hl3346005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__neg__"], false]

