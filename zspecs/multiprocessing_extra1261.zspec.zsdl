spec: multiprocessing_extra1261
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.__all__ membership checks via __contains__; __all__ type verification"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 531 (_extra1261): __all__ membership checks — multiprocessing.__all__ is a list; verified Python 3.14.3."
    - "multiprocessing.__all__ contains: Array, AuthenticationError, Barrier, BoundedSemaphore, BufferTooShort, Condition, Event, JoinableQueue, Lock, Manager, Pipe, Pool, Process, ProcessError, Queue, RLock, RawArray, RawValue, Semaphore, SimpleQueue, TimeoutError, Value, active_children, allow_connection_pickling, cpu_count, current_process, freeze_support, get_all_start_methods, get_context, get_logger, get_start_method, log_to_stderr, parent_process, reducer, set_executable, set_forkserver_preload, set_start_method; verified Python 3.14.3."
    - "Thread, Executor, Future, run, sleep, gather, wait, Task are NOT in multiprocessing.__all__; verified Python 3.14.3."
    - "Distinct from prior waves: extra991 (__doc__ class checks), extra976 (__dict__.__contains__), extra946 (__mro__.__len__), extra931 (__bases__/__mro__ lengths)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1261.all_contains_in:
  description: "multiprocessing.__all__.__contains__ returns true for names IN __all__: Process, Queue, Lock, Pool, Manager, Pipe, Event, Semaphore, Barrier, Array, Condition, RLock, Value, SimpleQueue, JoinableQueue, cpu_count, active_children"
  kind: python_call_eq
  category: all_membership
  id_prefix: mp1261in
  columns: [id, function, args, expected]
  rows:
    - [mp1261in001, multiprocessing.__all__.__contains__, ["Process"],        true]
    - [mp1261in002, multiprocessing.__all__.__contains__, ["Queue"],          true]
    - [mp1261in003, multiprocessing.__all__.__contains__, ["Lock"],           true]
    - [mp1261in004, multiprocessing.__all__.__contains__, ["Pool"],           true]
    - [mp1261in005, multiprocessing.__all__.__contains__, ["Manager"],        true]
    - [mp1261in006, multiprocessing.__all__.__contains__, ["Pipe"],           true]
    - [mp1261in007, multiprocessing.__all__.__contains__, ["Event"],          true]
    - [mp1261in008, multiprocessing.__all__.__contains__, ["Semaphore"],      true]
    - [mp1261in009, multiprocessing.__all__.__contains__, ["Barrier"],        true]
    - [mp1261in010, multiprocessing.__all__.__contains__, ["Array"],          true]
    - [mp1261in011, multiprocessing.__all__.__contains__, ["Condition"],      true]
    - [mp1261in012, multiprocessing.__all__.__contains__, ["RLock"],          true]
    - [mp1261in013, multiprocessing.__all__.__contains__, ["Value"],          true]
    - [mp1261in014, multiprocessing.__all__.__contains__, ["SimpleQueue"],    true]
    - [mp1261in015, multiprocessing.__all__.__contains__, ["JoinableQueue"],  true]
    - [mp1261in016, multiprocessing.__all__.__contains__, ["cpu_count"],      true]
    - [mp1261in017, multiprocessing.__all__.__contains__, ["active_children"], true]

table multiprocessing_extra1261.all_contains_not_in:
  description: "multiprocessing.__all__.__contains__ returns false for names NOT in __all__: Thread, Executor, Future, run, sleep, gather, wait, Task"
  kind: python_call_eq
  category: all_membership
  id_prefix: mp1261ni
  columns: [id, function, args, expected]
  rows:
    - [mp1261ni001, multiprocessing.__all__.__contains__, ["Thread"],   false]
    - [mp1261ni002, multiprocessing.__all__.__contains__, ["Executor"], false]
    - [mp1261ni003, multiprocessing.__all__.__contains__, ["Future"],   false]
    - [mp1261ni004, multiprocessing.__all__.__contains__, ["run"],      false]
    - [mp1261ni005, multiprocessing.__all__.__contains__, ["sleep"],    false]
    - [mp1261ni006, multiprocessing.__all__.__contains__, ["gather"],   false]
    - [mp1261ni007, multiprocessing.__all__.__contains__, ["wait"],     false]
    - [mp1261ni008, multiprocessing.__all__.__contains__, ["Task"],     false]

table multiprocessing_extra1261.all_type_is_list:
  description: "multiprocessing.__all__.__class__.__name__ is 'list'; cross-checks against 'tuple', 'set', 'dict', 'str', 'int'"
  kind: python_call_eq
  category: all_type
  id_prefix: mp1261ty
  columns: [id, function, args, expected]
  rows:
    - [mp1261ty001, multiprocessing.__all__.__class__.__name__.__eq__, ["list"],  true]
    - [mp1261ty002, multiprocessing.__all__.__class__.__name__.__eq__, ["tuple"], false]
    - [mp1261ty003, multiprocessing.__all__.__class__.__name__.__eq__, ["set"],   false]
    - [mp1261ty004, multiprocessing.__all__.__class__.__name__.__eq__, ["dict"],  false]
    - [mp1261ty005, multiprocessing.__all__.__class__.__name__.__eq__, ["str"],   false]
    - [mp1261ty006, multiprocessing.__all__.__class__.__name__.__eq__, ["int"],   false]
