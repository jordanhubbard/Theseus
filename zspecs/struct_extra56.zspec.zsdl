spec: struct_extra56
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra55.zspec.zsdl — covers struct.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "struct_extra54.zspec.zsdl — covers struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format.__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra39.zspec.zsdl — covers Struct.__mro__[1]/__name__.__eq__('object'); Struct.size.__qualname__.__eq__('Struct.size') and Struct.size.__qualname__.__len__()==11."
    - "struct_extra28.zspec.zsdl — covers Struct.__init_subclass__.__qualname__.__len__()==24 and error.__init_subclass__.__qualname__.__len__()==23 (length axis only; does NOT check __qualname__.__eq__ string values)."
    - "struct_extra23.zspec.zsdl — covers Struct.__new__/__sizeof__ __qualname__.__eq__."
    - "struct_extra21.zspec.zsdl — covers Struct.__init__/__repr__ __qualname__.__eq__ and __qualname__.__len__()."
    - "struct_extra9.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__ and __name__.__eq__."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra55; it does NOT duplicate invariants present in those files."
    - "Wave 227 theme: Class method __qualname__ string equality checks for methods not yet covered."
    - "struct.Struct is a C extension type. Its method descriptors use 'Struct.' as the class prefix in __qualname__. struct_extra9 covers pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__. struct_extra21 covers __init__/__repr__ __qualname__.__eq__. struct_extra23 covers __new__/__sizeof__ __qualname__.__eq__. struct_extra28 covers __init_subclass__.__qualname__.__len__()==24 (length only, NOT __eq__). No prior struct spec checks __qualname__.__eq__ for __init_subclass__, __subclasshook__, __getattribute__, __delattr__, or __setattr__. All five are defined directly on the Struct C type (qualname prefix 'Struct.'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Struct.__init_subclass__.__qualname__ == 'Struct.__init_subclass__' (len 24). struct_extra28 covers the length (24); no prior spec checks the string value via __qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Struct.__subclasshook__.__qualname__ == 'Struct.__subclasshook__' (len 23). No prior struct spec checks Struct.__subclasshook__.__qualname__ in any form (__eq__ or __len__). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Struct.__getattribute__.__qualname__ == 'Struct.__getattribute__' (len 23). The Struct C type defines __getattribute__ directly. No prior struct spec checks Struct.__getattribute__.__qualname__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Struct.__delattr__.__qualname__ == 'Struct.__delattr__' (len 18). The Struct C type defines __delattr__ directly. No prior struct spec checks Struct.__delattr__.__qualname__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Struct.__setattr__.__qualname__ == 'Struct.__setattr__' (len 18). The Struct C type defines __setattr__ directly. No prior struct spec checks Struct.__setattr__.__qualname__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct dunder method __qualname__.__eq__ string values — novel
#
# Wave 227 theme: Class method __qualname__ string equality checks for methods
# not yet covered.
#
# Prior coverage:
#   struct_extra9:  pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__
#   struct_extra21: __init__/__repr__ __qualname__.__eq__
#   struct_extra23: __new__/__sizeof__ __qualname__.__eq__
#   struct_extra28: __init_subclass__.__qualname__.__len__()==24 (length only)
#
# Novel: __init_subclass__, __subclasshook__, __getattribute__, __delattr__,
#        __setattr__ — all defined directly on the Struct C type.
#        For __init_subclass__ specifically, extra28 established the length (24)
#        but the string equality axis is entirely new.
# ---------------------------------------------------------------------------

table struct_extra56.Struct_novel_dunder_qualname_eq:
  description: "struct.Struct.__init_subclass__/__subclasshook__/__getattribute__/__delattr__/__setattr__ __qualname__.__eq__ string values — all defined directly on Struct C type with 'Struct.' prefix; struct_extra9/extra21/extra23 cover pack/unpack/init/repr/new/sizeof; struct_extra28 covers __init_subclass__ __len__ only; no prior struct spec checks __qualname__.__eq__ for any of these five methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: structqual56

  columns: [id, function, args, expected]
  rows:
    - [init_subclass_qualname_eq, "Struct.__init_subclass__.__qualname__.__eq__", ["Struct.__init_subclass__"], true]
    - [subclasshook_qualname_eq,  "Struct.__subclasshook__.__qualname__.__eq__",  ["Struct.__subclasshook__"],  true]
    - [getattribute_qualname_eq,  "Struct.__getattribute__.__qualname__.__eq__",  ["Struct.__getattribute__"],  true]
    - [delattr_qualname_eq,       "Struct.__delattr__.__qualname__.__eq__",        ["Struct.__delattr__"],       true]
    - [setattr_qualname_eq,       "Struct.__setattr__.__qualname__.__eq__",        ["Struct.__setattr__"],       true]

# ---------------------------------------------------------------------------
# Struct.__init_subclass__.__qualname__.__eq__('Struct.__init_subclass__') — standalone
#
# struct_extra28 covers Struct.__init_subclass__.__qualname__.__len__()==24
# (the length axis). The complementary string equality axis — the exact string
# value 'Struct.__init_subclass__' — is not checked by any prior struct spec.
# This invariant anchors the primary string equality for __init_subclass__,
# confirming the exact qualname string beyond just its character count.
# ---------------------------------------------------------------------------

invariant struct_extra56.Struct_init_subclass_qualname_str:
  description: "struct.Struct.__init_subclass__.__qualname__.__eq__('Struct.__init_subclass__') == True — C extension type method_descriptor; struct_extra28 covers __qualname__.__len__()==24 (length axis only); no prior struct spec checks __init_subclass__.__qualname__.__eq__ string value; primary string equality anchor complementing extra28's length check"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.__init_subclass__.__qualname__.__eq__"
  args: ["Struct.__init_subclass__"]
  expected: true

# ---------------------------------------------------------------------------
# Struct.__subclasshook__.__qualname__.__eq__('Struct.__subclasshook__') — standalone
#
# No prior struct spec checks Struct.__subclasshook__.__qualname__ in any form
# (__eq__ or __len__). The Struct C type defines __subclasshook__ directly;
# its qualname is 'Struct.__subclasshook__' (23 chars). This is the first
# qualname check for this method on the Struct type.
# ---------------------------------------------------------------------------

invariant struct_extra56.Struct_subclasshook_qualname_str:
  description: "struct.Struct.__subclasshook__.__qualname__.__eq__('Struct.__subclasshook__') == True — C extension type method_descriptor; no prior struct spec checks Struct.__subclasshook__.__qualname__ in any form; first qualname anchor for __subclasshook__ on Struct"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.__subclasshook__.__qualname__.__eq__"
  args: ["Struct.__subclasshook__"]
  expected: true
