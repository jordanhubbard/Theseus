spec: pickle_extra21
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra20.zspec.zsdl."
    - "pickle_extra20 covers: Pickler/__bases__[0]/__name__; Unpickler/__bases__[0]/__name__; five-class __bases__[0]/__qualname__; dump/__module__/__class__/__name__; loads/__module__/__class__/__name__ (type axes)."
    - "pickle_extra18 covers: Pickler/__init__/__qualname__; Unpickler/__init__/__qualname__."
    - "pickle_extra14 covers: dumps/__qualname__; loads/__qualname__; load/__qualname__; dump/__qualname__."
    - "pickle_extra4 covers: dump/__name__; load/__name__."
    - "pickle_extra covers: HIGHEST_PROTOCOL/__class__/__name__; DEFAULT_PROTOCOL/__class__/__name__."
    - "Focus: __name__ for Pickler.__init__ and Unpickler.__init__; type axes (__class__.__name__) for Pickler/__init__/__name__ and Unpickler/__init__/__name__; __class__.__qualname__ and __class__.__module__ for DEFAULT_PROTOCOL and HIGHEST_PROTOCOL."
    - "No prior pickle spec checks Pickler.__init__.__name__."
    - "No prior pickle spec checks Unpickler.__init__.__name__."
    - "No prior pickle spec checks Pickler.__init__.__name__.__class__.__name__ (type axis)."
    - "No prior pickle spec checks Unpickler.__init__.__name__.__class__.__name__ (type axis)."
    - "No prior pickle spec checks DEFAULT_PROTOCOL.__class__.__qualname__."
    - "No prior pickle spec checks HIGHEST_PROTOCOL.__class__.__qualname__."
    - "No prior pickle spec checks DEFAULT_PROTOCOL.__class__.__module__."
    - "No prior pickle spec checks HIGHEST_PROTOCOL.__class__.__module__."
    - "pickle.Pickler.__init__.__name__ == '__init__' — wrapper_descriptor __name__ is always the bare dunder string."
    - "pickle.Unpickler.__init__.__name__ == '__init__' — wrapper_descriptor __name__ is always the bare dunder string."
    - "pickle.Pickler.__init__.__name__.__class__.__name__ == 'str' — __name__ attribute is a plain string."
    - "pickle.Unpickler.__init__.__name__.__class__.__name__ == 'str' — __name__ attribute is a plain string."
    - "pickle.DEFAULT_PROTOCOL.__class__.__qualname__ == 'int' — for top-level built-in types, qualname equals name."
    - "pickle.HIGHEST_PROTOCOL.__class__.__qualname__ == 'int' — for top-level built-in types, qualname equals name."
    - "pickle.DEFAULT_PROTOCOL.__class__.__module__ == 'builtins' — the int type is defined in the builtins module."
    - "pickle.HIGHEST_PROTOCOL.__class__.__module__ == 'builtins' — the int type is defined in the builtins module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler.__init__ and Unpickler.__init__ — __name__
#
# pickle_extra18 checks __qualname__ for Pickler.__init__ and Unpickler.__init__.
# No prior pickle spec checks the bare __name__ of either dunder method.
# Both are C wrapper_descriptor objects; their __name__ is the plain identifier
# '__init__' without any class prefix.
# ---------------------------------------------------------------------------

invariant pickle_extra21.Pickler.__init__.name:
  description: "pickle.Pickler.__init__.__name__ == '__init__' — bare method name without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: Pickler.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant pickle_extra21.Unpickler.__init__.name:
  description: "pickle.Unpickler.__init__.__name__ == '__init__' — bare method name without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: Unpickler.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Type axis: __name__ of Pickler.__init__ and Unpickler.__init__
#
# Verifies that the __name__ attribute on each wrapper_descriptor is itself a
# plain str instance.  No prior pickle spec checks this type axis.
# ---------------------------------------------------------------------------

invariant pickle_extra21.Pickler.__init__.name.class_name:
  description: "pickle.Pickler.__init__.__name__.__class__.__name__ == 'str' — __name__ is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: Pickler.__init__.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pickle_extra21.Unpickler.__init__.name.class_name:
  description: "pickle.Unpickler.__init__.__name__.__class__.__name__ == 'str' — __name__ is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: Unpickler.__init__.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_PROTOCOL and HIGHEST_PROTOCOL — __class__.__qualname__ and __class__.__module__
#
# pickle_extra and pickle_extra10 check __class__.__name__ == 'int' for both
# constants.  pickle_extra19 checks __qualname__.__class__.__name__ (type axis)
# for the PickleError family.  No prior pickle spec checks __class__.__qualname__
# or __class__.__module__ for DEFAULT_PROTOCOL or HIGHEST_PROTOCOL.
# Both constants are plain int instances.  The int type's __qualname__ is 'int'
# (same as its __name__) and its __module__ is 'builtins'.
# ---------------------------------------------------------------------------

invariant pickle_extra21.DEFAULT_PROTOCOL.class_qualname:
  description: "pickle.DEFAULT_PROTOCOL.__class__.__qualname__ == 'int' — built-in type qualname equals name"
  category: constant_types
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

invariant pickle_extra21.HIGHEST_PROTOCOL.class_qualname:
  description: "pickle.HIGHEST_PROTOCOL.__class__.__qualname__ == 'int' — built-in type qualname equals name"
  category: constant_types
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

invariant pickle_extra21.DEFAULT_PROTOCOL.class_module:
  description: "pickle.DEFAULT_PROTOCOL.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant pickle_extra21.HIGHEST_PROTOCOL.class_module:
  description: "pickle.HIGHEST_PROTOCOL.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all eight new invariants
#
# All eight are first covered in this spec (pickle_extra21).
# ---------------------------------------------------------------------------

table pickle_extra21.init_names_and_protocol_type_axes:
  description: "pickle Pickler/Unpickler __init__.__name__, type axes, DEFAULT/HIGHEST_PROTOCOL __class__ qualname/module"
  kind: python_call_eq
  category: method_attrs
  id_prefix: pfa21

  columns: [id, function, args, expected]
  rows:
    - [Pickler_init_name,         Pickler.__init__.__name__.__eq__,                   ["__init__"],  true]
    - [Unpickler_init_name,       Unpickler.__init__.__name__.__eq__,                 ["__init__"],  true]
    - [Pickler_init_name_type,    Pickler.__init__.__name__.__class__.__name__.__eq__, ["str"],       true]
    - [Unpickler_init_name_type,  Unpickler.__init__.__name__.__class__.__name__.__eq__, ["str"],     true]
    - [DEFAULT_PROTO_class_qn,    DEFAULT_PROTOCOL.__class__.__qualname__.__eq__,     ["int"],       true]
    - [HIGHEST_PROTO_class_qn,    HIGHEST_PROTOCOL.__class__.__qualname__.__eq__,     ["int"],       true]
    - [DEFAULT_PROTO_class_mod,   DEFAULT_PROTOCOL.__class__.__module__.__eq__,       ["builtins"],  true]
    - [HIGHEST_PROTO_class_mod,   HIGHEST_PROTOCOL.__class__.__module__.__eq__,       ["builtins"],  true]
