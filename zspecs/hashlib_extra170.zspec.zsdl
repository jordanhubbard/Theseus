spec: hashlib_extra170
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra169.zspec.zsdl — covers hashlib.algorithms_guaranteed.__contains__ for sha256/sha512/md5/sha1/sha3_256/blake2b/sha224/shake_256/sha3_512 and algorithms_guaranteed/__available __len__()==14/19 (table + invariants)."
    - "hashlib_extra168.zspec.zsdl — covers hashlib.sha256/__md5/__sha512 .__name__ (openssl_ prefix) and .__module__ ('_hashlib'); algorithms_available/__guaranteed .__class__.__name__=='set'; module lengths (table + invariants)."
    - "hashlib_extra167.zspec.zsdl — covers hashlib.__spec__ attributes (table + invariants)."
    - "hashlib_extra165.zspec.zsdl — covers hashlib.sha256.__class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib_extra164.zspec.zsdl — covers hashlib.algorithms_available and algorithms_guaranteed membership and lengths (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra169."
    - "Wave 349 theme: hashlib constructor __name__ and __module__ for six additional algorithms — sha1, sha224, sha384, blake2b, blake2s, sha3_256. On macOS/Darwin with OpenSSL-backed CPython: sha1.__name__=='openssl_sha1'(12 chars)/__module__=='_hashlib'; sha224.__name__=='openssl_sha224'(14 chars)/__module__=='_hashlib'; sha384.__name__=='openssl_sha384'(14 chars)/__module__=='_hashlib'; sha3_256.__name__=='openssl_sha3_256'(16 chars)/__module__=='_hashlib'. Blake2 variants come from a different C extension: blake2b.__name__=='blake2b'(7 chars)/__module__=='_blake2'; blake2s.__name__=='blake2s'(7 chars)/__module__=='_blake2'. hashlib_extra168 anchors sha256/md5/sha512 __name__ and __module__; this spec anchors the six additional algorithms as the primary novel content."
    - "hashlib.sha1.__name__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__name__ == 'openssl_sha224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__name__ == 'openssl_sha384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.sha1.__name__ == 'openssl_sha1' (12 chars = 'openssl_'=8 + 'sha1'=4). sha1's OpenSSL name is shorter than sha256/sha512/sha224/sha384 (all 14 chars) because 'sha1'=4 chars vs 'sha256'/'sha512'/'sha224'/'sha384'=6 chars each. 'openssl_sha1'(12) < 'openssl_sha224'/'openssl_sha384'(14) by 2 chars. SHA-1 produces a 160-bit (20-byte) digest."
    - "Note: hashlib.sha224.__name__ == 'openssl_sha224' (14 chars = 'openssl_'=8 + 'sha224'=6). Same 14-char length as sha256 and sha512 because 'sha224'=6 chars. sha224 and sha256 share the same __name__ length. SHA-224 is a truncated variant of SHA-256 producing a 224-bit digest."
    - "Note: hashlib.sha384.__name__ == 'openssl_sha384' (14 chars = 'openssl_'=8 + 'sha384'=6). Same 14-char length as sha256/sha512/sha224. SHA-384 is a truncated variant of SHA-512 producing a 384-bit digest."
    - "Note: hashlib.blake2b.__name__ == 'blake2b' (7 chars) and __module__ == '_blake2' (7 chars). BLAKE2 constructors are NOT OpenSSL-backed — they come from the _blake2 C extension (Modules/_blake2/). blake2b.__name__ is just 'blake2b' (no 'openssl_' prefix, unlike SHA constructors). '_blake2'(7 chars) is a different C extension from '_hashlib'(8 chars)."
    - "Note: hashlib.sha3_256.__name__ == 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8). This is the longest OpenSSL constructor name in this spec. 'sha3_256'(8 chars) > 'sha256'(6 chars) by 2 chars — the '3_' infix. 'openssl_sha3_256'(16) > 'openssl_sha256'(14) by 2 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha1.__name__.__eq__('openssl_sha1')
# hashlib.sha1.__module__.__eq__('_hashlib')
# hashlib.sha224.__name__.__eq__('openssl_sha224')
# hashlib.sha224.__module__.__eq__('_hashlib')
#
# Wave 349 theme: sha1 and sha224 constructor __name__ and __module__ identity.
#
# sha1.__name__ == 'openssl_sha1' (12 chars; 'openssl_'=8 + 'sha1'=4).
# sha1.__module__ == '_hashlib' (8 chars; same C extension as sha256/md5/sha512).
# sha224.__name__ == 'openssl_sha224' (14 chars; 'openssl_'=8 + 'sha224'=6).
# sha224.__module__ == '_hashlib' (8 chars; same C extension).
# hashlib_extra168 anchors sha256/md5/sha512 __name__ and __module__; no prior spec anchors
# sha1 or sha224 constructor __name__ as a table under hashlibctor170.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra170.sha1_sha224_name_and_module:
  description: "hashlib.sha1.__name__.__eq__('openssl_sha1')==True / sha1.__module__.__eq__('_hashlib')==True / sha224.__name__.__eq__('openssl_sha224')==True / sha224.__module__.__eq__('_hashlib')==True — sha1.__name__ is 'openssl_sha1' (12 chars = 'openssl_'=8 + 'sha1'=4; the SHA-1 hash constructor on OpenSSL-backed CPython has the 'openssl_' prefix in its __name__; 'sha1'=4 chars is shorter than 'sha256'/'sha512'/'sha224'/'sha384'=6 chars each; therefore 'openssl_sha1'(12) < 'openssl_sha256'/'openssl_sha512'/'openssl_sha224'/'openssl_sha384'(14) by 2 chars; SHA-1 produces a 160-bit (20-byte) digest; hashlib_extra168 anchors sha256.__name__=='openssl_sha256'(14) and md5.__name__=='openssl_md5'(11)); sha1.__module__ is '_hashlib' (8 chars; same private C extension as sha256/md5/sha512; all OpenSSL-backed constructors share __module__=='_hashlib'); sha224.__name__ is 'openssl_sha224' (14 chars = 'openssl_'=8 + 'sha224'=6; 'sha224'=6 chars; same 14-char length as sha256.__name__=='openssl_sha256'(14) and sha512.__name__=='openssl_sha512'(14); SHA-224 is a truncated SHA-256 variant producing 224-bit digest); sha224.__module__ is '_hashlib' (8 chars; same C extension as sha256/md5/sha512/sha1; first hashlibctor170 anchor for sha1 and sha224 __name__ and __module__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor170

  columns: [id, function, args, expected, description]
  rows:
    - [sha1_name_openssl,   "sha1.__name__.__eq__",   ["openssl_sha1"],   true, "hashlib.sha1.__name__ == 'openssl_sha1' (12 chars = 'openssl_'=8 + 'sha1'=4; shorter than sha256/sha512=14 by 2; SHA-1; 160-bit digest)"]
    - [sha1_module_hashlib, "sha1.__module__.__eq__", ["_hashlib"],        true, "hashlib.sha1.__module__ == '_hashlib' (8 chars; private C extension; same as sha256/md5/sha512)"]
    - [sha224_name_openssl, "sha224.__name__.__eq__", ["openssl_sha224"],  true, "hashlib.sha224.__name__ == 'openssl_sha224' (14 chars = 'openssl_'=8 + 'sha224'=6; same length as sha256/sha512=14; SHA-224; 224-bit truncated SHA-256)"]
    - [sha224_module_hashlib, "sha224.__module__.__eq__", ["_hashlib"],    true, "hashlib.sha224.__module__ == '_hashlib' (8 chars; same C extension as sha1/sha256/md5/sha512)"]

# ---------------------------------------------------------------------------
# hashlib.sha384.__name__.__eq__('openssl_sha384')
# hashlib.sha384.__module__.__eq__('_hashlib')
# hashlib.sha1.__name__.__len__()==12
# hashlib.sha384.__name__.__len__()==14
#
# Wave 349 theme: sha384 identity and sha1/sha384 name lengths.
#
# sha384.__name__ == 'openssl_sha384' (14 chars; 'openssl_'=8 + 'sha384'=6).
# sha384.__module__ == '_hashlib' (8 chars; same C extension).
# sha1.__name__.__len__() == 12 ('openssl_sha1' = 12 chars).
# sha384.__name__.__len__() == 14 ('openssl_sha384' = 14 chars).
# No prior hashlib spec anchors sha384.__name__ as a table under hashlibctor170.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra170.sha384_name_module_and_lengths:
  description: "hashlib.sha384.__name__.__eq__('openssl_sha384')==True / sha384.__module__.__eq__('_hashlib')==True / sha1.__name__.__len__()==12 / sha384.__name__.__len__()==14 — sha384.__name__ is 'openssl_sha384' (14 chars = 'openssl_'=8 + 'sha384'=6; 'sha384'=6 chars same as 'sha256'/'sha512'/'sha224'; SHA-384 is a truncated SHA-512 variant producing 384-bit (48-byte) digest; 'openssl_sha384'(14) == 'openssl_sha256'(14) == 'openssl_sha512'(14) == 'openssl_sha224'(14) in length — all 14 chars; sha384.__name__(14) > sha1.__name__(12) by 2 chars because 'sha384'(6) > 'sha1'(4) by 2); sha384.__module__ is '_hashlib' (8 chars; same private C extension as sha1/sha224/sha256/md5/sha512; all OpenSSL-backed constructors share __module__=='_hashlib'(8 chars)); sha1.__name__.__len__() is 12 ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12 chars; shortest OpenSSL name in this spec because 'sha1'=4 chars is the shortest suffix; sha1(12) < sha224/sha256/sha512/sha384(14) by 2); sha384.__name__.__len__() is 14 ('openssl_sha384' = 'openssl_'=8 + 'sha384'=6 = 14; same length as sha224/sha256/sha512(14); 14 > 12 by 2; first hashlibctor170 anchor for sha384 __name__ and __module__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor170

  columns: [id, function, args, expected, description]
  rows:
    - [sha384_name_openssl,   "sha384.__name__.__eq__",   ["openssl_sha384"], true, "hashlib.sha384.__name__ == 'openssl_sha384' (14 chars = 'openssl_'=8 + 'sha384'=6; SHA-384; 384-bit truncated SHA-512; same length as sha224/sha256/sha512=14)"]
    - [sha384_module_hashlib, "sha384.__module__.__eq__", ["_hashlib"],        true, "hashlib.sha384.__module__ == '_hashlib' (8 chars; private C extension; same as sha1/sha224/sha256/md5/sha512)"]
    - [sha1_name_len_12,      "sha1.__name__.__len__",    [],                  12,  "hashlib.sha1.__name__.__len__() is 12 ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12; shortest OpenSSL name in this spec; 12 < 14 by 2)"]
    - [sha384_name_len_14,    "sha384.__name__.__len__",  [],                  14,  "hashlib.sha384.__name__.__len__() is 14 ('openssl_sha384' = 'openssl_'=8 + 'sha384'=6 = 14; same length as sha224/sha256/sha512=14)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b')
# hashlib.blake2b.__module__.__eq__('_blake2')
# hashlib.blake2s.__name__.__eq__('blake2s')
# hashlib.blake2s.__module__.__eq__('_blake2')
#
# Wave 349 theme: blake2b and blake2s constructor identity.
#
# blake2b.__name__ == 'blake2b' (7 chars; NO 'openssl_' prefix; from _blake2 extension).
# blake2b.__module__ == '_blake2' (7 chars; different C extension from _hashlib).
# blake2s.__name__ == 'blake2s' (7 chars; same length as blake2b.__name__).
# blake2s.__module__ == '_blake2' (7 chars; same C extension as blake2b).
# No prior hashlib spec anchors blake2b.__name__ or blake2s.__name__ as a table under
# hashlibctor170. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra170.blake2b_blake2s_name_and_module:
  description: "hashlib.blake2b.__name__.__eq__('blake2b')==True / blake2b.__module__.__eq__('_blake2')==True / blake2s.__name__.__eq__('blake2s')==True / blake2s.__module__.__eq__('_blake2')==True — blake2b.__name__ is 'blake2b' (7 chars = 'blake2'=6 + 'b'=1; BLAKE2 constructors do NOT carry the 'openssl_' prefix in their __name__ unlike SHA constructors; blake2b is implemented in the _blake2 C extension (Modules/_blake2/) not the _hashlib OpenSSL extension; 'blake2b'(7) is the bare name with no prefix; BLAKE2b produces up to 512-bit (64-byte) digest and is fast in software); blake2b.__module__ is '_blake2' (7 chars = '_'=1 + 'blake2'=6; private C extension for BLAKE2 algorithms; leading underscore marks private; '_blake2'(7) has the same length as 'blake2b'(7) and 'blake2s'(7); crucially different from '_hashlib'(8) which backs SHA constructors — blake2 uses a separate extension); blake2s.__name__ is 'blake2s' (7 chars = 'blake2'=6 + 's'=1; BLAKE2s constructor; same 7-char length as blake2b.__name__=='blake2b'(7); BLAKE2s produces up to 256-bit (32-byte) digest and is optimized for small platforms; 'b' vs 's' suffix: 'b' = big (for 64-bit platforms), 's' = small (for 32-bit platforms and small inputs)); blake2s.__module__ is '_blake2' (7 chars; same C extension as blake2b; first hashlibctor170 anchor for blake2b and blake2s __name__ and __module__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor170

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name,         "blake2b.__name__.__eq__",   ["blake2b"],  true, "hashlib.blake2b.__name__ == 'blake2b' (7 chars; no 'openssl_' prefix; from _blake2 C extension not _hashlib; BLAKE2b; up to 512-bit digest)"]
    - [blake2b_module,       "blake2b.__module__.__eq__", ["_blake2"],  true, "hashlib.blake2b.__module__ == '_blake2' (7 chars; separate C extension from _hashlib(8); '_blake2'(7)==len('blake2b')==len('blake2s')==7)"]
    - [blake2s_name,         "blake2s.__name__.__eq__",   ["blake2s"],  true, "hashlib.blake2s.__name__ == 'blake2s' (7 chars; same length as blake2b=7; no 'openssl_' prefix; BLAKE2s; up to 256-bit digest; 's'=small/32-bit)"]
    - [blake2s_module,       "blake2s.__module__.__eq__", ["_blake2"],  true, "hashlib.blake2s.__module__ == '_blake2' (7 chars; same C extension as blake2b; both BLAKE2 constructors come from _blake2 not _hashlib)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')
# hashlib.sha3_256.__module__.__eq__('_hashlib')
# hashlib.sha3_256.__name__.__len__()==16
# hashlib.blake2b.__name__.__len__()==7
#
# Wave 349 theme: sha3_256 identity and name length comparison.
#
# sha3_256.__name__ == 'openssl_sha3_256' (16 chars; longest OpenSSL name in this spec).
# sha3_256.__module__ == '_hashlib' (8 chars; same C extension as other SHA constructors).
# sha3_256.__name__.__len__() == 16 ('openssl_sha3_256' = 16 chars).
# blake2b.__name__.__len__() == 7 ('blake2b' = 7 chars; shortest in this spec).
# No prior hashlib spec anchors sha3_256.__name__ as a table under hashlibctor170.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra170.sha3_256_name_module_and_lengths:
  description: "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')==True / sha3_256.__module__.__eq__('_hashlib')==True / sha3_256.__name__.__len__()==16 / blake2b.__name__.__len__()==7 — sha3_256.__name__ is 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8; the SHA3-256 constructor on OpenSSL-backed CPython has the 'openssl_' prefix; 'sha3_256'=8 chars (the algorithm suffix) is longer than 'sha256'=6 chars by 2 chars due to the '3_' infix; therefore 'openssl_sha3_256'(16) > 'openssl_sha256'(14) by 2 chars; sha3_256.__name__(16) is the longest constructor name in this spec: blake2b/blake2s(7) < sha1(12) < sha224/sha384/sha256/sha512(14) < sha3_256(16)); sha3_256.__module__ is '_hashlib' (8 chars; same private C extension as sha1/sha224/sha384/sha256/md5/sha512; on this platform OpenSSL provides SHA-3 via the hashlib module); sha3_256.__name__.__len__() is 16 ('openssl_sha3_256' = 16 chars; longest name among all hashlib constructors examined in this spec; 16 > 14 by 2; 16 > 12 by 4; 16 > 7 by 9); blake2b.__name__.__len__() is 7 ('blake2b' = 7 chars; shortest in this spec; no 'openssl_' prefix; from _blake2; 7 < 12 < 14 < 16 in length ordering; first hashlibctor170 anchor for sha3_256 __name__ and __module__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor170

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name_openssl,   "sha3_256.__name__.__eq__",   ["openssl_sha3_256"], true, "hashlib.sha3_256.__name__ == 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8; longest OpenSSL constructor name; 16 > sha224/sha384/sha256/sha512=14 by 2)"]
    - [sha3_256_module_hashlib, "sha3_256.__module__.__eq__", ["_hashlib"],          true, "hashlib.sha3_256.__module__ == '_hashlib' (8 chars; same C extension as sha1/sha224/sha384/sha256; OpenSSL provides SHA-3)"]
    - [sha3_256_name_len_16,    "sha3_256.__name__.__len__",  [],                    16,  "hashlib.sha3_256.__name__.__len__() is 16 ('openssl_sha3_256' = 16 chars; longest in this spec; length ordering: blake2b/blake2s(7) < sha1(12) < sha224/sha384/sha256/sha512(14) < sha3_256(16))"]
    - [blake2b_name_len_7,      "blake2b.__name__.__len__",   [],                    7,   "hashlib.blake2b.__name__.__len__() is 7 ('blake2b' = 7 chars; shortest in this spec; no 'openssl_' prefix; from _blake2 C extension)"]

# ---------------------------------------------------------------------------
# hashlib.sha1.__name__.__eq__('openssl_sha1') — standalone
#
# hashlib.sha1.__name__ is 'openssl_sha1' (12 chars = 'openssl_'=8 + 'sha1'=4). On OpenSSL-
# backed CPython, the SHA-1 hash constructor has the 'openssl_' prefix in its __name__.
# 'sha1' (4 chars) is shorter than 'sha224'/'sha256'/'sha384'/'sha512' (all 6 chars), so
# 'openssl_sha1' (12 chars) is shorter than 'openssl_sha224'/'openssl_sha384' etc. (all 14 chars).
# hashlib_extra168 anchors sha256.__name__=='openssl_sha256'(14) and md5.__name__=='openssl_md5'(11)
# as standalones; no prior hashlib spec anchors sha1.__name__ as a standalone under hashlibctor170.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra170.sha1_name_openssl_sha1:
  description: "hashlib.sha1.__name__.__eq__('openssl_sha1') == True — 'openssl_sha1' (12 chars = 'openssl_'=8 + 'sha1'=4); SHA-1 constructor on OpenSSL-backed CPython; 'sha1'=4 chars is shorter than 'sha256'/'sha512'/'sha224'/'sha384'=6 chars each; openssl_sha1(12) < openssl_sha224/sha384/sha256/sha512(14) by 2 chars; sha1.__module__=='_hashlib'(8 chars; same C extension as sha256/md5/sha512); sha1 produces 160-bit (20-byte) digest; considered cryptographically weak since SHAttered collision (2017); algorithms_guaranteed.__contains__('sha1')==True (guaranteed for backward compatibility); first hashlibctor170 standalone for sha1.__name__"
  category: identity
  kind: python_call_eq
  function: sha1.__name__.__eq__
  args: ["openssl_sha1"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha1.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha1.__module__ is '_hashlib' (8 chars). sha1 comes from the same _hashlib C
# extension as sha256, md5, sha512, sha224, sha384, and sha3_256. All six OpenSSL-backed
# hash constructors share __module__ == '_hashlib'. blake2b and blake2s differ, having
# __module__ == '_blake2' (7 chars) instead. '_hashlib'(8) > '_blake2'(7) by 1 char.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra170.sha1_module_hashlib:
  description: "hashlib.sha1.__module__.__eq__('_hashlib') == True — '_hashlib' (8 chars = '_'=1 + 'hashlib'=7); private C extension module (Modules/_hashlib.c); sha1 shares __module__=='_hashlib' with sha224/sha384/sha256/md5/sha512/sha3_256 (all OpenSSL-backed); blake2b/blake2s differ: __module__=='_blake2'(7 chars) — '_blake2'(7) < '_hashlib'(8) by 1 char; sha1.__name__=='openssl_sha1'(12 chars); first hashlibctor170 standalone for sha1.__module__"
  category: identity
  kind: python_call_eq
  function: sha1.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.__name__ is 'blake2b' (7 chars). BLAKE2b does NOT carry the 'openssl_'
# prefix because it is not from the OpenSSL library — BLAKE2 is implemented in a separate
# C extension (_blake2, from Modules/_blake2/). blake2b.__name__ is the bare algorithm name
# 'blake2b'. This contrasts with sha1.__name__=='openssl_sha1', sha256.__name__=='openssl_sha256',
# etc. 'blake2b' (7 chars) is the same length as 'blake2s' and '_blake2'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra170.blake2b_name_blake2b:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — 'blake2b' (7 chars = 'blake2'=6 + 'b'=1; NO 'openssl_' prefix — BLAKE2b is from the _blake2 C extension, not OpenSSL; blake2b.__module__=='_blake2'(7 chars); BLAKE2b is a fast cryptographic hash designed by Jean-Philippe Aumasson et al.; produces up to 512-bit (64-byte) digest; optimized for 64-bit platforms ('b'=big); contrasts with sha1.__name__=='openssl_sha1'(12) and sha256.__name__=='openssl_sha256'(14) which carry the 'openssl_' prefix; 'blake2b'(7) < 'openssl_sha1'(12) < 'openssl_sha224'(14) < 'openssl_sha3_256'(16) in length; first hashlibctor170 standalone for blake2b.__name__"
  category: identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2') — standalone
#
# hashlib.blake2b.__module__ is '_blake2' (7 chars). The BLAKE2 C extension (_blake2) is
# separate from the OpenSSL-backed _hashlib extension. '_blake2' (7 chars) = '_'=1 + 'blake2'=6.
# Both blake2b and blake2s share __module__ == '_blake2'. This is 1 char shorter than
# '_hashlib' (8 chars) which backs SHA and MD5 constructors. '_blake2' (7 chars) ==
# 'blake2b'(7 chars) == 'blake2s'(7 chars) in length — a three-way tie.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra170.blake2b_module_blake2:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — '_blake2' (7 chars = '_'=1 + 'blake2'=6; private C extension for BLAKE2 algorithms; Modules/_blake2/); separate from '_hashlib'(8 chars) which backs SHA/MD5; '_blake2'(7) < '_hashlib'(8) by 1 char; '_blake2'(7) == 'blake2b'(7) == 'blake2s'(7) in length — three-way tie; blake2s.__module__=='_blake2' too (both BLAKE2 constructors from same extension); first hashlibctor170 standalone for blake2b.__module__"
  category: identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__name__.__eq__('blake2s') — standalone
#
# hashlib.blake2s.__name__ is 'blake2s' (7 chars). BLAKE2s is the small variant of BLAKE2,
# optimized for 32-bit platforms and small messages. 'blake2s' (7 chars) = 'blake2'=6 + 's'=1.
# blake2s.__name__ (7 chars) is identical in length to blake2b.__name__ (7 chars). The only
# difference is the final letter: 'b' (big/64-bit) vs 's' (small/32-bit). BLAKE2s produces
# up to 256-bit (32-byte) digests (same bit-width as SHA-256, but different algorithm).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra170.blake2s_name_blake2s:
  description: "hashlib.blake2s.__name__.__eq__('blake2s') == True — 'blake2s' (7 chars = 'blake2'=6 + 's'=1; 's'=small/32-bit; BLAKE2s is optimized for 32-bit platforms and small inputs; produces up to 256-bit (32-byte) digests; no 'openssl_' prefix — from _blake2 C extension; blake2s.__module__=='_blake2'(7); 'blake2s'(7)==blake2b.__name__.__len__()==7: 'b' vs 's' suffix is the only difference; first hashlibctor170 standalone for blake2s.__name__"
  category: identity
  kind: python_call_eq
  function: blake2s.__name__.__eq__
  args: ["blake2s"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256.__name__ is 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8).
# This is the longest OpenSSL constructor name among all hashlib constructors examined in
# this spec. The '3_' infix in 'sha3_256' (8 chars) adds 2 chars compared to 'sha256' (6 chars),
# making 'openssl_sha3_256' (16 chars) 2 chars longer than 'openssl_sha256' (14 chars).
# sha3_256 is an OpenSSL-backed implementation of SHA3-256 (Keccak), distinct from blake2b/blake2s
# which are in _blake2 and have no 'openssl_' prefix. No prior hashlib spec anchors
# sha3_256.__name__ as a standalone under hashlibctor170. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra170.sha3_256_name_openssl_sha3_256:
  description: "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') == True — 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8; longest OpenSSL constructor name in this spec); 'sha3_256'=8 chars vs 'sha256'=6 chars: '3_' infix adds 2 chars, so openssl_sha3_256(16) > openssl_sha256(14) by 2; sha3_256.__module__=='_hashlib'(8 chars; OpenSSL provides SHA-3 on this platform); SHA3-256 uses Keccak sponge construction (FIPS 202); length ordering in this spec: blake2b/blake2s(7) < sha1(12) < sha224/sha384/sha256/sha512(14) < sha3_256(16); first hashlibctor170 standalone for sha3_256.__name__"
  category: identity
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_256.__module__ is '_hashlib' (8 chars). On this platform (macOS/Darwin with
# Python 3.14.3 linked against OpenSSL), SHA-3 is provided by the OpenSSL library and
# accessed through the _hashlib C extension. sha3_256 shares __module__ == '_hashlib' with
# sha1, sha224, sha384, sha256, md5, and sha512. This confirms that on OpenSSL-backed
# CPython, SHA-3 constructors come from _hashlib, not from a separate SHA-3 extension.
# blake2b and blake2s differ: their __module__ is '_blake2' (7 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra170.sha3_256_module_hashlib:
  description: "hashlib.sha3_256.__module__.__eq__('_hashlib') == True — '_hashlib' (8 chars; private C extension; Modules/_hashlib.c); sha3_256 shares __module__=='_hashlib' with sha1/sha224/sha384/sha256/md5/sha512 (all OpenSSL-backed); blake2b/blake2s differ: __module__=='_blake2'(7 chars); on macOS/Darwin with Python 3.14.3 + OpenSSL, SHA-3 is OpenSSL-backed via _hashlib; sha3_256.__name__=='openssl_sha3_256'(16 chars; longest); first hashlibctor170 standalone for sha3_256.__module__"
  category: identity
  kind: python_call_eq
  function: sha3_256.__module__.__eq__
  args: ["_hashlib"]
  expected: true
