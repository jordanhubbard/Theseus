spec: keyword_extra4
version: ">=3.12"
backend: python_module(keyword)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/keyword.html — Python keyword module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/keyword.py"
    - "keyword.zspec.zsdl — covers iskeyword true/false cases (for/while/if/def/class/return/import/lambda/True/False/None/and/or/not/in/is; hello/foo/print/len/match/case), issoftkeyword true/false cases"
    - "keyword_extra.zspec.zsdl — covers kwlist is_list, kwlist len>=35, iskeyword.__name__, iskeyword(else/elif/try/except/with/yield)==True, iskeyword(hello)==False, issoftkeyword.__name__"
    - "keyword_extra2.zspec.zsdl — covers iskeyword.__name__/__module__, issoftkeyword.__name__, kwlist is_list/len>=30/__contains__(if/for/while/class/def), softkwlist is_list/len==4/__contains__(_/case/match/type)"
    - "keyword_extra3.zspec.zsdl — covers iskeyword.__qualname__, issoftkeyword.__qualname__, kwlist.__contains__('hello')==False"
  notes:
    - "This spec adds kwlist membership checks for keywords not covered in any prior keyword spec."
    - "keyword_extra2 covers: if, for, while, class, def."
    - "keyword.zspec.zsdl covers: for, while, if, def, class, return, import, lambda, True, False, None, and, or, not, in, is (via iskeyword table)."
    - "keyword_extra covers: else, elif, try, except, with, yield (via iskeyword calls)."
    - "This spec adds: kwlist.__contains__ checks for raise, del, pass, break, continue, global, nonlocal, assert."
    - "All these are hard keywords present in Python 3.12's kwlist."
    - "softkwlist.__contains__('_') is covered in keyword_extra2; this adds a negative check: 'hello' not in softkwlist."
    - "kwlist.__len__() == 35 on Python 3.12 exactly — keyword_extra uses >=35, this pins the exact count."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# kwlist membership — keywords not checked via kwlist.__contains__ in any prior spec
# keyword_extra2 covers: if, for, while, class, def
# keyword.zspec.zsdl tests iskeyword(kw) but not kwlist.__contains__(kw) directly
# keyword_extra tests iskeyword(else/elif/try/except/with/yield) but not kwlist.__contains__
# ---------------------------------------------------------------------------

table keyword_extra4.kwlist.additional_keywords:
  kind: python_call_eq
  category: kwlist
  id_prefix: kwlist_has

  columns: [id, function, args, expected]
  rows:
    - [raise,    kwlist.__contains__, ["raise"],    true]
    - [del,      kwlist.__contains__, ["del"],      true]
    - [pass,     kwlist.__contains__, ["pass"],     true]
    - [break,    kwlist.__contains__, ["break"],    true]
    - [continue, kwlist.__contains__, ["continue"], true]
    - [global,   kwlist.__contains__, ["global"],   true]
    - [nonlocal, kwlist.__contains__, ["nonlocal"], true]
    - [assert,   kwlist.__contains__, ["assert"],   true]

# ---------------------------------------------------------------------------
# kwlist exact length on Python 3.12
# keyword_extra uses >= 35; keyword_extra2 uses >= 30.
# This spec pins the exact length for Python 3.12 via __eq__.
# ---------------------------------------------------------------------------

invariant keyword_extra4.kwlist.len_eq_35:
  description: "len(kwlist) == 35 on Python 3.12"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__len__
  args: []
  method: __eq__
  method_args: [35]
  expected: true

# ---------------------------------------------------------------------------
# softkwlist negative membership check
# keyword_extra2 covers softkwlist.__contains__ for all 4 soft keywords.
# This adds a negative check: 'hello' is not in softkwlist.
# keyword_extra3 adds kwlist.__contains__('hello')==False; this is softkwlist.
# ---------------------------------------------------------------------------

invariant keyword_extra4.softkwlist.not_contains_hello:
  description: "softkwlist.__contains__('hello') == False — 'hello' is not a soft keyword"
  category: softkwlist
  kind: python_call_eq
  function: softkwlist.__contains__
  args: ["hello"]
  expected: false

# ---------------------------------------------------------------------------
# softkwlist negative: hard keywords are not soft keywords
# These use kwlist.__contains__ in extra2, but NOT softkwlist.__contains__.
# ---------------------------------------------------------------------------

invariant keyword_extra4.softkwlist.not_contains_for:
  description: "softkwlist.__contains__('for') == False — 'for' is a hard keyword, not soft"
  category: softkwlist
  kind: python_call_eq
  function: softkwlist.__contains__
  args: ["for"]
  expected: false

invariant keyword_extra4.softkwlist.not_contains_if:
  description: "softkwlist.__contains__('if') == False — 'if' is a hard keyword, not soft"
  category: softkwlist
  kind: python_call_eq
  function: softkwlist.__contains__
  args: ["if"]
  expected: false
