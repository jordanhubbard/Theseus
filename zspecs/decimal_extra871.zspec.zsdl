spec: decimal_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - decimal module CPython source
    - Python 3.9+ standard library documentation
  not_derived_from:
    - any third-party decimal implementations
  notes:
    - Covers decimal module exception class identities
    - All expected values verified against CPython 3.9+ behavior
  created_at: "2026-04-12"

table decimal_extra871.exception_identities:
  description: decimal module exception class qualname and module identity introspection
  kind: python_call_eq
  category: module_introspection
  id_prefix: dc871xx
  columns: [id, function, args, expected]
  rows:
    - [dc871xx001, decimal.Overflow.__qualname__.__eq__, ["Overflow"], true]
    - [dc871xx002, decimal.Overflow.__module__.__eq__, ["decimal"], true]
    - [dc871xx003, decimal.Underflow.__qualname__.__eq__, ["Underflow"], true]
    - [dc871xx004, decimal.Underflow.__module__.__eq__, ["decimal"], true]
    - [dc871xx005, decimal.Inexact.__qualname__.__eq__, ["Inexact"], true]
    - [dc871xx006, decimal.Inexact.__module__.__eq__, ["decimal"], true]
    - [dc871xx007, decimal.Rounded.__qualname__.__eq__, ["Rounded"], true]
    - [dc871xx008, decimal.Rounded.__module__.__eq__, ["decimal"], true]
    - [dc871xx009, decimal.Subnormal.__qualname__.__eq__, ["Subnormal"], true]
    - [dc871xx010, decimal.Subnormal.__module__.__eq__, ["decimal"], true]
    - [dc871xx011, decimal.FloatOperation.__qualname__.__eq__, ["FloatOperation"], true]
    - [dc871xx012, decimal.FloatOperation.__module__.__eq__, ["decimal"], true]
