spec: io_extra197
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec extends io_extra196.zspec.zsdl."
    - "This spec covers: io.BufferedReader class identity — __name__, __module__, __bases__[0].__name__, __init__.__qualname__, read.__qualname__, read1.__qualname__, peek.__qualname__, and __class__.__name__."
    - "io.BufferedReader.__name__ == 'BufferedReader' (len=14); confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__module__ == '_io' (len=3); BufferedReader is implemented in the _io C extension, not in the pure-Python io wrapper; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' (len=15); the direct base is the C-level _BufferedIOBase, not the pure-Python BufferedIOBase; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__init__.__qualname__ == 'BufferedReader.__init__' (len=23: 'BufferedReader.'=15+'__init__'=8=23); confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (len=19: 'BufferedReader.'=15+'read'=4=19); confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1' (len=20: 'BufferedReader.'=15+'read1'=5=20); confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.peek.__qualname__ == 'BufferedReader.peek' (len=19: 'BufferedReader.'=15+'peek'=4=19); same length as read qualname; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__class__.__name__ == 'type' — BufferedReader uses the plain type metaclass (not ABCMeta); confirmed Python 3.14.3 macOS."
    - "Qualname length ordering: read.__qualname__=19 == peek.__qualname__=19 < read1.__qualname__=20 < __init__.__qualname__=23; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.BufferedReader method __qualname__ equality
# read(19), read1(20), peek(19), __init__(23)
# ---------------------------------------------------------------------------

table io_extra197.bufferedreader_method_qualnames:
  description: "io.BufferedReader method __qualname__ values: read='BufferedReader.read'(19), read1='BufferedReader.read1'(20), peek='BufferedReader.peek'(19), __init__='BufferedReader.__init__'(23)"
  kind: python_call_eq
  category: identity
  id_prefix: iobufferedreader197

  columns: [id, function, args, expected, description]
  rows:
    - [read_qn_eq,   io.BufferedReader.read.__qualname__.__eq__,    ["BufferedReader.read"],    true, "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (len=19); confirmed Python 3.14.3 macOS"]
    - [read1_qn_eq,  io.BufferedReader.read1.__qualname__.__eq__,   ["BufferedReader.read1"],   true, "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1' (len=20); confirmed Python 3.14.3 macOS"]
    - [peek_qn_eq,   io.BufferedReader.peek.__qualname__.__eq__,    ["BufferedReader.peek"],    true, "io.BufferedReader.peek.__qualname__ == 'BufferedReader.peek' (len=19); confirmed Python 3.14.3 macOS"]
    - [init_qn_eq,   io.BufferedReader.__init__.__qualname__.__eq__, ["BufferedReader.__init__"], true, "io.BufferedReader.__init__.__qualname__ == 'BufferedReader.__init__' (len=23, longest in spec); confirmed Python 3.14.3 macOS"]
    - [read_qn_len,  io.BufferedReader.read.__qualname__.__len__,   [],                         19,   "io.BufferedReader.read.__qualname__.__len__() == 19 ('BufferedReader.'=15+'read'=4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.BufferedReader method __qualname__ lengths
# read(19) == peek(19) < read1(20) < __init__(23)
# ---------------------------------------------------------------------------

table io_extra197.bufferedreader_method_qualname_lengths:
  description: "io.BufferedReader method __qualname__ lengths: read=19, read1=20, peek=19, __init__=23; length ordering read==peek < read1 < __init__"
  kind: python_call_eq
  category: identity
  id_prefix: iobufferedreader197

  columns: [id, function, args, expected, description]
  rows:
    - [read_qn_len,  io.BufferedReader.read.__qualname__.__len__,    [], 19, "io.BufferedReader.read.__qualname__.__len__() == 19 ('BufferedReader.'=15+'read'=4); confirmed Python 3.14.3 macOS"]
    - [read1_qn_len, io.BufferedReader.read1.__qualname__.__len__,   [], 20, "io.BufferedReader.read1.__qualname__.__len__() == 20 ('BufferedReader.'=15+'read1'=5); confirmed Python 3.14.3 macOS"]
    - [peek_qn_len,  io.BufferedReader.peek.__qualname__.__len__,    [], 19, "io.BufferedReader.peek.__qualname__.__len__() == 19 ('BufferedReader.'=15+'peek'=4); same length as read; confirmed Python 3.14.3 macOS"]
    - [init_qn_len,  io.BufferedReader.__init__.__qualname__.__len__, [], 23, "io.BufferedReader.__init__.__qualname__.__len__() == 23 ('BufferedReader.'=15+'__init__'=8); longest in spec; confirmed Python 3.14.3 macOS"]
    - [module_len,   io.BufferedReader.__module__.__len__,           [], 3,  "io.BufferedReader.__module__.__len__() == 3 — _io (underscore+i+o); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.BufferedReader class-level identity attributes
# __name__(BufferedReader,14), __module__(_io,3), __bases__[0].__name__(_BufferedIOBase,15), __class__(type)
# ---------------------------------------------------------------------------

table io_extra197.bufferedreader_class_identity:
  description: "io.BufferedReader class-level identity: __name__='BufferedReader'(14), __module__='_io'(3), __bases__[0].__name__='_BufferedIOBase'(15), __class__.__name__='type'"
  kind: python_call_eq
  category: identity
  id_prefix: iobufferedreader197

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      io.BufferedReader.__name__.__eq__,                             ["BufferedReader"],   true, "io.BufferedReader.__name__ == 'BufferedReader' (len=14); confirmed Python 3.14.3 macOS"]
    - [module_eq,    io.BufferedReader.__module__.__eq__,                           ["_io"],              true, "io.BufferedReader.__module__ == '_io' (C extension, len=3); confirmed Python 3.14.3 macOS"]
    - [base_eq,      "io.BufferedReader.__bases__[0].__name__.__eq__",              ["_BufferedIOBase"],  true, "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' (len=15); confirmed Python 3.14.3 macOS"]
    - [class_name_eq, io.BufferedReader.__class__.__name__.__eq__,                  ["type"],             true, "io.BufferedReader.__class__.__name__ == 'type' (plain type metaclass, not ABCMeta); confirmed Python 3.14.3 macOS"]
    - [name_len,     io.BufferedReader.__name__.__len__,                            [],                   14,   "io.BufferedReader.__name__.__len__() == 14 — B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)R(9)e(10)a(11)d(12)e(13)r(14); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra197.bufferedreader_name_eq:
  description: "io.BufferedReader.__name__ == 'BufferedReader' — class name string length 14 ('BufferedReader'); io.BufferedReader is the public buffered I/O reader class; its __name__ attribute returns the plain class name as a string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra197.bufferedreader_module_eq:
  description: "io.BufferedReader.__module__ == '_io' — BufferedReader is implemented in the _io C extension (len=3); although accessed as io.BufferedReader, the class itself lives in the C extension module _io; this contrasts with classes defined in Lib/io.py which would show __module__=='io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra197.bufferedreader_base_name_eq:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — the direct base class of BufferedReader is _BufferedIOBase (len=15), which is the internal C-level base class; the public Python API uses BufferedIOBase (without underscore prefix) as the documented abstract base class, but the actual C inheritance chain goes through _BufferedIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra197.bufferedreader_init_qualname_eq:
  description: "io.BufferedReader.__init__.__qualname__ == 'BufferedReader.__init__' — the qualified name of the __init__ method is 'BufferedReader.__init__' (len=23: 'BufferedReader.'=15 + '__init__'=8 = 23); this is the longest qualname among the methods examined in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.__init__.__qualname__.__eq__
  args: ["BufferedReader.__init__"]
  expected: true

invariant io_extra197.bufferedreader_read_qualname_eq:
  description: "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' — the qualified name of the read method is 'BufferedReader.read' (len=19: 'BufferedReader.'=15 + 'read'=4 = 19); read reads and returns up to size bytes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.read.__qualname__.__eq__
  args: ["BufferedReader.read"]
  expected: true

invariant io_extra197.bufferedreader_read1_qualname_eq:
  description: "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1' — the qualified name of the read1 method is 'BufferedReader.read1' (len=20: 'BufferedReader.'=15 + 'read1'=5 = 20); read1 reads up to size bytes with at most one raw read() call; one longer than read.__qualname__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.read1.__qualname__.__eq__
  args: ["BufferedReader.read1"]
  expected: true

invariant io_extra197.bufferedreader_peek_qualname_eq:
  description: "io.BufferedReader.peek.__qualname__ == 'BufferedReader.peek' — the qualified name of the peek method is 'BufferedReader.peek' (len=19: 'BufferedReader.'=15 + 'peek'=4 = 19); peek returns buffered data without advancing the position; peek.__qualname__ and read.__qualname__ are both length 19; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.peek.__qualname__.__eq__
  args: ["BufferedReader.peek"]
  expected: true

invariant io_extra197.bufferedreader_class_name_type:
  description: "io.BufferedReader.__class__.__name__ == 'type' — BufferedReader's metaclass is the plain 'type' (not ABCMeta); this contrasts with abstract base classes in the io module such as RawIOBase and BufferedIOBase which use ABCMeta as their metaclass; BufferedReader is a concrete class and does not use ABCMeta; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.__class__.__name__.__eq__
  args: ["type"]
  expected: true

