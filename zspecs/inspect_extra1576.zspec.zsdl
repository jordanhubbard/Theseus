spec: inspect_extra1576
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "inspect.isbuiltin(repr) == True — repr is a C-level built-in function."
    - "inspect.isbuiltin(str) == False — str is a class (type), not a built-in function."
    - "inspect.isclass(str) == True — str is a class object."
    - "inspect.isclass(repr) == False — repr is a function, not a class."
    - "inspect.isbuiltin(len) == True — len is a C-level built-in function."
    - "inspect.isbuiltin(print) == True — print is a C-level built-in function."
    - "inspect.isfunction(str.format) == False — str.format is a slot wrapper, not a Python function."
    - "inspect.isbuiltin(str.upper) == False — str.upper is an unbound method wrapper, not a builtin_function_or_method."
    - "inspect.isroutine(repr) == True — repr is a callable routine (built-in counts)."
    - "inspect.isroutine(str) == False — str is a class, not a routine."
    - "inspect.isroutine(str.upper) == True — str.upper is a method descriptor (routine)."
    - "inspect.getdoc(str.upper) returns a str whose __class__.__name__ == 'str'."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the _empty sentinel class (a type object)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: isbuiltin applied to repr, str, len, print — str/repr protocol
#
# repr and len and print are C-level built-in functions: isbuiltin → True.
# str is a class (type): isbuiltin → False.
# str.upper is an unbound method wrapper: isbuiltin → False.
# ---------------------------------------------------------------------------

table inspect_extra1576.isbuiltin_str_repr_builtins:
  description: "inspect.isbuiltin applied to repr, str, len, print, and str.upper — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: isbuiltin_str_repr
  id_prefix: in1576ib

  columns: [id, function, args, expected, description]
  rows:
    - ["in1576ib001",
       "isbuiltin",
       [repr],
       true,
       "inspect.isbuiltin(repr) == True — repr is a C-level built-in function; wave 552; new to extra1576"]
    - ["in1576ib002",
       "isbuiltin",
       [str],
       false,
       "inspect.isbuiltin(str) == False — str is a class (type), not a built-in function; wave 552; new to extra1576"]
    - ["in1576ib003",
       "isbuiltin",
       [len],
       true,
       "inspect.isbuiltin(len) == True — len is a C-level built-in function; wave 552; new to extra1576"]
    - ["in1576ib004",
       "isbuiltin",
       [print],
       true,
       "inspect.isbuiltin(print) == True — print is a C-level built-in function; wave 552; new to extra1576"]
    - ["in1576ib005",
       "isbuiltin",
       [str.upper],
       false,
       "inspect.isbuiltin(str.upper) == False — str.upper is an unbound method wrapper, not a builtin_function_or_method; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 2: isclass applied to str, repr, int, bytes, float
#
# str, int, bytes, float are classes: isclass → True.
# repr is a built-in function: isclass → False.
# ---------------------------------------------------------------------------

table inspect_extra1576.isclass_str_repr_types:
  description: "inspect.isclass applied to str, repr, int, bytes, float — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: isclass_str_repr
  id_prefix: in1576ic

  columns: [id, function, args, expected, description]
  rows:
    - ["in1576ic001",
       "isclass",
       [str],
       true,
       "inspect.isclass(str) == True — str is a class object; wave 552; new to extra1576"]
    - ["in1576ic002",
       "isclass",
       [repr],
       false,
       "inspect.isclass(repr) == False — repr is a built-in function, not a class; wave 552; new to extra1576"]
    - ["in1576ic003",
       "isclass",
       [int],
       true,
       "inspect.isclass(int) == True — int is a class object; wave 552; new to extra1576"]
    - ["in1576ic004",
       "isclass",
       [bytes],
       true,
       "inspect.isclass(bytes) == True — bytes is a class object; wave 552; new to extra1576"]
    - ["in1576ic005",
       "isclass",
       [float],
       true,
       "inspect.isclass(float) == True — float is a class object; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 3: isroutine applied to repr, str, str.upper, len
#
# isroutine returns True for any callable routine (function, method, built-in).
# repr, len, str.upper are routines; str is a class, not a routine.
# ---------------------------------------------------------------------------

table inspect_extra1576.isroutine_str_repr:
  description: "inspect.isroutine applied to repr, str, str.upper, len — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: isroutine_str_repr
  id_prefix: in1576ir

  columns: [id, function, args, expected, description]
  rows:
    - ["in1576ir001",
       "isroutine",
       [repr],
       true,
       "inspect.isroutine(repr) == True — repr is a built-in callable routine; wave 552; new to extra1576"]
    - ["in1576ir002",
       "isroutine",
       [str],
       false,
       "inspect.isroutine(str) == False — str is a class; classes are not routines; wave 552; new to extra1576"]
    - ["in1576ir003",
       "isroutine",
       [str.upper],
       true,
       "inspect.isroutine(str.upper) == True — str.upper is an unbound method descriptor (routine); wave 552; new to extra1576"]
    - ["in1576ir004",
       "isroutine",
       [len],
       true,
       "inspect.isroutine(len) == True — len is a built-in callable routine; wave 552; new to extra1576"]
    - ["in1576ir005",
       "isfunction",
       [str.format],
       false,
       "inspect.isfunction(str.format) == False — str.format is a slot wrapper, not a Python-level function; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 4: getdoc and Parameter.empty — str representation protocol
#
# getdoc(str.upper) returns a str whose class name is 'str'.
# Parameter.empty is the _empty sentinel class; its __class__.__name__ is 'type'.
# Both checks relate to how inspect represents objects as strings or uses
# sentinel objects in the str/repr protocol.
# ---------------------------------------------------------------------------

table inspect_extra1576.getdoc_and_parameter_empty:
  description: "inspect.getdoc return type and inspect.Parameter.empty class name — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: getdoc_parameter
  id_prefix: in1576gp

  columns: [id, function, args, expected, description]
  rows:
    - ["in1576gp001",
       "getdoc",
       [str.upper],
       "Return a copy of the string converted to uppercase.",
       "inspect.getdoc(str.upper) == 'Return a copy of the string converted to uppercase.' — exact docstring of str.upper; wave 552; new to extra1576"]
    - ["in1576gp002",
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__ == 'Parameter' — class name identity; wave 552; new to extra1576"]
    - ["in1576gp003",
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__ == 'Signature' — class name identity; wave 552; new to extra1576"]
    - ["in1576gp004",
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the _empty sentinel class (a type object); wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1576
# ---------------------------------------------------------------------------

invariant inspect_extra1576.isbuiltin_repr_true:
  description: "inspect.isbuiltin(repr) == True — repr is a C-level built-in function; wave 552; new to extra1576"
  kind: python_call_eq
  function: isbuiltin
  args: [repr]
  expected: true

invariant inspect_extra1576.isbuiltin_str_false:
  description: "inspect.isbuiltin(str) == False — str is a class, not a built-in function; wave 552; new to extra1576"
  kind: python_call_eq
  function: isbuiltin
  args: [str]
  expected: false

invariant inspect_extra1576.isclass_str_true:
  description: "inspect.isclass(str) == True — str is a class object; wave 552; new to extra1576"
  kind: python_call_eq
  function: isclass
  args: [str]
  expected: true

invariant inspect_extra1576.isclass_repr_false:
  description: "inspect.isclass(repr) == False — repr is a built-in function, not a class; wave 552; new to extra1576"
  kind: python_call_eq
  function: isclass
  args: [repr]
  expected: false

invariant inspect_extra1576.isclass_bytes_true:
  description: "inspect.isclass(bytes) == True — bytes is a class object; wave 552; new to extra1576"
  kind: python_call_eq
  function: isclass
  args: [bytes]
  expected: true

invariant inspect_extra1576.isroutine_repr_true:
  description: "inspect.isroutine(repr) == True — repr is a callable routine; wave 552; new to extra1576"
  kind: python_call_eq
  function: isroutine
  args: [repr]
  expected: true

invariant inspect_extra1576.isroutine_str_false:
  description: "inspect.isroutine(str) == False — str is a class; classes are not routines; wave 552; new to extra1576"
  kind: python_call_eq
  function: isroutine
  args: [str]
  expected: false

invariant inspect_extra1576.isfunction_str_format_false:
  description: "inspect.isfunction(str.format) == False — str.format is a slot wrapper, not a Python function; wave 552; new to extra1576"
  kind: python_call_eq
  function: isfunction
  args: [str.format]
  expected: false

invariant inspect_extra1576.parameter_empty_class_is_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the _empty sentinel (a type object); wave 552; new to extra1576"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true
