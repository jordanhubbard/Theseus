spec: numbers_extra5
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers documentation"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl and prior extras."
    - "numbers.zspec covers: all five __name__ and __module__ (tables); abstract method counts; Complex/__abs__/conjugate; Rational/numerator/denominator; Integral/__and__."
    - "numbers_extra covers: all five __bases__[0].__name__; isinstance checks; Integral __or__/__xor__/__lshift__; Real __trunc__/__floor__; Complex real/imag."
    - "numbers_extra2 covers: class_names table (description variant); Number/Complex/Real __module__ invariants; Complex/Real __bases__[0].__name__ via __eq__ style."
    - "numbers_extra3 covers: class_names table (class_name prefix); all five __qualname__; Rational/Integral __module__; Rational/Integral __bases__ via __eq__ style; bases_len for Number/Integral; Integral __int__/__rrshift__/__invert__; Real __ceil__."
    - "numbers_extra4 covers: Complex __neg__/__pos__/__mul__; Integral __pow__/__mod__/__floordiv__; isinstance for Integral(0)/Real(0.0)/Number(0j)/Integral(False)."
    - "This spec adds: MRO length for each tower class; bases_len for Complex/Real/Rational; Real abstract methods __float__/__le__/__lt__/__rfloordiv__/__rmod__/__round__; Integral abstract methods __rand__/__rlshift__/__ror__/__rshift__/__rxor__."
    - "numbers.Number.__mro__.__len__() == 2 — [Number, object]."
    - "numbers.Complex.__mro__.__len__() == 3 — [Complex, Number, object]."
    - "numbers.Real.__mro__.__len__() == 4 — [Real, Complex, Number, object]."
    - "numbers.Rational.__mro__.__len__() == 5 — [Rational, Real, Complex, Number, object]."
    - "numbers.Integral.__mro__.__len__() == 6 — [Integral, Rational, Real, Complex, Number, object]."
    - "numbers.Complex.__bases__.__len__() == 1 — Complex has a single direct base (Number)."
    - "numbers.Real.__bases__.__len__() == 1 — Real has a single direct base (Complex)."
    - "numbers.Rational.__bases__.__len__() == 1 — Rational has a single direct base (Real)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO length for each class in the numeric tower
# numbers_extra3 covers bases_len for Number and Integral only.
# This spec covers MRO lengths (orthogonal to bases_len) for all five.
# ---------------------------------------------------------------------------

table numbers_extra5.mro_lengths:
  kind: python_call_eq
  category: mro_length
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [Number,   Number.__mro__.__len__,   [], 2]
    - [Complex,  Complex.__mro__.__len__,  [], 3]
    - [Real,     Real.__mro__.__len__,     [], 4]
    - [Rational, Rational.__mro__.__len__, [], 5]
    - [Integral, Integral.__mro__.__len__, [], 6]

# ---------------------------------------------------------------------------
# __bases__ length for Complex, Real, Rational
# numbers_extra3 covers bases_len for Number and Integral.
# New here: Complex, Real, Rational (all have length 1).
# ---------------------------------------------------------------------------

table numbers_extra5.bases_lengths:
  kind: python_call_eq
  category: bases_len
  id_prefix: bases_len

  columns: [id, function, args, expected]
  rows:
    - [Complex,  Complex.__bases__.__len__,  [], 1]
    - [Real,     Real.__bases__.__len__,     [], 1]
    - [Rational, Rational.__bases__.__len__, [], 1]

# ---------------------------------------------------------------------------
# Abstract method membership — Real: new methods not covered in prior specs
# numbers_extra covers Real: __trunc__, __floor__.
# numbers_extra3 covers Real: __ceil__.
# New here: Real.__float__, Real.__le__, Real.__lt__, Real.__rfloordiv__,
#   Real.__rmod__, Real.__round__.
# ---------------------------------------------------------------------------

table numbers_extra5.abstract_methods.real_ops:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: real_op

  columns: [id, function, args, expected]
  rows:
    - [float,      Real.__abstractmethods__.__contains__, ["__float__"],      true]
    - [le,         Real.__abstractmethods__.__contains__, ["__le__"],         true]
    - [lt,         Real.__abstractmethods__.__contains__, ["__lt__"],         true]
    - [rfloordiv,  Real.__abstractmethods__.__contains__, ["__rfloordiv__"],  true]
    - [rmod,       Real.__abstractmethods__.__contains__, ["__rmod__"],       true]
    - [round,      Real.__abstractmethods__.__contains__, ["__round__"],      true]

# ---------------------------------------------------------------------------
# Abstract method membership — Integral: new methods not covered in prior specs
# numbers covers Integral: __and__.
# numbers_extra covers Integral: __or__, __xor__, __lshift__.
# numbers_extra3 covers Integral: __int__, __rrshift__, __invert__.
# numbers_extra4 covers Integral: __pow__, __mod__, __floordiv__.
# New here: __rand__, __rlshift__, __ror__, __rshift__, __rxor__.
# ---------------------------------------------------------------------------

table numbers_extra5.abstract_methods.integral_reverse_ops:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: integral_rev

  columns: [id, function, args, expected]
  rows:
    - [rand,    Integral.__abstractmethods__.__contains__, ["__rand__"],    true]
    - [rlshift, Integral.__abstractmethods__.__contains__, ["__rlshift__"], true]
    - [ror,     Integral.__abstractmethods__.__contains__, ["__ror__"],     true]
    - [rshift,  Integral.__abstractmethods__.__contains__, ["__rshift__"],  true]
    - [rxor,    Integral.__abstractmethods__.__contains__, ["__rxor__"],    true]
