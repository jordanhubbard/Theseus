spec: socket_extra291
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum member."
    - "socket.AF_INET == 2 — universally stable POSIX constant."
    - "socket.AF_INET6 == 30 on macOS (Darwin); this is platform-specific (10 on Linux)."
    - "socket.SOCK_STREAM == 1 and socket.SOCK_DGRAM == 2 — stable POSIX constants."
    - "socket.SOL_SOCKET.__class__.__name__ == 'int' on macOS — SOL_SOCKET is a plain int constant."
    - "socket.getfqdn.__module__ == 'socket' — implemented in pure Python."
    - "socket.gethostname.__module__ == '_socket' — implemented in the C extension."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Address family and socket kind — enum class names
# ---------------------------------------------------------------------------

invariant socket_extra291.AF_INET.class_name:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily'"
  category: constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra291.SOCK_STREAM.class_name:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# Integer values — stable POSIX constants
# ---------------------------------------------------------------------------

invariant socket_extra291.AF_INET.value:
  description: "socket.AF_INET == 2 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra291.AF_INET6.value_macos:
  description: "socket.AF_INET6 == 30 on macOS/Darwin (platform-specific; 10 on Linux)"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true

invariant socket_extra291.SOCK_STREAM.value:
  description: "socket.SOCK_STREAM == 1 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

invariant socket_extra291.SOCK_DGRAM.value:
  description: "socket.SOCK_DGRAM == 2 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# SOL_SOCKET — plain int on macOS
# ---------------------------------------------------------------------------

invariant socket_extra291.SOL_SOCKET.class_name:
  description: "socket.SOL_SOCKET.__class__.__name__ == 'int' on macOS (plain int, not an enum)"
  category: constants
  kind: python_call_eq
  function: SOL_SOCKET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Module attributes — getfqdn and gethostname source modules
# ---------------------------------------------------------------------------

invariant socket_extra291.getfqdn.module:
  description: "socket.getfqdn.__module__ == 'socket' (pure-Python implementation)"
  category: functions
  kind: python_call_eq
  function: getfqdn.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra291.gethostname.module:
  description: "socket.gethostname.__module__ == '_socket' (C extension implementation)"
  category: functions
  kind: python_call_eq
  function: gethostname.__module__.__eq__
  args: ["_socket"]
  expected: true
