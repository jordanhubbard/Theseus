spec: py_compile
version: ">=3.2"
backend: python_module(py_compile)

docs: https://docs.python.org/3/library/py_compile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/py_compile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/py_compile.py (internal implementation)"
  notes:
    - "py_compile.compile(file) compiles a Python source file to bytecode and writes a .pyc file; returns the .pyc path."
    - "py_compile.PyCompileError is raised when the source file contains a syntax error; it subclasses Exception."
    - "py_compile.PycInvalidationMode is an IntEnum with members TIMESTAMP (1), CHECKED_HASH (2), UNCHECKED_HASH (3)."
    - "PycInvalidationMode.TIMESTAMP controls how the interpreter validates cached .pyc files against their source."
    - "PyCompileError.__str__ returns a formatted error message that includes the filename and line number."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "py_compile.compile raises PyCompileError (wrapping SyntaxError) when the source has a syntax error; raises OSError for file access failures."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

