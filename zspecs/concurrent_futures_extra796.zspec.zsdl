spec: concurrent_futures_extra796
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/concurrent/futures/thread.py"
    - "cpython/Lib/concurrent/futures/process.py"
  not_derived_from:
    - "any third-party futures implementation"
  notes:
    - "Covers concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor method qualnames"
    - "Validates __qualname__ for __init__, submit, map, shutdown, __enter__, __exit__"
  created_at: "2026-04-12"

table concurrent_futures_extra796.name:
  description: "concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor method qualname checks"
  kind: python_call_eq
  category: stdlib_concurrent_futures
  id_prefix: cf796xx
  columns: [id, function, args, expected]
  rows:
    - [cf796xx001, concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__, ["ThreadPoolExecutor.__init__"], true]
    - [cf796xx002, concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__, ["ThreadPoolExecutor.submit"], true]
    - [cf796xx003, concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__, ["ThreadPoolExecutor.map"], true]
    - [cf796xx004, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true]
    - [cf796xx005, concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__eq__, ["ThreadPoolExecutor.__enter__"], true]
    - [cf796xx006, concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__eq__, ["ThreadPoolExecutor.__exit__"], true]
    - [cf796xx007, concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__, ["ProcessPoolExecutor.__init__"], true]
    - [cf796xx008, concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__, ["ProcessPoolExecutor.submit"], true]
    - [cf796xx009, concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__, ["ProcessPoolExecutor.map"], true]
    - [cf796xx010, concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__, ["ProcessPoolExecutor.shutdown"], true]
    - [cf796xx011, concurrent.futures.ProcessPoolExecutor.__enter__.__qualname__.__eq__, ["ProcessPoolExecutor.__enter__"], true]
    - [cf796xx012, concurrent.futures.ProcessPoolExecutor.__exit__.__qualname__.__eq__, ["ProcessPoolExecutor.__exit__"], true]
