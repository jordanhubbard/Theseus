spec: decimal_extra127
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal mathematical and transcendental method __qualname__ values and lengths."
    - "decimal.Decimal.as_tuple.__qualname__ = 'Decimal.as_tuple' (length 16)."
    - "decimal.Decimal.fma.__qualname__ = 'Decimal.fma' (length 11)."
    - "decimal.Decimal.ln.__qualname__ = 'Decimal.ln' (length 10)."
    - "decimal.Decimal.log10.__qualname__ = 'Decimal.log10' (length 13)."
    - "decimal.Decimal.exp.__qualname__ = 'Decimal.exp' (length 11)."
    - "decimal.Decimal.logb.__qualname__ = 'Decimal.logb' (length 12)."
    - "decimal.Decimal.next_minus.__qualname__ = 'Decimal.next_minus' (length 18)."
    - "decimal.Decimal.next_plus.__qualname__ = 'Decimal.next_plus' (length 17)."
    - "decimal.Decimal.next_toward.__qualname__ = 'Decimal.next_toward' (length 19)."
    - "decimal.Decimal.sqrt.__qualname__ = 'Decimal.sqrt' (length 12)."
    - "decimal.Decimal.canonical.__qualname__ = 'Decimal.canonical' (length 17)."
    - "decimal.Decimal.copy_abs.__qualname__ = 'Decimal.copy_abs' (length 16)."
    - "All these are C extension methods; their __qualname__ follows 'Decimal.method_name' pattern."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal transcendental and special value method qualnames
# ln, log10, exp: transcendental functions (natural log, base-10 log, exponential).
# fma: fused multiply-add.
# logb: base-10 exponent of a number (as an integer).
# as_tuple: returns a DecimalTuple named tuple.
# All qualnames follow 'Decimal.method_name' pattern.
# ---------------------------------------------------------------------------

table decimal_extra127.Decimal_transcendental_method_qualnames:
  description: "decimal.Decimal transcendental and special method __qualname__ values: ln='Decimal.ln'(10), log10='Decimal.log10'(13), exp='Decimal.exp'(11), fma='Decimal.fma'(11), logb='Decimal.logb'(12), as_tuple='Decimal.as_tuple'(16)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decmathqname127

  columns: [id, function, args, expected, description]
  rows:
    - [ln_qname_eq,       Decimal.ln.__qualname__.__eq__,       ["Decimal.ln"],       true,  "Decimal.ln.__qualname__ == 'Decimal.ln'"]
    - [ln_qname_len,      Decimal.ln.__qualname__.__len__,      [],                   10,    "Decimal.ln.__qualname__ has 10 characters"]
    - [log10_qname_eq,    Decimal.log10.__qualname__.__eq__,    ["Decimal.log10"],    true,  "Decimal.log10.__qualname__ == 'Decimal.log10'"]
    - [log10_qname_len,   Decimal.log10.__qualname__.__len__,   [],                   13,    "Decimal.log10.__qualname__ has 13 characters"]
    - [exp_qname_eq,      Decimal.exp.__qualname__.__eq__,      ["Decimal.exp"],      true,  "Decimal.exp.__qualname__ == 'Decimal.exp'"]
    - [exp_qname_len,     Decimal.exp.__qualname__.__len__,     [],                   11,    "Decimal.exp.__qualname__ has 11 characters"]
    - [fma_qname_eq,      Decimal.fma.__qualname__.__eq__,      ["Decimal.fma"],      true,  "Decimal.fma.__qualname__ == 'Decimal.fma'"]
    - [fma_qname_len,     Decimal.fma.__qualname__.__len__,     [],                   11,    "Decimal.fma.__qualname__ has 11 characters"]
    - [logb_qname_eq,     Decimal.logb.__qualname__.__eq__,     ["Decimal.logb"],     true,  "Decimal.logb.__qualname__ == 'Decimal.logb'"]
    - [logb_qname_len,    Decimal.logb.__qualname__.__len__,    [],                   12,    "Decimal.logb.__qualname__ has 12 characters"]
    - [astuple_qname_eq,  Decimal.as_tuple.__qualname__.__eq__, ["Decimal.as_tuple"], true,  "Decimal.as_tuple.__qualname__ == 'Decimal.as_tuple'"]
    - [astuple_qname_len, Decimal.as_tuple.__qualname__.__len__,[],                   16,    "Decimal.as_tuple.__qualname__ has 16 characters"]

# ---------------------------------------------------------------------------
# decimal.Decimal next_* method qualnames
# next_minus: returns the largest representable number smaller than self.
# next_plus: returns the smallest representable number larger than self.
# next_toward: returns the number closest to self in the direction of other.
# next_minus=18, next_plus=17, next_toward=19.
# ---------------------------------------------------------------------------

table decimal_extra127.Decimal_next_method_qualnames:
  description: "decimal.Decimal next_* method __qualname__ values: next_minus='Decimal.next_minus'(18), next_plus='Decimal.next_plus'(17), next_toward='Decimal.next_toward'(19)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decmathqname127

  columns: [id, function, args, expected, description]
  rows:
    - [nm_qname_eq,   Decimal.next_minus.__qualname__.__eq__,   ["Decimal.next_minus"],   true,  "Decimal.next_minus.__qualname__ == 'Decimal.next_minus'"]
    - [nm_qname_len,  Decimal.next_minus.__qualname__.__len__,  [],                       18,    "Decimal.next_minus.__qualname__ has 18 characters"]
    - [np_qname_eq,   Decimal.next_plus.__qualname__.__eq__,    ["Decimal.next_plus"],    true,  "Decimal.next_plus.__qualname__ == 'Decimal.next_plus'"]
    - [np_qname_len,  Decimal.next_plus.__qualname__.__len__,   [],                       17,    "Decimal.next_plus.__qualname__ has 17 characters"]
    - [nt_qname_eq,   Decimal.next_toward.__qualname__.__eq__,  ["Decimal.next_toward"],  true,  "Decimal.next_toward.__qualname__ == 'Decimal.next_toward'"]
    - [nt_qname_len,  Decimal.next_toward.__qualname__.__len__, [],                       19,    "Decimal.next_toward.__qualname__ has 19 characters"]
    - [nm_not_bare,   Decimal.next_minus.__qualname__.__eq__,   ["next_minus"],           false, "Decimal.next_minus.__qualname__ != 'next_minus' (always includes class prefix)"]

# ---------------------------------------------------------------------------
# decimal.Decimal sqrt and copy_abs method qualnames
# sqrt: square root function (uses current context for precision).
# canonical: returns the canonical encoding of the argument (no-op for most).
# copy_abs: returns a copy with sign set to 0 (no context used).
# sqrt=12, canonical=17, copy_abs=16.
# ---------------------------------------------------------------------------

table decimal_extra127.Decimal_sqrt_copy_qualnames:
  description: "decimal.Decimal sqrt and copy method __qualname__ values: sqrt='Decimal.sqrt'(12), canonical='Decimal.canonical'(17), copy_abs='Decimal.copy_abs'(16)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decmathqname127

  columns: [id, function, args, expected, description]
  rows:
    - [sqrt_qname_eq,      Decimal.sqrt.__qualname__.__eq__,      ["Decimal.sqrt"],      true,  "Decimal.sqrt.__qualname__ == 'Decimal.sqrt'"]
    - [sqrt_qname_len,     Decimal.sqrt.__qualname__.__len__,     [],                    12,    "Decimal.sqrt.__qualname__ has 12 characters"]
    - [canon_qname_eq,     Decimal.canonical.__qualname__.__eq__, ["Decimal.canonical"], true,  "Decimal.canonical.__qualname__ == 'Decimal.canonical'"]
    - [canon_qname_len,    Decimal.canonical.__qualname__.__len__,[],                    17,    "Decimal.canonical.__qualname__ has 17 characters"]
    - [copyabs_qname_eq,   Decimal.copy_abs.__qualname__.__eq__,  ["Decimal.copy_abs"],  true,  "Decimal.copy_abs.__qualname__ == 'Decimal.copy_abs'"]
    - [copyabs_qname_len,  Decimal.copy_abs.__qualname__.__len__, [],                    16,    "Decimal.copy_abs.__qualname__ has 16 characters"]
    - [sqrt_not_bare,      Decimal.sqrt.__qualname__.__eq__,      ["sqrt"],              false, "Decimal.sqrt.__qualname__ != 'sqrt' (includes 'Decimal.' prefix)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra127.Decimal.ln_qualname:
  description: "decimal.Decimal.ln.__qualname__ == 'Decimal.ln' (ln computes the natural logarithm using the current context; qualname is 'Decimal.ln' with length 10)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.ln.__qualname__.__eq__
  args: ["Decimal.ln"]
  expected: true

invariant decimal_extra127.Decimal.fma_qualname_len:
  description: "decimal.Decimal.fma.__qualname__.__len__() == 11 ('Decimal.fma' is 11 characters: 7 for 'Decimal' + 1 for '.' + 3 for 'fma'; fma computes (self * other) + third with a single rounding)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.fma.__qualname__.__len__
  args: []
  expected: 11

invariant decimal_extra127.Decimal.next_toward_qualname:
  description: "decimal.Decimal.next_toward.__qualname__ == 'Decimal.next_toward' (next_toward returns the number closest to self in the direction of other; qualname length 19)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.next_toward.__qualname__.__eq__
  args: ["Decimal.next_toward"]
  expected: true

invariant decimal_extra127.Decimal.sqrt_qualname_len:
  description: "decimal.Decimal.sqrt.__qualname__.__len__() == 12 ('Decimal.sqrt' is 12 characters: 7 for 'Decimal' + 1 for '.' + 4 for 'sqrt')"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__len__
  args: []
  expected: 12

invariant decimal_extra127.Decimal.next_minus_qualname_len:
  description: "decimal.Decimal.next_minus.__qualname__.__len__() == 18 ('Decimal.next_minus' is 18 characters: 7 + 1 + 10)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.next_minus.__qualname__.__len__
  args: []
  expected: 18
