spec: gc_extra20
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
    - "gc_extra19.zspec.zsdl — covers isenabled/__name__/__qualname__; get_threshold/__name__; get_count/__name__; threshold/count element int type checks; garbage/callbacks __len__==0"
    - "gc_extra18.zspec.zsdl — covers garbage/callbacks __class__.__name__; get_threshold/__class__/__len__; get_count/__class__/__len__; isenabled __class__.__name__; freeze/unfreeze/get_freeze_count __name__"
    - "gc_extra17.zspec.zsdl — covers collect return type; set_threshold/__name__/__module__; set_debug/__name__; get_debug return type; DEBUG_* __class__.__name__"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra19.zspec.zsdl."
    - "NEW: table of __qualname__ for collect, enable, disable, set_threshold, get_objects, set_debug, get_debug."
    - "NEW: collect.__module__ == 'gc'; enable.__module__ == 'gc'; disable.__module__ == 'gc' as standalone invariants."
    - "gc_extra17 covers set_threshold.__module__; no prior spec covers collect/__module__, enable/__module__, disable/__module__ as standalone named invariants in the extra20 namespace."
    - "All gc builtin functions have __qualname__ == __name__ (no class nesting); verified at runtime."
    - "gc.collect.__qualname__ == 'collect'; gc.enable.__qualname__ == 'enable'; gc.disable.__qualname__ == 'disable'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ standalone invariants — collect, enable, disable
#
# gc_extra17 covers set_threshold.__module__ as a standalone invariant.
# No prior gc spec covers collect/__module__, enable/__module__, or
# disable/__module__ as standalone named invariants in the extra20 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra20.collect.module:
  description: "gc.collect.__module__ == 'gc' — collect is a C builtin defined in the gc module"
  category: function_attrs
  kind: python_call_eq
  function: collect.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra20.enable.module:
  description: "gc.enable.__module__ == 'gc' — enable is a C builtin defined in the gc module"
  category: function_attrs
  kind: python_call_eq
  function: enable.__module__.__eq__
  args: ["gc"]
  expected: true

invariant gc_extra20.disable.module:
  description: "gc.disable.__module__ == 'gc' — disable is a C builtin defined in the gc module"
  category: function_attrs
  kind: python_call_eq
  function: disable.__module__.__eq__
  args: ["gc"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — collect, enable, disable, set_threshold,
#                      get_objects, set_debug, get_debug
#
# gc_extra19 covers isenabled/__qualname__ and get_threshold/__name__/
# get_count/__name__ as standalone invariants. No prior gc spec collects
# __qualname__ for these seven functions in a single table. All C-level
# gc builtins have __qualname__ == __name__ (verified at runtime).
# ---------------------------------------------------------------------------

table gc_extra20.function_qualnames:
  description: "__qualname__ for seven gc builtin functions (equals __name__ for top-level C builtins)"
  kind: python_call_eq
  category: function_attrs

  columns: [id, function, args, expected]
  rows:
    - [collect,       collect.__qualname__.__eq__,       ["collect"],       true]
    - [enable,        enable.__qualname__.__eq__,        ["enable"],        true]
    - [disable,       disable.__qualname__.__eq__,       ["disable"],       true]
    - [set_threshold, set_threshold.__qualname__.__eq__, ["set_threshold"], true]
    - [get_objects,   get_objects.__qualname__.__eq__,   ["get_objects"],   true]
    - [set_debug,     set_debug.__qualname__.__eq__,     ["set_debug"],     true]
    - [get_debug,     get_debug.__qualname__.__eq__,     ["get_debug"],     true]
