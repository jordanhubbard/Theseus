spec: end_of_stream
version: ">=1.4.0"
backend: node(end-of-stream)

docs: https://github.com/mafintosh/end-of-stream#readme

provenance:
  derived_from:
    - "end-of-stream README — https://github.com/mafintosh/end-of-stream#readme"
    - "Test vectors verified with end-of-stream via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "end-of-stream source"
  notes:
    - "Cross-stream-version 'end of stream' helper — listens for end / finish / close / error events with normalised semantics. Used by pump, multistream, etc."
    - "Install: npm install end-of-stream"
    - "v1 CJS; module export IS eos(stream, [opts], callback)."
    - "Spec covers shape only — feeding a real stream via JSON entry_args is not possible."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Callback receives an Error if the stream errored, null otherwise."
  stderr: "null"
  stickiness: "Returns a cancel() function for unsubscribing the listeners."
  codes: {}

invariant end_of_stream.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant end_of_stream.module_name:
  description: "Function name is 'eos'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "eos"

invariant end_of_stream.module_arity:
  description: "Module function takes 3 args (stream, opts, callback)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 3
