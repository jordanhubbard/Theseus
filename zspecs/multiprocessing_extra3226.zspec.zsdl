    - ["mp3226015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__rsub__"], false]
    - ["mp3226016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__rsub__"], false]

# ---------------------------------------------------------------------------
# __rmul__ dict-presence — operator.contains(Cls.__dict__, '__rmul__')
#
# All 8 multiprocessing classes return false for __rmul__.
# Process/Pool/AsyncResult/MapResult/SyncManager: process-management types;
#   reflected multiplication is not defined.
# managers.BaseListProxy: proxies list — list does NOT define __rmul__.
#   In wave 658 (mp3166), BaseListProxy.__mul__ was TRUE because list defines
#   __mul__ for repetition (list * n), and BaseListProxy proxies it. However,
#   n * list uses int.__mul__ directly to produce a repeated list — Python
#   does NOT call list.__rmul__ for this operation. Python's list type has
#   NO __rmul__ entry in its __dict__. Therefore BaseListProxy.__rmul__ = false.
# managers._BaseDictProxy: proxies dict — dict defines no __rmul__.
# managers._BaseSetProxy: proxies set — set defines no __rmul__; sets are not
#   sequences and do not support n * set repetition from either side.
# ---------------------------------------------------------------------------

