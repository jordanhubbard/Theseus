    - ["mp3226011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__rsub__"], false]
    - ["mp3226012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__rsub__"], false]
    - ["mp3226013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__rsub__"], false]
