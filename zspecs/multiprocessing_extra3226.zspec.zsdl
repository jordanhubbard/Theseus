  description: "multiprocessing types __rmul__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3226

  columns: [id, function, args, expected]
  rows:
    - ["mp3226017",  operator.contains, [multiprocessing.Process.__dict__,                 "__rmul__"], false]
    - ["mp3226018",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__rmul__"], false]
    - ["mp3226019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__rmul__"], false]
    - ["mp3226020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__rmul__"], false]
    - ["mp3226021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__rmul__"], false]
    - ["mp3226022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__rmul__"], false]
    - ["mp3226023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__rmul__"], false]
    - ["mp3226024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__rmul__"], false]

# ---------------------------------------------------------------------------
# combined — __radd__, __rsub__, __rmul__ across all 8 multiprocessing subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __radd__: false for all 8 — not in any type's own __dict__.
# __rsub__: false for all 8 — not in any type's own __dict__.
# __rmul__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# The BaseListProxy asymmetry across waves deserves emphasis:
#   Wave 658: BaseListProxy.__add__ = true (list + list via __add__).
#   Wave 658: BaseListProxy.__mul__ = true (list * n via __mul__).
#   Wave 662: BaseListProxy.__radd__ = false (list has no __radd__).
#   Wave 662: BaseListProxy.__rmul__ = false (list has no __rmul__).
#   Python's list type defines __add__ and __mul__ but NOT their reflected
#   counterparts. For list repetition, n * list, Python uses int.__mul__
#   directly — list.__rmul__ is never needed and never defined. For list
#   concatenation, n + list raises TypeError because int.__add__ rejects
#   list and list has no __radd__ to provide a fallback.
# _BaseSetProxy note: set defines __sub__ (set difference s - t) and
#   __and__/__or__/__xor__ (wave 661 confirmed all false in __dict__
#   because proxy uses _method IPC callthrough). Set does NOT define
#   __rsub__ or __radd__ or __rmul__ at all. All reflected arithmetic
#   operators are absent from both set and _BaseSetProxy.
# multiprocessing is a process-based concurrency library; its types
#   interact exclusively through explicit method calls, subprocess lifecycle
#   management, and IPC — never through Python's reflected arithmetic operators.
# ---------------------------------------------------------------------------

