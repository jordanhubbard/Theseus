spec: hashlib_extra223
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__name__ == 'hashlib' (7 chars)."
    - "hashlib.md5.__name__ == 'openssl_md5' (11 chars) — C-level function has 'openssl_' prefix."
    - "hashlib.sha1.__name__ == 'openssl_sha1' (12 chars) — C-level function has 'openssl_' prefix."
    - "hashlib.sha256.__name__ == 'openssl_sha256' (14 chars) — C-level function has 'openssl_' prefix."
    - "hashlib.sha512.__name__ == 'openssl_sha512' (14 chars) — C-level function has 'openssl_' prefix."
    - "hashlib.new.__name__ == '__hash_new' (10 chars) — internal hash dispatch function."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars) — plain Python set, not frozenset."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars)."
    - "hashlib.md5().__class__.__name__ == 'HASH' (4 chars) — OpenSSL-backed HASH object."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module and function __name__.__len__() checks
#
# hashlib.__name__.__len__()       == 7   ('hashlib')
# hashlib.md5.__name__.__len__()   == 11  ('openssl_md5')
# hashlib.sha1.__name__.__len__()  == 12  ('openssl_sha1')
# hashlib.sha256.__name__.__len__() == 14 ('openssl_sha256')
# hashlib.sha512.__name__.__len__() == 14 ('openssl_sha512')
# hashlib.new.__name__.__len__()   == 10  ('__hash_new')
# ---------------------------------------------------------------------------

table hashlib_extra223.function_name_lengths:
  description: "hashlib function __name__.__len__() checks in hashlib223 namespace — wave 223 theme: hashlib module and function name lengths; md5/sha1/sha256/sha512 C-level names include 'openssl_' prefix; hashlib.new is '__hash_new' (10 chars); module name is 'hashlib' (7 chars); all verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib223

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,  hashlib.__name__.__len__,       [], 7,  "hashlib.__name__.__len__() == 7 — module name 'hashlib' is 7 characters"]
    - [md5_name_len,     hashlib.md5.__name__.__len__,   [], 11, "hashlib.md5.__name__.__len__() == 11 — C-level name 'openssl_md5' is 11 characters"]
    - [sha1_name_len,    hashlib.sha1.__name__.__len__,  [], 12, "hashlib.sha1.__name__.__len__() == 12 — C-level name 'openssl_sha1' is 12 characters"]
    - [sha256_name_len,  hashlib.sha256.__name__.__len__, [], 14, "hashlib.sha256.__name__.__len__() == 14 — C-level name 'openssl_sha256' is 14 characters"]
    - [sha512_name_len,  hashlib.sha512.__name__.__len__, [], 14, "hashlib.sha512.__name__.__len__() == 14 — C-level name 'openssl_sha512' is 14 characters"]

# ---------------------------------------------------------------------------
# hashlib.new and algorithms attribute name length checks
#
# hashlib.new.__name__.__len__()                             == 10  ('__hash_new')
# hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3   ('set')
# hashlib.algorithms_available.__class__.__name__.__len__()  == 3   ('set')
# ---------------------------------------------------------------------------

table hashlib_extra223.attr_name_lengths:
  description: "hashlib attribute name length checks in hashlib223a namespace — wave 223 theme: hashlib.new internal name '__hash_new' is 10 chars; algorithms_guaranteed and algorithms_available are both type 'set' (3 chars); verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib223a

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_len,             hashlib.new.__name__.__len__,                              [], 10, "hashlib.new.__name__.__len__() == 10 — internal name '__hash_new' is 10 characters"]
    - [alg_guaranteed_type_len,  hashlib.algorithms_guaranteed.__class__.__name__.__len__,  [], 3,  "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3 — type name 'set' is 3 characters"]
    - [alg_available_type_len,   hashlib.algorithms_available.__class__.__name__.__len__,   [], 3,  "hashlib.algorithms_available.__class__.__name__.__len__() == 3 — type name 'set' is 3 characters"]

# ---------------------------------------------------------------------------
# hashlib.md5() HASH object class name checks
#
# hashlib.md5().__class__.__name__.__len__() == 4  ('HASH')
# hashlib.md5().__class__.__name__.__eq__('HASH') == True
# ---------------------------------------------------------------------------

invariant hashlib_extra223.md5_hash_class_name_len:
  description: "hashlib.md5().__class__.__name__.__len__() == 4 — HASH object class name is 'HASH' which is 4 characters; OpenSSL-backed HASH type from _hashlib C extension; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: hashlib.md5().__class__.__name__.__len__
  args: []
  expected: 4

invariant hashlib_extra223.md5_hash_class_name_eq:
  description: "hashlib.md5().__class__.__name__.__eq__('HASH') == True — HASH object class name is exactly 'HASH'; OpenSSL-backed type from _hashlib C extension; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true
