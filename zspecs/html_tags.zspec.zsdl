spec: html_tags
version: ">=5.0.0"
backend: node(html-tags)

docs: https://github.com/sindresorhus/html-tags#readme

provenance:
  derived_from:
    - "html-tags README — https://github.com/sindresorhus/html-tags#readme"
    - "WHATWG HTML Living Standard — list of HTML5 elements"
    - "Test vectors verified with html-tags via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "html-tags source"
  notes:
    - "List of standard HTML tags as a static array — used by sanitizers, linters, JSX runtimes."
    - "Install: npm install html-tags"
    - "v5 ESM only; default export is the array of HTML tags; named voidHtmlTags is the void/self-closing subset."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure data; never throws."
  stderr: "null"
  stickiness: "N/A — static module."
  codes: {}

invariant html_tags.has_115_tags:
  description: "Default export is an array of 115 standard HTML tags"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 115

invariant html_tags.first_tag_is_a:
  description: "List is alphabetically sorted; first tag is 'a'"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: at, args: [0]}
  expected: "a"

invariant html_tags.contains_div:
  description: "Default list contains 'div'"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["div"]}
  expected: true

invariant html_tags.contains_section:
  description: "Default list contains 'section'"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["section"]}
  expected: true

invariant html_tags.does_not_contain_made_up:
  description: "Made-up tag 'foobar' is not in the list"
  category: data
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["foobar"]}
  expected: false

invariant html_tags.void_has_13:
  description: "voidHtmlTags has 13 entries (per HTML Living Standard)"
  category: void
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "voidHtmlTags.length"}
  expected: 13

invariant html_tags.void_includes_br:
  description: "voidHtmlTags includes 'br'"
  category: void
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: voidHtmlTags}
    - {method: includes, args: ["br"]}
  expected: true

invariant html_tags.void_includes_img:
  description: "voidHtmlTags includes 'img'"
  category: void
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: voidHtmlTags}
    - {method: includes, args: ["img"]}
  expected: true

invariant html_tags.void_does_not_include_div:
  description: "voidHtmlTags does NOT include 'div' (div has children)"
  category: void
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: voidHtmlTags}
    - {method: includes, args: ["div"]}
  expected: false

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:59:02Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
