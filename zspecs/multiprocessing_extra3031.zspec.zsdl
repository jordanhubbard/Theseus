spec: mp3031
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (mp3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Key findings: pool.AsyncResult and managers._BaseSetProxy define __class_getitem__ (true)."
    - "No multiprocessing class defines __missing__ or __init_subclass__ in their own __dict__."
    - "managers._BaseDictProxy does NOT define __class_getitem__ despite implementing dict-proxy iteration."
    - "managers.BaseListProxy, managers.SyncManager, multiprocessing.Process, pool.Pool, and pool.MapResult also lack __class_getitem__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# No multiprocessing class defines __missing__; all results are false.
# None of these classes subclass dict directly or implement the missing-key hook.
# managers._BaseDictProxy wraps a shared dict but does not define __missing__.
# ---------------------------------------------------------------------------

table mp3031.missing:
  description: "multiprocessing types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3031

  columns: [id, function, args, expected]
  rows:
    - ["mp3031001", operator.contains, [multiprocessing.Process.__dict__,                  "__missing__"], false]
    - ["mp3031002", operator.contains, [multiprocessing.pool.Pool.__dict__,                "__missing__"], false]
    - ["mp3031003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__missing__"], false]
    - ["mp3031004", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__missing__"], false]
    - ["mp3031005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__missing__"], false]
    - ["mp3031006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__missing__"], false]
    - ["mp3031007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__missing__"], false]
    - ["mp3031008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__missing__"], false]

