# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — operator.contains(Cls.__dict__, '__class_getitem__')
#
# pool.AsyncResult and managers._BaseSetProxy define __class_getitem__ (true).
# All other multiprocessing classes return false.
# ---------------------------------------------------------------------------

