spec: black_rust
version: ">=3.9"
backend: rust_module(black_rust)

docs: https://black.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://black.readthedocs.io/en/stable/ — Black documentation"
  not_derived_from:
    - "black source: blib2to3/__init__.py"
  notes:
    - "Black is the uncompromising Python code formatter."
    - "black.format_str('x=1', mode=black.Mode()) == 'x = 1\\n'."
    - "black.format_str('y=2+3', mode=black.Mode()) == 'y = 2 + 3\\n'."
    - "black.__version__ is a non-empty string."
    - "Expose black_format(code) -> str: black.format_str(code, mode=black.Mode())."
    - "Expose black_version_nonempty() -> bool: len(black.__version__) > 0."
    - "All test vectors verified against black 25.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# black_format — format Python code
table black_rust.format.strings:
  kind: python_call_eq
  category: format
  id_prefix: blk_f
  function: black_format

  columns: [id, args, expected]
  rows:
    - [assign, ["x=1"],   "x = 1\n"]
    - [expr,   ["y=2+3"], "y = 2 + 3\n"]

# black_version_nonempty — version non-empty
invariant black_rust.version.nonempty:
  description: "black.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: black_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:02:50Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
