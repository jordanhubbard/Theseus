spec: micropython_rust
version: ">=3.9"
backend: rust_module(micropython_rust)

docs: https://micropython.org/

provenance:
  derived_from:
    - "https://micropython.org/ — MicroPython"
  notes:
    - "MicroPython is Python for microcontrollers."
    - "Platform info via sys.implementation for MicroPython detection."
    - "sys.platform is a non-empty string."
    - "sys.maxsize > 0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant micropython_rust.sys_platform_nonempty:
  description: "sys.platform is non-empty"
  category: platform
  kind: python_call_eq
  function: micropython_sys_platform_nonempty
  args: []
  expected: true

invariant micropython_rust.sys_maxsize_positive:
  description: "sys.maxsize > 0"
  category: platform
  kind: python_call_eq
  function: micropython_sys_maxsize_positive
  args: []
  expected: true

invariant micropython_rust.sys_prefix_nonempty:
  description: "sys.prefix is non-empty"
  category: platform
  kind: python_call_eq
  function: micropython_sys_prefix_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T04:13:38Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
