docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (sk3466): __iter__, __next__, __len__ dict-presence checks for socket types."
    - "Theme: __iter__/__next__/__len__ dict-presence (iter(x), next(x), len(x))."
    - "All values False — hashlib/uuid/struct/socket types do not implement iterator or sizing protocols."
    - "socket.socket is a Python class; it does not define __iter__, __next__, or __len__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "AddressFamily and SocketKind are IntEnum but do NOT define __iter__, __next__, or __len__ in their own __dict__; these methods are not overridden at the subclass level."
    - "operator.contains(socket.AddressFamily.__dict__, '__next__') is False — not present in AddressFamily's own __dict__."
    - "operator.contains(socket.SocketKind.__dict__, '__len__') is False — same reasoning as AddressFamily."
    - "All values are False for all 3 socket types across all 3 operators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

