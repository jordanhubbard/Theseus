spec: object_inspect
version: ">=1.0.0"
backend: node(object-inspect)

docs: https://github.com/inspect-js/object-inspect#readme

provenance:
  derived_from:
    - "object-inspect README — https://github.com/inspect-js/object-inspect#readme"
    - "Test vectors verified with object-inspect@1.13.4 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "object-inspect source: index.js (MIT; source inspection permitted)"
  not_derived_from:
    - "object-inspect source: internal symbol/circular detection"
  notes:
    - "object-inspect exports a single function that returns a human-readable string representation of any JS value."
    - "Strings are represented with single quotes. Numbers, booleans, null, undefined are bare literals."
    - "Arrays use [ ] brackets with spaces inside when non-empty. Empty arrays are '[]'."
    - "Objects use { } braces with spaces inside when non-empty. Empty objects are '{}'."
    - "Object keys are unquoted when valid identifiers; values follow the same rules as top-level values."
    - "NaN, Infinity, -Infinity are not representable as JSON args — those invariants are omitted."
    - "undefined is not representable as a JSON arg — that invariant is omitted."
    - "The module export is the function itself (no named method); function: ~ (null) is used."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "object-inspect does not throw for any input. node exits 0 for all invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Primitive values — numbers
# ---------------------------------------------------------------------------

table object_inspect.numbers:
  kind: node_module_call_eq
  function: ~
  id_prefix: num
  category: number

  columns: [id, args, expected]
  rows:
    - [int,       [42],    "42"]
    - [zero,      [0],     "0"]
    - [neg,       [-1],    "-1"]
    - [float,     [3.14],  "3.14"]
    - [neg_float, [-2.5],  "-2.5"]
    - [large,     [1000],  "1000"]

# ---------------------------------------------------------------------------
# Primitive values — booleans, null
# ---------------------------------------------------------------------------

table object_inspect.booleans_null:
  kind: node_module_call_eq
  function: ~
  id_prefix: prim
  category: primitive

  columns: [id, args, expected]
  rows:
    - [true_val,  [true],  "true"]
    - [false_val, [false], "false"]
    - [null_val,  [null],  "null"]

# ---------------------------------------------------------------------------
# Primitive values — strings
# ---------------------------------------------------------------------------

table object_inspect.strings:
  kind: node_module_call_eq
  function: ~
  id_prefix: str
  category: string

  columns: [id, args, expected]
  rows:
    - [hello,     ["hello"],       "'hello'"]
    - [empty,     [""],            "''"]
    - [single,    ["a"],           "'a'"]
    - [with_space,["hello world"], "'hello world'"]
    - [digits,    ["123"],         "'123'"]

# ---------------------------------------------------------------------------
# Arrays
# ---------------------------------------------------------------------------

table object_inspect.arrays:
  kind: node_module_call_eq
  function: ~
  id_prefix: arr
  category: array

  columns: [id, args, expected]
  rows:
    - [empty,          [[]],                   "[]"]
    - [single_int,     [[1]],                  "[ 1 ]"]
    - [ints,           [[1, 2, 3]],            "[ 1, 2, 3 ]"]
    - [strings,        [["hello", "world"]],   "[ 'hello', 'world' ]"]
    - [mixed,          [[true, false, null]],  "[ true, false, null ]"]
    - [nested,         [[1, [2, 3]]],          "[ 1, [ 2, 3 ] ]"]

# ---------------------------------------------------------------------------
# Objects
# ---------------------------------------------------------------------------

table object_inspect.objects:
  kind: node_module_call_eq
  function: ~
  id_prefix: obj
  category: object

  columns: [id, args, expected]
  rows:
    - [empty,        [{}],                  "{}"]
    - [int_value,    [{"a": 1}],            "{ a: 1 }"]
    - [str_value,    [{"a": "b"}],          "{ a: 'b' }"]
    - [two_keys,     [{"x": 1, "y": 2}],   "{ x: 1, y: 2 }"]
    - [arr_value,    [{"a": [1, 2]}],       "{ a: [ 1, 2 ] }"]
    - [bool_values,  [{"t": true, "f": false}], "{ t: true, f: false }"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-15T19:45:51Z
  iterations: 1
  pass_count: 26
  fail_count: 0
  total_invariants: 26
  notes: Synthesis succeeded in 1 iteration(s). 26 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
