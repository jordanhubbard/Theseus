spec: commitizen_rust
version: ">=3.9"
backend: rust_module(commitizen_rust)

docs: https://commitizen-tools.github.io/commitizen/

provenance:
  derived_from:
    - "https://commitizen-tools.github.io/commitizen/ — commitizen"
  notes:
    - "commitizen provides conventional commits tooling."
    - "commitizen.git is importable."
    - "commitizen.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant commitizen_rust.has_git_module:
  description: "commitizen.git is importable"
  category: presence
  kind: python_call_eq
  function: commitizen_has_git_module
  args: []
  expected: true

invariant commitizen_rust.has_changelog:
  description: "commitizen.changelog is importable"
  category: presence
  kind: python_call_eq
  function: commitizen_has_changelog
  args: []
  expected: true

invariant commitizen_rust.version_nonempty:
  description: "commitizen.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: commitizen_version_nonempty
  args: []
  expected: true

