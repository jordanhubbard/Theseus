spec: abc_extra2326
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attributes — class __name__ and type-identity checks."
    - "abc.ABC is a helper base class whose metaclass is ABCMeta; abc.ABC.__class__.__name__ == 'ABCMeta'."
    - "abc.abstractmethod is a plain function/decorator; abc.abstractclassmethod, abstractstaticmethod, abstractproperty are deprecated but present."
    - "abc.get_cache_token is a builtin_function_or_method."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2326.class_names:
  description: "abc module class and callable __name__ attribute checks"
  kind: python_call_eq
  category: class_name
  id_prefix: ab2326

  columns: [id, function, args, expected]
  rows:
    - ["ab2326001", "abc.ABC.__name__", [], "ABC"]
    - ["ab2326002", "abc.ABCMeta.__name__", [], "ABCMeta"]
    - ["ab2326003", "abc.abstractmethod.__name__", [], "abstractmethod"]
    - ["ab2326004", "abc.get_cache_token.__name__", [], "get_cache_token"]
    - ["ab2326005", "abc.abstractclassmethod.__name__", [], "abstractclassmethod"]
    - ["ab2326006", "abc.abstractstaticmethod.__name__", [], "abstractstaticmethod"]
    - ["ab2326007", "abc.abstractproperty.__name__", [], "abstractproperty"]

