spec: hashlib_extra469
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module public API"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks stable identity properties of hashlib module-level callables and set attributes"
    - "algorithms_guaranteed and algorithms_available are frozenset/set at runtime"
    - "new() and pbkdf2_hmac() are module-level functions with stable __name__ strings"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra469.module_function_names:
  description: "hashlib module-level function __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: HLN

  columns: [id, function, args, expected]
  rows:
    - [HLN001, hashlib.new.__name__.__eq__, ["new"], true]
    - [HLN002, hashlib.pbkdf2_hmac.__name__.__eq__, ["pbkdf2_hmac"], true]

table hashlib_extra469.module_function_qualname_types:
  description: "hashlib module-level function __qualname__ type checks"
  kind: python_call_eq
  category: identity
  id_prefix: HLQ

  columns: [id, function, args, expected]
  rows:
    - [HLQ001, hashlib.new.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [HLQ002, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra469.algorithms_set_types:
  description: "hashlib algorithms_guaranteed and algorithms_available are set-like"
  kind: python_call_eq
  category: identity
  id_prefix: HLA

  columns: [id, function, args, expected]
  rows:
    - [HLA001, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]
    - [HLA002, hashlib.algorithms_available.__class__.__name__.__eq__, ["set"], true]

table hashlib_extra469.algorithms_guaranteed_members:
  description: "Core digest algorithms guaranteed to be present in hashlib.algorithms_guaranteed"
  kind: python_call_eq
  category: membership
  id_prefix: HLG

  columns: [id, function, args, expected]
  rows:
    - [HLG001, hashlib.algorithms_guaranteed.__contains__, ["md5"], true]
    - [HLG002, hashlib.algorithms_guaranteed.__contains__, ["sha1"], true]
    - [HLG003, hashlib.algorithms_guaranteed.__contains__, ["sha256"], true]
    - [HLG004, hashlib.algorithms_guaranteed.__contains__, ["sha512"], true]
