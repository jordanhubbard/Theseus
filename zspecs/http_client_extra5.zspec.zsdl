spec: http_client_extra5
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
  notes:
    - "This spec extends http_client.zspec.zsdl through http_client_extra4.zspec.zsdl."
    - "http_client.zspec.zsdl covers: status code int-equality table, HTTP_PORT/HTTPS_PORT invariants, class __name__ table, responses dict for 200/201/301/404/500."
    - "http_client_extra.zspec.zsdl covers: class __name__ and __module__ for connection/response/exception classes; HTTPException base == 'Exception'; NotConnected/InvalidURL bases; type identity checks."
    - "http_client_extra2.zspec.zsdl covers: __qualname__ table for connection/exception classes; __module__ for HTTPException/HTTPResponse/NotConnected/InvalidURL; HTTP_PORT/HTTPS_PORT class and value."
    - "http_client_extra3.zspec.zsdl covers: BadStatusLine/RemoteDisconnected __qualname__/__module__/base; RemoteDisconnected base == 'BadStatusLine'; OK/NOT_FOUND/INTERNAL_SERVER_ERROR .value; OK/NOT_FOUND __class__.__name__ == 'HTTPStatus'."
    - "http_client_extra4.zspec.zsdl covers: CREATED/NO_CONTENT/MOVED_PERMANENTLY/BAD_REQUEST/UNAUTHORIZED/FORBIDDEN/METHOD_NOT_ALLOWED/BAD_GATEWAY/SERVICE_UNAVAILABLE .value; OK/NOT_FOUND/CREATED/INTERNAL_SERVER_ERROR .name; ImproperConnectionState name/qualname/module/base; IncompleteRead name/qualname/module/base; CannotSendRequest/CannotSendHeader names/qualnames/modules."
    - "Focus: new axes not yet tested in any prior http.client spec."
    - "responses dict extended — http_client.zspec.zsdl covers 200/201/301/404/500; additional responses (204/302/400/403/503) are new."
    - "HTTPStatus class __name__ and __module__ — the enum class itself (not its members) has not been inspected."
    - "FOUND.value and NOT_MODIFIED.value — extra3 covers OK/NOT_FOUND/INTERNAL_SERVER_ERROR; extra4 covers CREATED/NO_CONTENT/MOVED_PERMANENTLY; FOUND(302) and NOT_MODIFIED(304) are new."
    - "FOUND.name and NOT_MODIFIED.name — extra4 covers OK/NOT_FOUND/CREATED/INTERNAL_SERVER_ERROR name; FOUND and NOT_MODIFIED .name are new."
    - "CannotSendRequest/CannotSendHeader bases — extra4 covers their names/qualnames/modules but NOT the __bases__[0].__name__ hierarchy check."
    - "ImproperConnectionState base hierarchy — extra4 covers ImproperConnectionState.base == 'HTTPException'; this is already tested. CannotSendRequest/Header -> ImproperConnectionState is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# responses dict — additional status codes not in http_client.zspec.zsdl
# The base spec covers 200/201/301/404/500. The remaining standard codes
# (204, 302, 304, 400, 401, 403, 405, 502, 503) are new.
# ---------------------------------------------------------------------------

table http_client_extra5.responses_extended:
  kind: python_call_eq
  category: responses
  id_prefix: resp
  function: responses.__getitem__

  columns: [id, args, expected]
  rows:
    - [r204, [204], "No Content"            ]
    - [r302, [302], "Found"                 ]
    - [r400, [400], "Bad Request"           ]
    - [r403, [403], "Forbidden"             ]
    - [r503, [503], "Service Unavailable"   ]

# ---------------------------------------------------------------------------
# HTTPStatus enum class — __name__ and __module__
# Prior specs inspect enum members (OK, NOT_FOUND, etc.) but never inspect
# the HTTPStatus enum class itself.
# ---------------------------------------------------------------------------

invariant http_client_extra5.HTTPStatus.name:
  description: "http.client.HTTPStatus.__name__ == 'HTTPStatus'"
  category: class_names
  kind: python_call_eq
  function: HTTPStatus.__name__.__eq__
  args: ["HTTPStatus"]
  expected: true

invariant http_client_extra5.HTTPStatus.module:
  description: "http.client.HTTPStatus.__module__ == 'http'"
  category: modules
  kind: python_call_eq
  function: HTTPStatus.__module__.__eq__
  args: ["http"]
  expected: true

# ---------------------------------------------------------------------------
# FOUND and NOT_MODIFIED — .value and .name
# http_client_extra3 covers OK/NOT_FOUND/INTERNAL_SERVER_ERROR .value/.class_name.
# http_client_extra4 covers CREATED/NO_CONTENT/MOVED_PERMANENTLY/BAD_REQUEST/
#   UNAUTHORIZED/FORBIDDEN/METHOD_NOT_ALLOWED/BAD_GATEWAY/SERVICE_UNAVAILABLE .value,
#   and OK/NOT_FOUND/CREATED/INTERNAL_SERVER_ERROR .name.
# FOUND (302) and NOT_MODIFIED (304) .value and .name are entirely new.
# ---------------------------------------------------------------------------

invariant http_client_extra5.FOUND.value:
  description: "http.client.FOUND.value == 302"
  category: status_values
  kind: python_call_eq
  function: FOUND.value.__eq__
  args: [302]
  expected: true

invariant http_client_extra5.NOT_MODIFIED.value:
  description: "http.client.NOT_MODIFIED.value == 304"
  category: status_values
  kind: python_call_eq
  function: NOT_MODIFIED.value.__eq__
  args: [304]
  expected: true

invariant http_client_extra5.FOUND.name:
  description: "http.client.FOUND.name == 'FOUND'"
  category: status_names
  kind: python_call_eq
  function: FOUND.name.__eq__
  args: ["FOUND"]
  expected: true

invariant http_client_extra5.NOT_MODIFIED.name:
  description: "http.client.NOT_MODIFIED.name == 'NOT_MODIFIED'"
  category: status_names
  kind: python_call_eq
  function: NOT_MODIFIED.name.__eq__
  args: ["NOT_MODIFIED"]
  expected: true

# ---------------------------------------------------------------------------
# CannotSendRequest and CannotSendHeader base hierarchy
# http_client_extra4 covers their __name__/__qualname__/__module__ but NOT
# the __bases__[0].__name__ hierarchy. Both inherit ImproperConnectionState.
# ---------------------------------------------------------------------------

invariant http_client_extra5.CannotSendRequest.base:
  description: "http.client.CannotSendRequest.__bases__[0].__name__ == 'ImproperConnectionState'"
  category: hierarchy
  kind: python_call_eq
  function: CannotSendRequest.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ImproperConnectionState"

invariant http_client_extra5.CannotSendHeader.base:
  description: "http.client.CannotSendHeader.__bases__[0].__name__ == 'ImproperConnectionState'"
  category: hierarchy
  kind: python_call_eq
  function: CannotSendHeader.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ImproperConnectionState"
