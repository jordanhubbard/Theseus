spec: decimal_extra229
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal __mro__ chain contracts."
    - "decimal.Decimal.__mro__[0].__name__ == 'Decimal' — first entry in MRO is Decimal itself; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__mro__[1].__name__ == 'object' — second entry in MRO is object; verified Python 3.14.3 macOS."
    - "len(decimal.Decimal.__mro__) == 2 — MRO chain has exactly 2 entries: Decimal and object; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__name__ == 'Decimal' — class name; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__module__ == 'decimal' — module attribute; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__qualname__ == 'Decimal' — qualname matches name (top-level class); verified Python 3.14.3 macOS."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — direct base is object; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' — verified Python 3.14.3 macOS."
    - "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' — verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal __mro__ chain contracts
# Decimal has a minimal MRO: [Decimal, object]. No intermediate base classes.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra229.Decimal.mro_len:
  description: "len(decimal.Decimal.__mro__) == 2 — MRO chain has exactly 2 entries (Decimal, object); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__mro__.__len__"
  args: []
  expected: 2

invariant decimal_extra229.Decimal.mro_0_name:
  description: "decimal.Decimal.__mro__[0].__name__ == 'Decimal' — first MRO entry is Decimal itself; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__mro__[0].__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra229.Decimal.mro_1_name:
  description: "decimal.Decimal.__mro__[1].__name__ == 'object' — second MRO entry is object; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra229.Decimal.mro_0_module:
  description: "decimal.Decimal.__mro__[0].__module__ == 'decimal' — first MRO entry has module 'decimal'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__mro__[0].__module__.__eq__"
  args: ["decimal"]
  expected: true

invariant decimal_extra229.Decimal.mro_1_module:
  description: "decimal.Decimal.__mro__[1].__module__ == 'builtins' — second MRO entry (object) has module 'builtins'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__mro__[1].__module__.__eq__"
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal class identity contracts
# __name__, __module__, __qualname__, and __bases__ contracts.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra229.Decimal.class_name:
  description: "decimal.Decimal.__name__ == 'Decimal' — class name is 'Decimal'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra229.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal' — module attribute is 'decimal'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra229.Decimal.qualname:
  description: "decimal.Decimal.__qualname__ == 'Decimal' — qualname matches name for top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__qualname__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra229.Decimal.base_name:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object' — direct base is object; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal method qualname contracts
# Spot-check qualnames for __str__ and sqrt.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra229.Decimal.str_qualname:
  description: "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' — qualname includes class name; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__str__.__qualname__.__eq__
  args: ["Decimal.__str__"]
  expected: true

invariant decimal_extra229.Decimal.sqrt_qualname:
  description: "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' — qualname includes class name; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__eq__
  args: ["Decimal.sqrt"]
  expected: true
