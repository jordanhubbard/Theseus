spec: multiprocessing_extra616
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing class __doc__ type and Process property identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __doc__ type checks for Process and Queue, property identity checks on Process descriptors, and top-level function qualname checks"
  created_at: "2026-04-12T00:00:00Z"

table multiprocessing_extra616.doc_class_name:
  description: "Verify that __doc__ attributes of core multiprocessing classes are strings"
  kind: python_call_eq
  category: doc_type
  id_prefix: mp616dc
  columns: [id, function, args, expected]
  rows:
    - [mp616dc001, multiprocessing.Process.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [mp616dc002, multiprocessing.Queue.__doc__.__class__.__name__.__eq__, ["str"], true]

table multiprocessing_extra616.process_properties:
  description: "Verify that Process descriptors are property objects"
  kind: python_call_eq
  category: property_identity
  id_prefix: mp616pp
  columns: [id, function, args, expected]
  rows:
    - [mp616pp001, multiprocessing.Process.pid.__class__.__name__.__eq__, ["property"], true]
    - [mp616pp002, multiprocessing.Process.exitcode.__class__.__name__.__eq__, ["property"], true]
    - [mp616pp003, multiprocessing.Process.name.__class__.__name__.__eq__, ["property"], true]
    - [mp616pp004, multiprocessing.Process.daemon.__class__.__name__.__eq__, ["property"], true]
    - [mp616pp005, multiprocessing.Process.authkey.__class__.__name__.__eq__, ["property"], true]
    - [mp616pp006, multiprocessing.Process.sentinel.__class__.__name__.__eq__, ["property"], true]

table multiprocessing_extra616.function_qualnames:
  description: "Verify __qualname__ of top-level multiprocessing utility functions"
  kind: python_call_eq
  category: qualname
  id_prefix: mp616qn
  columns: [id, function, args, expected]
  rows:
    - [mp616qn001, multiprocessing.current_process.__qualname__.__eq__, ["current_process"], true]
    - [mp616qn002, multiprocessing.active_children.__qualname__.__eq__, ["active_children"], true]
    - [mp616qn003, multiprocessing.cpu_count.__qualname__.__eq__, ["cpu_count"], true]
