spec: socket_extra1876
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "socket module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party socket libraries"
  notes:
    - "Tests attribute access protocol membership in socket.socket and socket.error"
    - "socket.socket is a Python class wrapping a C socket; __getattr__/__setattr__/__delattr__ are not overridden"
    - "socket.error is an alias for OSError; no custom attribute protocol overrides"
    - "IP-level constants (IPPROTO_*, TCP_*, IP_*, SO_*, MSG_*) verified present in module dict on Unix/macOS"
  created_at: "2026-04-12"

table socket_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["sk1876-aa-001", "socket.socket.__dict__.__contains__", ["__getattr__"], false]
    - ["sk1876-aa-002", "socket.socket.__dict__.__contains__", ["__setattr__"], false]
    - ["sk1876-aa-003", "socket.socket.__dict__.__contains__", ["__delattr__"], false]
    - ["sk1876-aa-004", "socket.socket.__dict__.__contains__", ["__getattribute__"], false]
    - ["sk1876-aa-005", "socket.error.__dict__.__contains__", ["__getattr__"], false]
    - ["sk1876-aa-006", "socket.error.__dict__.__contains__", ["__setattr__"], false]
    - ["sk1876-aa-007", "socket.__dict__.__contains__", ["__getattr__"], false]
    - ["sk1876-aa-008", "socket.__dict__.__contains__", ["__setattr__"], false]

