spec: theseus_xml_dom_cr
version: ">=3.0"
backend: python_cleanroom(theseus_xml_dom_cr)
blocks: xml.dom

docs: https://docs.python.org/3/library/xml.dom.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xml.dom.html"
  not_derived_from:
    - "CPython source: Lib/xml/dom/__init__.py"
  notes:
    - "Clean-room xml.dom module. Do NOT import xml.dom."

error_model: python_exceptions

invariant theseus_xml_dom_cr.xmldom2_exceptions:
  description: "DOMException and related exceptions exist"
  category: behavior
  kind: python_call_eq
  function: xmldom2_exceptions
  args: []
  expected: true

invariant theseus_xml_dom_cr.xmldom2_node:
  description: "Node type constants are defined"
  category: behavior
  kind: python_call_eq
  function: xmldom2_node
  args: []
  expected: true

invariant theseus_xml_dom_cr.xmldom2_get_dom:
  description: "getDOMImplementation() returns a DOM implementation"
  category: behavior
  kind: python_call_eq
  function: xmldom2_get_dom
  args: []
  expected: true
