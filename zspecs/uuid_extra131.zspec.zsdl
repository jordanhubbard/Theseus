spec: uuid_extra131
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra130.zspec.zsdl — covers SafeUUID MRO member names and metaclass / SafeUUID module/doc/member names / uuid.__spec__ and __loader__ attribute identity (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant / type(UUID.hex).__name__=='property'."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ and __name__.__len__()==8 / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / uuid3/uuid5/getnode __qualname__.__len__()."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra130."
    - "Wave 283 theme: UUID class __doc__ length and identity / uuid function __doc__ lengths (uuid1/uuid3/uuid4/uuid5/getnode) / uuid module __doc__ length / uuid.UUID __name__ and MRO."
    - "uuid.UUID.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__.__len__() == 2787. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__doc__.__len__() == 258. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__doc__.__len__() == 23. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__doc__.__len__() == 65. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__doc__.__len__() == 67. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__doc__.__len__() == 287. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__doc__.__len__() == 1948. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__.__eq__('UUID') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__[0].__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__[1].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__doc__ is 2787 chars — it is the longest docstring in the uuid module by a wide margin. It documents the full UUID class including all constructor arguments (hex, bytes, bytes_le, fields, int, version, is_safe) with detailed explanations of each."
    - "Note: uuid4.__doc__ (23 chars) is the shortest of the uuid generator function docstrings. uuid4 generates a random UUID and has minimal parameters, hence the short docstring. uuid1 (258) is longest as it documents the node/clock_seq/time parameters."
    - "Note: uuid.UUID.__mro__ has length 2 ([UUID, object]) — UUID is a plain Python class with no explicit base class other than object, and uses __slots__ for memory efficiency."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__.__class__.__name__.__eq__('str')
# uuid.UUID.__doc__.__len__()==2787
#
# Wave 283 theme: UUID class __doc__ identity.
#
# uuid.UUID.__doc__ is the longest docstring in the uuid module at 2787 chars.
# It documents the full constructor signature and all keyword arguments (hex,
# bytes, bytes_le, fields, int, version, is_safe) with detailed explanations.
# No prior uuid spec anchors UUID.__doc__.__class__.__name__ or __len__() under
# uuiddoc131. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra131.UUID_class_doc:
  description: "uuid.UUID/__doc__/__class__.__name__.__eq__('str')==True / UUID/__doc__/__len__()==2787 — UUID.__doc__ is the longest docstring in the uuid module (2787 chars); documents the full constructor signature including hex/bytes/bytes_le/fields/int/version/is_safe arguments; no prior uuid spec anchors UUID.__doc__ identity or length; first uuiddoc131 anchor"
  kind: python_call_eq
  category: doc_identity
  id_prefix: uuiddoc131

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_doc_class, UUID.__doc__.__class__.__name__.__eq__, ["str"], true, "uuid.UUID.__doc__ is a str (Python-level class docstring from Lib/uuid.py)"]
    - [UUID_doc_len,   UUID.__doc__.__len__,                  [],       2787, "uuid.UUID.__doc__.__len__() is 2787 (longest docstring in the uuid module)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__doc__.__class__.__name__.__eq__('str') / __len__()==258
# uuid.uuid4.__doc__.__class__.__name__.__eq__('str') / __len__()==23
# uuid.uuid3.__doc__.__class__.__name__.__eq__('str') / __len__()==65
# uuid.uuid5.__doc__.__class__.__name__.__eq__('str') / __len__()==67
# uuid.getnode.__doc__.__class__.__name__.__eq__('str') / __len__()==287
#
# Wave 283 theme: uuid generator function __doc__ lengths.
#
# The five uuid generator functions have widely varying docstring lengths.
# uuid4 (23 chars) is the shortest — it takes no arguments and simply returns
# a random UUID. uuid1 (258 chars) is longest among generators — it documents
# the node, clock_seq, and time parameters. getnode (287 chars) has the longest
# docstring of all five functions. No prior uuid spec anchors these __doc__
# lengths under uuiddoc131. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra131.uuid_function_doc_lengths:
  description: "uuid.uuid1/__doc__/__class__.__name__.__eq__('str')==True / uuid1/__doc__/__len__()==258 / uuid4/__doc__/__len__()==23 / uuid3/__doc__/__len__()==65 / uuid5/__doc__/__len__()==67 / getnode/__doc__/__len__()==287 — uuid4 has the shortest function docstring (23 chars, no parameters to document); getnode has the longest (287); uuid1 documents node/clock_seq/time parameters (258); no prior uuid spec anchors these; first uuiddoc131 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: uuiddoc131

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_doc_class,   uuid1.__doc__.__class__.__name__.__eq__,   ["str"], true, "uuid.uuid1.__doc__ is a str (pure-Python function docstring)"]
    - [uuid1_doc_len,     uuid1.__doc__.__len__,                     [],      258,  "uuid.uuid1.__doc__.__len__() is 258 (documents node/clock_seq/time parameters)"]
    - [uuid4_doc_class,   uuid4.__doc__.__class__.__name__.__eq__,   ["str"], true, "uuid.uuid4.__doc__ is a str (pure-Python function docstring)"]
    - [uuid4_doc_len,     uuid4.__doc__.__len__,                     [],      23,   "uuid.uuid4.__doc__.__len__() is 23 (shortest uuid generator docstring — no parameters)"]
    - [uuid3_doc_class,   uuid3.__doc__.__class__.__name__.__eq__,   ["str"], true, "uuid.uuid3.__doc__ is a str (pure-Python function docstring)"]
    - [uuid3_doc_len,     uuid3.__doc__.__len__,                     [],      65,   "uuid.uuid3.__doc__.__len__() is 65 (documents namespace and name parameters for MD5 UUID)"]
    - [uuid5_doc_class,   uuid5.__doc__.__class__.__name__.__eq__,   ["str"], true, "uuid.uuid5.__doc__ is a str (pure-Python function docstring)"]
    - [uuid5_doc_len,     uuid5.__doc__.__len__,                     [],      67,   "uuid.uuid5.__doc__.__len__() is 67 (documents namespace and name parameters for SHA-1 UUID, 2 chars longer than uuid3)"]
    - [getnode_doc_class, getnode.__doc__.__class__.__name__.__eq__, ["str"], true, "uuid.getnode.__doc__ is a str (pure-Python function docstring)"]
    - [getnode_doc_len,   getnode.__doc__.__len__,                   [],      287,  "uuid.getnode.__doc__.__len__() is 287 (longest of the five uuid functions)"]

# ---------------------------------------------------------------------------
# uuid.__doc__.__class__.__name__.__eq__('str')
# uuid.__doc__.__len__()==1948
# uuid.UUID.__name__.__eq__('UUID')
# uuid.UUID.__name__.__len__()==4
# uuid.UUID.__mro__.__len__()==2
#
# Wave 283 theme: uuid module __doc__ and UUID class __name__/__mro__.
#
# uuid.__doc__ is the module-level docstring (1948 chars). UUID.__name__ is 'UUID'
# (4 chars). UUID.__mro__ has length 2 — [UUID, object] — because UUID inherits
# only from object (uses __slots__ for efficiency). uuid_extra94 anchors
# UUID.__mro__.__len__()==2 at table level; uuid_extra96 anchors UUID.__qualname__
# and __class__.__name__; this spec anchors uuid.__doc__.__len__() and
# UUID.__name__.__len__() under uuiddoc131. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra131.module_doc_and_UUID_name_mro:
  description: "uuid/__doc__/__class__.__name__.__eq__('str')==True / uuid/__doc__/__len__()==1948 / UUID/__name__.__eq__('UUID')==True / UUID/__name__/__len__()==4 / UUID/__mro__/__len__()==2 — uuid module __doc__ is 1948 chars; UUID.__name__ is 'UUID' (4 chars); UUID.__mro__ has 2 entries ([UUID, object]) since UUID inherits only from object; extra94 anchors mro len at table level; extra96 anchors UUID.__qualname__; first uuiddoc131 anchor for uuid.__doc__.__len__() and UUID.__name__.__len__()"
  kind: python_call_eq
  category: module_doc
  id_prefix: uuiddoc131

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class, __doc__.__class__.__name__.__eq__, ["str"],  true, "uuid.__doc__ is a str (module-level docstring from Lib/uuid.py)"]
    - [module_doc_len,   __doc__.__len__,                  [],        1948, "uuid.__doc__.__len__() is 1948 chars (module-level docstring explaining UUID versions, NAMESPACE constants, and RFC 4122)"]
    - [UUID_name_eq,     UUID.__name__.__eq__,             ["UUID"],  true, "uuid.UUID.__name__ is 'UUID' (the simple unqualified class name)"]
    - [UUID_name_len,    UUID.__name__.__len__,            [],        4,    "uuid.UUID.__name__.__len__() is 4 ('UUID' = 4 chars)"]
    - [UUID_mro_len,     "UUID.__mro__.__len__",           [],        2,    "uuid.UUID.__mro__.__len__() is 2 ([UUID, object]) — UUID inherits only from object, no intermediate base classes"]

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__.__len__()==2787 — standalone
#
# uuid.UUID.__doc__.__len__() is 2787. The UUID class docstring is the most
# comprehensive docstring in the uuid module: it documents all seven constructor
# keyword arguments (hex, bytes, bytes_le, fields, int, version, is_safe), their
# mutual exclusivity constraints, the 'fields' argument as a 6-tuple, and the
# variant/version/is_safe semantics. At 2787 chars it is 44x longer than the
# shortest uuid function docstring (uuid4, 23 chars). No prior uuid spec anchors
# UUID.__doc__.__len__() as a standalone under uuiddoc131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra131.UUID_doc_len_2787:
  description: "uuid.UUID.__doc__.__len__() == 2787 — UUID class docstring is the longest in the uuid module (2787 chars); documents all seven constructor keyword arguments and their mutual exclusivity; 44x longer than uuid4.__doc__ (23 chars); no prior uuid spec anchors UUID.__doc__.__len__() as a standalone; first standalone under uuiddoc131"
  category: doc_lengths
  kind: python_call_eq
  function: UUID.__doc__.__len__
  args: []
  expected: 2787

# ---------------------------------------------------------------------------
# uuid.uuid4.__doc__.__len__()==23 — standalone
#
# uuid.uuid4.__doc__.__len__() is 23. uuid4 generates a random UUID using
# os.urandom() and takes no explicit arguments. Its brevity results in the
# shortest docstring of any uuid generator function. The full docstring is
# 'Generate a random UUID.' (23 chars). No prior uuid spec anchors
# uuid4.__doc__.__len__() as a standalone under uuiddoc131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra131.uuid4_doc_len_23:
  description: "uuid.uuid4.__doc__.__len__() == 23 — uuid4 generates a random UUID (no explicit arguments), yielding the shortest uuid generator docstring ('Generate a random UUID.' = 23 chars); no prior uuid spec anchors uuid4.__doc__.__len__() as a standalone; first standalone under uuiddoc131"
  category: doc_lengths
  kind: python_call_eq
  function: uuid4.__doc__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# uuid.getnode.__doc__.__len__()==287 — standalone
#
# uuid.getnode.__doc__.__len__() is 287. getnode returns the hardware address
# as a 48-bit positive integer, trying multiple platform-specific strategies
# (ifconfig, ip, ipconfig, etc.) before falling back to a random multicast
# address. The length of its docstring (287) reflects the complexity of the
# platform fallback logic it describes. No prior uuid spec anchors
# getnode.__doc__.__len__() as a standalone under uuiddoc131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra131.getnode_doc_len_287:
  description: "uuid.getnode.__doc__.__len__() == 287 — getnode returns the hardware address as a 48-bit int, trying multiple platform strategies; its docstring (287 chars) is the longest of the uuid function docstrings, reflecting platform-fallback complexity; no prior uuid spec anchors this as a standalone; first standalone under uuiddoc131"
  category: doc_lengths
  kind: python_call_eq
  function: getnode.__doc__.__len__
  args: []
  expected: 287

# ---------------------------------------------------------------------------
# uuid.__doc__.__len__()==1948 — standalone
#
# uuid.__doc__.__len__() is 1948. The uuid module docstring provides an overview
# of UUID formats (including fields, hex string, bytes, integer representations),
# the NAMESPACE constants (dns, url, oid, x500), and references RFC 4122 for
# the specification of UUID versions 1, 3, 4, and 5. At 1948 chars it is shorter
# than UUID.__doc__ (2787) but longer than any individual function docstring.
# No prior uuid spec anchors uuid.__doc__.__len__() as a standalone under uuiddoc131.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra131.module_doc_len_1948:
  description: "uuid.__doc__.__len__() == 1948 — uuid module docstring (1948 chars) covers UUID format representations, NAMESPACE constants, and RFC 4122 reference; shorter than UUID.__doc__ (2787) but longer than any single function docstring; no prior uuid spec anchors uuid.__doc__.__len__() as a standalone; first standalone under uuiddoc131"
  category: module_doc
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1948

