    - ["as3061028", operator.contains, [asyncio.StreamWriter.__dict__,     "__await__"], false]

# ---------------------------------------------------------------------------
# __anext__ dict-presence — operator.contains(Cls.__dict__, '__anext__')
#
# asyncio.StreamReader defines __anext__ directly in its own __dict__ (true) —
# StreamReader supports async iteration with 'async for line in reader:'.
# All other asyncio classes return false — they do not implement async iteration.
# ---------------------------------------------------------------------------

