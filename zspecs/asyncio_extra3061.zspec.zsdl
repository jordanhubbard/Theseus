spec: as3061
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (as3061): __aexit__, __await__, __anext__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Key findings for __aexit__: asyncio.Timeout and asyncio.TaskGroup define __aexit__ in their own __dict__ (true) — they are native async context managers."
    - "asyncio.Lock, asyncio.Semaphore, asyncio.Condition, asyncio.BoundedSemaphore inherit __aexit__ from a shared mixin; __aexit__ is NOT in their own __dict__ (false)."
    - "All other asyncio classes return false for __aexit__."
    - "Key findings for __await__: asyncio.Task and asyncio.Future define __await__ in their own __dict__ (true) — both are directly awaitable."
    - "asyncio.Task inherits from asyncio.Future and also defines __await__ directly in its own __dict__."
    - "All other asyncio classes return false for __await__."
    - "Key findings for __anext__: asyncio.StreamReader defines __anext__ in its own __dict__ (true) — it supports async iteration (async for line in reader)."
    - "All other asyncio classes return false for __anext__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# asyncio.Timeout and asyncio.TaskGroup define __aexit__ directly (true) —
# they are native async context managers used with 'async with'.
# Lock, Semaphore, Condition, BoundedSemaphore inherit __aexit__ from a shared
# mixin; it is NOT in their own __dict__ (false).
# Task, Future, Queue, Event, Handle, TimerHandle, StreamReader, StreamWriter
# define no __aexit__ in their own __dict__ (false).
# ---------------------------------------------------------------------------

table as3061.aexit:
  description: "asyncio types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3061

  columns: [id, function, args, expected]
  rows:
    - ["as3061001", operator.contains, [asyncio.Task.__dict__,             "__aexit__"], false]
    - ["as3061002", operator.contains, [asyncio.Future.__dict__,           "__aexit__"], false]
    - ["as3061003", operator.contains, [asyncio.Queue.__dict__,            "__aexit__"], false]
    - ["as3061004", operator.contains, [asyncio.Event.__dict__,            "__aexit__"], false]
    - ["as3061005", operator.contains, [asyncio.Semaphore.__dict__,        "__aexit__"], false]
    - ["as3061006", operator.contains, [asyncio.Lock.__dict__,             "__aexit__"], false]
    - ["as3061007", operator.contains, [asyncio.Condition.__dict__,        "__aexit__"], false]
    - ["as3061008", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__aexit__"], false]
    - ["as3061009", operator.contains, [asyncio.Handle.__dict__,           "__aexit__"], false]
    - ["as3061010", operator.contains, [asyncio.TimerHandle.__dict__,      "__aexit__"], false]
    - ["as3061011", operator.contains, [asyncio.Timeout.__dict__,          "__aexit__"], true]
    - ["as3061012", operator.contains, [asyncio.TaskGroup.__dict__,        "__aexit__"], true]
    - ["as3061013", operator.contains, [asyncio.StreamReader.__dict__,     "__aexit__"], false]
    - ["as3061014", operator.contains, [asyncio.StreamWriter.__dict__,     "__aexit__"], false]

# ---------------------------------------------------------------------------
# __await__ dict-presence — operator.contains(Cls.__dict__, '__await__')
#
# asyncio.Future defines __await__ directly in its own __dict__ (true) —
# Future is directly awaitable via the await expression.
# asyncio.Task also defines __await__ directly in its own __dict__ (true) —
# Task subclasses Future but independently defines __await__.
# All other asyncio classes return false — they are not awaitable objects.
# ---------------------------------------------------------------------------

table as3061.await:
  description: "asyncio types __await__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
