spec: fire_rust
version: ">=3.9"
backend: rust_module(fire_rust)

docs: https://github.com/google/python-fire

provenance:
  derived_from:
    - "https://github.com/google/python-fire — Python Fire documentation"
  not_derived_from:
    - "fire source: fire/__init__.py"
  notes:
    - "Python Fire automatically generates CLIs from Python objects."
    - "fire.Fire is the main function."
    - "fire.__version__ is a non-empty string."
    - "fire.Fire is callable."
    - "Expose fire_has_fire() -> bool: hasattr(fire, 'Fire')."
    - "Expose fire_main_callable() -> bool: callable(fire.Fire)."
    - "Expose fire_version_nonempty() -> bool: len(fire.__version__) > 0."
    - "All test vectors verified against fire 0.7.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# fire_has_fire — Fire function present
invariant fire_rust.module.has_fire:
  description: "fire.Fire is available"
  category: module
  kind: python_call_eq
  function: fire_has_fire
  args: []
  expected: true

# fire_main_callable — Fire is callable
invariant fire_rust.module.main_callable:
  description: "fire.Fire is callable"
  category: callable
  kind: python_call_eq
  function: fire_main_callable
  args: []
  expected: true

# fire_version_nonempty — version non-empty
invariant fire_rust.version.nonempty:
  description: "fire.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: fire_version_nonempty
  args: []
  expected: true

