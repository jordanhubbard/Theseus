spec: io_extra310
version: ">=3.10"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BytesIO — read length after constructing with b'hello'
# BytesIO(b'hello').read() returns b'hello'; __len__ == 5
# ---------------------------------------------------------------------------

invariant io.BytesIO.read_len:
  description: "BytesIO(b'hello').read().__len__() == 5"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: read
  method_chain: __len__
  expected: 5

invariant io.BytesIO.tell_after_read:
  description: "BytesIO(b'hello').read(); tell() == 5 — position advances to end after read"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: tell
  expected: 5

invariant io.BytesIO.getvalue_empty_len:
  description: "BytesIO().getvalue().__len__() == 0 — empty buffer has zero length"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: getvalue
  method_chain: __len__
  expected: 0

invariant io.BytesIO.readable:
  description: "BytesIO(b'hello').readable() == True"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: readable
  expected: true

invariant io.BytesIO.writable:
  description: "BytesIO(b'hello').writable() == True"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: writable
  expected: true

# ---------------------------------------------------------------------------
# StringIO — read and position behaviors
# ---------------------------------------------------------------------------

invariant io.StringIO.read_eq:
  description: "StringIO('hello').read().__eq__('hello') == True"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  method_chain: __eq__
  method_chain_args: ["hello"]
  expected: true

invariant io.StringIO.tell_after_read:
  description: "StringIO('hello').read(); tell() == 5 — position advances to end after read"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: tell
  expected: 5

invariant io.StringIO.getvalue_empty_eq:
  description: "StringIO().getvalue().__eq__('') == True — empty buffer returns empty string"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: []
  method: getvalue
  method_chain: __eq__
  method_chain_args: [""]
  expected: true
