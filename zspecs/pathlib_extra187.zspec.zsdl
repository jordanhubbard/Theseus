spec: pathlib_extra187
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "pathlib.Path.home.__name__=='home' (len=4); pathlib.Path.cwd.__name__=='cwd' (len=3); pathlib.Path.stat.__name__=='stat' (len=4); pathlib.Path.chmod.__name__=='chmod' (len=5)."
    - "pathlib.Path.exists.__name__=='exists' (len=6); pathlib.Path.is_dir.__name__=='is_dir' (len=6); pathlib.Path.is_file.__name__=='is_file' (len=7); pathlib.Path.is_symlink.__name__=='is_symlink' (len=10)."
    - "Method name lengths in ascending order: cwd(3) < home(4)==stat(4) < chmod(5) < exists(6)==is_dir(6) < is_file(7) < is_symlink(10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path short navigation method names (len 3-4)
# cwd (len=3), home (len=4), stat (len=4)
# ---------------------------------------------------------------------------

table pathlib_extra187.path_short_method_names:
  description: "pathlib.Path short navigation method names: cwd.__name__=='cwd' (len=3); home.__name__=='home' (len=4); stat.__name__=='stat' (len=4); cwd (3) < home (4) == stat (4)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath187

  columns: [id, function, args, expected, description]
  rows:
    - [cwd_name,      Path.cwd.__name__.__eq__,   ["cwd"],  true, "pathlib.Path.cwd.__name__ == 'cwd' — the classmethod for getting the current directory has name 'cwd'; len('cwd')==3: c(1)w(2)d(3); cwd (3) is the shortest method name in this spec; confirmed Python 3.14.3 macOS"]
    - [cwd_name_len,  Path.cwd.__name__.__len__,  [],       3,    "pathlib.Path.cwd.__name__.__len__() == 3 — 'cwd' has 3 characters; cwd (3) < home (4): cwd is shorter than home; confirmed Python 3.14.3 macOS"]
    - [home_name,     Path.home.__name__.__eq__,  ["home"], true, "pathlib.Path.home.__name__ == 'home' — the classmethod for getting the user home directory has name 'home'; len('home')==4: h(1)o(2)m(3)e(4); confirmed Python 3.14.3 macOS"]
    - [home_name_len, Path.home.__name__.__len__, [],       4,    "pathlib.Path.home.__name__.__len__() == 4 — 'home' has 4 characters; home (4) == stat (4): same length as stat; confirmed Python 3.14.3 macOS"]
    - [stat_name,     Path.stat.__name__.__eq__,  ["stat"], true, "pathlib.Path.stat.__name__ == 'stat' — the method for getting file statistics has name 'stat'; len('stat')==4: s(1)t(2)a(3)t(4); stat (4) == home (4): same length as home; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path medium navigation method names (len 5-6)
# chmod (len=5), exists (len=6), is_dir (len=6)
# ---------------------------------------------------------------------------

table pathlib_extra187.path_medium_method_names:
  description: "pathlib.Path medium navigation method names: chmod.__name__=='chmod' (len=5); exists.__name__=='exists' (len=6); is_dir.__name__=='is_dir' (len=6); chmod (5) < exists (6) == is_dir (6)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath187

  columns: [id, function, args, expected, description]
  rows:
    - [chmod_name,      Path.chmod.__name__.__eq__,    ["chmod"],  true, "pathlib.Path.chmod.__name__ == 'chmod' — the method for changing file permissions has name 'chmod'; len('chmod')==5: c(1)h(2)m(3)o(4)d(5); chmod (5) < exists (6); confirmed Python 3.14.3 macOS"]
    - [chmod_name_len,  Path.chmod.__name__.__len__,   [],         5,    "pathlib.Path.chmod.__name__.__len__() == 5 — 'chmod' has 5 characters; chmod (5) < exists (6): chmod is 1 char shorter than exists; confirmed Python 3.14.3 macOS"]
    - [exists_name,     Path.exists.__name__.__eq__,   ["exists"], true, "pathlib.Path.exists.__name__ == 'exists' — the method for testing path existence has name 'exists'; len('exists')==6: e(1)x(2)i(3)s(4)t(5)s(6); exists (6) == is_dir (6); confirmed Python 3.14.3 macOS"]
    - [exists_name_len, Path.exists.__name__.__len__,  [],         6,    "pathlib.Path.exists.__name__.__len__() == 6 — 'exists' has 6 characters; exists (6) == is_dir (6): same length as is_dir; confirmed Python 3.14.3 macOS"]
    - [isdir_name,      Path.is_dir.__name__.__eq__,   ["is_dir"], true, "pathlib.Path.is_dir.__name__ == 'is_dir' — the method for testing directory status has name 'is_dir'; len('is_dir')==6: i(1)s(2)_(3)d(4)i(5)r(6); is_dir (6) == exists (6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path longer navigation method names (len 7-10)
# is_file (len=7), is_symlink (len=10)
# ---------------------------------------------------------------------------

table pathlib_extra187.path_longer_method_names:
  description: "pathlib.Path longer navigation method names: is_file.__name__=='is_file' (len=7); is_symlink.__name__=='is_symlink' (len=10); is_file (7) < is_symlink (10); is_symlink (10) is the longest method name in this spec"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpath187

  columns: [id, function, args, expected, description]
  rows:
    - [isfile_name,       Path.is_file.__name__.__eq__,      ["is_file"],    true, "pathlib.Path.is_file.__name__ == 'is_file' — the method for testing regular-file status has name 'is_file'; len('is_file')==7: i(1)s(2)_(3)f(4)i(5)l(6)e(7); is_file (7) < is_symlink (10); confirmed Python 3.14.3 macOS"]
    - [isfile_name_len,   Path.is_file.__name__.__len__,     [],             7,    "pathlib.Path.is_file.__name__.__len__() == 7 — 'is_file' has 7 characters; is_file (7) < is_symlink (10): is_file is 3 chars shorter than is_symlink; confirmed Python 3.14.3 macOS"]
    - [issymlink_name,    Path.is_symlink.__name__.__eq__,   ["is_symlink"], true, "pathlib.Path.is_symlink.__name__ == 'is_symlink' — the method for testing symlink status has name 'is_symlink'; len('is_symlink')==10: i(1)s(2)_(3)s(4)y(5)m(6)l(7)i(8)n(9)k(10); is_symlink (10) is the longest; confirmed Python 3.14.3 macOS"]
    - [issymlink_name_len, Path.is_symlink.__name__.__len__, [],             10,   "pathlib.Path.is_symlink.__name__.__len__() == 10 — 'is_symlink' has 10 characters; is_symlink (10) > is_file (7): is_symlink is 3 chars longer than is_file; confirmed Python 3.14.3 macOS"]
    - [isfile_ne_issymlink, Path.is_file.__name__.__eq__,   ["is_symlink"], false, "pathlib.Path.is_file.__name__.__eq__('is_symlink') == False — 'is_file' != 'is_symlink'; the two method names are distinct; is_file (7) != is_symlink (10); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra187.path_home_name_is_home:
  description: "pathlib.Path.home.__name__ == 'home' — classmethod for home directory; len('home')==4: h(1)o(2)m(3)e(4); home (4) > cwd (3); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.home.__name__.__eq__
  args: ["home"]
  expected: true

invariant pathlib_extra187.path_cwd_name_len_is_3:
  description: "pathlib.Path.cwd.__name__.__len__() == 3 — 'cwd' has 3 characters; cwd (3) is the shortest method name in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.cwd.__name__.__len__
  args: []
  expected: 3

invariant pathlib_extra187.path_stat_name_is_stat:
  description: "pathlib.Path.stat.__name__ == 'stat' — method for file statistics; len('stat')==4: s(1)t(2)a(3)t(4); stat (4) == home (4): same length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.stat.__name__.__eq__
  args: ["stat"]
  expected: true

invariant pathlib_extra187.path_chmod_name_len_is_5:
  description: "pathlib.Path.chmod.__name__.__len__() == 5 — 'chmod' has 5 characters; chmod (5) < exists (6): chmod is 1 char shorter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.chmod.__name__.__len__
  args: []
  expected: 5

invariant pathlib_extra187.path_exists_name_is_exists:
  description: "pathlib.Path.exists.__name__ == 'exists' — method for testing path existence; len('exists')==6: e(1)x(2)i(3)s(4)t(5)s(6); exists (6) == is_dir (6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.exists.__name__.__eq__
  args: ["exists"]
  expected: true

invariant pathlib_extra187.path_is_dir_name_len_is_6:
  description: "pathlib.Path.is_dir.__name__.__len__() == 6 — 'is_dir' has 6 characters; is_dir (6) == exists (6): same length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.is_dir.__name__.__len__
  args: []
  expected: 6

invariant pathlib_extra187.path_is_file_name_is_is_file:
  description: "pathlib.Path.is_file.__name__ == 'is_file' — method for testing regular-file status; len('is_file')==7: i(1)s(2)_(3)f(4)i(5)l(6)e(7); is_file (7) < is_symlink (10); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.is_file.__name__.__eq__
  args: ["is_file"]
  expected: true

invariant pathlib_extra187.path_is_symlink_name_len_is_10:
  description: "pathlib.Path.is_symlink.__name__.__len__() == 10 — 'is_symlink' has 10 characters; is_symlink (10) is the longest method name in this spec; is_symlink (10) > is_file (7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.is_symlink.__name__.__len__
  args: []
  expected: 10
