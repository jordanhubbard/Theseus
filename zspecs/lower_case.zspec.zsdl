spec: lower_case
version: ">=3.0.0"
backend: node(lower-case)

docs: https://www.npmjs.com/package/lower-case

provenance:
  derived_from:
    - "lower-case README — https://www.npmjs.com/package/lower-case"
    - "Test vectors verified with lower-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lower-case source"
  notes:
    - "lower-case is an npm package. Install: npm install lower-case"
    - "Converts a string to lower case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lower_case.lowerCase:
  kind: node_module_call_eq
  function: lowerCase
  category: string
  id_prefix: lcase

  columns: [id, args, expected]
  rows:
    - [upper,   ["HELLO WORLD"],  "hello world"]
    - [mixed,   ["FooBar"],       "foobar"]
    - [lower,   ["hello"],        "hello"]
