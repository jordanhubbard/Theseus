spec: tracemalloc_extra5
version: ">=3.4"
backend: python_module(tracemalloc)

docs: https://docs.python.org/3/library/tracemalloc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tracemalloc.html — Python tracemalloc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tracemalloc.py"
    - "CPython source: Modules/_tracemalloc.c"
    - "tracemalloc.zspec.zsdl — covers function __name__ table, class __name__ table, Snapshot.__module__, is_tracing, get_traceback_limit"
    - "tracemalloc_extra.zspec.zsdl — covers class __name__ table, Snapshot.__module__, function __name__ table"
    - "tracemalloc_extra2.zspec.zsdl — covers individual class __name__ invariants, class __module__ table for all classes"
    - "tracemalloc_extra3.zspec.zsdl — covers class __bases__[0].__name__ for Snapshot/Filter/StatisticDiff/Statistic/Frame, class __qualname__ table (Snapshot/Filter/StatisticDiff/Statistic/Traceback/Frame)"
    - "tracemalloc_extra4.zspec.zsdl — covers function __qualname__ and __module__ tables, DomainFilter.__qualname__, get_traceback_limit return type"
  notes:
    - "This spec extends tracemalloc_extra4.zspec.zsdl."
    - "Focus: Traceback.__bases__[0].__name__ (standalone invariant; extra3 notes it but never writes the invariant); DomainFilter.__bases__[0].__name__ (not in extra3); tracemalloc.__name__ module attribute; Snapshot/Filter/Traceback method __name__ checks."
    - "tracemalloc_extra3 lists Traceback.__bases__[0].__name__ == 'Sequence' in notes only — no invariant was written for it."
    - "Traceback inherits from collections.abc.Sequence, so __bases__[0].__name__ == 'Sequence'."
    - "DomainFilter inherits directly from object: __bases__[0].__name__ == 'object'."
    - "tracemalloc.__name__ == 'tracemalloc' — module-level __name__ attribute not covered in any prior tracemalloc spec."
    - "Snapshot.compare_to and Snapshot.filter_traces are instance methods with __name__ matching their simple name."
    - "Filter.__init__ is a regular function; Filter.__name__ attribute on the class itself is already covered; method __name__ checks are new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tracemalloc.__name__ — module-level attribute
# No prior tracemalloc spec verifies the module's own __name__ attribute.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra5.module_name:
  description: "tracemalloc.__name__ == 'tracemalloc'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["tracemalloc"]
  expected: true

# ---------------------------------------------------------------------------
# Traceback.__bases__[0].__name__ — standalone invariant
# tracemalloc_extra3 notes this in the provenance but never writes the invariant.
# Traceback inherits from collections.abc.Sequence, not object.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra5.Traceback.base_name:
  description: "tracemalloc.Traceback.__bases__[0].__name__ == 'Sequence' — Traceback inherits from collections.abc.Sequence"
  category: hierarchy
  kind: python_call_eq
  function: Traceback.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Sequence"

# ---------------------------------------------------------------------------
# DomainFilter.__bases__[0].__name__ — not covered in any prior spec
# tracemalloc_extra3 covers Snapshot/Filter/StatisticDiff/Statistic/Frame but omits DomainFilter.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra5.DomainFilter.base_name:
  description: "tracemalloc.DomainFilter.__bases__[0].__name__ == 'object' — DomainFilter inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: DomainFilter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Snapshot method __name__ checks
# No prior tracemalloc spec checks Snapshot method names.
# Snapshot.compare_to and Snapshot.filter_traces are the two primary instance methods.
# ---------------------------------------------------------------------------

table tracemalloc_extra5.Snapshot_method_names:
  description: "Snapshot methods have __name__ matching their simple name"
  kind: python_call_eq
  category: method_names
  id_prefix: Snap_mname

  columns: [id, function, args, expected]
  rows:
    - [compare_to,    Snapshot.compare_to.__name__.__eq__,    ["compare_to"],    true]
    - [filter_traces, Snapshot.filter_traces.__name__.__eq__, ["filter_traces"], true]

# ---------------------------------------------------------------------------
# Snapshot method __class__.__name__ type checks
# No prior tracemalloc spec verifies that Snapshot methods are plain Python functions.
# ---------------------------------------------------------------------------

table tracemalloc_extra5.Snapshot_method_types:
  description: "Snapshot methods are plain Python functions"
  kind: python_call_eq
  category: method_types
  id_prefix: Snap_mtype

  columns: [id, function, args, expected]
  rows:
    - [compare_to,    Snapshot.compare_to.__class__.__name__.__eq__,    ["function"], true]
    - [filter_traces, Snapshot.filter_traces.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# DomainFilter.__qualname__ is already covered in tracemalloc_extra4.
# Here we add __module__ for DomainFilter as a standalone invariant —
# tracemalloc_extra2 covers it only via a table row; this is an explicit named invariant.
# ---------------------------------------------------------------------------

invariant tracemalloc_extra5.DomainFilter.module:
  description: "tracemalloc.DomainFilter.__module__ == 'tracemalloc' — defined in the tracemalloc module"
  category: class_attrs
  kind: python_call_eq
  function: DomainFilter.__module__.__eq__
  args: ["tracemalloc"]
  expected: true
