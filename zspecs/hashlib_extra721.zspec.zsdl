spec: hashlib_extra721
version: ">=3.9"
backend: python_module(hashlib)
docs: "Behavioral spec covering sha3 and shake class qualnames and module attributes in hashlib"
error_model: python_exceptions

provenance:
  derived_from: "hashlib stdlib documentation and CPython source"
  not_derived_from: "any third-party hashlib extension"
  notes: "sha3 and shake types are implemented in _sha3 C extension; blake2 types have str docstrings"
  created_at: "2026-04-12"

table hashlib_extra721.sha3_qualnames:
  description: "sha3 and shake class qualnames and module attributes"
  kind: python_call_eq
  category: qualname
  id_prefix: hl721qn
  columns: [id, function, args, expected]
  rows:
    - [hl721qn001, hashlib.sha3_224.__qualname__.__eq__, ["sha3_224"], true]
    - [hl721qn002, hashlib.sha3_224.__module__.__eq__, ["_sha3"], true]
    - [hl721qn003, hashlib.sha3_256.__qualname__.__eq__, ["sha3_256"], true]
    - [hl721qn004, hashlib.sha3_256.__module__.__eq__, ["_sha3"], true]
    - [hl721qn005, hashlib.sha3_384.__qualname__.__eq__, ["sha3_384"], true]
    - [hl721qn006, hashlib.sha3_512.__qualname__.__eq__, ["sha3_512"], true]
    - [hl721qn007, hashlib.shake_128.__qualname__.__eq__, ["shake_128"], true]
    - [hl721qn008, hashlib.shake_128.__module__.__eq__, ["_sha3"], true]
    - [hl721qn009, hashlib.shake_256.__qualname__.__eq__, ["shake_256"], true]
    - [hl721qn010, hashlib.shake_256.__module__.__eq__, ["_sha3"], true]
    - [hl721qn011, hashlib.blake2b.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl721qn012, hashlib.blake2s.__doc__.__class__.__name__.__eq__, ["str"], true]
