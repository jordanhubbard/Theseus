spec: socket_extra285
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module function identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c, Lib/socket.py"
  notes:
    - "gethostname, gethostbyname, getnameinfo, setdefaulttimeout, getdefaulttimeout are C builtins; __module__ is '_socket'"
    - "getfqdn, create_connection, create_server, socketpair, fromfd are pure Python; __module__ is 'socket'"
    - "getaddrinfo is re-exported from pure Python wrapper; __module__ is 'socket'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra285.func_names:
  description: "socket module function __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: skname

  columns: [id, function, args, expected, description]
  rows:
    - [skname001, socket.gethostname.__name__, [], gethostname, "gethostname __name__"]
    - [skname002, socket.gethostbyname.__name__, [], gethostbyname, "gethostbyname __name__"]
    - [skname003, socket.getfqdn.__name__, [], getfqdn, "getfqdn __name__"]
    - [skname004, socket.create_connection.__name__, [], create_connection, "create_connection __name__"]
    - [skname005, socket.create_server.__name__, [], create_server, "create_server __name__"]
    - [skname006, socket.getaddrinfo.__name__, [], getaddrinfo, "getaddrinfo __name__"]
    - [skname007, socket.getnameinfo.__name__, [], getnameinfo, "getnameinfo __name__"]
    - [skname008, socket.setdefaulttimeout.__name__, [], setdefaulttimeout, "setdefaulttimeout __name__"]
    - [skname009, socket.getdefaulttimeout.__name__, [], getdefaulttimeout, "getdefaulttimeout __name__"]

table socket_extra285.func_modules:
  description: "socket module function __module__ for pure-Python functions"
  kind: python_call_eq
  category: identity
  id_prefix: skmod

  columns: [id, function, args, expected, description]
  rows:
    - [skmod001, socket.getfqdn.__module__, [], socket, "getfqdn is pure Python in socket"]
    - [skmod002, socket.create_connection.__module__, [], socket, "create_connection is pure Python in socket"]
    - [skmod003, socket.create_server.__module__, [], socket, "create_server is pure Python in socket"]
    - [skmod004, socket.getaddrinfo.__module__, [], socket, "getaddrinfo wrapper is in socket"]
    - [skmod005, socket.socketpair.__module__, [], socket, "socketpair is pure Python in socket"]
    - [skmod006, socket.fromfd.__module__, [], socket, "fromfd is pure Python in socket"]
    - [skmod007, socket.gethostname.__module__, [], _socket, "gethostname is a C builtin in _socket"]
    - [skmod008, socket.gethostbyname.__module__, [], _socket, "gethostbyname is a C builtin in _socket"]
    - [skmod009, socket.getnameinfo.__module__, [], _socket, "getnameinfo is a C builtin in _socket"]

invariant socket_extra285.socketpair_name:
  description: "socketpair __name__ is socketpair"
  category: identity
  kind: python_call_eq
  function: socket.socketpair.__name__
  args: []
  expected: socketpair

invariant socket_extra285.setdefaulttimeout_module:
  description: "setdefaulttimeout is a C builtin in _socket"
  category: identity
  kind: python_call_eq
  function: socket.setdefaulttimeout.__module__
  args: []
  expected: _socket

invariant socket_extra285.getdefaulttimeout_module:
  description: "getdefaulttimeout is a C builtin in _socket"
  category: identity
  kind: python_call_eq
  function: socket.getdefaulttimeout.__module__
  args: []
  expected: _socket
