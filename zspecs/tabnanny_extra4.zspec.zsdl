spec: tabnanny_extra4
version: ">=3.9"
backend: python_module(tabnanny)

docs: https://docs.python.org/3/library/tabnanny.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tabnanny.html — Python tabnanny documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tabnanny.py"
  notes:
    - "This spec extends tabnanny.zspec.zsdl through tabnanny_extra3.zspec.zsdl."
    - "tabnanny covers: check/__name__, process_tokens/__name__, NannyNag/__name__/__module__/__bases__[0], NannyNag method names (get_lineno/get_line/get_msg), verbose/filename_only type+value."
    - "tabnanny_extra covers: same names/modules/hierarchy, verbose/filename_only, method names (get_lineno/get_msg/get_filename note — get_filename absent in 3.12), NannyNag is type."
    - "tabnanny_extra2 covers: check/__module__/__qualname__, process_tokens/__module__, NannyNag/__qualname__, function_names table."
    - "tabnanny_extra3 covers: process_tokens/__qualname__, NannyNag.__bases__.__len__, NannyNag.__module__ type str, NannyNag.get_lineno/__qualname__, NannyNag.get_msg/__qualname__, check.__name__ type str."
    - "NEW in this spec: tabnanny.__name__ (module attr); tabnanny.__spec__.name; check/__class__.__name__=='function'; process_tokens/__class__.__name__=='function'; NannyNag.get_line/__qualname__; check/__code__.co_name; process_tokens/__code__.co_name."
    - "tabnanny.__name__ == 'tabnanny' — the module's own __name__ attribute, distinct from any function name."
    - "tabnanny.__spec__.name == 'tabnanny' — the importlib ModuleSpec records the module name."
    - "check and process_tokens are both plain Python functions; their __class__.__name__ is 'function'."
    - "tabnanny.NannyNag.get_line.__qualname__ == 'NannyNag.get_line' — method qualname includes the class scope prefix."
    - "check.__code__.co_name == 'check' and process_tokens.__code__.co_name == 'process_tokens' — the bytecode-level co_name matches the function name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module __name__ and __spec__.name — module self-identification.
# Not covered in any prior tabnanny spec.
# ---------------------------------------------------------------------------

invariant tabnanny_extra4.module.self_name:
  description: "tabnanny.__name__ == 'tabnanny' — the module's own __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["tabnanny"]
  expected: true

invariant tabnanny_extra4.module.spec_name:
  description: "tabnanny.__spec__.name == 'tabnanny' — the importlib ModuleSpec records the module name"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["tabnanny"]
  expected: true

# ---------------------------------------------------------------------------
# check and process_tokens function type — both are plain Python functions.
# Prior specs check __name__/__module__/__qualname__ for both;
# __class__.__name__ == 'function' is new here.
# Not covered in any prior tabnanny spec.
# ---------------------------------------------------------------------------

table tabnanny_extra4.function_types:
  kind: python_call_eq
  category: function_types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [check,          check.__class__.__name__.__eq__,          ["function"], true]
    - [process_tokens, process_tokens.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# NannyNag.get_line.__qualname__ — method qualname carries class prefix.
# tabnanny_extra3 covered get_lineno.__qualname__ and get_msg.__qualname__;
# get_line.__qualname__ is new here.
# Not covered in any prior tabnanny spec.
# ---------------------------------------------------------------------------

invariant tabnanny_extra4.method_qualnames.get_line:
  description: "tabnanny.NannyNag.get_line.__qualname__ == 'NannyNag.get_line' — method qualname includes class scope"
  category: method_qualnames
  kind: python_call_eq
  function: NannyNag.get_line.__qualname__.__eq__
  args: ["NannyNag.get_line"]
  expected: true

# ---------------------------------------------------------------------------
# check and process_tokens __code__.co_name — bytecode-level function name.
# Prior specs cover __name__ (str attribute); co_name is the code-object
# recording and is a distinct angle.
# Not covered in any prior tabnanny spec.
# ---------------------------------------------------------------------------

invariant tabnanny_extra4.co_names.check:
  description: "tabnanny.check.__code__.co_name == 'check' — bytecode-level function name matches __name__"
  category: co_names
  kind: python_call_eq
  function: check.__code__.co_name.__eq__
  args: ["check"]
  expected: true

invariant tabnanny_extra4.co_names.process_tokens:
  description: "tabnanny.process_tokens.__code__.co_name == 'process_tokens' — bytecode-level function name"
  category: co_names
  kind: python_call_eq
  function: process_tokens.__code__.co_name.__eq__
  args: ["process_tokens"]
  expected: true
