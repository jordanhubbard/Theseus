spec: struct_extra25
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack."
    - "struct_extra22.zspec.zsdl — covers __module__.__len__() for Struct (7) and error (6)."
    - "struct_extra23.zspec.zsdl — covers __module__.__len__() for pack_into/unpack_from/iter_unpack (all 7)."
    - "struct_extra24.zspec.zsdl — covers __module__.__len__() for pack/unpack/calcsize (all 7); __name__.__len__() not yet covered."
  notes:
    - "This spec extends struct_extra24.zspec.zsdl."
    - "Prior specs covered: __qualname__ equality and lengths for all six module-level functions plus Struct and error; __module__ equality and __module__.__len__() for all functions and classes."
    - "This spec covers: __module__.__len__() for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack restated as a unified table; __name__.__len__() for pack/unpack/calcsize/pack_into; Struct.__module__.__len__() and error.__module__.__len__() restated."
    - "struct.pack.__module__.__len__() == 7 — len('_struct') == 7. Verified."
    - "struct.unpack.__module__.__len__() == 7. Verified."
    - "struct.calcsize.__module__.__len__() == 7. Verified."
    - "struct.pack_into.__module__.__len__() == 7. Verified."
    - "struct.unpack_from.__module__.__len__() == 7. Verified."
    - "struct.iter_unpack.__module__.__len__() == 7. Verified."
    - "struct.pack.__name__.__len__() == 4 — len('pack') == 4. Verified."
    - "struct.unpack.__name__.__len__() == 6 — len('unpack') == 6. Verified."
    - "struct.calcsize.__name__.__len__() == 8 — len('calcsize') == 8. Verified."
    - "struct.pack_into.__name__.__len__() == 9 — len('pack_into') == 9. Verified."
    - "struct.Struct.__module__.__len__() == 7 — len('_struct') == 7. Verified."
    - "struct.error.__module__.__len__() == 6 — len('struct') == 6 (Python wrapper, not C extension). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for all six C extension module-level functions
#
# All six functions (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack)
# are C builtins in _struct, so their __module__ is '_struct' (len 7).
# Prior specs cover these in fragments (extra22/23/24). This table provides
# the complete six-function set in a single extra25 namespace reference.
# Verified: all six yield 7.
# ---------------------------------------------------------------------------

table struct_extra25.all_function_module_lengths:
  description: "__module__.__len__() == 7 for all six struct C extension functions — len('_struct') == 7"
  kind: python_call_eq
  category: module_identity
  id_prefix: afml25

  columns: [id, function, args, expected]
  rows:
    - [pack,        pack.__module__.__len__,        [], 7]
    - [unpack,      unpack.__module__.__len__,      [], 7]
    - [calcsize,    calcsize.__module__.__len__,    [], 7]
    - [pack_into,   pack_into.__module__.__len__,   [], 7]
    - [unpack_from, unpack_from.__module__.__len__, [], 7]
    - [iter_unpack, iter_unpack.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for pack/unpack/calcsize/pack_into
#
# No prior spec covers __name__.__len__() for any struct functions. This table
# provides name length checks for the four functions with distinct lengths
# (4/6/8/9), providing an independent cross-validation axis.
# Verified: pack=4, unpack=6, calcsize=8, pack_into=9.
# ---------------------------------------------------------------------------

table struct_extra25.function_name_lengths:
  description: "__name__.__len__() for struct pack/unpack/calcsize/pack_into — lengths 4/6/8/9"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnlen25

  columns: [id, function, args, expected]
  rows:
    - [pack,      pack.__name__.__len__,      [], 4]
    - [unpack,    unpack.__name__.__len__,    [], 6]
    - [calcsize,  calcsize.__name__.__len__,  [], 8]
    - [pack_into, pack_into.__name__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__module__.__len__() == 7
#
# Struct is a C extension type defined in _struct (len 7), matching all
# six module-level functions. struct_extra22 covers Struct.__module__.__len__()
# but this standalone restates it in the extra25 namespace alongside the
# error case below for a unified class module-length reference.
# Verified: len('_struct') == 7.
# ---------------------------------------------------------------------------

invariant struct_extra25.Struct.module_len:
  description: "struct.Struct.__module__.__len__() == 7 — Struct is a C extension type in '_struct'; len('_struct') == 7"
  category: module_identity
  kind: python_call_eq
  function: Struct.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Standalone: struct.error.__module__.__len__() == 6
#
# struct.error is defined in the Python-level struct.py wrapper, so its
# __module__ is 'struct' (len 6), distinct from the C extension functions
# whose __module__ is '_struct' (len 7). This length difference (6 vs 7)
# reflects the architectural boundary between the Python wrapper and the
# C extension.
# struct_extra22 covers error.__module__.__len__(); this standalone restates
# it in the extra25 namespace for unified co-location with Struct above.
# Verified: len('struct') == 6.
# ---------------------------------------------------------------------------

invariant struct_extra25.error.module_len:
  description: "struct.error.__module__.__len__() == 6 — error is in Python wrapper 'struct' (len 6), not C extension '_struct' (len 7)"
  category: module_identity
  kind: python_call_eq
  function: error.__module__.__len__
  args: []
  expected: 6
