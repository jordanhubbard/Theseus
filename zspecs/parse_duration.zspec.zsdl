spec: parse_duration
version: ">=2.1.6"
backend: node(parse-duration)

docs: https://www.npmjs.com/package/parse-duration

provenance:
  derived_from:
    - "parse-duration README — https://www.npmjs.com/package/parse-duration"
    - "Test vectors verified with parse-duration via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "parse-duration source"
  notes:
    - "parse-duration is an npm package. Install: npm install parse-duration"
    - "Parses a human-readable duration string and returns milliseconds."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number (milliseconds)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table parse_duration.parseDuration:
  kind: node_module_call_eq
  function: "default"
  category: time
  id_prefix: pdur

  columns: [id, args, expected]
  rows:
    - [second,   ["1s"],      1000]
    - [hour,     ["2h"],      7200000]
    - [ms,       ["500ms"],   500]
    - [minute,   ["1 minute"], 60000]

