spec: re_extra2281
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size."
    - "Subjects: re.Pattern, re.Match, re.error, re.RegexFlag."
    - "re.Pattern and re.Match are C-implemented types: __mro__.__len__ == 2 (direct object subclasses)."
    - "re.error (alias for re.PatternError in Python 3.13+): __mro__.__len__ == 4 (PatternError→Exception→BaseException→object)."
    - "re.RegexFlag: __mro__.__len__ == 7 (RegexFlag→IntFlag→int→ReprEnum→Flag→Enum→object), deep enum hierarchy."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra2281.pattern_match_mro:
  description: "re.Pattern and re.Match C-type MRO depth, base count, and dict size"
  kind: python_call_eq
  category: mro_depth
  id_prefix: re2281

  columns: [id, function, args, expected]
  rows:
    - ["re2281001", "re.Pattern.__mro__.__len__", [], 2]
    - ["re2281002", "re.Pattern.__bases__.__len__", [], 1]
    - ["re2281003", "re.Pattern.__dict__.__len__", [], 26]
    - ["re2281004", "re.Match.__mro__.__len__", [], 2]
    - ["re2281005", "re.Match.__bases__.__len__", [], 1]
    - ["re2281006", "re.Match.__dict__.__len__", [], 21]

