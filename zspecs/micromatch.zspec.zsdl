spec: micromatch
version: ">=4.0.0"
backend: node(micromatch)

docs: https://github.com/micromatch/micromatch#readme

provenance:
  derived_from:
    - "micromatch README — https://github.com/micromatch/micromatch#readme"
    - "Test vectors verified with micromatch@4.0.8 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "micromatch source"
  notes:
    - "micromatch exports an object with match, isMatch, contains, and other functions."
    - "isMatch(str, pattern) returns true if the string matches the glob pattern."
    - "micromatch(list, pattern) returns the matched strings from the list."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "isMatch returns boolean; match returns array. No errors for valid patterns."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table micromatch.isMatch:
  kind: node_module_call_eq
  function: isMatch
  category: isMatch
  id_prefix: mm_is

  columns: [id, args, expected]
  rows:
    - [js_match,    ["foo.js", "*.js"],   true]
    - [ts_nomatch,  ["foo.js", "*.ts"],   false]
    - [deep,        ["foo/bar.js", "**/*.js"],  true]

table micromatch.match:
  kind: node_module_call_eq
  function: ~
  category: match
  id_prefix: mm_match

  columns: [id, args, expected]
  rows:
    - [js_files,  [["foo.js", "bar.ts", "baz.js"], "*.js"],  ["foo.js", "baz.js"]]
