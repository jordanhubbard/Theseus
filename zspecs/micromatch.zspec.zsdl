spec: micromatch
version: ">=4.0.0"
backend: node(micromatch)

docs: https://www.npmjs.com/package/micromatch

provenance:
  derived_from:
    - "micromatch README — https://www.npmjs.com/package/micromatch"
    - "Test vectors verified with micromatch via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "micromatch source"
  notes:
    - "micromatch is an npm package. Install: npm install micromatch"
    - "micromatch(list, pattern) returns matching items from a list."
    - "micromatch.isMatch(str, pattern) returns true if str matches the glob pattern."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns matching array or boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table micromatch.match:
  kind: node_module_call_eq
  function: ~
  category: match
  id_prefix: mmatch

  columns: [id, args, expected]
  rows:
    - [js_only,  [["foo.js", "foo.txt", "bar.js"], "*.js"], ["foo.js", "bar.js"]]

table micromatch.isMatch:
  kind: node_module_call_eq
  function: isMatch
  category: match
  id_prefix: misMatch

  columns: [id, args, expected]
  rows:
    - [match,    ["foo.js",  "*.js"], true]
    - [no_match, ["foo.txt", "*.js"], false]
    - [glob,     ["foo/bar.js", "**/*.js"], true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:16:28Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
