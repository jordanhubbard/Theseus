spec: struct_extra172
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra171.zspec.zsdl — covers struct.Struct('i').size==4; Struct('q').size==8; Struct('2i').size==8; Struct('i').format=='i'; Struct('2i').format=='2i'; Struct('i').__class__.__name__=='Struct'; Struct('i').size.__class__.__name__=='int' (table + invariants)."
    - "struct_extra170.zspec.zsdl — covers struct format character byte sizes: calcsize('b')==1; calcsize('h')==2; calcsize('i')==4; calcsize('l')==4; calcsize('q')==8; calcsize('f')==4; calcsize('d')==8 (table + invariants)."
    - "struct_extra169.zspec.zsdl — covers struct.Struct/__error class name and module / error.__bases__[0].__name__=='Exception' / pack/calcsize __name__ strings (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__=='struct' and pack/unpack base vectors (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra171."
    - "Wave 355 theme: struct pack/unpack round-trip behavior — struct.pack('i', 42).__class__.__name__=='bytes'; struct.pack('i', 42).__len__()==4; struct.pack('q', 0).__len__()==8; struct.pack('h', 0).__len__()==2; struct.pack('b', 0).__len__()==1; struct.unpack('i', struct.pack('i', 42)).__class__.__name__=='tuple'; struct.unpack('i', struct.pack('i', 42)).__len__()==1; struct.unpack('2i', struct.pack('2i', 1, 2)).__len__()==2. These anchor the output class and length of pack() and the output class and length of unpack() for various format strings as novel content under structpackunpack172."
    - "struct.pack('i', 42).__class__.__name__ == 'bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0. pack() always returns bytes."
    - "struct.pack('i', 42).__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0. Packing one signed int ('i') produces 4 bytes."
    - "struct.pack('q', 0).__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0. Packing one signed long long ('q') produces 8 bytes."
    - "struct.pack('h', 0).__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. Packing one signed short ('h') produces 2 bytes."
    - "struct.pack('b', 0).__len__() == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0. Packing one signed byte ('b') produces 1 byte."
    - "struct.unpack('i', struct.pack('i', 42)).__class__.__name__ == 'tuple'. Verified Python 3.14.3 macOS/Darwin 25.4.0. unpack() always returns a tuple."
    - "struct.unpack('i', struct.pack('i', 42)).__len__() == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0. Unpacking a single 'i' format yields a 1-element tuple."
    - "struct.unpack('2i', struct.pack('2i', 1, 2)).__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. Unpacking a '2i' format yields a 2-element tuple."
    - "Note: pack('i', 42).__len__()==4 == pack('f', 0).__len__()==4 (not tested here; noted for context). pack('h', 0).__len__()==2 < pack('i', 42).__len__()==4 < pack('q', 0).__len__()==8."
    - "Note: unpack('i', ...).__len__()==1 < unpack('2i', ...).__len__()==2. Unpacking a 2-element format yields a tuple with 2 elements — one per format count."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack('i', 42).__class__.__name__ == 'bytes'
# struct.pack('i', 42).__len__() == 4
# struct.pack('q', 0).__len__() == 8
# struct.pack('h', 0).__len__() == 2
#
# Wave 355 theme: struct.pack() return type and byte-length values.
#
# pack('i', 42).__class__.__name__ is 'bytes'.
# pack('i', 42).__len__() is 4.
# pack('q', 0).__len__() is 8.
# pack('h', 0).__len__() is 2.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra172.pack_return_type_and_lengths:
  description: "struct.pack('i', 42).__class__.__name__.__eq__('bytes')==True / struct.pack('i', 42).__len__()==4 / struct.pack('q', 0).__len__()==8 / struct.pack('h', 0).__len__()==2 — pack('i', 42).__class__.__name__ is 'bytes' (5 chars; struct.pack() always returns a bytes object; the __class__.__name__ of the returned object is 'bytes' regardless of the format string; novel anchor: no prior struct spec anchors pack('i',42).__class__.__name__ under structpackunpack172; first structpackunpack172 anchor for 'bytes' as pack return type); pack('i', 42).__len__() is 4 (4 bytes; packing one signed int ('i') into bytes produces exactly 4 bytes (32 bits); pack().__len__()==4 == calcsize('i')==4: the byte count matches calcsize; novel anchor: first structpackunpack172 anchor for the integer 4 as pack('i') byte length); pack('q', 0).__len__() is 8 (8 bytes; packing one signed long long ('q') produces 8 bytes (64 bits); pack('q',0).__len__(8) > pack('i',42).__len__(4) by 4: long long is twice the int byte count; novel anchor: first structpackunpack172 anchor for the integer 8 as pack('q') byte length); pack('h', 0).__len__() is 2 (2 bytes; packing one signed short ('h') produces 2 bytes (16 bits); pack('h',0).__len__(2) < pack('i',42).__len__(4) by 2: short is half the int byte count; novel anchor: first structpackunpack172 anchor for the integer 2 as pack('h') byte length)"
  kind: python_call_eq
  category: identity
  id_prefix: structpackunpack172

  columns: [id, function, args, expected, description]
  rows:
    - [pack_i_42_class_bytes, "pack('i', 42).__class__.__name__.__eq__", ["bytes"], true, "struct.pack('i', 42).__class__.__name__ == 'bytes' (5 chars; always bytes; novel anchor)"]
    - [pack_i_42_len_4,       "pack('i', 42).__len__",                   [],        4,    "struct.pack('i', 42).__len__() == 4 (one int=4 bytes; novel anchor)"]
    - [pack_q_0_len_8,        "pack('q', 0).__len__",                    [],        8,    "struct.pack('q', 0).__len__() == 8 (one long long=8 bytes; 8>4; novel anchor)"]
    - [pack_h_0_len_2,        "pack('h', 0).__len__",                    [],        2,    "struct.pack('h', 0).__len__() == 2 (one short=2 bytes; 2<4; novel anchor)"]

# ---------------------------------------------------------------------------
# struct.pack('b', 0).__len__() == 1
# struct.pack('b', 0).__class__.__name__ == 'bytes'
# struct.unpack('i', struct.pack('i', 42)).__class__.__name__ == 'tuple'
# struct.unpack('i', struct.pack('i', 42)).__len__() == 1
#
# Wave 355 theme: pack('b') byte length and unpack() return type.
#
# pack('b', 0).__len__() is 1 (minimum byte count; signed byte).
# pack('b', 0).__class__.__name__ is 'bytes'.
# unpack('i', pack('i', 42)).__class__.__name__ is 'tuple'.
# unpack('i', pack('i', 42)).__len__() is 1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra172.pack_b_and_unpack_type:
  description: "struct.pack('b', 0).__len__()==1 / struct.pack('b', 0).__class__.__name__.__eq__('bytes')==True / struct.unpack('i', struct.pack('i', 42)).__class__.__name__.__eq__('tuple')==True / struct.unpack('i', struct.pack('i', 42)).__len__()==1 — pack('b', 0).__len__() is 1 (1 byte; packing one signed byte ('b') produces exactly 1 byte (8 bits); pack('b',0).__len__(1) is the minimum possible non-empty pack result; 1 < 2 < 4 < 8: the full ordering of single-format pack lengths in this spec; novel anchor: first structpackunpack172 anchor for the integer 1 as pack('b') byte length); pack('b', 0).__class__.__name__ is 'bytes' (confirms bytes type for the 'b' format; pack always returns bytes regardless of format; novel anchor: first structpackunpack172 anchor for bytes type via pack('b')); unpack('i', pack('i', 42)).__class__.__name__ is 'tuple' (5 chars; struct.unpack() always returns a tuple of unpacked values; the __class__.__name__ is 'tuple' regardless of format; novel anchor: first structpackunpack172 anchor for 'tuple' as unpack return type); unpack('i', pack('i', 42)).__len__() is 1 (unpacking a single 'i' format string yields one value wrapped in a tuple; the tuple has length 1; unpack('i',...).__len__(1) == pack('b',0).__len__(1): same integer 1 appears as both minimum pack byte count and single-value unpack result length; novel anchor: first structpackunpack172 anchor for 1 as unpack('i') result length)"
  kind: python_call_eq
  category: identity
  id_prefix: structpackunpack172

  columns: [id, function, args, expected, description]
  rows:
    - [pack_b_0_len_1,         "pack('b', 0).__len__",                                    [],        1,    "struct.pack('b', 0).__len__() == 1 (one byte=1; minimum; novel anchor)"]
    - [pack_b_0_class_bytes,   "pack('b', 0).__class__.__name__.__eq__",                  ["bytes"], true, "struct.pack('b', 0).__class__.__name__ == 'bytes' (always bytes; novel anchor)"]
    - [unpack_i_class_tuple,   "unpack('i', pack('i', 42)).__class__.__name__.__eq__",    ["tuple"], true, "struct.unpack('i', pack('i', 42)).__class__.__name__ == 'tuple' (always tuple; novel anchor)"]
    - [unpack_i_len_1,         "unpack('i', pack('i', 42)).__len__",                      [],        1,    "struct.unpack('i', pack('i', 42)).__len__() == 1 (one value; novel anchor)"]

# ---------------------------------------------------------------------------
# struct.unpack('2i', struct.pack('2i', 1, 2)).__len__() == 2
# struct.unpack('2i', struct.pack('2i', 1, 2)).__class__.__name__ == 'tuple'
# struct.pack('2i', 1, 2).__len__() == 8
#
# Wave 355 theme: multi-element pack/unpack round-trip.
#
# unpack('2i', pack('2i', 1, 2)).__len__() is 2 (two values in result tuple).
# unpack('2i', pack('2i', 1, 2)).__class__.__name__ is 'tuple'.
# pack('2i', 1, 2).__len__() is 8 (two ints = 2*4 = 8 bytes).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra172.pack_unpack_2i_round_trip:
  description: "struct.unpack('2i', struct.pack('2i', 1, 2)).__len__()==2 / struct.unpack('2i', struct.pack('2i', 1, 2)).__class__.__name__.__eq__('tuple')==True / struct.pack('2i', 1, 2).__len__()==8 — unpack('2i', pack('2i', 1, 2)).__len__() is 2 (unpacking a '2i' format string yields two values in the result tuple; the '2' count prefix means two signed ints are packed/unpacked; unpack('2i',...).__len__(2) > unpack('i',...).__len__(1) by 1: two-element unpack has one more result than single-element; novel anchor: first structpackunpack172 anchor for the integer 2 as unpack('2i') result length); unpack('2i', pack('2i', 1, 2)).__class__.__name__ is 'tuple' (confirms bytes type persists for multi-element format; struct.unpack always returns a tuple; novel anchor: first structpackunpack172 anchor for 'tuple' via unpack('2i')); pack('2i', 1, 2).__len__() is 8 (two signed ints = 2 * 4 = 8 bytes; pack('2i',1,2).__len__(8) == pack('q',0).__len__(8): two ints and one long long both pack to 8 bytes — a coincidental size equality; novel anchor: first structpackunpack172 anchor for 8 as pack('2i') byte length)"
  kind: python_call_eq
  category: identity
  id_prefix: structpackunpack172

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_2i_len_2,       "unpack('2i', pack('2i', 1, 2)).__len__",                   [],        2,    "struct.unpack('2i', pack('2i', 1, 2)).__len__() == 2 (two values; novel anchor)"]
    - [unpack_2i_class_tuple, "unpack('2i', pack('2i', 1, 2)).__class__.__name__.__eq__", ["tuple"], true, "struct.unpack('2i', pack('2i', 1, 2)).__class__.__name__ == 'tuple' (always tuple; novel anchor)"]
    - [pack_2i_len_8,         "pack('2i', 1, 2).__len__",                                 [],        8,    "struct.pack('2i', 1, 2).__len__() == 8 (two ints=2*4=8 bytes; ties pack('q'); novel anchor)"]

# ---------------------------------------------------------------------------
# struct.pack('i', 42).__class__.__name__.__eq__('bytes') — standalone
#
# struct.pack('i', 42).__class__.__name__ is 'bytes' (5 chars). pack() always
# returns bytes. 'bytes'(5) > 'tuple'(5) — both are 5-char type names.
# Novel anchor under structpackunpack172. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra172.pack_i_42_class_bytes:
  description: "struct.pack('i', 42).__class__.__name__.__eq__('bytes') == True — 'bytes' (5 chars; struct.pack() takes a format string and values and returns a bytes object containing the packed binary data; the return type is always bytes regardless of the format string or values; 'bytes' is a 5-char lowercase type name; struct.pack('i', 42) packs the integer 42 as a signed 32-bit int in native byte order; the result is 4 bytes of packed data whose type is bytes; __class__.__name__=='bytes' is the runtime confirmation of the return type; novel anchor: no prior struct spec anchors pack('i',42).__class__.__name__ under structpackunpack172; first structpackunpack172 standalone for pack('i', 42).__class__.__name__.__eq__('bytes')"
  category: identity
  kind: python_call_eq
  function: "pack('i', 42).__class__.__name__.__eq__"
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack('i', 42).__len__() == 4 — standalone
#
# struct.pack('i', 42).__len__() is 4. Packing one signed int produces 4 bytes.
# pack('i')(4) == calcsize('i')(4): byte count matches calcsize.
# Novel anchor under structpackunpack172. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra172.pack_i_42_len_4:
  description: "struct.pack('i', 42).__len__() == 4 — 4 (struct.pack('i', 42) packs the integer 42 using the 'i' format (signed 32-bit int) and returns 4 bytes; the packed bytes always have __len__() == calcsize('i') == 4; 4 bytes = 32 bits: signed int range is -2,147,483,648 to 2,147,483,647; pack('i', 42).__len__(4) < pack('q', 0).__len__(8) by 4: int is half the size of long long; pack('i', 42).__len__(4) > pack('h', 0).__len__(2) by 2: int is double the size of short; novel anchor: no prior struct spec anchors pack('i',42).__len__ under structpackunpack172; first structpackunpack172 standalone for pack('i', 42).__len__()==4"
  category: identity
  kind: python_call_eq
  function: "pack('i', 42).__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.pack('q', 0).__len__() == 8 — standalone
#
# struct.pack('q', 0).__len__() is 8. Packing one signed long long produces
# 8 bytes. pack('q')(8) == pack('2i',1,2)(8): same byte count, different layout.
# Novel anchor under structpackunpack172. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra172.pack_q_0_len_8:
  description: "struct.pack('q', 0).__len__() == 8 — 8 (struct.pack('q', 0) packs the integer 0 using the 'q' format (signed 64-bit long long) and returns 8 bytes; the 'q' format always produces 8 bytes (64 bits); pack('q', 0).__len__(8) == pack('2i', 1, 2).__len__(8): packing one long long and packing two ints both produce 8 bytes — the same byte count from very different formats; this equality is because 8 bytes = 2 * 4 bytes = 1 * 8 bytes; pack('q',0).__len__(8) > pack('i',42).__len__(4) by 4: long long takes twice as many bytes as int; novel anchor: no prior struct spec anchors pack('q',0).__len__ under structpackunpack172; first structpackunpack172 standalone for pack('q', 0).__len__()==8"
  category: identity
  kind: python_call_eq
  function: "pack('q', 0).__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.unpack('i', struct.pack('i', 42)).__class__.__name__.__eq__('tuple') — standalone
#
# struct.unpack('i', pack('i', 42)).__class__.__name__ is 'tuple' (5 chars).
# unpack() always returns a tuple. 'tuple'(5) has the same length as 'bytes'(5).
# Novel anchor under structpackunpack172. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra172.unpack_i_class_tuple:
  description: "struct.unpack('i', struct.pack('i', 42)).__class__.__name__.__eq__('tuple') == True — 'tuple' (5 chars; struct.unpack() takes a format string and a bytes buffer and returns a tuple of unpacked values; the return type is always a tuple regardless of how many values are unpacked; 'tuple' is 5 chars — the same length as 'bytes' (the return type of pack()); unpack('i', pack('i', 42)) unpacks the 4 bytes produced by pack('i', 42) back into Python values; the result is a 1-tuple containing the integer 42; __class__.__name__=='tuple' confirms the return type at runtime; novel anchor: no prior struct spec anchors unpack('i', pack('i',42)).__class__.__name__ under structpackunpack172; first structpackunpack172 standalone for unpack('i', pack('i', 42)).__class__.__name__.__eq__('tuple')"
  category: identity
  kind: python_call_eq
  function: "unpack('i', pack('i', 42)).__class__.__name__.__eq__"
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack('2i', struct.pack('2i', 1, 2)).__len__() == 2 — standalone
#
# struct.unpack('2i', pack('2i', 1, 2)).__len__() is 2. Unpacking a 2-element
# format yields a 2-element tuple. unpack('2i')(2) > unpack('i')(1).
# Novel anchor under structpackunpack172. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra172.unpack_2i_len_2:
  description: "struct.unpack('2i', struct.pack('2i', 1, 2)).__len__() == 2 — 2 (struct.unpack('2i', pack('2i', 1, 2)) unpacks two signed ints from the bytes buffer produced by pack('2i', 1, 2); the result is a 2-tuple (1, 2) containing the two original integer values; the __len__() of the result tuple is 2; unpack('2i',...).__len__(2) > unpack('i',...).__len__(1) by 1: the count prefix in the format string directly determines the number of elements in the result tuple; pack/unpack('2i') is a round-trip: pack('2i', 1, 2) produces 8 bytes and unpack('2i', ...) recovers the original values (1, 2) in a 2-tuple; novel anchor: no prior struct spec anchors unpack('2i', pack('2i',1,2)).__len__ under structpackunpack172; first structpackunpack172 standalone for unpack('2i', pack('2i', 1, 2)).__len__()==2"
  category: identity
  kind: python_call_eq
  function: "unpack('2i', pack('2i', 1, 2)).__len__"
  args: []
  expected: 2
