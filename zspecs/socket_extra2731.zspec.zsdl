# ---------------------------------------------------------------------------
# Combined view — AddressFamily and SocketKind vs. all three rounding protocols
# ---------------------------------------------------------------------------

table socket_extra2731.enum_rounding_combined:
  description: "socket.AddressFamily and socket.SocketKind define none of __trunc__, __floor__, __ceil__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2731

  columns: [id, function, args, expected]
  rows:
    - ["sk2731010", "socket.AddressFamily.__dict__.__contains__", ["__trunc__"], false]
    - ["sk2731011", "socket.AddressFamily.__dict__.__contains__", ["__floor__"], false]
    - ["sk2731012", "socket.AddressFamily.__dict__.__contains__", ["__ceil__"],  false]
    - ["sk2731013", "socket.SocketKind.__dict__.__contains__",    ["__trunc__"], false]
    - ["sk2731014", "socket.SocketKind.__dict__.__contains__",    ["__floor__"], false]
    - ["sk2731015", "socket.SocketKind.__dict__.__contains__",    ["__ceil__"],  false]
