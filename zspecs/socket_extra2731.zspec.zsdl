spec: socket_extra2731
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol)."
    - "socket.socket is a network socket class; it does not implement numeric rounding protocols."
    - "socket.AddressFamily is an IntEnum representing address families (AF_INET, AF_UNIX, etc.); IntEnum provides rounding via the int MRO, but AddressFamily does NOT define __trunc__, __floor__, or __ceil__ in its own __dict__."
    - "socket.SocketKind is an IntEnum representing socket types (SOCK_STREAM, SOCK_DGRAM, etc.); same reasoning as AddressFamily — its own __dict__ does not contain __trunc__, __floor__, or __ceil__."
    - "None of the socket public classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all socket classes
# ---------------------------------------------------------------------------

table socket_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all socket class __dict__s — none implement numeric truncation in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2731

  columns: [id, function, args, expected]
  rows:
    - ["sk2731001", "socket.socket.__dict__.__contains__",        ["__trunc__"], false]
    - ["sk2731002", "socket.AddressFamily.__dict__.__contains__", ["__trunc__"], false]
    - ["sk2731003", "socket.SocketKind.__dict__.__contains__",    ["__trunc__"], false]

