    - [pl1441ic002, pathlib.PurePosixPath.__instancecheck__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [pl1441ic003, pathlib.PureWindowsPath.__instancecheck__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [pl1441ic004, pathlib.Path.__instancecheck__.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
    - [pl1441ic005, pathlib.PosixPath.__instancecheck__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]

