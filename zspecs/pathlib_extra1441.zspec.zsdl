spec: pathlib_extra1441
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 543 (_extra1441): ABC machinery focus — __subclasshook__ and __instancecheck__ checks."
    - "pathlib classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) use plain 'type' metaclass."
    - "__subclasshook__ is inherited from object.__dict__ — not present in any pathlib class __dict__."
    - "__instancecheck__ is on the plain 'type' metaclass — not in the class __dict__ itself."
    - "All __subclasshook__.__class__.__name__ and __instancecheck__.__class__.__name__ yield 'builtin_function_or_method'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1441.subclasshook_class_name:
  description: "pathlib class __subclasshook__.__class__.__name__ — all resolve as builtin_function_or_method"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: pl1441sh
  columns: [id, function, args, expected]
  rows:
    - [pl1441sh001, pathlib.PurePath.__subclasshook__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [pl1441sh002, pathlib.PurePosixPath.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [pl1441sh003, pathlib.PureWindowsPath.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [pl1441sh004, pathlib.Path.__subclasshook__.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
    - [pl1441sh005, pathlib.PosixPath.__subclasshook__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]

