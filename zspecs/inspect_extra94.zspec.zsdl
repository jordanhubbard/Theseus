spec: inspect_extra94
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra93

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra93.zspec.zsdl."
    - "This spec covers: inspect module identity (__name__, __package__, __loader__, __spec__) + inspect.FrameInfo and inspect.Traceback namedtuple identity (Wave 254)."
    - "inspect.__name__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.__package__ == '' (empty string). Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a pure-Python module. Verified with Python 3.14.3."
    - "inspect.__spec__.__class__.__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "inspect.__doc__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__name__ == 'FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — FrameInfo inherits from the internal _FrameInfo namedtuple. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__mro__.__len__() == 4 — mro is [FrameInfo, _FrameInfo, tuple, object]. Verified with Python 3.14.3."
    - "inspect.Traceback.__name__ == 'Traceback'. Verified with Python 3.14.3."
    - "inspect.Traceback.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Traceback.__bases__[0].__name__ == '_Traceback'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple (inherits from tuple). Verified with Python 3.14.3."
    - "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a namedtuple. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect module identity (__name__, __package__, __doc__ class name)
#
# Wave 254 theme: inspect module string identity.
#
# inspect.__name__.__eq__('inspect') == True
# inspect.__package__.__eq__('') == True
# inspect.__doc__.__class__.__name__.__eq__('str') == True
#
# inspect is a top-level pure-Python module; __package__ is empty string. New to extra94.
# ---------------------------------------------------------------------------

table inspect_extra94.module_string_identity:
  description: "inspect.__name__, __package__, __doc__ class name; top-level stdlib module in Lib/inspect.py; wave 254; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule94

  columns: [id, function, args, expected, description]
  rows:
    - [inspect_name_eq_inspect,
       "__name__.__eq__",
       ["inspect"],
       true,
       "inspect.__name__.__eq__('inspect') == True — inspect is a pure-Python module defined in Lib/inspect.py; its __name__ attribute is 'inspect'; str.__eq__('inspect') returns True; prior spec extra93 checked class identity; this spec (extra94) checks module identity; new to extra94"]
    - [inspect_package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "inspect.__package__.__eq__('') == True — inspect is a top-level module not inside any package; its __package__ attribute is the empty string ''; str.__eq__('') returns True; new to extra94"]
    - [inspect_doc_class_name_eq_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.__doc__.__class__.__name__.__eq__('str') == True — inspect has a module-level docstring; the __doc__ attribute is a plain Python string; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Table 2: inspect __spec__ and __loader__ class names
#
# Wave 254 theme: inspect import machinery attributes.
#
# inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
# inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
#
# inspect is a pure-Python source module loaded by SourceFileLoader.
# __spec__ is a ModuleSpec instance. New to extra94.
# ---------------------------------------------------------------------------

table inspect_extra94.module_spec_loader:
  description: "inspect.__loader__.__class__.__name__ == 'SourceFileLoader'; inspect.__spec__.__class__.__name__ == 'ModuleSpec'; import machinery attrs; wave 254; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule94

  columns: [id, function, args, expected, description]
  rows:
    - [inspect_loader_class_name_eq_SourceFileLoader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect is a pure-Python source module (Lib/inspect.py); it is loaded by importlib.machinery.SourceFileLoader; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra94"]
    - [inspect_spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every importable module has a __spec__ that is a ModuleSpec instance; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FrameInfo namedtuple identity
#
# Wave 254 theme: inspect.FrameInfo class identity attributes.
#
# inspect.FrameInfo.__name__.__eq__('FrameInfo') == True
# inspect.FrameInfo.__module__.__eq__('inspect') == True
# inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True
# inspect.FrameInfo.__mro__.__len__().__eq__(4) == True
#
# FrameInfo inherits from _FrameInfo (an internal namedtuple); mro is [FrameInfo, _FrameInfo, tuple, object].
# New to extra94.
# ---------------------------------------------------------------------------

table inspect_extra94.frameinfo_identity:
  description: "inspect.FrameInfo __name__, __module__, __bases__[0].__name__, __mro__.__len__(); namedtuple subclass; wave 254; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule94

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_eq_FrameInfo,
       "FrameInfo.__name__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a named class defined in Lib/inspect.py; __name__ is 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra94"]
    - [frameinfo_module_eq_inspect,
       "FrameInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra94"]
    - ["frameinfo_bases0_eq_FrameInfo",
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo inherits from _FrameInfo which is an internal namedtuple subclass also defined in Lib/inspect.py; __bases__[0].__name__ is '_FrameInfo'; str.__eq__('_FrameInfo') returns True; mro is [FrameInfo, _FrameInfo, tuple, object]; new to extra94"]
    - [frameinfo_mro_len_eq_4,
       "FrameInfo.__mro__.__len__",
       [],
       4,
       "inspect.FrameInfo.__mro__.__len__() == 4 — FrameInfo's mro is [FrameInfo, _FrameInfo, tuple, object]; the namedtuple chain adds two extra classes; tuple.__len__() returns 4; new to extra94"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Traceback namedtuple identity + FullArgSpec/ArgInfo
#
# Wave 254 theme: inspect.Traceback and namedtuple base-class checks.
#
# inspect.Traceback.__name__.__eq__('Traceback') == True
# inspect.Traceback.__module__.__eq__('inspect') == True
# inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True
# inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True
# inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True
#
# Traceback mirrors FrameInfo structure but for traceback records.
# FullArgSpec and ArgInfo are direct namedtuple subclasses (base is 'tuple'). New to extra94.
# ---------------------------------------------------------------------------

table inspect_extra94.traceback_and_namedtuples:
  description: "inspect.Traceback identity; FullArgSpec and ArgInfo __bases__[0].__name__; namedtuple subclasses; wave 254; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule94

  columns: [id, function, args, expected, description]
  rows:
    - [traceback_name_eq_Traceback,
       "Traceback.__name__.__eq__",
       ["Traceback"],
       true,
       "inspect.Traceback.__name__.__eq__('Traceback') == True — Traceback is a named class defined in Lib/inspect.py; __name__ is 'Traceback'; str.__eq__('Traceback') returns True; new to extra94"]
    - [traceback_module_eq_inspect,
       "Traceback.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra94"]
    - ["traceback_bases0_eq_Traceback",
       "Traceback.__bases__[0].__name__.__eq__",
       ["_Traceback"],
       true,
       "inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True — Traceback inherits from _Traceback, an internal namedtuple subclass in Lib/inspect.py; __bases__[0].__name__ is '_Traceback'; str.__eq__('_Traceback') returns True; mirrors the FrameInfo/_FrameInfo pattern; new to extra94"]
    - ["fullargspec_bases0_eq_tuple",
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a standard namedtuple created with collections.namedtuple; namedtuples inherit from tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra94"]
    - ["arginfo_bases0_eq_tuple",
       "ArgInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — ArgInfo is a standard namedtuple created with collections.namedtuple; namedtuples inherit from tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant inspect_extra94.inspect_name_eq_inspect:
  description: "inspect.__name__ == 'inspect' — top-level stdlib module identity; wave 254; new to extra94"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra94.inspect_loader_class_name:
  description: "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python source module; wave 254; new to extra94"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra94.frameinfo_name_eq_FrameInfo:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo' — namedtuple-based class in Lib/inspect.py; wave 254; new to extra94"
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra94.frameinfo_mro_len_eq_4:
  description: "inspect.FrameInfo.__mro__.__len__() == 4 — mro is [FrameInfo, _FrameInfo, tuple, object]; wave 254; new to extra94"
  kind: python_call_eq
  function: FrameInfo.__mro__.__len__
  args: []
  expected: 4

invariant inspect_extra94.fullargspec_bases_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple; wave 254; new to extra94"
  kind: python_call_eq
  function: FullArgSpec.__bases__[0].__name__.__eq__
  args: ["tuple"]
  expected: true
