spec: fileinput_extra2
version: ">=3.9"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fileinput.html — Python fileinput module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
  notes:
    - "This spec extends fileinput.zspec.zsdl and fileinput_extra.zspec.zsdl."
    - "fileinput.zspec.zsdl covers: FileInput.__name__, FileInput.__module__, and a table of __name__ checks for all module-level functions including input, filename, fileno, lineno, filelineno, isfirstline, isstdin, nextfile, close, hook_compressed, hook_encoded."
    - "fileinput_extra.zspec.zsdl covers: standalone __name__ invariants for all the same functions and FileInput, FileInput class type check, callability checks for input/hook_compressed/hook_encoded."
    - "This spec adds: __module__ checks for module-level functions (input, filename, fileno, lineno, filelineno, isfirstline, isstdin, nextfile, close), and __qualname__ checks for FileInput and selected functions."
    - "fileinput.input.__module__ == 'fileinput' — input is defined in the fileinput module."
    - "fileinput.FileInput.__qualname__ == 'FileInput' — the class is not nested."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __module__ checks
# Not covered by fileinput.zspec.zsdl or fileinput_extra.zspec.zsdl.
# ---------------------------------------------------------------------------

table fileinput_extra2.function_modules:
  description: "fileinput module-level functions have __module__ == 'fileinput'"
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [input,       input.__module__.__eq__,       ["fileinput"], true]
    - [filename,    filename.__module__.__eq__,     ["fileinput"], true]
    - [fileno,      fileno.__module__.__eq__,       ["fileinput"], true]
    - [lineno,      lineno.__module__.__eq__,       ["fileinput"], true]
    - [filelineno,  filelineno.__module__.__eq__,   ["fileinput"], true]
    - [isfirstline, isfirstline.__module__.__eq__,  ["fileinput"], true]
    - [isstdin,     isstdin.__module__.__eq__,      ["fileinput"], true]

# ---------------------------------------------------------------------------
# Module-level function __module__ — nextfile and close
# Kept as standalone invariants to give them distinct IDs.
# ---------------------------------------------------------------------------

invariant fileinput_extra2.nextfile.module:
  description: "fileinput.nextfile.__module__ == 'fileinput'"
  category: functions
  kind: python_call_eq
  function: nextfile.__module__.__eq__
  args: ["fileinput"]
  expected: true

invariant fileinput_extra2.close.module:
  description: "fileinput.close.__module__ == 'fileinput'"
  category: functions
  kind: python_call_eq
  function: close.__module__.__eq__
  args: ["fileinput"]
  expected: true

# ---------------------------------------------------------------------------
# FileInput class — __qualname__ and __bases__
# __qualname__ not covered in prior specs.
# ---------------------------------------------------------------------------

invariant fileinput_extra2.FileInput.qualname:
  description: "fileinput.FileInput.__qualname__ == 'FileInput' — the class is not nested"
  category: classes
  kind: python_call_eq
  function: FileInput.__qualname__.__eq__
  args: ["FileInput"]
  expected: true

invariant fileinput_extra2.FileInput.base_is_object:
  description: "fileinput.FileInput.__bases__[0].__name__ == 'object' — FileInput inherits from object"
  category: classes
  kind: python_call_eq
  function: FileInput.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# FileInput class — __name__ and __module__ standalone invariants
# These are canonical anchors for this spec family and confirm the class
# identity checks from a distinct spec context.
# ---------------------------------------------------------------------------

invariant fileinput_extra2.FileInput.name:
  description: "fileinput.FileInput.__name__ == 'FileInput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__name__.__eq__
  args: ["FileInput"]
  expected: true

invariant fileinput_extra2.FileInput.module:
  description: "fileinput.FileInput.__module__ == 'fileinput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__module__.__eq__
  args: ["fileinput"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ checks — selected module-level functions
# __qualname__ == __name__ for all module-level functions (not nested).
# ---------------------------------------------------------------------------

table fileinput_extra2.function_qualnames:
  description: "fileinput module-level functions have __qualname__ equal to their identifier"
  kind: python_call_eq
  category: functions
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [input,       input.__qualname__.__eq__,       ["input"],       true]
    - [filename,    filename.__qualname__.__eq__,     ["filename"],    true]
    - [fileno,      fileno.__qualname__.__eq__,       ["fileno"],      true]
    - [lineno,      lineno.__qualname__.__eq__,       ["lineno"],      true]
    - [filelineno,  filelineno.__qualname__.__eq__,   ["filelineno"],  true]
    - [isfirstline, isfirstline.__qualname__.__eq__,  ["isfirstline"], true]
    - [isstdin,     isstdin.__qualname__.__eq__,      ["isstdin"],     true]
