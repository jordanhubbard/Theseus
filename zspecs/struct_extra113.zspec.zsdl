spec: struct_extra113
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra112.zspec.zsdl — covers Struct dunder method qualname equality and lengths / __new__/__repr__/__sizeof__/__reduce_ex__/__reduce__ type identities (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualname equality and __objclass__.__name__ equality (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/format getset_descriptor class names and qualnames / descriptor qualname/name lengths and __objclass__.__name__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra112; it does NOT duplicate invariants present in those files."
    - "Wave 277 theme: Struct.size and Struct.format getset_descriptor __objclass__.__module__ and __class__.__module__ not yet covered — extra98 anchors class names/qualnames; extra104 anchors __objclass__.__name__ and qualname equality; NOT YET covered: __objclass__.__module__ equality, __class__.__module__ equality, __class__.__name__.__len__(), __objclass__.__module__.__len__(), and __doc__ equality."
    - "struct.Struct.size.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('getset_descriptor') == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('_struct') == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__doc__ == 'struct size in bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__doc__ == 'struct format string'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.Struct.size.__doc__) == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.Struct.format.__doc__) == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct.size and Struct.format are getset_descriptor objects (C-level read-only attributes defined via PyGetSetDef in Modules/_struct.c). Their __class__.__module__ is 'builtins' (getset_descriptor is a fundamental CPython type). Their __objclass__ is the Struct C type, which lives in the _struct module (__objclass__.__module__=='_struct', 7 chars). The docstrings are 'struct size in bytes' and 'struct format string', both 20 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size.__objclass__.__module__.__eq__('_struct')
# struct.Struct.format.__objclass__.__module__.__eq__('_struct')
# struct.Struct.size.__class__.__module__.__eq__('builtins')
# struct.Struct.format.__class__.__module__.__eq__('builtins')
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor')
#
# Wave 277 theme: Struct descriptor __objclass__.__module__ and __class__.__module__.
#
# struct_extra104 anchors __objclass__.__name__=='Struct' and qualname equality.
# struct_extra98 anchors __class__.__name__=='getset_descriptor' and name lengths.
# No prior spec anchors __objclass__.__module__ or __class__.__module__ for
# Struct.size and Struct.format as a grouped table. __objclass__.__module__ is
# '_struct' (7 chars; the C extension module). __class__.__module__ is 'builtins'
# (getset_descriptor is a fundamental CPython runtime type).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra113.Struct_descriptor_module_identity:
  description: "Struct.size.__objclass__.__module__.__eq__('_struct')==True / Struct.format.__objclass__.__module__.__eq__('_struct')==True / Struct.size.__class__.__module__.__eq__('builtins')==True / Struct.format.__class__.__module__.__eq__('builtins')==True / Struct.size.__class__.__name__.__eq__('getset_descriptor')==True — __objclass__ (the Struct C type) lives in '_struct' module (7 chars); __class__ (getset_descriptor type) lives in 'builtins'; extra98 anchors class name; extra104 anchors objclass name; first structdesc113 anchor for module identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc113

  columns: [id, function, args, expected, description]
  rows:
    - [size_objclass_module_eq,   "Struct.size.__objclass__.__module__.__eq__",   ["_struct"],         true, "Struct.size.__objclass__.__module__ is '_struct' (the Struct C type is defined in Modules/_struct.c)"]
    - [format_objclass_module_eq, "Struct.format.__objclass__.__module__.__eq__", ["_struct"],         true, "Struct.format.__objclass__.__module__ is '_struct' (same C extension module as Struct.size)"]
    - [size_class_module_eq,      "Struct.size.__class__.__module__.__eq__",      ["builtins"],        true, "Struct.size.__class__.__module__ is 'builtins' (getset_descriptor is a fundamental CPython runtime type)"]
    - [format_class_module_eq,    "Struct.format.__class__.__module__.__eq__",    ["builtins"],        true, "Struct.format.__class__.__module__ is 'builtins' (same as Struct.size; getset_descriptor type is built-in)"]
    - [size_class_name_eq2,       "Struct.size.__class__.__name__.__eq__",        ["getset_descriptor"],true,"Struct.size.__class__.__name__ is 'getset_descriptor' (C-level read-only attribute descriptor type)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__class__.__name__.__len__() == 17
# struct.Struct.format.__class__.__name__.__len__() == 17
# struct.Struct.size.__objclass__.__module__.__len__() == 7
# struct.Struct.format.__objclass__.__module__.__len__() == 7
# struct.Struct.size.__class__.__module__.__len__() == 8
#
# Wave 277 theme: Struct descriptor class name and module lengths.
#
# 'getset_descriptor' is 17 chars (same for both size and format). '_struct' is
# 7 chars (1 underscore + 'struct'=6). 'builtins' is 8 chars. No prior struct
# spec anchors these length values for the Struct property descriptors as a
# grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra113.Struct_descriptor_name_and_module_lengths:
  description: "Struct.size.__class__.__name__.__len__()==17 / Struct.format.__class__.__name__.__len__()==17 / Struct.size.__objclass__.__module__.__len__()==7 / Struct.format.__objclass__.__module__.__len__()==7 / Struct.size.__class__.__module__.__len__()==8 — 'getset_descriptor'=17 chars (both size and format); '_struct'=7 chars (1 underscore + 'struct'=6); 'builtins'=8 chars; no prior spec anchors these length values for Struct descriptors; first structdesc113 anchor for descriptor lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc113

  columns: [id, function, args, expected, description]
  rows:
    - [size_class_name_len,         "Struct.size.__class__.__name__.__len__",         [], 17, "Struct.size.__class__.__name__.__len__() is 17 (len('getset_descriptor')==17)"]
    - [format_class_name_len,       "Struct.format.__class__.__name__.__len__",       [], 17, "Struct.format.__class__.__name__.__len__() is 17 (same as Struct.size; both are getset_descriptor)"]
    - [size_objclass_module_len,    "Struct.size.__objclass__.__module__.__len__",    [], 7,  "Struct.size.__objclass__.__module__.__len__() is 7 (len('_struct')==7; 1 underscore + 'struct'=6)"]
    - [format_objclass_module_len,  "Struct.format.__objclass__.__module__.__len__",  [], 7,  "Struct.format.__objclass__.__module__.__len__() is 7 (same as Struct.size; both bound to the same _struct C type)"]
    - [size_class_module_len,       "Struct.size.__class__.__module__.__len__",       [], 8,  "Struct.size.__class__.__module__.__len__() is 8 (len('builtins')==8; getset_descriptor type is a built-in)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__doc__.__eq__('struct size in bytes')
# struct.Struct.format.__doc__.__eq__('struct format string')
# len(struct.Struct.size.__doc__) == 20
# len(struct.Struct.format.__doc__) == 20
# struct.Struct.size.__objclass__.__module__.__eq__('_struct')
#
# Wave 277 theme: Struct descriptor __doc__ equality and shared length.
#
# Struct.size.__doc__ is 'struct size in bytes' (20 chars). Struct.format.__doc__
# is 'struct format string' (20 chars). Both docstrings have the same length (20)
# despite describing different attributes. Both begin with 'struct ' (7 chars)
# and end with 'bytes'/'string' (5/6 chars) via the middle word. No prior struct
# spec anchors these docstring values as a grouped table under structdesc113.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra113.Struct_descriptor_doc_equality:
  description: "Struct.size.__doc__.__eq__('struct size in bytes')==True / Struct.format.__doc__.__eq__('struct format string')==True / Struct.size.__doc__.__len__()==20 / Struct.format.__doc__.__len__()==20 / Struct.size.__objclass__.__module__.__eq__('_struct')==True — both docstrings are 20 chars; 'struct size in bytes' and 'struct format string' both start with 'struct '; extra99 anchors Struct.size/__format__ doc equality and lengths; first structdesc113 anchor for doc content"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc113

  columns: [id, function, args, expected, description]
  rows:
    - [size_doc_eq,     "Struct.size.__doc__.__eq__",    ["struct size in bytes"], true, "Struct.size.__doc__ is 'struct size in bytes' (20 chars; describes the packed binary size)"]
    - [format_doc_eq,   "Struct.format.__doc__.__eq__",  ["struct format string"], true, "Struct.format.__doc__ is 'struct format string' (20 chars; describes the format string like '>HH' or '<I')"]
    - [size_doc_len,    "Struct.size.__doc__.__len__",   [],                       20,   "Struct.size.__doc__.__len__() is 20 (len('struct size in bytes')==20)"]
    - [format_doc_len,  "Struct.format.__doc__.__len__", [],                       20,   "Struct.format.__doc__.__len__() is 20 (len('struct format string')==20; same length as size doc)"]
    - [size_obj_mod_eq, "Struct.size.__objclass__.__module__.__eq__", ["_struct"], true, "Struct.size.__objclass__.__module__ is '_struct' (cross-check; the Struct C type lives in _struct)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__objclass__.__module__.__eq__('_struct') — standalone
#
# struct.Struct.size.__objclass__.__module__ is '_struct'. The __objclass__
# attribute of a getset_descriptor points to the class that owns the descriptor
# (here: the Struct C type). That Struct C type is defined in Modules/_struct.c
# and belongs to the '_struct' module (7 chars: 1 underscore + 'struct' = 6+1).
# The leading underscore marks '_struct' as a private C extension module; it is
# imported by the public 'struct' module (Lib/struct.py). struct_extra104 anchors
# __objclass__.__name__=='Struct'; no prior spec anchors __objclass__.__module__
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra113.Struct_size_objclass_module_struct:
  description: "struct.Struct.size.__objclass__.__module__.__eq__('_struct') == True — __objclass__ is the Struct C type from Modules/_struct.c; its module is '_struct' (7 chars; private C extension); public 'struct' module wraps '_struct'; extra104 anchors __objclass__.__name__=='Struct'; no prior spec anchors __objclass__.__module__ as standalone; first standalone under structdesc113"
  category: type_identity
  kind: python_call_eq
  function: Struct.size.__objclass__.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__class__.__module__.__eq__('builtins') — standalone
#
# struct.Struct.format.__class__.__module__ is 'builtins'. The getset_descriptor
# type (type(Struct.format)) has its __module__ set to 'builtins' because it is
# a fundamental CPython runtime type defined in Objects/descrobject.c and exposed
# as part of the Python C API without any module attribution. This parallels the
# builtin_function_or_method type which also has __class__.__module__=='builtins'.
# No prior struct spec anchors Struct.format.__class__.__module__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra113.Struct_format_class_module_builtins:
  description: "struct.Struct.format.__class__.__module__.__eq__('builtins') == True — getset_descriptor TYPE (not the descriptor itself) has __module__=='builtins' (fundamental CPython runtime type from Objects/descrobject.c; no explicit module; parallels builtin_function_or_method pattern); no prior spec anchors format.__class__.__module__ as standalone; first standalone under structdesc113"
  category: type_identity
  kind: python_call_eq
  function: Struct.format.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__class__.__name__.__len__() == 17 — standalone
#
# struct.Struct.size.__class__.__name__.__len__() is 17. 'getset_descriptor' has
# 17 chars: 'getset_' (7) + 'descriptor' (10) = 17. The name reflects its dual
# capability: it can both get and set (though for Struct.size and Struct.format
# it is read-only — attempts to set raise AttributeError). The '_descriptor' suffix
# (10 chars) is the longest part of the name. No prior struct spec anchors
# Struct.size.__class__.__name__.__len__() as a standalone under structdesc113.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra113.Struct_size_class_name_len_17:
  description: "struct.Struct.size.__class__.__name__.__len__() == 17 — len('getset_descriptor')==17 ('getset_'=7+'descriptor'=10=17); read-only in practice for Struct.size/format (setting raises AttributeError); same length for Struct.format class name; no prior spec anchors this length as standalone; first standalone under structdesc113"
  category: type_identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# struct.Struct.size.__doc__.__eq__('struct size in bytes') — standalone
#
# struct.Struct.size.__doc__ is 'struct size in bytes'. Struct.size returns the
# packed binary size in bytes for a format string. For example,
# struct.Struct('>HH').size == 4 (two unsigned shorts, 2 bytes each). The docstring
# precisely describes what .size returns: the total byte count of the packed data.
# struct_extra99 anchors Struct.size/__format__ doc equality and lengths at table level;
# no prior spec anchors Struct.size.__doc__ equality as a standalone under structdesc113.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra113.Struct_size_doc_eq:
  description: "struct.Struct.size.__doc__.__eq__('struct size in bytes') == True — docstring is 'struct size in bytes' (20 chars; example: Struct('>HH').size==4 for two 2-byte unsigned shorts); extra99 anchors this at table level; no prior spec anchors size.__doc__ equality as standalone; first standalone under structdesc113"
  category: type_identity
  kind: python_call_eq
  function: Struct.size.__doc__.__eq__
  args: ["struct size in bytes"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__objclass__.__module__.__len__() == 7 — standalone
#
# struct.Struct.format.__objclass__.__module__.__len__() is 7. '_struct' has
# 7 chars (1 + 6). The format attribute stores the format string (e.g., '>HH')
# passed to struct.Struct() at creation time. It is read-only: once a Struct object
# is created with a given format, the format cannot be changed. The __objclass__
# of the format getset_descriptor is the Struct C type, living in '_struct'.
# No prior struct spec anchors format.__objclass__.__module__.__len__() as standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra113.Struct_format_objclass_module_len_7:
  description: "struct.Struct.format.__objclass__.__module__.__len__() == 7 — len('_struct')==7 (1 underscore+'struct'=6=7); format stores the format string at creation (read-only; e.g. '>HH'); __objclass__ is the Struct C type from _struct; no prior spec anchors format.__objclass__.__module__.__len__() as standalone; first standalone under structdesc113"
  category: type_identity
  kind: python_call_eq
  function: Struct.format.__objclass__.__module__.__len__
  args: []
  expected: 7

