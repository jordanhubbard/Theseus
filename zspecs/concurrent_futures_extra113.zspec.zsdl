spec: concurrent_futures_extra113
version: ">=3.11"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra112.zspec.zsdl."
    - "This spec covers: wave 256 theme — concurrent.futures as_completed and wait function co_qualname and co_varnames.__len__() attributes not covered in extra62-extra112. Prior specs covered: as_completed co_varnames.__class__.__name__=='tuple' (extra62), as_completed co_varnames[0]=='fs' (extra62), wait co_varnames.__class__.__name__=='tuple' (extra62), wait co_varnames[0]=='fs' (extra62), as_completed co_varnames.__len__()==9 (extra75), wait co_varnames.__len__()==7 (extra75 only covered as_completed len, not wait). NOT previously covered: as_completed.__code__.co_qualname, wait.__code__.co_qualname, wait.__code__.co_varnames.__len__(). NEW in extra113: as_completed.__code__.co_qualname=='as_completed' (len=12); wait.__code__.co_qualname=='wait' (len=4, shortest in spec); as_completed.__module__=='concurrent.futures._base' (len=24); wait.__module__=='concurrent.futures._base' (len=24); wait.__code__.co_varnames.__len__()==7 ('fs','timeout','return_when','f','done','not_done','waiter'); wait.__code__.co_argcount==3 (fs, timeout, return_when). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.as_completed.__code__.co_qualname == 'as_completed' (len=12). For module-level functions, co_qualname equals the function name. as_completed.__code__.co_argcount==2 (fs and timeout). as_completed.__module__=='concurrent.futures._base' (len=24: the internal _base submodule). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait.__code__.co_qualname == 'wait' (len=4, shortest co_qualname in spec). wait.__code__.co_argcount==3 (fs, timeout, return_when). wait.__code__.co_varnames.__len__()==7 ('fs','timeout','return_when','f','done','not_done','waiter'). wait.__module__=='concurrent.futures._base' (len=24, same as as_completed). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures as_completed co_qualname and module — extra113
#
# Wave 256 theme: as_completed co_qualname (not previously covered).
#
# concurrent.futures.as_completed.__code__.co_qualname  == 'as_completed'  (len=12)
# concurrent.futures.as_completed.__module__            == 'concurrent.futures._base'  (len=24)
# ---------------------------------------------------------------------------

table concurrent_futures_extra113.cf_as_completed_coqualname:
  description: "concurrent.futures.as_completed co_qualname and module checks in cfcoq113 namespace — wave 256 theme: concurrent.futures.as_completed.__code__.co_qualname.__eq__('as_completed')==True (len=12: 'as_completed'=12; for module-level functions, co_qualname equals the function name; as_completed is a generator function that yields futures as they complete); concurrent.futures.as_completed.__code__.co_qualname.__len__()==12; concurrent.futures.as_completed.__code__.co_name.__eq__('as_completed')==True (co_name==co_qualname for module-level); concurrent.futures.as_completed.__code__.co_argcount.__eq__(2)==True (fs and timeout; fs is the iterable of futures, timeout is seconds to wait or None); concurrent.futures.as_completed.__code__.co_varnames.__len__()==9 (from extra75: 'fs','timeout','end_time','total_futures','finished','pending','waiter','wait_timeout','f'); concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base')==True (len=24: as_completed is implemented in the internal _base submodule of concurrent.futures); concurrent.futures.as_completed.__module__.__len__()==24; concurrent.futures.as_completed.__name__.__len__()==12 (same as co_qualname len=12); concurrent.futures.as_completed.__qualname__.__len__()==12 (same as co_qualname); compare: as_completed co_qualname len=12 > wait co_qualname len=4 (as_completed is 8 chars longer than wait); as_completed.__module__ is 'concurrent.futures._base' not 'concurrent.futures' because the function lives in the _base submodule and is re-exported by concurrent/futures/__init__.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcoq113

  columns: [id, function, args, expected, description]
  rows:
    - [ac_coq_eq,    as_completed.__code__.co_qualname.__eq__,    ["as_completed"],             true, "as_completed.__code__.co_qualname == 'as_completed' (len=12, module-level); verified with Python 3.14.3"]
    - [ac_coq_len,   as_completed.__code__.co_qualname.__len__,   [],                           12,   "as_completed.__code__.co_qualname.__len__() == 12 ('as_completed'=12); verified with Python 3.14.3"]
    - [ac_co_name,   as_completed.__code__.co_name.__eq__,        ["as_completed"],             true, "as_completed.__code__.co_name == 'as_completed' (co_name==co_qualname for module-level); verified with Python 3.14.3"]
    - [ac_argc,      as_completed.__code__.co_argcount.__eq__,    [2],                          true, "as_completed.__code__.co_argcount == 2 (fs and timeout); verified with Python 3.14.3"]
    - [ac_var_len,   as_completed.__code__.co_varnames.__len__,   [],                           9,    "as_completed.__code__.co_varnames.__len__() == 9 (generator with 9 locals); verified with Python 3.14.3"]
    - [ac_mod_eq,    as_completed.__module__.__eq__,              ["concurrent.futures._base"], true, "as_completed.__module__ == 'concurrent.futures._base' (internal _base submodule, len=24); verified with Python 3.14.3"]
    - [ac_mod_len,   as_completed.__module__.__len__,             [],                           24,   "as_completed.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]
    - [ac_name_len,  as_completed.__name__.__len__,               [],                           12,   "as_completed.__name__.__len__() == 12 (same as co_qualname len=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait co_qualname, co_varnames, and module — extra113
#
# Wave 256 theme: wait co_qualname and co_varnames.__len__() (not previously covered).
#
# concurrent.futures.wait.__code__.co_qualname       == 'wait'   (len=4, shortest in spec)
# concurrent.futures.wait.__code__.co_varnames.__len__()  == 7
# concurrent.futures.wait.__module__                 == 'concurrent.futures._base'  (len=24)
# ---------------------------------------------------------------------------

table concurrent_futures_extra113.cf_wait_coqualname:
  description: "concurrent.futures.wait co_qualname and co_varnames length checks in cfcoq113 namespace — wave 256 theme: concurrent.futures.wait.__code__.co_qualname.__eq__('wait')==True (len=4: 'wait'=4; shortest co_qualname in spec — 8 chars shorter than as_completed=12; for module-level functions, co_qualname equals the function name; wait blocks until the given futures are done or a timeout occurs); concurrent.futures.wait.__code__.co_qualname.__len__()==4; concurrent.futures.wait.__code__.co_name.__eq__('wait')==True (co_name==co_qualname for module-level); concurrent.futures.wait.__code__.co_argcount.__eq__(3)==True (fs, timeout, return_when: 3 positional params compared to as_completed's 2; return_when controls when to stop — ALL_COMPLETED, FIRST_COMPLETED, or FIRST_EXCEPTION); concurrent.futures.wait.__code__.co_varnames.__len__()==7 ('fs','timeout','return_when','f','done','not_done','waiter': 3 parameters plus 4 local vars); concurrent.futures.wait.__module__.__eq__('concurrent.futures._base')==True (len=24: same module as as_completed — both defined in Lib/concurrent/futures/_base.py); concurrent.futures.wait.__module__.__len__()==24; compare: wait co_varnames len=7 vs as_completed co_varnames len=9 (wait has fewer locals because it does not iterate yielding one-by-one); compare co_argcount: as_completed=2 < wait=3 (wait takes 3 positional params); compare co_qualname len: wait=4 (shortest in spec) vs as_completed=12 (longest in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcoq113a

  columns: [id, function, args, expected, description]
  rows:
    - [wt_coq_eq,    wait.__code__.co_qualname.__eq__,    ["wait"],                        true, "wait.__code__.co_qualname == 'wait' (len=4, shortest in spec); verified with Python 3.14.3"]
    - [wt_coq_len,   wait.__code__.co_qualname.__len__,   [],                              4,    "wait.__code__.co_qualname.__len__() == 4 ('wait'=4, shortest co_qualname); verified with Python 3.14.3"]
    - [wt_co_name,   wait.__code__.co_name.__eq__,        ["wait"],                        true, "wait.__code__.co_name == 'wait' (co_name==co_qualname for module-level); verified with Python 3.14.3"]
    - [wt_argc,      wait.__code__.co_argcount.__eq__,    [3],                             true, "wait.__code__.co_argcount == 3 (fs, timeout, return_when); verified with Python 3.14.3"]
    - [wt_var_len,   wait.__code__.co_varnames.__len__,   [],                              7,    "wait.__code__.co_varnames.__len__() == 7 ('fs','timeout','return_when','f','done','not_done','waiter'); verified with Python 3.14.3"]
    - [wt_mod_eq,    wait.__module__.__eq__,              ["concurrent.futures._base"],    true, "wait.__module__ == 'concurrent.futures._base' (same module as as_completed, len=24); verified with Python 3.14.3"]
    - [wt_mod_len,   wait.__module__.__len__,             [],                              24,   "wait.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]
    - [wt_name_len,  wait.__name__.__len__,               [],                              4,    "wait.__name__.__len__() == 4 (same as co_qualname len=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures as_completed vs wait cross-checks — extra113
#
# Wave 256 theme: cross-attribute comparisons between as_completed and wait.
#
# Both share __module__ == 'concurrent.futures._base' (len=24)
# as_completed co_qualname len=12 > wait co_qualname len=4 (difference=8)
# wait co_argcount=3 > as_completed co_argcount=2 (difference=1)
# as_completed co_varnames len=9 > wait co_varnames len=7 (difference=2)
# ---------------------------------------------------------------------------

table concurrent_futures_extra113.cf_ac_wait_crosscheck:
  description: "concurrent.futures as_completed vs wait cross-check comparisons in cfcoq113 namespace — wave 256 theme: confirming module equality and relative magnitude comparisons; as_completed.__module__.__eq__('concurrent.futures._base')==True AND wait.__module__.__eq__('concurrent.futures._base')==True (both functions are defined in the same _base submodule and re-exported from concurrent/futures/__init__.py); as_completed.__code__.co_qualname.__len__()==12 (longer: as_completed=12 vs wait=4, difference=8 because 'as_completed' has 12 chars vs 'wait' has 4 chars); wait.__code__.co_argcount.__eq__(3)==True (wait has more positional params than as_completed which has co_argcount==2; wait=3 > as_completed=2 by 1); as_completed.__code__.co_varnames.__len__()==9 (as_completed has more locals than wait=7; difference=2; as_completed is a generator that must track more state); wait.__code__.co_varnames.__len__()==7 (fewer locals than as_completed=9; wait collects all done/pending futures in one pass rather than yielding one-by-one); concurrent.futures.wait.__qualname__.__eq__('wait')==True (__qualname__==co_qualname for module-level); concurrent.futures.as_completed.__qualname__.__eq__('as_completed')==True; concurrent.futures.wait.__code__.co_qualname.__len__()==4 (shortest in spec); concurrent.futures.as_completed.__code__.co_qualname.__len__()==12 (longest in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcoq113b

  columns: [id, function, args, expected, description]
  rows:
    - [ac_mod24,      as_completed.__module__.__len__,        [],   24,   "as_completed.__module__.__len__() == 24 (concurrent.futures._base=24); verified with Python 3.14.3"]
    - [wt_mod24,      wait.__module__.__len__,                [],   24,   "wait.__module__.__len__() == 24 (same module as as_completed); verified with Python 3.14.3"]
    - [ac_coq_12,     as_completed.__code__.co_qualname.__len__, [], 12,  "as_completed co_qualname len=12 (longer: 8 chars more than wait=4); verified with Python 3.14.3"]
    - [wt_coq_4,      wait.__code__.co_qualname.__len__,      [],   4,    "wait co_qualname len=4 (shorter: 8 chars fewer than as_completed=12); verified with Python 3.14.3"]
    - [wt_argc_3,     wait.__code__.co_argcount.__eq__,       [3],  true, "wait co_argcount==3 (1 more than as_completed co_argcount==2); verified with Python 3.14.3"]
    - [ac_var9,       as_completed.__code__.co_varnames.__len__, [], 9,   "as_completed co_varnames len=9 (2 more than wait=7; generator tracks more state); verified with Python 3.14.3"]
    - [wt_var7,       wait.__code__.co_varnames.__len__,      [],   7,    "wait co_varnames len=7 (fewer than as_completed=9; not a generator); verified with Python 3.14.3"]
    - [wt_qn_eq,      wait.__qualname__.__eq__,               ["wait"], true, "wait.__qualname__ == 'wait' (__qualname__==co_qualname for module-level); verified with Python 3.14.3"]
    - [ac_qn_eq,      as_completed.__qualname__.__eq__,       ["as_completed"], true, "as_completed.__qualname__ == 'as_completed'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra113
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra113.as_completed_co_qualname_len_12:
  description: "concurrent.futures.as_completed.__code__.co_qualname.__len__() == 12 — 'as_completed'=12 chars; as_completed is a module-level generator function so co_qualname equals the function name (no class prefix); concurrent.futures.as_completed.__code__.co_qualname.__eq__('as_completed')==True; co_qualname matches __qualname__ and __name__ for module-level functions; concurrent.futures.as_completed.__code__.co_argcount==2 (fs and timeout); concurrent.futures.as_completed.__code__.co_varnames.__len__()==9 (9 locals from extra75); concurrent.futures.as_completed.__module__=='concurrent.futures._base' (len=24); compare co_qualname lengths: wait=4 (shortest in spec) vs as_completed=12 (longest in spec, difference=8); first standalone as_completed co_qualname length invariant in cfcoq113 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: as_completed.__code__.co_qualname.__len__
  args: []
  expected: 12

invariant concurrent_futures_extra113.wait_co_qualname_len_4:
  description: "concurrent.futures.wait.__code__.co_qualname.__len__() == 4 — 'wait'=4 chars; this is the shortest co_qualname in this spec; concurrent.futures.wait.__code__.co_qualname.__eq__('wait')==True; co_qualname matches __qualname__ and __name__ for module-level functions; concurrent.futures.wait.__code__.co_argcount==3 (fs, timeout, return_when); concurrent.futures.wait.__code__.co_varnames.__len__()==7; concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24); compare: wait co_qualname len=4 (shortest) vs as_completed co_qualname len=12 (longest); first standalone wait co_qualname length invariant in cfcoq113 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: wait.__code__.co_qualname.__len__
  args: []
  expected: 4

invariant concurrent_futures_extra113.wait_co_varnames_len_7:
  description: "concurrent.futures.wait.__code__.co_varnames.__len__() == 7 — co_varnames==('fs','timeout','return_when','f','done','not_done','waiter'): 3 parameters (fs, timeout, return_when) plus 4 local variables (f for iteration, done set, not_done set, waiter object); concurrent.futures.wait.__code__.co_qualname=='wait' (len=4); concurrent.futures.wait.__code__.co_argcount==3; concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24); compare: wait co_varnames len=7 < as_completed co_varnames len=9 (as_completed is a generator with more state variables); the 4 local vars (f, done, not_done, waiter) reflect wait's algorithm: it iterates over futures (f), builds done and not_done sets, and uses a waiter object for synchronization; first standalone wait co_varnames length invariant in cfcoq113 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: wait.__code__.co_varnames.__len__
  args: []
  expected: 7

invariant concurrent_futures_extra113.as_completed_module_len_24:
  description: "concurrent.futures.as_completed.__module__.__len__() == 24 — '__module__=='concurrent.futures._base' (len=24: 'concurrent.futures._base'=24 chars); as_completed is implemented in Lib/concurrent/futures/_base.py and re-exported by concurrent/futures/__init__.py; its __module__ reflects the implementation file not the public API package; compare: 'concurrent.futures'=18 chars (public package) vs 'concurrent.futures._base'=24 chars (implementation module, 6 chars longer due to '._base'=6); concurrent.futures.wait.__module__.__len__()==24 (same module as as_completed); concurrent.futures.as_completed.__code__.co_qualname.__len__()==12; first standalone as_completed module length invariant in cfcoq113 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: as_completed.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra113.wait_co_argcount_3:
  description: "concurrent.futures.wait.__code__.co_argcount == 3 — wait takes fs (iterable of futures), timeout (seconds or None), and return_when (FIRST_COMPLETED, FIRST_EXCEPTION, or ALL_COMPLETED); 3 positional parameters; concurrent.futures.wait.__code__.co_qualname=='wait' (len=4); concurrent.futures.wait.__code__.co_varnames.__len__()==7 (3 params + 4 locals); concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24); compare: wait co_argcount=3 > as_completed co_argcount=2 (wait has one more positional param because it takes return_when to control when to stop waiting); note: wait co_argcount=3 is also the number of parameters in the corresponding asyncio.wait co_argcount (asyncio.wait also takes fs, timeout, return_when); first standalone wait co_argcount==3 invariant in cfcoq113 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: wait.__code__.co_argcount.__eq__
  args: [3]
  expected: true
