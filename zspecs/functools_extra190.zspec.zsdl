spec: functools_extra190
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.partial and functools.partialmethod class identity — functools.partial.__name__=='partial' (len=7); functools.partial.__module__=='functools' (pure-Python class); functools.partial.__qualname__=='partial'; functools.partial.__bases__[0].__name__=='object'; functools.partialmethod.__name__=='partialmethod' (len=13); functools.partialmethod.__module__=='functools'; functools.partialmethod.__qualname__=='partialmethod'; functools.partialmethod.__bases__[0].__name__=='object'."
    - "functools.partial.__name__ == 'partial' — partial is a pure-Python class defined in Lib/functools.py (though also accelerated via C); its __name__ is 'partial', 7 characters. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — unlike cmp_to_key and reduce which report '_functools', the partial class reports __module__=='functools'. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial' — as a module-level class, __qualname__ equals __name__ 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object (single-inheritance); __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__ == 'partialmethod' — partialmethod is a pure-Python descriptor class for use in class bodies; its __name__ is 'partialmethod', 13 characters. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__ == 'partialmethod' — module-level class has __qualname__ == __name__ == 'partialmethod'. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits directly from object; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial __name__, __module__, __qualname__
#
# functools.partial.__name__ == 'partial'
# functools.partial.__name__.__len__() == 7
# functools.partial.__module__ == 'functools'
# functools.partial.__qualname__ == 'partial'
#
# functools.partial is a class (both pure-Python in Lib/functools.py and
# optionally accelerated via C) that freezes some arguments of a callable.
# Its __module__ is 'functools' (not '_functools'), distinguishing it from the
# C builtins cmp_to_key and reduce. New to extra190.
# ---------------------------------------------------------------------------

table functools_extra190.partial_name_module_qualname:
  description: "functools.partial.__name__=='partial' len 7; __module__=='functools' (not _functools); __qualname__=='partial'; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: functpartial190

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a class that freezes arguments of a callable; its __name__ is 'partial' (7 chars); str.__eq__('partial') returns True; new to extra190"]
    - [partial_name_len_7,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — the name 'partial' has exactly 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; new to extra190"]
    - [partial_module_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is defined in the functools module (not the C extension _functools); its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra190"]
    - [partial_qualname_eq,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — as a module-level class, __qualname__ equals __name__ 'partial' (7 chars); str.__eq__('partial') returns True; new to extra190"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial __bases__ and functools.partialmethod __name__,
#          __module__
#
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__name__.__len__() == 13
# functools.partialmethod.__module__ == 'functools'
#
# partial inherits directly from object (no intermediate base). partialmethod
# is a descriptor class used in class bodies to define partial methods; its
# __name__ is 'partialmethod' (13 chars) and __module__ is 'functools'.
# New to extra190.
# ---------------------------------------------------------------------------

table functools_extra190.partial_bases_and_partialmethod_name:
  description: "functools.partial.__bases__[0].__name__=='object'; functools.partialmethod.__name__=='partialmethod' len 13; __module__=='functools'; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: functpartial190

  columns: [id, function, args, expected, description]
  rows:
    - ["partial_bases0_name_eq",
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra190"]
    - [partialmethod_name_eq,
       partialmethod.__name__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a descriptor class for defining partial methods in class bodies; its __name__ is 'partialmethod' (13 chars); str.__eq__('partialmethod') returns True; new to extra190"]
    - [partialmethod_name_len_13,
       partialmethod.__name__.__len__,
       [],
       13,
       "functools.partialmethod.__name__.__len__() == 13 — the name 'partialmethod' has exactly 13 characters: p-a-r-t-i-a-l-m-e-t-h-o-d; str.__len__() returns 13; new to extra190"]
    - [partialmethod_module_eq,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra190"]

# ---------------------------------------------------------------------------
# Table 3: functools.partialmethod __qualname__ and __bases__
#
# functools.partialmethod.__qualname__ == 'partialmethod'
# functools.partialmethod.__bases__[0].__name__ == 'object'
#
# As a module-level class, partialmethod has __qualname__ == __name__.
# It inherits directly from object (single-inheritance). New to extra190.
# ---------------------------------------------------------------------------

table functools_extra190.partialmethod_qualname_and_bases:
  description: "functools.partialmethod.__qualname__=='partialmethod' equals __name__; __bases__[0].__name__=='object'; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: functpartial190

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_qualname_eq,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — as a module-level class, __qualname__ equals __name__ 'partialmethod' (13 chars); str.__eq__('partialmethod') returns True; new to extra190"]
    - [partialmethod_qualname_len_13,
       partialmethod.__qualname__.__len__,
       [],
       13,
       "functools.partialmethod.__qualname__.__len__() == 13 — the qualname 'partialmethod' has exactly 13 characters, equal to the __name__ length; str.__len__() returns 13; new to extra190"]
    - ["partialmethod_bases0_name_eq",
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra190"]
    - [partial_qualname_len_7,
       partial.__qualname__.__len__,
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — cross-check: 'partial' qualname is 7 chars (same as __name__) while 'partialmethod' qualname is 13 chars; confirmed by str.__len__(); new to extra190"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra190
# ---------------------------------------------------------------------------

invariant functools_extra190.partial_name_is_partial:
  description: "functools.partial.__name__ == 'partial' — class that freezes some arguments of a callable for later calling; __name__ is 'partial' (7 chars); new to extra190"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra190.partial_module_is_functools:
  description: "functools.partial.__module__ == 'functools' — partial class reports __module__=='functools', unlike the C builtins cmp_to_key and reduce which report '_functools'; new to extra190"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra190.partial_qualname_equals_name:
  description: "functools.partial.__qualname__ == 'partial' — module-level class has __qualname__ == __name__ == 'partial' (7 chars); new to extra190"
  category: identity
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra190.partial_bases_root_is_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object with single-inheritance; __bases__[0].__name__ is 'object'; new to extra190"
  category: identity
