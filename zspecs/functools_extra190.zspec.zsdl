invariant functools_extra190.partialmethod_bases_root_is_object:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits directly from object with single-inheritance; __bases__[0].__name__ is 'object'; new to extra190"
