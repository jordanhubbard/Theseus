invariant functools_extra190.partialmethod_module_is_functools:
  description: "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in Lib/functools.py; its __module__ is 'functools'; new to extra190"
  category: identity
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra190.partialmethod_qualname_equals_name:
  description: "functools.partialmethod.__qualname__ == 'partialmethod' — module-level class has __qualname__ == __name__ == 'partialmethod' (13 chars); new to extra190"
  category: identity
  kind: python_call_eq
  function: partialmethod.__qualname__.__eq__
