spec: theseus_queue_cr
version: ">=3.9"
backend: python_cleanroom(theseus_queue_cr)
blocks: queue

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html"
  notes:
    - "Clean-room queue module. Do NOT import queue, threading, or collections."
    - "Queue: FIFO queue. put(item), get() -> item, empty() -> bool, qsize() -> int."
    - "LifoQueue: LIFO (stack) queue. Same API as Queue."
    - "PriorityQueue: lowest-value-first. put((priority, item)), get() returns lowest."
    - "queue_fifo(): put(1) put(2); get() == 1."
    - "queue_lifo(): LifoQueue put(1) put(2); get() == 2."
    - "queue_empty(): new Queue().empty() == True."
    - "Export: Queue, LifoQueue, PriorityQueue classes."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_queue_cr.fifo:
  description: "Queue FIFO: put(1), put(2), get() == 1"
  category: queue
  kind: python_call_eq
  function: queue_fifo
  args: []
  expected: 1

invariant theseus_queue_cr.lifo:
  description: "LifoQueue LIFO: put(1), put(2), get() == 2"
  category: lifo
  kind: python_call_eq
  function: queue_lifo
  args: []
  expected: 2

invariant theseus_queue_cr.empty:
  description: "new Queue().empty() == True"
  category: empty
  kind: python_call_eq
  function: queue_empty
  args: []
  expected: true
