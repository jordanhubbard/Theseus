spec: lodash_pull
version: ">=4.0.0"
backend: node(lodash.pull)

docs: https://lodash.com/docs/#pull

provenance:
  derived_from:
    - "lodash.pull README — https://www.npmjs.com/package/lodash.pull"
    - "Test vectors verified with lodash.pull@4.1.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.pull exports the _.pull function directly as module.exports."
    - "pull(array, ...values) removes all occurrences of values from array in place."
    - "Returns the mutated array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the mutated array with matching values removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_pull.pull:
  kind: node_module_call_eq
  function: ~
  category: pull
  id_prefix: lpull

  columns: [id, args, expected]
  rows:
    - [remove_one,   [[1, 2, 3, 1, 2], 2],      [1, 3, 1]]
    - [remove_multi, [[1, 2, 3, 4, 5], 2, 4],   [1, 3, 5]]
    - [not_present,  [[1, 2, 3], 9],             [1, 2, 3]]
