spec: uuid_extra1141
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.__package__/__loader__ class attrs, uuid.RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE class attrs, uuid.UUID.int member_descriptor attrs, uuid.UUID.hex/urn/variant/version property and fget class attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1141.package_and_loader_attrs:
  description: "uuid.__package__ and uuid.__loader__ class identity"
  kind: python_call_eq
  category: package_loader_attrs
  id_prefix: uu1141pl
  columns: [id, function, args, expected]
  rows:
    - [uu1141pl001, uuid.__package__.__eq__,                                  [""],                            true]
    - [uu1141pl002, uuid.__package__.__class__.__name__.__eq__,               ["str"],                         true]
    - [uu1141pl003, uuid.__package__.__class__.__qualname__.__eq__,           ["str"],                         true]
    - [uu1141pl004, uuid.__package__.__class__.__module__.__eq__,             ["builtins"],                    true]
    - [uu1141pl005, uuid.__loader__.__class__.__name__.__eq__,                ["SourceFileLoader"],             true]
    - [uu1141pl006, uuid.__loader__.__class__.__qualname__.__eq__,            ["SourceFileLoader"],             true]
    - [uu1141pl007, uuid.__loader__.__class__.__module__.__eq__,              ["_frozen_importlib_external"],   true]
    - [uu1141pl008, uuid.__package__.__class__.__name__.__class__.__name__.__eq__, ["str"],                    true]

table uuid_extra1141.reserved_constants_class_attrs:
  description: "uuid.RESERVED_NCS, RESERVED_MICROSOFT, RESERVED_FUTURE class name, qualname, and module identity"
  kind: python_call_eq
  category: reserved_constants_class_attrs
  id_prefix: uu1141rc
  columns: [id, function, args, expected]
  rows:
    - [uu1141rc001, uuid.RESERVED_NCS.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1141rc002, uuid.RESERVED_MICROSOFT.__class__.__name__.__eq__,        ["str"],      true]
    - [uu1141rc003, uuid.RESERVED_FUTURE.__class__.__name__.__eq__,           ["str"],      true]
    - [uu1141rc004, uuid.RESERVED_NCS.__class__.__qualname__.__eq__,          ["str"],      true]
    - [uu1141rc005, uuid.RESERVED_MICROSOFT.__class__.__qualname__.__eq__,    ["str"],      true]
    - [uu1141rc006, uuid.RESERVED_FUTURE.__class__.__qualname__.__eq__,       ["str"],      true]
    - [uu1141rc007, uuid.RESERVED_NCS.__class__.__module__.__eq__,            ["builtins"], true]
    - [uu1141rc008, uuid.RESERVED_MICROSOFT.__class__.__module__.__eq__,      ["builtins"], true]
    - [uu1141rc009, uuid.RESERVED_FUTURE.__class__.__module__.__eq__,         ["builtins"], true]
    - [uu1141rc010, uuid.RESERVED_NCS.__class__.__name__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra1141.uuid_int_member_and_hex_urn_props:
  description: "uuid.UUID.int member_descriptor attrs and uuid.UUID.hex/urn/variant/version property and fget class attrs"
  kind: python_call_eq
  category: uuid_int_member_hex_urn_props
  id_prefix: uu1141ip
  columns: [id, function, args, expected]
  rows:
    - [uu1141ip001, uuid.UUID.int.__class__.__name__.__eq__,               ["member_descriptor"], true]
    - [uu1141ip002, uuid.UUID.int.__class__.__qualname__.__eq__,           ["member_descriptor"], true]
    - [uu1141ip003, uuid.UUID.int.__class__.__module__.__eq__,             ["builtins"],           true]
    - [uu1141ip004, uuid.UUID.int.__name__.__eq__,                         ["int"],                true]
    - [uu1141ip005, uuid.UUID.int.__qualname__.__eq__,                     ["UUID.int"],           true]
    - [uu1141ip006, uuid.UUID.hex.__class__.__name__.__eq__,               ["property"],           true]
    - [uu1141ip007, uuid.UUID.urn.__class__.__name__.__eq__,               ["property"],           true]
    - [uu1141ip008, uuid.UUID.variant.__class__.__name__.__eq__,           ["property"],           true]
    - [uu1141ip009, uuid.UUID.version.__class__.__name__.__eq__,           ["property"],           true]
    - [uu1141ip010, uuid.UUID.hex.fget.__class__.__name__.__eq__,          ["function"],           true]
    - [uu1141ip011, uuid.UUID.urn.fget.__module__.__eq__,                  ["uuid"],               true]
    - [uu1141ip012, uuid.UUID.variant.fget.__module__.__eq__,              ["uuid"],               true]
    - [uu1141ip013, uuid.UUID.version.fget.__class__.__name__.__eq__,      ["function"],           true]
