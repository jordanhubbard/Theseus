spec: threading_extra191
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Semaphore.acquire.__name__ == 'acquire' (len=7); verified with Python 3.14.3."
    - "threading.Semaphore.release.__name__ == 'release' (len=7); verified with Python 3.14.3."
    - "threading.Semaphore.__enter__.__name__ == 'acquire' (len=7); __enter__ is an alias for acquire, not a separate method — __name__ reflects the underlying function name; verified with Python 3.14.3."
    - "threading.Semaphore.__exit__.__name__ == '__exit__' (len=8); verified with Python 3.14.3."
    - "threading.Semaphore.__class__.__name__ == 'type'; Semaphore is a regular Python class; verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading'; Semaphore is defined in the threading module; verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore'; top-level class so __qualname__ equals __name__; verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object'; Semaphore inherits directly from object; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore acquire/release method __name__ values
#
# threading.Semaphore.acquire.__name__  == 'acquire' (len=7)
# threading.Semaphore.release.__name__  == 'release' (len=7)
#
# acquire and release are the primary synchronization methods on Semaphore.
# Both have __name__ length of 7. New to extra191.
# ---------------------------------------------------------------------------

table threading_extra191.semaphore_acquire_release_names:
  description: "threading.Semaphore acquire and release method __name__ values: acquire=='acquire'(len=7); release=='release'(len=7); new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: threadingsema191

  columns: [id, function, args, expected, description]
  rows:
    - [acquire_name_eq,
       Semaphore.acquire.__name__.__eq__,
       ["acquire"],
       true,
       "threading.Semaphore.acquire.__name__.__eq__('acquire') == True — acquire is the primary Semaphore locking method; __name__ is 'acquire' (len=7: a-c-q-u-i-r-e); str.__eq__('acquire') returns True; verified with Python 3.14.3; new to extra191"]
    - [acquire_name_len,
       Semaphore.acquire.__name__.__len__,
       [],
       7,
       "threading.Semaphore.acquire.__name__.__len__() == 7 — 'acquire' has 7 characters: a-c-q-u-i-r-e; str.__len__() returns 7; verified with Python 3.14.3; new to extra191"]
    - [release_name_eq,
       Semaphore.release.__name__.__eq__,
       ["release"],
       true,
       "threading.Semaphore.release.__name__.__eq__('release') == True — release is the primary Semaphore unlocking method; __name__ is 'release' (len=7: r-e-l-e-a-s-e); str.__eq__('release') returns True; verified with Python 3.14.3; new to extra191"]
    - [release_name_len,
       Semaphore.release.__name__.__len__,
       [],
       7,
       "threading.Semaphore.release.__name__.__len__() == 7 — 'release' has 7 characters: r-e-l-e-a-s-e; str.__len__() returns 7; verified with Python 3.14.3; new to extra191"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore context manager method __name__ values
#
# threading.Semaphore.__enter__.__name__  == 'acquire' (len=7)
# threading.Semaphore.__exit__.__name__   == '__exit__' (len=8)
#
# __enter__ is an alias for acquire (same function object), so its __name__
# is 'acquire' not '__enter__'. __exit__ is a distinct method with __name__
# '__exit__' (len=8). New to extra191.
# ---------------------------------------------------------------------------

table threading_extra191.semaphore_context_manager_names:
  description: "threading.Semaphore context manager __name__ values: __enter__=='acquire'(len=7) as it is an alias for acquire; __exit__=='__exit__'(len=8); new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: threadingsema191

  columns: [id, function, args, expected, description]
  rows:
    - [enter_name_eq,
       "Semaphore.__enter__.__name__.__eq__",
       ["acquire"],
       true,
       "threading.Semaphore.__enter__.__name__.__eq__('acquire') == True — __enter__ is an alias for the acquire method; its __name__ reflects the underlying function 'acquire' (len=7) not '__enter__'; str.__eq__('acquire') returns True; verified with Python 3.14.3; new to extra191"]
    - [enter_name_len,
       "Semaphore.__enter__.__name__.__len__",
       [],
       7,
       "threading.Semaphore.__enter__.__name__.__len__() == 7 — __enter__.__name__ is 'acquire' which has 7 characters: a-c-q-u-i-r-e; str.__len__() returns 7; verified with Python 3.14.3; new to extra191"]
    - [exit_name_eq,
       "Semaphore.__exit__.__name__.__eq__",
       ["__exit__"],
       true,
       "threading.Semaphore.__exit__.__name__.__eq__('__exit__') == True — __exit__ is a distinct method (not an alias); __name__ is '__exit__' (len=8: __+exit+__); str.__eq__('__exit__') returns True; verified with Python 3.14.3; new to extra191"]
    - [exit_name_len,
       "Semaphore.__exit__.__name__.__len__",
       [],
       8,
       "threading.Semaphore.__exit__.__name__.__len__() == 8 — '__exit__' has 8 characters: _-_-e-x-i-t-_-_; str.__len__() returns 8; verified with Python 3.14.3; new to extra191"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore class identity — __class__, __module__, __qualname__, __bases__
#
# threading.Semaphore.__class__.__name__      == 'type'
# threading.Semaphore.__module__              == 'threading'
# threading.Semaphore.__qualname__            == 'Semaphore'
# threading.Semaphore.__bases__[0].__name__   == 'object'
#
# Semaphore is a regular Python class (metaclass is type) defined in the
# threading module. It inherits directly from object. __qualname__ equals
# __name__ because it is a top-level class. New to extra191.
# ---------------------------------------------------------------------------

table threading_extra191.semaphore_class_identity:
  description: "threading.Semaphore class identity: __class__.__name__=='type'; __module__=='threading'; __qualname__=='Semaphore'; __bases__[0].__name__=='object'; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: threadingsema191

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,
       Semaphore.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Semaphore.__class__.__name__.__eq__('type') == True — Semaphore is a regular Python class whose metaclass is type; __class__.__name__ is 'type'; str.__eq__('type') returns True; verified with Python 3.14.3; new to extra191"]
    - [module_eq,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in the threading module; str.__eq__('threading') returns True; verified with Python 3.14.3; new to extra191"]
    - [qualname_eq,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is a top-level class so __qualname__ equals __name__; str.__eq__('Semaphore') returns True; verified with Python 3.14.3; new to extra191"]
    - [bases_first_name,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object with no intermediary base; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra191"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra191
# ---------------------------------------------------------------------------

invariant threading_extra191.semaphore_acquire_name_eq:
  description: "threading.Semaphore.acquire.__name__.__eq__('acquire') == True — acquire is the primary locking method; __name__ is 'acquire' (len=7: a-c-q-u-i-r-e); verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: Semaphore.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra191.semaphore_release_name_eq:
  description: "threading.Semaphore.release.__name__.__eq__('release') == True — release is the primary unlocking method; __name__ is 'release' (len=7: r-e-l-e-a-s-e); verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: Semaphore.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant threading_extra191.semaphore_enter_name_is_acquire:
  description: "threading.Semaphore.__enter__.__name__.__eq__('acquire') == True — __enter__ is an alias for acquire; its __name__ is 'acquire' (len=7), not '__enter__'; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__enter__.__name__.__eq__"
  args: ["acquire"]
  expected: true

invariant threading_extra191.semaphore_exit_name_eq:
  description: "threading.Semaphore.__exit__.__name__.__eq__('__exit__') == True — __exit__ is a distinct method; __name__ is '__exit__' (len=8: __+exit+__); verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__exit__.__name__.__eq__"
  args: ["__exit__"]
  expected: true

invariant threading_extra191.semaphore_class_is_type:
  description: "threading.Semaphore.__class__.__name__.__eq__('type') == True — Semaphore is a regular Python class; its metaclass is type; __class__.__name__ is 'type'; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: Semaphore.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra191.semaphore_module_eq:
  description: "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in the threading module; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra191.semaphore_qualname_eq:
  description: "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is a top-level class; __qualname__ equals __name__ ('Semaphore'); verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: Semaphore.__qualname__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra191.semaphore_bases_object:
  description: "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object; no intermediary base; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra191.semaphore_acquire_name_len_seven:
  description: "threading.Semaphore.acquire.__name__.__len__() == 7 — 'acquire' has exactly 7 characters: a-c-q-u-i-r-e; str.__len__() returns 7; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: Semaphore.acquire.__name__.__len__
  args: []
  expected: 7

invariant threading_extra191.semaphore_exit_name_len_eight:
  description: "threading.Semaphore.__exit__.__name__.__len__() == 8 — '__exit__' has exactly 8 characters: _-_-e-x-i-t-_-_; str.__len__() returns 8; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__exit__.__name__.__len__"
  args: []
  expected: 8
