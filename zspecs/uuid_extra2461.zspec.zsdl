spec: uuid_extra2461
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid.zspec.zsdl, uuid_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether uuid.UUID defines the length protocol in its class __dict__."
    - "uuid.UUID.__dict__.__contains__('__len__') == False — UUID objects are not sequences; len(uuid_obj) raises TypeError."
    - "uuid.UUID.__dict__.__contains__('__length_hint__') == False — UUID objects do not define __length_hint__ either."
    - "uuid.UUID.__dict__.__contains__('int') == True — int is a property descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('hex') == True — hex is a property descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('bytes') == True — bytes is a property descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('version') == True — version is a property descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('fields') == True — fields is a property descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('urn') == True — urn is a property descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('is_safe') == True — is_safe is a property descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('__hash__') == True — UUID defines __hash__ for use as dict key."
    - "uuid.UUID.__dict__.__contains__('__iter__') == False — UUID objects are not iterable."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ and __length_hint__ absence — core theme of this spec
# uuid.UUID defines neither __len__ nor __length_hint__ in its class __dict__.
# UUID objects are opaque value types, not sequences or collections.
# ---------------------------------------------------------------------------

table uuid_extra2461.UUID.len_protocol:
  description: "uuid.UUID class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2461

  columns: [id, function, args, expected]
  rows:
    - ["uu2461-001", "UUID.__dict__.__contains__", ["__len__"],         false]
    - ["uu2461-002", "UUID.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Property descriptor presence — attributes in UUID.__dict__
# These are the core value accessors defined as properties on the UUID class.
# ---------------------------------------------------------------------------

table uuid_extra2461.UUID.property_presence:
  description: "uuid.UUID class __dict__ contains the core property descriptors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2461

  columns: [id, function, args, expected]
  rows:
    - ["uu2461-010", "UUID.__dict__.__contains__", ["int"],     true]
    - ["uu2461-011", "UUID.__dict__.__contains__", ["hex"],     true]
    - ["uu2461-012", "UUID.__dict__.__contains__", ["bytes"],   true]
    - ["uu2461-013", "UUID.__dict__.__contains__", ["version"], true]
    - ["uu2461-014", "UUID.__dict__.__contains__", ["fields"],  true]
    - ["uu2461-015", "UUID.__dict__.__contains__", ["urn"],     true]
    - ["uu2461-016", "UUID.__dict__.__contains__", ["is_safe"], true]

# ---------------------------------------------------------------------------
# Dunder method presence — UUID defines comparison and string dunders
# ---------------------------------------------------------------------------

table uuid_extra2461.UUID.dunder_presence:
  description: "uuid.UUID class __dict__ contains __hash__, __eq__, __str__, __repr__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2461

  columns: [id, function, args, expected]
  rows:
    - ["uu2461-020", "UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu2461-021", "UUID.__dict__.__contains__", ["__eq__"],   true]
    - ["uu2461-022", "UUID.__dict__.__contains__", ["__str__"],  true]
    - ["uu2461-023", "UUID.__dict__.__contains__", ["__repr__"], true]

# ---------------------------------------------------------------------------
# Absent protocols — UUID does not define iteration or truthiness overrides
# ---------------------------------------------------------------------------

table uuid_extra2461.UUID.absent_protocols:
  description: "uuid.UUID class __dict__ does not contain __iter__, __bool__, __len__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2461

  columns: [id, function, args, expected]
  rows:
    - ["uu2461-030", "UUID.__dict__.__contains__", ["__iter__"], false]
    - ["uu2461-031", "UUID.__dict__.__contains__", ["__bool__"], false]

# ---------------------------------------------------------------------------
# Additional property descriptors — bytes_le, clock_seq, node, time, variant
# ---------------------------------------------------------------------------

table uuid_extra2461.UUID.extra_properties:
  description: "uuid.UUID class __dict__ contains bytes_le, clock_seq, node, time, variant"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2461

  columns: [id, function, args, expected]
  rows:
    - ["uu2461-040", "UUID.__dict__.__contains__", ["bytes_le"],  true]
    - ["uu2461-041", "UUID.__dict__.__contains__", ["clock_seq"], true]
    - ["uu2461-042", "UUID.__dict__.__contains__", ["node"],      true]
    - ["uu2461-043", "UUID.__dict__.__contains__", ["time"],      true]
    - ["uu2461-044", "UUID.__dict__.__contains__", ["variant"],   true]
