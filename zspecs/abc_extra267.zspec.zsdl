spec: abc_extra267
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "abc.__name__ == 'abc' and abc.__package__ == '' (empty string; frozen modules have empty __package__)."
    - "abc.__spec__.name == 'abc' and abc.__spec__.origin == 'frozen' (abc is a frozen module in Python 3.11+)."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec'; abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is the class itself, not an instance)."
    - "collections.abc.__name__ == 'collections.abc' but __spec__.name == '_collections_abc' (the implementation module)."
    - "collections.abc.__package__ == '' (empty string; frozen module with no package)."
    - "collections.abc.__loader__.__class__.__name__ == 'type' (FrozenImporter class, same pattern as abc)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module __spec__ and __package__ identity — table
#
# Module-level attributes: __name__, __package__, __spec__.name,
# __spec__.origin, __spec__.__class__.__name__, __loader__.__class__.__name__.
# abc is a frozen module: __package__ == '' and __spec__.origin == 'frozen'.
# ---------------------------------------------------------------------------

table abc_extra267.abc_module_spec_identity:
  description: "abc module __spec__ and __package__ identity (frozen module)"
  kind: python_call_eq
  category: identity
  id_prefix: abcspec267

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       abc.__name__.__eq__,                        ["abc"],         true, "abc.__name__ == 'abc'"]
    - [pkg_eq,        abc.__package__.__eq__,                     [""],            true, "abc.__package__ == '' (frozen modules have empty __package__)"]
    - [spec_name_eq,  abc.__spec__.name.__eq__,                   ["abc"],         true, "abc.__spec__.name == 'abc'"]
    - [spec_cls_eq,   abc.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"],  true, "abc.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [loader_cls_eq, abc.__loader__.__class__.__name__.__eq__,   ["type"],        true, "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, metaclass is type)"]

# ---------------------------------------------------------------------------
# collections.abc module __spec__ identity — table
#
# collections.abc is also a frozen module; its __spec__.name is '_collections_abc'
# (the underlying implementation module), not 'collections.abc'.
# ---------------------------------------------------------------------------

table abc_extra267.collections_abc_spec_identity:
  description: "collections.abc module __spec__ and __package__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: colabcspec267

  columns: [id, function, args, expected, description]
  rows:
    - [cabc_name,      collections.abc.__name__.__eq__,                    ["collections.abc"],  true, "collections.abc.__name__ == 'collections.abc'"]
    - [cabc_pkg,       collections.abc.__package__.__eq__,                 [""],                 true, "collections.abc.__package__ == '' (frozen module, no package)"]
    - [cabc_spec_name, collections.abc.__spec__.name.__eq__,               ["_collections_abc"], true, "collections.abc.__spec__.name == '_collections_abc' (underlying implementation module)"]
    - [cabc_spec_cls,  collections.abc.__spec__.__class__.__name__.__eq__, ["ModuleSpec"],       true, "collections.abc.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [cabc_ldr_cls,   collections.abc.__loader__.__class__.__name__.__eq__, ["type"],           true, "collections.abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class)"]

# ---------------------------------------------------------------------------
# abc.__spec__.origin — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra267.abc_spec_origin_frozen:
  description: "abc.__spec__.origin == 'frozen'"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.origin.__eq__
  args: ["frozen"]
  expected: true

# ---------------------------------------------------------------------------
# abc.__spec__.parent — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra267.abc_spec_parent_empty:
  description: "abc.__spec__.parent == ''"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.parent.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.__spec__.parent — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra267.collections_abc_spec_parent_empty:
  description: "collections.abc.__spec__.parent == ''"
  category: identity
  kind: python_call_eq
  function: collections.abc.__spec__.parent.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# abc.__loader__.__name__ is FrozenImporter — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra267.abc_loader_name_FrozenImporter:
  description: "abc.__loader__.__name__ == 'FrozenImporter'"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true
