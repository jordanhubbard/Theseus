spec: io_extra1486
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, BufferedReader, TextIOWrapper documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "_io C extension source"
  notes:
    - "Wave 546 (_extra1486): context manager protocol checks for io module classes."
    - "All io classes inherit __enter__ and __exit__ from _io._IOBase (the C-level base). The Python-level io.IOBase wraps _io._IOBase but does NOT itself define __enter__/__exit__ in its own __dict__."
    - "io.IOBase.__dict__.__contains__('__enter__') == False — __enter__ is defined on _io._IOBase, not on the Python-level io.IOBase class object."
    - "io.IOBase.__enter__.__class__.__name__ == 'method_descriptor' — the method is accessible via MRO but lives in the C-level _io._IOBase.__dict__."
    - "All subclasses (BytesIO, StringIO, FileIO, BufferedReader, TextIOWrapper, RawIOBase, BufferedIOBase, TextIOBase) also return False for __dict__.__contains__('__enter__') because they inherit from _io._IOBase, not from the Python io.IOBase."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1486.iobase_context_manager_protocol:
  description: "io.IOBase context manager protocol — __enter__ and __exit__ are inherited from the C-level _io._IOBase and are NOT in io.IOBase.__dict__; they are accessible as method_descriptor objects via MRO; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: io1486ib
  columns: [id, function, args, expected, description]
  rows:
    - [io1486ib001,
       io.IOBase.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.IOBase.__dict__.__contains__('__enter__') == False — __enter__ is defined in the C-level _io._IOBase, not in the Python-level io.IOBase class __dict__; io.IOBase wraps _io._IOBase but does not redefine __enter__ in its own namespace; verified with Python 3.12"]
    - [io1486ib002,
       io.IOBase.__dict__.__contains__,
       ["__exit__"],
       false,
       "io.IOBase.__dict__.__contains__('__exit__') == False — __exit__ is defined in _io._IOBase, not in io.IOBase.__dict__; the context manager protocol is implemented at the C level and inherited via MRO; verified with Python 3.12"]
    - [io1486ib003,
       io.IOBase.__enter__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "io.IOBase.__enter__.__class__.__name__ == 'method_descriptor' — even though __enter__ is not in io.IOBase.__dict__, it is accessible via MRO from _io._IOBase where it is stored as a C method_descriptor; verified with Python 3.12"]
    - [io1486ib004,
       io.IOBase.__exit__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "io.IOBase.__exit__.__class__.__name__ == 'method_descriptor' — __exit__ is accessible via MRO from _io._IOBase; the C-level descriptor type is method_descriptor, the same type used for built-in methods; verified with Python 3.12"]
    - [io1486ib005,
       io.IOBase.__dict__.__contains__,
       ["__abstractmethods__"],
       true,
       "io.IOBase.__dict__.__contains__('__abstractmethods__') == True — __abstractmethods__ IS defined in io.IOBase.__dict__; this is a Python-level attribute, in contrast to __enter__ and __exit__ which are defined at the C level; verified with Python 3.12"]
    - [io1486ib006,
       io.IOBase.__dict__.__contains__,
       ["__doc__"],
       true,
       "io.IOBase.__dict__.__contains__('__doc__') == True — __doc__ is a Python-level attribute present in io.IOBase.__dict__, demonstrating that the Python wrapper does define some attributes even though it delegates __enter__/__exit__ to the C base; verified with Python 3.12"]

table io_extra1486.concrete_classes_context_manager_protocol:
  description: "io.BytesIO, io.StringIO, io.FileIO context manager protocol — none define __enter__ or __exit__ in their own __dict__; all inherit from _io._IOBase via MRO; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: io1486cc
  columns: [id, function, args, expected, description]
  rows:
    - [io1486cc001,
       io.BytesIO.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.BytesIO.__dict__.__contains__('__enter__') == False — BytesIO is an in-memory bytes stream; it does not define __enter__ in its own __dict__ but inherits it from _io._IOBase; verified with Python 3.12"]
    - [io1486cc002,
       io.BytesIO.__dict__.__contains__,
       ["__exit__"],
       false,
       "io.BytesIO.__dict__.__contains__('__exit__') == False — BytesIO inherits __exit__ from _io._IOBase; its own __dict__ contains stream methods like read and write but not the context manager dunder methods; verified with Python 3.12"]
    - [io1486cc003,
       io.BytesIO.__enter__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "io.BytesIO.__enter__.__class__.__name__ == 'method_descriptor' — accessible via MRO from _io._IOBase; BytesIO instances can be used as context managers through this inherited C-level descriptor; verified with Python 3.12"]
    - [io1486cc004,
       io.StringIO.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.StringIO.__dict__.__contains__('__enter__') == False — StringIO is an in-memory text stream; it does not define __enter__ in its own __dict__ but inherits context manager support from _io._IOBase; verified with Python 3.12"]
    - [io1486cc005,
       io.StringIO.__dict__.__contains__,
       ["__exit__"],
       false,
       "io.StringIO.__dict__.__contains__('__exit__') == False — StringIO inherits __exit__ from _io._IOBase; its own __dict__ provides text-mode operations but not context manager dunders; verified with Python 3.12"]
    - [io1486cc006,
       io.StringIO.__dict__.__contains__,
       ["read"],
       true,
       "io.StringIO.__dict__.__contains__('read') == True — StringIO defines 'read' in its own __dict__; this illustrates that StringIO DOES define text-stream methods directly, but delegates context manager support to _io._IOBase; verified with Python 3.12"]
    - [io1486cc007,
       io.FileIO.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.FileIO.__dict__.__contains__('__enter__') == False — FileIO is the raw file I/O class; it does not define __enter__ in its own __dict__; context manager support comes from _io._IOBase; verified with Python 3.12"]
    - [io1486cc008,
       io.FileIO.__dict__.__contains__,
       ["__exit__"],
       false,
       "io.FileIO.__dict__.__contains__('__exit__') == False — FileIO inherits __exit__ from _io._IOBase; its own __dict__ contains OS-level I/O methods; verified with Python 3.12"]
    - [io1486cc009,
       io.FileIO.__dict__.__contains__,
       ["read"],
       true,
       "io.FileIO.__dict__.__contains__('read') == True — FileIO defines 'read' in its own __dict__; it is a concrete I/O class that owns its read method while inheriting context manager support; verified with Python 3.12"]

table io_extra1486.buffered_text_classes_context_manager_protocol:
  description: "io.BufferedReader, io.TextIOWrapper, io.RawIOBase, io.BufferedIOBase, io.TextIOBase context manager protocol — none define __enter__ or __exit__ in their own __dict__; all inherit from _io._IOBase; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: io1486bt
  columns: [id, function, args, expected, description]
  rows:
    - [io1486bt001,
       io.BufferedReader.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.BufferedReader.__dict__.__contains__('__enter__') == False — BufferedReader wraps a raw stream with buffering; it does not define __enter__ in its own __dict__ but inherits context manager support from _io._IOBase; verified with Python 3.12"]
    - [io1486bt002,
       io.BufferedReader.__dict__.__contains__,
       ["__exit__"],
       false,
       "io.BufferedReader.__dict__.__contains__('__exit__') == False — BufferedReader inherits __exit__ from _io._IOBase; its own __dict__ provides buffered-read methods; verified with Python 3.12"]
    - [io1486bt003,
       io.BufferedReader.__enter__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "io.BufferedReader.__enter__.__class__.__name__ == 'method_descriptor' — accessible via MRO from _io._IOBase; the C-level method_descriptor type is the same for all io classes; verified with Python 3.12"]
    - [io1486bt004,
       io.TextIOWrapper.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.TextIOWrapper.__dict__.__contains__('__enter__') == False — TextIOWrapper provides a text-mode interface over a binary stream; it does not define __enter__ in its own __dict__; context manager support is inherited from _io._IOBase; verified with Python 3.12"]
    - [io1486bt005,
       io.TextIOWrapper.__dict__.__contains__,
       ["__exit__"],
       false,
       "io.TextIOWrapper.__dict__.__contains__('__exit__') == False — TextIOWrapper inherits __exit__ from _io._IOBase; its own __dict__ contains text encoding and decoding methods; verified with Python 3.12"]
    - [io1486bt006,
       io.TextIOWrapper.__dict__.__contains__,
       ["read"],
       true,
       "io.TextIOWrapper.__dict__.__contains__('read') == True — TextIOWrapper defines 'read' in its own __dict__; it provides text-mode read while delegating context manager support upward; verified with Python 3.12"]
    - [io1486bt007,
       io.RawIOBase.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.RawIOBase.__dict__.__contains__('__enter__') == False — RawIOBase is the abstract base for raw I/O; it does not define __enter__ in its own __dict__; context manager support comes from _io._IOBase; verified with Python 3.12"]
    - [io1486bt008,
       io.BufferedIOBase.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.BufferedIOBase.__dict__.__contains__('__enter__') == False — BufferedIOBase is the abstract base for buffered I/O; it does not define __enter__ in its own __dict__; context manager support is inherited from _io._IOBase; verified with Python 3.12"]
    - [io1486bt009,
       io.TextIOBase.__dict__.__contains__,
       ["__enter__"],
       false,
       "io.TextIOBase.__dict__.__contains__('__enter__') == False — TextIOBase is the abstract base for text I/O; it does not define __enter__ in its own __dict__; all three abstract bases (RawIOBase, BufferedIOBase, TextIOBase) inherit context manager support from _io._IOBase; verified with Python 3.12"]
