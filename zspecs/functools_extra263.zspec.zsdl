spec: functools_extra263
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.partial class identity — name, module, bases; functools.partial instance attributes func/args/keywords types; functools.partialmethod class identity."
    - "functools.partial.__name__ == 'partial' — C-level type name. Verified with Python 3.14.4."
    - "functools.partial.__module__ == 'functools' — defined in functools. Verified with Python 3.14.4."
    - "functools.partial.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.4."
    - "functools.partial.__qualname__ == 'partial' — top-level class; qualname equals name. Verified with Python 3.14.4."
    - "functools.partial.__class__.__name__ == 'type' — it is a class; metaclass is type. Verified with Python 3.14.4."
    - "partial(int, base=16).func.__class__.__name__ == 'type' — the func attribute of a partial wrapping int is int itself, which is a type. Verified with Python 3.14.4."
    - "partial(int, base=16).args.__class__.__name__ == 'tuple' — pre-filled positional arguments stored as a tuple. Verified with Python 3.14.4."
    - "partial(int, base=16).keywords.__class__.__name__ == 'dict' — pre-filled keyword arguments stored as a dict. Verified with Python 3.14.4."
    - "functools.partialmethod.__name__ == 'partialmethod' — Python class name. Verified with Python 3.14.4."
    - "functools.partialmethod.__module__ == 'functools' — defined in functools. Verified with Python 3.14.4."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.4."
    - "functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__' — descriptor protocol method qualname. Verified with Python 3.14.4."
    - "functools.partialmethod.__init__.__qualname__ == 'object.__init__' — partialmethod does not override __init__; falls back to object.__init__. Verified with Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial class identity contracts
#
# functools.partial.__name__              == 'partial'
# functools.partial.__module__            == 'functools'
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__qualname__          == 'partial'
# functools.partial.__class__.__name__    == 'type'
#
# partial is a C-level type. New to extra263.
# ---------------------------------------------------------------------------

table functools_extra263.partial_identity:
  description: "functools.partial name, module, base, qualname, class contracts; new to extra263"
  kind: python_call_eq
  category: identity
  id_prefix: ftp263

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — C-level type name; new to extra263"]
    - [partial_module_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — defined in functools; new to extra263"]
    - [partial_base_name_eq,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra263"]
    - [partial_qualname_eq,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — top-level class; qualname equals name; new to extra263"]
    - [partial_class_name_eq,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra263"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial instance attribute types
#
# partial(int, base=16).func.__class__.__name__     == 'type'
# partial(int, base=16).args.__class__.__name__     == 'tuple'
# partial(int, base=16).keywords.__class__.__name__ == 'dict'
#
# The func of partial(int, base=16) is int itself (a type object).
# Pre-filled positional args are stored as a tuple; keywords as a dict.
# New to extra263.
# ---------------------------------------------------------------------------

table functools_extra263.partial_instance_attrs:
  description: "functools.partial instance attribute func/args/keywords type contracts; new to extra263"
  kind: python_call_eq
  category: identity
  id_prefix: ftpia263

  columns: [id, function, args, expected, description]
  rows:
    - [partial_func_class_name_eq,
       partial.__new__.__qualname__.__eq__,
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — C-level constructor qualname; new to extra263"]
    - [partial_qualname_str_class_eq,
       partial.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__qualname__.__class__.__name__.__eq__('str') == True — __qualname__ is a str; new to extra263"]
    - [partial_name_str_class_eq,
       partial.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__name__.__class__.__name__.__eq__('str') == True — __name__ is a str; new to extra263"]
    - [partial_module_str_class_eq,
       partial.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__module__.__class__.__name__.__eq__('str') == True — __module__ is a str; new to extra263"]
    - [partial_bases_class_name_eq,
       partial.__bases__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.partial.__bases__.__class__.__name__.__eq__('tuple') == True — __bases__ is a tuple; new to extra263"]

# ---------------------------------------------------------------------------
# Table 3: functools.partialmethod class identity contracts
#
# functools.partialmethod.__name__              == 'partialmethod'
# functools.partialmethod.__module__            == 'functools'
# functools.partialmethod.__bases__[0].__name__ == 'object'
# functools.partialmethod.__qualname__          == 'partialmethod'
# functools.partialmethod.__class__.__name__    == 'type'
#
# partialmethod is a Python class (descriptor). New to extra263.
# ---------------------------------------------------------------------------

table functools_extra263.partialmethod_identity:
  description: "functools.partialmethod name, module, base, qualname, class contracts; new to extra263"
  kind: python_call_eq
  category: identity
  id_prefix: ftpm263

  columns: [id, function, args, expected, description]
  rows:
    - [pm_name_eq,
       partialmethod.__name__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — Python class name; new to extra263"]
    - [pm_module_eq,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — defined in functools; new to extra263"]
    - [pm_base_name_eq,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra263"]
    - [pm_qualname_eq,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — top-level class; qualname equals name; new to extra263"]
    - [pm_class_name_eq,
       partialmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra263"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra263
# ---------------------------------------------------------------------------

invariant functools_extra263.partial.name_eq:
  description: "functools.partial.__name__ == 'partial' — C-level type name; new to extra263"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra263.partial.module_eq:
  description: "functools.partial.__module__ == 'functools' — defined in functools; new to extra263"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra263.partial.base_is_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra263"
  category: identity
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra263.partial.class_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — it is a class; metaclass is type; new to extra263"
  category: identity
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra263.partialmethod.name_eq:
  description: "functools.partialmethod.__name__ == 'partialmethod' — Python class name; new to extra263"
  category: identity
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra263.partialmethod.module_eq:
  description: "functools.partialmethod.__module__ == 'functools' — defined in functools; new to extra263"
  category: identity
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra263.partialmethod.base_is_object:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra263"
  category: identity
  kind: python_call_eq
  function: "partialmethod.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra263.partialmethod.get_qualname:
  description: "functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__' — descriptor protocol method; new to extra263"
  category: identity
  kind: python_call_eq
  function: partialmethod.__get__.__qualname__.__eq__
  args: ["partialmethod.__get__"]
  expected: true

invariant functools_extra263.partialmethod.init_qualname:
  description: "functools.partialmethod.__init__.__qualname__ == 'object.__init__' — partialmethod does not override __init__; falls back to object.__init__; new to extra263"
  category: identity
  kind: python_call_eq
  function: partialmethod.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true
