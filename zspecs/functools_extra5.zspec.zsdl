spec: functools_extra5
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Extends functools.zspec.zsdl, functools_extra.zspec.zsdl, functools_extra2.zspec.zsdl, functools_extra3.zspec.zsdl, functools_extra4.zspec.zsdl."
    - "Previous specs cover: function names, partial class name, lru_cache/cache behavior, reduce basic use, WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES tuple class names, partial.func/keywords/args, reduce.__module__, lru_cache/cache/cached_property/total_ordering/singledispatch/cmp_to_key __name__."
    - "functools.partial.__module__ == 'functools' — partial class is exposed through functools namespace."
    - "functools.wraps.__module__ == 'functools' — wraps is a Python function defined in functools."
    - "functools.reduce.__name__ == 'reduce' — reduce is the builtin_function_or_method name."
    - "functools.WRAPPER_ASSIGNMENTS is a tuple; its __class__.__name__ == 'tuple'."
    - "functools.WRAPPER_UPDATES is a tuple; its __class__.__name__ == 'tuple'."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits from object."
    - "functools.singledispatch.__module__ == 'functools'."
    - "functools.update_wrapper.__name__ == 'update_wrapper'."
    - "functools.update_wrapper.__module__ == 'functools'."
    - "functools.total_ordering.__module__ == 'functools'."
    - "functools.cmp_to_key.__module__ == 'functools' or '_functools' depending on C acceleration."
    - "functools.lru_cache.__module__ == 'functools'."
    - "functools.cache.__module__ == 'functools'."
    - "functools.cached_property.__module__ == 'functools'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ table — all key functools symbols
# ---------------------------------------------------------------------------

table functools_extra5.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [partial,          partial.__module__.__eq__,          ["functools"], true]
    - [wraps,            wraps.__module__.__eq__,            ["functools"], true]
    - [singledispatch,   singledispatch.__module__.__eq__,   ["functools"], true]
    - [update_wrapper,   update_wrapper.__module__.__eq__,   ["functools"], true]
    - [total_ordering,   total_ordering.__module__.__eq__,   ["functools"], true]
    - [lru_cache,        lru_cache.__module__.__eq__,        ["functools"], true]
    - [cache,            cache.__module__.__eq__,            ["functools"], true]
    - [cached_property,  cached_property.__module__.__eq__,  ["functools"], true]

# ---------------------------------------------------------------------------
# reduce.__name__ — 'reduce'
#
# functools.reduce is a C builtin; its __name__ reports 'reduce'.
# functools_extra4 verified __module__; this spec adds __name__.
# ---------------------------------------------------------------------------

invariant functools_extra5.reduce.name:
  description: "functools.reduce.__name__ == 'reduce'"
  category: reduce
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS — tuple class name
#
# functools.WRAPPER_ASSIGNMENTS is a tuple of attribute name strings that
# update_wrapper copies from the wrapped function.
# ---------------------------------------------------------------------------

invariant functools_extra5.WRAPPER_ASSIGNMENTS.class_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'"
  category: wrapper_constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES — tuple class name
#
# functools.WRAPPER_UPDATES is a tuple listing attributes that are updated
# (i.e., merged) on the wrapper — typically ('__dict__',).
# ---------------------------------------------------------------------------

invariant functools_extra5.WRAPPER_UPDATES.class_name:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'"
  category: wrapper_constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# partial.__bases__[0].__name__ — 'object'
#
# functools.partial is a C extension class whose single base is object.
# ---------------------------------------------------------------------------

invariant functools_extra5.partial.base_is_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: partial.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# cached_property.__bases__[0].__name__ — 'object'
#
# functools.cached_property is a pure-Python descriptor class whose single
# base is object.
# ---------------------------------------------------------------------------

invariant functools_extra5.cached_property.base_is_object:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: cached_property.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# update_wrapper.__name__ — 'update_wrapper'
# ---------------------------------------------------------------------------

invariant functools_extra5.update_wrapper.name:
  description: "functools.update_wrapper.__name__ == 'update_wrapper'"
  category: update_wrapper
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

# ---------------------------------------------------------------------------
# cmp_to_key.__module__ — 'functools' or '_functools'
#
# cmp_to_key is accelerated by a C implementation when available; its
# __module__ is '_functools' on CPython with C extensions enabled.
# We verify via __eq__ returning true for '_functools'.
# ---------------------------------------------------------------------------

invariant functools_extra5.cmp_to_key.module:
  description: "functools.cmp_to_key.__module__ == '_functools' (C-accelerated) or 'functools' (pure-Python fallback)"
  category: module_checks
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true
