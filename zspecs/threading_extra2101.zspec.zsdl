spec: threading_extra2101
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2101 (_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks for threading module types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread does NOT define __class_getitem__ in its own __dict__ (False) — Thread is a plain Python class without subscript generic alias support."
    - "threading._LockType (the C-level lock type) does NOT define __class_getitem__ in its own __dict__ (False)."
    - "threading._CRLock (the C-level RLock type) does NOT define __class_getitem__ in its own __dict__ (False)."
    - "threading._RLock (the Python-level RLock class) does NOT define __class_getitem__ in its own __dict__ (False)."
    - "threading.Condition, Event, Semaphore, BoundedSemaphore, Barrier, Timer all have False for __class_getitem__ in their own __dict__."
    - "threading.local does NOT define __class_getitem__ in its own __dict__ (False) — thread-local storage is not a generic container type."
    - "None of the threading types define __init_subclass__ in their own __dict__ — they rely on inherited object.__init_subclass__."
    - "None of the threading types define __subclasshook__ in their own __dict__ — threading types are not ABC-based."
    - "None of the threading types define __mro_entries__ in their own __dict__ — threading types are concrete runtime objects, not generic alias proxies."
    - "threading.ExceptHookArgs (namedtuple) and threading.BrokenBarrierError (exception) also have all False for the four dunders."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ dict-presence for threading types
#
# All threading public types: False
# Thread, Lock, RLock, Event, Condition, Semaphore, BoundedSemaphore,
# Barrier, Timer, local, ExceptHookArgs, BrokenBarrierError all return False.
# ---------------------------------------------------------------------------

table threading_extra2101.class_getitem_protocol:
  description: "threading types __class_getitem__ dict-presence checks — all False (no generic alias support)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2101

  columns: [id, function, args, expected]
  rows:
    - ["th2101001", "threading.Thread.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101002", "threading._LockType.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101003", "threading._RLock.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101004", "threading._CRLock.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101005", "threading.Event.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101006", "threading.Condition.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101007", "threading.Semaphore.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101008", "threading.BoundedSemaphore.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101009", "threading.Barrier.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101010", "threading.Timer.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101011", "threading.local.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101012", "threading.BrokenBarrierError.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2101013", "threading.ExceptHookArgs.__dict__.__contains__", ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 2: __init_subclass__ dict-presence for threading types
#
# None of the threading types override __init_subclass__ in their own
# __dict__. Thread, Lock, RLock, Event, Condition, Semaphore, Barrier, Timer,
# local, BrokenBarrierError all inherit object.__init_subclass__.
# ---------------------------------------------------------------------------

table threading_extra2101.init_subclass_protocol:
  description: "threading types __init_subclass__ dict-presence checks — all False (inherited from object)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2101

  columns: [id, function, args, expected]
  rows:
    - ["th2101014", "threading.Thread.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101015", "threading._LockType.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101016", "threading._RLock.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101017", "threading._CRLock.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101018", "threading.Event.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101019", "threading.Condition.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101020", "threading.Semaphore.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101021", "threading.BoundedSemaphore.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101022", "threading.Barrier.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101023", "threading.Timer.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101024", "threading.local.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2101025", "threading.BrokenBarrierError.__dict__.__contains__", ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 3: __subclasshook__ dict-presence for threading types
#
# __subclasshook__ is the ABCMeta virtual subclass hook. No threading type
# uses ABCMeta as its metaclass, so none define this hook in their own
# __dict__. The threading module is purely concrete.
# ---------------------------------------------------------------------------

table threading_extra2101.subclasshook_protocol:
  description: "threading types __subclasshook__ dict-presence checks — all False (not ABC-based)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2101

  columns: [id, function, args, expected]
  rows:
    - ["th2101026", "threading.Thread.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101027", "threading._LockType.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101028", "threading._RLock.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101029", "threading._CRLock.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101030", "threading.Event.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101031", "threading.Condition.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101032", "threading.Semaphore.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101033", "threading.BoundedSemaphore.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101034", "threading.Barrier.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101035", "threading.Timer.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2101036", "threading.local.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 4: __mro_entries__ dict-presence for threading types
#
# __mro_entries__ allows an object to expand into multiple bases when used
# in a class definition's base list (PEP 560). Threading types are concrete
# runtime objects (mutexes, threads, conditions) and none define this hook
# in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2101.mro_entries_protocol:
  description: "threading types __mro_entries__ dict-presence checks — all False (not MRO-entry proxy types)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2101

  columns: [id, function, args, expected]
  rows:
    - ["th2101037", "threading.Thread.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101038", "threading._LockType.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101039", "threading._RLock.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101040", "threading._CRLock.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101041", "threading.Event.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101042", "threading.Condition.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101043", "threading.Semaphore.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101044", "threading.BoundedSemaphore.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101045", "threading.Barrier.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101046", "threading.Timer.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101047", "threading.local.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101048", "threading.BrokenBarrierError.__dict__.__contains__", ["__mro_entries__"], false]
    - ["th2101049", "threading.ExceptHookArgs.__dict__.__contains__", ["__mro_entries__"], false]
