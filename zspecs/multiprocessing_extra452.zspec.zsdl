spec: multiprocessing_extra452
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html#exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — multiprocessing exception classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "ProcessError, BufferTooShort, AuthenticationError, and TimeoutError are defined in multiprocessing.context"
    - "multiprocessing.ProcessExitCode is not a public attribute; intentionally omitted"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra452.exception_names:
  description: "multiprocessing exception class __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcn

  columns: [id, function, args, expected]
  rows:
    - [mpexcn001, multiprocessing.ProcessError.__name__.__eq__, ["ProcessError"], true]
    - [mpexcn002, multiprocessing.BufferTooShort.__name__.__eq__, ["BufferTooShort"], true]
    - [mpexcn003, multiprocessing.AuthenticationError.__name__.__eq__, ["AuthenticationError"], true]
    - [mpexcn004, multiprocessing.TimeoutError.__name__.__eq__, ["TimeoutError"], true]

table multiprocessing_extra452.exception_modules:
  description: "multiprocessing exception class __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcm

  columns: [id, function, args, expected]
  rows:
    - [mpexcm001, multiprocessing.ProcessError.__module__.__eq__, ["multiprocessing.context"], true]
    - [mpexcm002, multiprocessing.BufferTooShort.__module__.__eq__, ["multiprocessing.context"], true]
    - [mpexcm003, multiprocessing.AuthenticationError.__module__.__eq__, ["multiprocessing.context"], true]
    - [mpexcm004, multiprocessing.TimeoutError.__module__.__eq__, ["multiprocessing.context"], true]

table multiprocessing_extra452.exception_bases:
  description: "multiprocessing exception class __bases__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcb

  columns: [id, function, args, expected]
  rows:
    - [mpexcb001, "multiprocessing.ProcessError.__bases__[0].__name__.__eq__", ["Exception"], true]
