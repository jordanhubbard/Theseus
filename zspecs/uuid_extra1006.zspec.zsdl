spec: uuid_extra1006
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ == 'str' for uuid functions, classes, and module attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1006.uuid_function_docs:
  description: "uuid generator function __doc__ class name checks"
  kind: python_call_eq
  category: uuid_function_docs
  id_prefix: uu1006fd
  columns: [id, function, args, expected]
  rows:
    - [uu1006fd001, uuid.uuid1.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu1006fd002, uuid.uuid3.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu1006fd003, uuid.uuid4.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu1006fd004, uuid.uuid5.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu1006fd005, uuid.getnode.__doc__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra1006.uuid_class_docs:
  description: "uuid.UUID and uuid.SafeUUID class __doc__ class name checks"
  kind: python_call_eq
  category: uuid_class_docs
  id_prefix: uu1006cd
  columns: [id, function, args, expected]
  rows:
    - [uu1006cd001, uuid.UUID.__doc__.__class__.__name__.__eq__,               ["str"], true]
    - [uu1006cd002, uuid.UUID.__init__.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [uu1006cd003, uuid.UUID.__str__.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [uu1006cd004, uuid.UUID.__repr__.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [uu1006cd005, uuid.SafeUUID.__doc__.__class__.__name__.__eq__,           ["str"], true]

table uuid_extra1006.module_attributes:
  description: "uuid module-level attribute class name checks"
  kind: python_call_eq
  category: module_attributes
  id_prefix: uu1006ma
  columns: [id, function, args, expected]
  rows:
    - [uu1006ma001, uuid.__all__.__class__.__name__.__eq__,    ["list"], true]
    - [uu1006ma002, uuid.__doc__.__class__.__name__.__eq__,    ["str"],  true]
    - [uu1006ma003, uuid.__name__.__class__.__name__.__eq__,   ["str"],  true]
    - [uu1006ma004, uuid.__version__.__class__.__name__.__eq__, ["str"], true]
    - [uu1006ma005, uuid.NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
