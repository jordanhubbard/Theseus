table inspect_extra1996.parameter_kind_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — enum member identity"
  kind: python_call_eq
  category: string_identity
  id_prefix: in1996
  columns: [id, function, args, expected]
  rows:
    - ["in1996016", "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__", ["_ParameterKind"], true]

table inspect_extra1996.parameter_all_numeric_attrs:
