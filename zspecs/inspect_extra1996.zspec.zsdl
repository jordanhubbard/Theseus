spec: inspect_extra1996
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are introspection types — none are numeric types."
    - "None of the inspect classes define __index__, __complex__, __float__, __round__, or __abs__ in their own dict."
    - "inspect.Parameter.POSITIONAL_ONLY is a member of the _ParameterKind IntEnum (which inherits from int), but inspect.Parameter itself is a plain Python class with no numeric conversion protocols."
    - "_ParameterKind is an IntEnum: it inherits __index__ and __float__ from int via MRO, but does not define them in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra1996.index_protocol:
  description: "inspect types __index__ dict-presence checks — none define integer conversion protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1996
  columns: [id, function, args, expected]
  rows:
    - ["in1996001", "inspect.Parameter.__dict__.__contains__",      ["__index__"], false]
    - ["in1996002", "inspect.Signature.__dict__.__contains__",      ["__index__"], false]
    - ["in1996003", "inspect.BoundArguments.__dict__.__contains__", ["__index__"], false]

