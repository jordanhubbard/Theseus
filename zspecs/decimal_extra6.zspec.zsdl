spec: decimal_extra6
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras."
    - "decimal_extra3 covers: Decimal/Context/DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow __bases__[0].__name__; getcontext/setcontext/localcontext __name__/__module__; Decimal.__module__; MAX_PREC/MAX_EMAX class names."
    - "decimal_extra4 covers: InvalidOperation/DivisionByZero/Overflow/Underflow __name__; ROUND_HALF_UP/ROUND_DOWN values; MAX_PREC gt 0."
    - "decimal_extra5 covers: Decimal/Context/DecimalException/Overflow/Underflow/InvalidOperation/DivisionByZero/Inexact/Rounded __qualname__; getcontext/setcontext/localcontext __qualname__; Decimal.__module__."
    - "This spec adds: Context.__module__, InvalidOperation.__module__, DecimalException.__module__, ExtendedContext.__class__.__name__, and rounding mode constants not yet covered (ROUND_HALF_EVEN, ROUND_UP, ROUND_05UP)."
    - "decimal.Context.__module__ == 'decimal' — Context is defined in the decimal module."
    - "decimal.InvalidOperation.__module__ == 'decimal' — InvalidOperation is in the decimal module."
    - "decimal.DecimalException.__module__ == 'decimal' — DecimalException is in the decimal module."
    - "decimal.ExtendedContext.__class__.__name__ == 'Context' — ExtendedContext is a Context instance."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — banker's rounding constant."
    - "decimal.ROUND_UP == 'ROUND_UP' — round away from zero."
    - "decimal.ROUND_05UP == 'ROUND_05UP' — round zero or five away from zero."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — Context, InvalidOperation, DecimalException
# decimal_extra3 covers Decimal.__module__ and getcontext.__module__.
# decimal_extra5 covers Decimal.__module__ again.
# New here: Context.__module__, InvalidOperation.__module__, DecimalException.__module__.
# ---------------------------------------------------------------------------

invariant decimal_extra6.Context.module:
  description: "decimal.Context.__module__ == 'decimal' — Context class lives in the decimal module"
  category: module
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra6.InvalidOperation.module:
  description: "decimal.InvalidOperation.__module__ == 'decimal' — InvalidOperation lives in the decimal module"
  category: module
  kind: python_call_eq
  function: InvalidOperation.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra6.DecimalException.module:
  description: "decimal.DecimalException.__module__ == 'decimal' — DecimalException lives in the decimal module"
  category: module
  kind: python_call_eq
  function: DecimalException.__module__.__eq__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# ExtendedContext class identity
# decimal_extra3 covers DefaultContext and BasicContext class names via table.
# New here: ExtendedContext.__class__.__name__.
# ---------------------------------------------------------------------------

invariant decimal_extra6.ExtendedContext.class_name:
  description: "decimal.ExtendedContext.__class__.__name__ == 'Context' — ExtendedContext is a Context instance"
  category: context_instances
  kind: python_call_eq
  function: ExtendedContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

# ---------------------------------------------------------------------------
# Rounding mode constants — not covered in prior specs
# decimal_extra3 covers ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR.
# decimal_extra4 covers ROUND_HALF_UP and ROUND_DOWN again.
# New here: ROUND_HALF_EVEN, ROUND_UP, ROUND_05UP.
# ---------------------------------------------------------------------------

table decimal_extra6.rounding_modes:
  kind: python_call_eq
  category: rounding_constants
  id_prefix: round

  columns: [id, function, args, expected]
  rows:
    - [half_even, ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]
    - [up,        ROUND_UP.__eq__,        ["ROUND_UP"],        true]
    - [zero_five, ROUND_05UP.__eq__,      ["ROUND_05UP"],      true]

# ---------------------------------------------------------------------------
# Module membership table for exception classes not yet checked for __module__
# ---------------------------------------------------------------------------

table decimal_extra6.exception_modules:
  kind: python_call_eq
  category: module
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [Overflow,         Overflow.__module__.__eq__,         ["decimal"], true]
    - [Underflow,        Underflow.__module__.__eq__,        ["decimal"], true]
    - [DivisionByZero,   DivisionByZero.__module__.__eq__,   ["decimal"], true]
    - [Inexact,          Inexact.__module__.__eq__,          ["decimal"], true]
    - [Rounded,          Rounded.__module__.__eq__,          ["decimal"], true]
