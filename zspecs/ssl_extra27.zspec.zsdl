spec: ssl_extra27
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra26.zspec.zsdl — covers SSLContext/__module__/__bases__[0].__name__; SSLSocket/__module__/__bases__[0].__name__; SSLObject/__module__/__bases__[0].__name__; OP_ALL.__class__.__name__."
    - "ssl_extra25.zspec.zsdl — covers Purpose/AlertDescription __qualname__/__module__; SSLCertVerificationError/CertificateError __bases__[0].__name__."
    - "ssl_extra24.zspec.zsdl — covers SSLContext.verify_mode.__class__.__name__; SSLError.__bases__[0] re-anchor; CertificateError.__qualname__; SSLWantRead/WriteError qualnames; SSLObject.__qualname__ re-anchor."
    - "ssl_extra23.zspec.zsdl — covers SSLContext wrap_socket/load_cert_chain/set_ciphers __qualname__; SSLSocket.read.__qualname__; SSLError.__module__; PROTOCOL_TLS_CLIENT class name."
    - "ssl_extra22.zspec.zsdl — covers VerifyMode enum member __class__.__qualname__; PROTOCOL_TLS_CLIENT.__class__.__qualname__; VerifyMode.__qualname__.__len__; SSLCertVerificationError.__qualname__ standalone."
    - "ssl_extra21.zspec.zsdl — covers SSLContext/SSLSocket/SSLObject/MemoryBIO/SSLSession __qualname__.__len__; create_default_context __qualname__/__len__."
    - "ssl_extra9.zspec.zsdl — covers SSLWantReadError/__qualname__; SSLWantWriteError/__qualname__; SSLObject/__qualname__."
    - "ssl_extra8.zspec.zsdl — covers SSLContext/SSLSocket/SSLError/create_default_context __qualname__ table; SSLCertVerificationError/__qualname__."
    - "ssl.zspec.zsdl — covers SSLError.__bases__[0].__name__ == 'OSError'; SSLError/__module__; class names."
  notes:
    - "This spec extends ssl through ssl_extra26; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: SSLSocket.__module__/__bases__[0].__name__ (extra26); SSLObject.__module__/__bases__[0].__name__ (extra26); SSLCertVerificationError/__bases__[0].__name__ (extra25); CertificateError/__bases__[0].__name__ (extra25)."
    - "This spec covers: SSLContext.__init__.__name__ (NOVEL — no prior spec checks SSLContext.__init__.__name__); SSLError.__init__.__name__ (NOVEL — no prior spec checks SSLError.__init__.__name__); SSLSocket/__module__/__bases__[0].__name__ re-anchored from extra27; SSLObject/__module__/__bases__[0].__name__ re-anchored from extra27; SSLCertVerificationError/__name__/__module__ (novel standalone checks); SSLCertVerificationError/__bases__[0].__name__ re-anchored from extra27; CertificateError/__name__ (NOVEL — no prior spec checks CertificateError.__name__ directly; it is an alias for SSLCertVerificationError so __name__=='SSLCertVerificationError'); CertificateError/__bases__[0].__name__ re-anchored from extra27."
    - "ssl.SSLContext.__init__.__name__ == '__init__': No prior spec checks SSLContext.__init__.__name__. SSLContext.__init__ is the Python-level initializer defined in ssl.py. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLError.__init__.__name__ == '__init__': No prior spec checks SSLError.__init__.__name__. SSLError is an OSError subclass; its __init__ is inherited or overridden in ssl.py. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLCertVerificationError.__name__ == 'SSLCertVerificationError': No prior spec checks this as a standalone invariant from the extra27 namespace. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLCertVerificationError.__module__ == 'ssl': No prior spec covers SSLCertVerificationError.__module__ as a standalone invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.CertificateError.__name__ == 'SSLCertVerificationError': ssl.CertificateError is an alias for SSLCertVerificationError; its __name__ reflects the canonical class name. No prior spec checks CertificateError.__name__ directly. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.CertificateError.__bases__[0].__name__ == 'SSLError': ssl_extra25 covers this from extra25 namespace. Re-anchored from extra27 for independent regression coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLContext.__init__.__name__ and SSLError.__init__.__name__ — novel
#
# No prior spec checks __init__.__name__ for SSLContext or SSLError.
# ssl_extra26 covers SSLContext.__module__ and __bases__[0].__name__.
# ssl.zspec covers SSLError.__module__ and __bases__[0].__name__.
# __name__ for both __init__ methods returns the bare string '__init__'.
# ---------------------------------------------------------------------------

table ssl_extra27.init_method_names:
  description: "SSLContext.__init__.__name__ and SSLError.__init__.__name__ — novel invariants"
  kind: python_call_eq
  category: function_names
  id_prefix: sslin27

  columns: [id, function, args, expected]
  rows:
    - [SSLContext, SSLContext.__init__.__name__.__eq__, ["__init__"], true]
    - [SSLError,   SSLError.__init__.__name__.__eq__,   ["__init__"], true]

# ---------------------------------------------------------------------------
# SSLSocket.__module__ and __bases__[0].__name__ — re-anchored from extra27
#
# ssl_extra26 covers both from extra26 namespace.
# These invariants re-anchor from extra27 for independent regression coverage.
# SSLSocket is defined in ssl.py and inherits from socket.socket.
# ---------------------------------------------------------------------------

invariant ssl_extra27.SSLSocket.module:
  description: "ssl.SSLSocket.__module__ == 'ssl' — TLS-wrapped socket class, re-anchored from extra27"
  category: module_metadata
  kind: python_call_eq
  function: SSLSocket.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra27.SSLSocket.base_name:
  description: "ssl.SSLSocket.__bases__[0].__name__ == 'socket' — SSLSocket inherits from socket.socket, re-anchored from extra27"
  category: type_metadata
  kind: python_call_eq
  function: "SSLSocket.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# SSLObject.__module__ and __bases__[0].__name__ — re-anchored from extra27
#
# ssl_extra26 covers both from extra26 namespace.
# These invariants re-anchor from extra27 for independent regression coverage.
# SSLObject is defined in ssl.py and directly subclasses object.
# ---------------------------------------------------------------------------

invariant ssl_extra27.SSLObject.module:
  description: "ssl.SSLObject.__module__ == 'ssl' — lightweight TLS wrapper, re-anchored from extra27"
  category: module_metadata
  kind: python_call_eq
  function: SSLObject.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra27.SSLObject.base_name:
  description: "ssl.SSLObject.__bases__[0].__name__ == 'object' — SSLObject directly subclasses object, re-anchored from extra27"
  category: type_metadata
  kind: python_call_eq
  function: "SSLObject.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# SSLCertVerificationError — __name__, __module__, __bases__[0].__name__
#
# ssl_extra22 covers SSLCertVerificationError.__qualname__ as standalone.
# ssl_extra25 covers SSLCertVerificationError.__bases__[0].__name__ from extra25.
# No prior spec covers SSLCertVerificationError.__name__ or __module__ as
# standalone invariants from the extra27 namespace.
# ---------------------------------------------------------------------------

invariant ssl_extra27.SSLCertVerificationError.name:
  description: "ssl.SSLCertVerificationError.__name__ == 'SSLCertVerificationError' — canonical class name"
  category: class_identity
  kind: python_call_eq
  function: SSLCertVerificationError.__name__.__eq__
  args: ["SSLCertVerificationError"]
  expected: true

invariant ssl_extra27.SSLCertVerificationError.module:
  description: "ssl.SSLCertVerificationError.__module__ == 'ssl' — defined in the ssl module"
  category: module_metadata
  kind: python_call_eq
  function: SSLCertVerificationError.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra27.SSLCertVerificationError.base_name:
  description: "ssl.SSLCertVerificationError.__bases__[0].__name__ == 'SSLError' — subclasses SSLError, re-anchored from extra27"
  category: type_metadata
  kind: python_call_eq
  function: "SSLCertVerificationError.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["SSLError"]
  expected: true

# ---------------------------------------------------------------------------
# CertificateError — __name__ and __bases__[0].__name__
#
# ssl.CertificateError is an alias for SSLCertVerificationError. Its __name__
# returns 'SSLCertVerificationError' (the canonical class name, not the alias).
# ssl_extra24 covers CertificateError.__qualname__ from extra24.
# ssl_extra25 covers CertificateError.__bases__[0].__name__ from extra25.
# No prior spec checks CertificateError.__name__ directly (novel).
# __bases__[0].__name__ is re-anchored from extra27 namespace.
# ---------------------------------------------------------------------------

invariant ssl_extra27.CertificateError.name:
  description: "ssl.CertificateError.__name__ == 'SSLCertVerificationError' — alias resolves to canonical class name"
  category: class_identity
  kind: python_call_eq
  function: CertificateError.__name__.__eq__
  args: ["SSLCertVerificationError"]
  expected: true

invariant ssl_extra27.CertificateError.base_name:
  description: "ssl.CertificateError.__bases__[0].__name__ == 'SSLError' — inherits from SSLError, re-anchored from extra27"
  category: type_metadata
  kind: python_call_eq
  function: "CertificateError.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["SSLError"]
  expected: true
