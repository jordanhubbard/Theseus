spec: statistics_extra14
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras through statistics_extra13.zspec.zsdl."
    - "statistics_extra2 covers __name__ attributes for mean, median, mode, stdev, variance, pstdev, pvariance, NormalDist, StatisticsError."
    - "statistics_extra10 covers mean([10,20,30])==20, mean([-1,-2,-3])==-2, median([2,4,6,8])==5.0, median([3,7])==5.0."
    - "statistics_extra12 covers mean([1,2,3,4,5])==3, variance([2,4,6])==4, stdev([2,4,6])==2.0, geometric_mean([2,3,6]), harmonic_mean([2,8]), pvariance/pstdev([1,3,5])."
    - "No prior spec covers mean([0, 100]) == 50 (zero-inclusive range)."
    - "No prior spec covers mean([5, 5, 5]) == 5 (identical elements yield same value)."
    - "No prior spec covers median([1, 2, 3]) == 2 (single odd-count middle element)."
    - "No prior spec covers median([10, 20]) == 15.0 (two-element even-count average)."
    - "No prior spec covers fmean([1, 9]) == 5.0 (mean of symmetric pair, always float)."
    - "No prior spec covers fmean([0, 0, 0]) == 0.0 (all-zero list, fmean returns float)."
    - "No prior spec covers harmonic_mean([2, 2]) == 2.0 (equal elements yield same value)."
    - "No prior spec covers geometric_mean([1, 1]) == 1.0 (unit elements yield 1.0)."
    - "No prior spec covers pstdev([0, 0, 0]) == 0.0 (no spread in constant population)."
    - "No prior spec covers pvariance([4, 4, 4]) == 0.0 (no spread in constant population)."
    - "No prior spec covers variance([1, 3]) == 2.0 (sample variance of two-element list)."
    - "mean([0, 100]) == 50 — arithmetic mean of 0 and 100 is 50."
    - "mean([5, 5, 5]) == 5 — mean of identical elements equals that element."
    - "median([1, 2, 3]) == 2 — middle element of odd-length sorted list."
    - "median([10, 20]) == 15.0 — average of two elements for even-length list."
    - "fmean([1, 9]) == 5.0 — fmean always returns a float."
    - "fmean([0, 0, 0]) == 0.0 — all-zero list, float result is 0.0."
    - "harmonic_mean([2, 2]) == 2.0 — equal elements give harmonic mean equal to the value."
    - "geometric_mean([1, 1]) == 1.0 — geometric mean of all-ones list is 1.0."
    - "pstdev([0, 0, 0]) == 0.0 — constant population has zero standard deviation."
    - "pvariance([4, 4, 4]) == 0.0 — constant population has zero variance."
    - "variance([1, 3]) == 2.0 — sample variance of [1, 3] is ((1-2)^2 + (3-2)^2)/(2-1) = 2.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mean — arithmetic mean with new input vectors
#
# statistics_extra10 covers mean([10,20,30])==20 and mean([-1,-2,-3])==-2.
# statistics_extra12 covers mean([1,2,3,4,5])==3.
# New: mean([0,100])==50 and mean([5,5,5])==5.
# ---------------------------------------------------------------------------

invariant statistics_extra14.mean.zero_and_hundred:
  description: "statistics.mean([0, 100]) == 50 — arithmetic mean of 0 and 100"
  category: mean
  kind: python_call_eq
  function: mean
  args: [[0, 100]]
  expected: 50

invariant statistics_extra14.mean.identical_elements:
  description: "statistics.mean([5, 5, 5]) == 5 — mean of identical elements equals that element"
  category: mean
  kind: python_call_eq
  function: mean
  args: [[5, 5, 5]]
  expected: 5

# ---------------------------------------------------------------------------
# median — middle value of a dataset
#
# statistics_extra10 covers median([2,4,6,8])==5.0 and median([3,7])==5.0.
# New: median([1,2,3])==2 (odd count, exact middle element) and
# median([10,20])==15.0 (even count, average of two adjacent elements).
# ---------------------------------------------------------------------------

invariant statistics_extra14.median.odd_count:
  description: "statistics.median([1, 2, 3]) == 2 — middle element of odd-length sorted list"
  category: median
  kind: python_call_eq
  function: median
  args: [[1, 2, 3]]
  expected: 2

invariant statistics_extra14.median.two_elements:
  description: "statistics.median([10, 20]) == 15.0 — average of two elements for even-length list"
  category: median
  kind: python_call_eq
  function: median
  args: [[10, 20]]
  expected: 15.0

# ---------------------------------------------------------------------------
# fmean — fast floating-point mean (Python 3.8+)
#
# statistics_extra3 covers fmean([2.0,4.0])==3.0.
# statistics_extra7 covers fmean([5])==5.0 and fmean([]) raises StatisticsError.
# statistics_extra12 covers fmean([3,6,9])==6.0.
# New: fmean([1,9])==5.0 and fmean([0,0,0])==0.0.
# ---------------------------------------------------------------------------

invariant statistics_extra14.fmean.symmetric_pair:
  description: "statistics.fmean([1, 9]) == 5.0 — fmean always returns a float"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[1, 9]]
  expected: 5.0

invariant statistics_extra14.fmean.all_zeros:
  description: "statistics.fmean([0, 0, 0]) == 0.0 — all-zero list, fmean returns float 0.0"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[0, 0, 0]]
  expected: 0.0

# ---------------------------------------------------------------------------
# harmonic_mean — harmonic mean of a dataset
#
# Prior specs cover harmonic_mean([1,2,4]), harmonic_mean([2,8]), harmonic_mean([2,3,6]).
# New: harmonic_mean([2,2])==2.0 — equal elements yield harmonic mean equal to the value.
# ---------------------------------------------------------------------------

invariant statistics_extra14.harmonic_mean.equal_elements:
  description: "statistics.harmonic_mean([2, 2]) == 2.0 — equal elements yield value itself"
  category: harmonic_mean
  kind: python_call_eq
  function: harmonic_mean
  args: [[2, 2]]
  expected: 2.0

# ---------------------------------------------------------------------------
# geometric_mean — geometric mean of a dataset (Python 3.8+)
#
# Prior specs cover geometric_mean([4.0,9.0]), geometric_mean([1,2,4,8]),
# geometric_mean([1,4,16]), geometric_mean([2,8]).
# New: geometric_mean([1,1])==1.0 — all-ones list, product is 1, nth root is 1.
# ---------------------------------------------------------------------------

invariant statistics_extra14.geometric_mean.unit_elements:
  description: "statistics.geometric_mean([1, 1]) == 1.0 — geometric mean of all-ones list is 1.0"
  category: geometric_mean
  kind: python_call_eq
  function: geometric_mean
  args: [[1, 1]]
  expected: 1.0

# ---------------------------------------------------------------------------
# pstdev — population standard deviation
#
# statistics_extra7 covers pstdev([1,2,3])==sqrt(2/3).
# statistics_extra12 covers pstdev([1,3,5]).
# New: pstdev([0,0,0])==0.0 — constant population has zero spread.
# ---------------------------------------------------------------------------

invariant statistics_extra14.pstdev.constant_population:
  description: "statistics.pstdev([0, 0, 0]) == 0.0 — constant population has zero standard deviation"
  category: pstdev
  kind: python_call_eq
  function: pstdev
  args: [[0, 0, 0]]
  expected: 0.0

# ---------------------------------------------------------------------------
# pvariance — population variance
#
# statistics_extra7 covers pvariance([1,2,3]).
# statistics_extra12 covers pvariance([1,3,5]).
# New: pvariance([4,4,4])==0.0 — constant population has zero variance.
# ---------------------------------------------------------------------------

invariant statistics_extra14.pvariance.constant_population:
  description: "statistics.pvariance([4, 4, 4]) == 0.0 — constant population has zero variance"
  category: pvariance
  kind: python_call_eq
  function: pvariance
  args: [[4, 4, 4]]
  expected: 0.0

# ---------------------------------------------------------------------------
# variance — sample variance
#
# statistics_extra10 covers variance([1,5]) and variance([3,3]).
# statistics_extra12 covers variance([2,4,6])==4.
# New: variance([1,3])==2.0 — ((1-2)^2 + (3-2)^2)/(2-1) = (1+1)/1 = 2.0.
# ---------------------------------------------------------------------------

invariant statistics_extra14.variance.two_element_list:
  description: "statistics.variance([1, 3]) == 2.0 — sample variance of [1, 3]"
  category: variance
  kind: python_call_eq
  function: variance
  args: [[1, 3]]
  expected: 2.0
