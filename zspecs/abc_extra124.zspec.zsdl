spec: abc_extra124
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 255 theme — abc.ABC and abc.ABCMeta __dict__ key counts and contents. NEW in extra124: abc.ABC.__dict__.__class__.__name__=='mappingproxy'; abc.ABC.__dict__.__contains__('__abstractmethods__')==True; abc.ABC.__dict__.__contains__('__doc__')==True; abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy'; abc.ABCMeta.__dict__.__contains__('register')==True; abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True; abc.ABCMeta.__dict__.__contains__('__subclasscheck__')==True; abc.ABCMeta.__dict__.__contains__('__new__')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ attributes are always mappingproxy objects (read-only views of the underlying dict), not plain dicts. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__ contains '__abstractmethods__' and '__doc__'. ABC.__dict__ keys include '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'. The '__abstractmethods__' entry is a frozenset (empty for ABC itself). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__dict__ contains 'register', '__instancecheck__', '__subclasscheck__', '__new__'. These are the key methods that ABCMeta defines to implement the abstract base class protocol. '__instancecheck__' and '__subclasscheck__' enable isinstance()/issubclass() checks against ABCs. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__.__contains__ is a 'method-wrapper' (C-level). The __contains__ method on mappingproxy objects is a C-level method-wrapper, but it is callable with a string argument and returns True/False. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__dict__ class identity and key membership — extra124
#
# Wave 255 theme: abc.ABC and abc.ABCMeta __dict__ key counts and contents.
#
# abc.ABC.__dict__.__class__.__name__               == 'mappingproxy'
# abc.ABC.__dict__.__contains__('__abstractmethods__') == True
# abc.ABC.__dict__.__contains__('__doc__')             == True
# ---------------------------------------------------------------------------

table abc_extra124.abc_ABC_dict_identity:
  description: "abc.ABC.__dict__ class identity and key membership checks in abcdict124 namespace — wave 255 theme: abc.ABC.__dict__ is a mappingproxy object (the standard read-only view of a class's namespace dict in CPython); abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True (every class __dict__ is a mappingproxy, not a plain dict); abc.ABC.__dict__.__contains__('__abstractmethods__')==True (__abstractmethods__ is present in ABC's own __dict__ as an empty frozenset, enabling isinstance/issubclass checks); abc.ABC.__dict__.__contains__('__doc__')==True (__doc__ is defined in ABC's class body in Lib/abc.py, set to None by default for the base ABC class); the full ABC.__dict__ key set is ['__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'] (7 keys total); ABC is a convenience class defined in Lib/abc.py with ABCMeta as its metaclass; abc.ABC.__dict__.__class__.__name__ is the string 'mappingproxy' (len=12: 'mapping'=7 + 'proxy'=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_identity
  id_prefix: abcdict124

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_cls,       abc.ABC.__dict__.__class__.__name__.__eq__,              ["mappingproxy"],       true, "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [abc_dict_cls_len,   abc.ABC.__dict__.__class__.__name__.__len__,             [],                    12,   "abc.ABC.__dict__.__class__.__name__.__len__() == 12 (len('mappingproxy')==12); verified with Python 3.14.3"]
    - [abc_has_absmeth,    abc.ABC.__dict__.__contains__,                            ["__abstractmethods__"], true, "abc.ABC.__dict__.__contains__('__abstractmethods__') == True; verified with Python 3.14.3"]
    - [abc_has_doc,        abc.ABC.__dict__.__contains__,                            ["__doc__"],            true, "abc.ABC.__dict__.__contains__('__doc__') == True; verified with Python 3.14.3"]
    - [abc_has_module,     abc.ABC.__dict__.__contains__,                            ["__module__"],         true, "abc.ABC.__dict__.__contains__('__module__') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__dict__ class identity and key membership — extra124
#
# Wave 255 theme: abc.ABCMeta.__dict__ key membership checks.
#
# abc.ABCMeta.__dict__.__class__.__name__             == 'mappingproxy'
# abc.ABCMeta.__dict__.__contains__('register')          == True
# abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True
# abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True
# abc.ABCMeta.__dict__.__contains__('__new__')           == True
# ---------------------------------------------------------------------------

table abc_extra124.abc_ABCMeta_dict_identity:
  description: "abc.ABCMeta.__dict__ class identity and key membership checks in abcdict124 namespace — wave 255 theme: abc.ABCMeta.__dict__ is also a mappingproxy object; ABCMeta is the metaclass for abstract base classes defined in Lib/abc.py; ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy')==True (all class __dict__ attributes are mappingproxy); ABCMeta.__dict__.__contains__('register')==True (register() is ABCMeta's public API to register a class as a virtual subclass of an ABC); ABCMeta.__dict__.__contains__('__instancecheck__')==True (__instancecheck__ enables isinstance(obj, SomeABC) to check registered virtual subclasses); ABCMeta.__dict__.__contains__('__subclasscheck__')==True (__subclasscheck__ enables issubclass(SomeClass, SomeABC) to check registered virtual subclasses); ABCMeta.__dict__.__contains__('__new__')==True (ABCMeta defines its own __new__ in Python, unlike __init__ which is inherited from type as a wrapper_descriptor); ABCMeta.__module__ is 'abc'; ABCMeta.__name__ is 'ABCMeta' (len=7); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_identity
  id_prefix: abcdict124a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_cls,      abc.ABCMeta.__dict__.__class__.__name__.__eq__,      ["mappingproxy"],       true, "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [abcmeta_has_register,  abc.ABCMeta.__dict__.__contains__,                    ["register"],           true, "abc.ABCMeta.__dict__.__contains__('register') == True; verified with Python 3.14.3"]
    - [abcmeta_has_instchk,   abc.ABCMeta.__dict__.__contains__,                    ["__instancecheck__"],  true, "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True; verified with Python 3.14.3"]
    - [abcmeta_has_subclschk, abc.ABCMeta.__dict__.__contains__,                    ["__subclasscheck__"],  true, "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True; verified with Python 3.14.3"]
    - [abcmeta_has_new,       abc.ABCMeta.__dict__.__contains__,                    ["__new__"],            true, "abc.ABCMeta.__dict__.__contains__('__new__') == True; verified with Python 3.14.3"]
    - [abcmeta_has_doc,       abc.ABCMeta.__dict__.__contains__,                    ["__doc__"],            true, "abc.ABCMeta.__dict__.__contains__('__doc__') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC vs ABCMeta __dict__ class name comparison — extra124
#
# Wave 255 theme: both ABC.__dict__ and ABCMeta.__dict__ are mappingproxy.
#
# abc.ABC.__dict__.__class__.__name__    == 'mappingproxy'
# abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table abc_extra124.abc_dict_class_comparison:
  description: "abc.ABC.__dict__ and abc.ABCMeta.__dict__ __class__.__name__ comparison checks in abcdict124 namespace — wave 255 theme: both ABC and ABCMeta have __dict__ attributes that are mappingproxy objects; in CPython all class __dict__ attributes are wrapped in mappingproxy to prevent direct mutation; abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True; abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy')==True; the string 'mappingproxy' has __len__()==12 ('mapping'=7 + 'proxy'=5); both mappingproxy objects support __contains__ for key membership testing; abc.ABC.__dict__.__class__.__name__ and abc.ABCMeta.__dict__.__class__.__name__ are equal to each other (both 'mappingproxy'); the class name 'mappingproxy' has the same length as abc.ABCMeta.__qualname__.__len__()==7 plus 5 == 12; both __contains__ calls return True for keys present in each class's namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_identity
  id_prefix: abcdict124b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_mp_eq,     abc.ABC.__dict__.__class__.__name__.__eq__,       ["mappingproxy"], true, "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [meta_mp_eq,    abc.ABCMeta.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true, "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [mp_len12,      abc.ABC.__dict__.__class__.__name__.__len__,      [],               12,   "abc.ABC.__dict__.__class__.__name__.__len__() == 12 (len('mappingproxy')==12); verified with Python 3.14.3"]
    - [meta_mp_len12, abc.ABCMeta.__dict__.__class__.__name__.__len__,  [],               12,   "abc.ABCMeta.__dict__.__class__.__name__.__len__() == 12 (len('mappingproxy')==12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra124
# ---------------------------------------------------------------------------

invariant abc_extra124.ABC_dict_class_is_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — ABC.__dict__ is a mappingproxy object, not a plain dict; in CPython all class __dict__ attributes are read-only mappingproxy wrappers that prevent direct mutation (e.g., ABC.__dict__['x'] = 1 would raise TypeError); mappingproxy has __class__.__name__=='mappingproxy' (len=12); ABC.__dict__ contains 7 keys in Python 3.14.3: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'; the '__abstractmethods__' entry is an empty frozenset() for the base ABC class; abc.ABC.__dict__.__class__.__name__ is the string 'mappingproxy'; abc.ABCMeta.__dict__.__class__.__name__ is also 'mappingproxy' (same for all classes); NEW in extra124: first standalone ABC __dict__ class name invariant in abcdict124 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra124.ABC_dict_contains_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') returns True — '__abstractmethods__' is present in abc.ABC.__dict__; for the base ABC class, this is an empty frozenset() (ABC itself has no abstract methods); when a subclass of ABC defines abstract methods, its __abstractmethods__ frozenset is non-empty, and Python prevents instantiation; abc.ABC.__dict__.__contains__ is a method-wrapper (C-level method on mappingproxy); the __abstractmethods__ key in ABC.__dict__ is placed there by ABCMeta.__new__ (defined in Lib/abc.py); abc.ABC.__dict__.__class__.__name__ is 'mappingproxy'; abc.ABC.__dict__.__contains__('__doc__') is also True; NEW in extra124: first standalone ABC __dict__ __abstractmethods__ membership invariant in abcdict124 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra124.ABCMeta_dict_contains_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — 'register' is present in abc.ABCMeta.__dict__; ABCMeta.register(subclass) adds subclass as a virtual subclass of the ABC, enabling isinstance(obj, TheABC) to return True for instances of subclass even if subclass does not actually inherit from TheABC; register is a pure-Python function defined in Lib/abc.py (abc.ABCMeta.register.__class__.__name__ is 'function'); abc.ABCMeta.__dict__.__class__.__name__ is 'mappingproxy'; ABCMeta.__dict__ also contains '__instancecheck__', '__subclasscheck__', '__new__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear'; all of these are defined directly in ABCMeta in abc.py; NEW in extra124: first standalone ABCMeta __dict__ register membership invariant in abcdict124 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra124.ABCMeta_dict_contains_instancecheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') returns True — '__instancecheck__' is present in abc.ABCMeta.__dict__; ABCMeta.__instancecheck__(cls, instance) is called by Python's isinstance() built-in when the second argument has a metaclass that defines __instancecheck__; ABCMeta's implementation checks both standard class hierarchy and virtual subclass registrations made via register(); '__instancecheck__' is defined in Python in Lib/abc.py (or its C accelerator in Modules/_abc.c); abc.ABCMeta.__dict__.__contains__('__subclasscheck__') is also True (__subclasscheck__ works analogously for issubclass()); abc.ABCMeta.__dict__.__class__.__name__ is 'mappingproxy'; ABCMeta.__module__ is 'abc'; NEW in extra124: first standalone ABCMeta __dict__ __instancecheck__ membership invariant in abcdict124 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra124.ABCMeta_dict_contains_new:
  description: "abc.ABCMeta.__dict__.__contains__('__new__') returns True — '__new__' is present in abc.ABCMeta.__dict__; ABCMeta defines its own __new__ classmethod in Python (Lib/abc.py) to set up the __abstractmethods__ frozenset during class creation; abc.ABCMeta.__new__.__class__.__name__ is 'function' (Python-defined, unlike ABCMeta.__init__ which is inherited from type as a 'wrapper_descriptor'); ABCMeta.__new__ takes (mcls, name, bases, namespace) as its 4 positional parameters (co_argcount==4); the presence of '__new__' in ABCMeta.__dict__ distinguishes ABCMeta from most metaclasses that simply inherit type.__new__; abc.ABCMeta.__dict__.__class__.__name__ is 'mappingproxy'; abc.ABCMeta.__dict__.__contains__('register') is also True; NEW in extra124: first standalone ABCMeta __dict__ __new__ membership invariant in abcdict124 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__new__"]
  expected: true
