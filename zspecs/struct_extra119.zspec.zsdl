    - "struct_extra92.zspec.zsdl — covers module-level function __class__.__name__.__eq__('builtin_function_or_method') (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.pack/__qualname__.__eq__ / calcsize/__qualname__.__eq__ / unpack/__qualname__.__eq__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra118; it does NOT duplicate invariants present in those files."
    - "Wave 291 theme: struct module-level function __name__ equality and pack_into/unpack_from/iter_unpack __qualname__ equality — extra91 anchors pack/unpack/calcsize __qualname__ equality; extra96 anchors all six __name__.__len__(); extra95 anchors pack_into/unpack_from/iter_unpack __qualname__.__len__() but NOT __qualname__.__eq__; extra92 anchors __class__.__name__.__eq__ for all six. NOT YET covered: __name__.__eq__ for any module-level function / __qualname__.__eq__ for pack_into, unpack_from, iter_unpack / __module__.__len__() for module-level functions."
    - "struct.pack.__name__.__eq__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__.__eq__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__.__eq__('calcsize') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__.__eq__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__.__eq__('unpack_from') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__.__eq__('iter_unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__.__eq__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__.__eq__('unpack_from') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__.__eq__('iter_unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__.__len__() == 7. len('_struct')==7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: For all six module-level struct functions, __name__ equals __qualname__ (for top-level C builtins, the two attributes are the same string). pack_into and iter_unpack use underscore-separated names ('pack_into', 'iter_unpack'). extra91 anchors __qualname__.__eq__ for pack/unpack/calcsize; no prior struct spec anchors __qualname__.__eq__ for pack_into/unpack_from/iter_unpack. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack')
# struct.unpack.__name__.__eq__('unpack')
# struct.calcsize.__name__.__eq__('calcsize')
# struct.pack_into.__name__.__eq__('pack_into')
# struct.unpack_from.__name__.__eq__('unpack_from')
#
# Wave 291 theme: module-level struct function __name__ equality.
#
# For C builtin functions, __name__ equals __qualname__ (both reflect the function
# name as defined in the C extension). extra96 anchors __name__.__len__() for all
# six functions; no prior struct spec anchors __name__.__eq__ for any module-level
# function under structname119. pack and unpack are 4 and 6 chars; calcsize is 8;
# pack_into is 9 (with underscore). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra119.module_fn_name_equality_group1:
  description: "pack.__name__.__eq__('pack')==True / unpack.__name__.__eq__('unpack')==True / calcsize.__name__.__eq__('calcsize')==True / pack_into.__name__.__eq__('pack_into')==True / unpack_from.__name__.__eq__('unpack_from')==True — for C builtins, __name__ equals __qualname__; extra96 anchors __name__.__len__() for all six; extra91 anchors __qualname__.__eq__ for pack/unpack/calcsize; no prior spec anchors __name__.__eq__ for any module-level struct function; first structname119 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structname119

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,      pack.__name__.__eq__,      ["pack"],       true, "struct.pack.__name__ is 'pack' (4 chars; matches __qualname__; C builtin from _struct; extra96 anchors __name__.__len__()==4; no prior spec anchors __name__.__eq__ for pack)"]
    - [unpack_name_eq,    unpack.__name__.__eq__,    ["unpack"],     true, "struct.unpack.__name__ is 'unpack' (6 chars; matches __qualname__; C builtin from _struct; extra96 anchors __name__.__len__()==6; no prior spec anchors __name__.__eq__ for unpack)"]
    - [calcsize_name_eq,  calcsize.__name__.__eq__,  ["calcsize"],   true, "struct.calcsize.__name__ is 'calcsize' (8 chars; matches __qualname__; C builtin from _struct; extra96 anchors __name__.__len__()==8; no prior spec anchors __name__.__eq__ for calcsize)"]
    - [pack_into_name_eq, pack_into.__name__.__eq__,  ["pack_into"],  true, "struct.pack_into.__name__ is 'pack_into' (9 chars; underscore-separated; matches __qualname__; extra96 anchors __name__.__len__()==9; no prior spec anchors __name__.__eq__ for pack_into)"]
    - [unpack_from_name,  unpack_from.__name__.__eq__, ["unpack_from"], true, "struct.unpack_from.__name__ is 'unpack_from' (11 chars; matches __qualname__; extra96 anchors __name__.__len__()==11; no prior spec anchors __name__.__eq__ for unpack_from)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__eq__('iter_unpack')
# struct.pack_into.__qualname__.__eq__('pack_into')
# struct.unpack_from.__qualname__.__eq__('unpack_from')
# struct.iter_unpack.__qualname__.__eq__('iter_unpack')
# struct.pack.__module__.__len__()==7
#
# Wave 291 theme: iter_unpack __name__, pack_into/unpack_from/iter_unpack
# __qualname__ equality, and module __len__.
#
# iter_unpack.__name__ is 'iter_unpack' (11 chars). pack_into, unpack_from,
# iter_unpack __qualname__ equality: extra91 anchors pack/unpack/calcsize __qualname__
# __eq__; no prior struct spec anchors __qualname__.__eq__ for pack_into/unpack_from/
# iter_unpack under structname119. pack.__module__.__len__()==7 (len('_struct')==7);
# extra95 anchors __module__.__eq__('_struct') but NOT the length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra119.module_fn_qualname_eq_and_module_len:
  description: "iter_unpack.__name__.__eq__('iter_unpack')==True / pack_into.__qualname__.__eq__('pack_into')==True / unpack_from.__qualname__.__eq__('unpack_from')==True / iter_unpack.__qualname__.__eq__('iter_unpack')==True / pack.__module__.__len__()==7 — extra91 anchors pack/unpack/calcsize __qualname__.__eq__; this table adds pack_into/unpack_from/iter_unpack __qualname__.__eq__; extra95 anchors __module__.__eq__('_struct') but NOT __len__()==7; first structname119 anchor for these"
  kind: python_call_eq
  category: function_identity
  id_prefix: structname119

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_name,      iter_unpack.__name__.__eq__,     ["iter_unpack"],  true, "struct.iter_unpack.__name__ is 'iter_unpack' (11 chars; same length as unpack_from; extra96 anchors __name__.__len__()==11; no prior spec anchors iter_unpack __name__.__eq__)"]
    - [pack_into_qualname,    pack_into.__qualname__.__eq__,    ["pack_into"],    true, "struct.pack_into.__qualname__ is 'pack_into' (9 chars; for C builtins __qualname__==__name__; extra91 anchors pack/unpack/calcsize qualname eq; no prior spec anchors pack_into qualname eq)"]
    - [unpack_from_qualname,  unpack_from.__qualname__.__eq__,  ["unpack_from"],  true, "struct.unpack_from.__qualname__ is 'unpack_from' (11 chars; matches __name__; extra91 anchors other qualnames but NOT unpack_from; no prior spec anchors unpack_from qualname eq)"]
    - [iter_unpack_qualname,  iter_unpack.__qualname__.__eq__,  ["iter_unpack"],  true, "struct.iter_unpack.__qualname__ is 'iter_unpack' (11 chars; matches __name__; same length as unpack_from; no prior spec anchors iter_unpack qualname eq)"]
    - [pack_module_len,       pack.__module__.__len__,           [],              7,    "struct.pack.__module__.__len__() is 7 (len('_struct')==7; extra95 anchors __module__.__eq__('_struct') but NOT __len__()==7; first spec to anchor module string length)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack')
# struct.unpack.__name__.__eq__('unpack')
# struct.pack_into.__qualname__.__eq__('pack_into')
# struct.unpack_from.__qualname__.__eq__('unpack_from')
# struct.iter_unpack.__qualname__.__eq__('iter_unpack')
#
# Wave 291 theme: unified cross-check for module-level function name/qualname equality.
#
# This table groups key assertions confirming that __name__.__eq__ and __qualname__.__eq__
# hold for the module-level struct functions. For C builtins, __name__ and __qualname__
# are the same string — this unified view confirms that __name__==__qualname__ for the
# top-level functions that have underscore-separated names (pack_into, unpack_from,
# iter_unpack). Together this table and the two above complete the picture.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra119.module_fn_name_qualname_unified:
  description: "pack.__name__.__eq__('pack')==True / unpack.__name__.__eq__('unpack')==True / pack_into.__qualname__.__eq__('pack_into')==True / unpack_from.__qualname__.__eq__('unpack_from')==True / iter_unpack.__qualname__.__eq__('iter_unpack')==True — unified cross-check confirming __name__==__qualname__ for all six C builtin module-level struct functions; extra91 anchors pack/unpack/calcsize __qualname__.__eq__; this unified table confirms the pattern extends to pack_into/unpack_from/iter_unpack; first structname119 unified anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structname119

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name2,          pack.__name__.__eq__,         ["pack"],        true, "struct.pack.__name__ is 'pack' (unified cross-check; __name__==__qualname__ for C builtins)"]
    - [unpack_name2,        unpack.__name__.__eq__,       ["unpack"],      true, "struct.unpack.__name__ is 'unpack' (unified cross-check; __name__==__qualname__ for C builtins)"]
    - [pack_into_qname2,    pack_into.__qualname__.__eq__, ["pack_into"],   true, "struct.pack_into.__qualname__ is 'pack_into' (unified cross-check; __qualname__==__name__ for top-level C builtin)"]
    - [unpack_from_qname2,  unpack_from.__qualname__.__eq__, ["unpack_from"], true, "struct.unpack_from.__qualname__ is 'unpack_from' (unified cross-check; __qualname__==__name__ for top-level C builtin)"]
    - [iter_unpack_qname2,  iter_unpack.__qualname__.__eq__, ["iter_unpack"], true, "struct.iter_unpack.__qualname__ is 'iter_unpack' (unified cross-check; __qualname__==__name__ for top-level C builtin; same 11-char length as unpack_from)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack') — standalone
#
# struct.pack.__name__ is 'pack'. For C builtin functions, __name__ is the name
# of the function as defined in the PyMethodDef table in the C source. For
# struct.pack, this is 'pack' (4 chars). __name__ equals __qualname__ for top-level
# C builtins — they both reflect the function name without any class prefix.
# extra91 anchors pack.__qualname__.__eq__('pack'); extra96 anchors pack.__name__.__len__
# ()==4; no prior struct spec anchors pack.__name__.__eq__('pack') as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra119.pack_name_eq_pack:
  description: "struct.pack.__name__.__eq__('pack') == True — pack.__name__ is 'pack' (4 chars; for C builtins __name__ equals __qualname__; both are 'pack' for this top-level function; extra91 anchors pack.__qualname__.__eq__('pack'); extra96 anchors pack.__name__.__len__()==4; no prior spec anchors pack.__name__.__eq__('pack') as standalone; first standalone under structname119)"
  category: function_identity
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__eq__('pack_into') — standalone
#
# struct.pack_into.__name__ is 'pack_into'. pack_into is the only module-level
# struct function that packs data into a pre-allocated buffer (mutable buffer
# object) at a specified offset — unlike pack which allocates and returns a new
# bytes object. Its name 'pack_into' (9 chars) has an underscore, distinguishing
# it from plain 'pack'. __name__=='pack_into' equals __qualname__=='pack_into'
# for this top-level C builtin. No prior struct spec anchors pack_into.__name__
# __eq__('pack_into') as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra119.pack_into_name_eq:
  description: "struct.pack_into.__name__.__eq__('pack_into') == True — pack_into.__name__ is 'pack_into' (9 chars; underscore-separated; packs into a pre-allocated mutable buffer at a specified offset, unlike pack which allocates new bytes; __name__==__qualname__=='pack_into' for this top-level C builtin; extra96 anchors __name__.__len__()==9; extra95 anchors __qualname__.__len__()==9; no prior spec anchors pack_into __name__.__eq__ as standalone; first standalone under structname119)"
  category: function_identity
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__qualname__.__eq__('unpack_from') — standalone
#
# struct.unpack_from.__qualname__ is 'unpack_from'. unpack_from reads from a
# bytes-like buffer at a specified offset, unlike unpack which reads from the
# beginning of the entire bytes object. Its __qualname__ is 'unpack_from' (11
# chars — same length as iter_unpack). extra91 anchors pack/unpack/calcsize
# __qualname__.__eq__; extra95 anchors unpack_from.__qualname__.__len__()==11;
# no prior struct spec anchors unpack_from.__qualname__.__eq__('unpack_from')
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra119.unpack_from_qualname_eq:
  description: "struct.unpack_from.__qualname__.__eq__('unpack_from') == True — unpack_from.__qualname__ is 'unpack_from' (11 chars; reads from buffer at offset, unlike unpack which reads from start; __qualname__==__name__ for top-level C builtin; same 11-char qualname length as iter_unpack; extra91 anchors pack/unpack/calcsize qualname eq; extra95 anchors unpack_from qualname len==11; no prior spec anchors unpack_from qualname eq as standalone; first standalone under structname119)"
  category: function_identity
  kind: python_call_eq
  function: unpack_from.__qualname__.__eq__
  args: ["unpack_from"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__qualname__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack.__qualname__ is 'iter_unpack'. iter_unpack returns an
# iterator that reads successive fixed-size structs from a bytes object —
# useful for processing binary files or network buffers containing repeated
# data structures. Its __qualname__ is 'iter_unpack' (11 chars — same length
# as unpack_from). No prior struct spec anchors iter_unpack.__qualname__.__eq__
# ('iter_unpack') as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra119.iter_unpack_qualname_eq:
  description: "struct.iter_unpack.__qualname__.__eq__('iter_unpack') == True — iter_unpack.__qualname__ is 'iter_unpack' (11 chars; returns iterator over repeated structs from bytes buffer; __qualname__==__name__ for top-level C builtin; same 11-char qualname length as unpack_from; extra95 anchors iter_unpack qualname len==11; no prior spec anchors iter_unpack qualname eq as standalone; first standalone under structname119)"
  category: function_identity
  kind: python_call_eq
  function: iter_unpack.__qualname__.__eq__
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__module__.__len__()==7 — standalone
#
# struct.pack.__module__.__len__() is 7. pack.__module__ is '_struct' (7 chars:
# '_'=1 + 'struct'=6). extra95 anchors pack.__module__.__eq__('_struct') (as a table
# row); no prior struct spec anchors pack.__module__.__len__()==7 as a standalone.
# The 7-char module name '_struct' uses the leading underscore convention for C
# extension modules that back a Python public module. len('_struct')==7 coincides
# with len('hashlib')==7 — a coincidental 7-char length shared by these module names.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra119.pack_module_len_7:
  description: "struct.pack.__module__.__len__() == 7 — pack.__module__ is '_struct' (7 chars; '_'=1 + 'struct'=6); the leading underscore convention marks C extension modules backing a Python public module; extra95 anchors pack.__module__.__eq__('_struct') as table row; coincidentally len('_struct')==7 equals len('hashlib')==7; no prior spec anchors pack.__module__.__len__() as standalone; first standalone under structname119"
  category: function_identity
  kind: python_call_eq
  function: pack.__module__.__len__
  args: []
  expected: 7

