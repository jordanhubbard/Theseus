spec: pathlib_extra165
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __qualname__ values for stat, lstat, chmod, rename, replace."
    - "All five Path method qualnames follow the 'Path.<method>' pattern using the public class name 'Path' (5 characters)."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' (len=9; 'Path.' (5) + 'stat' (4) = 9; the shortest of the five methods in this spec)."
    - "pathlib.Path.lstat.__qualname__ == 'Path.lstat' (len=10; 'Path.' (5) + 'lstat' (5) = 10; tied with chmod at 10)."
    - "pathlib.Path.chmod.__qualname__ == 'Path.chmod' (len=10; 'Path.' (5) + 'chmod' (5) = 10; tied with lstat at 10)."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename' (len=11; 'Path.' (5) + 'rename' (6) = 11)."
    - "pathlib.Path.replace.__qualname__ == 'Path.replace' (len=12; 'Path.' (5) + 'replace' (7) = 12; the longest of the five methods in this spec)."
    - "Length ranking: stat=9, lstat=chmod=10, rename=11, replace=12."
    - "lstat and chmod form a two-way tie at qualname length 10 — both have 5-character method names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path filesystem-metadata method __qualname__ values (group 1)
# stat, lstat, chmod — file metadata and permissions methods.
# stat=9, lstat=10, chmod=10 (lstat and chmod tied at 10).
# All use 'Path.' prefix (5 characters).
# ---------------------------------------------------------------------------

table pathlib_extra165.Path_metadata_method_qualnames:
  description: "pathlib.Path metadata method __qualname__ values: stat='Path.stat' (len=9), lstat='Path.lstat' (len=10), chmod='Path.chmod' (len=10); lstat and chmod tied at 10; stat is the shortest"
  kind: python_call_eq
  category: qualname
  id_prefix: pathmeta165

  columns: [id, function, args, expected, description]
  rows:
    - [stat_qeq,   Path.stat.__qualname__.__eq__,   ["Path.stat"],   true, "pathlib.Path.stat.__qualname__ == 'Path.stat' (Path.stat() returns an os.stat_result object with file metadata such as size, permissions, and modification time; follows symlinks (use lstat() to stat the symlink itself); 'Path.stat' has 9 characters: 'Path.' (5) + 'stat' (4) = 9; the shortest of the five Path methods in this spec; Path.stat() is equivalent to os.stat(str(path)) but uses the Path object directly; the 'stat' name comes from the POSIX stat(2) system call)"]
    - [lstat_qeq,  Path.lstat.__qualname__.__eq__,  ["Path.lstat"],  true, "pathlib.Path.lstat.__qualname__ == 'Path.lstat' (Path.lstat() is like stat() but does not follow symbolic links — it returns information about the symlink itself rather than the file it points to; 'Path.lstat' has 10 characters: 'Path.' (5) + 'lstat' (5) = 10; tied with 'Path.chmod' (also 10) — both lstat and chmod have 5-character method names; 'lstat' stands for 'link stat'; compare with stat (len=9): lstat is one character longer due to the 'l' prefix)"]
    - [chmod_qeq,  Path.chmod.__qualname__.__eq__,  ["Path.chmod"],  true, "pathlib.Path.chmod.__qualname__ == 'Path.chmod' (Path.chmod() changes the file mode and permissions, like os.chmod(); accepts a mode bitmask (e.g., 0o644); 'Path.chmod' has 10 characters: 'Path.' (5) + 'chmod' (5) = 10; tied with 'Path.lstat' (also 10); both chmod and lstat have 5-character method names; 'chmod' stands for 'change mode'; chmod() is a key filesystem permission method and does not follow symlinks by default in Python 3.10+)"]
    - [stat_qlen,  Path.stat.__qualname__.__len__,  [],              9,    "pathlib.Path.stat.__qualname__.__len__() == 9 ('Path.stat' has 9 characters: 'Path.' (5) + 'stat' (4) = 9; the shortest of all five Path method qualnames in this spec; the length ranking is: stat=9, lstat=chmod=10, rename=11, replace=12; a run of consecutive integers from 9 to 12 with a two-way tie at 10; note that Path.open.__qualname__ length is also 9 (established in pathlib_extra163), making stat and open the shortest Path method qualnames seen across these specs)"]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem-mutation method __qualname__ values (group 2)
# rename, replace — path renaming and replacement methods.
# rename=11, replace=12
# replace is the longest of all five Path methods in this spec.
# ---------------------------------------------------------------------------

table pathlib_extra165.Path_rename_method_qualnames:
  description: "pathlib.Path rename/replace method __qualname__ values: rename='Path.rename' (len=11), replace='Path.replace' (len=12); replace is the longest of all five methods in this spec"
  kind: python_call_eq
  category: qualname
  id_prefix: pathrename165

  columns: [id, function, args, expected, description]
  rows:
    - [rename_qeq,   Path.rename.__qualname__.__eq__,   ["Path.rename"],   true, "pathlib.Path.rename.__qualname__ == 'Path.rename' (Path.rename() renames the file or directory to the given target path; if the target exists, it may or may not be silently replaced depending on the OS; for guaranteed atomic replacement on Unix, use replace() instead; 'Path.rename' has 11 characters: 'Path.' (5) + 'rename' (6) = 11; one character longer than 'Path.lstat' (10) and one shorter than 'Path.replace' (12); rename() is the pathlib analog of os.rename())"]
    - [replace_qeq,  Path.replace.__qualname__.__eq__,  ["Path.replace"],  true, "pathlib.Path.replace.__qualname__ == 'Path.replace' (Path.replace() renames the file or directory to the given target, silently replacing the target if it exists; unlike rename(), replace() is guaranteed to be an atomic operation on Unix (POSIX rename(2)); 'Path.replace' has 12 characters: 'Path.' (5) + 'replace' (7) = 12; the longest of all five Path method qualnames in this spec; 'replace' (7 chars) is one character longer than 'rename' (6 chars))"]
    - [rename_qlen,  Path.rename.__qualname__.__len__,  [],                11,   "pathlib.Path.rename.__qualname__.__len__() == 11 ('Path.rename' has 11 characters: 'Path.' (5) + 'rename' (6) = 11; falls between lstat/chmod (10) and replace (12) in the length ranking; rename() and replace() are the two mutation methods in this spec — both change the filesystem path of the entry; 'rename' (6 chars) is one shorter than 'replace' (7 chars), producing a 1-character difference in qualname length)"]
    - [replace_qlen, Path.replace.__qualname__.__len__, [],                12,   "pathlib.Path.replace.__qualname__.__len__() == 12 ('Path.replace' has 12 characters: 'Path.' (5) + 'replace' (7) = 12; the longest Path method qualname in this spec; the complete length ranking for this spec: stat=9, lstat=chmod=10, rename=11, replace=12; 'Path.replace' (12) matches 'Path.resolve' (12) established in pathlib_extra163 — both have 7-character method names ('replace' and 'resolve'); this 7-letter tie is a coincidence of similar-length method names)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra165.Path_stat_is_shortest_qualname_at_9:
  description: "pathlib.Path.stat.__qualname__.__len__() == 9 — 'Path.stat' is the shortest of all five Path method qualnames in this spec with only 9 characters; 'stat' (4 chars) is the shortest method name of the five; the complete ascending length order is: stat=9, lstat=chmod=10, rename=11, replace=12; Path.stat() returns metadata about the path's target file, following symlinks; this is the lowest length seen for a Path method qualname across these pathlib_extra16x specs (tied with Path.open established in pathlib_extra163); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.stat.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra165.Path_lstat_chmod_tied_at_10:
  description: "pathlib.Path.lstat.__qualname__.__len__() == 10 — 'Path.lstat' has 10 characters: 'Path.' (5) + 'lstat' (5) = 10; tied with 'Path.chmod' (also 10: 'Path.' (5) + 'chmod' (5) = 10); lstat and chmod are the only two Path methods in this spec with 5-character method names, producing the same qualname length of 10; lstat() does not follow symlinks while stat() does — a one-character method name difference (l prefix) with a one-character qualname length difference (lstat=10 vs stat=9); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.lstat.__qualname__.__len__
  args: []
  expected: 10

invariant pathlib_extra165.Path_replace_is_longest_qualname_at_12:
  description: "pathlib.Path.replace.__qualname__.__len__() == 12 — 'Path.replace' is the longest of all five Path method qualnames in this spec at 12 characters: 'Path.' (5) + 'replace' (7) = 12; 'replace' (7 chars) is the longest method name of the five; the length progression from shortest to longest is stat (9), lstat=chmod (10), rename (11), replace (12) — a compact 4-step run; Path.replace() is the recommended atomic rename on Unix; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.replace.__qualname__.__len__
  args: []
  expected: 12

invariant pathlib_extra165.Path_chmod_qualname_eq:
  description: "pathlib.Path.chmod.__qualname__ == 'Path.chmod' — chmod() uses the public class name 'Path' in its qualname, consistent with all other Path methods; 'Path.chmod' has 10 characters, tied with 'Path.lstat' (both 5-character method names); Path.chmod() changes the mode/permissions of the file; the qualname 'Path.chmod' follows the same public class name convention established across all pathlib_extra16x specs; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.chmod.__qualname__.__eq__
  args: ["Path.chmod"]
  expected: true

