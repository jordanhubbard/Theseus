spec: concurrent_futures_extra2221
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "Wave 2221 (_extra2221): identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__ checks for concurrent.futures classes."
    - "All 4 classes (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor) are pure Python."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base' — defined in _base.py."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' — defined in _base.py."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — defined in thread.py."
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — defined in process.py."
    - "__repr__ IS in __dict__ for concurrent.futures.Future (defines a custom repr); NOT in dict for Executor, ThreadPoolExecutor, ProcessPoolExecutor."
    - "__hash__ is NOT in __dict__ for any of the 4 classes — none explicitly define or suppress __hash__."
    - "__str__ is NOT in __dict__ for any of the 4 classes — none define a custom __str__."
    - "__doc__ IS in __dict__ for all 4 classes."
    - "__module__ IS in __dict__ for all 4 classes."
    - "__qualname__ is NOT in __dict__ for any of the 4 classes."
    - "__name__ is NOT in __dict__ for any of the 4 classes."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __hash__ dict-presence — all 4 concurrent.futures classes
#
# __hash__ is NOT in the __dict__ of any concurrent.futures class. None of
# Future, Executor, ThreadPoolExecutor, or ProcessPoolExecutor explicitly
# define or suppress __hash__ in their own class body. All 4 return False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2221.hash_dict_presence:
  description: "__hash__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2221

  columns: [id, function, args, expected]
  rows:
    - ["cf2221001", "concurrent.futures.Future.__dict__.__contains__", ["__hash__"], false]
    - ["cf2221002", "concurrent.futures.Executor.__dict__.__contains__", ["__hash__"], false]
    - ["cf2221003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__hash__"], false]
    - ["cf2221004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 2: __repr__ dict-presence — all 4 concurrent.futures classes
#
# __repr__ IS in the __dict__ of concurrent.futures.Future only. Future
# defines a custom __repr__ in _base.py showing the future's state and
# result. Executor, ThreadPoolExecutor, and ProcessPoolExecutor do not define
# a custom __repr__ and inherit from object. Future=True, rest=False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2221.repr_dict_presence:
  description: "__repr__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — Future True, rest False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2221

  columns: [id, function, args, expected]
  rows:
    - ["cf2221005", "concurrent.futures.Future.__dict__.__contains__", ["__repr__"], true]
    - ["cf2221006", "concurrent.futures.Executor.__dict__.__contains__", ["__repr__"], false]
    - ["cf2221007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__repr__"], false]
    - ["cf2221008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__repr__"], false]

# ---------------------------------------------------------------------------
# Table 3: __str__ dict-presence — all 4 concurrent.futures classes
#
# __str__ is NOT in the __dict__ of any concurrent.futures class. None of
