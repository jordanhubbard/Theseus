spec: functools_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "functools module CPython documentation"
    - "Python 3.9+ standard library"
  not_derived_from:
    - "any third-party functools extension"
  notes:
    - "Covers singledispatch, singledispatchmethod, and cached_property qualnames and module identity"
    - "All rows verify identity properties via __eq__ chains"
  created_at: "2026-04-12"

table functools_extra826.singledispatch_identity:
  description: "Verify functools.singledispatch qualname and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: ft826sd
  columns: [id, function, args, expected]
  rows:
    - [ft826sd001, "functools.singledispatch.__qualname__.__eq__", ["singledispatch"], true]
    - [ft826sd002, "functools.singledispatch.__module__.__eq__", ["functools"], true]
    - [ft826sd003, "functools.singledispatch.__doc__.__class__.__name__.__eq__", ["str"], true]

table functools_extra826.singledispatchmethod_identity:
  description: "Verify functools.singledispatchmethod qualname, module, and method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: ft826sm
  columns: [id, function, args, expected]
  rows:
    - [ft826sm001, "functools.singledispatchmethod.__qualname__.__eq__", ["singledispatchmethod"], true]
    - [ft826sm002, "functools.singledispatchmethod.__module__.__eq__", ["functools"], true]
    - [ft826sm003, "functools.singledispatchmethod.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [ft826sm004, "functools.singledispatchmethod.__init__.__qualname__.__eq__", ["singledispatchmethod.__init__"], true]
    - [ft826sm005, "functools.singledispatchmethod.__get__.__qualname__.__eq__", ["singledispatchmethod.__get__"], true]

table functools_extra826.cached_property_identity:
