spec: ctypes_extra6
version: ">=3.9"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — Python ctypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
    - "CPython source: Modules/_ctypes/"
    - "ctypes.zspec.zsdl — covers baseline type names and instance value round-trips."
    - "ctypes_extra.zspec.zsdl — covers c_int/__name__/__module__, instance value c_int(42).value, c_double(3.14).value."
    - "ctypes_extra2.zspec.zsdl — covers __module__ for c_int/c_char_p/c_char/c_long/c_float/c_bool/c_double/c_void_p/CDLL/Union/Array."
    - "ctypes_extra3.zspec.zsdl — covers __qualname__ for all major types."
    - "ctypes_extra4.zspec.zsdl — covers PyDLL, LibraryLoader __module__."
    - "ctypes_extra5.zspec.zsdl — covers __module__ for c_byte/c_wchar_p/c_uint/c_ulong/c_wchar/c_ushort/c_ubyte/c_short; c_int/c_long/c_float/c_byte instance .value boundary cases."
  notes:
    - "This spec extends ctypes.zspec.zsdl through ctypes_extra5.zspec.zsdl."
    - "ctypes.c_int.__name__ == 'c_int' — Verified Python 3.12 macOS."
    - "ctypes.c_long.__name__ == 'c_long' — Verified."
    - "ctypes.c_double.__name__ == 'c_double' — Verified."
    - "ctypes.c_char.__name__ == 'c_char' — Verified."
    - "ctypes.c_void_p.__name__ == 'c_void_p' — Verified."
    - "ctypes.c_int(42).value == 42 — Verified."
    - "ctypes.c_double(3.14).value == 3.14 — Verified."
    - "ctypes.sizeof(ctypes.c_int) == 4 — Verified on macOS (32-bit signed int)."
    - "ctypes.sizeof(ctypes.c_long) == 8 — Verified on macOS 64-bit (long is 8 bytes on LP64)."
    - "ctypes.sizeof(ctypes.c_double) == 8 — Verified (IEEE 754 double)."
    - "ctypes.sizeof(ctypes.c_char) == 1 — Verified (single byte char)."
    - "ctypes.sizeof(ctypes.c_void_p) == 8 — Verified on macOS 64-bit (pointer size)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table for core ctypes numeric and pointer types
#
# ctypes_extra covers c_int.__name__; ctypes_extra2 covers c_char.__name__.
# This table anchors all five from the extra6 namespace with a single
# compact view: c_int, c_long, c_double, c_char, c_void_p.
# ---------------------------------------------------------------------------

table ctypes_extra6.type_names:
  description: "Core ctypes type class __name__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: tn6

  columns: [id, function, args, expected]
  rows:
    - [c_int,    c_int.__name__.__eq__,    ["c_int"],    true]
    - [c_long,   c_long.__name__.__eq__,   ["c_long"],   true]
    - [c_double, c_double.__name__.__eq__, ["c_double"], true]
    - [c_char,   c_char.__name__.__eq__,   ["c_char"],   true]
    - [c_void_p, c_void_p.__name__.__eq__, ["c_void_p"], true]

# ---------------------------------------------------------------------------
# c_int(42).value == 42
#
# ctypes_extra covers c_int(42).value via a method chain. This invariant
# anchors the same check in the extra6 namespace.
# ---------------------------------------------------------------------------

invariant ctypes_extra6.c_int.value_42:
  description: "ctypes.c_int(42).value == 42 — basic integer round-trip"
  category: instance_values
  kind: python_call_eq
  function: c_int
  args: [42]
  method: value
  expected: 42

# ---------------------------------------------------------------------------
# c_double(3.14).value == 3.14
#
# ctypes_extra covers c_double(3.14).value. This invariant anchors the same
# check in the extra6 namespace. 3.14 is not exactly representable in IEEE 754
# double but round-trips faithfully through Python's float.
# ---------------------------------------------------------------------------

invariant ctypes_extra6.c_double.value_3_14:
  description: "ctypes.c_double(3.14).value == 3.14 — double round-trip"
  category: instance_values
  kind: python_call_eq
  function: c_double
  args: [3.14]
  method: value
  expected: 3.14

# ---------------------------------------------------------------------------
# sizeof table — core numeric and pointer types
#
# No prior ctypes spec checks sizeof for c_long, c_double, c_char, c_void_p
# as a grouped table. ctypes_extra (base) checks sizeof(c_int)==4 as a
# standalone. This table covers all five types.
# macOS LP64: c_int=4, c_long=8, c_double=8, c_char=1, c_void_p=8.
# ---------------------------------------------------------------------------

table ctypes_extra6.sizeof_types:
  description: "sizeof for core ctypes types on macOS LP64"
  kind: python_call_eq
  category: sizeof
  id_prefix: sz6

  columns: [id, function, args, expected]
  rows:
    - [c_int,    sizeof, [c_int],    4]
    - [c_long,   sizeof, [c_long],   8]
    - [c_double, sizeof, [c_double], 8]
    - [c_char,   sizeof, [c_char],   1]
    - [c_void_p, sizeof, [c_void_p], 8]
