spec: zoneinfo_extra8
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py, Lib/zoneinfo/_tzpath.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
    - "zoneinfo_extra2.zspec.zsdl — covers __qualname__ for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo.__bases__[0].__name__=='tzinfo'; ZoneInfoNotFoundError/__module__; available_timezones/__module__"
    - "zoneinfo_extra5.zspec.zsdl — covers ZoneInfo/__qualname__/__module__; ZoneInfoNotFoundError/__qualname__/base KeyError; available_timezones __name__/returns_set/min_count"
    - "zoneinfo_extra6.zspec.zsdl — covers ZoneInfo/__name__/__module__; ZoneInfoNotFoundError/__name__/__base_name__; available_timezones/__name__/returns_set/min_count"
    - "zoneinfo_extra7.zspec.zsdl — covers __name__ table for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo/ZoneInfoNotFoundError base class standalone invariants; ZoneInfo/__qualname__ and ZoneInfoNotFoundError/__qualname__ standalone"
  notes:
    - "This spec extends zoneinfo.zspec.zsdl and prior extras through zoneinfo_extra7.zspec.zsdl."
    - "NEW in extra8 — Axis 1: available_timezones.__qualname__ as standalone extra8-namespace invariant."
    - "NEW in extra8 — Axis 2: ZoneInfo.__module__ == 'zoneinfo' as standalone extra8-namespace invariant."
    - "NEW in extra8 — Axis 3: ZoneInfoNotFoundError.__module__ == 'zoneinfo._common' as standalone extra8-namespace invariant."
    - "NEW in extra8 — Axis 4: available_timezones returns a set containing 'UTC', 'America/New_York', and 'Europe/London' — membership invariants in extra8 namespace."
    - "zoneinfo.available_timezones.__qualname__ == 'available_timezones' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.__module__ == 'zoneinfo' — verified Python 3.12."
    - "zoneinfo.ZoneInfoNotFoundError.__module__ == 'zoneinfo._common' — verified Python 3.12."
    - "zoneinfo.available_timezones().__contains__('UTC') == True — verified Python 3.12."
    - "zoneinfo.available_timezones().__contains__('America/New_York') == True — verified Python 3.12."
    - "zoneinfo.available_timezones().__contains__('Europe/London') == True — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# available_timezones.__qualname__ — standalone extra8-namespace invariant
#
# zoneinfo_extra2, extra5, and extra7 cover available_timezones.__qualname__
# in various contexts. This spec re-anchors it as a standalone invariant in
# the extra8 namespace for systematic chain continuity.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra8.available_timezones.qualname:
  description: "zoneinfo.available_timezones.__qualname__ == 'available_timezones'"
  category: function_qualnames
  kind: python_call_eq
  function: available_timezones.__qualname__.__eq__
  args: ["available_timezones"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfo.__module__ == 'zoneinfo'
#
# zoneinfo_extra2 covers ZoneInfo.__module__ as a table entry. This spec
# anchors it as a standalone invariant in the extra8 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra8.ZoneInfo.module:
  description: "zoneinfo.ZoneInfo.__module__ == 'zoneinfo'"
  category: class_modules
  kind: python_call_eq
  function: ZoneInfo.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError.__module__ == 'zoneinfo._common'
#
# ZoneInfoNotFoundError is defined in the private zoneinfo._common submodule.
# zoneinfo_extra2 covers this. This spec re-anchors it as a standalone
# invariant in the extra8 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra8.ZoneInfoNotFoundError.module:
  description: "zoneinfo.ZoneInfoNotFoundError.__module__ == 'zoneinfo._common' — defined in private submodule"
  category: class_modules
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__module__.__eq__
  args: ["zoneinfo._common"]
  expected: true

# ---------------------------------------------------------------------------
# available_timezones() contains canonical IANA timezone keys
#
# zoneinfo_extra3 and extra5 cover containment of 'UTC' and 'America/New_York'.
# This spec re-anchors all three canonical keys as standalone invariants in
# the extra8 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra8.available_timezones.contains_UTC:
  description: "zoneinfo.available_timezones().__contains__('UTC') — UTC is a canonical IANA key"
  category: available_timezones
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __contains__
  method_args: ["UTC"]
  expected: true

invariant zoneinfo_extra8.available_timezones.contains_America_New_York:
  description: "zoneinfo.available_timezones().__contains__('America/New_York') — standard North American timezone"
  category: available_timezones
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __contains__
  method_args: ["America/New_York"]
  expected: true

invariant zoneinfo_extra8.available_timezones.contains_Europe_London:
  description: "zoneinfo.available_timezones().__contains__('Europe/London') — standard European timezone"
  category: available_timezones
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __contains__
  method_args: ["Europe/London"]
  expected: true
