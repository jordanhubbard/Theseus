spec: asyncio_extra213
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec covers: __doc__ string contains checks for asyncio functions and classes. NEW in extra213: asyncio.sleep.__doc__.__contains__('seconds')==True (len=57); asyncio.sleep.__doc__.__contains__('Coroutine')==True; asyncio.Task.__doc__.__contains__('coroutine')==True (len=32); asyncio.Task.__doc__.__contains__('Future')==True; asyncio.Queue.__doc__.__contains__('Queue')==True (len=490); asyncio.Queue.__doc__.__contains__('producer')==True; asyncio.Queue.__doc__.__contains__('maxsize')==True; asyncio.get_event_loop.__doc__.__contains__('event')==True (len=306); asyncio.get_event_loop.__doc__.__contains__('loop')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.sleep.__doc__ == 'Coroutine that completes after a given time (in seconds).' (len=57). asyncio.sleep.__doc__.__contains__('sleep') is False — the word 'sleep' does not appear in the docstring. asyncio.sleep.__doc__.__contains__('seconds') is True and __contains__('Coroutine') is True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.__doc__ == 'A coroutine wrapped in a Future.' (len=32). asyncio.Task.__doc__.__contains__('Task') is False — 'Task' does not appear in the docstring. asyncio.Task.__doc__.__contains__('coroutine') is True and __contains__('Future') is True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.__doc__ starts with 'A queue, useful for coordinating producer and consumer coroutines.' (len=490). Queue.__doc__.__contains__('Queue') is True; __contains__('producer') is True; __contains__('maxsize') is True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.get_event_loop.__doc__ starts with 'Return an asyncio event loop.' (len=306). __contains__('event') is True; __contains__('loop') is True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.sleep __doc__ contains checks — extra213
#
# asyncio.sleep.__doc__ == 'Coroutine that completes after a given time (in seconds).'
# len == 57
# __contains__('seconds') == True
# __contains__('Coroutine') == True
# __contains__('sleep') == False
# ---------------------------------------------------------------------------

table asyncio_extra213.asyncio_sleep_doc_contains:
  description: "asyncio.sleep.__doc__ contains checks in ae213sleep namespace — wave 213 theme: asyncio.__doc__ string inspection; asyncio.sleep.__doc__.__contains__('seconds')==True ('seconds' appears in 'a given time (in seconds).'); asyncio.sleep.__doc__.__contains__('Coroutine')==True (the docstring opens with 'Coroutine that completes...'); asyncio.sleep.__doc__.__contains__('sleep')==False (the word 'sleep' does not appear in the brief docstring itself, only in the function name); asyncio.sleep.__doc__.__len__()==57 (full docstring: 'Coroutine that completes after a given time (in seconds).' = 57 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ae213sleep

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_doc_has_seconds,   asyncio.sleep.__doc__.__contains__, ["seconds"],  true,  "asyncio.sleep.__doc__.__contains__('seconds') == True; verified with Python 3.14.3"]
    - [sleep_doc_has_coroutine, asyncio.sleep.__doc__.__contains__, ["Coroutine"], true, "asyncio.sleep.__doc__.__contains__('Coroutine') == True; verified with Python 3.14.3"]
    - [sleep_doc_no_sleep,      asyncio.sleep.__doc__.__contains__, ["sleep"],    false, "asyncio.sleep.__doc__.__contains__('sleep') == False — 'sleep' not in brief docstring; verified with Python 3.14.3"]
    - [sleep_doc_len,           asyncio.sleep.__doc__.__len__,      [],           57,    "asyncio.sleep.__doc__.__len__() == 57 ('Coroutine that completes after a given time (in seconds).'); verified with Python 3.14.3"]

