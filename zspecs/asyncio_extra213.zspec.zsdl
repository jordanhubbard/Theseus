# ---------------------------------------------------------------------------
# Standalone invariants — extra213
# ---------------------------------------------------------------------------

invariant asyncio_extra213.sleep_doc_len_57:
  description: "asyncio.sleep.__doc__.__len__() == 57 — asyncio.sleep.__doc__ is 'Coroutine that completes after a given time (in seconds).' (57 chars); asyncio.sleep.__doc__.__contains__('seconds') is True; asyncio.sleep.__doc__.__contains__('Coroutine') is True; asyncio.sleep.__doc__.__contains__('sleep') is False (the word 'sleep' does not appear in the brief docstring — it only appears as the function name itself); asyncio.Task.__doc__.__len__()==32 (shorter); asyncio.Queue.__doc__.__len__()==490 (much longer); asyncio.get_event_loop.__doc__.__len__()==306; sleep doc len=57 is the second-shortest in this spec (Task=32 < sleep=57 < get_event_loop=306 < Queue=490); NEW in extra213: first standalone sleep __doc__ length invariant; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__doc__.__len__
  args: []
  expected: 57

invariant asyncio_extra213.task_doc_has_future:
  description: "asyncio.Task.__doc__.__contains__('Future') returns True — asyncio.Task.__doc__ is 'A coroutine wrapped in a Future.' (len=32); 'Future' appears at the end of the docstring; asyncio.Task.__doc__.__contains__('coroutine') is also True (opens with 'A coroutine'); asyncio.Task.__doc__.__contains__('Task') is False (the class name does not appear in its own brief docstring); asyncio.Task.__doc__.__len__()==32 (shortest __doc__ in this spec); Task wraps a coroutine in a Future, scheduling it on the event loop; NEW in extra213: first standalone Task __doc__ Future contains invariant; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__doc__.__contains__
  args: ["Future"]
  expected: true

invariant asyncio_extra213.queue_doc_len_490:
  description: "asyncio.Queue.__doc__.__len__() == 490 — asyncio.Queue has the longest __doc__ in this spec (490 chars); asyncio.Queue.__doc__.__contains__('Queue') is True; asyncio.Queue.__doc__.__contains__('producer') is True ('coordinating producer and consumer coroutines'); asyncio.Queue.__doc__.__contains__('maxsize') is True (the Queue constructor accepts a maxsize parameter); doc length ordering: Task=32 < sleep=57 < get_event_loop=306 < Queue=490; Queue's lengthy docstring describes the maxsize parameter and the producer-consumer pattern; NEW in extra213: first standalone Queue __doc__ length invariant; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__doc__.__len__
  args: []
  expected: 490

invariant asyncio_extra213.get_event_loop_doc_has_event:
  description: "asyncio.get_event_loop.__doc__.__contains__('event') returns True — asyncio.get_event_loop.__doc__ opens with 'Return an asyncio event loop.' (len=306); 'event' appears in 'event loop'; __contains__('loop') is also True; asyncio.get_event_loop.__doc__.__len__()==306; get_event_loop is the primary API for obtaining the running event loop (deprecated in favor of get_running_loop in newer Python versions, but still functional); NEW in extra213: first standalone get_event_loop __doc__ event contains invariant; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__doc__.__contains__
  args: ["event"]
  expected: true

