    - [task_doc_has_future,    asyncio.Task.__doc__.__contains__, ["Future"],    true,  "asyncio.Task.__doc__.__contains__('Future') == True; verified with Python 3.14.3"]
    - [task_doc_no_task,       asyncio.Task.__doc__.__contains__, ["Task"],      false, "asyncio.Task.__doc__.__contains__('Task') == False — 'Task' not in brief docstring; verified with Python 3.14.3"]
    - [task_doc_len,           asyncio.Task.__doc__.__len__,      [],            32,    "asyncio.Task.__doc__.__len__() == 32 ('A coroutine wrapped in a Future.'); verified with Python 3.14.3"]

