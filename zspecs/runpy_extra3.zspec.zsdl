spec: runpy_extra3
version: ">=3.9"
backend: python_module(runpy)

docs: https://docs.python.org/3/library/runpy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/runpy.html — Python runpy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/runpy.py"
  notes:
    - "This spec extends runpy.zspec.zsdl, runpy_extra.zspec.zsdl, and runpy_extra2.zspec.zsdl."
    - "runpy_extra covered: run_module.__name__, run_module.__module__, run_path.__name__, run_path.__module__, run_module.__qualname__, run_path.__qualname__."
    - "runpy_extra2 covered: same __name__/__module__/__qualname__ invariants (some overlap with extra), plus _run_code internals and __class__.__name__ == 'function' checks."
    - "This spec adds: _run_module_as_main.__name__ (different internal from _run_code), a function_names table (table form not previously used for runpy), and _run_module_as_main.__module__."
    - "runpy._run_module_as_main is the CPython internal that implements 'python -m module'; it is distinct from _run_code."
    - "runpy._run_module_as_main.__name__ == '_run_module_as_main' — name attribute of the internal function."
    - "runpy._run_module_as_main.__module__ == 'runpy' — defined in the runpy module."
    - "runpy._run_module_as_main.__class__.__name__ == 'function' — it is a plain Python function."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _run_module_as_main — private but accessible internal function
# runpy_extra2 covered _run_code; this spec covers _run_module_as_main (distinct).
# ---------------------------------------------------------------------------

invariant runpy_extra3.internals._run_module_as_main_name:
  description: "runpy._run_module_as_main.__name__ == '_run_module_as_main'"
  category: internals
  kind: python_call_eq
  function: _run_module_as_main.__name__.__eq__
  args: ["_run_module_as_main"]
  expected: true

invariant runpy_extra3.internals._run_module_as_main_module:
  description: "runpy._run_module_as_main.__module__ == 'runpy'"
  category: internals
  kind: python_call_eq
  function: _run_module_as_main.__module__.__eq__
  args: ["runpy"]
  expected: true

invariant runpy_extra3.internals._run_module_as_main_is_function:
  description: "runpy._run_module_as_main.__class__.__name__ == 'function'"
  category: internals
  kind: python_call_eq
  function: _run_module_as_main.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# function_names table — run_module and run_path (table form; not used before)
# runpy_extra and runpy_extra2 used individual invariant blocks for these.
# This spec provides the same facts in a table for cross-reference coverage.
# ---------------------------------------------------------------------------

table runpy_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: function_name

  columns: [id, function, args, expected]
  rows:
    - [run_module, run_module.__name__.__eq__, ["run_module"], true]
    - [run_path,   run_path.__name__.__eq__,   ["run_path"],   true]
