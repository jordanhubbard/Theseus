spec: collections_extra8
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras."
    - "collections_extra through collections_extra7 cover: __name__/__module__/__qualname__ for Counter/deque/defaultdict/OrderedDict/ChainMap/UserDict/UserList/UserString/namedtuple; OrderedDict/__bases__[0].__name__ (inherits dict); Counter/__bases__[0].__name__ (inherits dict); defaultdict/__bases__[0].__name__ (inherits dict); deque module via C extension."
    - "NEW in this spec: __bases__[0].__name__ for ChainMap, UserDict, UserList, UserString (none of these were tested in any prior spec); OrderedDict.__bases__.__len__() == 1; Counter.__bases__.__len__() == 1."
    - "collections.ChainMap.__bases__[0].__name__ == 'object' — ChainMap inherits directly from object."
    - "collections.UserDict.__bases__[0].__name__ == 'MutableMapping' — UserDict wraps a dict and inherits from MutableMapping."
    - "collections.UserList.__bases__[0].__name__ == 'MutableSequence' — UserList wraps a list and inherits from MutableSequence."
    - "collections.UserString.__bases__[0].__name__ == 'Sequence' — UserString wraps a str and inherits from Sequence."
    - "collections.OrderedDict.__bases__.__len__() == 1 — exactly one direct base (dict)."
    - "collections.Counter.__bases__.__len__() == 1 — exactly one direct base (dict)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for ChainMap, UserDict, UserList, UserString
#
# collections_extra (extra, extra2, extra3, extra5, extra6, extra7) covered
# __name__/__module__/__qualname__ for all four classes, plus __bases__ for
# Counter/OrderedDict/defaultdict. No prior spec tested the bases for ChainMap,
# UserDict, UserList, or UserString.
# ---------------------------------------------------------------------------

invariant collections_extra8.ChainMap.base_is_object:
  description: "collections.ChainMap.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: ChainMap.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant collections_extra8.UserDict.base_name:
  description: "collections.UserDict.__bases__[0].__name__ == 'MutableMapping' — UserDict inherits from MutableMapping"
  category: class_hierarchy
  kind: python_call_eq
  function: UserDict.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MutableMapping"

invariant collections_extra8.UserList.base_name:
  description: "collections.UserList.__bases__[0].__name__ == 'MutableSequence' — UserList inherits from MutableSequence"
  category: class_hierarchy
  kind: python_call_eq
  function: UserList.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MutableSequence"

invariant collections_extra8.UserString.base_name:
  description: "collections.UserString.__bases__[0].__name__ == 'Sequence' — UserString inherits from Sequence"
  category: class_hierarchy
  kind: python_call_eq
  function: UserString.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Sequence"

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for OrderedDict and Counter
#
# collections.zspec.zsdl confirmed OrderedDict.__bases__[0].__name__ == 'dict'
# and Counter.__bases__[0].__name__ == 'dict'. Not yet verified: that each has
# exactly one direct base (no multiple inheritance).
# ---------------------------------------------------------------------------

invariant collections_extra8.OrderedDict.bases_len:
  description: "collections.OrderedDict.__bases__.__len__() == 1 — exactly one direct base (dict)"
  category: class_hierarchy
  kind: python_call_eq
  function: OrderedDict.__bases__.__len__
  args: []
  expected: 1

invariant collections_extra8.Counter.bases_len:
  description: "collections.Counter.__bases__.__len__() == 1 — exactly one direct base (dict)"
  category: class_hierarchy
  kind: python_call_eq
  function: Counter.__bases__.__len__
  args: []
  expected: 1
