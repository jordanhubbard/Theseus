spec: sys_extra19
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra18.zspec.zsdl — covers version/version_info/platform/byteorder/maxsize/maxunicode class names; function __name__ table for getrecursionlimit/setrecursionlimit/getrefcount/getsizeof/intern"
    - "sys_extra15.zspec.zsdl — covers version_info.major/minor/micro __class__.__name__=='int'; stdin/stdout/stderr class names"
    - "sys_extra10.zspec.zsdl — covers maxunicode==1114111; maxsize>0; prefix/exec_prefix/executable class names"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra18.zspec.zsdl."
    - "sys.argv.__class__.__name__ == 'list' — argv is always a list."
    - "sys.path.__class__.__name__ == 'list' — path is always a list."
    - "sys.modules.__class__.__name__ == 'dict' — modules is always a dict."
    - "sys.builtin_module_names.__class__.__name__ == 'tuple' — a tuple of built-in module name strings."
    - "sys.flags.__class__.__name__ == 'flags' — flags is an instance of the sys.flags named tuple type."
    - "sys.implementation.__class__.__name__ == 'SimpleNamespace' — verified on Python 3.12 macOS."
    - "sys.float_info.__class__.__name__ == 'float_info' — a named tuple for floating-point precision limits."
    - "sys.int_info.__class__.__name__ == 'int_info' — a named tuple for integer implementation details."
    - "Table covers __class__.__name__ for argv, path, modules, builtin_module_names as a grouped check."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.flags — __class__.__name__ == 'flags'
#
# No prior sys spec checks flags.__class__.__name__ as a standalone invariant.
# sys.flags is a named tuple-like object whose type is named 'flags'.
# ---------------------------------------------------------------------------

invariant sys_extra19.flags.class_name:
  description: "sys.flags.__class__.__name__ == 'flags' — flags is a sys.flags instance"
  category: implementation_objects
  kind: python_call_eq
  function: flags.__class__.__name__.__eq__
  args: ["flags"]
  expected: true

# ---------------------------------------------------------------------------
# sys.implementation — __class__.__name__ == 'SimpleNamespace'
#
# No prior sys spec checks implementation.__class__.__name__ as a standalone
# invariant. On CPython 3.12, sys.implementation is a SimpleNamespace.
# ---------------------------------------------------------------------------

invariant sys_extra19.implementation.class_name:
  description: "sys.implementation.__class__.__name__ == 'SimpleNamespace'"
  category: implementation_objects
  kind: python_call_eq
  function: implementation.__class__.__name__.__eq__
  args: ["SimpleNamespace"]
  expected: true

# ---------------------------------------------------------------------------
# sys.float_info — __class__.__name__ == 'float_info'
#
# No prior sys spec checks float_info.__class__.__name__ as a standalone
# invariant. sys.float_info is a named tuple type named 'float_info'.
# ---------------------------------------------------------------------------

invariant sys_extra19.float_info.class_name:
  description: "sys.float_info.__class__.__name__ == 'float_info'"
  category: implementation_objects
  kind: python_call_eq
  function: float_info.__class__.__name__.__eq__
  args: ["float_info"]
  expected: true

# ---------------------------------------------------------------------------
# sys.int_info — __class__.__name__ == 'int_info'
#
# No prior sys spec checks int_info.__class__.__name__ as a standalone
# invariant. sys.int_info is a named tuple type named 'int_info'.
# ---------------------------------------------------------------------------

invariant sys_extra19.int_info.class_name:
  description: "sys.int_info.__class__.__name__ == 'int_info'"
  category: implementation_objects
  kind: python_call_eq
  function: int_info.__class__.__name__.__eq__
  args: ["int_info"]
  expected: true

# ---------------------------------------------------------------------------
# argv, path, modules, builtin_module_names — __class__.__name__ (table)
#
# No prior sys spec groups these four attributes together in a __class__.__name__
# table. sys_extra10 covers prefix/exec_prefix/executable type names; extra15
# covers version_info fields. This table covers the four core collection
# attributes as a single grouped check.
# ---------------------------------------------------------------------------

table sys_extra19.collection_class_names:
  description: "__class__.__name__ for sys.argv, sys.path, sys.modules, sys.builtin_module_names"
  kind: python_call_eq
  category: collection_types
  id_prefix: coll_cls

  columns: [id, function, args, expected]
  rows:
    - [argv,                 argv.__class__.__name__.__eq__,                 ["list"],  true]
    - [path,                 path.__class__.__name__.__eq__,                 ["list"],  true]
    - [modules,              modules.__class__.__name__.__eq__,              ["dict"],  true]
    - [builtin_module_names, builtin_module_names.__class__.__name__.__eq__, ["tuple"], true]
