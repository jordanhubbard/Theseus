spec: inspect_extra33
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra32.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__qualname__.__len__(), getmembers/getfile/getsource/getsourcelines/getmodule/getargs/signature/stack/currentframe/getfullargspec __qualname__.__len__(), isasyncgenfunction/isgeneratorfunction/iscoroutinefunction __qualname__.__len__(), Signature.from_callable.__qualname__.__len__() (23), Parameter/__mro__.__len__() (2)/Signature/__mro__.__len__() (2)/BoundArguments/__mro__.__len__() (2), class __bases__[0].__name__.__len__() for Parameter/Signature/BoundArguments (all 6), class __dict__.__class__.__name__.__len__() for Parameter/Signature/BoundArguments/FrameInfo (all 12), _ParameterKind.__qualname__.__len__() (14), Parameter.empty.__qualname__.__len__(), __all__.__len__() (107), FrameInfo/__mro__/__qualname__ metadata, inspect.__name__.__len__() (7)."
    - "This spec covers: Parameter.__name__.__len__() (9 — 'Parameter'); Parameter.__qualname__.__len__() (9 — same as __name__); Signature.__name__.__len__() (9 — 'Signature'); Signature.__qualname__.__len__() (9 — same); BoundArguments.__name__.__len__() (14 — 'BoundArguments'); BoundArguments.__qualname__.__len__() (14 — same); Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__len__() (14 — '_ParameterKind'); FullArgSpec.__name__.__len__() (11 — 'FullArgSpec'); FullArgSpec.__qualname__.__len__() (11 — same); FullArgSpec.__mro__.__len__() (3 — [FullArgSpec, tuple, object]); isfunction.__name__.__len__() (10 — same as __qualname__); ismethod.__name__.__len__() (8 — same as __qualname__)."
    - "Key findings: Parameter.__name__ and __qualname__ are both 'Parameter' (9 chars) — it is not a nested class. Signature.__name__ and __qualname__ are both 'Signature' (9 chars). BoundArguments.__name__ and __qualname__ are both 'BoundArguments' (14 chars). Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ is '_ParameterKind' (14 chars) — same length as BoundArguments. FullArgSpec is a namedtuple with MRO depth 3 ([FullArgSpec, tuple, object]), unlike Parameter/Signature/BoundArguments which have depth 2. isfunction.__name__ == 'isfunction' (10 chars) matches its qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Parameter and Signature __name__ and __qualname__ lengths — extra33 namespace
#
# inspect.Parameter.__name__ is 'Parameter' (9 chars). inspect.Parameter.__qualname__
# is also 'Parameter' (9 chars) — matching values confirm it is not a nested class.
# inspect.Signature.__name__ is 'Signature' (9 chars). inspect.Signature.__qualname__
# is also 'Signature' (9 chars). Prior specs covered __mro__.__len__() and
# __bases__[0].__name__.__len__() for these classes, but not their own
# __name__.__len__() or __qualname__.__len__(). No prior inspect spec records
# these four values together in a combined table in the extra33 namespace.
# ---------------------------------------------------------------------------

table inspect_extra33.parameter_signature_name_lengths:
  description: "inspect.Parameter and Signature __name__.__len__() and __qualname__.__len__() — all 9"
  kind: python_call_eq
  category: string_properties
  id_prefix: paramsignamelen33

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_name,
       Parameter.__name__.__len__,
       [],
       9,
       "len(inspect.Parameter.__name__) == 9 — 'Parameter'"]
    - [Parameter_qualname,
       Parameter.__qualname__.__len__,
       [],
       9,
       "len(inspect.Parameter.__qualname__) == 9 — 'Parameter' (not a nested class)"]
    - [Signature_name,
       Signature.__name__.__len__,
       [],
       9,
       "len(inspect.Signature.__name__) == 9 — 'Signature'"]
    - [Signature_qualname,
       Signature.__qualname__.__len__,
       [],
       9,
       "len(inspect.Signature.__qualname__) == 9 — 'Signature' (not a nested class)"]

# ---------------------------------------------------------------------------
# BoundArguments and FullArgSpec class name metadata — extra33 namespace
#
# inspect.BoundArguments.__name__ is 'BoundArguments' (14 chars). Its __qualname__
# is also 'BoundArguments' (14 chars). inspect.FullArgSpec.__name__ is 'FullArgSpec'
# (11 chars). FullArgSpec is a namedtuple; its __mro__.__len__() is 3 —
# [FullArgSpec, tuple, object] — unlike Parameter/Signature/BoundArguments (all 2).
# FullArgSpec.__qualname__ is also 'FullArgSpec' (11 chars). No prior inspect spec
# records these five values together in a combined table in the extra33 namespace.
# ---------------------------------------------------------------------------

table inspect_extra33.boundarguments_fullargspec_metadata:
  description: "inspect.BoundArguments and FullArgSpec class name metadata: __name__/__qualname__/__mro__ lengths"
  kind: python_call_eq
  category: class_structure
  id_prefix: bafasmetadata33

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_name,
       BoundArguments.__name__.__len__,
       [],
       14,
       "len(inspect.BoundArguments.__name__) == 14 — 'BoundArguments'"]
    - [BoundArguments_qualname,
       BoundArguments.__qualname__.__len__,
       [],
       14,
       "len(inspect.BoundArguments.__qualname__) == 14 — 'BoundArguments' (not a nested class)"]
    - [FullArgSpec_name,
       FullArgSpec.__name__.__len__,
       [],
       11,
       "len(inspect.FullArgSpec.__name__) == 11 — 'FullArgSpec'"]
    - [FullArgSpec_qualname,
       FullArgSpec.__qualname__.__len__,
       [],
       11,
       "len(inspect.FullArgSpec.__qualname__) == 11 — 'FullArgSpec'"]
    - [FullArgSpec_mro,
       FullArgSpec.__mro__.__len__,
       [],
       3,
       "len(inspect.FullArgSpec.__mro__) == 3 — [FullArgSpec, tuple, object]: namedtuple depth"]

# ---------------------------------------------------------------------------
# Core predicate __name__.__len__() table — isfunction/ismethod — extra33 namespace
#
# inspect.isfunction.__name__ is 'isfunction' (10 chars). inspect.ismethod.__name__
# is 'ismethod' (8 chars). Prior specs recorded the __qualname__.__len__() for
# isfunction (10) and ismethod (8) in the extra32 core_predicate_qualname_lengths
# table. However, the __name__.__len__() values were not explicitly listed, even
# though for plain module-level functions __name__ == __qualname__. No prior inspect
# spec records these two __name__.__len__() values together in a combined table
# in the extra33 namespace.
# ---------------------------------------------------------------------------

table inspect_extra33.predicate_name_lengths:
  description: "inspect predicate __name__.__len__() for isfunction and ismethod"
  kind: python_call_eq
  category: string_properties
  id_prefix: prednamelenlen33

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction,
       isfunction.__name__.__len__,
       [],
       10,
       "len(inspect.isfunction.__name__) == 10 — 'isfunction' (matches __qualname__)"]
    - [ismethod,
       ismethod.__name__.__len__,
       [],
       8,
       "len(inspect.ismethod.__name__) == 8 — 'ismethod' (matches __qualname__)"]

# ---------------------------------------------------------------------------
# Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__len__() — standalone invariant
#
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ is '_ParameterKind'
# (14 chars). This accesses the enum class name through a member instance rather
# than through the class directly. Prior specs recorded _ParameterKind.__qualname__.__len__()
# == 14 via the class object; this invariant confirms the same 14-character length
# is accessible through an enum member's __class__.__name__. No prior inspect spec
# records Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__len__() as a standalone
# in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra33.ParameterKind_via_member_classname_len:
  description: "len(inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__) == 14 — '_ParameterKind' accessible via enum member"
  category: string_properties
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__len__
  args: []
  expected: 14
