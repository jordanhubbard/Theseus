spec: zlib_extra18
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
  notes:
    - "This spec extends zlib_extra17.zspec.zsdl."
    - "Prior specs covered: compress/__name__/__module__, decompress/__name__/__module__, compressobj/__name__/__module__, decompressobj/__name__/__module__, crc32/__name__, adler32/__name__, Compress/__qualname__, Decompress/__qualname__, error/__name__/__module__/__qualname__/__bases__[0].__name__, Z_DEFAULT_COMPRESSION/__class__.__name__, DEFLATED/__class__.__name__, various __qualname__ checks, module/__len__() and __name__.__len__() for all functions, error/__mro__.__len__(), error/__bases__[0].__name__.__len__(), function __qualname__.__len__() for compress/decompress/crc32/adler32, Compress/Decompress method __qualname__.__len__()."
    - "zlib does not define __all__: hasattr(zlib, '__all__') == False. Verified 2026-04-10."
    - "This spec covers: zlib.error.__dict__.__class__.__name__.__len__(), zlib.error.__name__.__len__(), zlib.error.__qualname__.__len__(), zlib.Z_DEFAULT_COMPRESSION.__class__.__name__.__len__(), zlib.DEFLATED.__class__.__name__.__len__(), zlib.Z_BEST_COMPRESSION.__class__.__name__.__len__(), zlib.DEF_BUF_SIZE.__class__.__name__.__len__(), zlib.MAX_WBITS.__class__.__name__.__len__(), zlib.DEF_MEM_LEVEL.__class__.__name__.__len__(), zlib.Compress.__name__.__len__(), zlib.Compress.__qualname__.__len__(), zlib.Compress.__mro__.__len__(), zlib.Decompress.__name__.__len__(), zlib.Decompress.__qualname__.__len__(), zlib.Decompress.__mro__.__len__()."
    - "zlib.error.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified 2026-04-10."
    - "zlib.error.__name__ == 'error' (len 5). Verified 2026-04-10."
    - "zlib.error.__qualname__ == 'error' (len 5): not nested, __qualname__ == __name__. Verified 2026-04-10."
    - "All zlib integer constants (Z_DEFAULT_COMPRESSION, DEFLATED, Z_BEST_COMPRESSION, DEF_BUF_SIZE, MAX_WBITS, DEF_MEM_LEVEL) have __class__.__name__ == 'int' (len 3). Verified 2026-04-10."
    - "zlib.Compress (returned by compressobj()) is a C extension type: __name__='Compress' (len 8), __qualname__='Compress' (len 8), __mro__.__len__()==2 ([Compress, object]). Verified 2026-04-10."
    - "zlib.Decompress (returned by decompressobj()) is a C extension type: __name__='Decompress' (len 10), __qualname__='Decompress' (len 10), __mro__.__len__()==2 ([Decompress, object]). Verified 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# zlib.error.__dict__.__class__.__name__.__len__() == 12 — novel, extra18 anchor
#
# zlib.error.__dict__ is of type mappingproxy. 'mappingproxy' has 12
# characters. No prior zlib spec checks __dict__.__class__.__name__.__len__()
# for zlib.error. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.error.dict_class_name_len:
  description: "zlib.error.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has twelve characters (extra18)"
  category: type_names
  kind: python_call_eq
  function: error.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# zlib.error.__name__.__len__() == 5 — novel, extra18 anchor
#
# zlib.error.__name__ == 'error' which has 5 characters. No prior zlib spec
# checks __name__.__len__() on the error class object itself (prior specs
# checked __name__ == 'error' but not __len__()). Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.error.name_len:
  description: "zlib.error.__name__.__len__() == 5 — 'error' has five characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# zlib.error.__qualname__.__len__() == 5 — novel, extra18 anchor
#
# zlib.error.__qualname__ == 'error' which has 5 characters. zlib.error is not
# a nested class so __qualname__ == __name__. No prior zlib spec checks
# __qualname__.__len__() on the error class object itself. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.error.qualname_len:
  description: "zlib.error.__qualname__.__len__() == 5 — 'error' qualname has five characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: error.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# zlib.Z_DEFAULT_COMPRESSION.__class__.__name__.__len__() == 3 — novel, extra18
#
# zlib.Z_DEFAULT_COMPRESSION is -1, an int. 'int' has 3 characters. No prior
# zlib spec checks __class__.__name__.__len__() for Z_DEFAULT_COMPRESSION.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.Z_DEFAULT_COMPRESSION.class_name_len:
  description: "zlib.Z_DEFAULT_COMPRESSION.__class__.__name__.__len__() == 3 — 'int' has three characters (extra18)"
  category: type_names
  kind: python_call_eq
  function: Z_DEFAULT_COMPRESSION.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# zlib.DEFLATED.__class__.__name__.__len__() == 3 — novel, extra18 anchor
#
# zlib.DEFLATED is 8, an int. 'int' has 3 characters. No prior zlib spec
# checks __class__.__name__.__len__() for DEFLATED. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.DEFLATED.class_name_len:
  description: "zlib.DEFLATED.__class__.__name__.__len__() == 3 — 'int' has three characters (extra18)"
  category: type_names
  kind: python_call_eq
  function: DEFLATED.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# zlib.DEF_BUF_SIZE.__class__.__name__.__len__() == 3 — novel, extra18 anchor
#
# zlib.DEF_BUF_SIZE is 16384, an int. 'int' has 3 characters. No prior zlib
# spec checks __class__.__name__.__len__() for DEF_BUF_SIZE. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.DEF_BUF_SIZE.class_name_len:
  description: "zlib.DEF_BUF_SIZE.__class__.__name__.__len__() == 3 — 'int' has three characters (extra18)"
  category: type_names
  kind: python_call_eq
  function: DEF_BUF_SIZE.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Compress.__name__.__len__() == 8 — novel, extra18 anchor
#
# The Compress C type returned by zlib.compressobj() has __name__ == 'Compress'
# (8 characters). No prior zlib spec checks __name__.__len__() on the Compress
# class object. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.Compress.name_len:
  description: "zlib.Compress.__name__.__len__() == 8 — 'Compress' has eight characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: "compressobj().__class__.__name__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Compress.__qualname__.__len__() == 8 — novel, extra18 anchor
#
# The Compress C type has __qualname__ == 'Compress' (8 characters). For a
# top-level C extension type __qualname__ == __name__. No prior zlib spec
# checks __qualname__.__len__() on the Compress class object itself.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.Compress.qualname_len:
  description: "zlib.Compress.__qualname__.__len__() == 8 — 'Compress' qualname has eight characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: "compressobj().__class__.__qualname__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Compress.__mro__.__len__() == 2 — novel, extra18 anchor
#
# The Compress C type has __mro__ == [Compress, object] — two entries. It is a
# C extension type that bases directly from object with no intermediate
# Python-level classes. No prior zlib spec checks __mro__.__len__() for the
# Compress type. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.Compress.mro_len:
  description: "zlib.Compress.__mro__.__len__() == 2 — Compress MRO has two entries (extra18)"
  category: class_hierarchy
  kind: python_call_eq
  function: "compressobj().__class__.__mro__.__len__"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Decompress.__name__.__len__() == 10 — novel, extra18 anchor
#
# The Decompress C type returned by zlib.decompressobj() has __name__ ==
# 'Decompress' (10 characters). No prior zlib spec checks __name__.__len__()
# on the Decompress class object. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.Decompress.name_len:
  description: "zlib.Decompress.__name__.__len__() == 10 — 'Decompress' has ten characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: "decompressobj().__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Decompress.__qualname__.__len__() == 10 — novel, extra18 anchor
#
# The Decompress C type has __qualname__ == 'Decompress' (10 characters). For
# a top-level C extension type __qualname__ == __name__. No prior zlib spec
# checks __qualname__.__len__() on the Decompress class object itself.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.Decompress.qualname_len:
  description: "zlib.Decompress.__qualname__.__len__() == 10 — 'Decompress' qualname has ten characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: "decompressobj().__class__.__qualname__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Decompress.__mro__.__len__() == 2 — novel, extra18 anchor
#
# The Decompress C type has __mro__ == [Decompress, object] — two entries. It
# is a C extension type that bases directly from object. No prior zlib spec
# checks __mro__.__len__() for the Decompress type. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant zlib_extra18.Decompress.mro_len:
  description: "zlib.Decompress.__mro__.__len__() == 2 — Decompress MRO has two entries (extra18)"
  category: class_hierarchy
  kind: python_call_eq
  function: "decompressobj().__class__.__mro__.__len__"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# integer constant __class__.__name__.__len__() table — Z_DEFAULT_COMPRESSION,
#                   DEFLATED, Z_BEST_COMPRESSION, DEF_BUF_SIZE, MAX_WBITS,
#                   DEF_MEM_LEVEL (extra18)
#
# All zlib integer constants are plain Python int values. 'int' has 3
# characters. This table anchors the __class__.__name__.__len__() == 3 check
# for the six most-commonly referenced constants from the extra18 namespace.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

table zlib_extra18.constant_class_name_lengths:
  kind: python_call_eq
  category: type_names
  id_prefix: constcnlen18

  columns: [id, function, args, expected]
  rows:
    - [Z_DEFAULT_COMPRESSION, Z_DEFAULT_COMPRESSION.__class__.__name__.__len__, [], 3]
    - [DEFLATED,              DEFLATED.__class__.__name__.__len__,              [], 3]
    - [Z_BEST_COMPRESSION,    Z_BEST_COMPRESSION.__class__.__name__.__len__,    [], 3]
    - [DEF_BUF_SIZE,          DEF_BUF_SIZE.__class__.__name__.__len__,          [], 3]
    - [MAX_WBITS,             MAX_WBITS.__class__.__name__.__len__,             [], 3]
    - [DEF_MEM_LEVEL,         DEF_MEM_LEVEL.__class__.__name__.__len__,         [], 3]

# ---------------------------------------------------------------------------
# Compress and Decompress class attribute table — __name__.__len__(),
#                                                 __qualname__.__len__(),
#                                                 __mro__.__len__() (extra18)
#
# Both Compress and Decompress are C extension types returned by compressobj()
# and decompressobj() respectively. Each has a 2-entry MRO (type, object).
# Compress: name/qualname len=8, mro len=2. Decompress: name/qualname len=10,
# mro len=2. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table zlib_extra18.Compress_Decompress_class_attrs:
  kind: python_call_eq
  category: name_lengths
  id_prefix: cdclsattr18

  columns: [id, function, args, expected]
  rows:
    - [Compress_name,       "compressobj().__class__.__name__.__len__",       [], 8]
    - [Compress_qualname,   "compressobj().__class__.__qualname__.__len__",   [], 8]
    - [Decompress_name,     "decompressobj().__class__.__name__.__len__",     [], 10]
    - [Decompress_qualname, "decompressobj().__class__.__qualname__.__len__", [], 10]
