spec: asyncio_extra49
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queues documentation"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exceptions documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/exceptions.py"
  notes:
    - "This spec extends asyncio_extra48.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths, Semaphore acquire/release __qualname__ string values and lengths, BoundedSemaphore/__name__/__module__/inherited acquire qualname, Condition/__name__/__module__/wait qualname, TaskGroup/__name__/__module__/__bases__[0].__name__, Runner/__name__/__module__, shield/ensure_future/create_task __name__/__module__, get_event_loop/__name__/__module__, get_running_loop/__name__/__module__, new_event_loop/__name__/__module__, run/__name__/__module__, iscoroutine/__name__/__module__, iscoroutinefunction/__name__/__module__, get_event_loop/__qualname__=='get_event_loop', get_running_loop/__qualname__=='get_running_loop', run/__qualname__=='run', sleep/__qualname__=='sleep', gather/__qualname__=='gather', wait/__qualname__=='wait', Queue/Lock/Event __qualname__ string equality, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/TaskGroup __qualname__.__len__(), CancelledError/__qualname__=='CancelledError', TimeoutError/__qualname__=='TimeoutError', TaskGroup/Runner/Task/Future __mro__.__len__(), Semaphore/BoundedSemaphore/Condition/TaskGroup/Runner __qualname__ string equality, Task/__qualname__.__len__()==4, Future/__qualname__.__len__()==6, Runner/__qualname__.__len__()==6 (extra45), Task/__name__=='Task'/__module__=='_asyncio'/__qualname__=='Task', Future/__name__=='Future'/__module__=='_asyncio'/__qualname__=='Future', Task/__bases__[0].__name__=='Future', Task/__module__.__len__()==8, Future/__module__.__len__()==8, Task/__name__.__len__()==4, Future/__name__.__len__()==6 (extra46), Queue/__class__.__name__=='type', Lock/__class__.__name__=='type', Event/__class__.__name__=='type', Semaphore/__class__.__name__=='type', Task/__class__.__name__=='type', Future/__class__.__name__=='type', gather/__class__.__name__=='function', sleep/__class__.__name__=='function', run/__class__.__name__=='function', class __class__.__name__.__len__()==4, function __class__.__name__.__len__()==8 (extra47), Queue/__class__.__qualname__=='type', Lock/__class__.__qualname__=='type', Event/__class__.__qualname__=='type', Semaphore/__class__.__qualname__=='type', Task/__class__.__qualname__=='type', Future/__class__.__qualname__=='type', gather/__class__.__qualname__=='function', sleep/__class__.__qualname__=='function', run/__class__.__qualname__=='function', class __class__.__qualname__.__len__()==4, function __class__.__qualname__.__len__()==8 (extra48)."
    - "This spec covers: QueueEmpty/__class__.__name__=='type'; QueueFull/__class__.__name__=='type'; QueueEmpty/__bases__[0].__name__=='Exception'; QueueFull/__bases__[0].__name__=='Exception'; QueueEmpty/__mro__.__len__()==4; QueueFull/__mro__.__len__()==4; QueueEmpty/__module__=='asyncio.queues'; QueueFull/__module__=='asyncio.queues'; InvalidStateError/__module__=='asyncio.exceptions'; TimeoutError/__module__=='builtins'; CancelledError/__module__=='asyncio.exceptions'."
    - "asyncio.QueueEmpty.__class__.__name__ == 'type'. QueueEmpty is a plain Python exception class defined in asyncio.queues; its metaclass is the built-in 'type'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueFull.__class__.__name__ == 'type'. QueueFull is a plain Python exception class defined in asyncio.queues; its metaclass is the built-in 'type'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception'. QueueEmpty subclasses Exception directly; it does not go through a custom asyncio base class. MRO: [QueueEmpty, Exception, BaseException, object]. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueFull.__bases__[0].__name__ == 'Exception'. QueueFull subclasses Exception directly, same as QueueEmpty. MRO: [QueueFull, Exception, BaseException, object]. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueEmpty.__mro__.__len__() == 4. MRO is [QueueEmpty, Exception, BaseException, object] — four entries. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueFull.__mro__.__len__() == 4. MRO is [QueueFull, Exception, BaseException, object] — four entries. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueEmpty.__module__ == 'asyncio.queues'. QueueEmpty is defined in Lib/asyncio/queues.py, so __module__ reports 'asyncio.queues'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueFull.__module__ == 'asyncio.queues'. QueueFull is defined in Lib/asyncio/queues.py, so __module__ reports 'asyncio.queues'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions'. InvalidStateError is defined in Lib/asyncio/exceptions.py, so __module__ reports 'asyncio.exceptions'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimeoutError.__module__ == 'builtins'. In Python 3.11+, asyncio.TimeoutError is an alias for the built-in TimeoutError; its __module__ is 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.CancelledError.__module__ == 'asyncio.exceptions'. CancelledError is defined in Lib/asyncio/exceptions.py (in Python 3.8+, asyncio.CancelledError was moved to inherit directly from BaseException); its __module__ reports 'asyncio.exceptions'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.QueueEmpty and QueueFull __class__.__name__ — extra49
#
# Both queue exception classes are plain Python classes whose metaclass is
# the built-in 'type':
#   QueueEmpty.__class__.__name__ == 'type'
#   QueueFull.__class__.__name__  == 'type'
# These are consistent with all other asyncio classes captured in extra47.
# ---------------------------------------------------------------------------

table asyncio_extra49.queue_exc_class_name_eq:
  description: "asyncio QueueEmpty and QueueFull __class__.__name__ string equality in extra49 namespace — both are 'type'"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioexc49clsname

  columns: [id, function, args, expected, description]
  rows:
    - [QueueEmpty, QueueEmpty.__class__.__name__.__eq__, ["type"], true, "QueueEmpty.__class__.__name__ == 'type' — plain Python exception class in asyncio.queues; metaclass is built-in 'type'"]
    - [QueueFull,  QueueFull.__class__.__name__.__eq__,  ["type"], true, "QueueFull.__class__.__name__ == 'type' — plain Python exception class in asyncio.queues; metaclass is built-in 'type'"]

# ---------------------------------------------------------------------------
# asyncio.QueueEmpty and QueueFull __bases__[0].__name__ — extra49
#
# Both queue exception classes inherit directly from Exception:
#   QueueEmpty.__bases__[0].__name__ == 'Exception'
#   QueueFull.__bases__[0].__name__  == 'Exception'
# Neither class uses a custom asyncio-specific exception base.
# NOTE: function values contain '[' and therefore MUST be double-quoted per
# ZSDL critical quoting rules for table rows.
# ---------------------------------------------------------------------------

table asyncio_extra49.queue_exc_bases_eq:
  description: "asyncio QueueEmpty and QueueFull __bases__[0].__name__ string equality in extra49 namespace — both directly subclass Exception"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: asyncioexc49bases

  columns: [id, function, args, expected, description]
  rows:
    - [QueueEmpty, "QueueEmpty.__bases__[0].__name__.__eq__", ["Exception"], true, "QueueEmpty.__bases__[0].__name__ == 'Exception' — QueueEmpty subclasses Exception directly; MRO: [QueueEmpty, Exception, BaseException, object]"]
    - [QueueFull,  "QueueFull.__bases__[0].__name__.__eq__",  ["Exception"], true, "QueueFull.__bases__[0].__name__ == 'Exception' — QueueFull subclasses Exception directly; MRO: [QueueFull, Exception, BaseException, object]"]

# ---------------------------------------------------------------------------
# asyncio.QueueEmpty and QueueFull __mro__.__len__() — extra49
#
# Both queue exception classes have MRO depth 4:
#   QueueEmpty.__mro__ == [QueueEmpty, Exception, BaseException, object]
#   QueueFull.__mro__  == [QueueFull, Exception, BaseException, object]
# This is the canonical MRO depth for a simple single-inheritance exception.
# ---------------------------------------------------------------------------

table asyncio_extra49.queue_exc_mro_len:
  description: "asyncio QueueEmpty and QueueFull __mro__.__len__() in extra49 namespace — both == 4"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: asyncioexc49mrolen

  columns: [id, function, args, expected, description]
  rows:
    - [QueueEmpty, QueueEmpty.__mro__.__len__, [], 4, "QueueEmpty.__mro__.__len__() == 4 — MRO: [QueueEmpty, Exception, BaseException, object]"]
    - [QueueFull,  QueueFull.__mro__.__len__,  [], 4, "QueueFull.__mro__.__len__() == 4 — MRO: [QueueFull, Exception, BaseException, object]"]

# ---------------------------------------------------------------------------
# asyncio exception __module__ string equality — extra49
#
# Queue exceptions are defined in asyncio.queues:
#   QueueEmpty.__module__ == 'asyncio.queues'
#   QueueFull.__module__  == 'asyncio.queues'
# Futures/task exceptions are defined in asyncio.exceptions:
#   InvalidStateError.__module__ == 'asyncio.exceptions'
#   CancelledError.__module__    == 'asyncio.exceptions'
# TimeoutError is a built-in alias (Python 3.11+):
#   TimeoutError.__module__ == 'builtins'
# ---------------------------------------------------------------------------

table asyncio_extra49.exc_module_eq:
  description: "asyncio exception __module__ string equality in extra49 namespace — queue exceptions in asyncio.queues, others in asyncio.exceptions or builtins"
  kind: python_call_eq
  category: module_identity
  id_prefix: asyncioexc49module

  columns: [id, function, args, expected, description]
  rows:
    - [QueueEmpty,         QueueEmpty.__module__.__eq__,         ["asyncio.queues"],      true, "QueueEmpty.__module__ == 'asyncio.queues' — defined in Lib/asyncio/queues.py"]
    - [QueueFull,          QueueFull.__module__.__eq__,          ["asyncio.queues"],      true, "QueueFull.__module__ == 'asyncio.queues' — defined in Lib/asyncio/queues.py"]
    - [InvalidStateError,  InvalidStateError.__module__.__eq__,  ["asyncio.exceptions"], true, "InvalidStateError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py"]
    - [CancelledError,     CancelledError.__module__.__eq__,     ["asyncio.exceptions"], true, "CancelledError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py"]
    - [TimeoutError,       TimeoutError.__module__.__eq__,       ["builtins"],            true, "TimeoutError.__module__ == 'builtins' — in Python 3.11+ asyncio.TimeoutError is an alias for the built-in TimeoutError"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra49
# ---------------------------------------------------------------------------

invariant asyncio_extra49.QueueEmpty_class_name_eq:
  description: "asyncio.QueueEmpty.__class__.__name__ == 'type' — plain Python exception class in asyncio.queues; metaclass is built-in 'type'"
  category: class_names
  kind: python_call_eq
  function: QueueEmpty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra49.QueueFull_class_name_eq:
  description: "asyncio.QueueFull.__class__.__name__ == 'type' — plain Python exception class in asyncio.queues; metaclass is built-in 'type'"
  category: class_names
  kind: python_call_eq
  function: QueueFull.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra49.QueueEmpty_bases_eq:
  description: "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception' — QueueEmpty directly subclasses Exception; MRO: [QueueEmpty, Exception, BaseException, object]"
  category: exception_hierarchy
  kind: python_call_eq
  function: "QueueEmpty.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant asyncio_extra49.QueueFull_bases_eq:
  description: "asyncio.QueueFull.__bases__[0].__name__ == 'Exception' — QueueFull directly subclasses Exception; MRO: [QueueFull, Exception, BaseException, object]"
  category: exception_hierarchy
  kind: python_call_eq
  function: "QueueFull.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant asyncio_extra49.QueueEmpty_mro_len:
  description: "asyncio.QueueEmpty.__mro__.__len__() == 4 — MRO: [QueueEmpty, Exception, BaseException, object]"
  category: exception_hierarchy
  kind: python_call_eq
  function: QueueEmpty.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra49.QueueFull_mro_len:
  description: "asyncio.QueueFull.__mro__.__len__() == 4 — MRO: [QueueFull, Exception, BaseException, object]"
  category: exception_hierarchy
  kind: python_call_eq
  function: QueueFull.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra49.QueueEmpty_module_eq:
  description: "asyncio.QueueEmpty.__module__ == 'asyncio.queues' — QueueEmpty is defined in Lib/asyncio/queues.py"
  category: module_identity
  kind: python_call_eq
  function: QueueEmpty.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra49.QueueFull_module_eq:
  description: "asyncio.QueueFull.__module__ == 'asyncio.queues' — QueueFull is defined in Lib/asyncio/queues.py"
  category: module_identity
  kind: python_call_eq
  function: QueueFull.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra49.InvalidStateError_module_eq:
  description: "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' — InvalidStateError is defined in Lib/asyncio/exceptions.py"
  category: module_identity
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra49.TimeoutError_module_eq:
  description: "asyncio.TimeoutError.__module__ == 'builtins' — In Python 3.11+ asyncio.TimeoutError is an alias for the built-in TimeoutError; __module__ reports 'builtins'"
  category: module_identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra49.CancelledError_module_eq:
  description: "asyncio.CancelledError.__module__ == 'asyncio.exceptions' — CancelledError is defined in Lib/asyncio/exceptions.py"
  category: module_identity
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true
