spec: validate_npm_package_name
version: ">=4.0.0"
backend: node(validate-npm-package-name)

docs: https://github.com/npm/validate-npm-package-name#readme

provenance:
  derived_from:
    - "validate-npm-package-name README — https://github.com/npm/validate-npm-package-name#readme"
    - "npm package.json name rules — https://docs.npmjs.com/cli/v9/configuring-npm/package-json#name"
    - "Test vectors verified with validate-npm-package-name via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "validate-npm-package-name source"
  notes:
    - "Validates a string against npm package-name rules — returns {validForNewPackages, validForOldPackages, errors?, warnings?}."
    - "Install: npm install validate-npm-package-name"
    - "v4 CJS; module export IS the function. New packages disallow capitals; old packages tolerated them historically."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; returns a result object rather than throwing."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant validate_npm_package_name.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant validate_npm_package_name.module_arity:
  description: "Module function declared length is 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant validate_npm_package_name.simple_lowercase_valid_for_new:
  description: "'foo' is valid for new packages"
  category: validate
  kind: node_chain_eq
  entry: module
  entry_args: ["foo"]
  chain:
    - {get: validForNewPackages}
  expected: true

invariant validate_npm_package_name.simple_lowercase_valid_for_old:
  description: "'foo' is valid for old packages"
  category: validate
  kind: node_chain_eq
  entry: module
  entry_args: ["foo"]
  chain:
    - {get: validForOldPackages}
  expected: true

invariant validate_npm_package_name.uppercase_invalid_for_new:
  description: "Uppercase 'FOO' is rejected for new packages"
  category: validate
  kind: node_chain_eq
  entry: module
  entry_args: ["FOO"]
  chain:
    - {get: validForNewPackages}
  expected: false

invariant validate_npm_package_name.uppercase_valid_for_old:
  description: "Uppercase 'FOO' is tolerated for old packages"
  category: validate
  kind: node_chain_eq
  entry: module
  entry_args: ["FOO"]
  chain:
    - {get: validForOldPackages}
  expected: true

invariant validate_npm_package_name.leading_hyphen_invalid_new:
  description: "Names starting with '-' are invalid for new packages"
  category: validate
  kind: node_chain_eq
  entry: module
  entry_args: ["-foo"]
  chain:
    - {get: validForNewPackages}
  expected: false

invariant validate_npm_package_name.leading_hyphen_invalid_old:
  description: "Names starting with '-' are invalid for old packages"
  category: validate
  kind: node_chain_eq
  entry: module
  entry_args: ["-foo"]
  chain:
    - {get: validForOldPackages}
  expected: false

invariant validate_npm_package_name.scoped_name_valid:
  description: "Scoped name '@scope/pkg' is valid for new packages"
  category: validate
  kind: node_chain_eq
  entry: module
  entry_args: ["@scope/pkg"]
  chain:
    - {get: validForNewPackages}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:20:12Z
  iterations: 2
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 2 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
