invariant io_extra173.BufferedReader_name_is_BufferedReader:
  description: "io.BufferedReader.__name__ == 'BufferedReader' — BufferedReader is the buffered read-only binary stream class; 'BufferedReader' has 14 characters: 'Buffered' (8) + 'Reader' (6) = 14; BufferedReader is one of three concrete buffered stream classes all sharing the 14-character name length: BufferedReader (14) == BufferedWriter (14) == BufferedRandom (14); the three-way tie arises from the uniform 'Buffered' (8) prefix and the equal-length 6-character suffixes ('Reader', 'Writer', 'Random'); io.BufferedReader wraps a RawIOBase stream and uses a DEFAULT_BUFFER_SIZE (131072 byte) read-ahead buffer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra173.BufferedReader_module_is__io:
  description: "io.BufferedReader.__module__ == '_io' — BufferedReader is implemented in the '_io' C extension module, not in the public 'io' module; '_io' has 3 characters ('_'+'i'+'o'); the public 'io' module (2 chars) re-exports BufferedReader from '_io'; all three concrete buffered I/O classes (BufferedReader, BufferedWriter, BufferedRandom) share __module__ == '_io' (3 chars); the leading underscore in '_io' follows the CPython convention for internal C-extension modules backing a public Python module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra173.BufferedReader_base_is__BufferedIOBase:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — the immediate C-level base of BufferedReader is '_BufferedIOBase' (15 chars, leading underscore); '_BufferedIOBase' (15 chars) > 'BufferedReader' (14 chars) by 1 — the base name is 1 character longer than the derived class; '_BufferedIOBase' is the internal C implementation base; the public io.BufferedIOBase (14 chars, __module__=='io') is the Python-level abstract base accessible via isinstance(); BufferedReader is a subclass of io.BufferedIOBase via MRO despite the direct C-level parent being '_BufferedIOBase'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra173.BufferedWriter_name_is_BufferedWriter:
  description: "io.BufferedWriter.__name__ == 'BufferedWriter' — BufferedWriter is the buffered write-only binary stream class; 'BufferedWriter' has 14 characters: 'Buffered' (8) + 'Writer' (6) = 14; BufferedWriter ties with BufferedReader (14) and BufferedRandom (14) in class name length; 'Writer' (6 chars) == 'Reader' (6 chars) == 'Random' (6 chars): the three concrete buffered class suffixes are all exactly 6 characters; BufferedWriter accumulates writes in a buffer of size DEFAULT_BUFFER_SIZE (131072) and flushes to the underlying raw stream in bulk; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedWriter.__name__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra173.BufferedRandom_base_is__BufferedIOBase_not_BufferedWriter:
  description: "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom inherits directly from '_BufferedIOBase' (15 chars), NOT from BufferedWriter; despite supporting both reading and writing like a combination of BufferedReader and BufferedWriter, BufferedRandom is a sibling of both (not a child of either); all three buffered classes (BufferedReader, BufferedWriter, BufferedRandom) share '_BufferedIOBase' as their immediate C-level parent — a flat C-level hierarchy; '_BufferedIOBase' (15 chars, with underscore) is 1 character longer than 'BufferedRandom' (14 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BufferedRandom.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra173.buffered_trio_name_length_is_14:
  description: "io.BufferedRandom.__name__.__len__() == 14 — 'BufferedRandom' = 'Buffered'(8)+'Random'(6) = 14; the three concrete buffered I/O classes all have exactly 14-character names: BufferedReader (14), BufferedWriter (14), BufferedRandom (14); the three-way tie at 14 is the complete set of concrete buffered I/O classes in the io module; 'Buffered' (8 chars) is the common prefix and the three 6-character suffixes 'Reader', 'Writer', 'Random' produce the uniform 14-character total; 14 == len('BufferedIOBase') as well — the public abstract base class has the same name length as all three concrete subclasses; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__len__
  args: []
  expected: 14

invariant io_extra173.BufferedWriter_base_is__BufferedIOBase:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter's immediate C-level base is '_BufferedIOBase' (15 chars); '_BufferedIOBase' (15) > 'BufferedWriter' (14) by 1: the base name is 1 character longer than the derived class; BufferedReader.__bases__[0].__name__ == BufferedWriter.__bases__[0].__name__ == BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase': all three concrete buffered classes share the same immediate parent; '_BufferedIOBase' (15 chars): '_'(1)+'Buffered'(8)+'IO'(2)+'Base'(4)=15; confirmed Python 3.14.3 macOS"
  category: identity
