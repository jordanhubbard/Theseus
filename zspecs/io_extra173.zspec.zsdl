spec: io_extra173
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.BufferedReader, io.BufferedWriter, and io.BufferedRandom class identity (__name__, __module__, __bases__[0].__name__)."
    - "io.BufferedReader.__name__ == 'BufferedReader' (len=14: 'Buffered'(8)+'Reader'(6)=14)."
    - "io.BufferedReader.__module__ == '_io' (len=3) — all three buffered classes are implemented in the C extension '_io', not the public 'io' module."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' (len=15) — the immediate C-level base class."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' (len=14: 'Buffered'(8)+'Writer'(6)=14)."
    - "io.BufferedWriter.__module__ == '_io' (len=3) — same C extension as BufferedReader."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' (len=15) — same base as BufferedReader."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' (len=14: 'Buffered'(8)+'Random'(6)=14)."
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' (len=15) — all three buffered classes share this C-level base."
    - "Three-way tie in class name length: BufferedReader=BufferedWriter=BufferedRandom=14 characters each."
    - "All three have the 'Buffered' prefix (8 chars) followed by a 6-char suffix: 'Reader', 'Writer', 'Random'."
    - "All three have __module__ == '_io' (3 chars) — the internal C extension, not the public 'io' (2 chars) module."
    - "The public io.BufferedIOBase.__name__ == 'BufferedIOBase' (14 chars, __module__=='io') is the ABC used in isinstance checks, while the direct C-level base is '_BufferedIOBase' (15 chars, with underscore)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader class identity
# __name__ == 'BufferedReader' (len=14), __module__ == '_io' (len=3)
# __bases__[0].__name__ == '_BufferedIOBase' (len=15)
# ---------------------------------------------------------------------------

table io_extra173.BufferedReader_class_identity:
  description: "io.BufferedReader class identity: __name__=='BufferedReader' (len=14), __module__=='_io' (len=3), __bases__[0].__name__=='_BufferedIOBase' (len=15); BufferedReader provides read-ahead buffering for binary streams; all three buffered classes share len=14 names"
  kind: python_call_eq
  category: identity
  id_prefix: iobr173

  columns: [id, function, args, expected, description]
  rows:
    - [br_name,      BufferedReader.__name__.__eq__,                ["BufferedReader"],  true, "io.BufferedReader.__name__ == 'BufferedReader' — BufferedReader is the buffered binary read-only stream class; 'BufferedReader' has 14 characters: 'Buffered' (8) + 'Reader' (6) = 14; BufferedReader provides read-ahead buffering — it reads chunks of size DEFAULT_BUFFER_SIZE (131072 bytes) from the underlying raw stream to avoid repeated system calls; BufferedReader.__name__ (14 chars) is part of a three-way tie with BufferedWriter (14) and BufferedRandom (14) — all three 'Buffered' subclasses have 14-character names formed by the 'Buffered' prefix (8) plus a 6-character suffix ('Reader', 'Writer', 'Random'); confirmed Python 3.14.3 macOS"]
    - [br_module,    BufferedReader.__module__.__eq__,               ["_io"],             true, "io.BufferedReader.__module__ == '_io' — BufferedReader is implemented in the C extension module '_io', not in the public 'io' (2 chars) module; '_io' has 3 characters: '_' + 'i' + 'o'; the leading underscore signals that '_io' is an internal C-extension module not intended for direct import; the public 'io' module (2 chars) re-exports BufferedReader from '_io'; '_io' (3 chars) > 'io' (2 chars) by 1 — the underscore adds one character; all three buffered I/O classes (BufferedReader, BufferedWriter, BufferedRandom) share __module__ == '_io' (3 chars); this contrasts with io.BufferedIOBase.__module__ == 'io' (2 chars) — the abstract base has a different module attribution; confirmed Python 3.14.3 macOS"]
    - [br_base0,     "BufferedReader.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true, "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — the immediate C-level base class of BufferedReader is '_BufferedIOBase' (15 chars, leading underscore); '_BufferedIOBase' has 15 characters: '_' (1) + 'Buffered' (8) + 'IO' (2) + 'Base' (4) = 15; the leading underscore marks '_BufferedIOBase' as the internal C implementation base, distinct from the public io.BufferedIOBase (14 chars, no underscore) which is the Python-level ABC; BufferedReader is a subclass of the public io.BufferedIOBase via MRO (issubclass(io.BufferedReader, io.BufferedIOBase) is True), but the direct C-level parent is '_BufferedIOBase' (15 chars); confirmed Python 3.14.3 macOS"]
    - [br_name_len,  BufferedReader.__name__.__len__,                [],                 14,   "io.BufferedReader.__name__.__len__() == 14 — 'BufferedReader' has 14 characters: 'Buffered' (8) + 'Reader' (6) = 14; the 'Buffered' prefix (8 chars) is the structural constant shared by BufferedReader (14), BufferedWriter (14), and BufferedRandom (14); the suffix 'Reader' (6 chars) equals 'Writer' (6 chars) equals 'Random' (6 chars) in length — all three suffixes are 6 characters, contributing to the three-way name length tie at 14; 'Reader' (6) + 'Writer' (6) + 'Random' (6) = 18 — the combined suffix length for all three classes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.BufferedWriter class identity
# __name__ == 'BufferedWriter' (len=14), __module__ == '_io' (len=3)
# __bases__[0].__name__ == '_BufferedIOBase' (len=15)
# ---------------------------------------------------------------------------

table io_extra173.BufferedWriter_class_identity:
  description: "io.BufferedWriter class identity: __name__=='BufferedWriter' (len=14), __module__=='_io' (len=3), __bases__[0].__name__=='_BufferedIOBase' (len=15); BufferedWriter provides write buffering; shares 14-char name length with BufferedReader and BufferedRandom"
  kind: python_call_eq
  category: identity
  id_prefix: iobw173

  columns: [id, function, args, expected, description]
  rows:
    - [bw_name,      BufferedWriter.__name__.__eq__,                ["BufferedWriter"],  true, "io.BufferedWriter.__name__ == 'BufferedWriter' — BufferedWriter is the buffered binary write-only stream class; 'BufferedWriter' has 14 characters: 'Buffered' (8) + 'Writer' (6) = 14; BufferedWriter accumulates written bytes in an internal buffer (default size DEFAULT_BUFFER_SIZE = 131072 bytes) and flushes to the underlying raw stream in larger chunks; BufferedWriter.__name__ (14 chars) ties with BufferedReader (14) and BufferedRandom (14) — all three formed by 'Buffered' (8) + a 6-char role suffix; 'Writer' (6 chars) and 'Reader' (6 chars) are both 6-character suffixes forming opposite I/O roles; confirmed Python 3.14.3 macOS"]
    - [bw_module,    BufferedWriter.__module__.__eq__,               ["_io"],             true, "io.BufferedWriter.__module__ == '_io' — BufferedWriter is implemented in the '_io' C extension; '_io' has 3 characters; BufferedWriter.__module__ (3 chars: '_io') == BufferedReader.__module__ (3 chars: '_io') == BufferedRandom.__module__ (3 chars: '_io') — all three buffered classes share the same '_io' module attribution; the 3-character module name '_io' is longer than the 2-character public module name 'io' by 1 character (the underscore); the leading underscore in '_io' is the CPython convention for C-extension modules that back public Python modules; BufferedWriter is accessed in user code as io.BufferedWriter, but its __module__ points to the C-level '_io'; confirmed Python 3.14.3 macOS"]
    - [bw_base0,     "BufferedWriter.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true, "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter's immediate C-level base class is '_BufferedIOBase' (15 chars); '_BufferedIOBase' (15 chars) == BufferedReader's direct base (also '_BufferedIOBase') — both read and write buffered classes share the same immediate parent; '_BufferedIOBase' (15 chars) is 1 character longer than 'BufferedWriter' (14 chars) — the base class name is slightly longer than the derived class name; '_BufferedIOBase' (15 chars) > '_io' (3 chars): the base class name is 5 times longer than the module name; BufferedWriter is a subclass of the public io.BufferedIOBase via MRO even though the direct C-level base is '_BufferedIOBase'; confirmed Python 3.14.3 macOS"]
    - [bw_ne_br,     BufferedWriter.__name__.__eq__,                 ["BufferedReader"],  false, "io.BufferedWriter.__name__.__eq__('BufferedReader') == False — 'BufferedWriter' and 'BufferedReader' are distinct class names despite both having 14 characters and the same 'Buffered' prefix (8 chars); the suffixes differ: 'Writer' (6) vs 'Reader' (6) — same length, different string values; BufferedWriter (write-only) and BufferedReader (read-only) are complementary; to do both reading and writing, use BufferedRandom (also 14 chars) which supports seek; BufferedWriter.__name__ (14) == BufferedReader.__name__.__len__() (14) in length but not in value; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.BufferedRandom class identity
# __name__ == 'BufferedRandom' (len=14), __module__ == '_io' (len=3)
# __bases__[0].__name__ == '_BufferedIOBase' (len=15)
# BufferedRandom inherits from _BufferedIOBase directly (not from BufferedWriter)
# ---------------------------------------------------------------------------

table io_extra173.BufferedRandom_class_identity:
  description: "io.BufferedRandom class identity: __name__=='BufferedRandom' (len=14), __module__=='_io' (len=3), __bases__[0].__name__=='_BufferedIOBase' (len=15); BufferedRandom supports read/write/seek; base is _BufferedIOBase (not BufferedWriter)"
  kind: python_call_eq
  category: identity
  id_prefix: ibra173

  columns: [id, function, args, expected, description]
  rows:
    - [bra_name,      BufferedRandom.__name__.__eq__,                ["BufferedRandom"],  true, "io.BufferedRandom.__name__ == 'BufferedRandom' — BufferedRandom is the buffered binary read-write stream class that also supports seeking; 'BufferedRandom' has 14 characters: 'Buffered' (8) + 'Random' (6) = 14; the 'Random' suffix (6 chars) in 'BufferedRandom' refers to random-access (seekable) I/O — the ability to seek to arbitrary positions — not random numbers; BufferedRandom (14) ties with BufferedReader (14) and BufferedWriter (14) in class name length — all three have exactly 14 characters; 'Random' (6 chars) == 'Reader' (6 chars) == 'Writer' (6 chars) in suffix length, producing the three-way tie at 14; confirmed Python 3.14.3 macOS"]
    - [bra_module,    BufferedRandom.__module__.__eq__,               ["_io"],             true, "io.BufferedRandom.__module__ == '_io' — BufferedRandom is implemented in the '_io' C extension; '_io' (3 chars) is the shared module for all three buffered stream classes: BufferedReader, BufferedWriter, and BufferedRandom; '_io' (3 chars) > 'io' (2 chars): the C-extension module name is one character longer than the public module name due to the underscore prefix; BufferedRandom.__module__ (3: '_io') == BufferedReader.__module__ (3: '_io') == BufferedWriter.__module__ (3: '_io') — the module name is uniform across the buffered I/O trio; confirmed Python 3.14.3 macOS"]
    - [bra_base0,     "BufferedRandom.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true, "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom's immediate C-level base class is '_BufferedIOBase' (15 chars), NOT BufferedWriter; despite BufferedRandom supporting both reading and writing, it does NOT inherit from BufferedWriter — it directly extends the same C-level base '_BufferedIOBase' as both BufferedReader and BufferedWriter; all three buffered classes (BufferedReader, BufferedWriter, BufferedRandom) share '_BufferedIOBase' as their direct base — a flat hierarchy at the C level; '_BufferedIOBase' (15 chars) is longer than 'BufferedRandom' (14 chars) by 1 — the base name is 1 character longer than the derived class name; confirmed Python 3.14.3 macOS"]
    - [bra_base0_ne,  "BufferedRandom.__bases__[0].__name__.__eq__",  ["BufferedWriter"],  false, "io.BufferedRandom.__bases__[0].__name__.__eq__('BufferedWriter') == False — BufferedRandom does NOT inherit from BufferedWriter; BufferedRandom.__bases__[0].__name__ is '_BufferedIOBase' (15 chars), not 'BufferedWriter' (14 chars); the design choice to have BufferedRandom extend '_BufferedIOBase' directly (rather than BufferedWriter) avoids the diamond inheritance problem and keeps the C-level hierarchy flat; both BufferedRandom and BufferedWriter inherit from the same '_BufferedIOBase' base — they are sibling classes, not parent-child; this also means BufferedRandom is not a BufferedWriter but isinstance(io.BufferedRandom(...), io.BufferedWriter) is False (only via public abc, not direct class); confirmed Python 3.14.3 macOS"]

