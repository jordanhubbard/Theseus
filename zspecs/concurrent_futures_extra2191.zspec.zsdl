spec: concurrent_futures_extra2191
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "concurrent.futures.Executor defines __enter__ and __exit__ directly in its own __dict__ — Executor IS a sync context manager."
    - "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor do NOT define __enter__ or __exit__ in their own __dict__; they inherit from Executor."
    - "concurrent.futures.Future defines no context manager or lock protocol in its own __dict__."
    - "concurrent.futures.InterpreterPoolExecutor (Python 3.14+) inherits __enter__/__exit__ from Executor via ThreadPoolExecutor; none in own __dict__."
    - "None of the concurrent.futures public classes define __aenter__, __aexit__, acquire, or release."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2191.executor_protocol:
  description: "concurrent.futures.Executor dict-presence — __enter__ and __exit__ defined directly; no async or lock protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2191

  columns: [id, function, args, expected]
  rows:
    - ["cf2191001", "concurrent.futures.Executor.__dict__.__contains__", ["__enter__"], true]
    - ["cf2191002", "concurrent.futures.Executor.__dict__.__contains__", ["__exit__"], true]
    - ["cf2191003", "concurrent.futures.Executor.__dict__.__contains__", ["__aenter__"], false]
    - ["cf2191004", "concurrent.futures.Executor.__dict__.__contains__", ["__aexit__"], false]
    - ["cf2191005", "concurrent.futures.Executor.__dict__.__contains__", ["acquire"], false]
    - ["cf2191006", "concurrent.futures.Executor.__dict__.__contains__", ["release"], false]
    - ["cf2191007", "concurrent.futures.Executor.__dict__.__contains__", ["__wrapped__"], false]
    - ["cf2191008", "concurrent.futures.Executor.__dict__.__contains__", ["__closure__"], false]

table concurrent_futures_extra2191.thread_pool_protocol:
  description: "concurrent.futures.ThreadPoolExecutor dict-presence — __enter__/__exit__ inherited from Executor, not in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2191

  columns: [id, function, args, expected]
  rows:
    - ["cf2191009", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__enter__"], false]
    - ["cf2191010", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__exit__"], false]
    - ["cf2191011", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__aenter__"], false]
    - ["cf2191012", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__aexit__"], false]
    - ["cf2191013", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["acquire"], false]
    - ["cf2191014", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["release"], false]
    - ["cf2191015", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__wrapped__"], false]

