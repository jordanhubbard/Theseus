spec: abc_extra736
version: ">=3.9"
backend: python_module(abc)
docs: "Behavioral spec for abc module-level names and ABC class method identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from: []
  notes: "Covers abc module identity, ABC, ABCMeta, abstractmethod, get_cache_token, and update_abstractmethods qualname and module checks"
  created_at: "2026-04-12"

table abc_extra736.abc_qualnames:
  description: "abc module-level names and ABC class method identity checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: ab736xx
  columns: [id, function, args, expected]
  rows:
    - ["ab736xx001", "abc.__name__.__eq__", ["abc"], true]
    - ["ab736xx002", "abc.__spec__.__name__.__eq__", ["abc"], true]
    - ["ab736xx003", "abc.ABC.__qualname__.__eq__", ["ABC"], true]
    - ["ab736xx004", "abc.ABCMeta.__qualname__.__eq__", ["ABCMeta"], true]
    - ["ab736xx005", "abc.abstractmethod.__qualname__.__eq__", ["abstractmethod"], true]
    - ["ab736xx006", "abc.get_cache_token.__qualname__.__eq__", ["get_cache_token"], true]
    - ["ab736xx007", "abc.get_cache_token.__module__.__eq__", ["abc"], true]
    - ["ab736xx008", "abc.update_abstractmethods.__qualname__.__eq__", ["update_abstractmethods"], true]
    - ["ab736xx009", "abc.update_abstractmethods.__module__.__eq__", ["abc"], true]
    - ["ab736xx010", "abc.ABC.__class__.__name__.__eq__", ["ABCMeta"], true]
    - ["ab736xx011", "abc.ABCMeta.__doc__.__class__.__name__.__eq__", ["str"], true]
    - ["ab736xx012", "abc.abstractmethod.__doc__.__class__.__name__.__eq__", ["str"], true]
