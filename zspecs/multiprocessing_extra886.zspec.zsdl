spec: multiprocessing_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - multiprocessing stdlib documentation
    - CPython Lib/multiprocessing/pool.py
    - CPython Lib/multiprocessing/synchronize.py
  not_derived_from:
    - any third-party multiprocessing replacements
    - pathos or billiard forks
  notes:
    - Covers Pool async methods and synchronize.Barrier/Lock/RLock qualnames and module attrs
    - Barrier qualname is bare 'Barrier' (class-level) not 'Barrier.__class__'
    - Stable across CPython 3.9+
  created_at: "2026-04-12"

table multiprocessing_extra886.pool_sync_qualnames:
  description: Verify __qualname__ and __module__ strings for multiprocessing.pool.Pool async methods and synchronize primitives
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: mp886xx
  columns: [id, function, args, expected]
  rows:
    - [mp886xx001, multiprocessing.pool.Pool.map_async.__qualname__.__eq__, ["Pool.map_async"], true]
    - [mp886xx002, multiprocessing.pool.Pool.starmap_async.__qualname__.__eq__, ["Pool.starmap_async"], true]
    - [mp886xx003, multiprocessing.pool.Pool.imap.__qualname__.__eq__, ["Pool.imap"], true]
    - [mp886xx004, multiprocessing.pool.Pool.imap_unordered.__qualname__.__eq__, ["Pool.imap_unordered"], true]
    - [mp886xx005, multiprocessing.synchronize.Barrier.__qualname__.__eq__, ["Barrier"], true]
    - [mp886xx006, multiprocessing.synchronize.Barrier.__module__.__eq__, ["multiprocessing.synchronize"], true]
    - [mp886xx007, multiprocessing.synchronize.Barrier.__init__.__qualname__.__eq__, ["Barrier.__init__"], true]
    - [mp886xx008, multiprocessing.synchronize.Barrier.wait.__qualname__.__eq__, ["Barrier.wait"], true]
    - [mp886xx009, multiprocessing.synchronize.Barrier.reset.__qualname__.__eq__, ["Barrier.reset"], true]
    - [mp886xx010, multiprocessing.synchronize.Barrier.abort.__qualname__.__eq__, ["Barrier.abort"], true]
    - [mp886xx011, multiprocessing.synchronize.Lock.__init__.__qualname__.__eq__, ["Lock.__init__"], true]
    - [mp886xx012, multiprocessing.synchronize.RLock.__init__.__qualname__.__eq__, ["RLock.__init__"], true]
