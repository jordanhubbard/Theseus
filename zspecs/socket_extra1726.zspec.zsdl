spec: socket_extra1726
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "socket.socket is a Python class wrapping a file descriptor; it defines no comparison or ordering operators."
    - "socket.socket.__dict__.__contains__('__lt__') is False — socket objects have no ordering semantics."
    - "socket.socket.__dict__.__contains__('__eq__') is False — socket objects are not equality-comparable by value."
    - "socket.socket.__dict__.__contains__('__hash__') is False — socket objects are not hashable by default."
    - "socket.error is an alias for OSError; comparison methods are inherited from Exception/BaseException, not defined in socket.error's own __dict__."
    - "socket.timeout is a subclass of OSError; same inheritance applies — no comparison dunders in its own __dict__."
    - "None of __lt__, __le__, __gt__, __ge__, __ne__, __eq__, or __hash__ appear in socket.socket's own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra1726.comparison_protocol:
  description: "socket types comparison/ordering dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1726

  columns: [id, function, args, expected]
  rows:
    - ["sk1726001", "socket.socket.__dict__.__contains__", ["__lt__"], false]
    - ["sk1726002", "socket.socket.__dict__.__contains__", ["__le__"], false]
    - ["sk1726003", "socket.socket.__dict__.__contains__", ["__gt__"], false]
    - ["sk1726004", "socket.socket.__dict__.__contains__", ["__ge__"], false]
    - ["sk1726005", "socket.socket.__dict__.__contains__", ["__ne__"], false]
    - ["sk1726006", "socket.timeout.__dict__.__contains__", ["__lt__"], false]
    - ["sk1726007", "socket.timeout.__dict__.__contains__", ["__le__"], false]
    - ["sk1726008", "socket.timeout.__dict__.__contains__", ["__gt__"], false]
    - ["sk1726009", "socket.timeout.__dict__.__contains__", ["__ge__"], false]
    - ["sk1726010", "socket.timeout.__dict__.__contains__", ["__ne__"], false]

table socket_extra1726.eq_hash_protocol:
  description: "socket types __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1726

  columns: [id, function, args, expected]
  rows:
    - ["sk1726011", "socket.socket.__dict__.__contains__", ["__eq__"], false]
    - ["sk1726012", "socket.socket.__dict__.__contains__", ["__hash__"], false]
    - ["sk1726013", "socket.timeout.__dict__.__contains__", ["__eq__"], false]
    - ["sk1726014", "socket.timeout.__dict__.__contains__", ["__hash__"], false]
