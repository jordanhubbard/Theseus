spec: ft3226
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (ft3226): __radd__, __rsub__, __rmul__ dict-presence checks for functools types."
    - "Theme: __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic operators)."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — these types have no reflected arithmetic protocol."
    - "None of the four functools types define __radd__, __rsub__, or __rmul__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3226.radd:
  description: "functools types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3226
  columns: [id, function, args, expected]
  rows:
    - ["ft3226001", operator.contains, [functools.partial.__dict__,                              "__radd__"], false]
    - ["ft3226002", operator.contains, [functools.partialmethod.__dict__,                        "__radd__"], false]
    - ["ft3226003", operator.contains, [functools.cached_property.__dict__,                      "__radd__"], false]
    - ["ft3226004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,        "__radd__"], false]

