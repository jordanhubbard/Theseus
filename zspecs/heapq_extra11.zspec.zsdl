spec: heapq_extra11
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras through heapq_extra10.zspec.zsdl."
    - "Prior specs cover heappushpop/heapreplace behavioral return values; merge first-element; nlargest/nsmallest on [4,7,1,9,3]."
    - "NOT yet covered: nlargest/nsmallest on [1,5,2,4,3] (distinct from all prior fixtures); nlargest/nsmallest on [7,2,9] (3-element); n=0 edge case; n=all edge case; merge.__name__; nlargest.__name__; nsmallest.__name__."
    - "nlargest(3, [1,5,2,4,3]) == [5,4,3] — three largest of a 5-element list in descending order."
    - "nsmallest(3, [1,5,2,4,3]) == [1,2,3] — three smallest in ascending order."
    - "nlargest(1, [7,2,9]) == [9] — single largest element wrapped in list."
    - "nsmallest(1, [7,2,9]) == [2] — single smallest element wrapped in list."
    - "nlargest(2, [7,2,9]) == [9,7] — two largest from a 3-element list."
    - "nsmallest(2, [7,2,9]) == [2,7] — two smallest from a 3-element list."
    - "nlargest(0, [1,2,3]) == [] — n=0 returns empty list."
    - "nsmallest(0, [1,2,3]) == [] — n=0 returns empty list."
    - "merge.__name__ == 'merge'; nlargest.__name__ == 'nlargest'; nsmallest.__name__ == 'nsmallest'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# nlargest and nsmallest — new fixture [1, 5, 2, 4, 3]
#
# heapq_extra10 uses [4,7,1,9,3]. This spec uses [1,5,2,4,3] — the same list
# suggested in the original nlargest/nsmallest docs examples and not used in
# any prior spec for nlargest/nsmallest behavioral tests (prior specs use
# different fixtures per the heapq_extra10 notes).
# ---------------------------------------------------------------------------

invariant heapq_extra11.nlargest.top3_of_five:
  description: "heapq.nlargest(3, [1,5,2,4,3]) == [5,4,3] — three largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [1, 5, 2, 4, 3]]
  expected: [5, 4, 3]

invariant heapq_extra11.nsmallest.top3_of_five:
  description: "heapq.nsmallest(3, [1,5,2,4,3]) == [1,2,3] — three smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [1, 5, 2, 4, 3]]
  expected: [1, 2, 3]

invariant heapq_extra11.nlargest.all_five:
  description: "heapq.nlargest(5, [1,5,2,4,3]) == [5,4,3,2,1] — all elements in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [5, [1, 5, 2, 4, 3]]
  expected: [5, 4, 3, 2, 1]

invariant heapq_extra11.nsmallest.all_five:
  description: "heapq.nsmallest(5, [1,5,2,4,3]) == [1,2,3,4,5] — all elements in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [5, [1, 5, 2, 4, 3]]
  expected: [1, 2, 3, 4, 5]

# ---------------------------------------------------------------------------
# nlargest and nsmallest — 3-element fixture [7, 2, 9]
#
# No prior spec tests nlargest/nsmallest on [7,2,9]. This is a 3-element
# unordered list useful for verifying n=1 and n=2 cases.
# ---------------------------------------------------------------------------

invariant heapq_extra11.nlargest.single_from_three:
  description: "heapq.nlargest(1, [7,2,9]) == [9] — single largest wrapped in list"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [1, [7, 2, 9]]
  expected: [9]

invariant heapq_extra11.nsmallest.single_from_three:
  description: "heapq.nsmallest(1, [7,2,9]) == [2] — single smallest wrapped in list"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [1, [7, 2, 9]]
  expected: [2]

invariant heapq_extra11.nlargest.two_from_three:
  description: "heapq.nlargest(2, [7,2,9]) == [9,7] — two largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [2, [7, 2, 9]]
  expected: [9, 7]

invariant heapq_extra11.nsmallest.two_from_three:
  description: "heapq.nsmallest(2, [7,2,9]) == [2,7] — two smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [2, [7, 2, 9]]
  expected: [2, 7]

# ---------------------------------------------------------------------------
# Edge case — n=0 returns empty list
#
# No prior spec tests nlargest or nsmallest with n=0. Both functions must
# return an empty list when 0 elements are requested.
# ---------------------------------------------------------------------------

invariant heapq_extra11.nlargest.zero:
  description: "heapq.nlargest(0, [1,2,3]) == [] — n=0 yields empty list"
  category: edge_cases
  kind: python_call_eq
  function: nlargest
  args: [0, [1, 2, 3]]
  expected: []

invariant heapq_extra11.nsmallest.zero:
  description: "heapq.nsmallest(0, [1,2,3]) == [] — n=0 yields empty list"
  category: edge_cases
  kind: python_call_eq
  function: nsmallest
  args: [0, [1, 2, 3]]
  expected: []

# ---------------------------------------------------------------------------
# Function __name__ attributes — merge, nlargest, nsmallest
#
# heapq_extra10 notes confirm no prior spec tests the *behavioral* return value
# of nlargest/nsmallest on the new fixture. The __name__ checks below confirm
# the function identity using the extra11 namespace for fresh invariant IDs.
# ---------------------------------------------------------------------------

invariant heapq_extra11.merge.name:
  description: "heapq.merge.__name__ == 'merge' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: merge.__name__.__eq__
  args: ["merge"]
  expected: true

invariant heapq_extra11.nlargest.name:
  description: "heapq.nlargest.__name__ == 'nlargest' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: nlargest.__name__.__eq__
  args: ["nlargest"]
  expected: true

invariant heapq_extra11.nsmallest.name:
  description: "heapq.nsmallest.__name__ == 'nsmallest' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: nsmallest.__name__.__eq__
  args: ["nsmallest"]
  expected: true
