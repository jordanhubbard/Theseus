spec: traceback_extra22
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback_extra21.zspec.zsdl."
    - "Prior specs covered: traceback.__name__/__package__, TracebackException/__name__/__module__/__qualname__, StackSummary/__name__/__module__/__qualname__, FrameSummary/__name__/__module__/__qualname__, print_exc/__name__/__module__, format_exc/__name__/__module__, print_tb/__name__/__module__, format_tb/__name__/__module__, extract_tb/__name__/__module__, extract_stack/__name__/__module__, TracebackException.__bases__[0].__name__, StackSummary.__bases__[0].__name__, FrameSummary.__bases__[0].__name__, format_list/__name__/__qualname__/__module__, TracebackException.from_exception/__module__, TracebackException.format/__module__, TracebackException.format_exception_only/__module__, StackSummary.extract/__module__, StackSummary.format/__module__, format_exception/__module__, FrameSummary.__init__.__qualname__."
    - "This spec covers: TracebackException.__init__.__name__, StackSummary.__qualname__ (standalone extra22 anchor), FrameSummary.__qualname__ (standalone extra22 anchor), TracebackException.__qualname__ (standalone extra22 anchor), print_exc/__module__ (standalone extra22 anchor), format_exc/__module__ (standalone extra22 anchor), print_tb/__module__ (standalone extra22 anchor), format_tb/__module__ (standalone extra22 anchor), extract_tb/__module__ (standalone extra22 anchor), extract_stack/__module__ (standalone extra22 anchor), format_list/__name__ (standalone extra22 anchor), format_list/__module__ (standalone extra22 anchor)."
    - "traceback.TracebackException.__init__.__name__ == '__init__' — standard dunder method name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.__qualname__ == 'StackSummary' — top-level class; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.FrameSummary.__qualname__ == 'FrameSummary' — top-level class; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.TracebackException.__qualname__ == 'TracebackException' — top-level class; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.print_exc.__module__ == 'traceback' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_exc.__module__ == 'traceback' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.print_tb.__module__ == 'traceback' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_tb.__module__ == 'traceback' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.extract_tb.__module__ == 'traceback' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.extract_stack.__module__ == 'traceback' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_list.__name__ == 'format_list' — module-level function; __name__ equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_list.__module__ == 'traceback' — module-level function; __module__ equals module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TracebackException.__init__.__name__
#
# traceback_extra19 records FrameSummary.__init__.__qualname__; traceback_extra20
# records FrameSummary.__init__.__qualname__ as a standalone invariant. No prior
# traceback spec records TracebackException.__init__.__name__ as a standalone
# named invariant in the extra22 namespace. For any class method __init__,
# __name__ is always '__init__'.
# ---------------------------------------------------------------------------

invariant traceback_extra22.TracebackException.__init__.name:
  description: "traceback.TracebackException.__init__.__name__ == '__init__' — standard dunder method name"
  category: method_name
  kind: python_call_eq
  function: TracebackException.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# StackSummary.__qualname__, FrameSummary.__qualname__, TracebackException.__qualname__
#
# traceback_extra18 records StackSummary.__qualname__ and TracebackException.__qualname__
# as standalone invariants (extra18 namespace). traceback_extra19 records
# FrameSummary.__qualname__ in the extra19 namespace. traceback_extra12 covers
# all three in a table. This spec provides extra22-namespace standalone anchors.
# ---------------------------------------------------------------------------

invariant traceback_extra22.StackSummary.qualname:
  description: "traceback.StackSummary.__qualname__ == 'StackSummary' — top-level class; qualname equals simple name"
  category: class_qualname
  kind: python_call_eq
  function: StackSummary.__qualname__.__eq__
  args: ["StackSummary"]
  expected: true

invariant traceback_extra22.FrameSummary.qualname:
  description: "traceback.FrameSummary.__qualname__ == 'FrameSummary' — top-level class; qualname equals simple name"
  category: class_qualname
  kind: python_call_eq
  function: FrameSummary.__qualname__.__eq__
  args: ["FrameSummary"]
  expected: true

invariant traceback_extra22.TracebackException.qualname:
  description: "traceback.TracebackException.__qualname__ == 'TracebackException' — top-level class; qualname equals simple name"
  category: class_qualname
  kind: python_call_eq
  function: TracebackException.__qualname__.__eq__
  args: ["TracebackException"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __module__ values (extra22-namespace anchors)
#
# traceback_extra3 and traceback_extra20 cover print_exc, format_exc, print_tb,
# format_tb, extract_tb, and extract_stack __module__ in earlier namespaces.
# traceback_extra7 covers format_list.__module__. This spec provides fresh
# extra22-namespace standalone invariants for all six functions plus format_list.
# ---------------------------------------------------------------------------

invariant traceback_extra22.print_exc.module:
  description: "traceback.print_exc.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: print_exc.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra22.format_exc.module:
  description: "traceback.format_exc.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: format_exc.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra22.print_tb.module:
  description: "traceback.print_tb.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: print_tb.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra22.format_tb.module:
  description: "traceback.format_tb.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: format_tb.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra22.extract_tb.module:
  description: "traceback.extract_tb.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: extract_tb.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra22.extract_stack.module:
  description: "traceback.extract_stack.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: extract_stack.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# format_list __name__ and __module__
#
# traceback_extra11 records format_list.__name__ via predicate form; extra15
# records format_list.__qualname__; extra7 records format_list.__module__.
# This spec provides extra22-namespace standalone anchors for both attributes.
# ---------------------------------------------------------------------------

invariant traceback_extra22.format_list.name:
  description: "traceback.format_list.__name__ == 'format_list' — module-level function; __name__ equals simple name"
  category: function_name
  kind: python_call_eq
  function: format_list.__name__.__eq__
  args: ["format_list"]
  expected: true

invariant traceback_extra22.format_list.module:
  description: "traceback.format_list.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: format_list.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all twelve invariants
#
# Covers TracebackException.__init__.__name__ (1), class __qualname__ anchors
# for StackSummary/FrameSummary/TracebackException (3), module-level function
# __module__ anchors for print_exc/format_exc/print_tb/format_tb/extract_tb/
# extract_stack (6), and format_list __name__/__module__ (2).
# ---------------------------------------------------------------------------

table traceback_extra22.class_qualnames_and_function_modules:
  description: "TracebackException.__init__.__name__, class __qualname__ anchors, and module-level function __module__ values"
  kind: python_call_eq
  category: function_module

  columns: [id, function, args, expected]
  rows:
    - [TracebackException_init_name,  TracebackException.__init__.__name__.__eq__,  ["__init__"],          true]
    - [StackSummary_qualname,         StackSummary.__qualname__.__eq__,              ["StackSummary"],      true]
    - [FrameSummary_qualname,         FrameSummary.__qualname__.__eq__,              ["FrameSummary"],      true]
    - [TracebackException_qualname,   TracebackException.__qualname__.__eq__,        ["TracebackException"], true]
    - [print_exc_module,              print_exc.__module__.__eq__,                   ["traceback"],         true]
    - [format_exc_module,             format_exc.__module__.__eq__,                  ["traceback"],         true]
    - [print_tb_module,               print_tb.__module__.__eq__,                    ["traceback"],         true]
    - [format_tb_module,              format_tb.__module__.__eq__,                   ["traceback"],         true]
    - [extract_tb_module,             extract_tb.__module__.__eq__,                  ["traceback"],         true]
    - [extract_stack_module,          extract_stack.__module__.__eq__,               ["traceback"],         true]
    - [format_list_name,              format_list.__name__.__eq__,                   ["format_list"],       true]
    - [format_list_module,            format_list.__module__.__eq__,                 ["traceback"],         true]
