spec: itertools_extra2026
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__/__rtruediv__/__itruediv__, __floordiv__/__rfloordiv__/__ifloordiv__, __mod__/__rmod__/__imod__, __pow__/__rpow__, __divmod__/__rdivmod__ dict-presence checks."
    - "itertools C-level iterator types are not arithmetic types — none define division, modulo, exponentiation, or divmod operators."
    - "itertools.count: C-level infinite counter type — division/modulo/pow/divmod dunders absent from __dict__."
    - "itertools.cycle: C-level infinite cycling type — division/modulo/pow/divmod dunders absent from __dict__."
    - "itertools.chain: C-level chaining type — division/modulo/pow/divmod dunders absent from __dict__."
    - "itertools.islice: C-level slicing type — division/modulo/pow/divmod dunders absent from __dict__."
    - "itertools.zip_longest: C-level zipping type — division/modulo/pow/divmod dunders absent from __dict__."
    - "itertools.product: C-level Cartesian product type — division/modulo/pow/divmod dunders absent from __dict__."
    - "itertools.combinations: C-level combinatoric type — division/modulo/pow/divmod dunders absent from __dict__."
    - "itertools.permutations: C-level permutation type — division/modulo/pow/divmod dunders absent from __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __truediv__ / __rtruediv__ / __itruediv__ dict-presence
#
# itertools iterator types are pure iteration machinery; they carry no numeric
# semantics and define no true-division operators in their __dict__.
# Types covered: count, cycle, chain, islice.
# All checks expected False.
# ---------------------------------------------------------------------------

table itertools_extra2026.truediv_protocol:
  description: "itertools C-types __truediv__/__rtruediv__/__itruediv__ dict-presence checks — all False — wave 582 _extra2026"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2026

  columns: [id, function, args, expected]
  rows:
    - ["it2026001", "itertools.count.__dict__.__contains__", ["__truediv__"], false]
    - ["it2026002", "itertools.count.__dict__.__contains__", ["__rtruediv__"], false]
    - ["it2026003", "itertools.count.__dict__.__contains__", ["__itruediv__"], false]
    - ["it2026004", "itertools.cycle.__dict__.__contains__", ["__truediv__"], false]
    - ["it2026005", "itertools.cycle.__dict__.__contains__", ["__rtruediv__"], false]
    - ["it2026006", "itertools.cycle.__dict__.__contains__", ["__itruediv__"], false]
    - ["it2026007", "itertools.chain.__dict__.__contains__", ["__truediv__"], false]
    - ["it2026008", "itertools.chain.__dict__.__contains__", ["__rtruediv__"], false]
    - ["it2026009", "itertools.chain.__dict__.__contains__", ["__itruediv__"], false]
    - ["it2026010", "itertools.islice.__dict__.__contains__", ["__truediv__"], false]
    - ["it2026011", "itertools.islice.__dict__.__contains__", ["__rtruediv__"], false]
    - ["it2026012", "itertools.islice.__dict__.__contains__", ["__itruediv__"], false]

