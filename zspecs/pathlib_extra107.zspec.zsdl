spec: pathlib_extra107
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra106

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra106.zspec.zsdl."
    - "This spec covers: pathlib.Path method __qualname__ values and lengths for I/O and filesystem methods: open, read_text, write_text, read_bytes, mkdir, stat, exists, iterdir, glob, is_file, is_dir."
    - "All pathlib.Path methods are Python functions (not C descriptors); their __class__.__name__ == 'function'."
    - "pathlib.Path.open.__qualname__ = 'Path.open' (length 9)."
    - "pathlib.Path.read_text.__qualname__ = 'Path.read_text' (length 14)."
    - "pathlib.Path.write_text.__qualname__ = 'Path.write_text' (length 15)."
    - "pathlib.Path.read_bytes.__qualname__ = 'Path.read_bytes' (length 15; same length as write_text)."
    - "pathlib.Path.mkdir.__qualname__ = 'Path.mkdir' (length 10)."
    - "pathlib.Path.stat.__qualname__ = 'Path.stat' (length 9; same length as open)."
    - "pathlib.Path.exists.__qualname__ = 'Path.exists' (length 11)."
    - "pathlib.Path.iterdir.__qualname__ = 'Path.iterdir' (length 12)."
    - "pathlib.Path.glob.__qualname__ = 'Path.glob' (length 9; same length as open and stat)."
    - "pathlib.Path.is_file.__qualname__ = 'Path.is_file' (length 12; same length as iterdir)."
    - "pathlib.Path.is_dir.__qualname__ = 'Path.is_dir' (length 11; same length as exists)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path I/O method __qualname__ values and lengths
# open, read_text, write_text, read_bytes are the primary file content methods.
# All are Python functions with qualname 'Path.method_name'.
# ---------------------------------------------------------------------------

table pathlib_extra107.Path_io_method_qualnames:
  description: "pathlib.Path I/O method __qualname__ values and lengths: open (9), read_text (14), write_text (15), read_bytes (15)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibpathmeth107

  columns: [id, function, args, expected, description]
  rows:
    - [open_qn,      Path.open.__qualname__.__eq__,        ["Path.open"],       true, "Path.open.__qualname__ == 'Path.open'"]
    - [open_qn_len,  Path.open.__qualname__.__len__,       [],                  9,    "Path.open.__qualname__.__len__() == 9 ('Path.open' has 9 characters)"]
    - [rt_qn,        Path.read_text.__qualname__.__eq__,   ["Path.read_text"],  true, "Path.read_text.__qualname__ == 'Path.read_text'"]
    - [rt_qn_len,    Path.read_text.__qualname__.__len__,  [],                  14,   "Path.read_text.__qualname__.__len__() == 14 ('Path.read_text' has 14 characters)"]
    - [wt_qn,        Path.write_text.__qualname__.__eq__,  ["Path.write_text"], true, "Path.write_text.__qualname__ == 'Path.write_text'"]
    - [wt_qn_len,    Path.write_text.__qualname__.__len__, [],                  15,   "Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 characters)"]
    - [rb_qn,        Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"], true, "Path.read_bytes.__qualname__ == 'Path.read_bytes'"]
    - [rb_qn_len,    Path.read_bytes.__qualname__.__len__, [],                  15,   "Path.read_bytes.__qualname__.__len__() == 15 ('Path.read_bytes' has 15 characters; same length as write_text)"]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem query method __qualname__ values and lengths
# mkdir, stat, exists, iterdir, glob, is_file, is_dir.
# All are Python functions with qualname 'Path.method_name'.
# ---------------------------------------------------------------------------

table pathlib_extra107.Path_filesystem_method_qualnames:
  description: "pathlib.Path filesystem method __qualname__ values and lengths: mkdir (10), stat (9), exists (11), iterdir (12), glob (9), is_file (12), is_dir (11)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibpathmeth107

  columns: [id, function, args, expected, description]
  rows:
    - [mkdir_qn,      Path.mkdir.__qualname__.__eq__,    ["Path.mkdir"],    true, "Path.mkdir.__qualname__ == 'Path.mkdir'"]
    - [mkdir_qn_len,  Path.mkdir.__qualname__.__len__,   [],                10,   "Path.mkdir.__qualname__.__len__() == 10 ('Path.mkdir' has 10 characters)"]
    - [stat_qn,       Path.stat.__qualname__.__eq__,     ["Path.stat"],     true, "Path.stat.__qualname__ == 'Path.stat'"]
    - [stat_qn_len,   Path.stat.__qualname__.__len__,    [],                9,    "Path.stat.__qualname__.__len__() == 9 ('Path.stat' has 9 characters; same length as Path.open and Path.glob)"]
    - [exists_qn,     Path.exists.__qualname__.__eq__,   ["Path.exists"],   true, "Path.exists.__qualname__ == 'Path.exists'"]
    - [exists_qn_len, Path.exists.__qualname__.__len__,  [],                11,   "Path.exists.__qualname__.__len__() == 11 ('Path.exists' has 11 characters)"]
    - [iterdir_qn,    Path.iterdir.__qualname__.__eq__,  ["Path.iterdir"],  true, "Path.iterdir.__qualname__ == 'Path.iterdir'"]
    - [iterdir_len,   Path.iterdir.__qualname__.__len__, [],                12,   "Path.iterdir.__qualname__.__len__() == 12 ('Path.iterdir' has 12 characters)"]
    - [glob_qn,       Path.glob.__qualname__.__eq__,     ["Path.glob"],     true, "Path.glob.__qualname__ == 'Path.glob'"]
    - [glob_qn_len,   Path.glob.__qualname__.__len__,    [],                9,    "Path.glob.__qualname__.__len__() == 9 ('Path.glob' has 9 characters; same as Path.open and Path.stat)"]
    - [isfile_qn,     Path.is_file.__qualname__.__eq__,  ["Path.is_file"],  true, "Path.is_file.__qualname__ == 'Path.is_file'"]
    - [isfile_qn_len, Path.is_file.__qualname__.__len__, [],                12,   "Path.is_file.__qualname__.__len__() == 12 ('Path.is_file' has 12 characters; same length as iterdir)"]
    - [isdir_qn,      Path.is_dir.__qualname__.__eq__,   ["Path.is_dir"],   true, "Path.is_dir.__qualname__ == 'Path.is_dir'"]
    - [isdir_qn_len,  Path.is_dir.__qualname__.__len__,  [],                11,   "Path.is_dir.__qualname__.__len__() == 11 ('Path.is_dir' has 11 characters; same length as exists)"]

# ---------------------------------------------------------------------------
# pathlib.Path method class names
# All Path methods are Python functions (not C extension descriptors).
# ---------------------------------------------------------------------------

table pathlib_extra107.Path_method_class_names:
  description: "pathlib.Path methods are Python functions (not C descriptors), so __class__.__name__ == 'function'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: pathlibpathmeth107

  columns: [id, function, args, expected, description]
  rows:
    - [open_cls,    Path.open.__class__.__name__.__eq__,    ["function"], true,  "Path.open.__class__.__name__ == 'function' (Python-defined method)"]
    - [mkdir_cls,   Path.mkdir.__class__.__name__.__eq__,   ["function"], true,  "Path.mkdir.__class__.__name__ == 'function'"]
    - [exists_cls,  Path.exists.__class__.__name__.__eq__,  ["function"], true,  "Path.exists.__class__.__name__ == 'function'"]
    - [glob_cls,    Path.glob.__class__.__name__.__eq__,    ["function"], true,  "Path.glob.__class__.__name__ == 'function'"]
    - [isfile_cls,  Path.is_file.__class__.__name__.__eq__, ["function"], true,  "Path.is_file.__class__.__name__ == 'function'"]
    - [open_not_md, Path.open.__class__.__name__.__eq__,    ["method_descriptor"], false, "Path.open.__class__.__name__ is NOT 'method_descriptor' (Path methods are Python functions, not C extension descriptors)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra107.Path.open_qualname:
  description: "pathlib.Path.open.__qualname__ == 'Path.open' (Path I/O methods have the 'Path.method_name' qualname pattern; 'Path.open' is 9 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

invariant pathlib_extra107.Path.write_text_qualname_len:
  description: "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 characters; same length as 'Path.read_bytes')"
  category: method_qualnames
  kind: python_call_eq
  function: Path.write_text.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra107.Path.iterdir_qualname_len:
  description: "pathlib.Path.iterdir.__qualname__.__len__() == 12 ('Path.iterdir' has 12 characters; same length as 'Path.is_file')"
  category: method_qualnames
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__len__
  args: []
  expected: 12

invariant pathlib_extra107.Path.is_dir_qualname_len:
  description: "pathlib.Path.is_dir.__qualname__.__len__() == 11 ('Path.is_dir' has 11 characters; same length as 'Path.exists')"
  category: method_qualnames
  kind: python_call_eq
  function: Path.is_dir.__qualname__.__len__
  args: []
  expected: 11

invariant pathlib_extra107.Path.open_is_function:
  description: "pathlib.Path.open.__class__.__name__ == 'function' (pathlib.Path methods are pure Python implementations, not C extension descriptors)"
  category: method_class_names
  kind: python_call_eq
  function: Path.open.__class__.__name__.__eq__
  args: ["function"]
  expected: true

