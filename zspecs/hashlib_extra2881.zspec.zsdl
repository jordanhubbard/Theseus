spec: hl2881
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 639 (_extra2881): __iadd__, __isub__, __imul__ dict-presence checks for hashlib types."
    - "hashlib exposes two HASH-family types: _hashlib.HASH (used by md5, sha1, sha256, sha512, etc.) and _hashlib.HASHXOF (used by shake_128, shake_256)."
    - "hashlib also exposes hashlib.blake2b and hashlib.blake2s as first-class C-level types."
    - "None of these types define in-place augmented assignment operators (__iadd__, __isub__, __imul__) in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl2881.iadd:
  description: "hashlib types __iadd__ dict-presence checks; wave 639"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2881
  columns: [id, function, args, expected]
  rows:
    - ["hl2881001", "type(hashlib.md5()).__dict__.__contains__",       ["__iadd__"], false]
    - ["hl2881002", "type(hashlib.sha256()).__dict__.__contains__",    ["__iadd__"], false]
    - ["hl2881003", "type(hashlib.sha3_256()).__dict__.__contains__",  ["__iadd__"], false]
    - ["hl2881004", "hashlib.blake2b.__dict__.__contains__",           ["__iadd__"], false]
    - ["hl2881005", "hashlib.blake2s.__dict__.__contains__",           ["__iadd__"], false]
    - ["hl2881006", "type(hashlib.new('md5')).__dict__.__contains__",  ["__iadd__"], false]

