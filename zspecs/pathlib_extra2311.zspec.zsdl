spec: pathlib_extra2311
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content checks."
    - "pathlib classes (PurePath, Path, PurePosixPath, PureWindowsPath, PosixPath) are not abstract."
    - "None of the pathlib public classes have __abstractmethods__ in their own __dict__."
    - "Accessing .__abstractmethods__ on any pathlib class raises AttributeError because neither the class itself nor any class in its MRO provides the attribute."
    - "In older Python 3.x pathlib had abstract internal classes, but the public API has never exposed __abstractmethods__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ dict-presence for pathlib classes
#
# None of the public pathlib classes set __abstractmethods__ in their own
# __dict__.  Expected: False for all.
# ---------------------------------------------------------------------------

table pathlib_extra2311.abstract_absence:
  description: "pathlib classes have no __abstractmethods__ in class __dict__ — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2311

  columns: [id, function, args, expected]
  rows:
    - ["pp2311001", "pathlib.PurePath.__dict__.__contains__",        ["__abstractmethods__"], false]
    - ["pp2311002", "pathlib.Path.__dict__.__contains__",            ["__abstractmethods__"], false]
    - ["pp2311003", "pathlib.PurePosixPath.__dict__.__contains__",   ["__abstractmethods__"], false]
    - ["pp2311004", "pathlib.PureWindowsPath.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["pp2311005", "pathlib.PosixPath.__dict__.__contains__",       ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__.__len__ raises AttributeError
#
# Because __abstractmethods__ is absent from each class dict and no base
# in the MRO supplies it, accessing .__abstractmethods__ raises AttributeError.
# Chained calls like .__abstractmethods__.__len__ therefore also raise.
# ---------------------------------------------------------------------------

table pathlib_extra2311.abstract_len_error:
  description: "pathlib classes raise AttributeError on __abstractmethods__.__len__ — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: pp2311

  columns: [id, function, args, expected]
  rows:
    - ["pp2311006", "pathlib.PurePath.__abstractmethods__.__len__",        [], "AttributeError"]
    - ["pp2311007", "pathlib.Path.__abstractmethods__.__len__",            [], "AttributeError"]
    - ["pp2311008", "pathlib.PurePosixPath.__abstractmethods__.__len__",   [], "AttributeError"]
    - ["pp2311009", "pathlib.PureWindowsPath.__abstractmethods__.__len__", [], "AttributeError"]
    - ["pp2311010", "pathlib.PosixPath.__abstractmethods__.__len__",       [], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: __abstractmethods__.__contains__ raises AttributeError
#
# Chained access to .__abstractmethods__.__contains__ also raises AttributeError
# because the intermediate __abstractmethods__ attribute does not exist.
# Representative method names used: "open", "stat", "read_text", "__fspath__".
# ---------------------------------------------------------------------------

table pathlib_extra2311.abstract_contains_error:
  description: "pathlib __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: pp2311

  columns: [id, function, args, expected]
  rows:
    - ["pp2311011", "pathlib.PurePath.__abstractmethods__.__contains__",        ["open"],       "AttributeError"]
    - ["pp2311012", "pathlib.Path.__abstractmethods__.__contains__",            ["stat"],       "AttributeError"]
    - ["pp2311013", "pathlib.PurePosixPath.__abstractmethods__.__contains__",   ["read_text"],  "AttributeError"]
    - ["pp2311014", "pathlib.PureWindowsPath.__abstractmethods__.__contains__", ["__fspath__"], "AttributeError"]
    - ["pp2311015", "pathlib.PosixPath.__abstractmethods__.__contains__",       ["open"],       "AttributeError"]

# ---------------------------------------------------------------------------
# Table 4: cross-checks — additional method names for PurePath and Path
#
# Verifies that common path-manipulation methods are not listed as abstract
# (via the AttributeError absence pattern) and confirms dict-presence is
# consistently False across variant spellings.
# ---------------------------------------------------------------------------

table pathlib_extra2311.purepath_contains_error:
  description: "pathlib.PurePath __abstractmethods__.__contains__ raises for several names — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: pp2311

  columns: [id, function, args, expected]
  rows:
    - ["pp2311016", "pathlib.PurePath.__abstractmethods__.__contains__", ["__str__"],      "AttributeError"]
    - ["pp2311017", "pathlib.PurePath.__abstractmethods__.__contains__", ["__truediv__"],  "AttributeError"]
    - ["pp2311018", "pathlib.PurePath.__abstractmethods__.__contains__", ["is_absolute"],  "AttributeError"]
    - ["pp2311019", "pathlib.Path.__abstractmethods__.__contains__",     ["iterdir"],      "AttributeError"]
    - ["pp2311020", "pathlib.Path.__abstractmethods__.__contains__",     ["write_text"],   "AttributeError"]
