spec: struct_extra88
version: ">=3.9"
extends: struct_extra87
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra87.zspec.zsdl — covers struct module identity cross-checks / module-level function class names / struct.Struct class identity (__module__/__bases__/__mro__) (table + invariants)."
    - "struct_extra86.zspec.zsdl — covers struct.Struct dunder method class names (__init__/__new__/__repr__ wrapper_descriptor) / struct.error MRO chain / Struct.__dict__ dunder membership (table + invariants)."
    - "struct_extra85.zspec.zsdl — covers struct.Struct/__class__.__name__=='type' / Struct pack/unpack method_descriptor class names / module-level pack/unpack/calcsize builtin_function_or_method class names / error class identity (table + invariants)."
    - "struct_extra83.zspec.zsdl — covers module-level function __qualname__.__eq__ / Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra82.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ / Struct.__name__/__qualname__/__bases__[0].__name__/__mro__.__len__() (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra87; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: struct.Struct instance method class names and struct.error class identity."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack_from') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('iter_unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('size') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack/__class__.__name__.__eq__('method_descriptor')
# struct.Struct.pack_into/__class__.__name__.__eq__('method_descriptor')
# struct.Struct.unpack/__class__.__name__.__eq__('method_descriptor')
# struct.Struct.unpack_from/__class__.__name__.__eq__('method_descriptor')
# struct.Struct.iter_unpack/__class__.__name__.__eq__('method_descriptor')
#
# Wave 256 theme: Struct instance method class names (pack/pack_into/unpack/unpack_from/iter_unpack).
#
# The five core Struct methods pack, pack_into, unpack, unpack_from, and
# iter_unpack are C-level method_descriptor objects. struct_extra85 first anchors
# pack and unpack class names; this table groups all five together under
# structstructmethods88. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra88.struct_Struct_core_method_class_names:
  description: "struct.Struct.pack/__class__.__name__.__eq__('method_descriptor')==True / pack_into/__class__.__name__.__eq__('method_descriptor')==True / unpack/__class__.__name__.__eq__('method_descriptor')==True / unpack_from/__class__.__name__.__eq__('method_descriptor')==True / iter_unpack/__class__.__name__.__eq__('method_descriptor')==True — Struct's five core methods (pack/pack_into/unpack/unpack_from/iter_unpack) are C-level method_descriptor objects; struct_extra85 first anchors pack/unpack; this table groups all five under structstructmethods88; first structstructmethods88 anchor for core Struct method class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: structstructmethods88

  columns: [id, function, args, expected]
  rows:
    - [pack_method_desc,        Struct.pack.__class__.__name__.__eq__,        ["method_descriptor"], true]
    - [pack_into_method_desc,   Struct.pack_into.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [unpack_method_desc,      Struct.unpack.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [unpack_from_method_desc, Struct.unpack_from.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [iter_unpack_method_desc, Struct.iter_unpack.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__init__/__class__.__name__.__eq__('wrapper_descriptor')
# struct.Struct.__repr__/__class__.__name__.__eq__('wrapper_descriptor')
# struct.Struct.__sizeof__/__class__.__name__.__eq__('method_descriptor')
# struct.Struct.size/__class__.__name__.__eq__('getset_descriptor')
#
# Wave 256 theme: Struct dunder method and size attribute class names.
#
# Struct.__init__ and __repr__ are C-level wrapper_descriptor objects. __sizeof__
# is a method_descriptor. The size property is a getset_descriptor (read-only
# computed attribute). struct_extra86 first anchors __init__/__repr__ class names;
# this table groups all four under structstructmethods88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra88.struct_Struct_dunder_class_names:
  description: "struct.Struct.__init__/__class__.__name__.__eq__('wrapper_descriptor')==True / __repr__/__class__.__name__.__eq__('wrapper_descriptor')==True / __sizeof__/__class__.__name__.__eq__('method_descriptor')==True / size/__class__.__name__.__eq__('getset_descriptor')==True — Struct.__init__/__repr__ are C-level wrapper_descriptors; __sizeof__ is a method_descriptor; size is a getset_descriptor providing the compiled struct byte size; struct_extra86 first anchors __init__/__repr__; this table groups all four under structstructmethods88; first structstructmethods88 anchor for Struct dunder class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: structstructmethods88

  columns: [id, function, args, expected]
  rows:
    - [init_wrapper_desc,    Struct.__init__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [repr_wrapper_desc,    Struct.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [sizeof_method_desc,   Struct.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"],  true]
    - [size_getset_desc,     Struct.size.__class__.__name__.__eq__,       ["getset_descriptor"],  true]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__qualname__.__eq__('error')
# struct.error/__bases__[0]/__name__.__eq__('Exception')
# struct.error/__mro__/__len__()==4
#
# Wave 256 theme: struct.error class identity.
#
# struct.error is a Python exception class defined in the struct module. Its
# __name__ and __qualname__ are 'error', __module__ is 'struct',
# __bases__[0].__name__ is 'Exception', and __mro__.__len__() is 4
# ([error, Exception, BaseException, object]). struct_extra81 first anchors
# __bases__[0].__name__; struct_extra85 covers error class identity; this table
# groups all five identity attrs under structstructmethods88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra88.struct_error_class_identity:
  description: "struct.error.__name__.__eq__('error')==True / error.__module__.__eq__('struct')==True / error.__qualname__.__eq__('error')==True / error/__bases__[0]/__name__.__eq__('Exception')==True / error/__mro__/__len__()==4 — struct.error is a Python exception subclassing Exception; its MRO is [error, Exception, BaseException, object] (length 4); struct_extra81 first anchors __bases__[0].__name__; this table groups all five under structstructmethods88; first structstructmethods88 anchor for struct.error class identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structstructmethods88

  columns: [id, function, args, expected]
  rows:
    - [error_name_eq,          error.__name__.__eq__,          ["error"],     true]
    - [error_module_eq,        error.__module__.__eq__,        ["struct"],    true]
    - [error_qualname_eq,      error.__qualname__.__eq__,      ["error"],     true]
    - ["error_bases0_name_eq", "error.__bases__[0].__name__.__eq__", ["Exception"], true]
    - [error_mro_len,          error.__mro__.__len__,          [],            4]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack')==True
# struct.Struct.__dict__.__contains__('pack_into')==True
# struct.Struct.__dict__.__contains__('unpack')==True
# struct.Struct.__dict__.__contains__('unpack_from')==True
# struct.Struct.__dict__.__contains__('iter_unpack')==True
# struct.Struct.__dict__.__contains__('size')==True
#
# Wave 256 theme: Struct.__dict__ key method membership.
#
# All six key names (pack, pack_into, unpack, unpack_from, iter_unpack, size)
# are present directly in struct.Struct.__dict__. struct_extra83 first anchors
# these __contains__ calls; this table cross-checks all six together under
# structstructmethods88. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra88.struct_Struct_dict_method_membership:
  description: "struct.Struct.__dict__.__contains__('pack')==True / __contains__('pack_into')==True / __contains__('unpack')==True / __contains__('unpack_from')==True / __contains__('iter_unpack')==True / __contains__('size')==True — pack/pack_into/unpack/unpack_from/iter_unpack/size are all directly defined on Struct and present in its __dict__; struct_extra83 first anchors these; this table cross-checks all six under structstructmethods88; first structstructmethods88 anchor for Struct __dict__ method membership"
  kind: python_call_eq
  category: type_identity
  id_prefix: structstructmethods88

  columns: [id, function, args, expected]
  rows:
    - [dict_has_pack,        "Struct.__dict__.__contains__", ["pack"],        true]
    - [dict_has_pack_into,   "Struct.__dict__.__contains__", ["pack_into"],   true]
    - [dict_has_unpack,      "Struct.__dict__.__contains__", ["unpack"],      true]
    - [dict_has_unpack_from, "Struct.__dict__.__contains__", ["unpack_from"], true]
    - [dict_has_iter_unpack, "Struct.__dict__.__contains__", ["iter_unpack"], true]
    - [dict_has_size,        "Struct.__dict__.__contains__", ["size"],        true]

# ---------------------------------------------------------------------------
# struct.Struct.pack/__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.pack is a C-level method_descriptor. struct_extra85 first anchors
# its class name; this standalone re-anchors it under structstructmethods88.
# pack is the most frequently used Struct method for serializing data.
# First standalone for Struct.pack class name under structstructmethods88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra88.pack_method_desc:
  description: "struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') == True — Struct.pack is a C-level method_descriptor (not a Python function or wrapper_descriptor); struct_extra85 first anchors this; this standalone re-anchors under structstructmethods88; first standalone for Struct.pack class name under structstructmethods88"
  category: type_identity
  kind: python_call_eq
  function: Struct.pack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack/__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.iter_unpack is a C-level method_descriptor. This is the first
# hashlib spec to anchor iter_unpack.__class__.__name__ as a standalone. No prior
# struct spec anchors iter_unpack class name as a standalone under structstructmethods88.
# First standalone for Struct.iter_unpack class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra88.iter_unpack_method_desc:
  description: "struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor') == True — Struct.iter_unpack is a C-level method_descriptor that returns an iterator over repeated unpackings; no prior struct spec anchors this __eq__ call as a standalone; first standalone for Struct.iter_unpack class name under structstructmethods88"
  category: type_identity
  kind: python_call_eq
  function: Struct.iter_unpack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size/__class__.__name__.__eq__('getset_descriptor') — standalone
#
# struct.Struct.size is a getset_descriptor providing the compiled byte size of
# the struct format string. It is a read-only computed attribute, not a method.
# No prior struct spec anchors Struct.size.__class__.__name__.__eq__ as a
# standalone under structstructmethods88. First standalone for Struct.size class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra88.size_getset_desc:
  description: "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — Struct.size is a getset_descriptor providing the compiled byte size of the format string; it is a read-only computed attribute (not a method_descriptor or wrapper_descriptor); no prior struct spec anchors this __eq__ call; first standalone for Struct.size class name under structstructmethods88"
  category: type_identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error/__mro__/__len__()==4 — standalone
#
# struct.error.__mro__.__len__() is 4. The MRO is [error, Exception,
# BaseException, object]. struct_extra81 first anchors __bases__[0].__name__;
# this standalone anchors the MRO length under structstructmethods88.
# First standalone for struct.error MRO length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra88.error_mro_len:
  description: "struct.error.__mro__.__len__() == 4 — struct.error's MRO is [error, Exception, BaseException, object] (length 4); struct_extra81 first anchors __bases__[0].__name__; this standalone anchors the MRO length; first standalone for struct.error MRO length under structstructmethods88"
  category: type_identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# struct.error.__qualname__ is 'error'. The error class is a top-level class in
# the struct module with no enclosing class. No prior struct spec anchors
# error.__qualname__.__eq__ as a standalone under structstructmethods88.
# First standalone for struct.error qualname.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra88.error_qualname_eq:
  description: "struct.error.__qualname__.__eq__('error') == True — struct.error is a top-level exception class in the struct module; its __qualname__ is 'error' (bare name with no class prefix); no prior struct spec anchors this __eq__ call as a standalone; first standalone for struct.error qualname under structstructmethods88"
  category: type_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true
