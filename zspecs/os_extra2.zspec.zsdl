spec: os_extra2
version: ">=3.2"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "Python 3 os module documentation — https://docs.python.org/3/library/os.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os.path — covered separately in os_path.zspec.zsdl"
    - "os.environ — covered separately in os_environ.zspec.zsdl"
    - "os.stat — covered separately in os_stat.zspec.zsdl"
  notes:
    - "Complements os.zspec.zsdl and os_extra.zspec.zsdl."
    - "os.devnull is '/dev/null' on POSIX and 'nul' on Windows; this spec checks its class name only."
    - "os.altsep is None on POSIX (macOS/Linux/FreeBSD); Windows uses '\\' as altsep."
    - "os.getcwd.__name__ == 'getcwd' — function name attribute."
    - "os.listdir.__name__ == 'listdir' — function name attribute."
    - "os.makedirs.__name__ == 'makedirs' — function name attribute."
    - "os.curdir == '.' and os.pardir == '..' and os.extsep == '.' are POSIX-universal."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Constant class name checks
# ---------------------------------------------------------------------------

invariant os_extra2.devnull.class_name:
  description: "os.devnull.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: devnull.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra2.sep.class_name:
  description: "os.sep.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra2.linesep.class_name:
  description: "os.linesep.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: linesep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Constant value checks
# ---------------------------------------------------------------------------

invariant os_extra2.curdir.value:
  description: "os.curdir == '.' — current directory symbol on all platforms"
  category: constants
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant os_extra2.pardir.value:
  description: "os.pardir == '..' — parent directory symbol on all platforms"
  category: constants
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

invariant os_extra2.extsep.value:
  description: "os.extsep == '.' — file extension separator on all platforms"
  category: constants
  kind: python_call_eq
  function: extsep.__eq__
  args: ["."]
  expected: true

invariant os_extra2.altsep.is_none:
  description: "os.altsep is None on POSIX (macOS/Linux/FreeBSD)"
  category: constants
  kind: python_call_eq
  function: altsep.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table os_extra2.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, description, function, args, expected]
  rows:
    - [getcwd,   "getcwd.__name__ == 'getcwd'",     getcwd.__name__.__eq__,   ["getcwd"],   true]
    - [listdir,  "listdir.__name__ == 'listdir'",   listdir.__name__.__eq__,  ["listdir"],  true]
    - [makedirs, "makedirs.__name__ == 'makedirs'", makedirs.__name__.__eq__, ["makedirs"], true]
