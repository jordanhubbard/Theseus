spec: apscheduler_rust
version: ">=3.9"
backend: rust_module(apscheduler_rust)

docs: https://apscheduler.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://apscheduler.readthedocs.io/en/latest/ — APScheduler documentation"
  not_derived_from:
    - "apscheduler source: apscheduler/__init__.py"
  notes:
    - "APScheduler provides task scheduling for Python."
    - "from apscheduler.schedulers.background import BackgroundScheduler."
    - "BackgroundScheduler.__name__ == 'BackgroundScheduler'."
    - "from apscheduler.triggers.cron import CronTrigger."
    - "CronTrigger.__name__ == 'CronTrigger'."
    - "apscheduler.__version__ is a non-empty string."
    - "Expose apscheduler_bg_name() -> str: BackgroundScheduler.__name__."
    - "Expose apscheduler_cron_name() -> str: CronTrigger.__name__."
    - "Expose apscheduler_version_nonempty() -> bool: len(apscheduler.__version__) > 0."
    - "All test vectors verified against apscheduler 3.11.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# apscheduler_bg_name — BackgroundScheduler class name
invariant apscheduler_rust.scheduler.bg_name:
  description: "BackgroundScheduler.__name__ == 'BackgroundScheduler'"
  category: scheduler
  kind: python_call_eq
  function: apscheduler_bg_name
  args: []
  expected: "BackgroundScheduler"

# apscheduler_cron_name — CronTrigger class name
invariant apscheduler_rust.trigger.cron_name:
  description: "CronTrigger.__name__ == 'CronTrigger'"
  category: trigger
  kind: python_call_eq
  function: apscheduler_cron_name
  args: []
  expected: "CronTrigger"

# apscheduler_version_nonempty — version non-empty
invariant apscheduler_rust.version.nonempty:
  description: "apscheduler.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: apscheduler_version_nonempty
  args: []
  expected: true

