spec: hashlib_extra101
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra99

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / md5-sha512 __name__.__eq__ / blake2b/blake2s class identity + __module__ + __qualname__ / new __class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__.__eq__('__hash_new') / new/__qualname__.__len__()==10 (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512/sha3_256/sha3_512 __qualname__.__eq__ and __module__.__eq__('_hashlib') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 261 theme: hashlib constructor __qualname__.__len__() values for all algorithm families — md5/sha1/sha224/sha256/sha384/sha512 __qualname__ lengths / sha3_224/sha3_256/sha3_384/sha3_512 __qualname__ lengths / shake_128/shake_256 __qualname__ lengths / blake2b/blake2s __qualname__ lengths."
    - "hashlib.md5.__qualname__.__len__() == 11 ('openssl_md5'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__.__len__() == 12 ('openssl_sha1'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__.__len__() == 14 ('openssl_sha224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__.__len__() == 14 ('openssl_sha256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__.__len__() == 14 ('openssl_sha384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__.__len__() == 14 ('openssl_sha512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__qualname__.__len__() == 16 ('openssl_sha3_224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__.__len__() == 16 ('openssl_sha3_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__qualname__.__len__() == 16 ('openssl_sha3_384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__.__len__() == 16 ('openssl_sha3_512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__.__len__() == 17 ('openssl_shake_128'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__qualname__.__len__() == 17 ('openssl_shake_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__.__len__() == 7 ('blake2b'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__.__len__() == 7 ('blake2s'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: the 'openssl_' prefix in __qualname__ adds 7 characters to the algorithm name length for OpenSSL-backed constructors; blake2b/blake2s come from _blake2 and have no prefix."
    - "Note: sha224/sha256/sha384/sha512 all have the same __qualname__ length of 14 because 'openssl_sha' (11) plus '224'/'256'/'384'/'512' (3) = 14; sha3_* lengths are 16 due to 'openssl_sha3_' (13) plus '224'/'256'/'384'/'512' (3)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11
# hashlib.sha1.__qualname__.__len__()==12
# hashlib.sha224.__qualname__.__len__()==14
# hashlib.sha256.__qualname__.__len__()==14
# hashlib.sha384.__qualname__.__len__()==14
# hashlib.sha512.__qualname__.__len__()==14
#
# Wave 261 theme: md5/sha1/sha224/sha256/sha384/sha512 __qualname__.__len__().
#
# The six core SHA-family constructors all carry the 'openssl_' prefix in their
# __qualname__. md5: 'openssl_md5' (11 chars), sha1: 'openssl_sha1' (12),
# sha224/sha256/sha384/sha512: 14 chars each ('openssl_sha' + 3-digit suffix).
# Prior specs (extra95/extra99) anchor __qualname__.__eq__ equality; this table
# anchors the __len__() values for the first time under hashlibqlen101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra101.sha_constructor_qualname_lengths:
  description: "hashlib.md5/__qualname__/__len__()==11 / sha1/__qualname__/__len__()==12 / sha224/__qualname__/__len__()==14 / sha256/__qualname__/__len__()==14 / sha384/__qualname__/__len__()==14 / sha512/__qualname__/__len__()==14 — OpenSSL-backed constructors carry 'openssl_' prefix (7 chars) in __qualname__; md5/sha1 have shorter suffixes than sha224/sha384/sha512/sha256; extra95/extra99 anchor __qualname__.__eq__; this table first anchors __qualname__.__len__() for all six; first hashlibqlen101 anchor for SHA constructor qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen101

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qlen,    md5.__qualname__.__len__,    [], 11, "hashlib.md5.__qualname__ is 'openssl_md5' (11 chars)"]
    - [sha1_qlen,   sha1.__qualname__.__len__,   [], 12, "hashlib.sha1.__qualname__ is 'openssl_sha1' (12 chars)"]
    - [sha224_qlen, sha224.__qualname__.__len__,  [], 14, "hashlib.sha224.__qualname__ is 'openssl_sha224' (14 chars)"]
    - [sha256_qlen, sha256.__qualname__.__len__,  [], 14, "hashlib.sha256.__qualname__ is 'openssl_sha256' (14 chars)"]
    - [sha384_qlen, sha384.__qualname__.__len__,  [], 14, "hashlib.sha384.__qualname__ is 'openssl_sha384' (14 chars)"]
    - [sha512_qlen, sha512.__qualname__.__len__,  [], 14, "hashlib.sha512.__qualname__ is 'openssl_sha512' (14 chars)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__qualname__.__len__()==16
# hashlib.sha3_256.__qualname__.__len__()==16
# hashlib.sha3_384.__qualname__.__len__()==16
# hashlib.sha3_512.__qualname__.__len__()==16
# hashlib.shake_128.__qualname__.__len__()==17
# hashlib.shake_256.__qualname__.__len__()==17
#
# Wave 261 theme: sha3_*/shake_* __qualname__.__len__().
#
# The four SHA-3 constructors have __qualname__ 'openssl_sha3_NNN' (16 chars:
# 'openssl_sha3_' = 13, plus '224'/'256'/'384'/'512' = 3). The two SHAKE
# constructors have 'openssl_shake_NNN' (17 chars: 'openssl_shake_' = 14, plus
# '128'/'256' = 3). extra98 anchors __qualname__.__eq__ for sha3_*/shake_*;
# this table first anchors __len__() values under hashlibqlen101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra101.sha3_shake_qualname_lengths:
  description: "hashlib.sha3_224/__qualname__/__len__()==16 / sha3_256/__qualname__/__len__()==16 / sha3_384/__qualname__/__len__()==16 / sha3_512/__qualname__/__len__()==16 / shake_128/__qualname__/__len__()==17 / shake_256/__qualname__/__len__()==17 — sha3_* qualnames are 'openssl_sha3_NNN' (16 chars); shake_* are 'openssl_shake_NNN' (17 chars); extra98 anchors __qualname__.__eq__; this table first anchors sha3_*/shake_* __qualname__.__len__(); first hashlibqlen101 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen101

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_qlen, sha3_224.__qualname__.__len__, [], 16, "hashlib.sha3_224.__qualname__ is 'openssl_sha3_224' (16 chars)"]
    - [sha3_256_qlen, sha3_256.__qualname__.__len__, [], 16, "hashlib.sha3_256.__qualname__ is 'openssl_sha3_256' (16 chars)"]
    - [sha3_384_qlen, sha3_384.__qualname__.__len__, [], 16, "hashlib.sha3_384.__qualname__ is 'openssl_sha3_384' (16 chars)"]
    - [sha3_512_qlen, sha3_512.__qualname__.__len__, [], 16, "hashlib.sha3_512.__qualname__ is 'openssl_sha3_512' (16 chars)"]
    - [shake_128_qlen, shake_128.__qualname__.__len__, [], 17, "hashlib.shake_128.__qualname__ is 'openssl_shake_128' (17 chars)"]
    - [shake_256_qlen, shake_256.__qualname__.__len__, [], 17, "hashlib.shake_256.__qualname__ is 'openssl_shake_256' (17 chars)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__len__()==7
# hashlib.blake2s.__qualname__.__len__()==7
#
# Wave 261 theme: blake2b/blake2s __qualname__.__len__() values.
#
# Unlike the OpenSSL-backed constructors, blake2b and blake2s come from the
# _blake2 C extension and have simple __qualname__ values: 'blake2b' (7 chars)
# and 'blake2s' (7 chars), with no 'openssl_' prefix. extra99 anchors
# blake2b/blake2s __qualname__.__eq__('blake2b') / __qualname__.__eq__('blake2s');
# this table anchors the __len__() values under hashlibqlen101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra101.blake2_qualname_lengths:
  description: "hashlib.blake2b/__qualname__/__len__()==7 / blake2s/__qualname__/__len__()==7 — blake2b/blake2s come from _blake2 and have simple unqualified names 'blake2b'/'blake2s' (7 chars each); no 'openssl_' prefix unlike the SHA family; extra99 anchors __qualname__.__eq__; this table first anchors blake2b/blake2s __qualname__.__len__() under hashlibqlen101"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen101

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_qlen, blake2b.__qualname__.__len__, [], 7, "hashlib.blake2b.__qualname__ is 'blake2b' (7 chars), no 'openssl_' prefix"]
    - [blake2s_qlen, blake2s.__qualname__.__len__, [], 7, "hashlib.blake2s.__qualname__ is 'blake2s' (7 chars), no 'openssl_' prefix"]

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11 — standalone
#
# hashlib.md5.__qualname__.__len__() is 11. hashlib.md5.__qualname__ is
# 'openssl_md5' — 'openssl_' (7 chars) plus 'md5' (3 chars) = 10? Let's
# recount: o-p-e-n-s-s-l-_ = 8, m-d-5 = 3, total = 11 chars. Prior specs
# anchor __qualname__.__eq__('openssl_md5'); this is the first standalone
# anchoring the length under hashlibqlen101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra101.md5_qualname_len_11:
  description: "hashlib.md5.__qualname__.__len__() == 11 — md5.__qualname__ is 'openssl_md5': 'openssl_' (8 chars) + 'md5' (3 chars) = 11; extra99 anchors __qualname__.__eq__; this is the first standalone for md5.__qualname__.__len__() under hashlibqlen101"
  category: qualname_lengths
  kind: python_call_eq
  function: md5.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__len__()==16 — standalone
#
# hashlib.sha3_256.__qualname__.__len__() is 16. hashlib.sha3_256.__qualname__
# is 'openssl_sha3_256': 'openssl_' (8) + 'sha3_256' (8) = 16. The SHA-3
# family constructors have 16-char qualnames on Python 3.14.3 macOS/Darwin.
# extra98 anchors sha3_256.__qualname__.__eq__('openssl_sha3_256'); no prior
# spec anchors sha3_256.__qualname__.__len__() as a standalone under hashlibqlen101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra101.sha3_256_qualname_len_16:
  description: "hashlib.sha3_256.__qualname__.__len__() == 16 — sha3_256.__qualname__ is 'openssl_sha3_256': 'openssl_' (8) + 'sha3_256' (8) = 16; extra98 anchors __qualname__.__eq__; first standalone for sha3_256.__qualname__.__len__() under hashlibqlen101"
  category: qualname_lengths
  kind: python_call_eq
  function: sha3_256.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# hashlib.shake_128.__qualname__.__len__()==17 — standalone
#
# hashlib.shake_128.__qualname__.__len__() is 17. hashlib.shake_128.__qualname__
# is 'openssl_shake_128': 'openssl_' (8) + 'shake_128' (9) = 17. The SHAKE
# family has 17-char qualnames, one longer than the SHA-3 family (16 chars),
# because 'shake_' (6) is one character longer than 'sha3_' (5) plus the
# 3-digit suffix. extra98 anchors shake_128.__qualname__.__eq__; no prior spec
# anchors shake_128.__qualname__.__len__() as a standalone under hashlibqlen101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra101.shake_128_qualname_len_17:
  description: "hashlib.shake_128.__qualname__.__len__() == 17 — shake_128.__qualname__ is 'openssl_shake_128': 'openssl_' (8) + 'shake_128' (9) = 17; SHAKE qualnames are 1 char longer than SHA-3 qualnames (17 vs 16); extra98 anchors __qualname__.__eq__; first standalone for shake_128.__qualname__.__len__() under hashlibqlen101"
  category: qualname_lengths
  kind: python_call_eq
  function: shake_128.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__len__()==7 — standalone
#
# hashlib.blake2b.__qualname__.__len__() is 7. blake2b.__qualname__ is 'blake2b'
# (7 chars), with no 'openssl_' prefix because blake2b comes from the _blake2
# C extension (not _hashlib/OpenSSL). This makes its qualname the shortest among
# the standard hashlib constructors. extra99 anchors blake2b.__qualname__.__eq__;
# no prior spec anchors blake2b.__qualname__.__len__() as a standalone under
# hashlibqlen101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra101.blake2b_qualname_len_7:
  description: "hashlib.blake2b.__qualname__.__len__() == 7 — blake2b.__qualname__ is 'blake2b' (7 chars); no 'openssl_' prefix because blake2b comes from _blake2, not _hashlib/OpenSSL; shortest qualname among standard hashlib constructors; extra99 anchors __qualname__.__eq__; first standalone for blake2b.__qualname__.__len__() under hashlibqlen101"
  category: qualname_lengths
  kind: python_call_eq
  function: blake2b.__qualname__.__len__
  args: []
  expected: 7
