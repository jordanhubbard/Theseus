spec: threading_extra245
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra244.zspec.zsdl — covers TIMEOUT_MAX and local class identity"
    - "threading_extra243.zspec.zsdl — covers current_thread, active_count, enumerate function identity"
    - "threading_extra242.zspec.zsdl — covers Semaphore and BoundedSemaphore class identity"
    - "threading_extra.zspec.zsdl — covers module checks for synchronization primitives, local, get_ident, TIMEOUT_MAX, stack_size"
    - "threading.zspec.zsdl — covers class __name__ checks and function names"
  notes:
    - "This spec covers threading.Barrier class identity and method name contracts."
    - "threading.Barrier.__name__ == 'Barrier' (len=7) — Barrier is a Python class in Lib/threading.py added in Python 3.2. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' (len=9) — Barrier is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object. Verified with Python 3.14.3."
    - "threading.Barrier.__class__.__name__ == 'type' — Barrier is a Python class; its metaclass is type. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__name__ == 'wait' (len=4) — the wait method of Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len=12) — qualname includes the class name. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__name__ == 'reset' (len=5) — the reset method of Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len=13) — qualname includes the class name. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__name__ == 'abort' (len=5) — the abort method of Barrier. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len=13) — qualname includes the class name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Barrier class identity contracts
#
# threading.Barrier.__name__ == 'Barrier' (len=7)
# threading.Barrier.__module__ == 'threading' (len=9)
# threading.Barrier.__qualname__ == 'Barrier' (len=7)
# threading.Barrier.__class__.__name__ == 'type'
# threading.Barrier.__name__.__len__() == 7
#
# Barrier is a Python class in Lib/threading.py added in Python 3.2. New to extra245.
# ---------------------------------------------------------------------------

table threading_extra245.barrier245_identity:
  description: "threading.Barrier class identity: name, module, qualname, class; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: barrier245

  columns: [id, function, args, expected, description]
  rows:
    - [bar_name_eq,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a Python class in Lib/threading.py; __name__ is 'Barrier' (len=7); new to extra245"]
    - [bar_name_len_7,
       Barrier.__name__.__len__,
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has exactly 7 characters; str.__len__() returns 7; new to extra245"]
    - [bar_module_eq,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra245"]
    - [bar_module_len_9,
       Barrier.__module__.__len__,
       [],
       9,
       "threading.Barrier.__module__.__len__() == 9 — 'threading' has exactly 9 characters; str.__len__() returns 9; new to extra245"]
    - [bar_qualname_eq,
       Barrier.__qualname__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__.__eq__('Barrier') == True — __qualname__ is 'Barrier' (len=7); same as __name__ for top-level class; new to extra245"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier bases, class type, and content checks
#
# threading.Barrier.__bases__[0].__name__ == 'object'
# threading.Barrier.__class__.__name__ == 'type'
# threading.Barrier.__name__.__contains__('Barrier') == True
# threading.Barrier.__module__.__contains__('threading') == True
# threading.Barrier.__bases__[0].__name__.__len__() == 6
#
# New to extra245.
# ---------------------------------------------------------------------------

table threading_extra245.barrier245_bases:
  description: "threading.Barrier bases, class type, content checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: barrier245b

  columns: [id, function, args, expected, description]
  rows:
    - [bar_bases_0_is_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier inherits directly from object; __bases__[0] is object; new to extra245"]
    - [bar_class_is_type,
       Barrier.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Barrier.__class__.__name__.__eq__('type') == True — Barrier is a Python class; its metaclass is the built-in type; new to extra245"]
    - [bar_name_contains_barrier,
       Barrier.__name__.__contains__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__contains__('Barrier') == True — 'Barrier' contains 'Barrier'; new to extra245"]
    - [bar_module_contains_threading,
       Barrier.__module__.__contains__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__contains__('threading') == True — 'threading' contains the substring 'threading'; new to extra245"]
    - [bar_bases_0_len_6,
       "Barrier.__bases__[0].__name__.__len__",
       [],
       6,
       "threading.Barrier.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra245"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier.wait and reset method name contracts
#
# threading.Barrier.wait.__name__ == 'wait' (len=4)
# threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len=12)
# threading.Barrier.reset.__name__ == 'reset' (len=5)
# threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len=13)
# threading.Barrier.wait.__class__.__name__ == 'function'
#
# New to extra245.
# ---------------------------------------------------------------------------

table threading_extra245.barrierm245_wait_reset:
  description: "threading.Barrier.wait and reset method name and qualname contracts; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: barrierm245

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,
       Barrier.wait.__name__.__eq__,
       ["wait"],
       true,
       "threading.Barrier.wait.__name__.__eq__('wait') == True — the wait method of Barrier; __name__ is 'wait' (len=4); new to extra245"]
    - [wait_qualname_eq,
       Barrier.wait.__qualname__.__eq__,
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — __qualname__ is 'Barrier.wait' (len=12); includes the class name; new to extra245"]
    - [reset_name_eq,
       Barrier.reset.__name__.__eq__,
       ["reset"],
       true,
       "threading.Barrier.reset.__name__.__eq__('reset') == True — the reset method of Barrier; __name__ is 'reset' (len=5); new to extra245"]
    - [reset_qualname_eq,
       Barrier.reset.__qualname__.__eq__,
       ["Barrier.reset"],
       true,
       "threading.Barrier.reset.__qualname__.__eq__('Barrier.reset') == True — __qualname__ is 'Barrier.reset' (len=13); includes the class name; new to extra245"]
    - [wait_class_is_function,
       Barrier.wait.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Barrier.wait.__class__.__name__.__eq__('function') == True — wait is a plain Python function; __class__.__name__ is 'function'; new to extra245"]

# ---------------------------------------------------------------------------
# Table 4: threading.Barrier.abort method and method length checks
#
# threading.Barrier.abort.__name__ == 'abort' (len=5)
# threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len=13)
# threading.Barrier.wait.__name__.__len__() == 4
# threading.Barrier.reset.__name__.__len__() == 5
# threading.Barrier.abort.__name__.__len__() == 5
#
# New to extra245.
# ---------------------------------------------------------------------------

table threading_extra245.barrierm245_abort:
  description: "threading.Barrier.abort method name, qualname, and method name length checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: barrierm245b

  columns: [id, function, args, expected, description]
  rows:
    - [abort_name_eq,
       Barrier.abort.__name__.__eq__,
       ["abort"],
       true,
       "threading.Barrier.abort.__name__.__eq__('abort') == True — the abort method of Barrier; __name__ is 'abort' (len=5); new to extra245"]
    - [abort_qualname_eq,
       Barrier.abort.__qualname__.__eq__,
       ["Barrier.abort"],
       true,
       "threading.Barrier.abort.__qualname__.__eq__('Barrier.abort') == True — __qualname__ is 'Barrier.abort' (len=13); includes the class name; new to extra245"]
    - [wait_name_len_4,
       Barrier.wait.__name__.__len__,
       [],
       4,
       "threading.Barrier.wait.__name__.__len__() == 4 — 'wait' has exactly 4 characters; str.__len__() returns 4; new to extra245"]
    - [reset_name_len_5,
       Barrier.reset.__name__.__len__,
       [],
       5,
       "threading.Barrier.reset.__name__.__len__() == 5 — 'reset' has exactly 5 characters; str.__len__() returns 5; new to extra245"]
    - [abort_name_len_5,
       Barrier.abort.__name__.__len__,
       [],
       5,
       "threading.Barrier.abort.__name__.__len__() == 5 — 'abort' has exactly 5 characters; str.__len__() returns 5; new to extra245"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra245
# ---------------------------------------------------------------------------

invariant threading_extra245.bar_name_eq:
  description: "threading.Barrier.__name__ == 'Barrier' (len=7); new to extra245"
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra245.bar_module_eq:
  description: "threading.Barrier.__module__ == 'threading' — defined in Lib/threading.py; new to extra245"
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra245.bar_bases_0_is_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — inherits from object; new to extra245"
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra245.bar_class_is_type:
  description: "threading.Barrier.__class__.__name__ == 'type' — Barrier is a Python class; new to extra245"
  kind: python_call_eq
  function: Barrier.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra245.bar_name_len_7:
  description: "threading.Barrier.__name__.__len__() == 7; new to extra245"
  kind: python_call_eq
  function: Barrier.__name__.__len__
  args: []
  expected: 7

invariant threading_extra245.wait_name_eq:
  description: "threading.Barrier.wait.__name__ == 'wait' (len=4); new to extra245"
  kind: python_call_eq
  function: Barrier.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra245.wait_qualname_eq:
  description: "threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len=12); new to extra245"
  kind: python_call_eq
  function: Barrier.wait.__qualname__.__eq__
  args: ["Barrier.wait"]
  expected: true

invariant threading_extra245.reset_name_eq:
  description: "threading.Barrier.reset.__name__ == 'reset' (len=5); new to extra245"
  kind: python_call_eq
  function: Barrier.reset.__name__.__eq__
  args: ["reset"]
  expected: true

invariant threading_extra245.reset_qualname_eq:
  description: "threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len=13); new to extra245"
  kind: python_call_eq
  function: Barrier.reset.__qualname__.__eq__
  args: ["Barrier.reset"]
  expected: true

invariant threading_extra245.abort_name_eq:
  description: "threading.Barrier.abort.__name__ == 'abort' (len=5); new to extra245"
  kind: python_call_eq
  function: Barrier.abort.__name__.__eq__
  args: ["abort"]
  expected: true

invariant threading_extra245.abort_qualname_eq:
  description: "threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len=13); new to extra245"
  kind: python_call_eq
  function: Barrier.abort.__qualname__.__eq__
  args: ["Barrier.abort"]
  expected: true

invariant threading_extra245.bar_qualname_eq:
  description: "threading.Barrier.__qualname__ == 'Barrier' (len=7); new to extra245"
  kind: python_call_eq
  function: Barrier.__qualname__.__eq__
  args: ["Barrier"]
  expected: true
