spec: itertools_extra16
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra15.zspec.zsdl."
    - "itertools_extra15 covers: __module__.__eq__ for compress, dropwhile, takewhile, filterfalse, starmap; __name__.__len__ for chain(5), repeat(6), zip_longest(12), permutations(12), combinations(12), groupby(7), islice(6); repeat instance class via method_chain."
    - "itertools.zspec.zsdl covers: __name__.__eq__ for chain, islice, count, cycle, repeat, accumulate, compress, starmap, product, combinations, permutations, dropwhile, takewhile, zip_longest."
    - "itertools_extra8 covers: pairwise.__name__.__eq__, __qualname__.__eq__, __module__.__eq__, __class__.__name__.__eq__, __bases__.__len__, instance tests."
    - "No prior itertools spec covers __name__.__len__() for compress, dropwhile, takewhile, filterfalse, starmap, accumulate, pairwise, or combinations_with_replacement."
    - "itertools_extra4 covers compress/accumulate/starmap __name__.__eq__ (not __len__)."
    - "itertools_extra.zspec.zsdl covers filterfalse.__name__.__eq__ (not __len__)."
    - "Name lengths: compress==8, dropwhile==9, takewhile==9, filterfalse==11, starmap==7, accumulate==10, pairwise==8, combinations_with_replacement==27."
    - "version: >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for filtering itertools types
#
# itertools_extra15 covers __name__.__len__ for chain, repeat, zip_longest,
# permutations, combinations, groupby, islice. No prior spec records
# __name__.__len__() for compress, dropwhile, takewhile, filterfalse, or starmap.
# ---------------------------------------------------------------------------

invariant itertools_extra16.compress.name_len:
  description: "itertools.compress.__name__.__len__() == 8 — len('compress')"
  category: name_lengths
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8

invariant itertools_extra16.dropwhile.name_len:
  description: "itertools.dropwhile.__name__.__len__() == 9 — len('dropwhile')"
  category: name_lengths
  kind: python_call_eq
  function: dropwhile.__name__.__len__
  args: []
  expected: 9

invariant itertools_extra16.takewhile.name_len:
  description: "itertools.takewhile.__name__.__len__() == 9 — len('takewhile')"
  category: name_lengths
  kind: python_call_eq
  function: takewhile.__name__.__len__
  args: []
  expected: 9

invariant itertools_extra16.filterfalse.name_len:
  description: "itertools.filterfalse.__name__.__len__() == 11 — len('filterfalse')"
  category: name_lengths
  kind: python_call_eq
  function: filterfalse.__name__.__len__
  args: []
  expected: 11

invariant itertools_extra16.starmap.name_len:
  description: "itertools.starmap.__name__.__len__() == 7 — len('starmap')"
  category: name_lengths
  kind: python_call_eq
  function: starmap.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __name__.__len__() for additional itertools types not covered by extra15
#
# No prior spec records __name__.__len__() for accumulate, pairwise, or
# combinations_with_replacement. These complement the __name__.__eq__ records
# in itertools.zspec.zsdl, extra4, extra8, and extra13.
# ---------------------------------------------------------------------------

invariant itertools_extra16.accumulate.name_len:
  description: "itertools.accumulate.__name__.__len__() == 10 — len('accumulate')"
  category: name_lengths
  kind: python_call_eq
  function: accumulate.__name__.__len__
  args: []
  expected: 10

invariant itertools_extra16.pairwise.name_len:
  description: "itertools.pairwise.__name__.__len__() == 8 — len('pairwise')"
  category: name_lengths
  kind: python_call_eq
  function: pairwise.__name__.__len__
  args: []
  expected: 8

invariant itertools_extra16.combinations_with_replacement.name_len:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 27 — len('combinations_with_replacement')"
  category: name_lengths
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 27

# ---------------------------------------------------------------------------
# Instance __class__.__name__ checks via method_chain
#
# itertools_extra15 covers repeat(1,3).__class__.__name__ via method_chain.
# itertools_extra4 covers islice.__class__.__name__.__eq__ (class attribute,
# not instance). No prior spec covers __class__.__name__ on a compress,
# dropwhile, or accumulate instance via method_chain.
# compress([True,False,True],[1,2,3]): instance type name is 'compress'.
# dropwhile(lambda x:x<2,[1,2,3]): ZSDL cannot pass lambdas; use accumulate.
# accumulate([1,2,3]): instance type name is 'accumulate'.
# ---------------------------------------------------------------------------

invariant itertools_extra16.compress.instance_class_name:
  description: "compress([True,False,True],[1,2,3]).__class__.__name__ == 'compress'"
  category: instance_class
  kind: python_call_eq
  function: compress
  args: [[true, false, true], [1, 2, 3]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["compress"]
  expected: true

invariant itertools_extra16.accumulate.instance_class_name:
  description: "accumulate([1,2,3]).__class__.__name__ == 'accumulate'"
  category: instance_class
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["accumulate"]
  expected: true

invariant itertools_extra16.cycle.instance_class_name:
  description: "cycle([1,2,3]).__class__.__name__ == 'cycle'"
  category: instance_class
  kind: python_call_eq
  function: cycle
  args: [[1, 2, 3]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["cycle"]
  expected: true
