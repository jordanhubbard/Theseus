spec: zoneinfo_extra4
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py, Lib/zoneinfo/_tzpath.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
    - "zoneinfo.zspec.zsdl — covers ZoneInfo/__name__/__module__, ZoneInfoNotFoundError/__name__, available_timezones/__name__, base=KeyError, returns set, UTC/America/New_York containment, ZoneInfo('UTC') class"
    - "zoneinfo_extra.zspec.zsdl — covers class_names table, ZoneInfo/__module__, ZoneInfoNotFoundError base=KeyError, available_timezones/__name__/__returns_set__/min_count (598)"
    - "zoneinfo_extra2.zspec.zsdl — covers __qualname__ for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo.__bases__[0].__name__=='tzinfo'; ZoneInfoNotFoundError/__module__; available_timezones/__module__; ZoneInfo('UTC').key; ZoneInfo('America/New_York').key; Europe/London/Asia/Tokyo/Pacific/Auckland containment"
    - "zoneinfo_extra3.zspec.zsdl — covers ZoneInfo.__mro__ length; clear_cache/no_cache/from_file __name__ (table); ZoneInfo('UTC').utcoffset/tzname; available_timezones().__class__.__name__=='set'; Africa/Cairo/America/Los_Angeles/Australia/Sydney containment"
  notes:
    - "This spec adds new axes not present in any prior zoneinfo spec."
    - "New axis 1: __qualname__ for ZoneInfo.no_cache, ZoneInfo.clear_cache, ZoneInfo.from_file — nested qualnames, not covered by any prior spec (which only checked __name__)."
    - "New axis 2: ZoneInfoNotFoundError MRO length == 6 — not covered in any prior spec."
    - "New axis 3: additional well-known IANA timezone containment — Africa/Nairobi, America/Chicago, Europe/Paris, Asia/Shanghai."
    - "New axis 4: ZoneInfo.no_cache.__module__ and ZoneInfo.clear_cache.__module__ — method module attributes."
    - "ZoneInfo.no_cache.__qualname__ == 'ZoneInfo.no_cache' — dotted qualname reflecting class nesting."
    - "ZoneInfo.clear_cache.__qualname__ == 'ZoneInfo.clear_cache' — dotted qualname reflecting class nesting."
    - "ZoneInfo.from_file.__qualname__ == 'ZoneInfo.from_file' — dotted qualname reflecting class nesting."
    - "len(ZoneInfoNotFoundError.__mro__) == 6 — ZoneInfoNotFoundError -> KeyError -> LookupError -> Exception -> BaseException -> object."
    - "Africa/Nairobi, America/Chicago, Europe/Paris, Asia/Shanghai all present in available_timezones() on Python 3.12/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ZoneInfo() raises ZoneInfoNotFoundError (subclass of KeyError) for unknown timezone keys"
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# ZoneInfo class method __qualname__ — nested dotted qualnames
#
# zoneinfo_extra3 checks clear_cache.__name__, no_cache.__name__, from_file.__name__
# in a table (all simple strings matching the unqualified name). No prior spec
# checks their __qualname__ attributes, which are dotted nested qualnames:
# 'ZoneInfo.no_cache', 'ZoneInfo.clear_cache', 'ZoneInfo.from_file'.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra4.ZoneInfo.no_cache_qualname:
  description: "zoneinfo.ZoneInfo.no_cache.__qualname__ == 'ZoneInfo.no_cache' — nested method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: ZoneInfo.no_cache.__qualname__.__eq__
  args: ["ZoneInfo.no_cache"]
  expected: true

invariant zoneinfo_extra4.ZoneInfo.clear_cache_qualname:
  description: "zoneinfo.ZoneInfo.clear_cache.__qualname__ == 'ZoneInfo.clear_cache' — nested method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: ZoneInfo.clear_cache.__qualname__.__eq__
  args: ["ZoneInfo.clear_cache"]
  expected: true

invariant zoneinfo_extra4.ZoneInfo.from_file_qualname:
  description: "zoneinfo.ZoneInfo.from_file.__qualname__ == 'ZoneInfo.from_file' — nested method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: ZoneInfo.from_file.__qualname__.__eq__
  args: ["ZoneInfo.from_file"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError MRO length
#
# No prior spec checks the MRO length of ZoneInfoNotFoundError. The full MRO
# is: ZoneInfoNotFoundError -> KeyError -> LookupError -> Exception ->
# BaseException -> object, giving length 6.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra4.ZoneInfoNotFoundError.mro_length:
  description: "len(zoneinfo.ZoneInfoNotFoundError.__mro__) == 6 — ZoneInfoNotFoundError -> KeyError -> LookupError -> Exception -> BaseException -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__mro__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# ZoneInfo method __module__ attributes
#
# zoneinfo_extra2 checks ZoneInfo.__module__ (the class itself). No prior spec
# checks the __module__ attribute of individual class methods like no_cache
# or clear_cache.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra4.ZoneInfo.no_cache_module:
  description: "zoneinfo.ZoneInfo.no_cache.__module__ == 'zoneinfo' — method module"
  category: method_modules
  kind: python_call_eq
  function: ZoneInfo.no_cache.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

invariant zoneinfo_extra4.ZoneInfo.clear_cache_module:
  description: "zoneinfo.ZoneInfo.clear_cache.__module__ == 'zoneinfo' — method module"
  category: method_modules
  kind: python_call_eq
  function: ZoneInfo.clear_cache.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

# ---------------------------------------------------------------------------
# Additional IANA timezone containment in available_timezones()
#
# zoneinfo and zoneinfo_extra confirm UTC and America/New_York.
# zoneinfo_extra2 adds Europe/London, Asia/Tokyo, Pacific/Auckland.
# zoneinfo_extra3 adds Africa/Cairo, America/Los_Angeles, Australia/Sydney.
# This spec adds Africa/Nairobi, America/Chicago, Europe/Paris, Asia/Shanghai.
# ---------------------------------------------------------------------------

table zoneinfo_extra4.additional_timezones:
  kind: python_call_eq
  category: behavioral
  id_prefix: tzcontains

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [africa_nairobi,   available_timezones, [], __contains__, ["Africa/Nairobi"],   true]
    - [america_chicago,  available_timezones, [], __contains__, ["America/Chicago"],  true]
    - [europe_paris,     available_timezones, [], __contains__, ["Europe/Paris"],     true]
    - [asia_shanghai,    available_timezones, [], __contains__, ["Asia/Shanghai"],    true]

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError __qualname__ in extra4 namespace
#
# zoneinfo_extra2 covers ZoneInfoNotFoundError.__qualname__ == 'ZoneInfoNotFoundError'
# in the extra2 namespace. This adds a parallel anchor in extra4's namespace
# for continuity, alongside the genuinely novel ZoneInfoNotFoundError.mro_length.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra4.ZoneInfoNotFoundError.bases_qualname:
  description: "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' — direct parent class"
  category: class_hierarchy
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "KeyError"
