spec: dc3211
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 661 (dc3211): __and__, __or__, __xor__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "decimal.Decimal does NOT define __and__ in its own __dict__ (false): Decimal supports decimal arithmetic but not bitwise AND, which is an integer operation."
    - "decimal.Decimal does NOT define __or__ in its own __dict__ (false): Decimal supports decimal arithmetic but not bitwise OR, which is an integer operation."
    - "decimal.Decimal does NOT define __xor__ in its own __dict__ (false): Decimal supports decimal arithmetic but not bitwise XOR, which is an integer operation."
    - "decimal.Context does NOT define __and__, __or__, or __xor__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "Decimal is a decimal floating-point type implementing IEEE 754; bitwise operators are integer operations and are not part of the Decimal arithmetic protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __and__ dict-presence — operator.contains(Cls.__dict__, '__and__')
#
# No decimal class defines __and__ in its own __dict__; all false.
# decimal.Decimal is a decimal floating-point type; bitwise AND is an integer
# operation and is not part of the Decimal arithmetic protocol.
# ---------------------------------------------------------------------------

table dc3211.and_:
  description: "decimal types __and__ dict-presence checks; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3211

  columns: [id, function, args, expected]
  rows:
    - ["dc3211001", operator.contains, [decimal.Decimal.__dict__,          "__and__"], false]
    - ["dc3211002", operator.contains, [decimal.Context.__dict__,           "__and__"], false]
    - ["dc3211003", operator.contains, [decimal.DecimalException.__dict__,  "__and__"], false]
    - ["dc3211004", operator.contains, [decimal.InvalidOperation.__dict__,  "__and__"], false]
    - ["dc3211005", operator.contains, [decimal.Overflow.__dict__,          "__and__"], false]
    - ["dc3211006", operator.contains, [decimal.Underflow.__dict__,         "__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — operator.contains(Cls.__dict__, '__or__')
#
# No decimal class defines __or__ in its own __dict__; all false.
# Decimal arithmetic does not include bitwise OR; that is an integer
# operation only. decimal.Decimal is a decimal floating-point type, not an int.
# ---------------------------------------------------------------------------

