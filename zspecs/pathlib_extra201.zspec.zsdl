spec: pathlib_extra201
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib module-level structure attributes not covered by prior pathlib_extra specs."
    - "pathlib.__name__ == 'pathlib' (len=7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS."
    - "pathlib.__package__ == 'pathlib' (len=7); pathlib is a package (has __init__.py); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__module__ == 'pathlib' (len=7); the Path class is defined in the pathlib package; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__module__ == 'pathlib' (len=7); PurePath is also defined in the pathlib package; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__name__.__len__() == 4 — P(1)a(2)t(3)h(4); confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__name__.__len__() == 8 — P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__name__.__len__() == 9 — P(1)o(2)s(3)i(4)x(5)P(6)a(7)t(8)h(9); confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__name__.__len__() == 11 — W(1)i(2)n(3)d(4)o(5)w(6)s(7)P(8)a(9)t(10)h(11); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib module-level __name__ and __package__
# __name__=='pathlib'(7), __package__=='pathlib'(7)
# ---------------------------------------------------------------------------

table pathlib_extra201.module_identity:
  description: "pathlib module identity: __name__='pathlib'(7), __package__='pathlib'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmodule201

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,     pathlib.__name__.__eq__,        ["pathlib"], true, "pathlib.__name__ == 'pathlib' (len=7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS"]
    - [module_package_eq,  pathlib.__package__.__eq__,     ["pathlib"], true, "pathlib.__package__ == 'pathlib' (len=7); pathlib is a package with __init__.py; confirmed Python 3.14.3 macOS"]
    - [module_name_len,    pathlib.__name__.__len__,        [],         7,    "pathlib.__name__.__len__() == 7 — p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [module_package_len, pathlib.__package__.__len__,     [],         7,    "pathlib.__package__.__len__() == 7 — same string as __name__; confirmed Python 3.14.3 macOS"]
    - [name_eq_package,    pathlib.__name__.__eq__,         ["pathlib"], true, "pathlib.__name__ == pathlib.__package__ == 'pathlib'; both are the same string for a top-level package; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib class __module__ attributes
# Path.__module__=='pathlib'(7), PurePath.__module__=='pathlib'(7)
# ---------------------------------------------------------------------------

table pathlib_extra201.class_modules:
  description: "pathlib class __module__ attributes: Path.__module__='pathlib'(7), PurePath.__module__='pathlib'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmodule201

  columns: [id, function, args, expected, description]
  rows:
    - [path_module_eq,       pathlib.Path.__module__.__eq__,       ["pathlib"], true, "pathlib.Path.__module__ == 'pathlib' (len=7); Path is defined in the pathlib package; confirmed Python 3.14.3 macOS"]
    - [purepath_module_eq,   pathlib.PurePath.__module__.__eq__,   ["pathlib"], true, "pathlib.PurePath.__module__ == 'pathlib' (len=7); PurePath is defined in the pathlib package; confirmed Python 3.14.3 macOS"]
    - [path_module_len,      pathlib.Path.__module__.__len__,       [],         7,    "pathlib.Path.__module__.__len__() == 7; same length as the module name; confirmed Python 3.14.3 macOS"]
    - [purepath_module_len,  pathlib.PurePath.__module__.__len__,   [],         7,    "pathlib.PurePath.__module__.__len__() == 7; same length as Path.__module__; confirmed Python 3.14.3 macOS"]
    - [path_name_len,        pathlib.Path.__name__.__len__,         [],         4,    "pathlib.Path.__name__.__len__() == 4 — P(1)a(2)t(3)h(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib class name lengths — Path, PurePath, PosixPath, WindowsPath
# Path(4), PurePath(8), PosixPath(9), WindowsPath(11)
# ---------------------------------------------------------------------------

table pathlib_extra201.class_name_lengths:
  description: "pathlib class name lengths: Path(4), PurePath(8), PosixPath(9), WindowsPath(11)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmodule201

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_len,        pathlib.Path.__name__.__len__,        [], 4,  "pathlib.Path.__name__.__len__() == 4 — P(1)a(2)t(3)h(4); confirmed Python 3.14.3 macOS"]
    - [purepath_name_len,    pathlib.PurePath.__name__.__len__,    [], 8,  "pathlib.PurePath.__name__.__len__() == 8 — P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS"]
    - [posixpath_name_len,   pathlib.PosixPath.__name__.__len__,   [], 9,  "pathlib.PosixPath.__name__.__len__() == 9 — P(1)o(2)s(3)i(4)x(5)P(6)a(7)t(8)h(9); confirmed Python 3.14.3 macOS"]
    - [windowspath_name_len, pathlib.WindowsPath.__name__.__len__, [], 11, "pathlib.WindowsPath.__name__.__len__() == 11 — W(1)i(2)n(3)d(4)o(5)w(6)s(7)P(8)a(9)t(10)h(11); confirmed Python 3.14.3 macOS"]
    - [purepath_name_eq,     pathlib.PurePath.__name__.__eq__,     ["PurePath"], true, "pathlib.PurePath.__name__ == 'PurePath' (len=8); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra201.module_name_eq:
  description: "pathlib.__name__ == 'pathlib' — the module's own __name__ attribute (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra201.module_package_eq:
  description: "pathlib.__package__ == 'pathlib' — pathlib is a top-level package; __package__ equals __name__ (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra201.path_module_eq:
  description: "pathlib.Path.__module__ == 'pathlib' — the Path class is defined in the pathlib package (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra201.purepath_module_eq:
  description: "pathlib.PurePath.__module__ == 'pathlib' — PurePath is defined in the pathlib package (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra201.path_name_len:
  description: "pathlib.Path.__name__.__len__() == 4 — 'Path' has 4 characters: P(1)a(2)t(3)h(4); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra201.purepath_name_len:
  description: "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' has 8 characters: P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra201.posixpath_name_len:
  description: "pathlib.PosixPath.__name__.__len__() == 9 — 'PosixPath' has 9 characters: P(1)o(2)s(3)i(4)x(5)P(6)a(7)t(8)h(9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PosixPath.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra201.windowspath_name_len:
  description: "pathlib.WindowsPath.__name__.__len__() == 11 — 'WindowsPath' has 11 characters: W(1)i(2)n(3)d(4)o(5)w(6)s(7)P(8)a(9)t(10)h(11); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__name__.__len__
  args: []
  expected: 11
