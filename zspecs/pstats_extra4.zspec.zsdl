spec: pstats_extra4
version: ">=3.9"
backend: python_module(pstats)

docs: https://docs.python.org/3/library/profile.html#the-stats-class

provenance:
  derived_from:
    - "https://docs.python.org/3/library/profile.html#the-stats-class — Python pstats documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pstats.py"
    - "pstats.zspec.zsdl — covers Stats/__name__/__module__, FunctionProfile/__name__, StatsProfile/__name__, SortKey/__name__, Stats method __name__ (sort_stats/print_stats/print_callers/print_callees/strip_dirs)"
    - "pstats_extra.zspec.zsdl — covers Stats/__name__/__module__, FunctionProfile/__name__, StatsProfile/__name__, SortKey/__name__/__module__"
    - "pstats_extra2.zspec.zsdl — covers Stats/__bases__[0]/__name__, Stats/__qualname__, SortKey/__qualname__, SortKey member .value checks"
    - "pstats_extra3.zspec.zsdl — covers FunctionProfile/__module__/__qualname__, StatsProfile/__module__/__qualname__, FunctionProfile/__bases__[0]/__name__, StatsProfile/__bases__[0]/__name__, Stats method __qualname__ (sort_stats/print_stats/print_callers/print_callees/strip_dirs), Stats method __module__ table, SortKey.CUMULATIVE/__class__/__name__"
    - "profile_extra2.zspec.zsdl — covers SortKey member .value checks, Stats.dump_stats/__name__, Stats.add/__name__"
  notes:
    - "This spec extends pstats.zspec.zsdl through pstats_extra3.zspec.zsdl."
    - "Focus: pstats.__name__ module attribute (not covered by any prior pstats spec); base class count checks for all major classes; SortKey.__bases__.__len__; Stats.dump_stats and Stats.add __qualname__ (not covered by any prior pstats spec); Stats.add/__module__."
    - "pstats.__name__ == 'pstats' — the module-level __name__ attribute; no prior pstats spec verifies this."
    - "len(Stats.__bases__) == 1 — Stats has exactly one direct base class."
    - "len(FunctionProfile.__bases__) == 1 — FunctionProfile (dataclass) has one direct base class."
    - "len(StatsProfile.__bases__) == 1 — StatsProfile (dataclass) has one direct base class."
    - "len(SortKey.__bases__) == 1 — SortKey inherits from StrEnum (Python 3.11+) or str+Enum mix-in."
    - "Stats.dump_stats.__qualname__ == 'Stats.dump_stats' — profile_extra2 covers __name__ only; qualname not yet covered."
    - "Stats.add.__qualname__ == 'Stats.add' — profile_extra2 covers __name__ only; qualname not yet covered."
    - "Stats.add.__module__ == 'pstats' — not covered by any prior pstats or profile spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pstats.__name__ — module-level attribute
# No prior pstats spec verifies the module's own __name__ attribute.
# (profile.zspec.zsdl covers profile.__name__; pstats has no equivalent.)
# ---------------------------------------------------------------------------

invariant pstats_extra4.module_name:
  description: "pstats.__name__ == 'pstats'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pstats"]
  expected: true

# ---------------------------------------------------------------------------
# Base class count — __bases__.__len__ for all major classes
# pstats_extra2 checks Stats.__bases__[0].__name__ but not the count.
# pstats_extra3 checks FunctionProfile/StatsProfile base name but not count.
# No prior spec checks SortKey.__bases__.__len__.
# ---------------------------------------------------------------------------

invariant pstats_extra4.Stats.bases_len:
  description: "len(pstats.Stats.__bases__) == 1 — Stats has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: Stats.__bases__.__len__
  args: []
  expected: 1

invariant pstats_extra4.FunctionProfile.bases_len:
  description: "len(pstats.FunctionProfile.__bases__) == 1 — FunctionProfile has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: FunctionProfile.__bases__.__len__
  args: []
  expected: 1

invariant pstats_extra4.StatsProfile.bases_len:
  description: "len(pstats.StatsProfile.__bases__) == 1 — StatsProfile has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: StatsProfile.__bases__.__len__
  args: []
  expected: 1

invariant pstats_extra4.SortKey.bases_len:
  description: "len(pstats.SortKey.__bases__) == 1 — SortKey has exactly one direct base class (StrEnum or equivalent)"
  category: hierarchy
  kind: python_call_eq
  function: SortKey.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Stats.dump_stats and Stats.add __qualname__ checks
# profile_extra2.zspec.zsdl (pstats backend) covers __name__ for dump_stats and add.
# No prior spec covers __qualname__ for these two methods.
# pstats_extra3 covers __qualname__ for sort_stats/print_stats/print_callers/print_callees/strip_dirs only.
# ---------------------------------------------------------------------------

invariant pstats_extra4.Stats.dump_stats.qualname:
  description: "pstats.Stats.dump_stats.__qualname__ == 'Stats.dump_stats'"
  category: method_qualnames
  kind: python_call_eq
  function: Stats.dump_stats.__qualname__.__eq__
  args: ["Stats.dump_stats"]
  expected: true

invariant pstats_extra4.Stats.add.qualname:
  description: "pstats.Stats.add.__qualname__ == 'Stats.add'"
  category: method_qualnames
  kind: python_call_eq
  function: Stats.add.__qualname__.__eq__
  args: ["Stats.add"]
  expected: true

# ---------------------------------------------------------------------------
# Stats.add.__module__ check
# pstats_extra3 covers __module__ for sort_stats/print_stats/print_callers/print_callees/strip_dirs.
# Stats.dump_stats and Stats.add are missing from that table — add them here.
# ---------------------------------------------------------------------------

invariant pstats_extra4.Stats.add.module:
  description: "pstats.Stats.add.__module__ == 'pstats'"
  category: method_modules
  kind: python_call_eq
  function: Stats.add.__module__.__eq__
  args: ["pstats"]
  expected: true

invariant pstats_extra4.Stats.dump_stats.module:
  description: "pstats.Stats.dump_stats.__module__ == 'pstats'"
  category: method_modules
  kind: python_call_eq
  function: Stats.dump_stats.__module__.__eq__
  args: ["pstats"]
  expected: true

# ---------------------------------------------------------------------------
# SortKey.__module__ type check — the module string is a str
# pstats_extra.zspec.zsdl covers SortKey.__module__ value == 'pstats'.
# This adds a type-axis check: SortKey.__module__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant pstats_extra4.SortKey.module_is_str:
  description: "pstats.SortKey.__module__.__class__.__name__ == 'str' — __module__ attribute is a str"
  category: class_attrs
  kind: python_call_eq
  function: SortKey.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
