spec: dc3436
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 676 (dc3436): __le__, __gt__, __ge__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __le__/__gt__/__ge__ dict-presence (x<=y, x>y, x>=y)."
    - "decimal.Decimal defines __le__, __gt__, __ge__ (all true): Decimal supports full numeric ordering."
    - "decimal.Context does NOT define __le__, __gt__, or __ge__ in its own __dict__: Context is a precision/rounding configuration object."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no ordering protocol defined in their own __dict__."
    - "decimal.Decimal is unique among the covered types in this wave: it is the only type defining __le__, __gt__, and __ge__ (all true), reflecting its status as a complete numeric type with rich comparison semantics."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
#
# decimal.Decimal DOES define __le__ in its own __dict__: true.
# Decimal objects support <= numeric ordering via __le__.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3436.le:
  description: "decimal types __le__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3436

  columns: [id, function, args, expected]
  rows:
    - ["dc3436001", operator.contains, [decimal.Decimal.__dict__,          "__le__"], true]
    - ["dc3436002", operator.contains, [decimal.Context.__dict__,           "__le__"], false]
    - ["dc3436003", operator.contains, [decimal.DecimalException.__dict__,  "__le__"], false]
    - ["dc3436004", operator.contains, [decimal.InvalidOperation.__dict__,  "__le__"], false]
    - ["dc3436005", operator.contains, [decimal.Overflow.__dict__,          "__le__"], false]
    - ["dc3436006", operator.contains, [decimal.Underflow.__dict__,         "__le__"], false]

