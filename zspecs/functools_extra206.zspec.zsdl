spec: functools_extra206
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers __dict__ structure and __code__.co_name identity for public functools callables."
    - "functools.__dict__.__class__.__name__ == 'dict' — module __dict__ is a plain dict. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__.__name__ == '__contains__' — the bound method name is '__contains__'. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__.__class__.__name__ == 'builtin_function_or_method' — dict.__contains__ is a builtin_function_or_method. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__class__.__name__ == 'mappingproxy' — C-level type __dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_name == 'lru_cache' — Python decorator factory; co_name matches def name. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_name == 'wraps' — Python decorator helper; co_name matches def name. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_name == 'update_wrapper' — Python helper function; co_name matches def name. Verified with Python 3.14.3."
    - "functools.cache.__code__.co_name == 'cache' — Python function (simple LRU wrapper); co_name matches def name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools module __dict__ structural identity
#
# functools.__dict__.__class__.__name__ == 'dict'
# functools.__dict__.__contains__.__name__ == '__contains__'
# functools.__dict__.__contains__.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table functools_extra206.dict_structure:
  description: "functools.__dict__ structure: class name 'dict', __contains__ name and class identity; new to extra206"
  kind: python_call_eq
  category: dict_structure
  id_prefix: functconames206

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_class_name,
       "__dict__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.__dict__.__class__.__name__.__eq__('dict') == True — module-level __dict__ is a plain dict; __class__.__name__ is 'dict'; new to extra206"]
    - [dict_contains_method_name,
       "__dict__.__contains__.__name__.__eq__",
       ["__contains__"],
       true,
       "functools.__dict__.__contains__.__name__.__eq__('__contains__') == True — dict __contains__ bound method name is '__contains__'; new to extra206"]
    - [dict_contains_class_name,
       "__dict__.__contains__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.__dict__.__contains__.__class__.__name__.__eq__('builtin_function_or_method') == True — dict.__contains__ is a builtin_function_or_method; new to extra206"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial __dict__ and Python function __code__.co_name
#
# functools.partial.__dict__.__class__.__name__ == 'mappingproxy' (C-level type)
# functools.lru_cache.__code__.co_name == 'lru_cache'
# functools.wraps.__code__.co_name == 'wraps'
# ---------------------------------------------------------------------------

table functools_extra206.partial_dict_and_conames:
  description: "functools.partial.__dict__ is mappingproxy; lru_cache and wraps co_name identity; new to extra206"
  kind: python_call_eq
  category: conames
  id_prefix: functconames206

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_class_mappingproxy,
       partial.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.partial.__dict__.__class__.__name__.__eq__('mappingproxy') == True — partial is a C-level type; its __dict__ is a mappingproxy; new to extra206"]
    - [lru_cache_co_name,
       lru_cache.__code__.co_name.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — lru_cache is a Python decorator factory; __code__.co_name == 'lru_cache'; new to extra206"]
    - [wraps_co_name,
       wraps.__code__.co_name.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__code__.co_name.__eq__('wraps') == True — wraps is a Python decorator helper; __code__.co_name == 'wraps'; new to extra206"]

# ---------------------------------------------------------------------------
# Table 3: functools Python function __code__.co_name for helpers
#
# functools.update_wrapper.__code__.co_name == 'update_wrapper'
# functools.cache.__code__.co_name == 'cache'
# functools.total_ordering.__code__.co_name == 'total_ordering' (bonus)
# ---------------------------------------------------------------------------

table functools_extra206.helper_conames:
  description: "functools update_wrapper, cache, total_ordering __code__.co_name identity; new to extra206"
  kind: python_call_eq
  category: conames
  id_prefix: functconames206

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_co_name,
       update_wrapper.__code__.co_name.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — update_wrapper is a Python function; __code__.co_name == 'update_wrapper'; new to extra206"]
    - [cache_co_name,
       cache.__code__.co_name.__eq__,
       ["cache"],
       true,
       "functools.cache.__code__.co_name.__eq__('cache') == True — cache is a Python function (simple LRU alias); __code__.co_name == 'cache'; new to extra206"]
    - [total_ordering_co_name,
       total_ordering.__code__.co_name.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering is a Python class decorator; __code__.co_name == 'total_ordering'; new to extra206"]

