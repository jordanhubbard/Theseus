spec: itertools_extra282
version: ">=3.1"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.zip_longest raises TypeError immediately when passed a non-iterable argument (unlike chain, which defers)."
    - "zip_longest is a C-level type: __class__.__name__ == 'type', __module__ == 'itertools', __name__ == 'zip_longest'."
    - "itertools.chain is a C-level type: __class__.__name__ == 'type', __module__ == 'itertools', __name__ == 'chain'."
    - "itertools.accumulate is a C-level type: __class__.__name__ == 'type', __module__ == 'itertools', __name__ == 'accumulate'."
    - "itertools.__doc__ is not None — the module ships with a top-level docstring."
    - "chain.__doc__, accumulate.__doc__, zip_longest.__doc__ are all not None."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.zip_longest — TypeError on non-iterable arguments
#
# zip_longest raises TypeError immediately when a non-iterable is passed,
# unlike chain() which defers the error until iteration.
# ---------------------------------------------------------------------------

table itertools_extra282.zip_longest_non_iterable_raises:
  description: "itertools.zip_longest raises TypeError immediately for non-iterable arguments; verified with Python 3.14.3"
  kind: python_call_raises
  category: error_cases
  id_prefix: itex282zr

  columns: [id, function, args, expected, description]
  rows:
    - [zr_int,       zip_longest, [42],    TypeError, "zip_longest(42) raises TypeError — int is not iterable; verified with Python 3.14.3"]
    - [zr_float,     zip_longest, [3.14],  TypeError, "zip_longest(3.14) raises TypeError — float is not iterable; verified with Python 3.14.3"]
    - [zr_bool,      zip_longest, [false], TypeError, "zip_longest(False) raises TypeError — bool is not iterable; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.chain, accumulate, zip_longest — C-level type identities
#
# chain.__name__ == 'chain' (5 chars); accumulate.__name__ == 'accumulate' (10 chars).
# zip_longest.__name__ == 'zip_longest' (11 chars).
# All three are C-level types with __module__ == 'itertools'.
# All three ship with non-None docstrings.
# ---------------------------------------------------------------------------

table itertools_extra282.c_type_identities:
  description: "itertools.chain, accumulate, zip_longest — C-level type identities and docstrings; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex282ci

  columns: [id, function, args, expected, description]
  rows:
    - [ci_chain_name,  chain.__name__.__eq__,             ["chain"],       true,  "itertools.chain.__name__ == 'chain'; verified with Python 3.14.3"]
    - [ci_chain_len,   chain.__name__.__len__,             [],              5,     "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 chars; verified with Python 3.14.3"]
    - [ci_chain_cls,   chain.__class__.__name__.__eq__,    ["type"],        true,  "itertools.chain.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [ci_chain_doc,   chain.__doc__.__eq__,               [null],          false, "itertools.chain.__doc__ is not None — chain ships with a docstring; verified with Python 3.14.3"]
    - [ci_acc_name,    accumulate.__name__.__eq__,         ["accumulate"],  true,  "itertools.accumulate.__name__ == 'accumulate'; verified with Python 3.14.3"]
    - [ci_acc_len,     accumulate.__name__.__len__,        [],              10,    "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 chars; verified with Python 3.14.3"]
    - [ci_acc_cls,     accumulate.__class__.__name__.__eq__, ["type"],      true,  "itertools.accumulate.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [ci_acc_doc,     accumulate.__doc__.__eq__,          [null],          false, "itertools.accumulate.__doc__ is not None — accumulate ships with a docstring; verified with Python 3.14.3"]
    - [ci_zl_name,     zip_longest.__name__.__eq__,        ["zip_longest"], true,  "itertools.zip_longest.__name__ == 'zip_longest'; verified with Python 3.14.3"]
    - [ci_zl_len,      zip_longest.__name__.__len__,       [],              11,    "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 chars; verified with Python 3.14.3"]
    - [ci_zl_cls,      zip_longest.__class__.__name__.__eq__, ["type"],     true,  "itertools.zip_longest.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [ci_zl_doc,      zip_longest.__doc__.__eq__,         [null],          false, "itertools.zip_longest.__doc__ is not None — zip_longest ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra282
# ---------------------------------------------------------------------------

invariant itertools_extra282.zip_longest_int_raises_typeerror:
  description: "itertools.zip_longest(42) raises TypeError — int is not iterable (error is immediate, not deferred)"
  category: error_cases
  kind: python_call_raises
  function: zip_longest
  args: [42]
  raises: TypeError

invariant itertools_extra282.module_has_docstring:
  description: "itertools.__doc__.__eq__(None) == False — the itertools module ships with a non-None top-level docstring"
  category: identity
  kind: python_call_eq
  function: __doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra282.chain_has_docstring:
  description: "itertools.chain.__doc__.__eq__(None) == False — chain ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: chain.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra282.chain_is_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C-level type, not a function"
  category: identity
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra282.chain_module_is_itertools:
  description: "itertools.chain.__module__ == 'itertools' — chain is registered in the itertools module"
  category: identity
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra282.accumulate_has_docstring:
  description: "itertools.accumulate.__doc__.__eq__(None) == False — accumulate ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: accumulate.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra282.accumulate_is_type:
  description: "itertools.accumulate.__class__.__name__ == 'type' — accumulate is a C-level type, not a function"
  category: identity
  kind: python_call_eq
  function: accumulate.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra282.zip_longest_has_docstring:
  description: "itertools.zip_longest.__doc__.__eq__(None) == False — zip_longest ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: zip_longest.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra282.zip_longest_name_length_is_11:
  description: "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 characters"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11
