spec: theseus_decimal_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_decimal_cr3)
blocks: decimal

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
  notes:
    - "Clean-room extended decimal utilities. Do NOT import decimal."
    - "Context(prec=28, rounding='ROUND_HALF_EVEN'): decimal arithmetic context."
    - "localcontext(ctx=None): context manager for a local decimal context."
    - "getcontext(): return current thread-local decimal context."
    - "setcontext(ctx): set current thread-local context."
    - "decimal3_context_prec(): Context(prec=10).prec == 10."
    - "decimal3_getcontext_type(): isinstance(getcontext(), Context) == True."
    - "decimal3_decimal_in_context(): with localcontext(Context(prec=5)): Decimal('1')/Decimal('3') has ≤5 significant digits."
    - "Implement Context with prec, rounding attributes; getcontext returns default Context."
    - "Use threading.local for thread-local context storage (import threading allowed)."
    - "Export: Context, localcontext, getcontext, setcontext, Decimal (from theseus_decimal_cr2)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_decimal_cr3.context_prec:
  description: "Context(prec=10).prec == 10"
  category: context
  kind: python_call_eq
  function: decimal3_context_prec
  args: []
  expected: 10

invariant theseus_decimal_cr3.getcontext_type:
  description: "isinstance(getcontext(), Context) == True"
  category: context
  kind: python_call_eq
  function: decimal3_getcontext_type
  args: []
  expected: true

invariant theseus_decimal_cr3.decimal_in_context:
  description: "Decimal in local context uses context precision"
  category: context
  kind: python_call_eq
  function: decimal3_decimal_in_context
  args: []
  expected: true
