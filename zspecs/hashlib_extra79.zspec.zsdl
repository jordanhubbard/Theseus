spec: hashlib_extra79
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra78.zspec.zsdl — covers sha3_256/sha3_512/__module__=='_hashlib' / sha3_224/sha3_384/__class__/__name__=='builtin_function_or_method' / shake_128/shake_256/__module__=='_hashlib' / sha3_256/sha3_512/shake_256/__class__/__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib_extra77.zspec.zsdl — covers blake2b/__name__/__module__/__bases__[0]/__mro__.__len__() / blake2b/__doc__.__class__.__name__ / blake2s/__name__/__module__/__bases__[0]/__mro__.__len__() (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra78; it does NOT duplicate invariants present in those files."
    - "Wave 243 theme: hashlib blake2b/blake2s __dict__ content and method class identity."
    - "hashlib.blake2b.__dict__.__contains__('copy') == True — blake2b defines copy() as a method_descriptor in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('update') == True — blake2b defines update() as a method_descriptor in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('digest') == True — blake2b defines digest() as a method_descriptor in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('hexdigest') == True — blake2b defines hexdigest() as a method_descriptor in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('SALT_SIZE') == True — blake2b defines SALT_SIZE as a class-level constant in its __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('copy') == True — blake2s defines copy() as a method_descriptor in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('update') == True — blake2s defines update() as a method_descriptor in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('digest') == True — blake2s defines digest() as a method_descriptor in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.copy.__class__.__name__ == 'method_descriptor' — blake2b.copy is a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.update.__class__.__name__ == 'method_descriptor' — blake2b.update is a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.digest.__class__.__name__ == 'method_descriptor' — blake2b.digest is a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__ for copy, update, digest, hexdigest
#
# Wave 243 theme: blake2b __dict__ content.
#
# hashlib.blake2b is a C extension type defining copy, update, digest, and
# hexdigest as method_descriptors in its class __dict__. No prior hashlib spec
# checks blake2b.__dict__.__contains__ for any of these methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra79.blake2b_dict_methods:
  description: "hashlib.blake2b/__dict__.__contains__('copy')==True / __contains__('update')==True / __contains__('digest')==True / __contains__('hexdigest')==True — blake2b defines copy/update/digest/hexdigest as method_descriptors in its class __dict__; no prior hashlib spec checks blake2b.__dict__.__contains__ for any of these methods; first __dict__ method content anchor for blake2b"
  kind: python_call_eq
  category: class_dict
  id_prefix: hashlibmore79

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_has_copy,     blake2b.__dict__.__contains__, ["copy"],      true]
    - [blake2b_dict_has_update,   blake2b.__dict__.__contains__, ["update"],    true]
    - [blake2b_dict_has_digest,   blake2b.__dict__.__contains__, ["digest"],    true]
    - [blake2b_dict_has_hexdigest, blake2b.__dict__.__contains__, ["hexdigest"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__('SALT_SIZE')
#
# Wave 243 theme: blake2b class-level constants in __dict__.
#
# hashlib.blake2b defines SALT_SIZE as a class-level constant in its __dict__.
# SALT_SIZE is directly accessible as an integer attribute on the class.
# No prior hashlib spec checks blake2b.__dict__.__contains__('SALT_SIZE').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra79.blake2b_dict_constants:
  description: "hashlib.blake2b/__dict__.__contains__('SALT_SIZE')==True — blake2b defines SALT_SIZE as a class-level constant in its __dict__; no prior hashlib spec checks blake2b.__dict__.__contains__('SALT_SIZE'); first SALT_SIZE dict contains anchor for blake2b"
  kind: python_call_eq
  category: class_dict
  id_prefix: hashlibmore79

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_has_SALT_SIZE, blake2b.__dict__.__contains__, ["SALT_SIZE"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2s.__dict__.__contains__ for copy, update, digest
#
# Wave 243 theme: blake2s __dict__ content.
#
# hashlib.blake2s is a C extension type defining copy, update, and digest as
# method_descriptors in its class __dict__. No prior hashlib spec checks
# blake2s.__dict__.__contains__ for any method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra79.blake2s_dict_methods:
  description: "hashlib.blake2s/__dict__.__contains__('copy')==True / __contains__('update')==True / __contains__('digest')==True — blake2s defines copy/update/digest as method_descriptors in its class __dict__; no prior hashlib spec checks blake2s.__dict__.__contains__ for any method; first __dict__ method content anchor for blake2s"
  kind: python_call_eq
  category: class_dict
  id_prefix: hashlibmore79

  columns: [id, function, args, expected]
  rows:
    - [blake2s_dict_has_copy,   blake2s.__dict__.__contains__, ["copy"],   true]
    - [blake2s_dict_has_update, blake2s.__dict__.__contains__, ["update"], true]
    - [blake2s_dict_has_digest, blake2s.__dict__.__contains__, ["digest"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b method __class__.__name__ == 'method_descriptor'
#
# Wave 243 theme: blake2b method class identity.
#
# hashlib.blake2b.copy, .update, and .digest are all C method_descriptors.
# Their __class__.__name__ is 'method_descriptor'. No prior hashlib spec
# checks blake2b.copy/__class__/__name__, blake2b.update/__class__/__name__,
# or blake2b.digest/__class__/__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra79.blake2b_method_class_name:
  description: "hashlib.blake2b.copy/__class__/__name__.__eq__('method_descriptor')==True / blake2b.update/__class__/__name__.__eq__('method_descriptor')==True / blake2b.digest/__class__/__name__.__eq__('method_descriptor')==True — copy/update/digest are C method_descriptors on blake2b; no prior hashlib spec checks __class__.__name__ for blake2b.copy/update/digest; first method class identity anchor for blake2b methods"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore79

  columns: [id, function, args, expected]
  rows:
    - [blake2b_copy_class_method_descriptor,   blake2b.copy.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [blake2b_update_class_method_descriptor, blake2b.update.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [blake2b_digest_class_method_descriptor, blake2b.digest.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__('copy') — standalone
#
# blake2b defines copy in its class __dict__. No prior hashlib spec checks
# blake2b.__dict__.__contains__('copy') as a standalone. First copy dict
# contains standalone for blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra79.blake2b_dict_has_copy:
  description: "hashlib.blake2b.__dict__.__contains__('copy') == True — blake2b defines copy as a method_descriptor in its class __dict__; no prior hashlib spec checks blake2b.__dict__.__contains__('copy') as a standalone; first copy dict contains standalone for blake2b"
  category: class_dict
  kind: python_call_eq
  function: blake2b.__dict__.__contains__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__contains__('SALT_SIZE') — standalone
#
# blake2b defines SALT_SIZE as a class-level constant in its __dict__. No
# prior hashlib spec checks blake2b.__dict__.__contains__('SALT_SIZE') as a
# standalone. First SALT_SIZE dict contains standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra79.blake2b_dict_has_SALT_SIZE:
  description: "hashlib.blake2b.__dict__.__contains__('SALT_SIZE') == True — blake2b defines SALT_SIZE as a class-level constant in its __dict__; no prior hashlib spec checks blake2b.__dict__.__contains__('SALT_SIZE') as a standalone; first SALT_SIZE dict contains standalone for blake2b"
  category: class_dict
  kind: python_call_eq
  function: blake2b.__dict__.__contains__
  args: ["SALT_SIZE"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy.__class__.__name__.__eq__('method_descriptor') — standalone
#
# blake2b.copy is a C method_descriptor. No prior hashlib spec checks
# blake2b.copy.__class__.__name__. First method class identity standalone for
# blake2b.copy. Verified Python 3.14.3 macOS/Darwin 25.4.0.
