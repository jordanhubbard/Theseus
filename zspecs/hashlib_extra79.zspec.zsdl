invariant hashlib_extra79.blake2b_copy_class_method_descriptor:
  description: "hashlib.blake2b.copy.__class__.__name__.__eq__('method_descriptor') == True — blake2b.copy is a C method_descriptor; no prior hashlib spec checks blake2b.copy.__class__.__name__; first method class identity standalone for blake2b.copy"
  category: class_identity
  kind: python_call_eq
  function: blake2b.copy.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.update.__class__.__name__.__eq__('method_descriptor') — standalone
#
# blake2b.update is a C method_descriptor. No prior hashlib spec checks
# blake2b.update.__class__.__name__. First method class identity standalone for
# blake2b.update. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra79.blake2b_update_class_method_descriptor:
  description: "hashlib.blake2b.update.__class__.__name__.__eq__('method_descriptor') == True — blake2b.update is a C method_descriptor; no prior hashlib spec checks blake2b.update.__class__.__name__; first method class identity standalone for blake2b.update"
  category: class_identity
  kind: python_call_eq
  function: blake2b.update.__class__.__name__.__eq__
