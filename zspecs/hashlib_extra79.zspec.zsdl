invariant hashlib_extra79.blake2b_digest_class_method_descriptor:
  description: "hashlib.blake2b.digest.__class__.__name__.__eq__('method_descriptor') == True — blake2b.digest is a C method_descriptor; no prior hashlib spec checks blake2b.digest.__class__.__name__; first method class identity standalone for blake2b.digest"
  category: class_identity
  kind: python_call_eq
  function: blake2b.digest.__class__.__name__.__eq__
  args: ["method_descriptor"]
