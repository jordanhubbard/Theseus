# ---------------------------------------------------------------------------
# hashlib.blake2b.digest.__class__.__name__.__eq__('method_descriptor') — standalone
#
# blake2b.digest is a C method_descriptor. No prior hashlib spec checks
# blake2b.digest.__class__.__name__. First method class identity standalone for
