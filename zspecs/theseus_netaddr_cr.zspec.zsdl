spec: theseus_netaddr_cr
version: ">=3.9"
backend: python_cleanroom(theseus_netaddr_cr)
blocks: ipaddress

docs: https://docs.python.org/3/library/ipaddress.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html"
  notes:
    - "Clean-room network address utilities (IPv4Network/IPv6Network). Do NOT import ipaddress."
    - "IPv4Network('192.168.1.0/24'): network with network_address, broadcast_address, prefixlen."
    - "IPv6Network('::1/128'): IPv6 network."
    - "network_address: first address in the network."
    - "broadcast_address: last address (all host bits set)."
    - "netaddr_v4_prefixlen(): IPv4Network('10.0.0.0/8').prefixlen == 8."
    - "netaddr_v4_broadcast(): IPv4Network('192.168.1.0/24').broadcast_address == '192.168.1.255'."
    - "netaddr_v4_contains(): IPv4Address('10.0.0.5') in IPv4Network('10.0.0.0/8')."
    - "Export: IPv4Network, IPv6Network (supplementing existing theseus_ipaddress)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_netaddr_cr.v4_prefixlen:
  description: "IPv4Network('10.0.0.0/8').prefixlen == 8"
  category: network
  kind: python_call_eq
  function: netaddr_v4_prefixlen
  args: []
  expected: 8

invariant theseus_netaddr_cr.v4_broadcast:
  description: "IPv4Network('192.168.1.0/24').broadcast_address == '192.168.1.255'"
  category: network
  kind: python_call_eq
  function: netaddr_v4_broadcast
  args: []
  expected: "192.168.1.255"

invariant theseus_netaddr_cr.v4_contains:
  description: "IPv4Address('10.0.0.5') in IPv4Network('10.0.0.0/8')"
  category: contains
  kind: python_call_eq
  function: netaddr_v4_contains
  args: []
  expected: true
