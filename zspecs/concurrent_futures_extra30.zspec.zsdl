spec: concurrent_futures_extra30
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/exceptions.html — Python built-in exceptions"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra29.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values, class __module__/__name__/__len__() tables, ThreadPoolExecutor submit/shutdown qualname lens, ProcessPoolExecutor submit/shutdown qualname lens, Executor.map/submit/shutdown qualname lens, Future method qualname lens for result/add_done_callback/cancel/done/exception/set_result/set_exception/running/set_running_or_notify_cancel, class __dict__.__class__.__name__.__len__() for Future/ThreadPoolExecutor/ProcessPoolExecutor/Executor/BrokenExecutor/CancelledError, as_completed/wait __module__.__len__(), __all__.__len__() == 14, __mro__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor, __bases__[0].__name__.__len__() for all four, Executor context manager __enter__/__exit__ qualname lens."
    - "This spec covers: InvalidStateError/__name__.__len__()==17, InvalidStateError/__module__.__len__()==24, InvalidStateError/__mro__.__len__()==5, InvalidStateError/__bases__[0].__name__.__len__()==5 ('Error'); as_completed/__name__.__len__()==12, wait/__name__.__len__()==4; FIRST_COMPLETED/__len__()==15, FIRST_EXCEPTION/__len__()==15, ALL_COMPLETED/__len__()==13; Executor.__enter__/__qualname__.__len__()==18, Executor.__exit__/__qualname__.__len__()==17."
    - "InvalidStateError.__mro__ == (InvalidStateError, Error, Exception, BaseException, object) — MRO depth 5."
    - "InvalidStateError.__bases__[0].__name__ == 'Error' (5 chars) — subclasses the internal concurrent.futures._base.Error class."
    - "FIRST_COMPLETED and FIRST_EXCEPTION are both 15-character strings; ALL_COMPLETED is 13 characters."
    - "as_completed.__name__ == 'as_completed' (12 chars); wait.__name__ == 'wait' (4 chars) — matching their __qualname__ lengths from extra27."
    - "Executor.__enter__ and ThreadPoolExecutor.__enter__ are the same object — TPE inherits context manager support directly from Executor."
    - "Executor.__enter__.__qualname__ == 'Executor.__enter__' (18 chars); Executor.__exit__.__qualname__ == 'Executor.__exit__' (17 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.InvalidStateError class identity — extra30 namespace
#
# InvalidStateError is rarely examined in prior specs. Its key attributes:
#   InvalidStateError.__name__.__len__()             == 17 ('InvalidStateError')
#   InvalidStateError.__module__.__len__()            == 24 ('concurrent.futures._base')
#   InvalidStateError.__mro__.__len__()               == 5  — (InvalidStateError, Error, Exception, BaseException, object)
#   InvalidStateError.__bases__[0].__name__.__len__() == 5  ('Error' — internal _base.Error)
# The MRO depth of 5 is the deepest among concurrent.futures exception classes,
# one entry longer than BrokenExecutor/CancelledError/TimeoutError (also 5)
# but through a different Error intermediate class.
# No prior spec has measured InvalidStateError's name length, module length,
# MRO depth, or base class name length.
# ---------------------------------------------------------------------------

table concurrent_futures_extra30.invalidstateerror_identity:
  description: "concurrent.futures.InvalidStateError class identity lengths in extra30 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: iserident30

  columns: [id, function, args, expected]
  rows:
    - [name_len,   InvalidStateError.__name__.__len__,   [], 17]
    - [module_len, InvalidStateError.__module__.__len__,  [], 24]

table concurrent_futures_extra30.invalidstateerror_hierarchy:
  description: "concurrent.futures.InvalidStateError __mro__.__len__() and __bases__[0].__name__.__len__() in extra30 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iserhier30

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [mro_len,
       InvalidStateError.__mro__,
       [],
       !ascii "",
       __len__,
       [],
       "InvalidStateError MRO depth == 5 — (InvalidStateError, Error, Exception, BaseException, object)"]

invariant concurrent_futures_extra30.InvalidStateError_base_name_len:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__name__.__len__() == 5 — base is the internal 'Error' class"
  category: class_hierarchy
  kind: python_call_eq
  function: "InvalidStateError.__bases__[0].__name__.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# concurrent.futures module-level function name lengths — extra30 namespace
#
# The two top-level iterator functions have very different name lengths:
#   as_completed.__name__.__len__() == 12 ('as_completed')
#   wait.__name__.__len__()         == 4  ('wait')
# These __name__ lengths equal their __qualname__ lengths (already measured
# in extra27 as __qualname__); this table captures the __name__ angle
# which was not separately recorded.
# ---------------------------------------------------------------------------

table concurrent_futures_extra30.function_name_lengths:
  description: "concurrent.futures top-level function __name__.__len__() for as_completed/wait in extra30 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: funcnamelen30

  columns: [id, function, args, expected]
  rows:
    - [as_completed, as_completed.__name__.__len__, [], 12]
    - [wait,         wait.__name__.__len__,         [], 4]

# ---------------------------------------------------------------------------
# FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED string lengths — extra30
#
# The three sentinel constants used with concurrent.futures.wait() are strings:
#   FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' (15 chars)
#   FIRST_EXCEPTION.__len__() == 15 — 'FIRST_EXCEPTION' (15 chars)
#   ALL_COMPLETED.__len__()   == 13 — 'ALL_COMPLETED'  (13 chars)
# FIRST_COMPLETED and FIRST_EXCEPTION are the same length; ALL_COMPLETED
# is 2 characters shorter. No prior spec has measured these string lengths.
# ---------------------------------------------------------------------------

table concurrent_futures_extra30.wait_sentinel_lengths:
  description: "concurrent.futures wait sentinel string __len__() for FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED in extra30 namespace"
  kind: python_call_eq
  category: module_structure
  id_prefix: sentinellen30

  columns: [id, function, args, expected]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__len__, [], 15]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__len__, [], 15]
    - [ALL_COMPLETED,   ALL_COMPLETED.__len__,   [], 13]

# ---------------------------------------------------------------------------
# Executor context manager method __qualname__ lengths — extra30 namespace
#
# Executor defines __enter__ and __exit__ for context manager support.
# Both ThreadPoolExecutor and ProcessPoolExecutor inherit them from Executor.
#   Executor.__enter__.__qualname__ == 'Executor.__enter__' (18 chars)
#   Executor.__exit__.__qualname__  == 'Executor.__exit__'  (17 chars)
# __exit__ is one character shorter because 'exit' (4) is shorter than
# 'enter' (5). The extra29 spec covered these in a narrative note but did
# not create a table row or invariant for them. This table adds that coverage.
# ---------------------------------------------------------------------------

table concurrent_futures_extra30.executor_context_method_qualname_lengths:
  description: "Executor context manager method __qualname__.__len__() for __enter__/__exit__ in extra30 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execctxmqualnamelen30

  columns: [id, function, args, expected]
  rows:
    - [enter, Executor.__enter__.__qualname__.__len__, [], 18]
    - [exit,  Executor.__exit__.__qualname__.__len__,  [], 17]

# ---------------------------------------------------------------------------
# Standalone invariants — extra30
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra30.FIRST_COMPLETED_len:
  description: "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' is fifteen characters"
  category: module_structure
  kind: python_call_eq
  function: FIRST_COMPLETED.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra30.ALL_COMPLETED_len:
  description: "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 'ALL_COMPLETED' is thirteen characters, shorter than FIRST_* constants"
  category: module_structure
  kind: python_call_eq
  function: ALL_COMPLETED.__len__
  args: []
  expected: 13

invariant concurrent_futures_extra30.as_completed_name_len:
  description: "concurrent.futures.as_completed.__name__.__len__() == 12 — 'as_completed' has twelve characters"
  category: function_names
  kind: python_call_eq
  function: as_completed.__name__.__len__
  args: []
  expected: 12
