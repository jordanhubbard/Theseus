spec: is_fullwidth_code_point
version: ">=5.1.0"
backend: node(is-fullwidth-code-point)

docs: https://www.npmjs.com/package/is-fullwidth-code-point

provenance:
  derived_from:
    - "is-fullwidth-code-point README — https://www.npmjs.com/package/is-fullwidth-code-point"
    - "Test vectors verified with is-fullwidth-code-point via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-fullwidth-code-point source"
  notes:
    - "is-fullwidth-code-point is an npm package. Install: npm install is-fullwidth-code-point"
    - "Returns true for Unicode code points that occupy two terminal columns (CJK, fullwidth forms)."
    - "Pass the codepoint as an integer. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_fullwidth_code_point.isFullwidth:
  kind: node_module_call_eq
  function: "default"
  category: predicate
  id_prefix: isfwcp

  columns: [id, args, expected]
  rows:
    - [cjk_char,   [19981],  true]
    - [ascii_A,    [65],     false]
    - [ascii_z,    [122],    false]
