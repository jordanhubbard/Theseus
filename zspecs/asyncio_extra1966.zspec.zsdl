spec: asyncio_extra1966
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Lock, Semaphore, Condition inherit __aenter__/__aexit__ from _ContextManagerMixin — not in their own __dict__."
    - "asyncio.Timeout, TaskGroup, Barrier define __aenter__/__aexit__ directly in their own __dict__."
    - "asyncio.Task and asyncio.Future define __del__ for unawaited-task cleanup logging."
    - "asyncio.StreamWriter defines __del__ for close-without-drain warning."
    - "No asyncio class defines synchronous __enter__/__exit__ in its own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

table asyncio_extra1966.sync_enter_protocol:
  description: "asyncio types __enter__ dict-presence — none define __enter__ directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1966

  columns: [id, function, args, expected]
  rows:
    - ["as1966001", "asyncio.Lock.__dict__.__contains__",          ["__enter__"], false]
    - ["as1966002", "asyncio.Event.__dict__.__contains__",         ["__enter__"], false]
    - ["as1966003", "asyncio.Semaphore.__dict__.__contains__",     ["__enter__"], false]
    - ["as1966004", "asyncio.Condition.__dict__.__contains__",     ["__enter__"], false]
    - ["as1966005", "asyncio.Queue.__dict__.__contains__",         ["__enter__"], false]
    - ["as1966006", "asyncio.Task.__dict__.__contains__",          ["__enter__"], false]
    - ["as1966007", "asyncio.Future.__dict__.__contains__",        ["__enter__"], false]
    - ["as1966008", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__enter__"], false]
    - ["as1966009", "asyncio.Timeout.__dict__.__contains__",       ["__enter__"], false]
    - ["as1966010", "asyncio.TaskGroup.__dict__.__contains__",     ["__enter__"], false]

