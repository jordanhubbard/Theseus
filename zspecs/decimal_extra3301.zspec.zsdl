    - ["dc3301002", operator.contains, [decimal.Context.__dict__,           "__itruediv__"], false]
    - ["dc3301003", operator.contains, [decimal.DecimalException.__dict__,  "__itruediv__"], false]
    - ["dc3301004", operator.contains, [decimal.InvalidOperation.__dict__,  "__itruediv__"], false]
    - ["dc3301005", operator.contains, [decimal.Overflow.__dict__,          "__itruediv__"], false]
    - ["dc3301006", operator.contains, [decimal.Underflow.__dict__,         "__itruediv__"], false]

