spec: sqlite3_extra4
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_sqlite/module.c"
  notes:
    - "This spec extends prior sqlite3 specs."
    - "Focus: exception class names, constants, and Row/Connection/Cursor class names."
    - "sqlite3.sqlite_version.__class__.__name__ == 'str'."
    - "sqlite3.version.__class__.__name__ == 'str'."
    - "sqlite3.paramstyle == 'qmark'."
    - "sqlite3.threadsafety in (0, 1, 2, 3)."
    - "sqlite3.Error.__name__ == 'Error'."
    - "sqlite3.DatabaseError.__name__ == 'DatabaseError'."
    - "sqlite3.OperationalError.__name__ == 'OperationalError'."
    - "sqlite3.IntegrityError.__name__ == 'IntegrityError'."
    - "sqlite3.Row.__name__ == 'Row'."
    - "sqlite3.Connection.__name__ == 'Connection'."
    - "sqlite3.Cursor.__name__ == 'Cursor'."
    - "sqlite3.PARSE_DECLTYPES == 1; sqlite3.PARSE_COLNAMES == 2."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table sqlite3_extra4.exception_names:
  kind: python_call_eq
  category: exceptions
  id_prefix: exc

  columns: [id, function, args, expected]
  rows:
    - [Error,           Error.__name__.__eq__,           ["Error"],           true]
    - [DatabaseError,   DatabaseError.__name__.__eq__,   ["DatabaseError"],   true]
    - [OperationalError, OperationalError.__name__.__eq__, ["OperationalError"], true]
    - [IntegrityError,  IntegrityError.__name__.__eq__,  ["IntegrityError"],  true]
    - [InterfaceError,  InterfaceError.__name__.__eq__,  ["InterfaceError"],  true]
    - [ProgrammingError, ProgrammingError.__name__.__eq__, ["ProgrammingError"], true]
    - [DataError,       DataError.__name__.__eq__,       ["DataError"],       true]
    - [NotSupportedError, NotSupportedError.__name__.__eq__, ["NotSupportedError"], true]

table sqlite3_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Row,        Row.__name__.__eq__,        ["Row"],        true]
    - [Connection, Connection.__name__.__eq__, ["Connection"], true]
    - [Cursor,     Cursor.__name__.__eq__,     ["Cursor"],     true]

invariant sqlite3_extra4.sqlite_version.is_str:
  description: "sqlite3.sqlite_version.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: sqlite_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra4.version.is_str:
  description: "sqlite3.version.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra4.paramstyle.value:
  description: "sqlite3.paramstyle == 'qmark'"
  category: constants
  kind: python_call_eq
  function: paramstyle.__eq__
  args: ["qmark"]
  expected: true

invariant sqlite3_extra4.PARSE_DECLTYPES.value:
  description: "sqlite3.PARSE_DECLTYPES == 1"
  category: constants
  kind: python_call_eq
  function: PARSE_DECLTYPES.__eq__
  args: [1]
  expected: true

invariant sqlite3_extra4.PARSE_COLNAMES.value:
  description: "sqlite3.PARSE_COLNAMES == 2"
  category: constants
  kind: python_call_eq
  function: PARSE_COLNAMES.__eq__
  args: [2]
  expected: true

invariant sqlite3_extra4.Error.base:
  description: "sqlite3.Error.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant sqlite3_extra4.DatabaseError.base:
  description: "sqlite3.DatabaseError.__bases__[0].__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: DatabaseError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"
