invariant concurrent_futures_extra188.cf_Future_name_eq:
  description: "concurrent.futures.Future.__name__.__eq__('Future') returns True — concurrent.futures.Future is the thread-safe future object representing an asynchronous computation; Future.__name__=='Future' (len=6: F(1)u(2)t(3)u(4)r(5)e(6)); Future has five key states: PENDING (initial), RUNNING (set by executor), CANCELLED (cancel() succeeded before RUNNING), CANCELLED_AND_NOTIFIED (internal), FINISHED (set_result/set_exception called); 'Future'=6 is the same length as asyncio.Future.__name__ (also 'Future'=6) but they are distinct classes from different modules; concurrent.futures.Future is thread-safe (uses a Lock) while asyncio.Future is NOT thread-safe (requires event loop); NEW in extra188: first standalone Future.__name__ invariant in cffuture188 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra188.cf_Future_module_eq:
  description: "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') returns True — Future.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24); Future is implemented in the private _base submodule (Lib/concurrent/futures/_base.py); the public concurrent.futures package re-exports it; '_base'=5 with leading underscore signals an internal implementation module; 'concurrent.futures._base'=24 is the longest module path in the concurrent.futures spec series; compare: 'concurrent.futures._base'(24) vs 'multiprocessing.queues'(22) — concurrent.futures._base is 2 chars longer; add_done_callback qualname length (24) == module path length (24): coincidence; NEW in extra188: standalone Future.__module__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra188.cf_Future_base_is_object:
  description: "concurrent.futures.Future.__bases__[0].__name__.__eq__('object') returns True — Future.__bases__[0].__name__=='object' (len=6; Future inherits directly from object — it is a standalone class with no intermediate base); this contrasts with asyncio.Future which in CPython is a C-accelerated type and has a different inheritance chain; concurrent.futures.Future is a pure-Python class (lock-based thread safety via threading.Lock) that follows a simple object → Future hierarchy; all public concurrent.futures classes inherit from: object (Future), Executor (ThreadPoolExecutor, ProcessPoolExecutor), Exception (CancelledError, TimeoutError, BrokenExecutor); NEW in extra188: first standalone Future.__bases__[0].__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra188.cf_Future_init_qualname_eq:
  description: "concurrent.futures.Future.__init__.__qualname__.__eq__('Future.__init__') returns True — Future.__init__.__qualname__=='Future.__init__' (len=15: 'Future'=6+'.'=1+'__init__'=8=15); Future.__init__ sets up: _condition (threading.Condition), _state (initially PENDING), _result and _exception (None until set), _done_callbacks (list of registered callbacks); the threading.Condition wraps an internal Lock so multiple threads can safely wait on the future; __init__ (15) > result==cancel (13) by 2; __init__ (15) < add_done_callback (24) by 9; NEW in extra188: first standalone Future.__init__.__qualname__ invariant in cffuture188 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Future.__init__.__qualname__.__eq__"
  args: ["Future.__init__"]
  expected: true

invariant concurrent_futures_extra188.cf_Future_result_qualname_eq:
  description: "concurrent.futures.Future.result.__qualname__.__eq__('Future.result') returns True — Future.result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); Future.result(timeout=None) blocks the calling thread until the future is done (FINISHED or CANCELLED_AND_NOTIFIED); if the future completed normally, result() returns the stored value; if it raised an exception, result() re-raises it; if cancelled, raises CancelledError; if timeout expires before the future is done, raises TimeoutError; result==cancel at qualname length 13 (both 6-char method names); NEW in extra188: standalone Future.result.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra188.cf_Future_cancel_qualname_eq:
  description: "concurrent.futures.Future.cancel.__qualname__.__eq__('Future.cancel') returns True — Future.cancel.__qualname__=='Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13; same length as result); Future.cancel() attempts to cancel the future; cancellation is only possible when the future is in the PENDING state (not yet picked up by a worker thread); returns True if successfully cancelled, False if the future is RUNNING or FINISHED; cancel==result at qualname length 13 — a 2-way tie; cancel (13) < __init__ (15) by 2; NEW in extra188: standalone Future.cancel.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra188.cf_Future_done_qualname_eq:
  description: "concurrent.futures.Future.done.__qualname__.__eq__('Future.done') returns True — Future.done.__qualname__=='Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11); Future.done() returns True if the future was successfully cancelled or finished executing; done() is the non-blocking state query: it never blocks regardless of the future's current state; done (11) is the shortest qualname in this spec; length ordering: done (11) < result==cancel (13) < __init__ (15) < add_done_callback (24); 'done'=4 is the shortest method name in the spec (compare 'result'=6='cancel'=6, '__init__'=8, 'add_done_callback'=17); NEW in extra188: standalone Future.done.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true

invariant concurrent_futures_extra188.cf_Future_add_done_callback_qualname_eq:
  description: "concurrent.futures.Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback') returns True — Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24: 'Future'=6+'.'=1+'add_done_callback'=17=24); add_done_callback(fn) registers fn to be called with the future as its only argument when the future is done (cancelled or finished); if the future is already done at the time of registration, fn is called immediately via the executor's _invoke_callbacks mechanism; 'add_done_callback'=17 chars is the longest method name in this spec and in the concurrent.futures public API; add_done_callback (24) == Future.__module__.__len__() (24): a coincidental tie between the longest qualname and the module path length; NEW in extra188: standalone Future.add_done_callback.__qualname__ invariant completing the 8-method coverage; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__eq__
  args: ["Future.add_done_callback"]
  expected: true

