spec: socket_extra189
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "socket.socket.connect.__qualname__ == 'socket.connect' — len=14; longest in the set."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — len=11."
    - "socket.socket.listen.__qualname__ == 'socket.listen' — len=13."
    - "socket.socket.accept.__qualname__ == 'socket.accept' — len=13."
    - "socket.socket.send.__qualname__ == 'socket.send' — len=11."
    - "socket.socket.recv.__qualname__ == 'socket.recv' — len=11."
    - "socket.socket.close.__qualname__ == 'socket.close' — len=12."
    - "Length ordering: bind(11)==send(11)==recv(11) < close(12) < listen(13)==accept(13) < connect(14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket method qualnames — bind, send, recv (len=11)
#
# socket.socket.bind.__qualname__  == 'socket.bind'  (len=11)
# socket.socket.send.__qualname__  == 'socket.send'  (len=11)
# socket.socket.recv.__qualname__  == 'socket.recv'  (len=11)
#
# These three I/O primitives share the shortest qualnames in the set.
# All have a four-character method name, giving 'socket.' (7) + 4 = 11.
# ---------------------------------------------------------------------------

table socket_extra189.socket_method_qualnames_len11:
  description: "socket.socket method qualnames — bind, send, recv (len=11); new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocketqualnames189

  columns: [id, function, args, expected, description]
  rows:
    - [bind_qualname_eq,
       socket.socket.bind.__qualname__.__eq__,
       ["socket.bind"],
       true,
       "socket.socket.bind.__qualname__.__eq__('socket.bind') == True — dotted qualname; len=11; new to extra189"]
    - [bind_qualname_len,
       socket.socket.bind.__qualname__.__len__,
       [],
       11,
       "socket.socket.bind.__qualname__.__len__() == 11 — 'socket.bind' has 11 characters; new to extra189"]
    - [send_qualname_eq,
       socket.socket.send.__qualname__.__eq__,
       ["socket.send"],
       true,
       "socket.socket.send.__qualname__.__eq__('socket.send') == True — dotted qualname; len=11; new to extra189"]
    - [recv_qualname_eq,
       socket.socket.recv.__qualname__.__eq__,
       ["socket.recv"],
       true,
       "socket.socket.recv.__qualname__.__eq__('socket.recv') == True — dotted qualname; len=11; new to extra189"]

# ---------------------------------------------------------------------------
# Table 2: socket.socket method qualnames — close (len=12) and listen/accept (len=13)
#
# socket.socket.close.__qualname__   == 'socket.close'   (len=12)
# socket.socket.listen.__qualname__  == 'socket.listen'  (len=13)
# socket.socket.accept.__qualname__  == 'socket.accept'  (len=13)
#
# close is intermediate at 12 characters.  listen and accept share 13
# characters each, one more than close.
# ---------------------------------------------------------------------------

table socket_extra189.socket_method_qualnames_len12_13:
  description: "socket.socket method qualnames — close (len=12), listen and accept (len=13); new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocketqualnames189

  columns: [id, function, args, expected, description]
  rows:
    - [close_qualname_eq,
       socket.socket.close.__qualname__.__eq__,
       ["socket.close"],
       true,
       "socket.socket.close.__qualname__.__eq__('socket.close') == True — dotted qualname; len=12; new to extra189"]
    - [close_qualname_len,
       socket.socket.close.__qualname__.__len__,
       [],
       12,
       "socket.socket.close.__qualname__.__len__() == 12 — 'socket.close' has 12 characters; new to extra189"]
    - [listen_qualname_eq,
       socket.socket.listen.__qualname__.__eq__,
       ["socket.listen"],
       true,
       "socket.socket.listen.__qualname__.__eq__('socket.listen') == True — dotted qualname; len=13; new to extra189"]
    - [accept_qualname_eq,
       socket.socket.accept.__qualname__.__eq__,
       ["socket.accept"],
       true,
       "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — dotted qualname; len=13; new to extra189"]

# ---------------------------------------------------------------------------
# Table 3: socket.socket method qualnames — connect (len=14)
#
# socket.socket.connect.__qualname__  == 'socket.connect'  (len=14)
#
# connect has the longest qualname in this set: 'socket.' (7) + 'connect' (7)
# = 14 characters.
# ---------------------------------------------------------------------------

table socket_extra189.socket_method_qualnames_len14:
  description: "socket.socket.connect __qualname__ identity and length (len=14); new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocketqualnames189

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qualname_eq,
       socket.socket.connect.__qualname__.__eq__,
       ["socket.connect"],
       true,
       "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — longest qualname in the set; len=14; new to extra189"]
    - [connect_qualname_len,
       socket.socket.connect.__qualname__.__len__,
       [],
       14,
       "socket.socket.connect.__qualname__.__len__() == 14 — 'socket.connect' has 14 characters; new to extra189"]
    - [recv_qualname_len,
       socket.socket.recv.__qualname__.__len__,
       [],
       11,
       "socket.socket.recv.__qualname__.__len__() == 11 — 'socket.recv' has 11 characters; new to extra189"]
    - [listen_qualname_len,
       socket.socket.listen.__qualname__.__len__,
       [],
       13,
       "socket.socket.listen.__qualname__.__len__() == 13 — 'socket.listen' has 13 characters; new to extra189"]

