spec: runpy_extra
version: ">=3.1"
backend: python_module(runpy)

docs: https://docs.python.org/3/library/runpy.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/runpy.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/runpy.py"
    - "runpy.zspec.zsdl — that spec covers function names, modules, types, and runtime behavior"
  notes:
    - "This spec covers runpy aspects not in runpy.zspec.zsdl."
    - "runpy has only two public functions: run_module and run_path."
    - "runpy.__name__ == 'runpy' — the module itself reports its name correctly."
    - "runpy.__spec__.name == 'runpy' — the module spec name matches."
    - "runpy.__package__ == 'runpy' or '' — it is a top-level module."
    - "run_module.__qualname__ == 'run_module' — not nested, so qualname equals name."
    - "run_path.__qualname__ == 'run_path' — not nested, so qualname equals name."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — run_module and run_path __name__
#
# runpy.zspec.zsdl already checked these; we include __module__ cross-checks
# that complement rather than duplicate the base spec.
# ---------------------------------------------------------------------------

invariant runpy_extra.run_module.name:
  description: "runpy.run_module.__name__ == 'run_module'"
  category: function_names
  kind: python_call_eq
  function: run_module.__name__.__eq__
  args: ["run_module"]
  expected: true

invariant runpy_extra.run_module.module:
  description: "runpy.run_module.__module__ == 'runpy'"
  category: function_names
  kind: python_call_eq
  function: run_module.__module__.__eq__
  args: ["runpy"]
  expected: true

invariant runpy_extra.run_path.name:
  description: "runpy.run_path.__name__ == 'run_path'"
  category: function_names
  kind: python_call_eq
  function: run_path.__name__.__eq__
  args: ["run_path"]
  expected: true

invariant runpy_extra.run_path.module:
  description: "runpy.run_path.__module__ == 'runpy'"
  category: function_names
  kind: python_call_eq
  function: run_path.__module__.__eq__
  args: ["runpy"]
  expected: true

# ---------------------------------------------------------------------------
# Qualified name checks — both functions are top-level (qualname == name)
# ---------------------------------------------------------------------------

invariant runpy_extra.run_module.qualname:
  description: "runpy.run_module.__qualname__ == 'run_module'"
  category: qualnames
  kind: python_call_eq
  function: run_module.__qualname__.__eq__
  args: ["run_module"]
  expected: true

invariant runpy_extra.run_path.qualname:
  description: "runpy.run_path.__qualname__ == 'run_path'"
  category: qualnames
  kind: python_call_eq
  function: run_path.__qualname__.__eq__
  args: ["run_path"]
  expected: true
