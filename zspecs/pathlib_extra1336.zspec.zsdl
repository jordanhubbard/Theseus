spec: pathlib_extra1336
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 536 theme: __hash__ and __eq__ method descriptor checks for pathlib module classes."
    - "pathlib.PurePath defines both __hash__ and __eq__ as Python functions (kind 'function', not 'wrapper_descriptor'). This is unlike most classes that inherit from object."
    - "pathlib.PurePath.__hash__.__qualname__ == 'PurePath.__hash__' — custom hash is defined on PurePath itself."
    - "pathlib.PurePath.__eq__.__qualname__ == 'PurePath.__eq__' — custom equality is defined on PurePath itself."
    - "pathlib.Path.__hash__.__qualname__ == 'PurePath.__hash__' — Path inherits __hash__ from PurePath, does not override it."
    - "pathlib.Path.__eq__.__qualname__ == 'PurePath.__eq__' — Path inherits __eq__ from PurePath, does not override it."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath also inherit __hash__ and __eq__ from PurePath without overriding."
    - "All qualnames verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib PurePath __hash__ and __eq__ descriptor checks
#
# pathlib.PurePath.__hash__.__class__.__name__  == 'function'
# pathlib.PurePath.__hash__.__qualname__        == 'PurePath.__hash__'
# pathlib.PurePath.__eq__.__class__.__name__    == 'function'
# pathlib.PurePath.__eq__.__qualname__          == 'PurePath.__eq__'
# ---------------------------------------------------------------------------

table pathlib_extra1336.purepath_hash_eq:
  description: "pathlib.PurePath __hash__ and __eq__ descriptor checks — wave 536 theme: PurePath defines custom __hash__ and __eq__ as Python functions (class name 'function', not 'wrapper_descriptor'); __hash__.__qualname__=='PurePath.__hash__'; __eq__.__qualname__=='PurePath.__eq__'; this makes PurePath instances hashable and comparable by path value rather than identity; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: pl1336pp

  columns: [id, function, args, expected, description]
  rows:
    - [pl1336pp001, pathlib.PurePath.__hash__.__class__.__name__.__eq__,   ["function"],        true, "pathlib.PurePath.__hash__.__class__.__name__ == 'function' (custom Python function, not wrapper_descriptor); verified with Python 3.12"]
    - [pl1336pp002, pathlib.PurePath.__hash__.__qualname__.__eq__,         ["PurePath.__hash__"], true, "pathlib.PurePath.__hash__.__qualname__ == 'PurePath.__hash__' (defined on PurePath itself); verified with Python 3.12"]
    - [pl1336pp003, pathlib.PurePath.__eq__.__class__.__name__.__eq__,     ["function"],        true, "pathlib.PurePath.__eq__.__class__.__name__ == 'function' (custom Python function, not wrapper_descriptor); verified with Python 3.12"]
    - [pl1336pp004, pathlib.PurePath.__eq__.__qualname__.__eq__,           ["PurePath.__eq__"], true, "pathlib.PurePath.__eq__.__qualname__ == 'PurePath.__eq__' (defined on PurePath itself); verified with Python 3.12"]
    - [pl1336pp005, pathlib.PurePosixPath.__hash__.__qualname__.__eq__,    ["PurePath.__hash__"], true, "pathlib.PurePosixPath.__hash__.__qualname__ == 'PurePath.__hash__' (inherits from PurePath, not overridden); verified with Python 3.12"]
    - [pl1336pp006, pathlib.PurePosixPath.__eq__.__qualname__.__eq__,      ["PurePath.__eq__"], true, "pathlib.PurePosixPath.__eq__.__qualname__ == 'PurePath.__eq__' (inherits from PurePath, not overridden); verified with Python 3.12"]
    - [pl1336pp007, pathlib.PureWindowsPath.__hash__.__qualname__.__eq__,  ["PurePath.__hash__"], true, "pathlib.PureWindowsPath.__hash__.__qualname__ == 'PurePath.__hash__' (inherits from PurePath, not overridden); verified with Python 3.12"]
    - [pl1336pp008, pathlib.PureWindowsPath.__eq__.__qualname__.__eq__,    ["PurePath.__eq__"], true, "pathlib.PureWindowsPath.__eq__.__qualname__ == 'PurePath.__eq__' (inherits from PurePath, not overridden); verified with Python 3.12"]

# ---------------------------------------------------------------------------
# pathlib Path __hash__ and __eq__ descriptor checks
#
# pathlib.Path.__hash__.__class__.__name__  == 'function'
# pathlib.Path.__hash__.__qualname__        == 'PurePath.__hash__'
# pathlib.Path.__eq__.__class__.__name__    == 'function'
# pathlib.Path.__eq__.__qualname__          == 'PurePath.__eq__'
# ---------------------------------------------------------------------------

table pathlib_extra1336.path_hash_eq:
  description: "pathlib.Path __hash__ and __eq__ descriptor checks — wave 536 theme: Path inherits __hash__ and __eq__ from PurePath without overriding; __hash__.__class__.__name__=='function'; __hash__.__qualname__=='PurePath.__hash__'; __eq__.__qualname__=='PurePath.__eq__'; Path instances are hashable and comparable by path value; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: pl1336ph

  columns: [id, function, args, expected, description]
  rows:
    - [pl1336ph001, pathlib.Path.__hash__.__class__.__name__.__eq__,   ["function"],          true, "pathlib.Path.__hash__.__class__.__name__ == 'function' (inherited from PurePath, a Python function); verified with Python 3.12"]
    - [pl1336ph002, pathlib.Path.__hash__.__qualname__.__eq__,         ["PurePath.__hash__"], true, "pathlib.Path.__hash__.__qualname__ == 'PurePath.__hash__' (Path inherits, does not override __hash__); verified with Python 3.12"]
    - [pl1336ph003, pathlib.Path.__eq__.__class__.__name__.__eq__,     ["function"],          true, "pathlib.Path.__eq__.__class__.__name__ == 'function' (inherited from PurePath, a Python function); verified with Python 3.12"]
    - [pl1336ph004, pathlib.Path.__eq__.__qualname__.__eq__,           ["PurePath.__eq__"],   true, "pathlib.Path.__eq__.__qualname__ == 'PurePath.__eq__' (Path inherits, does not override __eq__); verified with Python 3.12"]
    - [pl1336ph005, pathlib.PurePath.__hash__.__class__.__name__.__eq__, ["function"],        true, "pathlib.PurePath.__hash__.__class__.__name__ == 'function' (contrast with C-extension classes which use wrapper_descriptor); verified with Python 3.12"]
    - [pl1336ph006, pathlib.PurePath.__eq__.__class__.__name__.__eq__,   ["function"],        true, "pathlib.PurePath.__eq__.__class__.__name__ == 'function' (contrast with C-extension classes which use wrapper_descriptor); verified with Python 3.12"]
    - [pl1336ph007, pathlib.PurePosixPath.__hash__.__class__.__name__.__eq__, ["function"],   true, "pathlib.PurePosixPath.__hash__.__class__.__name__ == 'function' (inherits Python function from PurePath); verified with Python 3.12"]
    - [pl1336ph008, pathlib.PurePosixPath.__eq__.__class__.__name__.__eq__,   ["function"],   true, "pathlib.PurePosixPath.__eq__.__class__.__name__ == 'function' (inherits Python function from PurePath); verified with Python 3.12"]

# ---------------------------------------------------------------------------
# pathlib __hash__ vs __eq__ qualname consistency checks
#
# Confirms that both __hash__ and __eq__ on Path/PurePath/PurePosixPath/PureWindowsPath
# all trace back to PurePath.__hash__ and PurePath.__eq__ respectively.
# ---------------------------------------------------------------------------

table pathlib_extra1336.hash_eq_qualname_consistency:
  description: "pathlib __hash__ and __eq__ qualname consistency across the Path hierarchy — wave 536 theme: confirms PurePath is the single defining class for __hash__ and __eq__ across all pathlib path types; Path, PurePosixPath, and PureWindowsPath all share qualnames PurePath.__hash__ and PurePath.__eq__; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: pl1336qc

  columns: [id, function, args, expected, description]
  rows:
    - [pl1336qc001, pathlib.PurePath.__hash__.__qualname__.__eq__,         ["PurePath.__hash__"], true, "PurePath.__hash__.__qualname__ == 'PurePath.__hash__' (origin of hash definition); verified with Python 3.12"]
    - [pl1336qc002, pathlib.Path.__hash__.__qualname__.__eq__,             ["PurePath.__hash__"], true, "Path.__hash__.__qualname__ == 'PurePath.__hash__' (same as PurePath — no override); verified with Python 3.12"]
    - [pl1336qc003, pathlib.PurePosixPath.__hash__.__qualname__.__eq__,    ["PurePath.__hash__"], true, "PurePosixPath.__hash__.__qualname__ == 'PurePath.__hash__' (no override in subclass); verified with Python 3.12"]
    - [pl1336qc004, pathlib.PureWindowsPath.__hash__.__qualname__.__eq__,  ["PurePath.__hash__"], true, "PureWindowsPath.__hash__.__qualname__ == 'PurePath.__hash__' (no override in subclass); verified with Python 3.12"]
    - [pl1336qc005, pathlib.PurePath.__eq__.__qualname__.__eq__,           ["PurePath.__eq__"],   true, "PurePath.__eq__.__qualname__ == 'PurePath.__eq__' (origin of eq definition); verified with Python 3.12"]
    - [pl1336qc006, pathlib.Path.__eq__.__qualname__.__eq__,               ["PurePath.__eq__"],   true, "Path.__eq__.__qualname__ == 'PurePath.__eq__' (same as PurePath — no override); verified with Python 3.12"]
    - [pl1336qc007, pathlib.PurePosixPath.__eq__.__qualname__.__eq__,      ["PurePath.__eq__"],   true, "PurePosixPath.__eq__.__qualname__ == 'PurePath.__eq__' (no override in subclass); verified with Python 3.12"]
    - [pl1336qc008, pathlib.PureWindowsPath.__eq__.__qualname__.__eq__,    ["PurePath.__eq__"],   true, "PureWindowsPath.__eq__.__qualname__ == 'PurePath.__eq__' (no override in subclass); verified with Python 3.12"]
