spec: threading_extra209
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "Python threading documentation — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra208.zspec.zsdl — covers co_flags, co_stacksize, and co_filename checks for current_thread, main_thread, active_count, Thread.__init__"
    - "threading_extra.zspec.zsdl — covers __module__ checks, local name/module, get_ident, TIMEOUT_MAX, stack_size"
    - "threading_sync.zspec.zsdl — covers Barrier, BoundedSemaphore, Condition, Semaphore, RLock"
  notes:
    - "threading.Thread.__init__.__code__.co_varnames is a tuple of 9 elements: ('self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon', 'context', 'target_name'). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_varnames.__contains__('target') == True — 'target' is the callable object to invoke in the thread. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_varnames.__contains__('daemon') == True — 'daemon' controls whether the thread is a daemon thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('start') == True — start is a method defined on the Thread class. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('run') == True — run is a method defined on the Thread class. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('join') == True — join is a method defined on the Thread class. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Thread.__init__ co_varnames class name and length
#
# threading.Thread.__init__ is a Python method.
# co_varnames is a tuple of 9 elements.
# co_varnames.__class__.__name__ == 'tuple'.
# co_varnames.__len__() == 9.
# ---------------------------------------------------------------------------

table threading_extra209.co_varnames_class_and_len:
  description: "Thread.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' and __len__() == 9; co_varnames contains self, group, target, name, args, kwargs, daemon, context, target_name; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: threadcovarnames209

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_varnames_class,
       "Thread.__init__.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 9 local variable names: self, group, target, name, args, kwargs, daemon, context, target_name; str.__eq__('tuple') returns True; new to extra209"]
    - [thread_init_varnames_len,
       "Thread.__init__.__code__.co_varnames.__len__",
       [],
       9,
       "threading.Thread.__init__.__code__.co_varnames.__len__() == 9 — Thread.__init__ has 9 local variable names: self, group, target, name, args, kwargs, daemon, context, target_name; tuple.__len__() returns 9; new to extra209"]
    - [thread_init_varnames_contains_target,
       "Thread.__init__.__code__.co_varnames.__contains__",
       ["target"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('target') == True — 'target' is the callable object invoked by the thread's run() method; tuple.__contains__('target') returns True; new to extra209"]
    - [thread_init_varnames_contains_daemon,
       "Thread.__init__.__code__.co_varnames.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('daemon') == True — 'daemon' controls whether the thread is a daemon thread that exits when the main program exits; tuple.__contains__('daemon') returns True; new to extra209"]

# ---------------------------------------------------------------------------
# Table 2: Thread.__init__ co_varnames additional membership checks
#
# Thread.__init__ co_varnames contains: 'self', 'group', 'name', 'args', 'kwargs'
# These are all standard Thread constructor parameters.
# ---------------------------------------------------------------------------

table threading_extra209.co_varnames_members:
  description: "Thread.__init__.__code__.co_varnames.__contains__ checks for standard constructor parameters; self, group, name, args, kwargs are all present; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: threadcovarnames209

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_contains_self,
       "Thread.__init__.__code__.co_varnames.__contains__",
       ["self"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('self') == True — 'self' is the Thread instance being initialized; the first element of co_varnames; tuple.__contains__('self') returns True; new to extra209"]
    - [thread_init_contains_group,
       "Thread.__init__.__code__.co_varnames.__contains__",
       ["group"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('group') == True — 'group' is the thread group parameter (reserved for future use, must be None); tuple.__contains__('group') returns True; new to extra209"]
    - [thread_init_contains_name,
       "Thread.__init__.__code__.co_varnames.__contains__",
       ["name"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('name') == True — 'name' is the thread name used for identification; tuple.__contains__('name') returns True; new to extra209"]
    - [thread_init_contains_args,
       "Thread.__init__.__code__.co_varnames.__contains__",
       ["args"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('args') == True — 'args' is the tuple of positional arguments passed to the target callable; tuple.__contains__('args') returns True; new to extra209"]

# ---------------------------------------------------------------------------
# Table 3: Thread.__dict__ membership checks
#
# Thread defines start, run, join, is_alive, getName, setName, isDaemon,
# setDaemon, and other methods as class-level attributes.
# start, run, and join are verified here.
# ---------------------------------------------------------------------------

table threading_extra209.thread_dict_contains:
  description: "threading.Thread.__dict__.__contains__ checks for core Thread methods; start, run, and join are all defined as class-level methods in Thread.__dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: thread_class
  id_prefix: threadcovarnames209

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_has_start,
       "Thread.__dict__.__contains__",
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — start is the method that begins thread execution; it must be defined at the class level; dict.__contains__('start') returns True; new to extra209"]
    - [thread_dict_has_run,
       "Thread.__dict__.__contains__",
       ["run"],
       true,
       "threading.Thread.__dict__.__contains__('run') == True — run is the method that defines the thread's activity and is invoked by start(); dict.__contains__('run') returns True; new to extra209"]
    - [thread_dict_has_join,
       "Thread.__dict__.__contains__",
       ["join"],
       true,
       "threading.Thread.__dict__.__contains__('join') == True — join is the method that blocks the calling thread until the thread completes; dict.__contains__('join') returns True; new to extra209"]
    - [thread_dict_has_is_alive,
       "Thread.__dict__.__contains__",
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — is_alive is the method that returns True if the thread is currently executing; dict.__contains__('is_alive') returns True; new to extra209"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra209
# ---------------------------------------------------------------------------

invariant threading_extra209.thread_init_varnames_class_tuple:
  description: "threading.Thread.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 9 local variable names for Thread.__init__; new to extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra209.thread_init_varnames_contains_target:
  description: "threading.Thread.__init__.__code__.co_varnames.__contains__('target') == True — 'target' is the callable invoked by the thread's run method; new to extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_varnames.__contains__
  args: ["target"]
  expected: true

invariant threading_extra209.thread_init_varnames_contains_daemon:
  description: "threading.Thread.__init__.__code__.co_varnames.__contains__('daemon') == True — 'daemon' controls daemon thread behavior; new to extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_varnames.__contains__
  args: ["daemon"]
  expected: true

invariant threading_extra209.thread_dict_has_start:
  description: "threading.Thread.__dict__.__contains__('start') == True — start is a class-level method defined in Thread.__dict__; new to extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["start"]
  expected: true

invariant threading_extra209.thread_dict_has_run:
  description: "threading.Thread.__dict__.__contains__('run') == True — run is a class-level method defined in Thread.__dict__; new to extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["run"]
  expected: true

invariant threading_extra209.thread_dict_has_join:
  description: "threading.Thread.__dict__.__contains__('join') == True — join is a class-level method defined in Thread.__dict__; new to extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["join"]
  expected: true

invariant threading_extra209.thread_init_varnames_len_9:
  description: "threading.Thread.__init__.__code__.co_varnames.__len__() == 9 — Thread.__init__ has 9 local variable names: self, group, target, name, args, kwargs, daemon, context, target_name; new to extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_varnames.__len__
