spec: itertools_extra202
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers module-level dunder attributes of itertools: __name__, __package__, __spec__.name, __doc__.__class__.__name__, __loader__.__class__.__name__."
    - "itertools.__name__ == 'itertools' — module identity attribute. Verified with Python 3.14.3."
    - "itertools.__package__ == '' — top-level module; __package__ is empty string. Verified with Python 3.14.3."
    - "itertools.__spec__.name == 'itertools' — ModuleSpec.name attribute equals module name. Verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' — module docstring is a str. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — itertools is a C extension (built-in); its loader is BuiltinImporter which is a class, so __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.__spec__.has_location == False — built-in module has no file location. Verified with Python 3.14.3."
    - "itertools.__spec__.origin == 'built-in' — built-in module origin string. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module __name__ and __package__ identity
#
# itertools.__name__ == 'itertools'
# itertools.__package__ == ''
# itertools.__name__.__class__.__name__ == 'str'
# itertools.__package__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table itertools_extra202.module_name_package:
  description: "itertools.__name__ and __package__ identity; new to extra202"
  kind: python_call_eq
  category: module_identity
  id_prefix: itertools202

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — module __name__ attribute equals 'itertools'; new to extra202"]
    - [module_name_class_str,
       __name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__name__.__class__.__name__.__eq__('str') == True — module __name__ is a str; new to extra202"]
    - [module_package_eq,
       __package__.__eq__,
       [""],
       true,
       "itertools.__package__.__eq__('') == True — top-level module; __package__ is empty string; new to extra202"]
    - [module_package_class_str,
       __package__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__package__.__class__.__name__.__eq__('str') == True — module __package__ is a str; new to extra202"]

# ---------------------------------------------------------------------------
# Table 2: itertools __spec__ attributes
#
# itertools.__spec__.name == 'itertools'
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.parent == ''
# itertools.__spec__.has_location == False  (built-in C extension)
# ---------------------------------------------------------------------------

table itertools_extra202.module_spec_attrs:
  description: "itertools.__spec__ name, class, parent and has_location identity; new to extra202"
  kind: python_call_eq
  category: module_spec
  id_prefix: itertools202

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — ModuleSpec.name attribute equals 'itertools'; new to extra202"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec instance; new to extra202"]
    - [spec_parent_eq,
       __spec__.parent.__eq__,
       [""],
       true,
       "itertools.__spec__.parent.__eq__('') == True — top-level module; spec.parent is empty string; new to extra202"]
    - [spec_has_location_eq,
       __spec__.has_location.__eq__,
       [false],
       true,
       "itertools.__spec__.has_location.__eq__(False) == True — built-in C extension; has no file location; new to extra202"]

# ---------------------------------------------------------------------------
# Table 3: itertools __loader__, __doc__ and __spec__.origin identity
#
# itertools.__loader__.__class__.__name__ == 'type'  (BuiltinImporter is a class)
# itertools.__doc__.__class__.__name__ == 'str'
# itertools.__spec__.origin == 'built-in'
# itertools.__spec__.origin.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table itertools_extra202.loader_doc_origin_identity:
  description: "itertools __loader__.__class__.__name__, __doc__ type and __spec__.origin identity; new to extra202"
  kind: python_call_eq
  category: loader_doc_origin
  id_prefix: itertools202

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq,
       __loader__.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — BuiltinImporter is a class; its __class__.__name__ is 'type'; new to extra202"]
    - [doc_class_name_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — module __doc__ is a str; new to extra202"]
    - [spec_origin_eq,
       __spec__.origin.__eq__,
       ["built-in"],
       true,
       "itertools.__spec__.origin.__eq__('built-in') == True — built-in C extension; origin string is 'built-in'; new to extra202"]
    - [spec_origin_class_str,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__spec__.origin.__class__.__name__.__eq__('str') == True — spec.origin is a str; new to extra202"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra202
# ---------------------------------------------------------------------------

invariant itertools_extra202.module_name_eq:
  description: "itertools.__name__ == 'itertools' — module identity attribute is 'itertools'; new to extra202"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra202.module_package_eq:
  description: "itertools.__package__ == '' — top-level module; __package__ is empty string; new to extra202"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra202.spec_name_eq:
  description: "itertools.__spec__.name == 'itertools' — ModuleSpec.name attribute equals module name; new to extra202"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra202.spec_class_name_eq:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is a ModuleSpec instance; new to extra202"
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra202.doc_class_name_eq:
  description: "itertools.__doc__.__class__.__name__ == 'str' — module docstring is a str; new to extra202"
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra202.loader_class_name_eq:
  description: "itertools.__loader__.__class__.__name__ == 'type' — BuiltinImporter is a class; __class__.__name__ is 'type'; new to extra202"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra202.spec_has_location_eq:
  description: "itertools.__spec__.has_location == False — built-in C extension has no file location; new to extra202"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true

invariant itertools_extra202.spec_origin_eq:
  description: "itertools.__spec__.origin == 'built-in' — built-in C extension origin string; new to extra202"
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["built-in"]
  expected: true
