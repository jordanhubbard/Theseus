spec: itertools_extra_rust
version: ">=3.9"
backend: rust_module(itertools_extra_rust)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Additional itertools functions not covered in itertools_rust."
    - "accumulate(iterable) returns running cumulative sums as a list."
    - "accumulate([1,2,3,4,5]) == [1, 3, 6, 10, 15]."
    - "compress(data, selectors) returns elements where selector is truthy."
    - "compress([1,2,3,4,5], [1,0,1,0,1]) == [1, 3, 5]."
    - "All functions return lists (not iterators) for ease of testing."
    - "All test vectors verified against Python 3.14.3 itertools module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# accumulate — running cumulative sums
table itertools_extra_rust.accumulate.vectors:
  kind: python_call_eq
  category: accumulate
  id_prefix: ite_acc
  function: accumulate

  columns: [id, args, expected]
  rows:
    - [one_to_five,  [[1, 2, 3, 4, 5]], [1, 3, 6, 10, 15]]
    - [single,       [[42]],            [42]]
    - [ones,         [[1, 1, 1, 1]],    [1, 2, 3, 4]]
    - [descending,   [[5, 4, 3, 2, 1]], [5, 9, 12, 14, 15]]

# compress — filter by boolean selector
table itertools_extra_rust.compress.vectors:
  kind: python_call_eq
  category: compress
  id_prefix: ite_cmp
  function: compress

  columns: [id, args, expected]
  rows:
    - [alt_select,  [[1, 2, 3, 4, 5], [1, 0, 1, 0, 1]], [1, 3, 5]]
    - [all_select,  [[1, 2, 3], [1, 1, 1]],              [1, 2, 3]]
    - [none_select, [[1, 2, 3], [0, 0, 0]],              []]
    - [first_only,  [[10, 20, 30], [1, 0, 0]],           [10]]
    - [last_two,    [["a","b","c","d"], [0,0,1,1]],       ["c", "d"]]

