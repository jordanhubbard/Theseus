# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool — context manager protocol presence
#
# Pool defines __enter__ and __exit__ directly in its own __dict__.
# These are plain Python functions. Pool does not support the async
# context manager protocol (__aenter__/__aexit__ are absent).
# ---------------------------------------------------------------------------

table multiprocessing_extra1486.pool_dict_contains:
  description: "multiprocessing.pool.Pool.__dict__.__contains__ checks for sync context manager protocol in mp1486pl namespace — wave 546 theme: Pool.__dict__.__contains__('__enter__') == True (Pool supports 'with Pool(...) as p:' pattern); Pool.__dict__.__contains__('__exit__') == True (Pool.__exit__ calls pool.terminate()); __enter__/__exit__ are plain Python functions (class name 'function'); Pool has no async context manager (__aenter__ not in Pool.__dict__); verified with Python 3.12"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: mp1486pl

  columns: [id, function, args, expected]
  rows:
    - [mp1486pl001, multiprocessing.pool.Pool.__dict__.__contains__, ["__enter__"],  true]
    - [mp1486pl002, multiprocessing.pool.Pool.__dict__.__contains__, ["__exit__"],   true]
    - [mp1486pl003, multiprocessing.pool.Pool.__enter__.__class__.__name__.__eq__, ["function"], true]
    - [mp1486pl004, multiprocessing.pool.Pool.__exit__.__class__.__name__.__eq__,  ["function"], true]
    - [mp1486pl005, multiprocessing.pool.Pool.__dict__.__contains__, ["__aenter__"], false]
    - [mp1486pl006, multiprocessing.pool.Pool.__dict__.__contains__, ["__aexit__"],  false]

# ---------------------------------------------------------------------------
# multiprocessing.queues.Queue — no context manager protocol
#
# multiprocessing.queues.Queue does NOT have __enter__ or __exit__ in its
# own __dict__. It is a FIFO queue for inter-process communication, not a
# context manager resource. JoinableQueue (a subclass of Queue) likewise
# does not define __enter__/__exit__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1486.queue_dict_no_enter:
  description: "multiprocessing.queues.Queue and JoinableQueue do NOT have __enter__/__exit__ in their own __dict__ — wave 546: Queue is a FIFO inter-process communication queue, not a context manager; Queue.__dict__.__contains__('__enter__') == False; Queue.__dict__.__contains__('__exit__') == False; JoinableQueue.__dict__.__contains__('__enter__') == False; JoinableQueue.__dict__.__contains__('__exit__') == False; Queue also has no async context manager protocol; compare: Pool.__dict__.__contains__('__enter__') == True; verified with Python 3.12"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: mp1486qu

  columns: [id, function, args, expected]
  rows:
    - [mp1486qu001, multiprocessing.queues.Queue.__dict__.__contains__,         ["__enter__"],  false]
    - [mp1486qu002, multiprocessing.queues.Queue.__dict__.__contains__,         ["__exit__"],   false]
    - [mp1486qu003, multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__enter__"],  false]
    - [mp1486qu004, multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__exit__"],   false]
    - [mp1486qu005, multiprocessing.queues.Queue.__dict__.__contains__,         ["__aenter__"], false]
    - [mp1486qu006, multiprocessing.queues.Queue.__dict__.__contains__,         ["__aexit__"],  false]

# ---------------------------------------------------------------------------
# multiprocessing.queues.SimpleQueue — no context manager protocol
#
# SimpleQueue is a simplified IPC queue with no context manager support.
# It is lighter-weight than Queue (no JoinableQueue semantics, no task_done).
# ---------------------------------------------------------------------------

table multiprocessing_extra1486.simplequeue_dict_no_enter:
  description: "multiprocessing.queues.SimpleQueue does NOT have __enter__/__exit__ in its own __dict__ — wave 546: SimpleQueue is a simplified inter-process communication queue with no context manager support; SimpleQueue.__dict__.__contains__('__enter__') == False; SimpleQueue.__dict__.__contains__('__exit__') == False; SimpleQueue.__dict__.__contains__('__aenter__') == False; SimpleQueue has get, put, close, empty methods; compare: Pool.__dict__.__contains__('__enter__') == True while all queue classes have no context manager protocol; verified with Python 3.12"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: mp1486sq

  columns: [id, function, args, expected]
  rows:
    - [mp1486sq001, multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__enter__"],  false]
    - [mp1486sq002, multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__exit__"],   false]
    - [mp1486sq003, multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__aenter__"], false]
    - [mp1486sq004, multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__aexit__"],  false]
    - [mp1486sq005, multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["get"],        true]
    - [mp1486sq006, multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["put"],        true]
