spec: masonite_rust
version: ">=3.9"
backend: rust_module(masonite_rust)

docs: https://docs.masoniteproject.com/

provenance:
  derived_from:
    - "https://docs.masoniteproject.com/ — Masonite framework"
  notes:
    - "Masonite is a full-featured Python web framework."
    - "masonite.app.App is a class."
    - "masonite.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant masonite_rust.has_app_class:
  description: "masonite.app.App is importable"
  category: presence
  kind: python_call_eq
  function: masonite_has_app_class
  args: []
  expected: true

invariant masonite_rust.has_request_class:
  description: "masonite.request.Request is importable"
  category: presence
  kind: python_call_eq
  function: masonite_has_request_class
  args: []
  expected: true

invariant masonite_rust.version_nonempty:
  description: "masonite.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: masonite_version_nonempty
  args: []
  expected: true

