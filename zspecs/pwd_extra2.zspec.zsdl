spec: pwd_extra2
version: ">=3.9"
backend: python_module(pwd)

docs: https://docs.python.org/3/library/pwd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pwd.html — Python pwd module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, passwd database access"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/pwdmodule.c"
  notes:
    - "This spec extends pwd.zspec.zsdl and pwd_extra.zspec.zsdl with new, non-duplicate invariants."
    - "pwd is a POSIX-only Unix module; it is available on macOS and Linux but NOT on Windows."
    - "struct_passwd is a C-level struct-sequence type (not a namedtuple); it does NOT have a _fields attribute."
    - "Instead of _fields, C struct-sequence types expose __match_args__ (Python 3.10+) and n_sequence_fields."
    - "struct_passwd.__match_args__ is a tuple of 7 strings covering all seven passwd fields."
    - "struct_passwd.n_unnamed_fields == 0 — all seven fields are named (no anonymous tail fields)."
    - "struct_passwd.__bases__[0].__name__ == 'tuple' — C struct-sequences subclass tuple."
    - "pwd_extra.zspec.zsdl covers: __match_args__ is tuple, len==7, each index 0..6 by __getitem__."
    - "New here: n_unnamed_fields, __qualname__ of functions, __bases__, getpwall item class."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct_passwd.n_unnamed_fields == 0
# pwd.zspec.zsdl and pwd_extra.zspec.zsdl do not cover n_unnamed_fields.
# C struct-sequence types may have unnamed tail fields; struct_passwd has none.
# ---------------------------------------------------------------------------

invariant pwd_extra2.struct_passwd.n_unnamed_fields:
  description: "pwd.struct_passwd.n_unnamed_fields == 0 — no anonymous tail fields"
  category: struct
  kind: python_call_eq
  function: struct_passwd.n_unnamed_fields.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# struct_passwd.__bases__ — struct_passwd inherits from tuple
# C struct-sequence types are tuple subclasses.
# ---------------------------------------------------------------------------

invariant pwd_extra2.struct_passwd.bases_getitem:
  description: "pwd.struct_passwd.__bases__[0].__name__ == 'tuple' — struct_passwd is a tuple subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_passwd.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tuple"

# ---------------------------------------------------------------------------
# struct_passwd.__match_args__ — __contains__ checks for all 7 fields
# pwd_extra covers: index 0..6 via __getitem__. New here: __contains__ checks.
# ---------------------------------------------------------------------------

table pwd_extra2.struct_passwd.match_args_contains:
  kind: python_call_eq
  category: match_args
  id_prefix: field

  columns: [id, function, args, expected]
  rows:
    - [pw_name,   struct_passwd.__match_args__.__contains__, ["pw_name"],   true]
    - [pw_passwd, struct_passwd.__match_args__.__contains__, ["pw_passwd"], true]
    - [pw_uid,    struct_passwd.__match_args__.__contains__, ["pw_uid"],    true]
    - [pw_gid,    struct_passwd.__match_args__.__contains__, ["pw_gid"],    true]
    - [pw_gecos,  struct_passwd.__match_args__.__contains__, ["pw_gecos"],  true]
    - [pw_dir,    struct_passwd.__match_args__.__contains__, ["pw_dir"],    true]
    - [pw_shell,  struct_passwd.__match_args__.__contains__, ["pw_shell"],  true]

# ---------------------------------------------------------------------------
# Function __qualname__ attributes
# pwd.zspec.zsdl and pwd_extra.zspec.zsdl cover __name__ but not __qualname__.
# For C-level builtins, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table pwd_extra2.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getpwnam, getpwnam.__qualname__.__eq__, ["getpwnam"], true]
    - [getpwuid, getpwuid.__qualname__.__eq__, ["getpwuid"], true]
    - [getpwall, getpwall.__qualname__.__eq__, ["getpwall"], true]

# ---------------------------------------------------------------------------
# Functions are C-level builtins — __class__.__name__
# pwd.zspec.zsdl covers func_types table; pwd_extra does not repeat it.
# New here: explicit invariants (not a table) for cross-reference clarity.
# ---------------------------------------------------------------------------

invariant pwd_extra2.getpwnam.is_builtin:
  description: "pwd.getpwnam is a builtin_function_or_method (C-level)"
  category: function_types
  kind: python_call_eq
  function: getpwnam.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant pwd_extra2.getpwuid.is_builtin:
  description: "pwd.getpwuid is a builtin_function_or_method (C-level)"
  category: function_types
  kind: python_call_eq
  function: getpwuid.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant pwd_extra2.getpwall.is_builtin:
  description: "pwd.getpwall is a builtin_function_or_method (C-level)"
  category: function_types
  kind: python_call_eq
  function: getpwall.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# getpwall() — result list element class
# pwd.zspec.zsdl checks getpwall returns a list.
# New here: first element is a struct_passwd instance.
# ---------------------------------------------------------------------------

invariant pwd_extra2.getpwall.item_class:
  description: "getpwall()[0].__class__.__name__ == 'struct_passwd' — elements are struct_passwd objects"
  category: behavior
  kind: python_call_eq
  function: getpwall
  args: []
  method: __getitem__
  method_args: [0]
  expected: "struct_passwd"

# ---------------------------------------------------------------------------
# struct_passwd.n_sequence_fields == 7 (standalone invariant, not a table row)
# pwd.zspec.zsdl has this as a standalone invariant; pwd_extra.zspec.zsdl has
# match_args len check. We add the n_fields companion (total == 7).
# ---------------------------------------------------------------------------

invariant pwd_extra2.struct_passwd.n_fields:
  description: "pwd.struct_passwd.n_fields == 7 — total field count matches n_sequence_fields"
  category: struct
  kind: python_call_eq
  function: struct_passwd.n_fields.__eq__
  args: [7]
  expected: true
