spec: pdb_extra3
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
    - "CPython source: Lib/bdb.py"
  notes:
    - "This spec extends pdb.zspec.zsdl, pdb_extra.zspec.zsdl, and pdb_extra2.zspec.zsdl."
    - "pdb (base) covers: Pdb.__name__, Restart.__name__, Pdb.__module__, run/runeval/runcall/set_trace/post_mortem/pm __name__ (table), Pdb().prompt, Pdb().use_rawinput."
    - "pdb_extra covers: Pdb.__name__, Pdb.__module__, Pdb.__bases__[0].__name__=='Bdb', run/runeval/runcall/set_trace/post_mortem/pm __name__, help.__name__."
    - "pdb_extra2 covers: Pdb.__name__, Pdb.__module__, Pdb.__qualname__, run/runcall/post_mortem/set_trace/pm __name__ and __module__."
    - "This spec adds: runeval.__module__, help.__module__, Restart.__module__, Pdb.__bases__[0].__module__, Pdb.__bases__.__len__() (Pdb has two bases: Bdb and Cmd)."
    - "pdb.Pdb inherits from both bdb.Bdb and cmd.Cmd — __bases__ has length 2."
    - "Pdb.__bases__[0].__module__ == 'bdb' — Bdb is defined in the bdb module."
    - "Pdb.__bases__[1].__name__ == 'Cmd' — the second base is cmd.Cmd."
    - "Pdb.__bases__[1].__module__ == 'cmd' — Cmd is defined in the cmd module."
    - "pdb.Restart is a simple Exception subclass used to restart the debugged program."
    - "Restart.__module__ == 'pdb' and Restart.__bases__[0].__name__ == 'Exception'."
    - "pdb.help is an alias for pdb.Pdb.help — a bound method on Pdb instances, exposed at module level as a convenience."
    - "runeval.__module__ == 'pdb' — not previously covered in prior pdb_extra specs."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# runeval.__module__ — not covered in pdb_extra2 (which covers run/runcall/
# post_mortem/set_trace/pm __module__ but omits runeval)
# ---------------------------------------------------------------------------

invariant pdb_extra3.function_modules.runeval:
  description: "pdb.runeval.__module__ == 'pdb'"
  category: function_modules
  kind: python_call_eq
  function: runeval.__module__.__eq__
  args: ["pdb"]
  expected: true

# ---------------------------------------------------------------------------
# help.__module__ — not covered in any prior pdb spec
# ---------------------------------------------------------------------------

invariant pdb_extra3.function_modules.help:
  description: "pdb.help.__module__ == 'pdb'"
  category: function_modules
  kind: python_call_eq
  function: help.__module__.__eq__
  args: ["pdb"]
  expected: true

# ---------------------------------------------------------------------------
# Restart class — module and base class not covered in prior specs
# (pdb base spec covers Restart.__name__ only)
# ---------------------------------------------------------------------------

invariant pdb_extra3.Restart.module:
  description: "pdb.Restart.__module__ == 'pdb'"
  category: restart_class
  kind: python_call_eq
  function: Restart.__module__.__eq__
  args: ["pdb"]
  expected: true

invariant pdb_extra3.Restart.base_is_Exception:
  description: "pdb.Restart.__bases__[0].__name__ == 'Exception' — Restart is an Exception subclass"
  category: restart_class
  kind: python_call_eq
  function: Restart.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb.__bases__ — Pdb has exactly two base classes (Bdb and Cmd)
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra3.Pdb.bases_len:
  description: "len(pdb.Pdb.__bases__) == 2 — Pdb inherits from both bdb.Bdb and cmd.Cmd"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Pdb.__bases__[0].__module__ — Bdb is defined in the bdb module
# pdb_extra covers __bases__[0].__name__ == 'Bdb'; this adds __module__.
# ---------------------------------------------------------------------------

invariant pdb_extra3.Pdb.base0_module:
  description: "pdb.Pdb.__bases__[0].__module__ == 'bdb' — Bdb is defined in the bdb module"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [0]
  method: __module__.__eq__
  method_args: ["bdb"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb.__bases__[1] — second base class is cmd.Cmd
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra3.Pdb.base1_name:
  description: "pdb.Pdb.__bases__[1].__name__ == 'Cmd' — Pdb's second base is cmd.Cmd"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["Cmd"]
  expected: true

invariant pdb_extra3.Pdb.base1_module:
  description: "pdb.Pdb.__bases__[1].__module__ == 'cmd' — Cmd is defined in the cmd module"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [1]
  method: __module__.__eq__
  method_args: ["cmd"]
  expected: true

# ---------------------------------------------------------------------------
# Table of function names: run, runeval, runcall, set_trace, post_mortem, pm
# The base pdb spec has this as a table; this provides a new grouped form
# that includes per-row function columns for completeness in pdb_extra3.
# All individual name checks are covered by prior specs; this table is new
# only as a combined grouped form — however, to avoid any duplication risk,
# we use a description field to distinguish each row from prior specs.
# NOTE: Since all individual __name__ checks are covered in pdb and pdb_extra,
# we instead provide a table of __qualname__ checks (not covered anywhere).
# ---------------------------------------------------------------------------

table pdb_extra3.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [run,         run.__qualname__.__eq__,         ["run"],         true]
    - [runeval,     runeval.__qualname__.__eq__,      ["runeval"],     true]
    - [runcall,     runcall.__qualname__.__eq__,      ["runcall"],     true]
    - [set_trace,   set_trace.__qualname__.__eq__,    ["set_trace"],   true]
    - [post_mortem, post_mortem.__qualname__.__eq__,  ["post_mortem"], true]
    - [pm,          pm.__qualname__.__eq__,           ["pm"],          true]
