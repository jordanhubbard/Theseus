spec: re_extra227
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module and function __doc__ string contains checks, and re.PatternError.__doc__ contains check."
    - "re.__doc__.__contains__('regular') == True — re module doc starts 'Support for regular expressions (RE).'; verified with Python 3.14.3."
    - "re.compile.__doc__.__contains__('Compile') == True — compile doc is 'Compile a regular expression pattern, returning a Pattern object.'; 'compile' (lowercase) is NOT present but 'Compile' (uppercase) is; verified with Python 3.14.3."
    - "re.match.__doc__.__contains__('match') == True — match doc starts 'Try to apply the pattern at the start of the string, returning a Match object, or None if no match was found.'; verified with Python 3.14.3."
    - "re.search.__doc__.__contains__('match') == True — search doc is 'Scan through string looking for a match to the pattern, returning a Match object, or None if no match was found.'; 'search' is NOT present but 'match' is; verified with Python 3.14.3."
    - "re.sub.__doc__.__contains__('replac') == True — sub doc starts 'Return the string obtained by replacing the leftmost...'; 'replac' is a substring of 'replacing'; verified with Python 3.14.3."
    - "re.findall.__doc__.__contains__('matches') == True — findall doc starts 'Return a list of all non-overlapping matches in the string.'; 'find' is NOT present but 'matches' is; verified with Python 3.14.3."
    - "re.split.__doc__.__contains__('split') == True — split doc starts 'Split the source string by the occurrences of the pattern'; 'split' appears in 'Split'; verified with Python 3.14.3."
    - "re.escape.__doc__.__contains__('special') == True — escape doc is 'Escape special characters in a string.'; 'escape' (lowercase) is NOT present but 'special' is; verified with Python 3.14.3."
    - "re.PatternError.__doc__.__contains__('pattern') == True — PatternError doc is 'Exception raised for invalid regular expressions. Attributes: ... pattern: The regular expression pattern ...'; 'pattern' appears; re.PatternError is the canonical exception class for invalid regex patterns (added in 3.13, aliased from re.error); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level __doc__ contains check
# re.__doc__ contains 'regular'
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table re_extra227.module_doc_contains:
  description: "re.__doc__ contains 'regular'; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: redoccontains227a

  columns: [id, function, args, expected]
  rows:
    - [re_doc_regular, "__doc__.__contains__", ["regular"], true]

# ---------------------------------------------------------------------------
# re function __doc__ contains checks
# compile->Compile, match->match, search->match, sub->replac,
# findall->matches, split->split, escape->special
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table re_extra227.function_doc_contains:
  description: "re function __doc__ string contains checks for compile, match, search, sub, findall, split, escape; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: redoccontains227b

  columns: [id, function, args, expected]
  rows:
    - [compile_doc_Compile,   "compile.__doc__.__contains__",  ["Compile"],   true]
    - [match_doc_match,       "match.__doc__.__contains__",    ["match"],     true]
    - [search_doc_match,      "search.__doc__.__contains__",   ["match"],     true]
    - [sub_doc_replac,        "sub.__doc__.__contains__",      ["replac"],    true]
    - [findall_doc_matches,   "findall.__doc__.__contains__",  ["matches"],   true]
    - [split_doc_split,       "split.__doc__.__contains__",    ["split"],     true]
    - [escape_doc_special,    "escape.__doc__.__contains__",   ["special"],   true]

# ---------------------------------------------------------------------------
# re.PatternError __doc__ contains check
# PatternError added in Python 3.13; version: ">=3.11" is a conservative lower bound
# but PatternError requires 3.13+; safe to include as the compiler checks version.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table re_extra227.pattern_error_doc_contains:
  description: "re.PatternError.__doc__ contains 'pattern'; PatternError is the canonical exception class for invalid regex (added 3.13, aliased from re.error); verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: redoccontains227c

  columns: [id, function, args, expected]
  rows:
    - [patternerror_doc_pattern, "PatternError.__doc__.__contains__", ["pattern"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant re_extra227.module_doc_contains_regular:
  description: "re.__doc__.__contains__('regular') == True — re module docstring starts 'Support for regular expressions (RE).'; 'regular' is the first keyword; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["regular"]
  expected: true

invariant re_extra227.compile.doc_contains_Compile:
  description: "re.compile.__doc__.__contains__('Compile') == True — compile docstring is 'Compile a regular expression pattern, returning a Pattern object.'; sentence-initial 'Compile' (uppercase); verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: compile.__doc__.__contains__
  args: ["Compile"]
  expected: true

invariant re_extra227.match.doc_contains_match:
  description: "re.match.__doc__.__contains__('match') == True — match docstring starts 'Try to apply the pattern at the start of the string, returning a Match object, or None if no match was found.'; 'match' appears in 'Match' and 'match'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: match.__doc__.__contains__
  args: ["match"]
  expected: true

invariant re_extra227.search.doc_contains_match:
  description: "re.search.__doc__.__contains__('match') == True — search docstring is 'Scan through string looking for a match to the pattern, returning a Match object, or None if no match was found.'; 'search' is NOT present but 'match' is; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: search.__doc__.__contains__
  args: ["match"]
  expected: true

invariant re_extra227.sub.doc_contains_replac:
  description: "re.sub.__doc__.__contains__('replac') == True — sub docstring starts 'Return the string obtained by replacing the leftmost non-overlapping occurrences...'; 'replac' is a substring of 'replacing'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: sub.__doc__.__contains__
  args: ["replac"]
  expected: true

invariant re_extra227.findall.doc_contains_matches:
  description: "re.findall.__doc__.__contains__('matches') == True — findall docstring starts 'Return a list of all non-overlapping matches in the string.'; 'find' is NOT present but 'matches' is; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: findall.__doc__.__contains__
  args: ["matches"]
  expected: true

invariant re_extra227.split.doc_contains_split:
  description: "re.split.__doc__.__contains__('split') == True — split docstring starts 'Split the source string by the occurrences of the pattern'; 'split' appears in sentence-initial 'Split'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: split.__doc__.__contains__
  args: ["split"]
  expected: true

invariant re_extra227.escape.doc_contains_special:
  description: "re.escape.__doc__.__contains__('special') == True — escape docstring is 'Escape special characters in a string.'; 'special' appears immediately after 'Escape'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: escape.__doc__.__contains__
  args: ["special"]
  expected: true

invariant re_extra227.PatternError.doc_contains_pattern:
  description: "re.PatternError.__doc__.__contains__('pattern') == True — PatternError docstring is 'Exception raised for invalid regular expressions. Attributes: ... pattern: The regular expression pattern ...'; 'pattern' appears in the attributes section; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: PatternError.__doc__.__contains__
  args: ["pattern"]
  expected: true
