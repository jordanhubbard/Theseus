spec: io_extra163
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.IOBase method __qualname__ values for close, readline, readlines, writelines, flush, truncate, readable, writable."
    - "A key discovery: all io.IOBase method __qualname__ values use the private C type name '_IOBase' rather than the public Python name 'IOBase'. For example, io.IOBase.close.__qualname__ == '_IOBase.close', NOT 'IOBase.close'."
    - "This contrasts with pathlib.Path method qualnames which use the public class name 'Path.' (no underscore prefix). The io module's C extension types expose private C qualnames, while pathlib's pure-Python methods use public class names."
    - "The pattern '_IOBase.<method>' applies to: close, readline, readlines, writelines, flush, truncate, readable, writable — all eight IOBase methods examined here."
    - "Qualname lengths: close=13, flush=13, readline=16, truncate=16, readable=16, writable=16, readlines=17, writelines=18."
    - "Four-way tie at length 16: '_IOBase.readline', '_IOBase.truncate', '_IOBase.readable', '_IOBase.writable' — all have 8-character method names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase method __qualname__ values (group 1)
# close, readline, readlines, writelines — all use '_IOBase.' prefix.
# Private C type name '_IOBase' appears in qualnames, not public 'IOBase'.
# This was first noted for io.IOBase.close in io_extra160.
# close=13, readline=16, readlines=17, writelines=18
# ---------------------------------------------------------------------------

table io_extra163.IOBase_method_qualnames_group1:
  description: "io.IOBase method __qualname__ values: close='_IOBase.close' (len=13), readline='_IOBase.readline' (len=16), readlines='_IOBase.readlines' (len=17), writelines='_IOBase.writelines' (len=18); all use private '_IOBase.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: iobaseq163

  columns: [id, function, args, expected, description]
  rows:
    - [close_qeq,      IOBase.close.__qualname__.__eq__,      ["_IOBase.close"],      true, "io.IOBase.close.__qualname__ == '_IOBase.close' (the close() method on the abstract base class IOBase uses the private C type name '_IOBase' in its qualname, NOT the public Python name 'IOBase'; close() flushes and closes the stream; it is idempotent — calling it on an already-closed stream has no effect; '_IOBase.' (8 chars) + 'close' (5 chars) = 13 chars total for '_IOBase.close')"]
    - [readline_qeq,   IOBase.readline.__qualname__.__eq__,   ["_IOBase.readline"],   true, "io.IOBase.readline.__qualname__ == '_IOBase.readline' (readline() reads and returns one line from the stream; defined on IOBase as a default implementation that calls read(1) repeatedly; subclasses (BufferedReader, TextIOWrapper) override it with more efficient implementations; '_IOBase.readline' has 16 characters: '_IOBase.' (8) + 'readline' (8) = 16; same length as '_IOBase.truncate', '_IOBase.readable', '_IOBase.writable')"]
    - [readlines_qeq,  IOBase.readlines.__qualname__.__eq__,  ["_IOBase.readlines"],  true, "io.IOBase.readlines.__qualname__ == '_IOBase.readlines' (readlines() reads and returns a list of lines from the stream; optionally accepts a hint to limit total bytes read; '_IOBase.readlines' has 17 characters: '_IOBase.' (8) + 'readlines' (9) = 17; the 's' suffix adds one character over readline (16), making readlines length 17; readlines() is implemented in terms of readline() on IOBase)"]
    - [writelines_qeq, IOBase.writelines.__qualname__.__eq__, ["_IOBase.writelines"], true, "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' (writelines() writes an iterable of lines to the stream; it does NOT add line separators — that is the caller's responsibility; '_IOBase.writelines' has 18 characters: '_IOBase.' (8) + 'writelines' (10) = 18; the longest of the four group-1 IOBase method qualnames; writelines() is the write analog of readlines())"]

# ---------------------------------------------------------------------------
# io.IOBase method __qualname__ values (group 2)
# flush, truncate, readable, writable — continue '_IOBase.' prefix pattern.
# readable() and writable() are predicates; flush() and truncate() are I/O ops.
# flush=13, truncate=16, readable=16, writable=16
# ---------------------------------------------------------------------------

table io_extra163.IOBase_method_qualnames_group2:
  description: "io.IOBase method __qualname__ values: flush='_IOBase.flush' (len=13), truncate='_IOBase.truncate' (len=16), readable='_IOBase.readable' (len=16), writable='_IOBase.writable' (len=16); all use private '_IOBase.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: iobaseq163

  columns: [id, function, args, expected, description]
  rows:
    - [flush_qeq,    IOBase.flush.__qualname__.__eq__,    ["_IOBase.flush"],    true, "io.IOBase.flush.__qualname__ == '_IOBase.flush' (flush() flushes the write buffers of the stream; for read-only streams it has no effect; '_IOBase.flush' has 13 characters: '_IOBase.' (8) + 'flush' (5) = 13; same length as '_IOBase.close' (13); flush and close share the shortest qualname length of 13 among the eight IOBase methods in this spec)"]
    - [truncate_qeq, IOBase.truncate.__qualname__.__eq__, ["_IOBase.truncate"], true, "io.IOBase.truncate.__qualname__ == '_IOBase.truncate' (truncate() resizes the stream to the given number of bytes; raises UnsupportedOperation if the stream does not support truncation; '_IOBase.truncate' has 16 characters: '_IOBase.' (8) + 'truncate' (8) = 16; part of the four-way tie at length 16 with '_IOBase.readline', '_IOBase.readable', and '_IOBase.writable')"]
    - [readable_qeq, IOBase.readable.__qualname__.__eq__, ["_IOBase.readable"], true, "io.IOBase.readable.__qualname__ == '_IOBase.readable' (readable() returns True if the stream can be read; the default IOBase implementation always returns False; concrete subclasses like BufferedReader and TextIOWrapper override it to return True; '_IOBase.readable' has 16 characters: '_IOBase.' (8) + 'readable' (8) = 16; four-way tie with '_IOBase.readline', '_IOBase.truncate', and '_IOBase.writable' at length 16)"]
    - [writable_qeq, IOBase.writable.__qualname__.__eq__, ["_IOBase.writable"], true, "io.IOBase.writable.__qualname__ == '_IOBase.writable' (writable() returns True if the stream supports writing; the default IOBase implementation always returns False; BufferedWriter and TextIOWrapper override it to return True; '_IOBase.writable' has 16 characters: '_IOBase.' (8) + 'writable' (8) = 16; completes the four-way tie at length 16 with readline, truncate, and readable)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra163.IOBase_close_qualname_uses_private_prefix:
  description: "io.IOBase.close.__qualname__ == '_IOBase.close' — IOBase.close() uses the private C type name '_IOBase' in its qualname, NOT the public Python name 'IOBase'; this private C prefix pattern holds for all IOBase methods (readline, readlines, writelines, flush, truncate, readable, writable) and contrasts with pathlib.Path methods which use the public class name 'Path.'; the underscore in '_IOBase' signals that this is the internal C implementation name; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: IOBase.close.__qualname__.__eq__
  args: ["_IOBase.close"]
  expected: true

invariant io_extra163.IOBase_flush_qualname_len_13:
  description: "io.IOBase.flush.__qualname__.__len__() == 13 — '_IOBase.flush' has 13 characters: '_IOBase.' (8) + 'flush' (5) = 13; this is the same length as '_IOBase.close' (also 8+5=13); among the eight IOBase methods covered in this spec, flush and close share the shortest qualname length at 13; the '_IOBase.' prefix of 8 characters is a fixed overhead for every IOBase method qualname; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: IOBase.flush.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra163.IOBase_writelines_qualname_len_18:
  description: "io.IOBase.writelines.__qualname__.__len__() == 18 — '_IOBase.writelines' has 18 characters: '_IOBase.' (8) + 'writelines' (10) = 18; writelines() has the longest method name (10 characters) among the eight IOBase methods covered here, making '_IOBase.writelines' the longest qualname in this spec; writelines() writes an iterable of lines to the stream without adding separators; one character longer than '_IOBase.readlines' (17); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: IOBase.writelines.__qualname__.__len__
  args: []
  expected: 18

invariant io_extra163.IOBase_readable_writable_truncate_readline_qualname_len_16:
  description: "io.IOBase.readable.__qualname__.__len__() == 16 — '_IOBase.readable' has 16 characters: '_IOBase.' (8) + 'readable' (8) = 16; readable() shares qualname length 16 with writable, truncate, and readline — all four have 8-character method names that exactly match the '_IOBase.' prefix length; this four-way tie at qualname length 16 is the dominant pattern among IOBase method qualnames; the readable() predicate returns True only if the stream supports read operations; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: IOBase.readable.__qualname__.__len__
  args: []
  expected: 16
