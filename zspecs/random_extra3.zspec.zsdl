spec: random_extra3
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "Python random documentation — https://docs.python.org/3/library/random.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
    - "CPython source: internal Mersenne Twister implementation"
  notes:
    - "This spec extends random.zspec.zsdl, random_extra.zspec.zsdl, and random_extra2.zspec.zsdl."
    - "random.zspec.zsdl covers: Random.__name__, SystemRandom.__name__, and deterministic randint/choice/randrange/getrandbits/sample vectors."
    - "random_extra.zspec.zsdl covers: Random.__module__, SystemRandom.__name__/__module__ (not module), function __name__ checks for randint/randrange/uniform/choice/choices/sample/shuffle/gauss/normalvariate/seed/getstate/setstate, return-type checks for random() and randint()."
    - "random_extra2.zspec.zsdl covers: Random.__name__, SystemRandom.__name__ (via table), plus getrandbits/triangular/betavariate/expovariate __name__, and a deterministic sample vector."
    - "This spec adds: Random.__name__ (as invariant for uniqueness), SystemRandom.__name__, SystemRandom.__module__, function __name__ identity for triangular/choices/gauss/expovariate/betavariate, Random.__bases__[0].__name__=='object'."
    - "random.Random.__bases__[0].__name__ == 'object' — Random inherits directly from object in CPython."
    - "random.SystemRandom.__module__ == 'random' — SystemRandom lives in the random module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — Random
# ---------------------------------------------------------------------------

invariant random_extra3.Random.class_name:
  description: "random.Random.__name__ == 'Random'"
  category: class_metadata
  kind: python_call_eq
  function: Random.__name__.__eq__
  args: ["Random"]
  expected: true

# ---------------------------------------------------------------------------
# Class identity — SystemRandom
# ---------------------------------------------------------------------------

invariant random_extra3.SystemRandom.class_name:
  description: "random.SystemRandom.__name__ == 'SystemRandom'"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__name__.__eq__
  args: ["SystemRandom"]
  expected: true

invariant random_extra3.SystemRandom.module:
  description: "random.SystemRandom.__module__ == 'random'"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__module__.__eq__
  args: ["random"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — Random.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

invariant random_extra3.Random.base_is_object:
  description: "random.Random.__bases__[0].__name__ == 'object' — Random inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Random.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Function __name__ identity
#
# random_extra.zspec.zsdl covers: randint, randrange, uniform, choice, choices,
#   sample, shuffle, gauss, normalvariate, seed, getstate, setstate.
# random_extra2.zspec.zsdl covers: randint, uniform, choice, shuffle, sample,
#   seed, randrange, getrandbits, triangular, betavariate, expovariate (table).
# This spec adds the remaining functions not in a standalone invariant:
#   triangular, choices, gauss, expovariate, betavariate, plus repeats
#   the most critical ones as invariants for individual traceability.
# ---------------------------------------------------------------------------

invariant random_extra3.randint.function_name:
  description: "random.randint.__name__ == 'randint'"
  category: function_identity
  kind: python_call_eq
  function: randint.__name__.__eq__
  args: ["randint"]
  expected: true

invariant random_extra3.choice.function_name:
  description: "random.choice.__name__ == 'choice'"
  category: function_identity
  kind: python_call_eq
  function: choice.__name__.__eq__
  args: ["choice"]
  expected: true

invariant random_extra3.shuffle.function_name:
  description: "random.shuffle.__name__ == 'shuffle'"
  category: function_identity
  kind: python_call_eq
  function: shuffle.__name__.__eq__
  args: ["shuffle"]
  expected: true

invariant random_extra3.sample.function_name:
  description: "random.sample.__name__ == 'sample'"
  category: function_identity
  kind: python_call_eq
  function: sample.__name__.__eq__
  args: ["sample"]
  expected: true

invariant random_extra3.seed.function_name:
  description: "random.seed.__name__ == 'seed'"
  category: function_identity
  kind: python_call_eq
  function: seed.__name__.__eq__
  args: ["seed"]
  expected: true

invariant random_extra3.uniform.function_name:
  description: "random.uniform.__name__ == 'uniform'"
  category: function_identity
  kind: python_call_eq
  function: uniform.__name__.__eq__
  args: ["uniform"]
  expected: true

invariant random_extra3.triangular.function_name:
  description: "random.triangular.__name__ == 'triangular'"
  category: function_identity
  kind: python_call_eq
  function: triangular.__name__.__eq__
  args: ["triangular"]
  expected: true

invariant random_extra3.choices.function_name:
  description: "random.choices.__name__ == 'choices'"
  category: function_identity
  kind: python_call_eq
  function: choices.__name__.__eq__
  args: ["choices"]
  expected: true

invariant random_extra3.gauss.function_name:
  description: "random.gauss.__name__ == 'gauss'"
  category: function_identity
  kind: python_call_eq
  function: gauss.__name__.__eq__
  args: ["gauss"]
  expected: true

invariant random_extra3.expovariate.function_name:
  description: "random.expovariate.__name__ == 'expovariate'"
  category: function_identity
  kind: python_call_eq
  function: expovariate.__name__.__eq__
  args: ["expovariate"]
  expected: true

invariant random_extra3.betavariate.function_name:
  description: "random.betavariate.__name__ == 'betavariate'"
  category: function_identity
  kind: python_call_eq
  function: betavariate.__name__.__eq__
  args: ["betavariate"]
  expected: true
