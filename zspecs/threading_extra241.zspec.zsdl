spec: threading_extra241
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra172.zspec.zsdl — covers threading.Thread identity"
  notes:
    - "This spec covers threading.Timer class identity and threading.main_thread function identity contracts."
    - "threading.Timer.__name__ == 'Timer' (len=5) — Timer is a class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' (len=9) — Timer is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread. Verified with Python 3.14.3."
    - "threading.Timer.__class__.__name__ == 'type' — Timer is a class; its metaclass is type. Verified with Python 3.14.3."
    - "threading.Timer.__qualname__ == 'Timer' (len=5) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "threading.main_thread.__name__ == 'main_thread' (len=11) — main_thread is a function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.main_thread.__module__ == 'threading' (len=9) — main_thread is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.main_thread.__class__.__name__ == 'function' — main_thread is a plain Python function. Verified with Python 3.14.3."
    - "threading.main_thread.__qualname__ == 'main_thread' (len=11) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "threading.main_thread.__doc__ contains 'main' == True — docstring says 'Return the main thread object.'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer identity contracts
#
# threading.Timer.__name__ == 'Timer' (len=5)
# threading.Timer.__module__ == 'threading' (len=9)
# threading.Timer.__bases__[0].__name__ == 'Thread'
# threading.Timer.__class__.__name__ == 'type'
# threading.Timer.__qualname__ == 'Timer' (len=5)
#
# Timer is a class in Lib/threading.py that inherits from Thread. New to extra241.
# ---------------------------------------------------------------------------

table threading_extra241.timer241_identity:
  description: "threading.Timer identity: name, module, bases, class, qualname; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: timer241

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a class in Lib/threading.py; __name__ is 'Timer' (len=5); new to extra241"]
    - [timer_name_len_5,
       Timer.__name__.__len__,
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — 'Timer' has exactly 5 characters; str.__len__() returns 5; new to extra241"]
    - [timer_module_eq,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra241"]
    - [timer_module_len_9,
       Timer.__module__.__len__,
       [],
       9,
       "threading.Timer.__module__.__len__() == 9 — 'threading' has exactly 9 characters; str.__len__() returns 9; new to extra241"]
    - [timer_bases_0_is_thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer inherits from Thread; __bases__[0].__name__ is 'Thread'; new to extra241"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer class and qualname contracts
#
# threading.Timer.__class__.__name__ == 'type'
# threading.Timer.__qualname__ == 'Timer' (len=5)
# threading.Timer.__doc__ contains 'timer' (case-insensitive) == True
# threading.Timer.__bases__[0].__module__ == 'threading'
#
# New to extra241.
# ---------------------------------------------------------------------------

table threading_extra241.timer241_class:
  description: "threading.Timer class, qualname, doc, base module checks; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: timer241cls

  columns: [id, function, args, expected, description]
  rows:
    - [timer_class_is_type,
       Timer.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Timer.__class__.__name__.__eq__('type') == True — Timer is a class; its metaclass is the built-in type; new to extra241"]
    - [timer_qualname_eq,
       Timer.__qualname__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — __qualname__ is 'Timer' (len=5); same as __name__ for top-level class; new to extra241"]
    - [timer_qualname_len_5,
       Timer.__qualname__.__len__,
       [],
       5,
       "threading.Timer.__qualname__.__len__() == 5 — 'Timer' has exactly 5 characters; str.__len__() returns 5; new to extra241"]
    - [timer_doc_contains_seconds,
       Timer.__doc__.__contains__,
       ["seconds"],
       true,
       "threading.Timer.__doc__.__contains__('seconds') == True — docstring says 'Call a function after a specified number of seconds'; new to extra241"]
    - [timer_base_module_eq,
       "Timer.__bases__[0].__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__bases__[0].__module__.__eq__('threading') == True — Thread base class is also defined in Lib/threading.py; new to extra241"]

# ---------------------------------------------------------------------------
# Table 3: threading.main_thread identity contracts
#
# threading.main_thread.__name__ == 'main_thread' (len=11)
# threading.main_thread.__module__ == 'threading' (len=9)
# threading.main_thread.__class__.__name__ == 'function'
# threading.main_thread.__qualname__ == 'main_thread' (len=11)
# threading.main_thread.__doc__ contains 'main' == True
#
# main_thread is a plain Python function in Lib/threading.py. New to extra241.
# ---------------------------------------------------------------------------

table threading_extra241.mthread241_identity:
  description: "threading.main_thread identity: name, module, class, qualname, doc; new to extra241"
  kind: python_call_eq
  category: identity
  id_prefix: mthread241

  columns: [id, function, args, expected, description]
  rows:
    - [mthread_name_eq,
       main_thread.__name__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — main_thread is a function in Lib/threading.py; __name__ is 'main_thread' (len=11); new to extra241"]
    - [mthread_name_len_11,
       main_thread.__name__.__len__,
       [],
       11,
       "threading.main_thread.__name__.__len__() == 11 — 'main_thread' has exactly 11 characters; str.__len__() returns 11; new to extra241"]
    - [mthread_module_eq,
       main_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra241"]
    - [mthread_class_is_function,
       main_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.main_thread.__class__.__name__.__eq__('function') == True — main_thread is a plain Python function; its __class__ is 'function'; new to extra241"]
    - [mthread_qualname_eq,
       main_thread.__qualname__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__qualname__.__eq__('main_thread') == True — __qualname__ is 'main_thread' (len=11); same as __name__ for top-level function; new to extra241"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra241
# ---------------------------------------------------------------------------

invariant threading_extra241.timer_name_eq:
  description: "threading.Timer.__name__ == 'Timer' (len=5); new to extra241"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra241.timer_name_len_5:
  description: "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 characters; new to extra241"
  kind: python_call_eq
  function: Timer.__name__.__len__
  args: []
  expected: 5

invariant threading_extra241.timer_module_eq:
  description: "threading.Timer.__module__ == 'threading' — defined in Lib/threading.py; new to extra241"
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra241.timer_module_len_9:
  description: "threading.Timer.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra241"
  kind: python_call_eq
  function: Timer.__module__.__len__
  args: []
  expected: 9

invariant threading_extra241.timer_bases_0_is_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread; new to extra241"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra241.timer_class_is_type:
  description: "threading.Timer.__class__.__name__ == 'type'; new to extra241"
  kind: python_call_eq
  function: Timer.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra241.timer_qualname_eq:
  description: "threading.Timer.__qualname__ == 'Timer' (len=5); new to extra241"
  kind: python_call_eq
  function: Timer.__qualname__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra241.mthread_name_eq:
  description: "threading.main_thread.__name__ == 'main_thread' (len=11); new to extra241"
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra241.mthread_name_len_11:
  description: "threading.main_thread.__name__.__len__() == 11 — 'main_thread' has 11 characters; new to extra241"
  kind: python_call_eq
  function: main_thread.__name__.__len__
  args: []
  expected: 11

invariant threading_extra241.mthread_module_eq:
  description: "threading.main_thread.__module__ == 'threading' — defined in Lib/threading.py; new to extra241"
  kind: python_call_eq
  function: main_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra241.mthread_module_len_9:
  description: "threading.main_thread.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra241"
  kind: python_call_eq
  function: main_thread.__module__.__len__
  args: []
  expected: 9

invariant threading_extra241.mthread_class_is_function:
  description: "threading.main_thread.__class__.__name__ == 'function' — plain Python function; new to extra241"
  kind: python_call_eq
  function: main_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra241.mthread_qualname_eq:
  description: "threading.main_thread.__qualname__ == 'main_thread' (len=11); new to extra241"
  kind: python_call_eq
  function: main_thread.__qualname__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra241.mthread_doc_contains_main:
  description: "threading.main_thread.__doc__.__contains__('main') == True — docstring mentions 'main'; new to extra241"
  kind: python_call_eq
  function: main_thread.__doc__.__contains__
  args: ["main"]
  expected: true

invariant threading_extra241.mthread_doc_contains_thread:
  description: "threading.main_thread.__doc__.__contains__('thread') == True — docstring mentions 'thread'; new to extra241"
  kind: python_call_eq
  function: main_thread.__doc__.__contains__
  args: ["thread"]
  expected: true
