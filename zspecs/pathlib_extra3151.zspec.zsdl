spec: pp3151
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (pp3151): __setitem__, __delitem__, __contains__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "No pathlib class defines __setitem__ in its own __dict__: path objects are immutable and do not support item assignment."
    - "No pathlib class defines __delitem__ in its own __dict__: path objects do not support item deletion."
    - "No pathlib class defines __contains__ in its own __dict__: path objects do not implement membership testing."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# No pathlib class defines __setitem__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths; item assignment is not supported.
# ---------------------------------------------------------------------------

table pp3151.setitem:
  description: "pathlib types __setitem__ dict-presence checks; wave 657"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3151

  columns: [id, function, args, expected]
  rows:
    - ["pp3151001", operator.contains, [pathlib.PurePath.__dict__,        "__setitem__"], false]
    - ["pp3151002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__setitem__"], false]
    - ["pp3151003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__setitem__"], false]
    - ["pp3151004", operator.contains, [pathlib.Path.__dict__,             "__setitem__"], false]
    - ["pp3151005", operator.contains, [pathlib.PosixPath.__dict__,        "__setitem__"], false]

