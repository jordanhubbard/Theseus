spec: functools_extra1696
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python functools documentation — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and callable type checks"
    - "functools_extra.zspec.zsdl — covers __name__ and __module__ for public symbols"
    - "functools_extra1681.zspec.zsdl — covers __call__ callable protocol and descriptor attrs"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "functools.partial is a C extension type that defines custom pickling: __reduce__ and __setstate__ are in its __dict__."
    - "functools.partial does NOT define __getstate__ (state is reconstructed via __setstate__ from the __reduce__ tuple)."
    - "functools.partial does NOT define __getnewargs__ or __getnewargs_ex__ (uses __reduce__ protocol instead)."
    - "functools.cached_property is a pure Python class with no custom pickling — __reduce__ not in __dict__ → False."
    - "functools._lru_cache_wrapper is a C extension type; it does not define __reduce__ in its __dict__ — lru_cache wrappers are not picklable."
    - "functools.partialmethod is a pure Python class; it does not define pickling protocol methods in its __dict__."
    - "Also checked: __copy__ and __deepcopy__ — neither is defined directly on functools types in their class __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol
#
# Records whether each functools type defines the five pickling dunder methods
# (__reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__)
# directly in its own __dict__.
#
# functools.partial: __reduce__ → True, __setstate__ → True, rest → False.
# All others: all five → False.
# ---------------------------------------------------------------------------

table functools_extra1696.pickling_protocol:
  description: "functools types pickling protocol dict-presence checks"
  kind: python_call_eq
  category: pickling_protocol
  id_prefix: fu1696

  columns: [id, function, args, expected]
  rows:
    - ["fu1696001", "functools.partial.__dict__.__contains__",            ["__reduce__"],       true]
    - ["fu1696002", "functools.partial.__dict__.__contains__",            ["__setstate__"],     true]
    - ["fu1696003", "functools.partial.__dict__.__contains__",            ["__getstate__"],     false]
    - ["fu1696004", "functools.partial.__dict__.__contains__",            ["__getnewargs__"],   false]
    - ["fu1696005", "functools.partial.__dict__.__contains__",            ["__getnewargs_ex__"], false]
    - ["fu1696006", "functools.cached_property.__dict__.__contains__",    ["__reduce__"],       false]
    - ["fu1696007", "functools.cached_property.__dict__.__contains__",    ["__setstate__"],     false]
    - ["fu1696008", "functools.cached_property.__dict__.__contains__",    ["__getstate__"],     false]
    - ["fu1696009", "functools.cached_property.__dict__.__contains__",    ["__getnewargs__"],   false]
    - ["fu1696010", "functools.cached_property.__dict__.__contains__",    ["__getnewargs_ex__"], false]
    - ["fu1696011", "functools._lru_cache_wrapper.__dict__.__contains__", ["__reduce__"],       false]
    - ["fu1696012", "functools._lru_cache_wrapper.__dict__.__contains__", ["__getstate__"],     false]
    - ["fu1696013", "functools._lru_cache_wrapper.__dict__.__contains__", ["__setstate__"],     false]
    - ["fu1696014", "functools.partialmethod.__dict__.__contains__",      ["__reduce__"],       false]
    - ["fu1696015", "functools.partialmethod.__dict__.__contains__",      ["__getstate__"],     false]
    - ["fu1696016", "functools.partialmethod.__dict__.__contains__",      ["__setstate__"],     false]

# ---------------------------------------------------------------------------
# Table 2: copy_protocol
#
# Checks whether functools types define __copy__ or __deepcopy__ in their
# own __dict__.  Neither is defined directly on any functools type — copying
# of partial objects relies on the standard pickling-based copy fallback.
# ---------------------------------------------------------------------------

table functools_extra1696.copy_protocol:
  description: "functools types copy protocol (__copy__, __deepcopy__) dict-presence checks"
  kind: python_call_eq
  category: copy_protocol
  id_prefix: fu1696

  columns: [id, function, args, expected]
  rows:
    - ["fu1696020", "functools.partial.__dict__.__contains__",            ["__copy__"],     false]
    - ["fu1696021", "functools.partial.__dict__.__contains__",            ["__deepcopy__"], false]
    - ["fu1696022", "functools.cached_property.__dict__.__contains__",    ["__copy__"],     false]
    - ["fu1696023", "functools.cached_property.__dict__.__contains__",    ["__deepcopy__"], false]
    - ["fu1696024", "functools._lru_cache_wrapper.__dict__.__contains__", ["__copy__"],     false]
    - ["fu1696025", "functools._lru_cache_wrapper.__dict__.__contains__", ["__deepcopy__"], false]
    - ["fu1696026", "functools.partialmethod.__dict__.__contains__",      ["__copy__"],     false]
    - ["fu1696027", "functools.partialmethod.__dict__.__contains__",      ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: partial_pickling_coexistence
#
# Contrasts the pickling attrs that ARE present on functools.partial with
# other structural attrs, confirming pickling coexists with the core
# callable/descriptor interface of partial.
# ---------------------------------------------------------------------------

table functools_extra1696.partial_pickling_coexistence:
  description: "functools.partial pickling attrs alongside callable/descriptor attrs"
  kind: python_call_eq
  category: partial_pickling_coexistence
  id_prefix: fu1696

  columns: [id, function, args, expected]
  rows:
    - ["fu1696030", "functools.partial.__dict__.__contains__", ["__reduce__"],   true]
    - ["fu1696031", "functools.partial.__dict__.__contains__", ["__setstate__"], true]
    - ["fu1696032", "functools.partial.__dict__.__contains__", ["__call__"],     true]
    - ["fu1696033", "functools.partial.__dict__.__contains__", ["__get__"],      true]
    - ["fu1696034", "functools.partial.__dict__.__contains__", ["func"],         true]
    - ["fu1696035", "functools.partial.__dict__.__contains__", ["args"],         true]
    - ["fu1696036", "functools.partial.__dict__.__contains__", ["keywords"],     true]
    - ["fu1696037", "functools.partial.__dict__.__contains__", ["__repr__"],     true]
