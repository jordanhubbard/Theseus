spec: io_extra256
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers io.open and io.open_code function identity, seek constants (SEEK_SET, SEEK_CUR, SEEK_END), DEFAULT_BUFFER_SIZE, and UnsupportedOperation class identity."
    - "io.open is a builtin_function_or_method defined in the _io C extension; io.open.__module__ == '_io' (not 'io') because it is implemented in C, not in Lib/io.py."
    - "io.open_code was added in Python 3.8 as a hook for audit tools; it is also a builtin_function_or_method with __module__ == '_io'."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — these mirror POSIX seek origin constants and are stable across all Python versions."
    - "io.DEFAULT_BUFFER_SIZE == 131072 on Python 3.14.3/macOS; note that this constant is 8192 on some older Python builds and platforms — the value was increased to 131072 in recent CPython; verified 131072 on macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__module__ == 'io' — the exception is defined in Lib/io.py (the Python wrapper module), not in the C extension _io."
    - "io.UnsupportedOperation inherits from both OSError and ValueError (in that order): __bases__[0].__name__ == 'OSError', __bases__[1].__name__ == 'ValueError'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.open and io.open_code function identity
#
# io.open is a builtin_function_or_method alias for the C-level _io.open.
# io.open_code (added in 3.8) opens a file for code execution; it also
# lives in _io.
# ---------------------------------------------------------------------------

table io_extra256.open_function_identity:
  description: "io.open and io.open_code function identity — __name__, __module__, __class__.__name__; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: ioxof256

  columns: [id, function, args, expected, description]
  rows:
    - [open_name,
       "open.__name__.__eq__",
       ["open"],
       true,
       "io.open.__name__.__eq__('open') == True — io.open is the public alias for the C-level _io.open builtin; its __name__ is 'open'; str.__eq__('open') returns True; new to extra256"]
    - [open_module,
       "open.__module__.__eq__",
       ["_io"],
       true,
       "io.open.__module__.__eq__('_io') == True — io.open is implemented in the C extension _io (not in Lib/io.py); its __module__ is '_io'; str.__eq__('_io') returns True; new to extra256"]
    - [open_class,
       "open.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "io.open.__class__.__name__.__eq__('builtin_function_or_method') == True — io.open is a C-level builtin function; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra256"]
    - [open_code_name,
       "open_code.__name__.__eq__",
       ["open_code"],
       true,
       "io.open_code.__name__.__eq__('open_code') == True — io.open_code is a C-level builtin that opens a file for reading as code (subject to auditing hooks, added in Python 3.8); its __name__ is 'open_code'; str.__eq__('open_code') returns True; new to extra256"]
    - [open_code_module,
       "open_code.__module__.__eq__",
       ["_io"],
       true,
       "io.open_code.__module__.__eq__('_io') == True — io.open_code is implemented in the C extension _io; its __module__ is '_io'; str.__eq__('_io') returns True; new to extra256"]
    - [open_code_class,
       "open_code.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "io.open_code.__class__.__name__.__eq__('builtin_function_or_method') == True — io.open_code is a C-level builtin function; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra256"]

# ---------------------------------------------------------------------------
# Table 2: io seek constants
#
# io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — these mirror the
# POSIX lseek(2) whence constants and are stable across all Python versions.
# Also: io.DEFAULT_BUFFER_SIZE == 131072 (verified on Python 3.14.3/macOS).
# ---------------------------------------------------------------------------

table io_extra256.seek_constants:
  description: "io seek constants — SEEK_SET=0, SEEK_CUR=1, SEEK_END=2, DEFAULT_BUFFER_SIZE=131072; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: ioxsc256

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_value,
       "SEEK_SET.__eq__",
       [0],
       true,
       "io.SEEK_SET.__eq__(0) == True — io.SEEK_SET == 0 is the seek origin constant for seeking from the beginning of the file; mirrors POSIX SEEK_SET; int.__eq__(0) returns True; new to extra256"]
    - [seek_cur_value,
       "SEEK_CUR.__eq__",
       [1],
       true,
       "io.SEEK_CUR.__eq__(1) == True — io.SEEK_CUR == 1 is the seek origin constant for seeking from the current position; mirrors POSIX SEEK_CUR; int.__eq__(1) returns True; new to extra256"]
    - [seek_end_value,
       "SEEK_END.__eq__",
       [2],
       true,
       "io.SEEK_END.__eq__(2) == True — io.SEEK_END == 2 is the seek origin constant for seeking from the end of the file; mirrors POSIX SEEK_END; int.__eq__(2) returns True; new to extra256"]
    - [default_buffer_size,
       "DEFAULT_BUFFER_SIZE.__eq__",
       [131072],
       true,
       "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — io.DEFAULT_BUFFER_SIZE is the default I/O buffer size used by open(); on Python 3.14.3/macOS it is 131072 bytes (128 KiB); int.__eq__(131072) returns True; new to extra256"]
    - [seek_set_class,
       "SEEK_SET.__class__.__name__.__eq__",
       ["int"],
       true,
       "io.SEEK_SET.__class__.__name__.__eq__('int') == True — SEEK_SET is a plain Python int constant; its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra256"]
    - [seek_cur_not_zero,
       "SEEK_CUR.__eq__",
       [0],
       false,
       "io.SEEK_CUR.__eq__(0) == False — SEEK_CUR is 1, not 0; cross-check distinguishing SEEK_CUR from SEEK_SET; int.__eq__(0) returns False; new to extra256"]

# ---------------------------------------------------------------------------
# Table 3: io.UnsupportedOperation class identity
#
# io.UnsupportedOperation is the exception raised when an unsupported I/O
# operation is requested (e.g. seeking a non-seekable stream). It inherits
# from both OSError and ValueError (multiple inheritance), making it
# catchable by either base type.
# ---------------------------------------------------------------------------

table io_extra256.unsupported_operation_identity:
  description: "io.UnsupportedOperation class identity — __name__, __module__, __bases__[0] OSError, __bases__[1] ValueError; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: ioxuoi256

  columns: [id, function, args, expected, description]
  rows:
    - [unsupported_op_name,
       "UnsupportedOperation.__name__.__eq__",
       ["UnsupportedOperation"],
       true,
       "io.UnsupportedOperation.__name__.__eq__('UnsupportedOperation') == True — UnsupportedOperation is the exception for unsupported I/O operations (e.g. seek on a non-seekable stream); its __name__ is 'UnsupportedOperation'; str.__eq__('UnsupportedOperation') returns True; new to extra256"]
    - [unsupported_op_module,
       "UnsupportedOperation.__module__.__eq__",
       ["io"],
       true,
       "io.UnsupportedOperation.__module__.__eq__('io') == True — UnsupportedOperation is defined in the Python-level Lib/io.py wrapper (not in the C extension _io); its __module__ is 'io'; str.__eq__('io') returns True; new to extra256"]
    - [unsupported_op_base0,
       "UnsupportedOperation.__bases__[0].__name__.__eq__",
       ["OSError"],
       true,
       "io.UnsupportedOperation.__bases__[0].__name__.__eq__('OSError') == True — UnsupportedOperation's first base is OSError; this makes it catchable as an OS-level error; __bases__[0].__name__ is 'OSError'; str.__eq__('OSError') returns True; new to extra256"]
    - [unsupported_op_base1,
       "UnsupportedOperation.__bases__[1].__name__.__eq__",
       ["ValueError"],
       true,
       "io.UnsupportedOperation.__bases__[1].__name__.__eq__('ValueError') == True — UnsupportedOperation's second base is ValueError; this makes it catchable as a value error when the operation is logically invalid; __bases__[1].__name__ is 'ValueError'; str.__eq__('ValueError') returns True; new to extra256"]
    - [unsupported_op_is_type,
       "UnsupportedOperation.__class__.__name__.__eq__",
       ["type"],
       true,
       "io.UnsupportedOperation.__class__.__name__.__eq__('type') == True — UnsupportedOperation is a class object; its metaclass is the standard 'type'; str.__eq__('type') returns True; new to extra256"]
    - [unsupported_op_module_not_underscore_io,
       "UnsupportedOperation.__module__.__eq__",
       ["_io"],
       false,
       "io.UnsupportedOperation.__module__.__eq__('_io') == False — UnsupportedOperation is defined in Lib/io.py (the Python wrapper), not in the C extension _io; its __module__ is 'io', not '_io'; str.__eq__('_io') returns False; new to extra256"]

# ---------------------------------------------------------------------------
# Standalone invariants — io_extra256
# ---------------------------------------------------------------------------

invariant io_extra256.open_name:
  description: "io.open.__name__ == 'open' — io.open is the C-level builtin file opener; new to extra256"
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra256.open_module_is_underscore_io:
  description: "io.open.__module__ == '_io' — io.open is implemented in the C extension _io, not Lib/io.py; new to extra256"
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra256.open_is_builtin:
  description: "io.open.__class__.__name__ == 'builtin_function_or_method' — io.open is a C-level builtin; new to extra256"
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant io_extra256.seek_set_is_zero:
  description: "io.SEEK_SET == 0 — SEEK_SET is the seek-from-beginning constant; new to extra256"
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra256.seek_end_is_two:
  description: "io.SEEK_END == 2 — SEEK_END is the seek-from-end constant; new to extra256"
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra256.unsupported_operation_base_is_oserror:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — UnsupportedOperation's first base is OSError; new to extra256"
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant io_extra256.unsupported_operation_base1_is_valueerror:
  description: "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' — UnsupportedOperation's second base is ValueError (multiple inheritance); new to extra256"
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[1].__name__.__eq__"
  args: ["ValueError"]
  expected: true
