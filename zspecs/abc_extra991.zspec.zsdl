spec: abc_extra991
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta and ABC documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta and abc.ABC inherited method qualnames resolving to type and object"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra991.abcmeta_inherited_qualnames:
  description: "abc.ABCMeta inherited method __qualname__ identity (resolves to type methods)"
  kind: python_call_eq
  category: abcmeta_inherited_qualnames
  id_prefix: ab991mq
  columns: [id, function, args, expected]
  rows:
    - [ab991mq001, abc.ABCMeta.__call__.__qualname__.__eq__, ["type.__call__"], true]
    - [ab991mq002, abc.ABCMeta.__repr__.__qualname__.__eq__, ["type.__repr__"], true]
    - [ab991mq003, abc.ABCMeta.__str__.__qualname__.__eq__, ["type.__str__"], true]
    - [ab991mq004, abc.ABCMeta.__init_subclass__.__qualname__.__eq__, ["type.__init_subclass__"], true]
    - [ab991mq005, abc.ABCMeta.__prepare__.__qualname__.__eq__, ["type.__prepare__"], true]
    - [ab991mq006, abc.ABCMeta.__sizeof__.__qualname__.__eq__, ["type.__sizeof__"], true]

table abc_extra991.abc_inherited_qualnames:
  description: "abc.ABC inherited method __qualname__ identity (resolves to object methods)"
  kind: python_call_eq
  category: abc_inherited_qualnames
  id_prefix: ab991aq
  columns: [id, function, args, expected]
  rows:
    - [ab991aq001, abc.ABC.__repr__.__qualname__.__eq__, ["object.__repr__"], true]
    - [ab991aq002, abc.ABC.__str__.__qualname__.__eq__, ["object.__str__"], true]
    - [ab991aq003, abc.ABC.__hash__.__qualname__.__eq__, ["object.__hash__"], true]
    - [ab991aq004, abc.ABC.__eq__.__qualname__.__eq__, ["object.__eq__"], true]
    - [ab991aq005, abc.ABC.__ne__.__qualname__.__eq__, ["object.__ne__"], true]
    - [ab991aq006, abc.ABC.__lt__.__qualname__.__eq__, ["object.__lt__"], true]
    - [ab991aq007, abc.ABC.__le__.__qualname__.__eq__, ["object.__le__"], true]
    - [ab991aq008, abc.ABC.__gt__.__qualname__.__eq__, ["object.__gt__"], true]
    - [ab991aq009, abc.ABC.__ge__.__qualname__.__eq__, ["object.__ge__"], true]

table abc_extra991.abc_module_qualnames:
  description: "abc module-level function __qualname__ identity"
  kind: python_call_eq
  category: abc_module_qualnames
  id_prefix: ab991fq
  columns: [id, function, args, expected]
  rows:
    - [ab991fq001, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [ab991fq002, abc.get_cache_token.__qualname__.__eq__, ["get_cache_token"], true]
    - [ab991fq003, abc.ABC.__class__.__name__.__eq__, ["ABCMeta"], true]
    - [ab991fq004, abc.ABCMeta.__module__.__eq__, ["abc"], true]
    - [ab991fq005, abc.ABC.__doc__.__class__.__name__.__eq__, ["NoneType"], true]
