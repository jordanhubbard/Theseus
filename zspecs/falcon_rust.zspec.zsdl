spec: falcon_rust
version: ">=3.9"
backend: rust_module(falcon_rust)

docs: https://falcon.readthedocs.io/

provenance:
  derived_from:
    - "https://falcon.readthedocs.io/ — Falcon web framework"
  notes:
    - "Falcon is a bare-metal WSGI/ASGI web framework."
    - "falcon.App is a class."
    - "falcon.Request is a class."
    - "falcon.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant falcon_rust.has_app:
  description: "falcon.App is a class"
  category: presence
  kind: python_call_eq
  function: falcon_has_app
  args: []
  expected: true

invariant falcon_rust.has_request:
  description: "falcon.Request is a class"
  category: presence
  kind: python_call_eq
  function: falcon_has_request
  args: []
  expected: true

invariant falcon_rust.version_nonempty:
  description: "falcon.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: falcon_version_nonempty
  args: []
  expected: true

