spec: functools_extra14
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra13.zspec.zsdl."
    - "functools_extra13 covers: __name__ string lengths for reduce/partial/wraps/cached_property; __bases__[0].__name__ for partial and cached_property; reduce/__qualname__.__len__() and partial/__qualname__.__len__(); wraps and cached_property standalone qualname invariants."
    - "No prior spec covers __name__.__len__() for cmp_to_key, total_ordering, lru_cache, singledispatch, or singledispatchmethod."
    - "No prior spec covers __qualname__.__len__() for total_ordering, cmp_to_key, lru_cache, singledispatch, or singledispatchmethod."
    - "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has 10 characters."
    - "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters."
    - "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters."
    - "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters."
    - "functools.singledispatchmethod.__name__.__len__() == 20 — 'singledispatchmethod' has 20 characters."
    - "functools.cmp_to_key.__qualname__.__len__() == 10 — qualname equals name for a top-level symbol."
    - "functools.total_ordering.__qualname__.__len__() == 14 — top-level decorator class."
    - "functools.lru_cache.__qualname__.__len__() == 9 — verified on Python 3.14."
    - "functools.singledispatch.__qualname__.__len__() == 14 — top-level function."
    - "functools.singledispatchmethod.__qualname__.__len__() == 20 — top-level class."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ string lengths for functools symbols not yet covered
#
# functools_extra13 covers __name__.__len__() for reduce/partial/wraps/
# cached_property. No prior spec checks the length of __name__ for
# cmp_to_key, total_ordering, lru_cache, singledispatch, or
# singledispatchmethod. These are structural checks independent of equality.
# ---------------------------------------------------------------------------

table functools_extra14.function_name_lengths:
  kind: python_call_eq
  category: function_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [cmp_to_key,           cmp_to_key.__name__.__len__,           [], 10]
    - [total_ordering,       total_ordering.__name__.__len__,       [], 14]
    - [lru_cache,            lru_cache.__name__.__len__,            [], 9]
    - [singledispatch,       singledispatch.__name__.__len__,       [], 14]
    - [singledispatchmethod, singledispatchmethod.__name__.__len__, [], 20]

# ---------------------------------------------------------------------------
# __qualname__ string lengths for functools symbols not yet covered
#
# functools_extra13 covers __qualname__.__len__() for reduce/partial.
# functools_extra12 covers lru_cache.__qualname__.__len__() == 9.
# No prior spec checks __qualname__.__len__() for cmp_to_key, total_ordering,
# singledispatch, or singledispatchmethod. For top-level symbols qualname
# equals name, so their lengths are identical to the __name__ lengths above.
# Verifying both axes independently provides orthogonal structural coverage.
# ---------------------------------------------------------------------------

invariant functools_extra14.cmp_to_key.qualname_len:
  description: "len(functools.cmp_to_key.__qualname__) == 10 — 'cmp_to_key' has 10 characters"
  category: qualnames
  kind: python_call_eq
  function: cmp_to_key.__qualname__.__len__
  args: []
  expected: 10

invariant functools_extra14.total_ordering.qualname_len:
  description: "len(functools.total_ordering.__qualname__) == 14 — 'total_ordering' has 14 characters"
  category: qualnames
  kind: python_call_eq
  function: total_ordering.__qualname__.__len__
  args: []
  expected: 14

invariant functools_extra14.singledispatch.qualname_len:
  description: "len(functools.singledispatch.__qualname__) == 14 — 'singledispatch' has 14 characters"
  category: qualnames
  kind: python_call_eq
  function: singledispatch.__qualname__.__len__
  args: []
  expected: 14

invariant functools_extra14.singledispatchmethod.qualname_len:
  description: "len(functools.singledispatchmethod.__qualname__) == 20 — 'singledispatchmethod' has 20 characters"
  category: qualnames
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__len__
  args: []
  expected: 20
