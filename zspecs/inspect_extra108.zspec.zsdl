spec: inspect_extra108
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra107.zspec.zsdl."
    - "This spec covers: inspect namedtuple types — inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute (base is 'tuple', MRO depth 3); inspect.FrameInfo (base is '_FrameInfo', MRO depth 4 because _FrameInfo is an intermediate base inheriting from tuple); their __module__ and __qualname__ values; inspect.Parameter._ParameterKind instances; wave 261."
    - "inspect.ArgInfo.__name__ == 'ArgInfo'. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__bases__[0].__name__ == 'tuple'. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__mro__.__len__() == 3 (ArgInfo -> tuple -> object). Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__mro__.__len__() == 3 (FullArgSpec -> tuple -> object). Verified with Python 3.14.3."
    - "inspect.Attribute.__name__ == 'Attribute'. Verified with Python 3.14.3."
    - "inspect.Attribute.__bases__[0].__name__ == 'tuple'. Verified with Python 3.14.3."
    - "inspect.Attribute.__mro__.__len__() == 3 (Attribute -> tuple -> object). Verified with Python 3.14.3."
    - "inspect.FrameInfo.__name__ == 'FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__mro__.__len__() == 4 (FrameInfo -> _FrameInfo -> tuple -> object). Verified with Python 3.14.3."
    - "inspect.ArgInfo.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__qualname__ == 'ArgInfo'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__qualname__ == 'FullArgSpec'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__qualname__ == 'FrameInfo'. Verified with Python 3.14.3."
    - "type(inspect.Parameter.POSITIONAL_ONLY).__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "type(inspect.Parameter.KEYWORD_ONLY).__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute namedtuple
# class identity
#
# Wave 261 theme: inspect.ArgInfo, inspect.FullArgSpec, and inspect.Attribute
# are namedtuple types defined in Lib/inspect.py. Each has __bases__[0] ==
# tuple (they inherit directly from tuple as namedtuples do). Their MRO
# depth is 3: [NamedTuple, tuple, object]. Their __module__ is 'inspect'
# and their __qualname__ equals their __name__ (all top-level types).
#
# inspect.ArgInfo.__bases__[0].__name__ == 'tuple'
# inspect.ArgInfo.__mro__.__len__() == 3
# inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'
# inspect.FullArgSpec.__mro__.__len__() == 3
# inspect.Attribute.__bases__[0].__name__ == 'tuple'
# inspect.Attribute.__mro__.__len__() == 3
#
# New to extra108.
# ---------------------------------------------------------------------------

table inspect_extra108.namedtuple_types_identity:
  description: "inspect.ArgInfo/FullArgSpec/Attribute namedtuple identity: __bases__[0].__name__ == 'tuple'; MRO depth 3; __module__ == 'inspect'; __qualname__ equals __name__; wave 261; new to extra108"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectnt108

  columns: [id, function, args, expected, description]
  rows:
    - ["arginfo_bases_0_tuple",
       "ArgInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — inspect.ArgInfo is a namedtuple defined via collections.namedtuple() in Lib/inspect.py; namedtuples inherit directly from tuple; __bases__[0] is tuple; tuple.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra108"]
    - [arginfo_mro_len_3,
       "ArgInfo.__mro__.__len__",
       [],
       3,
       "inspect.ArgInfo.__mro__.__len__() == 3 — inspect.ArgInfo is a namedtuple; its MRO is [ArgInfo, tuple, object] with length 3; contrasts with FrameInfo which has MRO depth 4 due to _FrameInfo intermediate base; new to extra108"]
    - [arginfo_module_inspect,
       "ArgInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — inspect.ArgInfo is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra108"]
    - [arginfo_qualname_eq,
       "ArgInfo.__qualname__.__eq__",
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__qualname__.__eq__('ArgInfo') == True — inspect.ArgInfo is a top-level type in the inspect module; __qualname__ equals __name__ equals 'ArgInfo' for top-level types; str.__eq__('ArgInfo') returns True; new to extra108"]
    - ["fullargspec_bases_0_tuple",
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — inspect.FullArgSpec is a namedtuple defined in Lib/inspect.py; it inherits directly from tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra108"]
    - [fullargspec_mro_len_3,
       "FullArgSpec.__mro__.__len__",
       [],
       3,
       "inspect.FullArgSpec.__mro__.__len__() == 3 — inspect.FullArgSpec is a namedtuple; its MRO is [FullArgSpec, tuple, object] with length 3; new to extra108"]
    - [fullargspec_module_inspect,
       "FullArgSpec.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — inspect.FullArgSpec is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra108"]
    - ["attribute_bases_0_tuple",
       "Attribute.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.Attribute.__bases__[0].__name__.__eq__('tuple') == True — inspect.Attribute is a namedtuple defined in Lib/inspect.py; it inherits directly from tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra108"]
    - [attribute_mro_len_3,
       "Attribute.__mro__.__len__",
       [],
       3,
       "inspect.Attribute.__mro__.__len__() == 3 — inspect.Attribute is a namedtuple; its MRO is [Attribute, tuple, object] with length 3; new to extra108"]
    - [attribute_module_inspect,
       "Attribute.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Attribute.__module__.__eq__('inspect') == True — inspect.Attribute is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra108"]

# ---------------------------------------------------------------------------
# Table 2: inspect.FrameInfo class identity
#
# Wave 261 theme: inspect.FrameInfo is special among inspect namedtuple types.
# Its __bases__[0] is not 'tuple' but '_FrameInfo' — an intermediate private
# base class that itself inherits from tuple. This gives FrameInfo an MRO
# depth of 4: [FrameInfo, _FrameInfo, tuple, object]. In Python 3.11+,
# FrameInfo was refactored to add the _FrameInfo intermediate layer for
# backwards-compatibility with code that accesses FrameInfo as a tuple.
#
# inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'
# inspect.FrameInfo.__mro__.__len__() == 4
# inspect.FrameInfo.__module__ == 'inspect'
# inspect.FrameInfo.__qualname__ == 'FrameInfo'
# inspect.FrameInfo.__name__ == 'FrameInfo'
#
# New to extra108.
# ---------------------------------------------------------------------------

table inspect_extra108.frameinfo_identity:
  description: "inspect.FrameInfo identity: __bases__[0].__name__ == '_FrameInfo' (intermediate base); MRO depth 4 (FrameInfo -> _FrameInfo -> tuple -> object); __module__ == 'inspect'; wave 261; new to extra108"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectfi108

  columns: [id, function, args, expected, description]
  rows:
    - ["frameinfo_bases_0_frameinfo_private",
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — inspect.FrameInfo is unique among inspect namedtuple types in that its direct base is the private '_FrameInfo' class (not 'tuple' directly); _FrameInfo itself inherits from tuple; this intermediate layer was added in Python 3.11 for API compatibility; __bases__[0].__name__ is '_FrameInfo'; str.__eq__('_FrameInfo') returns True; new to extra108"]
    - [frameinfo_mro_len_4,
       "FrameInfo.__mro__.__len__",
       [],
       4,
       "inspect.FrameInfo.__mro__.__len__() == 4 — inspect.FrameInfo has MRO [FrameInfo, _FrameInfo, tuple, object] with length 4; this is deeper than ArgInfo/FullArgSpec/Attribute which have MRO depth 3; the extra level is due to the _FrameInfo intermediate base; new to extra108"]
    - [frameinfo_module_inspect,
       "FrameInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — inspect.FrameInfo is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra108"]
    - [frameinfo_qualname_eq,
       "FrameInfo.__qualname__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__qualname__.__eq__('FrameInfo') == True — inspect.FrameInfo is a top-level class in the inspect module; __qualname__ equals __name__ equals 'FrameInfo' for top-level types; str.__eq__('FrameInfo') returns True; new to extra108"]
    - [frameinfo_name_eq,
       "FrameInfo.__name__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — inspect.FrameInfo is the named tuple type returned by inspect.getouterframes and inspect.stack; its __name__ is 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra108"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter._ParameterKind instances
#
# Wave 261 theme: inspect.Parameter.POSITIONAL_ONLY and
# inspect.Parameter.KEYWORD_ONLY are instances of the _ParameterKind enum
# (an IntEnum subclass defined inside inspect.py). Their type name is
# '_ParameterKind' (with leading underscore — a private class). Both have
# int values: POSITIONAL_ONLY == 0, KEYWORD_ONLY == 3.
#
# type(inspect.Parameter.POSITIONAL_ONLY).__name__ == '_ParameterKind'
# type(inspect.Parameter.KEYWORD_ONLY).__name__ == '_ParameterKind'
# int(inspect.Parameter.POSITIONAL_ONLY) == 0
# int(inspect.Parameter.KEYWORD_ONLY) == 3
#
# New to extra108.
# ---------------------------------------------------------------------------

table inspect_extra108.parameter_kind_identity:
  description: "inspect.Parameter._ParameterKind instances: POSITIONAL_ONLY and KEYWORD_ONLY are _ParameterKind enum members; POSITIONAL_ONLY == 0; KEYWORD_ONLY == 3; wave 261; new to extra108"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectpk108

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_type_name,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — inspect.Parameter.POSITIONAL_ONLY is a member of the _ParameterKind enum (an IntEnum subclass defined inside inspect.py); its __class__.__name__ is '_ParameterKind'; the leading underscore marks it as a private implementation detail; str.__eq__('_ParameterKind') returns True; new to extra108"]
    - [keyword_only_type_name,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — inspect.Parameter.KEYWORD_ONLY is a member of the _ParameterKind enum; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra108"]
    - [positional_only_int_0,
       "Parameter.POSITIONAL_ONLY.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — inspect.Parameter.POSITIONAL_ONLY is an IntEnum member with integer value 0; it is the lowest-valued kind (positional-only parameters come before positional-or-keyword parameters); int.__eq__(0) returns True; new to extra108"]
    - [keyword_only_int_3,
       "Parameter.KEYWORD_ONLY.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — inspect.Parameter.KEYWORD_ONLY is an IntEnum member with integer value 3; the ordering is: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4; int.__eq__(3) returns True; new to extra108"]
    - [positional_only_name_str,
       "Parameter.POSITIONAL_ONLY.name.__eq__",
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — _ParameterKind is an IntEnum; enum members have a .name attribute equal to the member name; for POSITIONAL_ONLY the name is 'POSITIONAL_ONLY'; str.__eq__('POSITIONAL_ONLY') returns True; new to extra108"]
    - [keyword_only_name_str,
       "Parameter.KEYWORD_ONLY.name.__eq__",
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — _ParameterKind is an IntEnum; the KEYWORD_ONLY member name is 'KEYWORD_ONLY'; str.__eq__('KEYWORD_ONLY') returns True; new to extra108"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra108
# ---------------------------------------------------------------------------

invariant inspect_extra108.arginfo_bases_tuple:
  description: "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a namedtuple inheriting directly from tuple; MRO depth 3; wave 261; new to extra108"
  kind: python_call_eq
  function: "ArgInfo.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant inspect_extra108.fullargspec_mro_len:
  description: "inspect.FullArgSpec.__mro__.__len__() == 3 — namedtuple MRO is [FullArgSpec, tuple, object]; wave 261; new to extra108"
  kind: python_call_eq
  function: FullArgSpec.__mro__.__len__
  args: []
  expected: 3

invariant inspect_extra108.frameinfo_bases_private:
  description: "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — unique intermediate base not present in other inspect namedtuples; MRO depth 4; wave 261; new to extra108"
  kind: python_call_eq
  function: "FrameInfo.__bases__[0].__name__.__eq__"
  args: ["_FrameInfo"]
  expected: true

invariant inspect_extra108.frameinfo_mro_len:
  description: "inspect.FrameInfo.__mro__.__len__() == 4 — [FrameInfo, _FrameInfo, tuple, object]; deeper than other inspect namedtuples; wave 261; new to extra108"
  kind: python_call_eq
  function: FrameInfo.__mro__.__len__
  args: []
  expected: 4

invariant inspect_extra108.positional_only_type:
  description: "type(inspect.Parameter.POSITIONAL_ONLY).__name__ == '_ParameterKind' — private IntEnum used for parameter kind classification; wave 261; new to extra108"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true
