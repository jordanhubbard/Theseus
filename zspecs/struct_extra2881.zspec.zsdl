spec: st2881
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 639 (_extra2881): __iadd__, __isub__, __imul__ dict-presence checks for struct types."
    - "struct module exposes exactly two types: struct.Struct (C-level compiled format object) and struct.error (exception class)."
    - "struct.Struct is a binary packing type with no numeric operator semantics."
    - "struct.error is an exception subclass of Exception; exception classes do not define arithmetic in-place operators."
    - "Neither struct.Struct nor struct.error defines any in-place augmented assignment operators (__iadd__, __isub__, __imul__) in its own __dict__."
    - "The struct module itself is of type 'module'; module types do not define arithmetic operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table st2881.iadd:
  description: "struct types __iadd__ dict-presence checks; wave 639"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2881
  columns: [id, function, args, expected]
  rows:
    - ["st2881001", "struct.Struct.__dict__.__contains__",             ["__iadd__"], false]
    - ["st2881002", "struct.error.__dict__.__contains__",              ["__iadd__"], false]
    - ["st2881003", "type(struct).__dict__.__contains__",              ["__iadd__"], false]
    - ["st2881004", "type(struct.Struct('>I')).__dict__.__contains__", ["__iadd__"], false]
    - ["st2881005", "type(struct.Struct('<H')).__dict__.__contains__", ["__iadd__"], false]
    - ["st2881006", "type(struct.Struct('!4s')).__dict__.__contains__", ["__iadd__"], false]

