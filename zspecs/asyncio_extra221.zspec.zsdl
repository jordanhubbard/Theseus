spec: asyncio_extra221
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
  notes:
    - "asyncio.Queue.__name__.__len__() == 5 ('Queue' = 5 chars)."
    - "asyncio.LifoQueue.__name__.__len__() == 9 ('LifoQueue' = 9 chars)."
    - "asyncio.PriorityQueue.__name__.__len__() == 13 ('PriorityQueue' = 13 chars)."
    - "asyncio.Lock.__name__.__len__() == 4 ('Lock' = 4 chars)."
    - "asyncio.Event.__name__.__len__() == 5 ('Event' = 5 chars)."
    - "asyncio.Condition.__name__.__len__() == 9 ('Condition' = 9 chars)."
    - "asyncio.Semaphore.__name__.__len__() == 9 ('Semaphore' = 9 chars)."
    - "asyncio.BoundedSemaphore.__name__.__len__() == 16 ('BoundedSemaphore' = 16 chars)."
    - "asyncio.Task.__name__.__len__() == 4 ('Task' = 4 chars)."
    - "asyncio.Future.__name__.__len__() == 6 ('Future' = 6 chars)."
    - "asyncio.CancelledError.__name__.__len__() == 14 ('CancelledError' = 14 chars)."
    - "asyncio.TimeoutError.__name__.__len__() == 12 ('TimeoutError' = 12 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class name lengths — extra221 namespace
#
# This spec captures the __name__.__len__() values for the key asyncio
# classes: Queue, LifoQueue, PriorityQueue, Lock, Event, Condition,
# Semaphore, BoundedSemaphore, Task, Future, CancelledError, TimeoutError.
# ---------------------------------------------------------------------------

table asyncio_extra221.queue_name_lengths:
  description: "asyncio queue class __name__.__len__() checks in extra221 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio221queuenamelen

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name_len,         Queue.__name__.__len__,         [], 5,  "asyncio.Queue.__name__.__len__() == 5 ('Queue'=5); verified with Python 3.14.3"]
    - [lifoqueue_name_len,     LifoQueue.__name__.__len__,     [], 9,  "asyncio.LifoQueue.__name__.__len__() == 9 ('LifoQueue'=9); verified with Python 3.14.3"]
    - [priorityqueue_name_len, PriorityQueue.__name__.__len__, [], 13, "asyncio.PriorityQueue.__name__.__len__() == 13 ('PriorityQueue'=13); verified with Python 3.14.3"]

table asyncio_extra221.sync_primitive_name_lengths:
  description: "asyncio synchronization primitive class __name__.__len__() checks in extra221 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio221syncnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_len,             Lock.__name__.__len__,             [], 4,  "asyncio.Lock.__name__.__len__() == 4 ('Lock'=4); verified with Python 3.14.3"]
    - [event_name_len,            Event.__name__.__len__,            [], 5,  "asyncio.Event.__name__.__len__() == 5 ('Event'=5); verified with Python 3.14.3"]
    - [condition_name_len,        Condition.__name__.__len__,        [], 9,  "asyncio.Condition.__name__.__len__() == 9 ('Condition'=9); verified with Python 3.14.3"]
    - [semaphore_name_len,        Semaphore.__name__.__len__,        [], 9,  "asyncio.Semaphore.__name__.__len__() == 9 ('Semaphore'=9); verified with Python 3.14.3"]
    - [boundedsemaphore_name_len, BoundedSemaphore.__name__.__len__, [], 16, "asyncio.BoundedSemaphore.__name__.__len__() == 16 ('BoundedSemaphore'=16); verified with Python 3.14.3"]

table asyncio_extra221.task_future_name_lengths:
  description: "asyncio Task and Future class __name__.__len__() checks in extra221 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio221taskfutnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [task_name_len,   Task.__name__.__len__,   [], 4, "asyncio.Task.__name__.__len__() == 4 ('Task'=4); verified with Python 3.14.3"]
    - [future_name_len, Future.__name__.__len__, [], 6, "asyncio.Future.__name__.__len__() == 6 ('Future'=6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio exception class name lengths — extra221 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra221.cancelled_error_name_len:
  description: "asyncio.CancelledError.__name__.__len__() == 14 ('CancelledError' = 14 chars); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: CancelledError.__name__.__len__
  args: []
  expected: 14

invariant asyncio_extra221.timeout_error_name_len:
  description: "asyncio.TimeoutError.__name__.__len__() == 12 ('TimeoutError' = 12 chars); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__name__.__len__
  args: []
  expected: 12
