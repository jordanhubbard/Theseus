spec: is_html
version: ">=3.2.0"
backend: node(is-html)

docs: https://www.npmjs.com/package/is-html

provenance:
  derived_from:
    - "is-html README — https://www.npmjs.com/package/is-html"
    - "Test vectors verified with is-html via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-html source"
  notes:
    - "is-html is an npm package. Install: npm install is-html"
    - "Returns true if the string appears to be HTML (contains recognizable HTML tags)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_html.check:
  kind: node_module_call_eq
  function: "default"
  category: strings
  id_prefix: ishtml

  columns: [id, args, expected]
  rows:
    - [div_tag,   ["<div>hello</div>"], true]
    - [p_tag,     ["<p>test</p>"],      true]
    - [plain,     ["plain text"],       false]
    - [empty,     [""],                 false]
