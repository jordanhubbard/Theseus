spec: io_extra172
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.DEFAULT_BUFFER_SIZE constant value and type, and io.SEEK_SET / SEEK_CUR / SEEK_END seek-whence constants."
    - "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — the default buffer size is 131072 bytes (128 KiB = 2**17) on Python 3.14.3."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int."
    - "io.SEEK_SET.__eq__(0) == True — SEEK_SET (seek from beginning of file) has integer value 0."
    - "io.SEEK_CUR.__eq__(1) == True — SEEK_CUR (seek from current position) has integer value 1."
    - "io.SEEK_END.__eq__(2) == True — SEEK_END (seek from end of file) has integer value 2."
    - "io.SEEK_SET.__class__.__name__ == 'int' — the SEEK_* constants are plain ints, unlike re flags which are RegexFlag enum members."
    - "SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2): consecutive integers starting at 0."
    - "The three seek-whence constants map directly to the POSIX SEEK_SET=0, SEEK_CUR=1, SEEK_END=2 values."
    - "DEFAULT_BUFFER_SIZE (131072) == 128 * 1024 == 2**17 — a power-of-2 byte count (128 KiB)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE value and class identity
# DEFAULT_BUFFER_SIZE == 131072 (128 KiB = 2**17), class name == 'int'
# 131072 == 2**17 == 128 * 1024 — a power-of-two buffer size
# ---------------------------------------------------------------------------

table io_extra172.DEFAULT_BUFFER_SIZE_value_and_type:
  description: "io.DEFAULT_BUFFER_SIZE value and type: DEFAULT_BUFFER_SIZE.__eq__(131072)==True (128 KiB = 2**17 bytes on Python 3.14.3), DEFAULT_BUFFER_SIZE.__class__.__name__=='int' — plain Python int, not an enum; 131072 is the default size for BufferedReader/BufferedWriter buffers"
  kind: python_call_eq
  category: identity
  id_prefix: iobs172

  columns: [id, function, args, expected, description]
  rows:
    - [dbs_eq_131072,   DEFAULT_BUFFER_SIZE.__eq__,               [131072],  true,  "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — io.DEFAULT_BUFFER_SIZE is 131072 bytes (128 KiB) on Python 3.14.3; 131072 == 2**17 == 128 * 1024: a power-of-two value chosen for disk I/O efficiency; io.DEFAULT_BUFFER_SIZE is used as the default buffer size for BufferedReader, BufferedWriter, and BufferedRandom when no explicit buffer_size argument is supplied; 131072 bytes == 128 KiB: 'KiB' (kibibyte) — the exact binary multiple; 2**17 in binary is 1 followed by 17 zeros (0b100000000000000000); the exponent 17 means 131072 is 2**4 == 16 times larger than 2**13 == 8192 (the historical smaller default); confirmed Python 3.14.3 macOS"]
    - [dbs_cls_name,    DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true, "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int, not an IntEnum or any other subclass; this contrasts with re module flags (re.IGNORECASE etc.) which are RegexFlag enum members with __class__.__name__ == 'RegexFlag'; io's SEEK_* constants and DEFAULT_BUFFER_SIZE are all bare ints without enum wrapping; 'int' has 3 characters; DEFAULT_BUFFER_SIZE.__class__.__name__ (3 chars: 'int') is the same class as SEEK_SET.__class__.__name__ (also 'int', 3 chars); the plain int type means DEFAULT_BUFFER_SIZE participates in all standard integer operations without special enum behavior; confirmed Python 3.14.3 macOS"]
    - [dbs_ne_65536,    DEFAULT_BUFFER_SIZE.__eq__,               [65536],   false, "io.DEFAULT_BUFFER_SIZE.__eq__(65536) == False — DEFAULT_BUFFER_SIZE is 131072 (2**17), not 65536 (2**16); 65536 == 2**16 is exactly half of DEFAULT_BUFFER_SIZE (131072 == 2**17); DEFAULT_BUFFER_SIZE (131072) > 65536 (2**16) by a factor of 2; DEFAULT_BUFFER_SIZE (2**17) is also not 262144 (2**18) — it is specifically 2**17 on Python 3.14.3 macOS; the choice of 131072 (128 KiB) for the default buffer size was updated in newer CPython to match modern memory hierarchies and improve I/O throughput on large sequential reads; confirmed Python 3.14.3 macOS"]
    - [dbs_gt_zero,     DEFAULT_BUFFER_SIZE.__gt__,               [0],       true,  "io.DEFAULT_BUFFER_SIZE.__gt__(0) == True — DEFAULT_BUFFER_SIZE (131072) is greater than 0; a positive buffer size is required: BufferedReader and BufferedWriter require a positive buffer_size argument; DEFAULT_BUFFER_SIZE.__gt__(0) confirms the buffer is non-empty and positive; 131072 > 0 by 131072 — the entire 131072-byte buffer capacity; io.open() uses DEFAULT_BUFFER_SIZE as the fallback when buffering=-1 (the sentinel for 'use default buffering'); confirmed Python 3.14.3 macOS"]
    - [dbs_pow2_check,  DEFAULT_BUFFER_SIZE.__eq__,               [131072],  true,  "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — confirming 131072 == 2**17; the power-of-2 property means 131072 & (131072 - 1) == 131072 & 131071 == 0 (no bits in common); 131072 in binary is 1 followed by 17 zeros (0b100000000000000000); DEFAULT_BUFFER_SIZE (131072) == 128 * 1024: 128 KiB expressed as 128 groups of 1024 bytes; 131072 is also 64 * 2048, 32 * 4096, 16 * 8192, and 8 * 16384 — consistent decompositions as products of powers of 2; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.SEEK_SET, SEEK_CUR, SEEK_END values
# SEEK_SET=0, SEEK_CUR=1, SEEK_END=2 — consecutive integers starting at 0
# All are plain ints (not enum members)
# ---------------------------------------------------------------------------

table io_extra172.SEEK_constants_values:
  description: "io.SEEK_SET.__eq__(0)==True, io.SEEK_CUR.__eq__(1)==True, io.SEEK_END.__eq__(2)==True; three consecutive integers 0,1,2 matching POSIX seek-whence constants; all are plain ints"
  kind: python_call_eq
  category: identity
  id_prefix: ioseek172

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_eq_0,  SEEK_SET.__eq__,  [0],  true,  "io.SEEK_SET.__eq__(0) == True — SEEK_SET is 0, the whence value for seek-from-beginning-of-file; stream.seek(offset, io.SEEK_SET) positions the stream at the absolute byte offset from the file start; SEEK_SET == 0 matches the POSIX C constant SEEK_SET defined in <stdio.h>; SEEK_SET (0) is the most commonly used seek whence: seek(0, SEEK_SET) rewinds to the start, seek(n, SEEK_SET) jumps to byte n; the value 0 is the minimum among SEEK_SET=0, SEEK_CUR=1, SEEK_END=2; SEEK_SET (0) is falsy in Python — the only falsy seek-whence constant; stream.seek(offset) with no whence argument defaults to whence=0 == SEEK_SET; confirmed Python 3.14.3 macOS"]
    - [seek_cur_eq_1,  SEEK_CUR.__eq__,  [1],  true,  "io.SEEK_CUR.__eq__(1) == True — SEEK_CUR is 1, the whence value for seek-from-current-position; stream.seek(offset, io.SEEK_CUR) moves the stream position by offset bytes relative to the current position; SEEK_CUR == 1 matches the POSIX C constant SEEK_CUR; seek(0, SEEK_CUR) is the idiomatic way to get the current position from a stream without moving it (equivalent to tell() on binary streams); SEEK_CUR (1) is between SEEK_SET (0) and SEEK_END (2) — the middle value in the consecutive sequence 0, 1, 2; SEEK_CUR (1) is truthy; confirmed Python 3.14.3 macOS"]
    - [seek_end_eq_2,  SEEK_END.__eq__,  [2],  true,  "io.SEEK_END.__eq__(2) == True — SEEK_END is 2, the whence value for seek-from-end-of-file; stream.seek(offset, io.SEEK_END) positions the stream at offset bytes from the end of the file; seek(0, SEEK_END) moves to the very end of the file; seek(-n, SEEK_END) positions n bytes before the end; SEEK_END == 2 matches the POSIX C constant SEEK_END defined in <stdio.h>; SEEK_END (2) is the maximum value among SEEK_SET=0, SEEK_CUR=1, SEEK_END=2; for TextIOWrapper (text mode), only seek(0, SEEK_END) is supported — SEEK_CUR is not valid in text mode; confirmed Python 3.14.3 macOS"]
    - [seek_set_ne_1,  SEEK_SET.__eq__,  [1],  false, "io.SEEK_SET.__eq__(1) == False — SEEK_SET is 0, not 1; SEEK_SET (0) != SEEK_CUR (1): the two most commonly confused seek-whence constants are distinct integers; SEEK_SET being 0 (not 1) means the default whence for seek() is the falsy integer 0; stream.seek(0) is equivalent to stream.seek(0, io.SEEK_SET) — both rewind to the beginning; SEEK_SET (0) < SEEK_CUR (1) by exactly 1; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.SEEK_SET class identity and SEEK_* type uniformity
# All SEEK_* are plain ints: __class__.__name__ == 'int'
# ---------------------------------------------------------------------------

table io_extra172.SEEK_constants_type_identity:
  description: "io.SEEK_SET.__class__.__name__=='int', io.SEEK_CUR.__class__.__name__=='int', io.SEEK_END.__class__.__name__=='int'; all seek-whence constants are plain ints, unlike re flags which are RegexFlag enum members"
  kind: python_call_eq
  category: identity
  id_prefix: ioseek172

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_cls, SEEK_SET.__class__.__name__.__eq__,  ["int"],  true, "io.SEEK_SET.__class__.__name__ == 'int' — SEEK_SET is a plain Python int, not an IntEnum or any subclass; 'int' has 3 characters; this contrasts with re.IGNORECASE which is a re.RegexFlag enum member with __class__.__name__ == 'RegexFlag'; the io module chose plain int constants for SEEK_SET, SEEK_CUR, SEEK_END rather than introducing an enum — this keeps them interchangeable with raw integers in call sites that use 0, 1, or 2 directly; io.SEEK_SET being a plain int means SEEK_SET + SEEK_CUR == 0 + 1 == 1 without any special enum arithmetic; confirmed Python 3.14.3 macOS"]
    - [seek_cur_cls, SEEK_CUR.__class__.__name__.__eq__,  ["int"],  true, "io.SEEK_CUR.__class__.__name__ == 'int' — SEEK_CUR is a plain Python int (value 1); all three seek constants SEEK_SET (0), SEEK_CUR (1), SEEK_END (2) share the same plain int type — they are type-uniform; 'int' (3 chars) is the class name; the type uniformity across SEEK_SET, SEEK_CUR, and SEEK_END means any seek-whence argument validation logic can simply check isinstance(whence, int) and 0 <= whence <= 2; SEEK_CUR's plain int type also means SEEK_CUR == 1 evaluates to True without any enum comparison overhead; confirmed Python 3.14.3 macOS"]
    - [seek_end_cls, SEEK_END.__class__.__name__.__eq__,  ["int"],  true, "io.SEEK_END.__class__.__name__ == 'int' — SEEK_END is a plain Python int (value 2); SEEK_SET (0), SEEK_CUR (1), and SEEK_END (2) are all plain ints forming a uniform trio; DEFAULT_BUFFER_SIZE is also a plain int — the io module consistently uses bare int constants rather than enum types for its module-level numeric constants; 'int' (3 chars) is both the class name for the SEEK_* constants and for DEFAULT_BUFFER_SIZE; the consistency of all four io constants (DEFAULT_BUFFER_SIZE, SEEK_SET, SEEK_CUR, SEEK_END) being plain ints simplifies type checking and interoperability with C-extension code; confirmed Python 3.14.3 macOS"]
    - [seek_set_sum, SEEK_SET.__add__,                    [SEEK_CUR], 1,  "io.SEEK_SET.__add__(io.SEEK_CUR) == 1 — SEEK_SET (0) + SEEK_CUR (1) == 1 == SEEK_CUR; since both SEEK_SET and SEEK_CUR are plain ints, standard integer addition applies: 0 + 1 == 1; this equality (SEEK_SET + SEEK_CUR == SEEK_CUR) confirms the consecutive-integer structure of the seek constants: each constant equals its index in the sequence 0, 1, 2; the sum 0 + 1 + 2 == 3 == SEEK_SET + SEEK_CUR + SEEK_END — the sum of the three seek constants equals 3; plain int addition works directly because SEEK_* are not enum members that might restrict arithmetic; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.SEEK_* ordering and DEFAULT_BUFFER_SIZE comparisons
# SEEK_SET < SEEK_CUR < SEEK_END; DEFAULT_BUFFER_SIZE > all SEEK_* values
# DEFAULT_BUFFER_SIZE == 131072 on Python 3.14.3
# ---------------------------------------------------------------------------

table io_extra172.constants_ordering:
  description: "Ordering: SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2) < DEFAULT_BUFFER_SIZE (131072); consecutive SEEK_* values form the sequence 0,1,2; DEFAULT_BUFFER_SIZE (131072 = 2**17 = 128 KiB) dwarfs all three seek constants"
  kind: python_call_eq
  category: identity
  id_prefix: iocmp172

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_lt_cur, SEEK_SET.__lt__,              [SEEK_CUR],            true,  "io.SEEK_SET.__lt__(io.SEEK_CUR) == True — 0 < 1; SEEK_SET (0) < SEEK_CUR (1): the beginning-of-file whence is numerically less than the current-position whence; the difference is exactly 1 (SEEK_CUR - SEEK_SET == 1); this consecutive integer property means SEEK_SET, SEEK_CUR, SEEK_END can be treated as indices 0, 1, 2 of a whence tuple; SEEK_SET < SEEK_CUR < SEEK_END forms a strict ascending sequence with equal step size 1; confirmed Python 3.14.3 macOS"]
    - [seek_cur_lt_end, SEEK_CUR.__lt__,              [SEEK_END],            true,  "io.SEEK_CUR.__lt__(io.SEEK_END) == True — 1 < 2; SEEK_CUR (1) < SEEK_END (2): the current-position whence is numerically less than the end-of-file whence; SEEK_END - SEEK_CUR == 1 — the same unit step as between SEEK_SET and SEEK_CUR; all three seek constants form an arithmetic sequence with common difference 1: SEEK_SET=0, SEEK_CUR=1, SEEK_END=2; this uniform step-size means SEEK_END == SEEK_SET + 2 and SEEK_CUR == SEEK_SET + 1; confirmed Python 3.14.3 macOS"]
    - [seek_end_lt_dbs, SEEK_END.__lt__,              [DEFAULT_BUFFER_SIZE], true,  "io.SEEK_END.__lt__(io.DEFAULT_BUFFER_SIZE) == True — 2 < 131072; SEEK_END (2) is much less than DEFAULT_BUFFER_SIZE (131072 = 2**17); DEFAULT_BUFFER_SIZE (131072) is 65536 times SEEK_END (2); the seek-whence constants (0, 1, 2) are tiny single-digit values while DEFAULT_BUFFER_SIZE (131072) is a large buffer capacity in bytes; the four io constants span a huge range: SEEK_SET=0 through DEFAULT_BUFFER_SIZE=131072 — a factor of 131072 between the smallest nonzero value (SEEK_CUR=1) and the largest; confirmed Python 3.14.3 macOS"]
    - [dbs_eq_131072,   DEFAULT_BUFFER_SIZE.__eq__,   [131072],              true,  "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — confirming DEFAULT_BUFFER_SIZE == 131072 == 2**17 == 128 * 1024; DEFAULT_BUFFER_SIZE / SEEK_CUR == 131072 / 1 == 131072; DEFAULT_BUFFER_SIZE / SEEK_END == 131072 / 2 == 65536 == 2**16 — exactly 65536 times SEEK_END; DEFAULT_BUFFER_SIZE (131072) = 2**17 while SEEK_END (2) = 2**1, so DEFAULT_BUFFER_SIZE / SEEK_END == 2**(17-1) == 2**16 == 65536; the power-of-two structure: 131072 (2**17), 2 (2**1), 1 (2**0), 0 (special); confirmed Python 3.14.3 macOS"]
    - [seek_sum_eq_3,   SEEK_END.__add__,             [SEEK_CUR],            3,     "io.SEEK_END.__add__(io.SEEK_CUR) == 3 — SEEK_END (2) + SEEK_CUR (1) == 3; the sum of SEEK_END and SEEK_CUR is 3 — the same as SEEK_SET + SEEK_CUR + SEEK_END == 0 + 1 + 2 == 3 (the sum of all three seek constants); SEEK_END + SEEK_CUR == 3 also equals SEEK_SET + SEEK_CUR + SEEK_END == 3 — the arithmetic identity; 3 is not itself a seek constant (valid whence values are 0, 1, 2 only); the sum 3 == T(2) the second triangular number (0+1+2=3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra172.DEFAULT_BUFFER_SIZE_is_131072:
  description: "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — the io module's default buffer size is 131072 bytes (128 KiB = 2**17) on Python 3.14.3; this value is used by BufferedReader, BufferedWriter, and BufferedRandom when no explicit buffer_size is given; 131072 is a power of two (2**17) chosen for alignment with modern memory hierarchies and to improve throughput on sequential I/O; DEFAULT_BUFFER_SIZE is a plain int (not enum), so DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'; 131072 == 128 * 1024 — 128 KiB; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra172.DEFAULT_BUFFER_SIZE_class_is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int, not an IntEnum or any enum subclass; 'int' has 3 characters; the io module uses bare int constants for DEFAULT_BUFFER_SIZE (131072) and for SEEK_SET (0), SEEK_CUR (1), SEEK_END (2) — unlike the re module which wraps its flag constants in the RegexFlag enum; the plain int type means DEFAULT_BUFFER_SIZE supports all integer operations without special enum behavior; isinstance(DEFAULT_BUFFER_SIZE, int) is True and type(DEFAULT_BUFFER_SIZE) is int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra172.SEEK_SET_is_0:
  description: "io.SEEK_SET.__eq__(0) == True — SEEK_SET is 0, the whence value for 'seek from beginning of file'; 0 is the most natural starting position for file access; SEEK_SET (0) < SEEK_CUR (1) < SEEK_END (2): consecutive integers matching the POSIX SEEK_SET, SEEK_CUR, SEEK_END constants in <stdio.h>; io.SEEK_SET being 0 means stream.seek(offset) (with default whence=0) is equivalent to stream.seek(offset, io.SEEK_SET); SEEK_SET is the minimum seek-whence value and the only falsy one (0 is falsy in Python); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra172.SEEK_CUR_is_1:
  description: "io.SEEK_CUR.__eq__(1) == True — SEEK_CUR is 1, the whence value for 'seek relative to current position'; SEEK_CUR (1) is between SEEK_SET (0) and SEEK_END (2) in the consecutive sequence; seek(0, io.SEEK_CUR) is the idiomatic way to get the current stream position from a binary stream without moving it; SEEK_CUR (1) is a truthy value (non-zero); SEEK_CUR.__class__.__name__ == 'int' — plain int, not enum; io.SEEK_CUR matches the POSIX SEEK_CUR constant value 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra172.SEEK_END_is_2:
  description: "io.SEEK_END.__eq__(2) == True — SEEK_END is 2, the whence value for 'seek relative to end of file'; SEEK_END (2) is the maximum seek-whence value; seek(0, io.SEEK_END) moves to the end of the file; seek(-n, io.SEEK_END) positions n bytes before the end; SEEK_END (2) is truthy; for TextIOWrapper (text mode), only seek(0, SEEK_END) is supported with SEEK_END — arbitrary offsets from end are not supported in text mode due to encoding complexity; SEEK_END = SEEK_SET + SEEK_CUR + 1 = 0 + 1 + 1 = 2; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra172.SEEK_SET_class_is_int:
  description: "io.SEEK_SET.__class__.__name__ == 'int' — SEEK_SET is a plain Python int (value 0); all three seek-whence constants (SEEK_SET=0, SEEK_CUR=1, SEEK_END=2) and DEFAULT_BUFFER_SIZE (131072) are plain ints — the io module's numeric constants are uniformly unboxed int values; 'int' has 3 characters: 'i-n-t'; this is unlike re.IGNORECASE.__class__.__name__ == 'RegexFlag' (9 chars) — the re module wraps flags in an IntFlag enum while io uses bare ints; SEEK_SET's plain int type means it can be used interchangeably with the literal 0 in seek() calls; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra172.SEEK_constants_sum_is_3:
  description: "io.SEEK_END.__add__(io.SEEK_CUR) == 3 — SEEK_END (2) + SEEK_CUR (1) == 3; this equals the sum of all three seek constants: SEEK_SET (0) + SEEK_CUR (1) + SEEK_END (2) == 3 (the triangular number T(2)); since all are plain ints, standard addition applies; the consecutive integer structure 0, 1, 2 means each constant equals its index in the sorted sequence; DEFAULT_BUFFER_SIZE (131072) + SEEK_SET (0) + SEEK_CUR (1) + SEEK_END (2) == 131075 — all four io module numeric constants sum to 131075; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: SEEK_END.__add__
  args: [SEEK_CUR]
  expected: 3
