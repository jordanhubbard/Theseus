spec: pathlib_extra554
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class attribute and qualname identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks module membership, qualname strings, and init/new qualnames for Path and PurePath hierarchies"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra554.doc_class_names:
  description: "pathlib.Path and PurePath __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: doc_class
  id_prefix: pl554dc

  columns: [id, function, args, expected]
  rows:
    - [pl554dc001, pathlib.Path.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [pl554dc002, pathlib.PurePath.__doc__.__class__.__name__.__eq__, ["str"], true]

table pathlib_extra554.qualnames:
  description: "pathlib.Path and PurePath __qualname__ identity"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: pl554qn

  columns: [id, function, args, expected]
  rows:
    - [pl554qn001, pathlib.Path.__qualname__.__eq__,     ["Path"],     true]
    - [pl554qn002, pathlib.PurePath.__qualname__.__eq__, ["PurePath"], true]

table pathlib_extra554.module_attrs:
  description: "pathlib class __module__ == 'pathlib' — all 6 pathlib classes"
  kind: python_call_eq
  category: module_identity
  id_prefix: pl554ma

  columns: [id, function, args, expected]
  rows:
    - [pl554ma001, pathlib.Path.__module__.__eq__,            ["pathlib"], true]
    - [pl554ma002, pathlib.PurePath.__module__.__eq__,        ["pathlib"], true]
    - [pl554ma003, pathlib.PosixPath.__module__.__eq__,       ["pathlib"], true]
    - [pl554ma004, pathlib.WindowsPath.__module__.__eq__,     ["pathlib"], true]
    - [pl554ma005, pathlib.PurePosixPath.__module__.__eq__,   ["pathlib"], true]
    - [pl554ma006, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"], true]

table pathlib_extra554.init_new_qualnames:
  description: "pathlib.Path.__init__ and __new__ __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl554in

  columns: [id, function, args, expected]
  rows:
    - [pl554in001, pathlib.Path.__init__.__qualname__.__eq__, ["Path.__init__"], true]
    - [pl554in002, pathlib.Path.__new__.__qualname__.__eq__,  ["Path.__new__"],  true]
