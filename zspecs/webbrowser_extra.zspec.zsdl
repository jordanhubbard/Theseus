spec: webbrowser_extra
version: ">=3.9"
backend: python_module(webbrowser)

docs: https://docs.python.org/3/library/webbrowser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/webbrowser.html — Python webbrowser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/webbrowser.py"
  notes:
    - "webbrowser provides a high-level interface for displaying web-based documents."
    - "open, open_new, open_new_tab are top-level functions for opening URLs."
    - "get returns a controller for the given browser type."
    - "register registers a browser type under a given name."
    - "webbrowser.Error is the module's exception class."
    - "Error.__name__ == 'Error' — short unqualified exception class name."
    - "Error.__module__ == 'webbrowser' — the exception is defined in the webbrowser module."
    - "All of open, open_new, open_new_tab, get, register are plain Python functions."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __name__ checks
# ---------------------------------------------------------------------------

table webbrowser_extra.functions.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fn

  columns: [id, function, args, expected]
  rows:
    - [open_name,         open.__name__.__eq__,         ["open"],         true]
    - [open_new_name,     open_new.__name__.__eq__,     ["open_new"],     true]
    - [open_new_tab_name, open_new_tab.__name__.__eq__, ["open_new_tab"], true]
    - [get_name,          get.__name__.__eq__,          ["get"],          true]
    - [register_name,     register.__name__.__eq__,     ["register"],     true]

# ---------------------------------------------------------------------------
# Module-level function type checks — each is a plain Python function
# ---------------------------------------------------------------------------

table webbrowser_extra.types.function_types:
  kind: python_call_eq
  category: types
  id_prefix: type

  columns: [id, function, args, expected]
  rows:
    - [open_is_function,         open.__class__.__name__.__eq__,         ["function"], true]
    - [open_new_is_function,     open_new.__class__.__name__.__eq__,     ["function"], true]
    - [open_new_tab_is_function, open_new_tab.__class__.__name__.__eq__, ["function"], true]
    - [get_is_function,          get.__class__.__name__.__eq__,          ["function"], true]
    - [register_is_function,     register.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# Error exception class — name and module affiliation
# ---------------------------------------------------------------------------

invariant webbrowser_extra.classes.Error_name:
  description: "Error.__name__ == 'Error' — exception class name"
  category: classes
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant webbrowser_extra.module.Error_module:
  description: "Error.__module__ == 'webbrowser' — the exception is defined in the webbrowser module"
  category: module
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["webbrowser"]
  expected: true

invariant webbrowser_extra.classes.Error_is_type:
  description: "type(Error).__name__ == 'type' — Error is a class object"
  category: classes
  kind: python_call_eq
  function: Error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Error class hierarchy — inherits from Exception
# ---------------------------------------------------------------------------

invariant webbrowser_extra.classes.Error_base_is_Exception:
  description: "Error.__bases__[0].__name__ == 'Exception' — Error inherits from Exception"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  expected: true

# ---------------------------------------------------------------------------
# Function qualname checks
# ---------------------------------------------------------------------------

table webbrowser_extra.functions.qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [open_qualname,         open.__qualname__.__eq__,         ["open"],         true]
    - [open_new_qualname,     open_new.__qualname__.__eq__,     ["open_new"],     true]
    - [open_new_tab_qualname, open_new_tab.__qualname__.__eq__, ["open_new_tab"], true]
    - [get_qualname,          get.__qualname__.__eq__,          ["get"],          true]
    - [register_qualname,     register.__qualname__.__eq__,     ["register"],     true]
