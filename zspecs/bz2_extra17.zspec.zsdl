spec: bz2_extra17
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra16.zspec.zsdl — covers BZ2File.__init__/readable/writable/seekable __qualname__ (extra16); BZ2Compressor.compress/flush __qualname__ (extra16); BZ2Decompressor.decompress __qualname__ (extra16)."
    - "bz2_extra15.zspec.zsdl — covers BZ2File.read/write/seek/close __qualname__ (extra15); BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra15); open/compress/decompress __qualname__ (extra15 anchor)."
    - "bz2_extra11.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __module__ table (cmod11); compress/decompress __name__ standalone (extra11); class __qualname__ standalone (extra11)."
    - "bz2_extra8.zspec.zsdl — covers BZ2File.__mro__[1].__name__ == 'BaseStream' (method_chain form)."
    - "bz2_extra7.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __module__ and open/compress/decompress __module__ standalone; BZ2File.__bases__[0].__name__ == 'BaseStream' (string-return form)."
    - "bz2_extra6.zspec.zsdl — covers BZ2Compressor.__bases__[0].__name__ == 'object'; BZ2Decompressor.__bases__[0].__name__ == 'object'."
    - "bz2_extra5.zspec.zsdl — covers BZ2File.__bases__[0].__name__ == 'BaseStream' (bool form)."
  notes:
    - "This spec extends bz2 through bz2_extra16; it does NOT duplicate invariants present in those files."
    - "Focus: MRO depth invariants for BZ2File (mro[2] and mro[3]); __dict__ membership checks for BZ2Compressor, BZ2Decompressor, and BZ2File; __qualname__ type sanity for BZ2Decompressor."
    - "BZ2File.__mro__[2].__name__ == 'BufferedIOBase': not covered in any prior bz2 spec. bz2_extra8 covers mro[1] == 'BaseStream'. Verified 2026-04-09."
    - "BZ2File.__mro__[3].__name__ == '_BufferedIOBase': not covered in any prior bz2 spec. Verified 2026-04-09."
    - "'compress' in BZ2Compressor.__dict__: BZ2Compressor exposes compress in its own __dict__ (C extension type). No prior bz2 spec checks __dict__ membership. Verified 2026-04-09."
    - "'flush' in BZ2Compressor.__dict__: same as compress — a novel __dict__ membership check. Verified 2026-04-09."
    - "'decompress' in BZ2Decompressor.__dict__: BZ2Decompressor exposes decompress in its own __dict__. No prior bz2 spec checks this. Verified 2026-04-09."
    - "'read' in BZ2File.__dict__ and 'write' in BZ2File.__dict__: BZ2File defines these methods directly. No prior bz2 spec checks __dict__ membership. Verified 2026-04-09."
    - "BZ2Decompressor.__qualname__.__class__.__name__ == 'str': qualname type sanity. bz2_extra8 covers BZ2File.__qualname__.__class__.__name__; bz2_extra6 covers BZ2Compressor.__qualname__.__class__.__name__; BZ2Decompressor is covered in bz2_extra8 notes but verified novel here. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File.__mro__[2].__name__ == 'BufferedIOBase' — novel, extra17 anchor
#
# bz2_extra8 covers mro[1] == 'BaseStream'. No prior bz2 spec checks mro[2].
# BZ2File's MRO: BZ2File -> BaseStream -> BufferedIOBase -> ... Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2File.mro2_name:
  description: "bz2.BZ2File.__mro__[2].__name__ == 'BufferedIOBase' — third MRO entry is BufferedIOBase (extra17)"
  category: hierarchy
  kind: python_call_eq
  function: BZ2File.__mro__.__getitem__
  args: [2]
  method: __name__.__eq__
  method_args: ["BufferedIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.__mro__[3].__name__ == '_BufferedIOBase' — novel, extra17 anchor
#
# No prior bz2 spec checks mro[3]. BZ2File's MRO continues through the
# internal _BufferedIOBase C-level type. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2File.mro3_name:
  description: "bz2.BZ2File.__mro__[3].__name__ == '_BufferedIOBase' — fourth MRO entry is the internal C-level _BufferedIOBase (extra17)"
  category: hierarchy
  kind: python_call_eq
  function: BZ2File.__mro__.__getitem__
  args: [3]
  method: __name__.__eq__
  method_args: ["_BufferedIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# 'compress' in BZ2Compressor.__dict__ — novel, extra17 anchor
#
# No prior bz2 spec checks __dict__ membership. BZ2Compressor exposes its
# compress method directly in the class's own __dict__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2Compressor.dict_has_compress:
  description: "bz2.BZ2Compressor.__dict__.__contains__('compress') == True — compress is defined directly on BZ2Compressor (extra17)"
  category: class_structure
  kind: python_call_eq
  function: BZ2Compressor.__dict__.__contains__
  args: ["compress"]
  expected: true

# ---------------------------------------------------------------------------
# 'flush' in BZ2Compressor.__dict__ — novel, extra17 anchor
#
# No prior bz2 spec checks __dict__ membership. BZ2Compressor exposes its
# flush method directly in the class's own __dict__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2Compressor.dict_has_flush:
  description: "bz2.BZ2Compressor.__dict__.__contains__('flush') == True — flush is defined directly on BZ2Compressor (extra17)"
  category: class_structure
  kind: python_call_eq
  function: BZ2Compressor.__dict__.__contains__
  args: ["flush"]
  expected: true

# ---------------------------------------------------------------------------
# 'decompress' in BZ2Decompressor.__dict__ — novel, extra17 anchor
#
# No prior bz2 spec checks __dict__ membership for BZ2Decompressor.
# BZ2Decompressor exposes its decompress method in the class's own __dict__.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2Decompressor.dict_has_decompress:
  description: "bz2.BZ2Decompressor.__dict__.__contains__('decompress') == True — decompress is defined directly on BZ2Decompressor (extra17)"
  category: class_structure
  kind: python_call_eq
  function: BZ2Decompressor.__dict__.__contains__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# 'read' in BZ2File.__dict__ — novel, extra17 anchor
#
# No prior bz2 spec checks __dict__ membership for BZ2File.
# BZ2File defines read directly in its class body. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2File.dict_has_read:
  description: "bz2.BZ2File.__dict__.__contains__('read') == True — read is defined directly on BZ2File (extra17)"
  category: class_structure
  kind: python_call_eq
  function: BZ2File.__dict__.__contains__
  args: ["read"]
  expected: true

# ---------------------------------------------------------------------------
# 'write' in BZ2File.__dict__ — novel, extra17 anchor
#
# No prior bz2 spec checks __dict__ membership for write on BZ2File.
# BZ2File defines write directly in its class body. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2File.dict_has_write:
  description: "bz2.BZ2File.__dict__.__contains__('write') == True — write is defined directly on BZ2File (extra17)"
  category: class_structure
  kind: python_call_eq
  function: BZ2File.__dict__.__contains__
  args: ["write"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor.__qualname__.__class__.__name__ == 'str' — extra17 anchor
#
# bz2_extra6 covers BZ2Compressor.__qualname__.__class__.__name__ == 'str';
# bz2_extra8 covers BZ2File.__qualname__.__class__.__name__ == 'str'.
# BZ2Decompressor from the extra17 namespace is not duplicated in any prior spec.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra17.BZ2Decompressor.qualname_is_str:
  description: "bz2.BZ2Decompressor.__qualname__.__class__.__name__ == 'str' — qualname is always a string (extra17 sanity check)"
  category: type_identity
  kind: python_call_eq
  function: BZ2Decompressor.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# __dict__ membership table — BZ2Compressor + BZ2Decompressor + BZ2File (extra17)
#
# No prior bz2 spec presents __dict__ membership checks in any table.
# This table anchors all five dict-membership invariants from extra17.
# ---------------------------------------------------------------------------

table bz2_extra17.dict_membership:
  kind: python_call_eq
  category: class_structure
  id_prefix: dict17

  columns: [id, function, args, expected]
  rows:
    - [BZ2Compressor_compress,   BZ2Compressor.__dict__.__contains__,   ["compress"],   true]
    - [BZ2Compressor_flush,      BZ2Compressor.__dict__.__contains__,   ["flush"],      true]
    - [BZ2Decompressor_decompress, BZ2Decompressor.__dict__.__contains__, ["decompress"], true]
    - [BZ2File_read,             BZ2File.__dict__.__contains__,         ["read"],       true]
    - [BZ2File_write,            BZ2File.__dict__.__contains__,         ["write"],      true]
