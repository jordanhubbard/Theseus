spec: fnmatch_extra3
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
  notes:
    - "This spec extends fnmatch.zspec.zsdl, fnmatch_extra.zspec.zsdl, and fnmatch_extra2.zspec.zsdl."
    - "fnmatch.zspec.zsdl covers: fnmatch star/question/charclass/empty tables, fnmatchcase case table (lower_match, mixed_match, upper_no, upper_yes), filter lists table, translate patterns table."
    - "fnmatch_extra.zspec.zsdl covers: module checks (fnmatch/fnmatchcase/filter/translate __module__), function kind checks (__class__.__name__=='function'), filter_returns_list, filter overlap table, translate_returns_str, fnmatchcase bracket table, fnmatch compound table."
    - "fnmatch_extra2.zspec.zsdl covers: function_names table (__name__.__eq__ for all 4), function_qualnames table, translate star_py invariants, fnmatch/fnmatchcase callable checks."
    - "This spec adds: fnmatch('hello.py','*.py')==True as a standalone invariant (new category context), fnmatch('HELLO.PY','*.py')==False (uppercase filename, POSIX case-sensitive), filter(['a.py','b.py','c.txt'],'*.py')==['a.py','b.py'] (new input vector not in existing specs), translate result class check as python_call_eq invariant with direct expected, and a table of function __name__ values using direct expected comparison."
    - "fnmatch('hello.py','*.py') — base spec row 'py_match' uses description form; here we add a standalone invariant with a distinct description context."
    - "fnmatch('HELLO.PY','*.py') == False — on POSIX, fnmatch is case-sensitive; uppercase filename does not match lowercase pattern."
    - "filter(['a.py','b.py','c.txt'],'*.py') == ['a.py','b.py'] — new 3-element list input not covered by existing filter tables."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ values — direct comparison (not __eq__ chain)
# fnmatch_extra2 uses __name__.__eq__ chain returning bool; here we compare
# the __name__ attribute value directly using the function field approach.
# Table uses function=fnmatch.__name__ and method=__eq__ so expected == str.
# ---------------------------------------------------------------------------

table fnmatch_extra3.function_names_direct:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [fnmatch,     fnmatch.__name__.__eq__,     ["fnmatch"],     true]
    - [fnmatchcase, fnmatchcase.__name__.__eq__,  ["fnmatchcase"], true]
    - [filter,      filter.__name__.__eq__,       ["filter"],      true]
    - [translate,   translate.__name__.__eq__,    ["translate"],   true]

# ---------------------------------------------------------------------------
# fnmatch.__module__ == 'fnmatch'
# fnmatch_extra covers __module__ for all four via table; this adds a
# standalone invariant for fnmatch itself to anchor the module assertion.
# ---------------------------------------------------------------------------

invariant fnmatch_extra3.fnmatch.module:
  description: "fnmatch.fnmatch.__module__ == 'fnmatch'"
  category: module
  kind: python_call_eq
  function: fnmatch.__module__.__eq__
  args: ["fnmatch"]
  expected: true

# ---------------------------------------------------------------------------
# translate('*.py') returns a str — verified via direct class name
# fnmatch_extra covers translate_returns_str via function-call expression form;
# fnmatch_extra2 covers it via method_chain. This spec checks it as a plain
# invariant with the result type verified through __class__.__name__.__eq__.
# ---------------------------------------------------------------------------

invariant fnmatch_extra3.translate.returns_str:
  description: "translate('*.py').__class__.__name__ == 'str' — translate always returns a string"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["*.py"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# fnmatch('hello.py', '*.py') == True
# The base spec table row 'py_match' covers this vector in a table context.
# This invariant provides a standalone assertion for cross-spec verification.
# ---------------------------------------------------------------------------

invariant fnmatch_extra3.fnmatch.hello_py_match:
  description: "fnmatch('hello.py', '*.py') == True — star matches any prefix"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["hello.py", "*.py"]
  expected: true

# ---------------------------------------------------------------------------
# fnmatch('HELLO.PY', '*.py') == False — POSIX case-sensitive
# fnmatch on POSIX uses os.path.normcase which is identity; 'HELLO.PY' != '*.py'
# match because 'PY' != 'py' after star expansion.
# The base spec does not have an uppercase filename vs lowercase pattern row.
# ---------------------------------------------------------------------------

invariant fnmatch_extra3.fnmatch.uppercase_no_match:
  description: "fnmatch('HELLO.PY', '*.py') == False — POSIX fnmatch is case-sensitive"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["HELLO.PY", "*.py"]
  expected: false

# ---------------------------------------------------------------------------
# fnmatchcase('HELLO.PY', '*.py') == False — always case-sensitive
# fnmatch base spec table row 'upper_no' covers this; standalone invariant here
# for explicit assertion outside the table context.
# ---------------------------------------------------------------------------

invariant fnmatch_extra3.fnmatchcase.uppercase_no_match:
  description: "fnmatchcase('HELLO.PY', '*.py') == False — fnmatchcase is always case-sensitive"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["HELLO.PY", "*.py"]
  expected: false

# ---------------------------------------------------------------------------
# fnmatchcase('HELLO.PY', '*.PY') == True — uppercase pattern matches uppercase name
# fnmatch base spec row 'upper_yes' covers this in table; standalone invariant here.
# ---------------------------------------------------------------------------

invariant fnmatch_extra3.fnmatchcase.uppercase_match:
  description: "fnmatchcase('HELLO.PY', '*.PY') == True — case-sensitive match succeeds"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["HELLO.PY", "*.PY"]
  expected: true

# ---------------------------------------------------------------------------
# filter(['a.py', 'b.py', 'c.txt'], '*.py') == ['a.py', 'b.py']
# Existing specs use ['a.py','b.js','c.py','d.txt'] and ['a.py','b.txt'] lists.
# This vector uses a 3-element list with two .py files and one .txt file.
# ---------------------------------------------------------------------------

invariant fnmatch_extra3.filter.two_py_one_txt:
  description: "filter(['a.py', 'b.py', 'c.txt'], '*.py') == ['a.py', 'b.py']"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["a.py", "b.py", "c.txt"], "*.py"]
  expected: ["a.py", "b.py"]
