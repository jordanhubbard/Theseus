spec: inspect_extra2161
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
    - "inspect_extra1936.zspec.zsdl — covers __get__/__set__/__delete__/__set_name__ dict-presence on Parameter/Signature/BoundArguments, property dict-presence, class name checks"
  notes:
    - "Wave 2161 (_extra2161): descriptor protocol dict-presence theme — fget/fset/fdel (property attrs), __objclass__ and __func__ (method wrapper attrs)."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments do NOT define fget, fset, fdel, __objclass__, or __func__ in their own __dict__."
    - "inspect.Parameter exposes read-only properties (name, default, annotation, kind) accessible via inspect.Parameter.kind etc.; these property objects have fget set but fset and fdel are None."
    - "inspect.Signature.from_callable is a classmethod object; classmethod carries __func__ (not __objclass__, fget, fset, or fdel)."
    - "inspect.Signature.parameters and inspect.Signature.return_annotation are read-only properties with non-None fget and None fset/fdel."
    - "inspect.BoundArguments.args and inspect.BoundArguments.kwargs are read-only properties with non-None fget."
    - "fget/fset/fdel attributes live on the property builtin type, not on the classes that host the property objects."
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra2161.fget_fset_fdel_classes:
  description: "inspect classes fget/fset/fdel dict-presence checks — none define these property attrs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2161
  columns: [id, function, args, expected]
  rows:
    - ["in2161001", "inspect.Parameter.__dict__.__contains__",      ["fget"],  false]
    - ["in2161002", "inspect.Parameter.__dict__.__contains__",      ["fset"],  false]
    - ["in2161003", "inspect.Parameter.__dict__.__contains__",      ["fdel"],  false]
    - ["in2161004", "inspect.Signature.__dict__.__contains__",      ["fget"],  false]
    - ["in2161005", "inspect.Signature.__dict__.__contains__",      ["fset"],  false]
    - ["in2161006", "inspect.Signature.__dict__.__contains__",      ["fdel"],  false]
    - ["in2161007", "inspect.BoundArguments.__dict__.__contains__", ["fget"],  false]
    - ["in2161008", "inspect.BoundArguments.__dict__.__contains__", ["fset"],  false]
    - ["in2161009", "inspect.BoundArguments.__dict__.__contains__", ["fdel"],  false]

table inspect_extra2161.objclass_func_classes:
  description: "inspect classes __objclass__ and __func__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2161
  columns: [id, function, args, expected]
  rows:
    - ["in2161010", "inspect.Parameter.__dict__.__contains__",      ["__objclass__"], false]
    - ["in2161011", "inspect.Parameter.__dict__.__contains__",      ["__func__"],     false]
    - ["in2161012", "inspect.Signature.__dict__.__contains__",      ["__objclass__"], false]
    - ["in2161013", "inspect.Signature.__dict__.__contains__",      ["__func__"],     false]
    - ["in2161014", "inspect.BoundArguments.__dict__.__contains__", ["__objclass__"], false]
    - ["in2161015", "inspect.BoundArguments.__dict__.__contains__", ["__func__"],     false]

table inspect_extra2161.parameter_property_fget_names:
  description: "inspect.Parameter property fget __name__ checks — fget is a function, fset and fdel are None"
  kind: python_call_eq
  category: fget_attr
  id_prefix: in2161
  columns: [id, function, args, expected]
  rows:
    - ["in2161016", "inspect.Parameter.kind.fget.__name__.__eq__",        ["kind"],       true]
    - ["in2161017", "inspect.Parameter.name.fget.__name__.__eq__",        ["name"],       true]
    - ["in2161018", "inspect.Parameter.default.fget.__name__.__eq__",     ["default"],    true]
    - ["in2161019", "inspect.Parameter.annotation.fget.__name__.__eq__",  ["annotation"], true]
    - ["in2161020", "inspect.Parameter.kind.fget.__class__.__name__.__eq__",       ["function"], true]
    - ["in2161021", "inspect.Parameter.default.fget.__class__.__name__.__eq__",    ["function"], true]

table inspect_extra2161.signature_property_fget_names:
  description: "inspect.Signature property fget __name__ checks"
  kind: python_call_eq
  category: fget_attr
  id_prefix: in2161
  columns: [id, function, args, expected]
  rows:
    - ["in2161022", "inspect.Signature.parameters.fget.__name__.__eq__",        ["parameters"],        true]
    - ["in2161023", "inspect.Signature.return_annotation.fget.__name__.__eq__", ["return_annotation"], true]
    - ["in2161024", "inspect.Signature.parameters.fget.__class__.__name__.__eq__",        ["function"], true]
    - ["in2161025", "inspect.Signature.return_annotation.fget.__class__.__name__.__eq__", ["function"], true]

table inspect_extra2161.boundarguments_property_fget:
  description: "inspect.BoundArguments property fget checks — args and kwargs are read-only properties"
  kind: python_call_eq
  category: fget_attr
  id_prefix: in2161
  columns: [id, function, args, expected]
  rows:
    - ["in2161026", "inspect.BoundArguments.args.fget.__name__.__eq__",   ["args"],   true]
    - ["in2161027", "inspect.BoundArguments.kwargs.fget.__name__.__eq__", ["kwargs"], true]
    - ["in2161028", "inspect.BoundArguments.args.fget.__class__.__name__.__eq__",   ["function"], true]
    - ["in2161029", "inspect.BoundArguments.kwargs.fget.__class__.__name__.__eq__", ["function"], true]

table inspect_extra2161.signature_classmethod_func:
  description: "inspect.Signature.from_callable is a classmethod; __func__ points to the underlying function"
  kind: python_call_eq
  category: func_attr
  id_prefix: in2161
  columns: [id, function, args, expected]
  rows:
    - ["in2161030", "inspect.Signature.from_callable.__func__.__name__.__eq__",         ["from_callable"], true]
    - ["in2161031", "inspect.Signature.from_callable.__func__.__class__.__name__.__eq__", ["function"],    true]
    - ["in2161032", "inspect.Signature.from_callable.__class__.__name__.__eq__",         ["method"], true]
    - ["in2161033", "inspect.Signature.__dict__.__contains__",                           ["from_callable"], true]

table inspect_extra2161.property_type_attr_presence:
  description: "property builtin __dict__ contains fget, fset, fdel, __get__, __set__, __delete__, __set_name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2161
  columns: [id, function, args, expected]
  rows:
    - ["in2161034", "inspect.Parameter.__dict__.__contains__",  ["kind"],        true]
    - ["in2161035", "inspect.Parameter.__dict__.__contains__",  ["name"],        true]
    - ["in2161036", "inspect.Parameter.__dict__.__contains__",  ["default"],     true]
    - ["in2161037", "inspect.Parameter.__dict__.__contains__",  ["annotation"],  true]
    - ["in2161038", "inspect.Signature.__dict__.__contains__",  ["parameters"],  true]
    - ["in2161039", "inspect.Signature.__dict__.__contains__",  ["return_annotation"], true]
    - ["in2161040", "inspect.BoundArguments.__dict__.__contains__", ["args"],    true]
    - ["in2161041", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"],  true]
