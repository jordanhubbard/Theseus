invariant abc_extra191.abc_ABCMeta_mro_len:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta's method resolution order is [ABCMeta, type, object]; ABCMeta inherits from type (it is a metaclass), and type inherits from object; this 3-step chain is the minimal MRO for a metaclass; ABCMeta.__mro__.__len__ (3) > ABC.__mro__.__len__ (2) by 1 — the metaclass has one extra step (type) that the regular class does not; ABCMeta.__mro__.__len__ (3) == ABCMeta.__bases__.__len__ (1) + 2 — bases plus itself plus object; NEW in abcmro191: first standalone ABCMeta.__mro__.__len__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__.__len__"
  args: []
  expected: 3

invariant abc_extra191.abc_ABC_mro_len:
  description: "abc.ABC.__mro__.__len__() == 2 — ABC's method resolution order is [ABC, object]; ABC is defined as 'class ABC(metaclass=ABCMeta): pass' with no explicit base other than the implicit object; this gives the minimal 2-step MRO for any Python class; ABC.__mro__.__len__ (2) < ABCMeta.__mro__.__len__ (3) by 1; ABC.__mro__.__len__ (2) == ABCMeta.__bases__.__len__ (1) + 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABC_mro
  kind: python_call_eq
  function: "abc.ABC.__mro__.__len__"
  args: []
  expected: 2

invariant abc_extra191.abc_ABCMeta_mro0_name_eq:
  description: "abc.ABCMeta.__mro__[0].__name__.__eq__('ABCMeta') returns True — ABCMeta.__mro__[0].__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); the first entry in any Python MRO is always the class itself; ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') > ABC.__mro__[0].__name__ (3: 'ABC') by 4 — the metaclass name is longer than the convenience class name; ABCMeta.__mro__[0] is ABCMeta itself — ABCMeta.__mro__[0] is ABCMeta evaluates to True; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__.__getitem__(0).__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

invariant abc_extra191.abc_ABCMeta_mro1_name_eq:
  description: "abc.ABCMeta.__mro__[1].__name__.__eq__('type') returns True — ABCMeta.__mro__[1].__name__=='type' (len=4: t(1)y(2)p(3)e(4)); the second entry in ABCMeta's MRO is type, the built-in metaclass; ABCMeta is a metaclass because it inherits from type; this allows instances of ABCMeta (i.e., classes that use ABCMeta as their metaclass) to have customized class creation behavior; ABCMeta.__mro__[1].__name__ (4: 'type') < ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') by 3; ABCMeta.__mro__[1].__name__ (4: 'type') < ABCMeta.__mro__[2].__name__ (6: 'object') by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__.__getitem__(1).__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra191.abc_ABCMeta_mro2_name_eq:
  description: "abc.ABCMeta.__mro__[2].__name__.__eq__('object') returns True — ABCMeta.__mro__[2].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6)); object is the last entry in every Python MRO; ABCMeta.__mro__[2].__name__ (6: 'object') == ABC.__mro__[1].__name__ (6: 'object') — object appears at the end of both MROs but at different indices; ABCMeta.__mro__[2].__name__ (6) > ABCMeta.__mro__[1].__name__ (4: 'type') by 2; ABCMeta.__mro__[2].__name__ (6) < ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__.__getitem__(2).__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra191.abc_ABC_mro0_name_eq:
  description: "abc.ABC.__mro__[0].__name__.__eq__('ABC') returns True — ABC.__mro__[0].__name__=='ABC' (len=3: A(1)B(2)C(3)); the first entry in any MRO is always the class itself; ABC.__mro__[0].__name__ (3: 'ABC') < ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') by 4 — the convenience class name is shorter than the metaclass name; ABC is a simple helper class that uses ABCMeta as its metaclass, allowing 'class Foo(abc.ABC):' as a shorthand for 'class Foo(metaclass=abc.ABCMeta):'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABC_mro
  kind: python_call_eq
  function: "abc.ABC.__mro__.__getitem__(0).__name__.__eq__"
  args: ["ABC"]
  expected: true

invariant abc_extra191.abc_ABC_mro1_name_eq:
  description: "abc.ABC.__mro__[1].__name__.__eq__('object') returns True — ABC.__mro__[1].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6)); object is ABC's only base and the final entry in its 2-item MRO; ABC.__mro__[1].__name__ (6: 'object') == ABCMeta.__mro__[2].__name__ (6: 'object') — both MROs end with object; ABC.__mro__[1].__name__ (6) > ABC.__mro__[0].__name__ (3: 'ABC') by 3 — the base class name is longer than the class name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABC_mro
  kind: python_call_eq
  function: "abc.ABC.__mro__.__getitem__(1).__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra191.abc_ABCMeta_bases_len:
  description: "abc.ABCMeta.__bases__.__len__() == 1 — ABCMeta.__bases__ is the tuple (type,), a 1-tuple; ABCMeta has exactly one direct base class: the built-in type metaclass; __bases__ contains only the directly-declared bases (not the full MRO), so it has one entry while __mro__ has three; ABCMeta.__bases__.__len__ (1) < ABCMeta.__mro__.__len__ (3) by 2 — the direct-base tuple is always smaller than the MRO; NEW in abcmro191: completing 8-invariant coverage for abc MRO and bases checks; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_bases
  kind: python_call_eq
  function: "abc.ABCMeta.__bases__.__len__"
  args: []
  expected: 1

