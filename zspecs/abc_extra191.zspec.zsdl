    - ["abcmeta_mro0_len",   "abc.ABCMeta.__mro__.__getitem__(0).__name__.__len__", [],           7,    "abc.ABCMeta.__mro__[0].__name__.__len__() == 7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7); verified Python 3.14.3"]
    - ["abcmeta_mro1_eq",    "abc.ABCMeta.__mro__.__getitem__(1).__name__.__eq__",  ["type"],     true, "abc.ABCMeta.__mro__[1].__name__ == 'type' (len=4; ABCMeta's direct base is the built-in type metaclass); verified Python 3.14.3"]
    - ["abcmeta_mro1_len",   "abc.ABCMeta.__mro__.__getitem__(1).__name__.__len__", [],           4,    "abc.ABCMeta.__mro__[1].__name__.__len__() == 4 ('type'=4: t(1)y(2)p(3)e(4)); verified Python 3.14.3"]

