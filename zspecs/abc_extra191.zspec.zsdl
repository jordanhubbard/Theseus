spec: abc_extra191
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABCMeta.__mro__.__len__() == 3; ABCMeta MRO is [ABCMeta, type, object]."
    - "abc.ABC.__mro__.__len__() == 2; ABC MRO is [ABC, object]."
    - "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7); the first entry in any MRO is the class itself."
    - "abc.ABCMeta.__mro__[1].__name__ == 'type' (len=4); ABCMeta inherits from type (it is a metaclass)."
    - "abc.ABCMeta.__mro__[2].__name__ == 'object' (len=6); object is the ultimate base of all Python classes."
    - "abc.ABC.__mro__[0].__name__ == 'ABC' (len=3); the first entry in ABC's MRO is ABC itself."
    - "abc.ABC.__mro__[1].__name__ == 'object' (len=6); ABC's only base is object."
    - "abc.ABCMeta.__bases__.__len__() == 1; ABCMeta has a single direct base: type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

