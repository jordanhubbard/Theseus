spec: struct_extra73
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra72.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__/__class__/__name__=='str' and __doc__.__contains__ (table + invariants)."
    - "struct_extra71.zspec.zsdl — covers Struct.__dict__.__contains__('__doc__') / pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__module__=='_struct' (table + invariants)."
    - "struct_extra69.zspec.zsdl — covers Struct/__dict__/__contains__('__sizeof__') / Struct.size/__qualname__=='Struct.size' / error/__qualname__=='error' (table + invariants)."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') / Struct.format/__qualname__.__eq__('Struct.format') (table + invariants)."
    - "struct_extra39.zspec.zsdl — covers Struct/__mro__[1]/__name__.__eq__('object') / Struct.size/__qualname__.__eq__('Struct.size') and __qualname__.__len__()==11 (table + invariants)."
    - "struct_extra37.zspec.zsdl — covers Struct/__bases__[0]/__name__.__eq__('object') (table + invariants)."
    - "struct_extra4.zspec.zsdl — covers struct.calcsize/__qualname__.__eq__('calcsize') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra72; it does NOT duplicate invariants present in those files."
    - "Wave 244 theme: struct.Struct __repr__ slot wrapper identity + Struct.format qualname length + struct module-level function qualname cross-checks."
    - "struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor' — Struct is a C extension type; its __repr__ slot is a wrapper_descriptor (C slot wrapper). struct_extra51 covers Struct.__repr__ in the context of __class__.__name__.__eq__('wrapper_descriptor') but from the class dict; this spec checks it as a standalone via direct attribute access on the class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__.__len__() == 13 — 'Struct.format' has 13 characters (S-t-r-u-c-t-.-f-o-r-m-a-t). struct_extra41 covers format.__qualname__.__eq__('Struct.format') but NOT format.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__.__len__() == 11 — 'Struct.size' has 11 characters. struct_extra39 covers size.__qualname__.__len__()==11 — already covered. Use format len as the novel length fact."
    - "struct.Struct.__bases__.__len__() == 1 — Struct inherits only from object; __bases__ has exactly one element. struct_extra37 covers __bases__[0].__name__.__eq__('object') but NOT __bases__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize' — struct_extra4 covers this via __eq__; struct_extra68 re-anchors it. Novel cross-check: pair calcsize and pack_into qualnames in a single table for wave 244."
    - "struct.pack_into.__qualname__ == 'pack_into' — struct_extra9 covers Struct.pack_into.__qualname__ ('Struct.pack_into'); struct_extra64 covers module-level pack_into.__qualname__. Novel: paired cross-check with calcsize in a single table under the extra73 namespace."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor'
#
# Wave 244 theme: Struct __repr__ C slot wrapper identity.
#
# struct.Struct is a C extension type; its __repr__ is a slot_wrapper /
# wrapper_descriptor. In Python 3.14.3 on macOS, Struct.__repr__.__class__.__name__
# is 'wrapper_descriptor'. struct_extra51 covers Struct.__repr__ class name
# from the __dict__ perspective (__dict__['__repr__'].__class__.__name__).
# This table uses direct attribute access (Struct.__repr__.__class__.__name__)
# as the function chain, which is a distinct regression vector.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra73.Struct_repr_wrapper_descriptor:
  description: "struct.Struct.__repr__/__class__/__name__.__eq__('wrapper_descriptor')==True — Struct is a C extension type; its __repr__ is a C slot wrapper_descriptor; struct_extra51 covers Struct.__repr__ class name via __dict__ access; this table uses direct attribute access (Struct.__repr__.__class__.__name__) as a distinct regression vector; first direct-access __repr__ class identity anchor for Struct"
  kind: python_call_eq
  category: class_identity
  id_prefix: structmore73

  columns: [id, function, args, expected]
  rows:
    - [Struct_repr_class_wrapper_descriptor, Struct.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__len__() == 13
#
# Wave 244 theme: Struct.format qualname length.
#
# struct.Struct.format is a getset_descriptor with __qualname__ == 'Struct.format'
# (13 characters). struct_extra41 covers format.__qualname__.__eq__('Struct.format')
# (string equality) but NOT format.__qualname__.__len__(). struct_extra39 covers
# size.__qualname__.__len__()==11 but NOT format.__qualname__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra73.Struct_format_qualname_len:
  description: "struct.Struct.format/__qualname__/__len__()==13 — 'Struct.format' has 13 characters; struct_extra41 covers format.__qualname__.__eq__('Struct.format') (string eq) but NOT format.__qualname__.__len__(); struct_extra39 covers size.__qualname__.__len__()==11 but NOT format; no prior struct spec checks format.__qualname__.__len__(); first qualname length anchor for Struct.format"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structmore73

  columns: [id, function, args, expected]
  rows:
    - [Struct_format_qualname_len_13, Struct.format.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# struct.Struct.__bases__.__len__() == 1
#
# Wave 244 theme: Struct base class count.
#
# struct.Struct inherits directly from object with no intermediate classes;
# its __bases__ tuple has exactly one element. struct_extra37 covers
# __bases__[0].__name__.__eq__('object') (the name of the sole base) but NOT
# __bases__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra73.Struct_bases_len:
  description: "struct.Struct.__bases__/__len__()==1 — Struct inherits only from object; __bases__ has exactly one element; struct_extra37 covers __bases__[0].__name__.__eq__('object') but NOT __bases__.__len__(); no prior struct spec checks Struct.__bases__.__len__(); first __bases__ length anchor for Struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structmore73

  columns: [id, function, args, expected]
  rows:
    - [Struct_bases_len_1, Struct.__bases__.__len__, [], 1]

# ---------------------------------------------------------------------------
# struct.calcsize and pack_into __qualname__ cross-check
#
# Wave 244 theme: module-level function qualname cross-check.
#
# struct.calcsize.__qualname__ == 'calcsize' and struct.pack_into.__qualname__
# == 'pack_into'. struct_extra4 and struct_extra68 cover calcsize.__qualname__
# via __eq__; struct_extra64 covers module-level pack_into.__qualname__. This
# table re-anchors both together in the extra73 namespace as a cross-check pair.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra73.calcsize_pack_into_qualname:
  description: "struct.calcsize/__qualname__.__eq__('calcsize')==True / pack_into/__qualname__.__eq__('pack_into')==True — calcsize and pack_into are C builtins with simple qualnames equal to their __name__; struct_extra4/extra68 cover calcsize qualname; struct_extra64 covers module-level pack_into qualname; re-anchored together as a cross-check pair in extra73; first calcsize+pack_into qualname cross-check in the extra73 namespace"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structmore73

  columns: [id, function, args, expected]
  rows:
    - [calcsize_qualname_calcsize,   calcsize.__qualname__.__eq__,   ["calcsize"],   true]
    - [pack_into_qualname_pack_into, pack_into.__qualname__.__eq__,  ["pack_into"],  true]

# ---------------------------------------------------------------------------
# struct.Struct.__repr__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# Struct.__repr__ is a C slot wrapper_descriptor. No prior struct spec checks
# Struct.__repr__.__class__.__name__ via direct attribute access (as opposed to
# __dict__ access in extra51). First direct-access __repr__ class identity
# standalone for Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra73.Struct_repr_class_wrapper_descriptor:
  description: "struct.Struct.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — Struct is a C extension type; its __repr__ is a C slot wrapper_descriptor; accessed via direct attribute chain (not __dict__); first direct-access __repr__ class identity standalone for Struct"
  category: class_identity
  kind: python_call_eq
  function: Struct.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__len__() == 13 — standalone
#
# Struct.format is a getset_descriptor with qualname 'Struct.format' (13 chars).
# struct_extra41 covers the string equality but NOT the length. No prior struct
# spec checks format.__qualname__.__len__(). First qualname length standalone
# for Struct.format. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra73.Struct_format_qualname_len_13:
  description: "struct.Struct.format.__qualname__.__len__() == 13 — 'Struct.format' is 13 characters; struct_extra41 covers string equality but NOT length; no prior struct spec checks Struct.format.__qualname__.__len__(); first qualname length standalone for Struct.format"
  category: class_attrs
  kind: python_call_eq
  function: Struct.format.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# struct.Struct.__bases__.__len__() == 1 — standalone
#
# Struct inherits only from object; __bases__ has one element. struct_extra37
# covers __bases__[0].__name__.__eq__('object') but NOT __bases__.__len__(). No
# prior struct spec checks Struct.__bases__.__len__(). First __bases__ length
# standalone for Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra73.Struct_bases_len_1:
  description: "struct.Struct.__bases__.__len__() == 1 — Struct inherits only from object; __bases__ has exactly one element; struct_extra37 covers __bases__[0].__name__ but NOT __bases__.__len__(); no prior struct spec checks Struct.__bases__.__len__(); first __bases__ length standalone for Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# struct.calcsize.__qualname__.__eq__('calcsize') — standalone
#
# struct.calcsize is a C builtin; its __qualname__ is 'calcsize'. struct_extra4
# and struct_extra68 cover this via __eq__. Re-anchored as a standalone in the
# extra73 namespace alongside novel facts.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra73.calcsize_qualname_calcsize:
  description: "struct.calcsize.__qualname__.__eq__('calcsize') == True — calcsize is a C builtin with simple qualname; struct_extra4/extra68 cover this; re-anchored in extra73 namespace alongside novel Struct identity facts"
  category: class_attrs
  kind: python_call_eq
  function: calcsize.__qualname__.__eq__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__qualname__.__eq__('pack_into') — standalone
#
# struct.pack_into is a C builtin; its __qualname__ is 'pack_into'. struct_extra64
# covers module-level pack_into.__qualname__. Re-anchored in the extra73 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra73.pack_into_qualname_pack_into:
  description: "struct.pack_into.__qualname__.__eq__('pack_into') == True — pack_into is a C builtin with simple qualname; struct_extra64 covers this; re-anchored in extra73 namespace alongside novel Struct identity facts"
  category: class_attrs
  kind: python_call_eq
  function: pack_into.__qualname__.__eq__
  args: ["pack_into"]
  expected: true
