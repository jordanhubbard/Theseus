spec: cli_progress
version: ">=3.0.0"
backend: node(cli-progress)

docs: https://github.com/npkgz/cli-progress#readme

provenance:
  derived_from:
    - "cli-progress README — https://github.com/npkgz/cli-progress#readme"
    - "Test vectors verified with cli-progress via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "cli-progress source"
  notes:
    - "Easy-to-use progress bars for the terminal."
    - "Install: npm install cli-progress"
    - "v3 CJS; named exports Bar / SingleBar / MultiBar / Format / Presets."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructors don't throw on valid options; bar updates emit ANSI sequences to stdout."
  stderr: "null"
  stickiness: "N/A — each bar independent."
  codes: {}

invariant cli_progress.exposes_SingleBar:
  description: "module exposes SingleBar (function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: SingleBar}
    - {get: "constructor.name"}
  expected: "Function"

invariant cli_progress.exposes_MultiBar:
  description: "module exposes MultiBar (function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: MultiBar}
    - {get: "constructor.name"}
  expected: "Function"

invariant cli_progress.Presets_keys_count:
  description: "Presets has 4 named presets (legacy, shades_classic, shades_grey, rect)"
  category: presets
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: Presets}
    - {method: hasOwnProperty, args: ["legacy"]}
  expected: true

invariant cli_progress.preset_shades_classic_exists:
  description: "Presets.shades_classic is an object"
  category: presets
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: Presets}
    - {method: hasOwnProperty, args: ["shades_classic"]}
  expected: true

invariant cli_progress.preset_shades_grey_exists:
  description: "Presets.shades_grey is an object"
  category: presets
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: Presets}
    - {method: hasOwnProperty, args: ["shades_grey"]}
  expected: true

invariant cli_progress.preset_rect_exists:
  description: "Presets.rect is an object"
  category: presets
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: Presets}
    - {method: hasOwnProperty, args: ["rect"]}
  expected: true

invariant cli_progress.shades_classic_format_string:
  description: "Presets.shades_classic.format is the documented format with {bar}/{percentage}/{eta}/{value}/{total} placeholders"
  category: presets
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Presets.shades_classic.format"}
  expected: " {bar} {percentage}% | ETA: {eta}s | {value}/{total}"
