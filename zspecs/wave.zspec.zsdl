spec: wave
version: ">=3.0"
backend: python_module(wave)

docs: https://docs.python.org/3/library/wave.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/wave.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "wave source: Lib/wave.py (PSF; source inspection permitted)"
  not_derived_from:
    - "wave source: internal chunk/struct parsing details"
  notes:
    - "wave.open() is the primary entry point; returns a Wave_read or Wave_write instance depending on mode."
    - "Wave_read is returned when a file is opened for reading (mode 'rb' or 'r')."
    - "Wave_write is returned when a file is opened for writing (mode 'wb' or 'w')."
    - "wave.Error is the module-level exception class, a subclass of Exception."
    - "WAVE_FORMAT_PCM is not a public export of the wave module in Python 3; it is an internal constant."
    - "wave.open.__name__ == 'open' — the function is named 'open' in the module namespace."
    - "Wave_read.__module__ and Wave_write.__module__ are both 'wave'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "wave.Error is raised for malformed WAV data or invalid operations (e.g., writing to a read-mode file). wave.open() raises wave.Error or OSError for bad files."
  stderr: "null"
  stickiness: "N/A — each open() call is independent."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — verify exported class __name__ attributes
# ---------------------------------------------------------------------------

table wave.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Wave_read,  Wave_read.__name__.__eq__,  ["Wave_read"],  true]
    - [Wave_write, Wave_write.__name__.__eq__, ["Wave_write"], true]
    - [Error,      Error.__name__.__eq__,      ["Error"],      true]

# ---------------------------------------------------------------------------
# Module membership checks — Wave_read and Wave_write live in 'wave'
# ---------------------------------------------------------------------------

table wave.module_checks:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Wave_read_module,  Wave_read.__module__.__eq__,  ["wave"], true]
    - [Wave_write_module, Wave_write.__module__.__eq__, ["wave"], true]

# ---------------------------------------------------------------------------
# Function name check — wave.open
# ---------------------------------------------------------------------------

invariant wave.names.open:
  description: "wave.open.__name__ == 'open'"
  category: names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — wave.Error is a subclass of Exception
# ---------------------------------------------------------------------------

invariant wave.Error.base_is_Exception:
  description: "wave.Error.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Type checks — Wave_read and Wave_write are types (classes)
# ---------------------------------------------------------------------------

table wave.type_checks:
  kind: python_call_eq
  category: types
  id_prefix: typecheck

  columns: [id, function, args, expected]
  rows:
    - [Wave_read_is_type,  Wave_read.__class__.__name__.__eq__,  ["type"], true]
    - [Wave_write_is_type, Wave_write.__class__.__name__.__eq__, ["type"], true]
    - [Error_is_type,      Error.__class__.__name__.__eq__,      ["type"], true]

# ---------------------------------------------------------------------------
# open() function type check — it is a plain Python function
# ---------------------------------------------------------------------------

invariant wave.open.is_function:
  description: "type(wave.open).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Wave_read — instance method presence checks via __name__
# ---------------------------------------------------------------------------

table wave.Wave_read.method_names:
  kind: python_call_eq
  category: Wave_read_methods
  id_prefix: wave_read_method

  columns: [id, function, args, expected]
  rows:
    - [getnchannels,  Wave_read.getnchannels.__name__.__eq__,  ["getnchannels"],  true]
    - [getsampwidth,  Wave_read.getsampwidth.__name__.__eq__,  ["getsampwidth"],  true]
    - [getframerate,  Wave_read.getframerate.__name__.__eq__,  ["getframerate"],  true]
    - [getnframes,    Wave_read.getnframes.__name__.__eq__,    ["getnframes"],    true]
    - [readframes,    Wave_read.readframes.__name__.__eq__,    ["readframes"],    true]
    - [close,         Wave_read.close.__name__.__eq__,         ["close"],         true]

# ---------------------------------------------------------------------------
# Wave_write — instance method presence checks via __name__
# ---------------------------------------------------------------------------

table wave.Wave_write.method_names:
  kind: python_call_eq
  category: Wave_write_methods
  id_prefix: wave_write_method

  columns: [id, function, args, expected]
  rows:
    - [setnchannels, Wave_write.setnchannels.__name__.__eq__, ["setnchannels"], true]
    - [setsampwidth, Wave_write.setsampwidth.__name__.__eq__, ["setsampwidth"], true]
    - [setframerate, Wave_write.setframerate.__name__.__eq__, ["setframerate"], true]
    - [writeframes,  Wave_write.writeframes.__name__.__eq__,  ["writeframes"],  true]
    - [close,        Wave_write.close.__name__.__eq__,        ["close"],        true]
