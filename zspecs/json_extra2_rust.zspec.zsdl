spec: json_extra2_rust
version: ">=3.9"
backend: rust_module(json_extra2_rust)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json documentation"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
  notes:
    - "Additional json functions not covered in json_rust or json_extra_rust."
    - "json.dumps with indent parameter produces multi-line formatted output."
    - "json.dumps({'a': 1}, indent=2) == '{\\n  \"a\": 1\\n}'."
    - "json.dumps({'b': 2, 'a': 1}, sort_keys=True) == '{\"a\": 1, \"b\": 2}'."
    - "json.dumps([1, 2, 3], indent=2) == '[\\n  1,\\n  2,\\n  3\\n]'."
    - "json.dumps with separators=(',', ':') produces compact output."
    - "json.dumps({'a': 1}, separators=(',', ':')) == '{\"a\":1}'."
    - "All test vectors verified against Python 3.14.3 json module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dumps with indent — formatted multi-line output
table json_extra2_rust.dumps.indent:
  kind: python_call_eq
  category: dumps_indent
  id_prefix: je2_di
  function: dumps

  columns: [id, args, expected]
  rows:
    - [single_kv,   [{"a": 1}, {"indent": 2}],          "{\n  \"a\": 1\n}"]
    - [array,       [[1, 2, 3], {"indent": 2}],          "[\n  1,\n  2,\n  3\n]"]
    - [indent_4,    [{"x": 0}, {"indent": 4}],           "{\n    \"x\": 0\n}"]

# dumps with sort_keys — deterministic key ordering
table json_extra2_rust.dumps.sort_keys:
  kind: python_call_eq
  category: dumps_sort
  id_prefix: je2_sk
  function: dumps

  columns: [id, args, expected]
  rows:
    - [two_keys, [{"b": 2, "a": 1}, {"sort_keys": true}],  "{\"a\": 1, \"b\": 2}"]
    - [three_keys, [{"c": 3, "a": 1, "b": 2}, {"sort_keys": true}], "{\"a\": 1, \"b\": 2, \"c\": 3}"]

# dumps with separators — compact output
table json_extra2_rust.dumps.separators:
  kind: python_call_eq
  category: dumps_sep
  id_prefix: je2_sp
  function: dumps

  columns: [id, args, expected]
  rows:
    - [compact_obj,   [{"a": 1}, {"separators": [",", ":"]}],          "{\"a\":1}"]
    - [compact_arr,   [[1, 2, 3], {"separators": [",", ":"]}],          "[1,2,3]"]
    - [two_keys_comp, [{"a": 1, "b": 2}, {"separators": [",", ":"]}],  "{\"a\":1,\"b\":2}"]

