spec: is_string
version: ">=1.1.1"
backend: node(is-string)

docs: https://www.npmjs.com/package/is-string

provenance:
  derived_from:
    - "is-string README — https://www.npmjs.com/package/is-string"
    - "Test vectors verified with is-string via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-string source"
  notes:
    - "is-string is an npm package. Install: npm install is-string"
    - "Returns true if the value is a string primitive or String object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_string.isString:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isstr

  columns: [id, args, expected]
  rows:
    - [string_lit,  ["foo"],  true]
    - [empty_str,   [""],     true]
    - [number,      [5],      false]
    - [bool,        [true],   false]
    - [null_val,    [null],   false]
