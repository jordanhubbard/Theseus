spec: itertools_extra2731
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol — used by math.trunc(), math.floor(), math.ceil())."
    - "All itertools iterator classes (chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement) are lazy iterators."
    - "Lazy iterators do not support numeric rounding protocols such as __trunc__, __floor__, or __ceil__."
    - "itertools.count yields integers/floats indefinitely but the iterator class itself defines none of __trunc__, __floor__, or __ceil__ in its __dict__."
    - "None of the itertools classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all itertools classes
# ---------------------------------------------------------------------------

table itertools_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all itertools iterator class __dict__s — lazy iterators do not support numeric truncation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2731

  columns: [id, function, args, expected]
  rows:
    - ["it2731001", "itertools.chain.__dict__.__contains__",                         ["__trunc__"], false]
    - ["it2731002", "itertools.count.__dict__.__contains__",                         ["__trunc__"], false]
    - ["it2731003", "itertools.repeat.__dict__.__contains__",                        ["__trunc__"], false]
    - ["it2731004", "itertools.cycle.__dict__.__contains__",                         ["__trunc__"], false]
    - ["it2731005", "itertools.islice.__dict__.__contains__",                        ["__trunc__"], false]
