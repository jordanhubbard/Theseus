    - ["it2731007", "itertools.dropwhile.__dict__.__contains__",                     ["__trunc__"], false]
    - ["it2731008", "itertools.takewhile.__dict__.__contains__",                     ["__trunc__"], false]
    - ["it2731009", "itertools.starmap.__dict__.__contains__",                       ["__trunc__"], false]
    - ["it2731010", "itertools.groupby.__dict__.__contains__",                       ["__trunc__"], false]
    - ["it2731011", "itertools.filterfalse.__dict__.__contains__",                   ["__trunc__"], false]
    - ["it2731012", "itertools.accumulate.__dict__.__contains__",                    ["__trunc__"], false]
    - ["it2731013", "itertools.zip_longest.__dict__.__contains__",                   ["__trunc__"], false]
    - ["it2731014", "itertools.pairwise.__dict__.__contains__",                      ["__trunc__"], false]
    - ["it2731015", "itertools.product.__dict__.__contains__",                       ["__trunc__"], false]
    - ["it2731016", "itertools.permutations.__dict__.__contains__",                  ["__trunc__"], false]
    - ["it2731017", "itertools.combinations.__dict__.__contains__",                  ["__trunc__"], false]
    - ["it2731018", "itertools.combinations_with_replacement.__dict__.__contains__",  ["__trunc__"], false]

