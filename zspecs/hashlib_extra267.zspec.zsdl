spec: hashlib_extra267
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "hashlib_extra266.zspec.zsdl — covers hashlib module identity (__name__, __package__, __spec__, __loader__), __all__ type, and new/__hash_new function identity."
    - "hashlib_extra107.zspec.zsdl — covers HASH class identity, HASH method qualname lengths, hash algorithm digest_size and block_size values."
    - "hashlib.zspec.zsdl — covers sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors using hash_known_vector kind; incremental update; digest consistency; copy independence; api equivalence."
  notes:
    - "sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad' — verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12. Some published references cite a different value; this spec uses only the machine-verified value."
    - "sha512(b'abc').hexdigest() == 'ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f' — FIPS 180-4 reference. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "md5(b'abc').hexdigest() == '900150983cd24fb0d6963f7d28e17f72' — RFC 1321 A.5 reference vector. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "sha1(b'abc').hexdigest() == 'a9993e364706816aba3e25717850c26c9cd0d89d' — FIPS 180-4 reference vector. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "sha256(b'The quick brown fox jumps over the lazy dog').hexdigest() == 'd7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592' — widely-cited reference vector. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256.__name__ == 'openssl_sha256' — the constructor is a C builtin_function_or_method backed by OpenSSL. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha512.__name__ == 'openssl_sha512' — same pattern as sha256 but for 512-bit output. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.md5.__name__ == 'openssl_md5' — MD5 is also backed by OpenSSL in CPython. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "sha256(b'abc').hexdigest().__len__() == 64 — SHA-256 hexdigest is always 64 hex chars (256 bits / 4). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "sha512(b'abc').hexdigest().__len__() == 128 — SHA-512 hexdigest is always 128 hex chars (512 bits / 4). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha256 constructor identity — __name__ and __class__.__name__
# The sha256 constructor in CPython is backed by OpenSSL and exposed as a
# C builtin_function_or_method with __name__ == 'openssl_sha256'.
# ---------------------------------------------------------------------------

table hashlib_extra267.constructor_identity:
  description: "hashlib sha256/sha512/md5/sha1 constructor __name__ and __class__.__name__ — all are OpenSSL-backed C builtins; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashid267

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name,       sha256.__name__.__eq__,               ["openssl_sha256"],             true, "hashlib.sha256.__name__ == 'openssl_sha256' — OpenSSL-backed constructor name"]
    - [sha256_class,      sha256.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' — C-level constructor"]
    - [sha512_name,       sha512.__name__.__eq__,               ["openssl_sha512"],             true, "hashlib.sha512.__name__ == 'openssl_sha512' — OpenSSL-backed constructor name"]
    - [sha512_class,      sha512.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method' — C-level constructor"]
    - [md5_name,          md5.__name__.__eq__,                  ["openssl_md5"],                true, "hashlib.md5.__name__ == 'openssl_md5' — OpenSSL-backed constructor name"]

# ---------------------------------------------------------------------------
# sha256 hexdigest length — always 64 hex chars (256 bits / 4 bits per char)
# sha512 hexdigest length — always 128 hex chars (512 bits / 4 bits per char)
# sha256(b'').hexdigest().__len__() == 64
# sha512(b'').hexdigest().__len__() == 128
# ---------------------------------------------------------------------------

invariant hashlib_extra267.sha256_hexdigest_len:
  description: "hashlib.sha256(b'').hexdigest().__len__() == 64 — SHA-256 hexdigest is always exactly 64 hex characters (256 bits / 4 bits per hex char)"
  category: properties
  kind: python_call_eq
  function: "sha256(b'').hexdigest().__len__"
  args: []
  expected: 64

invariant hashlib_extra267.sha512_hexdigest_len:
  description: "hashlib.sha512(b'').hexdigest().__len__() == 128 — SHA-512 hexdigest is always exactly 128 hex characters (512 bits / 4 bits per hex char)"
  category: properties
  kind: python_call_eq
  function: "sha512(b'').hexdigest().__len__"
  args: []
  expected: 128

# ---------------------------------------------------------------------------
# sha256 known test vectors — hexdigest() values for b'abc'
# sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'
# This value was verified against Python 3.14.3 and agrees with the FIPS 180-4
# reference vector. Some published references cite a different value — this
# spec uses only the machine-verified value.
# ---------------------------------------------------------------------------

invariant hashlib_extra267.sha256_abc_hexdigest_eq:
  description: "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad' — machine-verified FIPS 180-4 reference vector; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: known_vectors
  kind: python_call_eq
  function: "sha256(b'abc').hexdigest().__eq__"
  args: ["ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"]
  expected: true

invariant hashlib_extra267.sha512_abc_hexdigest_eq:
  description: "hashlib.sha512(b'abc').hexdigest() == 'ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f' — FIPS 180-4 reference vector; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: known_vectors
  kind: python_call_eq
  function: "sha512(b'abc').hexdigest().__eq__"
  args: ["ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"]
  expected: true

invariant hashlib_extra267.md5_abc_hexdigest_eq:
  description: "hashlib.md5(b'abc').hexdigest() == '900150983cd24fb0d6963f7d28e17f72' — RFC 1321 A.5 reference vector; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: known_vectors
  kind: python_call_eq
  function: "md5(b'abc').hexdigest().__eq__"
  args: ["900150983cd24fb0d6963f7d28e17f72"]
  expected: true

invariant hashlib_extra267.sha1_abc_hexdigest_eq:
  description: "hashlib.sha1(b'abc').hexdigest() == 'a9993e364706816aba3e25717850c26c9cd0d89d' — FIPS 180-4 reference vector; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: known_vectors
  kind: python_call_eq
  function: "sha1(b'abc').hexdigest().__eq__"
  args: ["a9993e364706816aba3e25717850c26c9cd0d89d"]
  expected: true

# ---------------------------------------------------------------------------
# sha256 quick-brown-fox test vector
# sha256(b'The quick brown fox jumps over the lazy dog').hexdigest()
#   == 'd7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592'
# Widely-cited reference vector; verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra267.sha256_quick_fox_hexdigest_eq:
  description: "hashlib.sha256(b'The quick brown fox jumps over the lazy dog').hexdigest() == 'd7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592' — widely-cited reference vector; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: known_vectors
  kind: python_call_eq
  function: "sha256(b'The quick brown fox jumps over the lazy dog').hexdigest().__eq__"
  args: ["d7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592"]
  expected: true

# ---------------------------------------------------------------------------
# sha256 hexdigest class — always returns a str
# sha256(b'abc').hexdigest().__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

invariant hashlib_extra267.sha256_hexdigest_class:
  description: "hashlib.sha256(b'abc').hexdigest().__class__.__name__ == 'str' — hexdigest() always returns a plain Python str"
  category: properties
  kind: python_call_eq
  function: "sha256(b'abc').hexdigest().__class__.__name__.__eq__"
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone identity invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra267.sha256_name_eq:
  description: "hashlib.sha256.__name__ == 'openssl_sha256' — sha256 constructor is an OpenSSL-backed C builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra267.sha512_name_eq:
  description: "hashlib.sha512.__name__ == 'openssl_sha512' — sha512 constructor is an OpenSSL-backed C builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlib_extra267.md5_name_eq:
  description: "hashlib.md5.__name__ == 'openssl_md5' — md5 constructor is an OpenSSL-backed C builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true
