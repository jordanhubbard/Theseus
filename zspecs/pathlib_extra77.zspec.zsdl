spec: pathlib_extra77
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra76."
    - "Prior specs covered: PurePath/PurePosixPath/PureWindowsPath/Path/PosixPath/WindowsPath __name__/__module__/__qualname__; Path instance attributes; Path method __name__/__qualname__ checks; Path MRO."
    - "pathlib_extra76 covers Path method __qualname__ values and lengths for open, read_text, write_text, iterdir, mkdir, exists, unlink, rename, stat."
    - "This spec covers: Path method __code__.co_name and __code__.co_argcount for open, read_text, write_text, iterdir, __init__. First spec to access __code__ objects for pathlib methods."
    - "Path.open.__code__.co_name == 'open' — the code object's name matches the method name."
    - "Path.open.__code__.co_argcount == 6 — self + mode + buffering + encoding + errors + newline (Python 3.14)."
    - "Path.read_text.__code__.co_name == 'read_text'."
    - "Path.read_text.__code__.co_argcount == 4 — self + encoding + errors + newline."
    - "Path.write_text.__code__.co_name == 'write_text'."
    - "Path.write_text.__code__.co_argcount == 5 — self + data + encoding + errors + newline."
    - "Path.iterdir.__code__.co_name == 'iterdir'."
    - "Path.iterdir.__code__.co_argcount == 1 — self only."
    - "Path.__init__.__code__.co_name == '__init__'."
    - "Path.__init__.__code__.co_argcount == 1 — self only (Python 3.14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path method __code__.co_name checks — open, read_text, write_text, iterdir
# No prior pathlib spec accesses the __code__ attribute of any Path method.
# co_name is the name embedded in the code object; for a method it matches
# the method name.
# ---------------------------------------------------------------------------

table pathlib_extra77.Path_code_name:
  description: "Path method __code__.co_name values match the method name"
  kind: python_call_eq
  category: code_attributes
  id_prefix: pathlibcode77

  columns: [id, function, args, expected]
  rows:
    - [open,       Path.open.__code__.co_name.__eq__,       ["open"],       true]
    - [read_text,  Path.read_text.__code__.co_name.__eq__,  ["read_text"],  true]
    - [write_text, Path.write_text.__code__.co_name.__eq__, ["write_text"], true]
    - [iterdir,    Path.iterdir.__code__.co_name.__eq__,    ["iterdir"],    true]

# ---------------------------------------------------------------------------
# Path method __code__.co_argcount checks — open, read_text, write_text, iterdir
# co_argcount counts positional + keyword positional arguments (not *args or
# **kwargs). Python 3.14 counts: open=6, read_text=4, write_text=5, iterdir=1.
# ---------------------------------------------------------------------------

table pathlib_extra77.Path_code_argcount:
  description: "Path method __code__.co_argcount values (Python 3.14)"
  kind: python_call_eq
  category: code_attributes
  id_prefix: pathlibcode77

  columns: [id, function, args, expected]
  rows:
    - [open,       Path.open.__code__.co_argcount.__eq__,       [6], true]
    - [read_text,  Path.read_text.__code__.co_argcount.__eq__,  [4], true]
    - [write_text, Path.write_text.__code__.co_argcount.__eq__, [5], true]
    - [iterdir,    Path.iterdir.__code__.co_argcount.__eq__,    [1], true]

# ---------------------------------------------------------------------------
# Path.__init__ __code__ attribute checks
# In Python 3.14, Path.__init__ is a Python method with a code object.
# co_name == '__init__', co_argcount == 1 (self only; remaining are *args).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra77.Path_init_code:
  description: "Path.__init__ code object attributes in Python 3.14"
  kind: python_call_eq
  category: code_attributes
  id_prefix: pathlibcode77

  columns: [id, function, args, expected]
  rows:
    - [co_name,     Path.__init__.__code__.co_name.__eq__,     ["__init__"], true]
    - [co_argcount, Path.__init__.__code__.co_argcount.__eq__, [1],          true]

# ---------------------------------------------------------------------------
# Path method co_argcount raw integer equality
# Verifying co_argcount values directly without __eq__ pattern.
# iterdir == 1 (self only), open == 6.
# ---------------------------------------------------------------------------

table pathlib_extra77.Path_code_argcount_direct:
  description: "Path method __code__.co_argcount integer values"
  kind: python_call_eq
  category: code_attributes
  id_prefix: pathlibcode77

  columns: [id, function, args, expected]
  rows:
    - [open_count,      Path.open.__code__.co_argcount.__eq__,      [6], true]
    - [iterdir_count,   Path.iterdir.__code__.co_argcount.__eq__,   [1], true]
    - [write_text_count, Path.write_text.__code__.co_argcount.__eq__, [5], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra77.Path_open.co_name:
  description: "pathlib.Path.open.__code__.co_name == 'open'"
  category: code_attributes
  kind: python_call_eq
  function: Path.open.__code__.co_name.__eq__
  args: ["open"]
  expected: true

invariant pathlib_extra77.Path_open.co_argcount_6:
  description: "pathlib.Path.open.__code__.co_argcount == 6 (self + mode + buffering + encoding + errors + newline)"
  category: code_attributes
  kind: python_call_eq
  function: Path.open.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant pathlib_extra77.Path_read_text.co_name:
  description: "pathlib.Path.read_text.__code__.co_name == 'read_text'"
  category: code_attributes
  kind: python_call_eq
  function: Path.read_text.__code__.co_name.__eq__
  args: ["read_text"]
  expected: true

invariant pathlib_extra77.Path_iterdir.co_argcount_1:
  description: "pathlib.Path.iterdir.__code__.co_argcount == 1 (self only)"
  category: code_attributes
  kind: python_call_eq
  function: Path.iterdir.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra77.Path_init.co_name:
  description: "pathlib.Path.__init__.__code__.co_name == '__init__'"
  category: code_attributes
  kind: python_call_eq
  function: Path.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true
