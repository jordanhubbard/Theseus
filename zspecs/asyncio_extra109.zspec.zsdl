# ---------------------------------------------------------------------------
# Standalone invariants — extra109
# ---------------------------------------------------------------------------

invariant asyncio_extra109.StreamReader_base_is_object:
  description: "asyncio.StreamReader.__bases__[0].__name__.__eq__('object') returns True — StreamReader inherits directly from object with MRO [StreamReader, object] (length=2); StreamReader.__module__=='asyncio.streams'; StreamReader.__qualname__=='StreamReader' (len=12); StreamReader is the class for reading data from async network streams; read(n) takes self and n (co_argcount=2); readline() takes only self (co_argcount=1); StreamWriter also has base=object, mro len=2, module=='asyncio.streams'; both Stream classes share the same base, module, and MRO structure; NEW in extra109: first standalone StreamReader base invariant in asynciostream109 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.StreamReader.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra109.StreamWriter_base_is_object:
  description: "asyncio.StreamWriter.__bases__[0].__name__.__eq__('object') returns True — StreamWriter inherits directly from object with MRO [StreamWriter, object] (length=2); StreamWriter.__module__=='asyncio.streams'; StreamWriter.__qualname__=='StreamWriter' (len=12, same length as StreamReader=12); write(data) takes self and data (co_argcount=2); drain() takes only self (co_argcount=1); StreamWriter.__name__.__len__()==12 == StreamReader.__name__.__len__()==12 (tied same length); both StreamReader and StreamWriter have mro len=2, base=object, module==asyncio.streams; NEW in extra109: first standalone StreamWriter base invariant in asynciostream109 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.StreamWriter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra109.StreamReader_read_co_argcount_2:
  description: "asyncio.StreamReader.read.__code__.co_argcount == 2 — read() takes self and n; StreamReader.read.__qualname__=='StreamReader.read' (len=17); type(asyncio.StreamReader.read).__name__=='function' (Python-defined); compare: StreamReader.readline.__code__.co_argcount==1 (self only — readline takes no args because it reads until newline); read co_argcount=2 vs readline co_argcount=1; read qualname=17 < readline qualname=21; similarly StreamWriter.write co_argcount=2 (self and data) and StreamWriter.drain co_argcount=1 (self only); pattern: methods requiring data payload (read, write) have co_argcount=2; standalone completion methods (readline reads until newline, drain flushes) have co_argcount=1; NEW in extra109: first standalone StreamReader.read argcount invariant in asynciostream109 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.StreamReader.read.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra109.open_connection_co_argcount_2:
  description: "asyncio.open_connection.__code__.co_argcount == 2 — open_connection takes host and port as positional args (additional keyword-only args are not counted by co_argcount); open_connection.__qualname__=='open_connection' (len=15); open_connection.__code__.co_name=='open_connection'; compare: start_server.__code__.co_argcount==3 (client_connected_cb, host, port — one more positional arg); open_connection qualname len=15 > start_server qualname len=12; open_connection is the client-side coroutine that opens a TCP connection returning (StreamReader, StreamWriter); start_server is the server-side coroutine; co_argcount counts only positional arguments (not keyword-only), so open_connection=2 and start_server=3 reflect their respective positional signatures; NEW in extra109: first standalone open_connection argcount invariant in asynciostream109 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.open_connection.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra109.start_server_co_argcount_3:
  description: "asyncio.start_server.__code__.co_argcount == 3 — start_server takes client_connected_cb, host, and port as positional args; start_server.__qualname__=='start_server' (len=12, shorter than open_connection=15); start_server.__code__.co_name=='start_server'; compare: open_connection.__code__.co_argcount==2 (one fewer positional arg); start_server co_argcount=3 > open_connection co_argcount=2; start_server is the coroutine that creates a TCP server and calls client_connected_cb(reader, writer) for each new connection; the extra positional arg (client_connected_cb) compared to open_connection reflects start_server's role as the server-side counterpart requiring a connection handler callback; start_server qualname='start_server' (len=12) < open_connection (len=15); NEW in extra109: first standalone start_server argcount invariant in asynciostream109 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.start_server.__code__.co_argcount.__eq__
  args: [3]
  expected: true

