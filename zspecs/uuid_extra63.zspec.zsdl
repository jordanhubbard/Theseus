invariant uuid_extra63.uuid3_co_name:
  description: "uuid.uuid3.__code__.co_name.__eq__('uuid3') == True — uuid3 is a module-level Python function in Lib/uuid.py; co_name is 'uuid3'; no prior uuid spec checks uuid3.__code__.co_name; first code object co_name standalone for uuid3"
  category: code_objects
  kind: python_call_eq
  function: uuid3.__code__.co_name.__eq__
  args: ["uuid3"]
  expected: true

