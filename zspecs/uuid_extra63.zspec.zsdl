invariant uuid_extra63.uuid5_co_name:
  description: "uuid.uuid5.__code__.co_name.__eq__('uuid5') == True — uuid5 is a module-level Python function in Lib/uuid.py; co_name is 'uuid5'; no prior uuid spec checks uuid5.__code__.co_name; first code object co_name standalone for uuid5"
  category: code_objects
