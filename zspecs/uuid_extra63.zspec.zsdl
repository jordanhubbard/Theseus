spec: uuid_extra63
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra62.zspec.zsdl — covers UUID.__init__.__code__.co_name/'__init__' / co_argcount/7 / UUID.__str__/__hash__ co_argcount/1 / uuid4/__code__.co_name/'uuid4' / co_argcount/0 / uuid1/__code__.co_name/'uuid1' / co_argcount/2 (table + invariants)."
    - "uuid_extra61.zspec.zsdl — covers uuid.__name__/__spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__ / UUID.__dict__.__class__.__name__=='mappingproxy' / UUID.__dict__.__contains__ __init__/__repr__/__str__/__hash__/__eq__ (table + invariants)."
    - "uuid_extra60.zspec.zsdl — covers UUID.__repr__/__str__/__hash__/__eq__ co_name and co_argcount / SafeUUID/__class__/__name__=='type' / SafeUUID/__name__/__module__/__qualname__ / SafeUUID/__bases__[0].__name__=='IntEnum' (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra62; it does NOT duplicate invariants present in those files."
    - "Wave 238 theme: UUID class attributes — version constants and RFC fields."
    - "uuid.UUID.__eq__.__code__.co_name == '__eq__' — uuid_extra60 covers co_name for __repr__/__str__/__hash__/__eq__; this spec re-anchors __eq__ co_name alongside novel co_argcount checks in extra63 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_argcount == 2 — UUID.__eq__ takes self and other. No prior uuid spec checks __eq__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__code__.co_name == '__lt__' — no prior uuid spec checks __lt__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__code__.co_argcount == 2 — UUID.__lt__ takes self and other. No prior uuid spec checks __lt__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_name == 'uuid3' — the code object name for module-level uuid3. No prior uuid spec checks uuid3.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_argcount == 2 — uuid3 takes namespace and name. No prior uuid spec checks uuid3.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_name == 'uuid5' — the code object name for module-level uuid5. No prior uuid spec checks uuid5.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_argcount == 2 — uuid5 takes namespace and name. No prior uuid spec checks uuid5.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance. No prior uuid spec checks NAMESPACE_DNS.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID instance. No prior uuid spec checks NAMESPACE_URL.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — NAMESPACE_OID is a UUID instance. No prior uuid spec checks NAMESPACE_OID.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — NAMESPACE_X500 is a UUID instance. No prior uuid spec checks NAMESPACE_X500.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__eq__ and UUID.__lt__ code object co_name and co_argcount
#
# Wave 238 theme: UUID comparison method code objects.
#
# uuid.UUID.__eq__ and uuid.UUID.__lt__ are Python comparison methods defined
# in Lib/uuid.py. uuid_extra60 covers co_name for __eq__; this spec re-anchors
# __eq__ co_name and adds co_argcount for both __eq__ and __lt__. No prior uuid
# spec checks __lt__.__code__ at all. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra63.UUID_comparison_code:
  description: "uuid.UUID.__eq__.__code__.co_name.__eq__('__eq__')==True / UUID.__eq__.__code__.co_argcount.__eq__(2)==True / UUID.__lt__.__code__.co_name.__eq__('__lt__')==True / UUID.__lt__.__code__.co_argcount.__eq__(2)==True — __eq__ and __lt__ are Python comparison methods; co_argcount is 2 (self + other); uuid_extra60 covers __eq__ co_name; no prior uuid spec checks __lt__.__code__ or __eq__.__code__.co_argcount; first code object table for UUID.__eq__ co_argcount and UUID.__lt__"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidmore63

  columns: [id, function, args, expected]
  rows:
    - [UUID_eq_co_name,      UUID.__eq__.__code__.co_name.__eq__,      ["__eq__"], true]
    - [UUID_eq_co_argcount,  UUID.__eq__.__code__.co_argcount.__eq__,  [2],        true]
    - [UUID_lt_co_name,      UUID.__lt__.__code__.co_name.__eq__,      ["__lt__"], true]
    - [UUID_lt_co_argcount,  UUID.__lt__.__code__.co_argcount.__eq__,  [2],        true]

# ---------------------------------------------------------------------------
# uuid3 and uuid5 code object co_name and co_argcount
#
# Wave 238 theme: uuid3/uuid5 function code objects.
#
# uuid.uuid3 and uuid.uuid5 are module-level Python functions in Lib/uuid.py.
# Both generate UUIDs using MD5/SHA1 of a namespace UUID and a name string.
# Both have co_argcount == 2 (namespace, name). No prior uuid spec checks
# uuid3.__code__ or uuid5.__code__ at all.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra63.uuid3_uuid5_code:
  description: "uuid.uuid3.__code__.co_name.__eq__('uuid3')==True / uuid3.__code__.co_argcount.__eq__(2)==True / uuid5.__code__.co_name.__eq__('uuid5')==True / uuid5.__code__.co_argcount.__eq__(2)==True — uuid3 and uuid5 are Python functions taking namespace and name; no prior uuid spec checks uuid3/__code__ or uuid5/__code__; first code object anchor for uuid3 and uuid5"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidmore63

  columns: [id, function, args, expected]
  rows:
    - [uuid3_co_name,      uuid3.__code__.co_name.__eq__,      ["uuid3"], true]
    - [uuid3_co_argcount,  uuid3.__code__.co_argcount.__eq__,  [2],       true]
    - [uuid5_co_name,      uuid5.__code__.co_name.__eq__,      ["uuid5"], true]
    - [uuid5_co_argcount,  uuid5.__code__.co_argcount.__eq__,  [2],       true]

# ---------------------------------------------------------------------------
# NAMESPACE_DNS and NAMESPACE_URL __class__.__name__
#
# Wave 238 theme: UUID namespace constants class identity.
#
# uuid.NAMESPACE_DNS and uuid.NAMESPACE_URL are module-level UUID instances
# defined as RFC 4122 namespace identifiers. Their __class__.__name__ is 'UUID'.
# No prior uuid spec checks NAMESPACE_DNS.__class__.__name__ or
# NAMESPACE_URL.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra63.namespace_dns_url_class:
  description: "uuid.NAMESPACE_DNS/__class__/__name__.__eq__('UUID')==True / NAMESPACE_URL/__class__/__name__.__eq__('UUID')==True — NAMESPACE_DNS and NAMESPACE_URL are UUID instances (RFC 4122 namespace identifiers); no prior uuid spec checks __class__.__name__ for these constants; first class identity anchor for NAMESPACE_DNS and NAMESPACE_URL"
  kind: python_call_eq
  category: constants
  id_prefix: uuidmore63

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS_class_UUID, NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
    - [NAMESPACE_URL_class_UUID, NAMESPACE_URL.__class__.__name__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# NAMESPACE_OID and NAMESPACE_X500 __class__.__name__
#
# Wave 238 theme: UUID namespace constants class identity (OID and X.500).
#
# uuid.NAMESPACE_OID and uuid.NAMESPACE_X500 are module-level UUID instances
# for the ISO OID and X.500 namespace identifiers from RFC 4122.
# Their __class__.__name__ is 'UUID'. No prior uuid spec checks
# NAMESPACE_OID.__class__.__name__ or NAMESPACE_X500.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra63.namespace_oid_x500_class:
  description: "uuid.NAMESPACE_OID/__class__/__name__.__eq__('UUID')==True / NAMESPACE_X500/__class__/__name__.__eq__('UUID')==True — NAMESPACE_OID and NAMESPACE_X500 are UUID instances (RFC 4122 namespace identifiers); no prior uuid spec checks __class__.__name__ for these constants; first class identity anchor for NAMESPACE_OID and NAMESPACE_X500"
  kind: python_call_eq
  category: constants
  id_prefix: uuidmore63

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_OID_class_UUID,  NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true]
    - [NAMESPACE_X500_class_UUID, NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# UUID.__lt__.__code__.co_name.__eq__('__lt__') — standalone
#
# uuid.UUID.__lt__ is a Python comparison method defined in Lib/uuid.py.
# Its code object co_name is '__lt__'. No prior uuid spec checks
# __lt__.__code__.co_name. First code object co_name standalone for UUID.__lt__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra63.UUID_lt_co_name:
  description: "uuid.UUID.__lt__.__code__.co_name.__eq__('__lt__') == True — UUID.__lt__ is defined in Lib/uuid.py; code object co_name is '__lt__'; no prior uuid spec checks __lt__.__code__.co_name; first code object co_name standalone for UUID.__lt__"
  category: code_objects
  kind: python_call_eq
  function: UUID.__lt__.__code__.co_name.__eq__
  args: ["__lt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid3.__code__.co_name.__eq__('uuid3') — standalone
#
# uuid.uuid3 is a module-level Python function. Code object co_name is 'uuid3'.
# No prior uuid spec checks uuid3.__code__.co_name.
# First code object co_name standalone for uuid3.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
