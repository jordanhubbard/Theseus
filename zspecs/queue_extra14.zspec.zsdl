spec: queue_extra14
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "CPython source: Modules/_queuemodule.c"
    - "queue_extra13.zspec.zsdl — covers Queue/__init__/__repr__ qualnames; LifoQueue/PriorityQueue __init__ qualnames; SimpleQueue.put/get qualnames."
    - "queue_extra12.zspec.zsdl — covers Queue instance method qualnames (put/get/etc.); LifoQueue/PriorityQueue __qualname__ standalone."
    - "queue_extra11.zspec.zsdl — covers __qualname__.__len__ for all 6 classes."
    - "queue_extra9.zspec.zsdl — covers Empty/__qualname__.__eq__ and Full/__qualname__.__eq__ standalone."
    - "queue_extra8.zspec.zsdl — covers __qualname__.__eq__ for all 6 classes."
    - "queue_extra4.zspec.zsdl — covers __name__/__module__/__bases__ for Queue, LifoQueue, PriorityQueue, SimpleQueue, Empty, Full."
  notes:
    - "This spec extends queue.zspec.zsdl through queue_extra13.zspec.zsdl."
    - "Prior specs cover: __qualname__/__qualname__.__len__/__qualname__.__eq__ for all 6 classes; __name__/__module__/__bases__ for all 6 classes (extra4); method qualnames for Queue/LifoQueue/PriorityQueue/SimpleQueue (extra12, extra13)."
    - "NOT yet covered: __module__.__eq__ in extra14 namespace for Queue/LifoQueue/PriorityQueue; SimpleQueue.__module__ pointing to '_queue' (C extension); __bases__[0].__name__.__eq__ in extra14 namespace; Empty/__module__ pointing to '_queue'; Full/__module__; Empty/Full __bases__[0].__name__.__len__()."
    - "Focus: __module__.__eq__ standalone invariants in extra14 namespace for all 4 classes; __bases__[0].__name__ standalone in extra14 namespace; Empty/Full module and base class name."
    - "queue.Queue.__module__ == 'queue' — pure-Python class. Verified Python 3.12 macOS."
    - "queue.LifoQueue.__module__ == 'queue' — pure-Python subclass of Queue. Verified."
    - "queue.PriorityQueue.__module__ == 'queue' — pure-Python subclass of Queue. Verified."
    - "queue.SimpleQueue.__module__ == '_queue' — implemented in the C extension _queue. Verified."
    - "queue.Queue.__bases__[0].__name__ == 'object' — Queue inherits directly from object. Verified."
    - "queue.LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue subclasses Queue. Verified."
    - "queue.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue subclasses Queue. Verified."
    - "queue.Empty.__qualname__ == 'Empty' — top-level exception class. Verified."
    - "queue.Empty.__module__ == '_queue' — Empty is defined in the C extension. Verified."
    - "queue.Empty.__bases__[0].__name__ == 'Exception' — Empty inherits from Exception. Verified."
    - "queue.Full.__qualname__ == 'Full' — top-level exception class. Verified."
    - "queue.Full.__module__ == 'queue' — Full is defined in Lib/queue.py. Verified."
    - "queue.Full.__bases__[0].__name__ == 'Exception' — Full inherits from Exception. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__eq__ for Queue, LifoQueue, PriorityQueue, SimpleQueue (extra14)
#
# queue_extra4 covers __module__ for all 6 classes. Re-anchored here in the
# extra14 namespace as standalone invariants. The key distinction: Queue,
# LifoQueue, and PriorityQueue are pure-Python (__module__ == 'queue'), while
# SimpleQueue is a C extension type (__module__ == '_queue').
# Under python_module(queue), e.g. Queue.__module__.__eq__ accesses the class
# attribute on the queue module.
# ---------------------------------------------------------------------------

invariant queue_extra14.Queue.module:
  description: "queue.Queue.__module__ == 'queue' — pure-Python class defined in Lib/queue.py (extra14 anchor)"
  category: class_module
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["queue"]
  expected: true

invariant queue_extra14.LifoQueue.module:
  description: "queue.LifoQueue.__module__ == 'queue' — pure-Python subclass of Queue (extra14 anchor)"
  category: class_module
  kind: python_call_eq
  function: LifoQueue.__module__.__eq__
  args: ["queue"]
  expected: true

invariant queue_extra14.PriorityQueue.module:
  description: "queue.PriorityQueue.__module__ == 'queue' — pure-Python subclass of Queue (extra14 anchor)"
  category: class_module
  kind: python_call_eq
  function: PriorityQueue.__module__.__eq__
  args: ["queue"]
  expected: true

invariant queue_extra14.SimpleQueue.module:
  description: "queue.SimpleQueue.__module__ == '_queue' — C extension type from _queue (extra14 anchor)"
  category: class_module
  kind: python_call_eq
  function: SimpleQueue.__module__.__eq__
  args: ["_queue"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for Queue, LifoQueue, PriorityQueue (extra14)
#
# queue_extra4 covers __bases__ for these classes. Re-anchored here in the
# extra14 namespace. Queue.__bases__[0].__name__ == 'object' (inherits from
# object directly). LifoQueue and PriorityQueue both subclass Queue, so their
# __bases__[0].__name__ == 'Queue'. The function values contain '[', so they
# must be quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant queue_extra14.Queue.bases_name:
  description: "queue.Queue.__bases__[0].__name__ == 'object' — Queue inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant queue_extra14.LifoQueue.bases_name:
  description: "queue.LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue subclasses Queue"
  category: class_identity
  kind: python_call_eq
  function: "LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant queue_extra14.PriorityQueue.bases_name:
  description: "queue.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue subclasses Queue"
  category: class_identity
  kind: python_call_eq
  function: "PriorityQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

# ---------------------------------------------------------------------------
# queue.Empty — qualname, module, and base class (extra14 namespace)
#
# queue_extra9 covers Empty.__qualname__.__eq__ as a standalone invariant.
# queue_extra4 covers Empty.__module__ and Empty.__bases__. Re-anchored here
# in extra14 with the additional observation that Empty is defined in the C
# extension _queue (not in Lib/queue.py), making its __module__ == '_queue'.
# empty.__bases__[0].__name__ == 'Exception'; len('Exception') == 9.
# ---------------------------------------------------------------------------

invariant queue_extra14.Empty.qualname:
  description: "queue.Empty.__qualname__ == 'Empty' — top-level exception class; qualname equals simple name (extra14)"
  category: class_qualname
  kind: python_call_eq
  function: Empty.__qualname__.__eq__
  args: ["Empty"]
  expected: true

invariant queue_extra14.Empty.module:
  description: "queue.Empty.__module__ == '_queue' — Empty is defined in the C extension _queue (extra14)"
  category: class_module
  kind: python_call_eq
  function: Empty.__module__.__eq__
  args: ["_queue"]
  expected: true

invariant queue_extra14.Empty.bases_name:
  description: "queue.Empty.__bases__[0].__name__ == 'Exception' — Empty inherits from Exception"
  category: class_identity
  kind: python_call_eq
  function: "Empty.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant queue_extra14.Empty.bases_name_len:
  description: "queue.Empty.__bases__[0].__name__.__len__() == 9 — len('Exception') == 9"
  category: class_identity
  kind: python_call_eq
  function: "Empty.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# queue.Full — qualname, module, and base class (extra14 namespace)
#
# queue_extra9 covers Full.__qualname__.__eq__. queue_extra4 covers
# Full.__module__ and Full.__bases__. Re-anchored here in extra14.
# Unlike Empty, Full is defined in Lib/queue.py, so __module__ == 'queue'.
# Full.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

invariant queue_extra14.Full.qualname:
  description: "queue.Full.__qualname__ == 'Full' — top-level exception class; qualname equals simple name (extra14)"
  category: class_qualname
  kind: python_call_eq
  function: Full.__qualname__.__eq__
  args: ["Full"]
  expected: true

invariant queue_extra14.Full.module:
  description: "queue.Full.__module__ == 'queue' — Full is defined in Lib/queue.py (extra14)"
  category: class_module
  kind: python_call_eq
  function: Full.__module__.__eq__
  args: ["queue"]
  expected: true

invariant queue_extra14.Full.bases_name:
  description: "queue.Full.__bases__[0].__name__ == 'Exception' — Full inherits from Exception"
  category: class_identity
  kind: python_call_eq
  function: "Full.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated __module__.__eq__ table for all 4 queue classes (extra14)
#
# Groups all 4 class __module__.__eq__ checks in one table, highlighting the
# C-vs-Python distinction: Queue/LifoQueue/PriorityQueue are pure-Python
# ('queue'); SimpleQueue is a C extension ('_queue'). id_prefix qcmod14 does
# not conflict with any prior queue spec.
# ---------------------------------------------------------------------------

table queue_extra14.class_modules:
  description: "__module__.__eq__ for Queue/LifoQueue/PriorityQueue (pure-Python) and SimpleQueue (C extension)"
  kind: python_call_eq
  category: class_module
  id_prefix: qcmod14

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__module__.__eq__,         ["queue"],  true]
    - [LifoQueue,     LifoQueue.__module__.__eq__,     ["queue"],  true]
    - [PriorityQueue, PriorityQueue.__module__.__eq__, ["queue"],  true]
    - [SimpleQueue,   SimpleQueue.__module__.__eq__,   ["_queue"], true]
