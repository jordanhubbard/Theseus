spec: functools_extra571
version: ">=3.9"
backend: python_module(functools)
docs: "Behavioral spec for functools.cached_property descriptor protocol identity and functools object class names"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers cached_property descriptor method qualnames and class name identity of top-level functools objects"
  created_at: "2026-04-12T00:00:00Z"

table functools_extra571.descriptor_qualnames:
  description: "Verify __qualname__ of cached_property descriptor methods"
  kind: python_call_eq
  category: descriptor_protocol
  id_prefix: FEXT571
  columns: [id, function, args, expected]
  rows:
    - [FEXT571001, functools.cached_property.__get__.__qualname__.__eq__, ["cached_property.__get__"], true]
    - [FEXT571002, functools.cached_property.__set__.__qualname__.__eq__, ["cached_property.__set__"], true]
    - [FEXT571003, functools.cached_property.__set_name__.__qualname__.__eq__, ["cached_property.__set_name__"], true]
    - [FEXT571004, functools.cached_property.__init__.__qualname__.__eq__, ["cached_property.__init__"], true]
table functools_extra571.doc_class:
  description: "Verify __doc__ attribute class name of cached_property"
  kind: python_call_eq
  category: descriptor_protocol
  id_prefix: FEXT571
  columns: [id, function, args, expected]
  rows:
    - [FEXT571005, functools.cached_property.__doc__.__class__.__name__.__eq__, ["str"], true]
table functools_extra571.object_class_names:
  description: "Verify __class__.__name__ of top-level functools objects"
  kind: python_call_eq
  category: class_identity
  id_prefix: FEXT571
  columns: [id, function, args, expected]
  rows:
    - [FEXT571006, functools.partial.__class__.__name__.__eq__, ["type"], true]
    - [FEXT571007, functools.cached_property.__class__.__name__.__eq__, ["type"], true]
    - [FEXT571008, functools.singledispatch.__class__.__name__.__eq__, ["function"], true]
    - [FEXT571009, functools.lru_cache.__class__.__name__.__eq__, ["function"], true]
    - [FEXT571010, functools.total_ordering.__class__.__name__.__eq__, ["function"], true]
    - [FEXT571011, functools.reduce.__class__.__name__.__eq__, ["builtin_function_or_method"], true]