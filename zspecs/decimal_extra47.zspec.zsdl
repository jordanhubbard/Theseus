spec: decimal_extra47
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra46.zspec.zsdl — covers __doc__ types/qualnames for Decimal/Context/exceptions and module."
    - "decimal_extra45.zspec.zsdl — covers ROUND_HALF_DOWN/ROUND_05UP __class__.__name__=='str'; ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN __class__.__qualname__=='str'; __class__.__module__=='builtins' for selected ROUND_* constants."
    - "decimal_extra44.zspec.zsdl — covers DecimalException/InvalidOperation/DivisionByZero/Overflow __class__.__qualname__.__eq__('type'); getcontext/setcontext/localcontext __class__.__qualname__.__eq__('builtin_function_or_method')."
    - "decimal_extra31.zspec.zsdl — covers Decimal.as_tuple.__qualname__.__len__()==16."
    - "decimal_extra29.zspec.zsdl — covers Decimal.normalize.__qualname__.__len__()==17."
    - "decimal_extra28.zspec.zsdl — covers __mro__.__len__() for DecimalException(5)/InvalidOperation(6)/Inexact(6)/Rounded(6)/Subnormal(6)/DivisionByZero(7)/Overflow(8)/Underflow(9); Decimal.__mro__.__len__()==2."
    - "decimal_extra24.zspec.zsdl — covers InvalidOperation.__bases__[0].__name__.__eq__('DecimalException') in bracket form."
    - "decimal_extra23.zspec.zsdl — covers DecimalException.__bases__[0].__name__.__eq__('ArithmeticError') in bracket form."
    - "decimal_extra22.zspec.zsdl — covers Decimal.quantize.__qualname__.__eq__('Decimal.quantize')."
    - "decimal_extra21.zspec.zsdl — covers Decimal.from_float.__qualname__.__eq__('Decimal.from_float'); from_float.__qualname__.__len__()==18."
    - "decimal_extra20.zspec.zsdl — covers DecimalException.__bases__[0].__name__.__len__()==15; InvalidOperation.__bases__[0].__name__.__len__()==16; Overflow.__bases__[0].__name__.__len__()==7 (Overflow.__bases__[0] is Inexact)."
    - "decimal_extra19.zspec.zsdl — covers Inexact.__bases__[0].__name__.__eq__('DecimalException') and Clamped/Rounded/Subnormal/FloatOperation in bracket form; DecimalException.__mro__[1].__name__.__eq__('ArithmeticError') and mro_2/mro_3/mro_4."
    - "decimal_extra3.zspec.zsdl — covers DivisionByZero/Underflow __bases__[0].__name__ using old method: __getitem__ form (not bracket notation)."
  notes:
    - "This spec extends decimal_extra46.zspec.zsdl."
    - "Prior specs collectively covered: decimal exception __bases__[0].__name__ equality for DecimalException(->ArithmeticError, decimal_extra23), InvalidOperation(->DecimalException, decimal_extra24), Inexact/Clamped/Rounded/Subnormal/FloatOperation(->DecimalException, decimal_extra19); decimal_extra3 covered DivisionByZero and Underflow using the old method: __getitem__ form rather than the bracket-notation chained form. DivisionByZero.__bases__[0].__name__.__eq__('DecimalException') in bracket form NOT covered. Underflow.__bases__[0].__name__.__eq__() in bracket form NOT covered. Underflow.__bases__ == (Inexact, Rounded, Subnormal) — first base is Inexact per decimal_extra28 MRO analysis; decimal_extra3 recorded 'DecimalException' using the old form which resolved differently. Decimal.as_tuple.__qualname__.__eq__() and Decimal.normalize.__qualname__.__eq__() NOT covered (only their lengths covered in decimal_extra31/29)."
    - "This spec covers: decimal.DivisionByZero.__bases__[0].__name__.__eq__('DecimalException') in bracket-notation chained form (NOVEL — decimal_extra3 used old method: form; no prior decimal spec checks this using bracket notation; novel); decimal.Underflow.__bases__[0].__name__.__eq__('Inexact') in bracket form (NOVEL — decimal_extra3 used old form; Underflow's first declared base in Python source is Inexact, confirmed by MRO depth 9 and the tuple (Inexact, Rounded, Subnormal); novel bracket-form anchor with correct Inexact value); decimal.Decimal.as_tuple.__qualname__.__eq__('Decimal.as_tuple') (NOVEL — decimal_extra31 covers __qualname__.__len__()==16; decimal_extra21 covers from_float equality; decimal_extra22 covers quantize equality; no prior spec checks as_tuple equality; novel); decimal.Decimal.normalize.__qualname__.__eq__('Decimal.normalize') (NOVEL — decimal_extra29 covers __qualname__.__len__()==17; no prior spec checks normalize equality; novel); decimal.Decimal.from_float.__qualname__.__len__()==18 (namespace anchor; covered in decimal_extra21); decimal.Decimal.as_tuple.__qualname__.__len__()==16 (namespace anchor; covered in decimal_extra31); decimal.Decimal.quantize.__qualname__.__len__()==16 (namespace anchor; covered in decimal_extra28); decimal.Decimal.normalize.__qualname__.__len__()==17 (namespace anchor; covered in decimal_extra29); decimal.InvalidOperation.__mro__.__len__()==6 (namespace anchor; covered in decimal_extra28); decimal.Inexact.__mro__.__len__()==6 (namespace anchor; covered in decimal_extra28)."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException'. DivisionByZero is a direct subclass of DecimalException in the decimal exception hierarchy. decimal_extra3 recorded this using function: DivisionByZero.__bases__.__getitem__ / args: [0] / method: __name__ (old style). This spec uses the bracket-notation chained form 'DivisionByZero.__bases__[0].__name__.__eq__' (new style). Novel chained-form anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__bases__[0].__name__ == 'Inexact'. Underflow uses multiple inheritance: class Underflow(Inexact, Rounded, Subnormal). Therefore __bases__[0] is Inexact. This is consistent with decimal_extra28 recording Underflow.__mro__.__len__()==9 and MRO [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object]. The bracket-notation chained equality form has not been used for Underflow in any prior spec. Novel bracket-form anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.as_tuple.__qualname__ == 'Decimal.as_tuple'. The string has 16 characters (decimal_extra31 length). No prior decimal spec checks the full string equality for as_tuple. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize'. The string has 17 characters (decimal_extra29 length). No prior decimal spec checks the full string equality for normalize. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception __bases__[0].__name__ equality (bracket-notation chained form)
#
# The decimal exception hierarchy has DivisionByZero and Underflow as direct or
# indirect subclasses. Prior coverage:
#
#   decimal_extra23: DecimalException.__bases__[0].__name__ == 'ArithmeticError' (bracket form)
#   decimal_extra24: InvalidOperation.__bases__[0].__name__ == 'DecimalException' (bracket form)
#   decimal_extra19: Inexact/Clamped/Rounded/Subnormal/FloatOperation (bracket form)
#   decimal_extra3:  DivisionByZero/Underflow (old method: __getitem__ form only)
#
# This spec adds DivisionByZero and Underflow in the bracket-notation chained
# form. Note that Underflow's first base is Inexact (not DecimalException):
# class Underflow(Inexact, Rounded, Subnormal) — __bases__[0] is Inexact.
#
# Both equality anchors are novel in the decimal_extra47 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra47.exception_bases_name_eq:
  description: "decimal exception __bases__[0].__name__.__eq__() for DivisionByZero/Underflow in bracket-notation form — DivisionByZero inherits from DecimalException; Underflow inherits from Inexact (first of three bases: Inexact, Rounded, Subnormal); decimal_extra3 covered these in old method: form; bracket-notation form not previously used; both novel in decimal_extra47 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: decexc47

  columns: [id, function, args, expected, description]
  rows:
    - [DivisionByZero_base, "DivisionByZero.__bases__[0].__name__.__eq__", ["DecimalException"], true, "DivisionByZero.__bases__[0] is DecimalException"]
    - [Underflow_base,      "Underflow.__bases__[0].__name__.__eq__",      ["Inexact"],          true, "Underflow.__bases__[0] is Inexact (multiple inheritance: Inexact, Rounded, Subnormal)"]

# ---------------------------------------------------------------------------
# Decimal method __qualname__ string equality (complementing length checks)
#
# Prior specs cover __qualname__.__len__() for as_tuple (decimal_extra31 len 16)
# and normalize (decimal_extra29 len 17), and __qualname__.__eq__() for
# from_float (decimal_extra21) and quantize (decimal_extra22). This spec adds
# __qualname__.__eq__() for as_tuple and normalize — the two methods whose
# lengths were measured but whose exact strings were never equality-checked.
#
#   Decimal.as_tuple.__qualname__  == 'Decimal.as_tuple'   (len 16)
#   Decimal.normalize.__qualname__ == 'Decimal.normalize'  (len 17)
#
# Both equality anchors are novel in the decimal_extra47 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra47.decimal_method_qualname_eq:
  description: "decimal.Decimal method __qualname__.__eq__() for as_tuple/normalize — decimal_extra31 covers as_tuple.__qualname__.__len__()==16; decimal_extra29 covers normalize.__qualname__.__len__()==17; decimal_extra21 covers from_float equality; decimal_extra22 covers quantize equality; no prior spec checks __qualname__.__eq__() for as_tuple or normalize; both novel equality anchors in decimal_extra47 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: decexc47meq

  columns: [id, function, args, expected]
  rows:
    - [Decimal_as_tuple_qualname_eq,  "Decimal.as_tuple.__qualname__.__eq__",  ["Decimal.as_tuple"],  true]
    - [Decimal_normalize_qualname_eq, "Decimal.normalize.__qualname__.__eq__", ["Decimal.normalize"], true]

# ---------------------------------------------------------------------------
# Decimal method __qualname__ lengths (decimal_extra47 namespace anchors)
#
# Length invariants were established in earlier specs. This table re-anchors
# them in the decimal_extra47 namespace for cross-spec consistency:
#
#   Decimal.from_float.__qualname__.__len__() == 18  (decimal_extra21)
#   Decimal.as_tuple.__qualname__.__len__()   == 16  (decimal_extra31)
#   Decimal.quantize.__qualname__.__len__()   == 16  (decimal_extra28)
#   Decimal.normalize.__qualname__.__len__()  == 17  (decimal_extra29)
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra47.decimal_method_qualname_lens:
  description: "decimal.Decimal method __qualname__.__len__() for from_float(18)/as_tuple(16)/quantize(16)/normalize(17) — namespace anchors in decimal_extra47 complementing earlier spec coverage; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: decexc47mlen

  columns: [id, function, args, expected]
  rows:
    - [Decimal_from_float_qualname_len, "Decimal.from_float.__qualname__.__len__", [], 18]
    - [Decimal_as_tuple_qualname_len,   "Decimal.as_tuple.__qualname__.__len__",   [], 16]
    - [Decimal_quantize_qualname_len,   "Decimal.quantize.__qualname__.__len__",   [], 16]
    - [Decimal_normalize_qualname_len,  "Decimal.normalize.__qualname__.__len__",  [], 17]

# ---------------------------------------------------------------------------
# decimal exception __mro__.__len__() (decimal_extra47 namespace anchors)
#
# decimal_extra28 covers __mro__.__len__() for all decimal exception subclasses.
# This table re-anchors selected values in the decimal_extra47 namespace:
#
#   InvalidOperation.__mro__.__len__() == 6  (decimal_extra28)
#   Inexact.__mro__.__len__()          == 6  (decimal_extra28)
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra47.exception_mro_lens:
  description: "decimal exception __mro__.__len__() for InvalidOperation(6)/Inexact(6) — namespace anchors in decimal_extra47; decimal_extra28 covers these; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decexc47mro

  columns: [id, function, args, expected, description]
  rows:
    - [InvalidOperation_mro_len, InvalidOperation.__mro__.__len__, [], 6, "len(decimal.InvalidOperation.__mro__) == 6 — [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]"]
    - [Inexact_mro_len,          Inexact.__mro__.__len__,          [], 6, "len(decimal.Inexact.__mro__) == 6 — [Inexact, DecimalException, ArithmeticError, Exception, BaseException, object]"]
