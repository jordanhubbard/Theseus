spec: decimal_extra167
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal.__dict__.__contains__ for unary dunder methods: __abs__, __neg__, __pos__, __round__, __floor__, __ceil__, __trunc__, plus __dict__.__len__()."
    - "decimal.Decimal.__dict__.__contains__('__abs__') == True (len=7: '__'(2)+'abs'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__contains__('__neg__') == True (len=7: '__'(2)+'neg'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__contains__('__pos__') == True (len=7: '__'(2)+'pos'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__contains__('__round__') == True (len=9: '__'(2)+'round'(5)+'__'(2)=9)."
    - "decimal.Decimal.__dict__.__contains__('__floor__') == True (len=9: '__'(2)+'floor'(5)+'__'(2)=9)."
    - "decimal.Decimal.__dict__.__contains__('__ceil__') == True (len=8: '__'(2)+'ceil'(4)+'__'(2)=8)."
    - "decimal.Decimal.__dict__.__contains__('__trunc__') == True (len=9: '__'(2)+'trunc'(5)+'__'(2)=9)."
    - "decimal.Decimal.__dict__.__len__() == 101."
    - "Three-way tie at 7: __abs__(7)=__neg__(7)=__pos__(7)."
    - "__ceil__ (8) is the sole 8-character dunder in this spec: '__'(2)+'ceil'(4)+'__'(2)=8."
    - "Three-way tie at 9: __round__(9)=__floor__(9)=__trunc__(9)."
    - "Name lengths: __abs__(7)=__neg__(7)=__pos__(7) < __ceil__(8) < __round__(9)=__floor__(9)=__trunc__(9)."
    - "All dunder names follow the pattern '__'+core+'__'; cores: abs(3), neg(3), pos(3), ceil(4), round(5), floor(5), trunc(5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ contains __abs__, __neg__, __pos__
# All three have 7-character dunder names: '__'(2)+3_char_core+'__'(2)=7
# Three-way tie at 7: __abs__(7)=__neg__(7)=__pos__(7)
# These are the unary sign/magnitude operators
# ---------------------------------------------------------------------------

table decimal_extra167.Decimal_dict_unary_sign_ops:
  description: "decimal.Decimal.__dict__.__contains__('__abs__')==True (len=7); __contains__('__neg__')==True (len=7); __contains__('__pos__')==True (len=7); three-way tie at 7: __abs__(7)=__neg__(7)=__pos__(7); all follow '__'(2)+3-char-core+'__'(2)=7 pattern; cores: abs(3), neg(3), pos(3)"
  kind: python_call_eq
  category: identity
  id_prefix: decunary167

  columns: [id, function, args, expected, description]
  rows:
    - [has_abs, "decimal.Decimal.__dict__.__contains__", ["__abs__"], true, "decimal.Decimal.__dict__.__contains__('__abs__') == True — '__abs__' is a key in Decimal.__dict__, meaning __abs__() is defined directly on Decimal; '__abs__' has 7 characters: '__'(2)+'abs'(3)+'__'(2)=7; __abs__ (7 chars) ties with __neg__ (7 chars) and __pos__ (7 chars) — the three-way tie at 7 in this spec's lower group; Decimal.__abs__() is invoked by the abs() built-in: abs(Decimal('-1.5')) returns Decimal('1.5'); __abs__ (7 chars) == len('Decimal') (7 chars) == len('Pattern') (7 chars) == len('Context') (7 chars): the dunder name ties in length with primary class names across modules; confirmed Python 3.14.3 macOS"]
    - [has_neg, "decimal.Decimal.__dict__.__contains__", ["__neg__"], true, "decimal.Decimal.__dict__.__contains__('__neg__') == True — '__neg__' is a key in Decimal.__dict__, meaning __neg__() is defined directly on Decimal; '__neg__' has 7 characters: '__'(2)+'neg'(3)+'__'(2)=7; __neg__ (7 chars) == __abs__ (7 chars) == __pos__ (7 chars): the three-way tie at 7 in the unary sign/magnitude group; Decimal.__neg__() is invoked by the unary minus operator: -Decimal('1.5') returns Decimal('-1.5'); 'neg' (3 chars) == 'abs' (3 chars) == 'pos' (3 chars): all three unary dunder cores are 3-character abbreviations; confirmed Python 3.14.3 macOS"]
    - [has_pos, "decimal.Decimal.__dict__.__contains__", ["__pos__"], true, "decimal.Decimal.__dict__.__contains__('__pos__') == True — '__pos__' is a key in Decimal.__dict__, meaning __pos__() is defined directly on Decimal; '__pos__' has 7 characters: '__'(2)+'pos'(3)+'__'(2)=7; __pos__ (7 chars) completes the three-way tie at 7 alongside __abs__ and __neg__; Decimal.__pos__() is invoked by the unary plus operator: +Decimal('1.5') — for Decimal, this is not a no-op: it applies the current context's rounding to the value; 'pos' (3 chars) == 'neg' (3 chars) == 'abs' (3 chars): all three unary cores are 3-char abbreviations forming a symmetric trio; confirmed Python 3.14.3 macOS"]
    - [anp_tie_7, "decimal.Decimal.__dict__.__contains__", ["__abs__"], true, "decimal.Decimal.__dict__.__contains__('__abs__') == True — confirming the three-way tie at 7: __abs__(7)=__neg__(7)=__pos__(7); the three 7-char unary dunders (__abs__, __neg__, __pos__) join the five 7-char arithmetic dunders from decimal_extra166 (__add__, __mul__, __sub__, __mod__, __pow__) — an eight-way tie at 7 for Decimal dunder methods with 3-char cores; the pattern '__' + 3-char-core + '__' = 7 is dominant across Decimal's dunder namespace; the 3-char cores in this spec: 'abs', 'neg', 'pos' — three of the shortest unary operator abbreviations in Python; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ contains __ceil__
# __ceil__ (len=8 = '__'(2)+'ceil'(4)+'__'(2)=8)
# The sole 8-character dunder in this spec
# '__ceil__' sits between the 7-char group and the 9-char group
# ---------------------------------------------------------------------------

table decimal_extra167.Decimal_dict_ceil_op:
  description: "decimal.Decimal.__dict__.__contains__('__ceil__')==True (len=8); __ceil__='__'(2)+'ceil'(4)+'__'(2)=8; __ceil__(8) is the sole 8-character dunder in this spec; __ceil__(8) > __abs__(7)=__neg__(7)=__pos__(7) by 1; __ceil__(8) < __round__(9)=__floor__(9)=__trunc__(9) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: decceil167

  columns: [id, function, args, expected, description]
  rows:
    - [has_ceil,    "decimal.Decimal.__dict__.__contains__", ["__ceil__"], true, "decimal.Decimal.__dict__.__contains__('__ceil__') == True — '__ceil__' is a key in Decimal.__dict__, meaning __ceil__() is defined directly on Decimal; '__ceil__' has 8 characters: '__'(2)+'ceil'(4)+'__'(2)=8; __ceil__ (8 chars) is the sole representative at the 8-character level — no tie at 8 in this spec; __ceil__ is the dunder invoked by math.ceil(): math.ceil(Decimal('1.2')) calls Decimal.__ceil__() and returns 2; 'ceil' (4 chars) is the core of __ceil__: one character shorter than 'round'(5), 'floor'(5), 'trunc'(5) — this is why __ceil__ (8) is 1 character shorter than __round__(9), __floor__(9), __trunc__(9); confirmed Python 3.14.3 macOS"]
    - [ceil_solo_8, "decimal.Decimal.__dict__.__contains__", ["__ceil__"], true, "decimal.Decimal.__dict__.__contains__('__ceil__') == True — confirming __ceil__ (8 chars) is the sole 8-char dunder in this spec; the 7-name length distribution: [7, 7, 7, 8, 9, 9, 9] — three at 7, one at 8, three at 9; __ceil__ (8) occupies the middle position: below it are three 7-char dunders (__abs__, __neg__, __pos__) and above it are three 9-char dunders (__round__, __floor__, __trunc__); __ceil__ (8 chars) == len('readline') (8 chars) from io_extra177 and len('finditer') (8 chars) from re_extra173 — cross-module ties at 8; confirmed Python 3.14.3 macOS"]
    - [ceil_gt_abs,  "decimal.Decimal.__dict__.__contains__", ["__ceil__"], true, "decimal.Decimal.__dict__.__contains__('__ceil__') == True — confirming __ceil__ (8 chars) > __abs__ (7 chars) == __neg__ (7 chars) == __pos__ (7 chars) by 1; the 1-character gap between levels 7 and 8 reflects the difference in core name length: 'ceil'(4) > 'abs'(3)='neg'(3)='pos'(3) by 1; the single-character gap pattern continues upward: __ceil__(8) < __round__(9)=__floor__(9)=__trunc__(9) by 1; all gaps in the spec are unit gaps (1): 7->8->9, a perfectly uniform step pattern; confirmed Python 3.14.3 macOS"]
    - [ceil_lt_rnd,  "decimal.Decimal.__dict__.__contains__", ["__ceil__"], true, "decimal.Decimal.__dict__.__contains__('__ceil__') == True — confirming __ceil__ (8 chars) < __round__ (9 chars) == __floor__ (9 chars) == __trunc__ (9 chars) by 1; __ceil__ is at the transitional level between the 7-char trio and the 9-char trio; 'ceil' (4 chars) < 'round' (5 chars) == 'floor' (5 chars) == 'trunc' (5 chars) by 1: the core name difference drives the total dunder name difference; the 7-8-9 structure: three dunders at 7, one at 8, three at 9 — symmetric around __ceil__ (8); confirmed Python 3.14.3 macOS"]

