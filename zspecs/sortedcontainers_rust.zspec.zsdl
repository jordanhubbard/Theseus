spec: sortedcontainers_rust
version: ">=3.9"
backend: rust_module(sortedcontainers_rust)

docs: http://www.grantjenks.com/docs/sortedcontainers/

provenance:
  derived_from:
    - "http://www.grantjenks.com/docs/sortedcontainers/ — sortedcontainers documentation"
  not_derived_from:
    - "sortedcontainers source: sortedcontainers/sortedlist.py"
  notes:
    - "sortedcontainers provides SortedList, SortedDict, and SortedSet."
    - "SortedList maintains sorted order after add/remove."
    - "SortedList([3, 1, 2]) == [1, 2, 3] when iterated."
    - "SortedList.add(4) inserts in sorted position."
    - "Expose sorted_list(lst) -> list: list(SortedList(lst)) — list in sorted order."
    - "Expose sorted_list_len(lst) -> int: len(SortedList(lst))."
    - "Expose sorted_list_min(lst) -> any: SortedList(lst)[0]."
    - "Expose sorted_list_max(lst) -> any: SortedList(lst)[-1]."
    - "Expose sorted_list_contains(lst, val) -> bool: val in SortedList(lst)."
    - "SortedList([3, 1, 2]) iterates as [1, 2, 3]."
    - "All test vectors verified against sortedcontainers 2.4.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# sorted_list — sorted order
table sortedcontainers_rust.sortedlist.order:
  kind: python_call_eq
  category: order
  id_prefix: sc_ord
  function: sorted_list

  columns: [id, args, expected]
  rows:
    - [reverse,  [[3, 1, 2]],     [1, 2, 3]]
    - [already,  [[1, 2, 3]],     [1, 2, 3]]
    - [dupes,    [[3, 1, 2, 1]], [1, 1, 2, 3]]
    - [single,   [[5]],           [5]]
    - [empty,    [[]],            []]

# sorted_list_min/max — boundary access
table sortedcontainers_rust.sortedlist.bounds:
  kind: python_call_eq
  category: bounds
  id_prefix: sc_bnds
  function: sorted_list_min

  columns: [id, args, expected]
  rows:
    - [min_of_3, [[3, 1, 2]], 1]

invariant sortedcontainers_rust.sortedlist.max:
  description: "SortedList([3,1,2])[-1] == 3"
  category: bounds
  kind: python_call_eq
  function: sorted_list_max
  args: [[3, 1, 2]]
  expected: 3

# sorted_list_contains — membership
table sortedcontainers_rust.sortedlist.contains:
  kind: python_call_eq
  category: contains
  id_prefix: sc_has
  function: sorted_list_contains

  columns: [id, args, expected]
  rows:
    - [has_2,    [[1, 2, 3], 2], true]
    - [no_4,    [[1, 2, 3], 4], false]
    - [empty,   [[], 1],        false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:21:12Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
