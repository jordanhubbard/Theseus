spec: decimal_extra98
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra97

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra97.zspec.zsdl."
    - "This spec covers: decimal module __name__, __package__, __spec__ attrs and key class/constant identity."
    - "decimal.__package__ == '' (decimal is a simple module, not a package; __package__ is empty string)."
    - "decimal.__spec__.__class__.__name__ == 'ModuleSpec' (length 10)."
    - "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' (decimal is a regular Python source file)."
    - "decimal.__spec__.has_location == True (decimal has an on-disk source file)."
    - "decimal.Decimal.__module__ == 'decimal' (length 7); same for Context, DecimalException, InvalidOperation."
    - "decimal.Overflow.__module__ == 'decimal', decimal.DivisionByZero.__module__ == 'decimal'."
    - "decimal.ROUND_UP.__class__.__name__ == 'str' (rounding mode constants are plain Python strings)."
    - "decimal.ROUND_DOWN.__class__.__name__ == 'str' (same type as ROUND_UP)."
    - "decimal.MAX_PREC.__class__.__name__ == 'int' (numeric limits are Python ints)."
    - "decimal.MAX_EMAX.__class__.__name__ == 'int', decimal.MIN_EMIN.__class__.__name__ == 'int'."
    - "decimal.Decimal.__name__ == 'Decimal' (length 7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module identity: __name__, __package__, __spec__ attributes
# decimal is a source file module (not a package), so __package__ == ''.
# __loader__.__class__.__name__ == 'SourceFileLoader'.
# ---------------------------------------------------------------------------

table decimal_extra98.module_identity:
  description: "decimal module identity: __name__ ('decimal', len 7), __package__ ('', empty), __spec__.__class__.__name__ ('ModuleSpec'), __spec__.name ('decimal')"
  kind: python_call_eq
  category: module_identity
  id_prefix: decmodid98

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,                    ["decimal"],       true,  "decimal.__name__ == 'decimal'"]
    - [name_len,       __name__.__len__,                   [],                7,     "decimal.__name__.__len__() == 7 ('decimal' has 7 characters)"]
    - [pkg_eq,         __package__.__eq__,                 [""],              true,  "decimal.__package__ == '' (decimal is a simple module, not a package)"]
    - [pkg_not_dec,    __package__.__eq__,                 ["decimal"],       false, "decimal.__package__ != 'decimal' (decimal is not a package; __package__ is empty string)"]
    - [spec_cls_name,  __spec__.__class__.__name__.__eq__, ["ModuleSpec"],    true,  "decimal.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_name_eq,   __spec__.name.__eq__,               ["decimal"],       true,  "decimal.__spec__.name == 'decimal'"]
    - [spec_name_len,  __spec__.name.__len__,              [],                7,     "decimal.__spec__.name.__len__() == 7 ('decimal' has 7 characters)"]
    - [loader_cls,     __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' (decimal is a regular Python source file)"]

# ---------------------------------------------------------------------------
# decimal module __spec__ source-file attributes
# has_location is True. __spec__.__class__.__name__.__len__() == 10.
# ---------------------------------------------------------------------------

table decimal_extra98.spec_source_attrs:
  description: "decimal.__spec__ source-module attributes: has_location (True), __spec__.__class__.__name__.__len__() (10)"
  kind: python_call_eq
  category: module_identity
  id_prefix: decmodid98

  columns: [id, function, args, expected, description]
  rows:
    - [has_loc_true,  __spec__.has_location.__eq__,            [true],  true, "decimal.__spec__.has_location == True (decimal has an on-disk source file)"]
    - [spec_cls_len,  __spec__.__class__.__name__.__len__,     [],      10,   "decimal.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec' has 10 characters)"]
    - [name_len_7,    __name__.__len__,                        [],      7,    "decimal.__name__.__len__() == 7 ('decimal' has 7 characters)"]

# ---------------------------------------------------------------------------
# decimal class __module__ values
# Decimal, Context, DecimalException, InvalidOperation, Overflow,
# DivisionByZero, Underflow, Inexact all have __module__ == 'decimal' (len 7).
# ---------------------------------------------------------------------------

table decimal_extra98.class_module_values:
  description: "decimal class __module__ == 'decimal' (length 7) for Decimal, Context, DecimalException, InvalidOperation, Overflow, DivisionByZero"
  kind: python_call_eq
  category: class_identity
  id_prefix: decmodid98

  columns: [id, function, args, expected, description]
  rows:
    - [dec_mod_eq,   Decimal.__module__.__eq__,          ["decimal"], true, "decimal.Decimal.__module__ == 'decimal'"]
    - [dec_mod_len,  Decimal.__module__.__len__,         [],          7,    "decimal.Decimal.__module__.__len__() == 7 ('decimal' has 7 characters)"]
    - [ctx_mod_eq,   Context.__module__.__eq__,          ["decimal"], true, "decimal.Context.__module__ == 'decimal'"]
    - [ctx_mod_len,  Context.__module__.__len__,         [],          7,    "decimal.Context.__module__.__len__() == 7 ('decimal' has 7 characters)"]
    - [de_mod_eq,    DecimalException.__module__.__eq__, ["decimal"], true, "decimal.DecimalException.__module__ == 'decimal'"]
    - [io_mod_eq,    InvalidOperation.__module__.__eq__, ["decimal"], true, "decimal.InvalidOperation.__module__ == 'decimal'"]
    - [ov_mod_eq,    Overflow.__module__.__eq__,         ["decimal"], true, "decimal.Overflow.__module__ == 'decimal'"]
    - [dbz_mod_eq,   DivisionByZero.__module__.__eq__,   ["decimal"], true, "decimal.DivisionByZero.__module__ == 'decimal'"]

# ---------------------------------------------------------------------------
# decimal Decimal.__name__ and constant type classes
# Decimal.__name__ == 'Decimal' (length 7).
# ROUND_UP/ROUND_DOWN are str constants; MAX_PREC/MAX_EMAX/MIN_EMIN are ints.
# ---------------------------------------------------------------------------

table decimal_extra98.names_and_constant_types:
  description: "decimal.Decimal.__name__ ('Decimal', len 7); ROUND_UP/ROUND_DOWN are str; MAX_PREC/MAX_EMAX/MIN_EMIN are int"
  kind: python_call_eq
  category: class_identity
  id_prefix: decmodid98

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name_eq,    Decimal.__name__.__eq__,                   ["Decimal"], true, "decimal.Decimal.__name__ == 'Decimal'"]
    - [dec_name_len,   Decimal.__name__.__len__,                  [],          7,    "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters)"]
    - [rup_cls,        ROUND_UP.__class__.__name__.__eq__,        ["str"],     true, "decimal.ROUND_UP.__class__.__name__ == 'str' (rounding mode constants are plain Python strings)"]
    - [rdown_cls,      ROUND_DOWN.__class__.__name__.__eq__,      ["str"],     true, "decimal.ROUND_DOWN.__class__.__name__ == 'str' (same type as ROUND_UP)"]
    - [maxprec_cls,    MAX_PREC.__class__.__name__.__eq__,        ["int"],     true, "decimal.MAX_PREC.__class__.__name__ == 'int' (numeric limit constants are Python ints)"]
    - [maxemax_cls,    MAX_EMAX.__class__.__name__.__eq__,        ["int"],     true, "decimal.MAX_EMAX.__class__.__name__ == 'int'"]
    - [minemin_cls,    MIN_EMIN.__class__.__name__.__eq__,        ["int"],     true, "decimal.MIN_EMIN.__class__.__name__ == 'int'"]
    - [rup_not_int,    ROUND_UP.__class__.__name__.__eq__,        ["int"],     false, "decimal.ROUND_UP.__class__.__name__ != 'int' (rounding constants are strings, not ints)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra98.module_name_is_decimal:
  description: "decimal.__name__ == 'decimal' (the public module name is 'decimal', length 7)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra98.package_is_empty:
  description: "decimal.__package__ == '' (decimal is a simple module, not a package; __package__ is empty string, unlike 're' or 'pathlib' which are packages)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra98.spec_has_location_true:
  description: "decimal.__spec__.has_location == True (decimal has an on-disk source file at Lib/decimal.py)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant decimal_extra98.Decimal_module_len_7:
  description: "decimal.Decimal.__module__.__len__() == 7 ('decimal' has 7 characters; all public decimal classes share this __module__ value)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__len__
  args: []
  expected: 7

invariant decimal_extra98.ROUND_UP_is_str:
  description: "decimal.ROUND_UP.__class__.__name__ == 'str' (the decimal rounding mode constants are plain Python string values, not enum members or ints)"
  category: class_identity
  kind: python_call_eq
  function: ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true
