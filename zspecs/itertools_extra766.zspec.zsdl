spec: itertools_extra766
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Modules/itertoolsmodule.c"
    - "cpython/Lib/itertools.py"
  not_derived_from:
    - "any third-party itertools extension"
  notes:
    - "Covers __module__ identity for all built-in itertools iterator types"
    - "All itertools types have __module__ == 'itertools' in CPython >=3.9"
  created_at: "2026-04-12"

table itertools_extra766.name:
  description: "itertools iterator __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: it766xx
  columns: [id, function, args, expected]
  rows:
    - [it766xx001, itertools.chain.__module__.__eq__, ["itertools"], true]
    - [it766xx002, itertools.product.__module__.__eq__, ["itertools"], true]
    - [it766xx003, itertools.combinations.__module__.__eq__, ["itertools"], true]
    - [it766xx004, itertools.permutations.__module__.__eq__, ["itertools"], true]
    - [it766xx005, itertools.combinations_with_replacement.__module__.__eq__, ["itertools"], true]
    - [it766xx006, itertools.accumulate.__module__.__eq__, ["itertools"], true]
    - [it766xx007, itertools.groupby.__module__.__eq__, ["itertools"], true]
    - [it766xx008, itertools.islice.__module__.__eq__, ["itertools"], true]
    - [it766xx009, itertools.compress.__module__.__eq__, ["itertools"], true]
    - [it766xx010, itertools.filterfalse.__module__.__eq__, ["itertools"], true]
    - [it766xx011, itertools.count.__module__.__eq__, ["itertools"], true]
    - [it766xx012, itertools.cycle.__module__.__eq__, ["itertools"], true]
