spec: theseus_string_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_string_cr2)
blocks: string

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html"
    - "PEP 3101 — Advanced String Formatting"
  notes:
    - "Clean-room extended string utilities. Do NOT import string."
    - "Formatter class: advanced string formatting with format() and vformat() methods."
    - "Template class: string substitution with $ placeholders."
    - "capwords(s, sep=None): split, capitalize each word, join."
    - "string2_formatter_basic(): Formatter().format('hello {}', 'world') == 'hello world'."
    - "string2_template_safe(): Template('$x is $y').safe_substitute(x='hi') == 'hi is $y'."
    - "string2_capwords(): capwords('hello world') == 'Hello World'."
    - "Zero-arg invariant signatures — def string2_formatter_basic(): return hardcoded_result"
    - "Formatter.format uses {} positional and {name} keyword placeholders."
    - "Template uses $identifier or ${identifier} syntax; safe_substitute leaves missing vars."
    - "Export: Formatter, Template, capwords(s), ascii_letters, digits, punctuation."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_string_cr2.formatter_basic:
  description: "Formatter().format('hello {}', 'world') == 'hello world'"
  category: formatter
  kind: python_call_eq
  function: string2_formatter_basic
  args: []
  expected: "hello world"

invariant theseus_string_cr2.template_safe:
  description: "Template('$x is $y').safe_substitute(x='hi') == 'hi is $y'"
  category: template
  kind: python_call_eq
  function: string2_template_safe
  args: []
  expected: "hi is $y"

invariant theseus_string_cr2.capwords:
  description: "capwords('hello world') == 'Hello World'"
  category: capwords
  kind: python_call_eq
  function: string2_capwords
  args: []
  expected: "Hello World"
