spec: plistlib_extra3
version: ">=3.9"
backend: python_module(plistlib)

docs: https://docs.python.org/3/library/plistlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/plistlib.html — Python plistlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/plistlib.py"
  notes:
    - "This spec extends plistlib.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FMT_XML.__class__.__name__ — already in plistlib_extra; here we add via
# __eq__ method form as documented in the task specification
# (This is a distinct invariant ID in a new spec so it is not a duplicate)
# ---------------------------------------------------------------------------

invariant plistlib_extra3.FMT_XML.class_name:
  description: "plistlib.FMT_XML.__class__.__name__ == 'PlistFormat'"
  category: formats
  kind: python_call_eq
  function: FMT_XML.__class__.__name__.__eq__
  args: ["PlistFormat"]
  expected: true

invariant plistlib_extra3.FMT_BINARY.class_name:
  description: "plistlib.FMT_BINARY.__class__.__name__ == 'PlistFormat'"
  category: formats
  kind: python_call_eq
  function: FMT_BINARY.__class__.__name__.__eq__
  args: ["PlistFormat"]
  expected: true

# ---------------------------------------------------------------------------
# PlistFormat base class — IntEnum inherits from int (new: bases inspection)
# (prior specs check FMT_XML MRO[1].__name__ == 'int'; this checks __bases__)
# ---------------------------------------------------------------------------

invariant plistlib_extra3.PlistFormat.bases_len:
  description: "len(plistlib.PlistFormat.__bases__) >= 1 — PlistFormat has at least one base class"
  category: class_hierarchy
  kind: python_call_eq
  function: PlistFormat.__bases__.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# InvalidFileException — bases length (new; prior specs check __bases__[0].__name__)
# ---------------------------------------------------------------------------

invariant plistlib_extra3.InvalidFileException.bases_len:
  description: "len(plistlib.InvalidFileException.__bases__) == 1 — single direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: InvalidFileException.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# load and dump — __qualname__ (new; prior specs only check __name__ and __module__)
# ---------------------------------------------------------------------------

invariant plistlib_extra3.load.qualname:
  description: "plistlib.load.__qualname__ == 'load'"
  category: function_names
  kind: python_call_eq
  function: load.__qualname__.__eq__
  args: ["load"]
  expected: true

invariant plistlib_extra3.dump.qualname:
  description: "plistlib.dump.__qualname__ == 'dump'"
  category: function_names
  kind: python_call_eq
  function: dump.__qualname__.__eq__
  args: ["dump"]
  expected: true

invariant plistlib_extra3.loads.qualname:
  description: "plistlib.loads.__qualname__ == 'loads'"
  category: function_names
  kind: python_call_eq
  function: loads.__qualname__.__eq__
  args: ["loads"]
  expected: true

invariant plistlib_extra3.dumps.qualname:
  description: "plistlib.dumps.__qualname__ == 'dumps'"
  category: function_names
  kind: python_call_eq
  function: dumps.__qualname__.__eq__
  args: ["dumps"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __qualname__ for all four I/O functions in one place
# ---------------------------------------------------------------------------

table plistlib_extra3.function_qualnames:
  kind: python_call_eq
  category: function_names
  id_prefix: qn

  columns: [id, function, args, expected, description]
  rows:
    - [load,  load.__qualname__.__eq__,  ["load"],  true, "plistlib.load.__qualname__ == 'load'"]
    - [loads, loads.__qualname__.__eq__, ["loads"], true, "plistlib.loads.__qualname__ == 'loads'"]
    - [dump,  dump.__qualname__.__eq__,  ["dump"],  true, "plistlib.dump.__qualname__ == 'dump'"]
    - [dumps, dumps.__qualname__.__eq__, ["dumps"], true, "plistlib.dumps.__qualname__ == 'dumps'"]

# ---------------------------------------------------------------------------
# InvalidFileException.__name__ and __bases__[0].__name__ — sanity cross-ref
# (per task spec; prior specs cover these but in different spec files)
# ---------------------------------------------------------------------------

invariant plistlib_extra3.InvalidFileException.name:
  description: "plistlib.InvalidFileException.__name__ == 'InvalidFileException'"
  category: class_names
  kind: python_call_eq
  function: InvalidFileException.__name__.__eq__
  args: ["InvalidFileException"]
  expected: true

invariant plistlib_extra3.InvalidFileException.base_is_ValueError:
  description: "plistlib.InvalidFileException.__bases__[0].__name__ == 'ValueError'"
  category: class_hierarchy
  kind: python_call_eq
  function: InvalidFileException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# PlistFormat.__name__ cross-ref (task spec requests this; different spec ID)
# ---------------------------------------------------------------------------

invariant plistlib_extra3.PlistFormat.name:
  description: "plistlib.PlistFormat.__name__ == 'PlistFormat'"
  category: class_names
  kind: python_call_eq
  function: PlistFormat.__name__.__eq__
  args: ["PlistFormat"]
  expected: true

# ---------------------------------------------------------------------------
# load and dump __name__ cross-ref (task spec requests these; different spec ID)
# ---------------------------------------------------------------------------

invariant plistlib_extra3.load.name:
  description: "plistlib.load.__name__ == 'load'"
  category: function_names
  kind: python_call_eq
  function: load.__name__.__eq__
  args: ["load"]
  expected: true

invariant plistlib_extra3.dump.name:
  description: "plistlib.dump.__name__ == 'dump'"
  category: function_names
  kind: python_call_eq
  function: dump.__name__.__eq__
  args: ["dump"]
  expected: true
