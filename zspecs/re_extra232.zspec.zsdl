spec: re_extra232
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.error/re.PatternError, re.Match, re.Pattern identity contracts — __name__, __module__, and base class contracts."
    - "re.error is re.PatternError — both names refer to the same class in Python 3.13+; verified Python 3.14.3 macOS."
    - "re.error.__name__ == 'PatternError' — the canonical name in Python 3.13+ is PatternError; verified Python 3.14.3 macOS."
    - "re.error.__module__ == 're' — PatternError is defined in the 're' public module; verified Python 3.14.3 macOS."
    - "re.error.__bases__[0].__name__ == 'Exception' — PatternError inherits from Exception; verified Python 3.14.3 macOS."
    - "re.Match.__name__ == 'Match' — the match object class name; verified Python 3.14.3 macOS."
    - "re.Match.__module__ == 're' — Match is reported as belonging to 're'; verified Python 3.14.3 macOS."
    - "re.Pattern.__name__ == 'Pattern' — the compiled pattern class name; verified Python 3.14.3 macOS."
    - "re.Pattern.__module__ == 're' — Pattern is reported as belonging to 're'; verified Python 3.14.3 macOS."
    - "type(re.match('a','a')).__name__ == 'Match' — live match object confirms type name; verified Python 3.14.3 macOS."
    - "type(re.compile('a')).__name__ == 'Pattern' — live compiled pattern confirms type name; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error / re.PatternError identity contracts
# In Python 3.13+ re.error is aliased to re.PatternError.
# __name__ == 'PatternError', __module__ == 're', base is Exception.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra232.error.name:
  description: "re.error.__name__ == 'PatternError' — in Python 3.13+, re.error is re.PatternError; name is 'PatternError'; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra232.error.name_length:
  description: "re.error.__name__.__len__() == 12 — 'PatternError' has 12 characters; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 12

invariant re_extra232.error.module:
  description: "re.error.__module__ == 're' — PatternError is defined in the public 're' module; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra232.error.base_exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' — PatternError inherits directly from Exception; verified Python 3.14.3 macOS"
  category: hierarchy
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# re.Match identity contracts
# __name__ == 'Match', __module__ == 're'.
# Live match object from re.match() has the same type name.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra232.Match.name:
  description: "re.Match.__name__ == 'Match' — compiled match object class name is 'Match'; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra232.Match.name_length:
  description: "re.Match.__name__.__len__() == 5 — 'Match' has 5 characters; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.__name__.__len__
  args: []
  expected: 5

invariant re_extra232.Match.module:
  description: "re.Match.__module__ == 're' — Match is reported as belonging to the public 're' module; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.Pattern identity contracts
# __name__ == 'Pattern', __module__ == 're'.
# Live compiled pattern from re.compile() has the same type name.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra232.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern' — compiled regex class name is 'Pattern'; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra232.Pattern.name_length:
  description: "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__len__
  args: []
  expected: 7

invariant re_extra232.Pattern.module:
  description: "re.Pattern.__module__ == 're' — Pattern is reported as belonging to the public 're' module; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true
