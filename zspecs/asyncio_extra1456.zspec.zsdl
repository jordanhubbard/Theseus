spec: asyncio_extra1456
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/, Modules/_asynciomodule.c"
    - "asyncio_extra1441.zspec.zsdl — covers __subclasshook__ and __instancecheck__ for asyncio classes"
  notes:
    - "Wave 544 (_extra1456): focuses on __contains__, __iter__, and __next__ method presence and type checks for asyncio classes."
    - "asyncio.Task defines __iter__ as a wrapper_descriptor in its own __dict__ (it is an awaitable coroutine-compatible object)."
    - "asyncio.Future defines __iter__ as a wrapper_descriptor in its own __dict__ (Future.__iter__ delegates to Future.__await__)."
    - "asyncio.Task.__iter__.__class__.__name__ == 'wrapper_descriptor' — verified Python 3.14.3."
    - "asyncio.Future.__iter__.__class__.__name__ == 'wrapper_descriptor' — verified Python 3.14.3."
    - "asyncio.Queue, Lock, Event, Semaphore, Barrier, TaskGroup do NOT define __iter__ in their own __dict__."
    - "No asyncio class defines __contains__ or __next__ in its own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1456.iter_class_name:
  description: "asyncio.Task and asyncio.Future define __iter__ as wrapper_descriptor in their own __dict__; other asyncio classes do not define __iter__ at all; __class__.__name__ == 'wrapper_descriptor' for Task and Future; verified with Python 3.14.3"
  kind: python_call_eq
  category: iter_class_name
  id_prefix: as1456ic
  columns: [id, function, args, expected]
  rows:
    - [as1456ic001, asyncio.Task.__iter__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [as1456ic002, asyncio.Future.__iter__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [as1456ic003, asyncio.Task.__iter__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [as1456ic004, asyncio.Future.__iter__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [as1456ic005, asyncio.Task.__iter__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [as1456ic006, asyncio.Future.__iter__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

table asyncio_extra1456.iter_in_dict:
  description: "asyncio.__dict__ membership for __iter__ — Task and Future define __iter__ in own __dict__ (True); Queue, Lock, Event, Semaphore, Barrier, TaskGroup do not (False); verified with Python 3.14.3"
  kind: python_call_eq
  category: iter_dict_membership
  id_prefix: as1456id
  columns: [id, function, args, expected]
  rows:
    - [as1456id001, asyncio.Task.__dict__.__contains__,      ["__iter__"], true]
    - [as1456id002, asyncio.Future.__dict__.__contains__,    ["__iter__"], true]
    - [as1456id003, asyncio.Queue.__dict__.__contains__,     ["__iter__"], false]
    - [as1456id004, asyncio.Lock.__dict__.__contains__,      ["__iter__"], false]
    - [as1456id005, asyncio.Event.__dict__.__contains__,     ["__iter__"], false]
    - [as1456id006, asyncio.Semaphore.__dict__.__contains__,  ["__iter__"], false]
    - [as1456id007, asyncio.Barrier.__dict__.__contains__,   ["__iter__"], false]
    - [as1456id008, asyncio.TaskGroup.__dict__.__contains__,  ["__iter__"], false]

table asyncio_extra1456.contains_not_in_dict:
  description: "asyncio.__dict__ membership for __contains__ — no asyncio class (Queue, Task, Future, Lock, Event, Semaphore, Barrier, TaskGroup) defines __contains__ in its own __dict__; all return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: as1456cd
  columns: [id, function, args, expected]
  rows:
    - [as1456cd001, asyncio.Queue.__dict__.__contains__,     ["__contains__"], false]
    - [as1456cd002, asyncio.Task.__dict__.__contains__,      ["__contains__"], false]
    - [as1456cd003, asyncio.Future.__dict__.__contains__,    ["__contains__"], false]
    - [as1456cd004, asyncio.Lock.__dict__.__contains__,      ["__contains__"], false]
    - [as1456cd005, asyncio.Event.__dict__.__contains__,     ["__contains__"], false]
    - [as1456cd006, asyncio.Semaphore.__dict__.__contains__,  ["__contains__"], false]
    - [as1456cd007, asyncio.Barrier.__dict__.__contains__,   ["__contains__"], false]
    - [as1456cd008, asyncio.TaskGroup.__dict__.__contains__,  ["__contains__"], false]

table asyncio_extra1456.next_not_in_dict:
  description: "asyncio.__dict__ membership for __next__ — no asyncio class defines __next__ in its own __dict__; all return False; verified with Python 3.14.3"
