spec: re_extra2656
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2641.zspec.zsdl — covers __copy__/__deepcopy__/__sizeof__ dict-presence"
  notes:
    - "Wave 624 (re_extra2656) theme: __contains__, __add__, and __mul__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __contains__, __add__, or __mul__ in its own __dict__."
    - "__contains__ is the membership-test protocol; regex Pattern and Match objects are not container types."
    - "__add__ and __mul__ are arithmetic operators; compiled patterns and match results do not support concatenation or repetition via these hooks."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __contains__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2656.no_contains_in_re_classes:
  description: "__contains__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the container membership protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2656

  columns: [id, function, args, expected]
  rows:
    - ["re2656001", "re.Pattern.__dict__.__contains__", ["__contains__"], false]
    - ["re2656002", "re.Match.__dict__.__contains__",   ["__contains__"], false]

# ---------------------------------------------------------------------------
# __add__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2656.no_add_in_re_classes:
  description: "__add__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement arithmetic addition"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2656

  columns: [id, function, args, expected]
  rows:
    - ["re2656003", "re.Pattern.__dict__.__contains__", ["__add__"], false]
    - ["re2656004", "re.Match.__dict__.__contains__",   ["__add__"], false]

# ---------------------------------------------------------------------------
# __mul__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2656.no_mul_in_re_classes:
  description: "__mul__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement arithmetic multiplication"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2656

  columns: [id, function, args, expected]
  rows:
    - ["re2656005", "re.Pattern.__dict__.__contains__", ["__mul__"], false]
    - ["re2656006", "re.Match.__dict__.__contains__",   ["__mul__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not arithmetic/container hooks
# Confirms that regex objects are pattern-matching types, not arithmetic or container types
# ---------------------------------------------------------------------------

table re_extra2656.re_has_regex_methods_not_arithmetic_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __contains__/__add__/__mul__; re.Match defines group/groups/start/end but NOT __contains__/__add__/__mul__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2656

  columns: [id, function, args, expected]
  rows:
    - ["re2656007", "re.Pattern.__dict__.__contains__", ["match"],        true]
    - ["re2656008", "re.Pattern.__dict__.__contains__", ["search"],       true]
    - ["re2656009", "re.Pattern.__dict__.__contains__", ["sub"],          true]
    - ["re2656010", "re.Pattern.__dict__.__contains__", ["findall"],      true]
    - ["re2656011", "re.Pattern.__dict__.__contains__", ["__contains__"], false]
    - ["re2656012", "re.Pattern.__dict__.__contains__", ["__add__"],      false]
    - ["re2656013", "re.Pattern.__dict__.__contains__", ["__mul__"],      false]
    - ["re2656014", "re.Match.__dict__.__contains__",   ["group"],        true]
    - ["re2656015", "re.Match.__dict__.__contains__",   ["groups"],       true]
    - ["re2656016", "re.Match.__dict__.__contains__",   ["start"],        true]
    - ["re2656017", "re.Match.__dict__.__contains__",   ["end"],          true]
    - ["re2656018", "re.Match.__dict__.__contains__",   ["__contains__"], false]
    - ["re2656019", "re.Match.__dict__.__contains__",   ["__add__"],      false]
    - ["re2656020", "re.Match.__dict__.__contains__",   ["__mul__"],      false]
