# ---------------------------------------------------------------------------
# decimal.Decimal class identity
# Decimal is the C extension type from _decimal, re-exported via decimal.
# __name__ == 'Decimal' (7), __module__ == 'decimal' (7),
# __qualname__ == 'Decimal' (7), __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table decimal_extra134.Decimal_class_identity:
  description: "decimal.Decimal class identity: __name__='Decimal' (7), __module__='decimal' (7), __qualname__='Decimal' (7), __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decdec134

  columns: [id, function, args, expected]
  rows:
    - [dec_name_eq,      Decimal.__name__.__eq__,          ["Decimal"], true]
    - [dec_name_len,     Decimal.__name__.__len__,         [],          7]
    - [dec_module_eq,    Decimal.__module__.__eq__,        ["decimal"], true]
    - [dec_module_len,   Decimal.__module__.__len__,       [],          7]
    - [dec_qualname_eq,  Decimal.__qualname__.__eq__,      ["Decimal"], true]
    - [dec_qualname_len, Decimal.__qualname__.__len__,     [],          7]
    - [dec_cls_eq,       Decimal.__class__.__name__.__eq__, ["type"],   true]

