# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra134.Decimal.__add__.qualname_eq:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (length 15; __add__ is a wrapper_descriptor on the C Decimal type, qualname has no module prefix)"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__add__.__qualname__.__eq__"
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra134.Decimal.__truediv__.qualname_len_19:
  description: "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 ('Decimal.__truediv__' has 19 characters; __truediv__ is longer than __add__/__sub__/__mul__ because of the longer dunder name)"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__truediv__.__qualname__.__len__"
  args: []
  expected: 19

invariant decimal_extra134.Decimal.__floordiv__.qualname_len_20:
  description: "decimal.Decimal.__floordiv__.__qualname__.__len__() == 20 ('Decimal.__floordiv__' has 20 characters; the longest arithmetic operator qualname in this spec)"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__floordiv__.__qualname__.__len__"
  args: []
  expected: 20

invariant decimal_extra134.Decimal.__add__.class_is_wrapper_descriptor:
  description: "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' (not 'method_descriptor'; Decimal arithmetic operators are C slot wrappers, distinguishing them from pure method_descriptor objects like those on re.Match)"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__add__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra134.Decimal.__radd__.objclass_is_Decimal:
  description: "decimal.Decimal.__radd__.__objclass__.__name__ == 'Decimal' (length 7; __radd__ is the reflected addition operator; its __objclass__ confirms the owning type is Decimal)"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__radd__.__objclass__.__name__.__eq__"
  args: ["Decimal"]
  expected: true

