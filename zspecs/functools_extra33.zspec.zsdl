spec: functools_extra33
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra32.zspec.zsdl."
    - "Prior specs covered: reduce/partial/lru_cache/wraps/cached_property/total_ordering/cmp_to_key/singledispatch __name__/__module__/__qualname__, partial.__bases__, cached_property.__bases__, WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES, partial/__module__/__qualname__, cached_property/__module__/__qualname__, lru_cache/__module__, reduce/__module__, wraps/__module__, total_ordering/__module__, singledispatch/__module__, cmp_to_key/__module__, partial.__init__.__name__."
    - "This spec covers: __name__.__len__() for reduce/partial/lru_cache/wraps/cached_property/total_ordering/singledispatch/cmp_to_key; __module__.__len__() for reduce/partial/lru_cache/wraps."
    - "Key findings: reduce.__module__ is '_functools' (len 10); partial/lru_cache/wraps.__module__ are 'functools' (len 9); name lengths vary widely from wraps (5) to cached_property (15)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — name string lengths for Python-attributed callables
#
# functools.wraps, partial, reduce, lru_cache, total_ordering, cmp_to_key,
# singledispatch, and cached_property all have __name__ attributes whose lengths
# differ. wraps (5) and partial (7) are short; reduce (6) is compact; lru_cache (9)
# uses underscore notation; total_ordering (14) and singledispatch (14) are the
# longest. This table captures the __name__ length for the six Python-attributed
# callables that report __module__ == 'functools'. No prior functools spec records
# these name lengths together in the extra33 namespace.
# ---------------------------------------------------------------------------

table functools_extra33.name_str_lengths_public:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra33.name_str_lengths_public.wraps,
       wraps.__name__.__len__,
       [],
       5,
       "len(functools.wraps.__name__) == 5"]
    - [functools_extra33.name_str_lengths_public.partial,
       partial.__name__.__len__,
       [],
       7,
       "len(functools.partial.__name__) == 7"]
    - [functools_extra33.name_str_lengths_public.lru_cache,
       lru_cache.__name__.__len__,
       [],
       9,
       "len(functools.lru_cache.__name__) == 9"]
    - [functools_extra33.name_str_lengths_public.total_ordering,
       total_ordering.__name__.__len__,
       [],
       14,
       "len(functools.total_ordering.__name__) == 14"]
    - [functools_extra33.name_str_lengths_public.singledispatch,
       singledispatch.__name__.__len__,
       [],
       14,
       "len(functools.singledispatch.__name__) == 14"]
    - [functools_extra33.name_str_lengths_public.cached_property,
       cached_property.__name__.__len__,
       [],
       15,
       "len(functools.cached_property.__name__) == 15"]

# ---------------------------------------------------------------------------
# __name__.__len__() table — name string lengths for C-extension callables
#
# functools.reduce and functools.cmp_to_key are C-level functions attributed to
# _functools. reduce has __name__ 'reduce' (len 6); cmp_to_key has __name__
# 'cmp_to_key' (len 10). This table records their name lengths in the extra33
# namespace. No prior functools spec records these lengths together in extra33.
# ---------------------------------------------------------------------------

table functools_extra33.name_str_lengths_cext:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra33.name_str_lengths_cext.reduce,
       reduce.__name__.__len__,
       [],
       6,
       "len(functools.reduce.__name__) == 6"]
    - [functools_extra33.name_str_lengths_cext.cmp_to_key,
       cmp_to_key.__name__.__len__,
       [],
       10,
       "len(functools.cmp_to_key.__name__) == 10"]

# ---------------------------------------------------------------------------
# __module__.__len__() table — module string lengths
#
# functools.partial, lru_cache, and wraps all have __module__ == 'functools'
# (len 9). functools.reduce has __module__ == '_functools' (len 10), one
# character longer due to the leading underscore. This table captures the
# contrast between the public-attributed and C-extension-attributed module
# strings. No prior functools spec records __module__.__len__() for these
# four callables together in the extra33 namespace.
# ---------------------------------------------------------------------------

table functools_extra33.module_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra33.module_str_lengths.partial,
       partial.__module__.__len__,
       [],
       9,
       "len(functools.partial.__module__) == 9"]
    - [functools_extra33.module_str_lengths.lru_cache,
       lru_cache.__module__.__len__,
       [],
       9,
       "len(functools.lru_cache.__module__) == 9"]
    - [functools_extra33.module_str_lengths.wraps,
       wraps.__module__.__len__,
       [],
       9,
       "len(functools.wraps.__module__) == 9"]
    - [functools_extra33.module_str_lengths.reduce,
       reduce.__module__.__len__,
       [],
       10,
       "len(functools.reduce.__module__) == 10"]

# ---------------------------------------------------------------------------
# cached_property.__name__.__len__() — standalone name string length
#
# functools.cached_property.__name__ is 'cached_property', a 15-character
# string. This is the longest __name__ among the commonly used functools
# callables. cached_property is a Python-level descriptor that computes a
# property value on first access and caches it as an instance attribute. Its
# compound name (including the underscore) reflects its combination of
# 'cached' and 'property' semantics. No prior functools spec records this
# standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra33.cached_property.name_len:
  description: "len(functools.cached_property.__name__) == 15"
  category: string_properties
  kind: python_call_eq
  function: cached_property.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# reduce.__module__.__len__() — standalone module string length
#
# functools.reduce.__module__ is '_functools', a 10-character string. This is
# one character longer than 'functools' (9 characters) because of the leading
# underscore that marks the private C extension module. reduce is implemented
# in Modules/_functoolsmodule.c and its __module__ reflects that private name.
# No prior functools spec records this standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra33.reduce.module_len:
  description: "len(functools.reduce.__module__) == 10"
  category: string_properties
  kind: python_call_eq
  function: reduce.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# singledispatch.__name__.__len__() — standalone name string length
#
# functools.singledispatch.__name__ is 'singledispatch', a 14-character string.
# singledispatch is a Python-level decorator that transforms a function into a
# single-dispatch generic function. It shares the same name length as
# total_ordering (14). No prior functools spec records this standalone in the
# extra33 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra33.singledispatch.name_len:
  description: "len(functools.singledispatch.__name__) == 14"
  category: string_properties
  kind: python_call_eq
  function: singledispatch.__name__.__len__
  args: []
  expected: 14
