spec: theseus_tarfile_cr
version: ">=3.8"
backend: python_cleanroom(theseus_tarfile_cr)
blocks: tarfile

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tarfile.html"
    - "GNU tar format specification — POSIX.1-1988 ustar format"
  not_derived_from:
    - "CPython source: Lib/tarfile.py (internal implementation)"
  notes:
    - "Clean-room tar archive reader/writer. Do NOT import tarfile."
    - "Supports ustar format (POSIX.1-1988): 512-byte headers + data blocks."
    - "TarFile(name, mode): open/create a tar archive."
    - "TarFile.add(name, arcname): add a file to the archive."
    - "TarFile.addfile(tarinfo, fileobj): add a TarInfo with data."
    - "TarFile.getmembers(): return list of TarInfo objects."
    - "TarFile.extractfile(member): return file-like object for reading member data."
    - "TarInfo: header record with name, size, mode, mtime fields."

error_model: python_exceptions

invariant theseus_tarfile_cr.tarfile2_addfile_read:
  description: "add bytes to tar, extractfile reads them back"
  category: extractfile
  kind: python_call_eq
  function: tarfile2_addfile_read
  args: []
  expected: "hello tar"

invariant theseus_tarfile_cr.tarfile2_getmembers:
  description: "add 2 files, getmembers() returns 2 entries"
  category: getmembers
  kind: python_call_eq
  function: tarfile2_getmembers
  args: []
  expected: 2

invariant theseus_tarfile_cr.tarfile2_tarinfo_name:
  description: "TarInfo constructed with name has correct .name attribute"
  category: TarInfo
  kind: python_call_eq
  function: tarfile2_tarinfo_name
  args: []
  expected: "test.txt"
