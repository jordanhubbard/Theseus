spec: uuid_extra90
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra89

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra89.zspec.zsdl — covers UUID.__hash__/__eq__/__int__/__lt__/__setattr__ __module__.__eq__('uuid') / UUID.fields fget __class__.__name__ and __qualname__ / uuid5/__module__ / getnode/__code__/co_name / UUID comparison dunder class names (table + invariants)."
    - "uuid_extra88.zspec.zsdl — covers UUID.__init__/__str__/__repr__ class names / NAMESPACE_DNS __class__.__name__=='UUID' / UUID property fget class names and qualnames (hex/bytes/version/urn/variant/fields) (table + invariants)."
    - "uuid_extra87.zspec.zsdl — covers UUID.__setattr__/__delattr__ class names / UUID field property fget class names and qualnames (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
    - "uuid_extra84.zspec.zsdl — covers uuid.UUID/__name__/__module__/__qualname__/__class__.__name__ / UUID/__bases__/__mro__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra89; it does NOT duplicate invariants present in those files."
    - "Wave 261 theme: uuid module NAMESPACE_* constants and variant string identity — NAMESPACE_URL/OID/X500 __class__.__name__=='UUID' / NAMESPACE_* version==1 / RFC_4122/RESERVED_* __class__.__name__=='str' / RFC_4122/__len__()==21 / UUID.__class__.__name__=='type'."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122 == 'specified in RFC 4122'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__len__() == 21. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__len__() == 30. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__len__() == 36. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__len__() == 30. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: NAMESPACE_DNS.__class__.__name__=='UUID' was anchored in uuid_extra88; this spec anchors NAMESPACE_URL/OID/X500 __class__.__name__=='UUID' for the first time."
    - "Note: RFC_4122/RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE are string constants (not IntEnum) in Python's uuid module; they describe the UUID variant field semantics."
    - "Note: All four NAMESPACE_* UUIDs have version==1 because they are version-1 (time-based) UUIDs as specified in RFC 4122."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID')
# uuid.UUID.__class__.__name__.__eq__('type')
#
# Wave 261 theme: NAMESPACE_URL/OID/X500 class identity and UUID metaclass.
#
# The four NAMESPACE_* constants are all UUID instances (__class__.__name__=='UUID').
# uuid_extra88 anchors NAMESPACE_DNS.__class__.__name__=='UUID'; this table extends
# that to the remaining three: NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500.
# uuid.UUID itself is a class whose metaclass is 'type' (standard Python class).
# No prior uuid spec anchors NAMESPACE_URL/OID/X500 class names or UUID metaclass
# under uuidns90. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra90.namespace_class_names:
  description: "uuid.NAMESPACE_URL/__class__.__name__.__eq__('UUID')==True / NAMESPACE_OID/__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500/__class__.__name__.__eq__('UUID')==True / UUID/__class__.__name__.__eq__('type')==True — NAMESPACE_URL/OID/X500 are UUID instances; uuid_extra88 anchors NAMESPACE_DNS class name; uuid.UUID has metaclass 'type' (standard Python class); no prior uuid spec anchors these four class names together; first uuidns90 anchor for NAMESPACE_URL/OID/X500 class identity and UUID metaclass"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns90

  columns: [id, function, args, expected, description]
  rows:
    - [url_class,   "NAMESPACE_URL.__class__.__name__.__eq__",  ["UUID"], true, "NAMESPACE_URL is a UUID instance; only DNS class was anchored in uuid_extra88"]
    - [oid_class,   "NAMESPACE_OID.__class__.__name__.__eq__",  ["UUID"], true, "NAMESPACE_OID is a UUID instance; first uuidns90 anchor for OID class name"]
    - [x500_class,  "NAMESPACE_X500.__class__.__name__.__eq__", ["UUID"], true, "NAMESPACE_X500 is a UUID instance; first uuidns90 anchor for X500 class name"]
    - [uuid_metaclass, "UUID.__class__.__name__.__eq__",        ["type"], true, "uuid.UUID class itself has metaclass 'type' (ordinary Python class)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version.__eq__(1)
# uuid.NAMESPACE_URL.version.__eq__(1)
# uuid.NAMESPACE_OID.version.__eq__(1)
# uuid.NAMESPACE_X500.version.__eq__(1)
#
# Wave 261 theme: NAMESPACE_* version field equality.
#
# All four NAMESPACE_* UUIDs have version==1 because they are version-1
# (time-based) UUIDs as specified in RFC 4122, Appendix C. The version field
# is stored in bits 12-15 of time_hi_and_version. No prior uuid spec anchors
# the version attribute of any NAMESPACE_* constant under uuidns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra90.namespace_versions:
  description: "uuid.NAMESPACE_DNS/version.__eq__(1)==True / NAMESPACE_URL/version.__eq__(1)==True / NAMESPACE_OID/version.__eq__(1)==True / NAMESPACE_X500/version.__eq__(1)==True — all four NAMESPACE_* UUIDs are version-1 (time-based) as defined in RFC 4122 Appendix C; no prior uuid spec anchors NAMESPACE_* version attribute; first uuidns90 anchor for NAMESPACE_* version field equality"
  kind: python_call_eq
  category: constant_values
  id_prefix: uuidns90

  columns: [id, function, args, expected, description]
  rows:
    - [dns_version,   "NAMESPACE_DNS.version.__eq__",   [1], true, "NAMESPACE_DNS is a version-1 UUID per RFC 4122 Appendix C"]
    - [url_version,   "NAMESPACE_URL.version.__eq__",   [1], true, "NAMESPACE_URL is a version-1 UUID per RFC 4122 Appendix C"]
    - [oid_version,   "NAMESPACE_OID.version.__eq__",   [1], true, "NAMESPACE_OID is a version-1 UUID per RFC 4122 Appendix C"]
    - [x500_version,  "NAMESPACE_X500.version.__eq__",  [1], true, "NAMESPACE_X500 is a version-1 UUID per RFC 4122 Appendix C"]

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__class__.__name__.__eq__('str')
# uuid.RESERVED_NCS.__class__.__name__.__eq__('str')
# uuid.RESERVED_MICROSOFT.__class__.__name__.__eq__('str')
# uuid.RESERVED_FUTURE.__class__.__name__.__eq__('str')
# uuid.RFC_4122.__len__()==21
# uuid.RESERVED_NCS.__len__()==30
# uuid.RESERVED_MICROSOFT.__len__()==36
# uuid.RESERVED_FUTURE.__len__()==30
#
# Wave 261 theme: uuid variant string constants class names and lengths.
#
# The four variant constants (RFC_4122, RESERVED_NCS, RESERVED_MICROSOFT,
# RESERVED_FUTURE) are Python str instances (not IntEnum). Their values are
# human-readable strings describing UUID variant semantics. RFC_4122 is
# 'specified in RFC 4122' (21 chars), RESERVED_NCS is 'reserved for NCS
# compatibility' (30 chars), RESERVED_MICROSOFT is 'reserved for Microsoft
# compatibility' (36 chars), RESERVED_FUTURE is 'reserved for future
# definition' (30 chars). No prior uuid spec anchors these constants under
# uuidns90. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra90.variant_constants_class_and_len:
  description: "uuid.RFC_4122/__class__.__name__.__eq__('str')==True / RESERVED_NCS/__class__.__name__.__eq__('str')==True / RESERVED_MICROSOFT/__class__.__name__.__eq__('str')==True / RESERVED_FUTURE/__class__.__name__.__eq__('str')==True / RFC_4122/__len__()==21 / RESERVED_NCS/__len__()==30 / RESERVED_MICROSOFT/__len__()==36 / RESERVED_FUTURE/__len__()==30 — uuid variant constants are plain str instances (not IntEnum); their human-readable values describe UUID variant semantics; no prior uuid spec anchors these; first uuidns90 anchor for variant string constants"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns90

  columns: [id, function, args, expected, description]
  rows:
    - [rfc4122_class,   RFC_4122.__class__.__name__.__eq__,        ["str"], true, "RFC_4122 is a plain str, not IntEnum"]
    - [ncs_class,       RESERVED_NCS.__class__.__name__.__eq__,    ["str"], true, "RESERVED_NCS is a plain str"]
    - [ms_class,        RESERVED_MICROSOFT.__class__.__name__.__eq__, ["str"], true, "RESERVED_MICROSOFT is a plain str"]
    - [future_class,    RESERVED_FUTURE.__class__.__name__.__eq__,  ["str"], true, "RESERVED_FUTURE is a plain str"]
    - [rfc4122_len,     RFC_4122.__len__,    [], 21, "RFC_4122 = 'specified in RFC 4122' (21 chars)"]
    - [ncs_len,         RESERVED_NCS.__len__,    [], 30, "RESERVED_NCS = 'reserved for NCS compatibility' (30 chars)"]
    - [ms_len,          RESERVED_MICROSOFT.__len__,    [], 36, "RESERVED_MICROSOFT = 'reserved for Microsoft compatibility' (36 chars)"]
    - [future_len,      RESERVED_FUTURE.__len__,    [], 30, "RESERVED_FUTURE = 'reserved for future definition' (30 chars)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_URL.__class__.__name__ is 'UUID'. NAMESPACE_URL is the well-known
# UUID namespace for URLs, defined in RFC 4122 Appendix C as
# 6ba7b811-9dad-11d1-80b4-00c04fd430c8. It is a UUID instance. uuid_extra88
# anchors NAMESPACE_DNS.__class__.__name__=='UUID'; NAMESPACE_URL is anchored
# here for the first time as a standalone under uuidns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra90.namespace_url_class_uuid:
  description: "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — NAMESPACE_URL (6ba7b811-9dad-11d1-80b4-00c04fd430c8) is the well-known UUID namespace for URLs per RFC 4122 Appendix C; it is a UUID instance; uuid_extra88 anchors NAMESPACE_DNS; this is the first standalone for NAMESPACE_URL class name under uuidns90"
  category: type_identity
  kind: python_call_eq
  function: "NAMESPACE_URL.__class__.__name__.__eq__"
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__class__.__name__.__eq__('str') — standalone
#
# uuid.RFC_4122.__class__.__name__ is 'str'. RFC_4122 is the string constant
# 'specified in RFC 4122', used as the value of the variant field for RFC-4122
# compliant UUIDs. It is a plain Python str (not an IntEnum or Flag member),
# meaning uuid variant constants in Python are human-readable strings rather
# than numeric values. No prior uuid spec anchors RFC_4122.__class__.__name__
# as a standalone under uuidns90. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra90.rfc4122_class_str:
  description: "uuid.RFC_4122.__class__.__name__.__eq__('str') == True — RFC_4122 is a plain str constant ('specified in RFC 4122'), not an IntEnum; uuid variant constants are human-readable strings in Python's uuid module; no prior uuid spec anchors RFC_4122 class name as a standalone; first standalone for RFC_4122.__class__.__name__ under uuidns90"
  category: type_identity
  kind: python_call_eq
  function: RFC_4122.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version.__eq__(1) — standalone
#
# uuid.NAMESPACE_DNS.version is 1. NAMESPACE_DNS is the well-known UUID
# namespace for fully-qualified domain names, defined in RFC 4122 Appendix C
# as 6ba7b810-9dad-11d1-80b4-00c04fd430c8. Its version field is 1, because
# it is a version-1 (time-based) UUID. No prior uuid spec anchors
# NAMESPACE_DNS.version as a standalone under uuidns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra90.namespace_dns_version_1:
  description: "uuid.NAMESPACE_DNS.version.__eq__(1) == True — NAMESPACE_DNS (6ba7b810-9dad-11d1-80b4-00c04fd430c8) is a version-1 UUID per RFC 4122 Appendix C; the version field encodes 1 in bits 12-15 of time_hi_and_version; no prior uuid spec anchors NAMESPACE_DNS.version as a standalone; first standalone for NAMESPACE_DNS version under uuidns90"
  category: constant_values
  kind: python_call_eq
  function: "NAMESPACE_DNS.version.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__len__()==21 — standalone
#
# uuid.RFC_4122.__len__() is 21. RFC_4122 is the string 'specified in RFC 4122',
# which has 21 characters. The length of this constant string is meaningful as a
# behavioral contract: it confirms that the UUID module's variant label for
# RFC-4122 compliant UUIDs has exactly 21 characters. No prior uuid spec anchors
# RFC_4122.__len__() as a standalone under uuidns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra90.rfc4122_len_21:
  description: "uuid.RFC_4122.__len__() == 21 — RFC_4122 is the string 'specified in RFC 4122' (21 chars); this confirms the variant label length as a behavioral contract; no prior uuid spec anchors RFC_4122.__len__() as a standalone; first standalone for RFC_4122 length under uuidns90"
  category: constant_values
  kind: python_call_eq
  function: RFC_4122.__len__
  args: []
  expected: 21
