spec: threading_extra1126
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.__name__, threading.__spec__.name, threading.__doc__.__class__.__name__, Thread/__doc__/__class__/__name__, Lock/__doc__/__class__/__name__, RLock/__doc__/__class__/__name__, Condition/__doc__/__class__/__name__, Event/__doc__/__class__/__name__ — not covered in _extra1096/_extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1126.module_name_spec_doc:
  description: "threading module-level __name__, __spec__.name, and __doc__ class identity"
  kind: python_call_eq
  category: module_name_spec_doc
  id_prefix: th1126mn
  columns: [id, function, args, expected]
  rows:
    - [th1126mn001, threading.__name__.__eq__,                                    ["threading"],                        true]
    - [th1126mn002, threading.__spec__.name.__eq__,                               ["threading"],                        true]
    - [th1126mn003, threading.__doc__.__class__.__name__.__eq__,                  ["str"],                              true]
    - [th1126mn004, threading.Thread.__doc__.__class__.__name__.__eq__,           ["str"],                              true]
    - [th1126mn005, threading.Lock.__doc__.__class__.__name__.__eq__,             ["str"],                              true]
    - [th1126mn006, threading.RLock.__doc__.__class__.__name__.__eq__,            ["str"],                              true]
    - [th1126mn007, threading.Condition.__doc__.__class__.__name__.__eq__,        ["str"],                              true]
    - [th1126mn008, threading.Event.__doc__.__class__.__name__.__eq__,            ["str"],                              true]

table threading_extra1126.lock_rlock_class_identity:
  description: "threading.Lock and RLock class identity (qualname, module, class name)"
  kind: python_call_eq
  category: lock_rlock_class_identity
  id_prefix: th1126lr
  columns: [id, function, args, expected]
  rows:
    - [th1126lr001, threading.Lock.__qualname__.__eq__,                           ["lock"],                             true]
    - [th1126lr002, threading.Lock.__module__.__eq__,                             ["_thread"],                          true]
    - [th1126lr003, threading.Lock.__class__.__name__.__eq__,                     ["type"],                             true]
    - [th1126lr004, threading.RLock.__qualname__.__eq__,                          ["RLock"],                            true]
    - [th1126lr005, threading.RLock.__module__.__eq__,                            ["threading"],                        true]
    - [th1126lr006, threading.RLock.__class__.__name__.__eq__,                    ["type"],                             true]
    - [th1126lr007, threading.Event.__qualname__.__eq__,                          ["Event"],                            true]
    - [th1126lr008, threading.Event.__module__.__eq__,                            ["threading"],                        true]

table threading_extra1126.semaphore_barrier_local_identity:
  description: "threading.BoundedSemaphore, local, and current_thread qualname/module identity"
  kind: python_call_eq
  category: semaphore_barrier_local_identity
  id_prefix: th1126sb
  columns: [id, function, args, expected]
  rows:
    - [th1126sb001, threading.BoundedSemaphore.__qualname__.__eq__,               ["BoundedSemaphore"],                 true]
    - [th1126sb002, threading.BoundedSemaphore.__module__.__eq__,                 ["threading"],                        true]
    - [th1126sb003, threading.BoundedSemaphore.__class__.__name__.__eq__,         ["type"],                             true]
    - [th1126sb004, threading.BoundedSemaphore.__doc__.__class__.__name__.__eq__, ["str"],                              true]
    - [th1126sb005, threading.local.__qualname__.__eq__,                          ["_local"],                           true]
    - [th1126sb006, threading.local.__class__.__name__.__eq__,                    ["type"],                             true]
    - [th1126sb007, threading.current_thread.__qualname__.__eq__,                 ["current_thread"],                   true]
    - [th1126sb008, threading.current_thread.__module__.__eq__,                   ["threading"],                        true]
