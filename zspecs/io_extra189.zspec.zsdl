    - [bw_base_ne_io,  "BufferedWriter.__bases__[0].__name__.__eq__",   ["IOBase"],           false,  "io.BufferedWriter.__bases__[0].__name__.__eq__('IOBase') == False — direct base is '_BufferedIOBase', not 'IOBase'; confirmed Python 3.14.3 macOS"]
