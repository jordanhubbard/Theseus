    - [br_base,        "BufferedReader.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"],  true,   "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader inherits from _BufferedIOBase; confirmed Python 3.14.3 macOS"]
