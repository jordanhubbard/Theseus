table io_extra189.bufferedreader_class_identity:
  description: "io.BufferedReader class identity: __name__=='BufferedReader' (len=14); __module__=='_io'; __qualname__=='BufferedReader'; implemented in C extension _io"
  kind: python_call_eq
  category: identity
  id_prefix: iobuffered189

  columns: [id, function, args, expected, description]
  rows:
    - [br_name,      BufferedReader.__name__.__eq__,      ["BufferedReader"],  true,   "io.BufferedReader.__name__ == 'BufferedReader' — class name for the buffered reader; confirmed Python 3.14.3 macOS"]
    - [br_name_len,  BufferedReader.__name__.__len__,     [],                  14,     "io.BufferedReader.__name__.__len__() == 14 — 'BufferedReader': B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)R(9)e(10)a(11)d(12)e(13)r(14); confirmed Python 3.14.3 macOS"]
    - [br_module,    BufferedReader.__module__.__eq__,    ["_io"],             true,   "io.BufferedReader.__module__ == '_io' — implemented in C extension module _io; confirmed Python 3.14.3 macOS"]
    - [br_qualname,  BufferedReader.__qualname__.__eq__,  ["BufferedReader"],  true,   "io.BufferedReader.__qualname__ == 'BufferedReader' — top-level class, qualname equals name; confirmed Python 3.14.3 macOS"]
    - [br_ne_writer, BufferedReader.__name__.__eq__,      ["BufferedWriter"],  false,  "io.BufferedReader.__name__.__eq__('BufferedWriter') == False — BufferedReader and BufferedWriter are distinct classes; confirmed Python 3.14.3 macOS"]

