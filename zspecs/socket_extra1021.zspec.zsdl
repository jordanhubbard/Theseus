spec: socket_extra1021
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket module metadata types and exception/class __weakref__ descriptor identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1021.module_metadata_types:
  description: "socket module top-level attribute class name checks"
  kind: python_call_eq
  category: module_metadata
  id_prefix: sk1021x
  columns: [id, function, args, expected]
  rows:
    - [sk1021x001, socket.__cached__.__class__.__name__.__eq__, ["str"],  true]
    - [sk1021x002, socket.__file__.__class__.__name__.__eq__,   ["str"],  true]
    - [sk1021x003, socket.__all__.__class__.__name__.__eq__,    ["list"], true]
    - [sk1021x004, socket.__name__.__class__.__name__.__eq__,   ["str"],  true]
    - [sk1021x005, socket.__doc__.__class__.__name__.__eq__,    ["str"],  true]
    - [sk1021x006, socket.__name__.__eq__,                      ["socket"], true]

table socket_extra1021.class_weakref_descriptors:
  description: "socket class and exception __weakref__ getset_descriptor checks"
  kind: python_call_eq
  category: weakref_descriptors
  id_prefix: sk1021w
  columns: [id, function, args, expected]
  rows:
    - [sk1021w001, socket.socket.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [sk1021w002, socket.error.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [sk1021w003, socket.timeout.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [sk1021w004, socket.herror.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [sk1021w005, socket.gaierror.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]

table socket_extra1021.class_module_identity:
  description: "socket class __module__ and __class__ name identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: sk1021c
  columns: [id, function, args, expected]
  rows:
    - [sk1021c001, socket.socket.__class__.__name__.__eq__,   ["type"],   true]
    - [sk1021c002, socket.error.__class__.__name__.__eq__,    ["type"],   true]
    - [sk1021c003, socket.timeout.__class__.__name__.__eq__,  ["type"],   true]
    - [sk1021c004, socket.herror.__class__.__name__.__eq__,   ["type"],   true]
    - [sk1021c005, socket.socket.__module__.__eq__,           ["socket"], true]
    - [sk1021c006, socket.error.__module__.__eq__,            ["socket"], true]
