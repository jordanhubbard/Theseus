spec: concurrent_futures_extra319
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers package-level dunder attributes for concurrent.futures."
    - "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader' — loaded from .py source."
    - "concurrent.futures.__path__.__class__.__name__ == 'list' — it is a package, not a single-file module."
    - "concurrent.futures.__path__.__len__() == 1 — exactly one directory in the package path."
    - "concurrent.futures.__file__.__class__.__name__ == 'str' — __file__ is a string path to __init__.py."
    - "concurrent.futures.__file__.__contains__('concurrent') == True — path includes the package name."
    - "concurrent.futures.__doc__.__class__.__name__ == 'str' — the package has a non-None docstring."
    - "concurrent.futures.__spec__.origin.__class__.__name__ == 'str' — origin is the path to __init__.py."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __loader__ — SourceFileLoader for a pure-Python package
#
# concurrent.futures is a pure-Python package loaded from source, so its
# __loader__ is an instance of importlib._bootstrap_external.SourceFileLoader.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra319.loader.class_name:
  description: "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: package_attrs
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# __path__ — package path is a list with exactly one entry
#
# Because concurrent.futures is a package (not a single-file module), it has
# a __path__ attribute. The attribute type is 'list' and it contains exactly
# one element: the directory containing the package.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra319.path.class_name:
  description: "concurrent.futures.__path__.__class__.__name__ == 'list'"
  category: package_attrs
  kind: python_call_eq
  function: __path__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant concurrent_futures_extra319.path.len_one:
  description: "concurrent.futures.__path__.__len__() == 1"
  category: package_attrs
  kind: python_call_eq
  function: __path__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# __file__ — path to __init__.py is a str containing 'concurrent'
#
# __file__ is the absolute filesystem path to concurrent/futures/__init__.py.
# Its type is 'str' and the path contains the string 'concurrent'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra319.file.class_name:
  description: "concurrent.futures.__file__.__class__.__name__ == 'str'"
  category: package_attrs
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra319.file.contains_concurrent:
  description: "concurrent.futures.__file__.__contains__('concurrent') == True"
  category: package_attrs
  kind: python_call_eq
  function: __file__.__contains__
  args: ["concurrent"]
  expected: true

# ---------------------------------------------------------------------------
# __doc__ — the package has a non-None docstring of type str
#
# concurrent.futures.__doc__ is 'Execute computations asynchronously using
# threads or processes.' — a non-empty str, not None.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra319.doc.class_name:
  description: "concurrent.futures.__doc__.__class__.__name__ == 'str'"
  category: package_attrs
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# __spec__.origin — the ModuleSpec origin is a str path
#
# __spec__ is the ModuleSpec used to load concurrent.futures. Its origin
# attribute is the filesystem path to __init__.py, which is a str.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra319.spec_origin.class_name:
  description: "concurrent.futures.__spec__.origin.__class__.__name__ == 'str'"
  category: package_attrs
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true
