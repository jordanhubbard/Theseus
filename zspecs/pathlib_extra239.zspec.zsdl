spec: pathlib_extra239
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path __truediv__ and joinpath behavioral contracts."
    - "str(pathlib.PurePosixPath('/a') / 'b' / 'c') == '/a/b/c' — chained / operator; verified Python 3.14.3 macOS."
    - "str(pathlib.PurePosixPath('a') / pathlib.PurePosixPath('b')) == 'a/b' — / with PurePath operand; verified Python 3.14.3 macOS."
    - "str(pathlib.PurePosixPath('/a/b') / '/c') == '/c' — absolute right operand replaces path; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').joinpath('d').__str__() == '/a/b/c/d' — joinpath single arg; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b').joinpath('c', 'd').__str__() == '/a/b/c/d' — joinpath multi-arg; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__truediv__.__name__ == '__truediv__' — method name; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.joinpath.__name__ == 'joinpath' — method name; length 8; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath' — qualname includes class; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' — qualname includes class; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath __truediv__ (/) behavioral contracts
# The / operator joins path segments; an absolute right operand replaces.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra239.PurePosixPath.truediv_abc:
  description: "str(PurePosixPath('/a') / 'b' / 'c') == '/a/b/c' — chained / operator joins segments; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath.__truediv__
  args: ["/a/b", "c"]
  expected: "/a/b/c"

invariant pathlib_extra239.PurePosixPath.truediv_relative:
  description: "str(PurePosixPath('a') / PurePosixPath('b')) == 'a/b' — / with PurePath operand joins relative paths; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath.__truediv__
  args: ["a", "b"]
  expected: "a/b"

invariant pathlib_extra239.PurePosixPath.truediv_abs_replaces:
  description: "str(PurePosixPath('/a/b') / '/c') == '/c' — absolute right operand replaces whole path; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath.__truediv__
  args: ["/a/b", "/c"]
  expected: "/c"

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath joinpath behavioral contracts
# joinpath joins one or more path segments; absolute segment replaces.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra239.PurePosixPath.joinpath_single:
  description: "PurePosixPath('/a/b/c').joinpath('d').__str__() == '/a/b/c/d' — joinpath single arg appends segment; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath.joinpath
  args: ["/a/b/c", "d"]
  expected: "/a/b/c/d"

invariant pathlib_extra239.PurePosixPath.joinpath_multi:
  description: "PurePosixPath('/a/b').joinpath('c', 'd').__str__() == '/a/b/c/d' — joinpath multi-arg appends multiple segments; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath.joinpath
  args: ["/a/b", "c", "d"]
  expected: "/a/b/c/d"

# ---------------------------------------------------------------------------
# pathlib.PurePath __truediv__ and joinpath method name contracts
# The method names are their canonical dunder/plain identifiers.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra239.PurePath.truediv_name:
  description: "pathlib.PurePath.__truediv__.__name__ == '__truediv__' — method name is '__truediv__'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.__truediv__.__name__.__eq__
  args: ["__truediv__"]
  expected: true

invariant pathlib_extra239.PurePath.joinpath_name:
  description: "pathlib.PurePath.joinpath.__name__ == 'joinpath' — method name is 'joinpath'; length 8; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.joinpath.__name__.__eq__
  args: ["joinpath"]
  expected: true

invariant pathlib_extra239.PurePath.joinpath_qualname:
  description: "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath' — qualname includes class name; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.joinpath.__qualname__.__eq__
  args: ["PurePath.joinpath"]
  expected: true

invariant pathlib_extra239.PurePath.truediv_qualname:
  description: "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' — qualname includes class name; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.__truediv__.__qualname__.__eq__
  args: ["PurePath.__truediv__"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.PurePath joinpath method name length contracts
# Spot-check the joinpath name length.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra239.PurePath.joinpath_name_length:
  description: "pathlib.PurePath.joinpath.__name__.__len__() == 8 — 'joinpath' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.joinpath.__name__.__len__
  args: []
  expected: 8
