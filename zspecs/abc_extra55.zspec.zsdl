spec: abc_extra55
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/importlib.html — importlib documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "CPython source: Lib/_frozen_importlib.py"
  notes:
    - "This spec extends abc_extra54.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52), abc.__package__.__eq__('') (extra53), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str') (extra53), ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') (extra53), __loader__.__class__.__name__.__eq__('type') (extra54), __loader__.__name__.__eq__('FrozenImporter') (extra54), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra54), __file__.__class__.__name__.__eq__('str') (extra54), ABCMeta.__instancecheck__.__qualname__.__len__()==25 (extra54)."
    - "This spec covers (abcspec55 namespace): wave 226 theme — __spec__.origin values + __spec__.submodule_search_locations checks + __loader__.__name__ length checks. IMPORTANT: abc is a frozen module (FrozenImporter). abc.__loader__.__name__.__len__() == 14 — len('FrozenImporter') == 14. abc.__spec__.origin.__eq__('frozen') — FrozenImporter sets the spec origin to the string 'frozen' (not a file path). abc.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') — abc is a non-package module; submodule_search_locations is None; None.__class__.__name__ == 'NoneType'. abc.__spec__.has_location == False — frozen modules are not file-based; has_location is False for FrozenImporter-loaded modules. No prior abc spec has captured these wave 226 checks."
    - "abc.__loader__.__name__.__len__() == 14. 'FrozenImporter' has 14 characters (F-r-o-z-e-n-I-m-p-o-r-t-e-r). abc.__loader__ is the FrozenImporter class object; its __name__ attribute is 'FrozenImporter'; __loader__.__name__.__len__() == 14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.origin == 'frozen'. FrozenImporter sets the module spec origin to the string 'frozen' for all frozen modules. __spec__.origin.__eq__('frozen') returns True. The origin is a str, not a file path. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.submodule_search_locations is None. abc is a non-package (single-file) module; submodule_search_locations is None for non-packages. None.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.has_location == False. abc is a frozen module loaded by FrozenImporter; frozen modules are not backed by a file on disk; has_location is False. __spec__.has_location.__eq__(False) returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc __spec__.origin + submodule_search_locations + loader name len — extra55
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations
# checks + __loader__.__name__ length checks.
#
# IMPORTANT: abc is a frozen module (FrozenImporter in Python 3.14.3).
# Frozen module behavior differs from SourceFileLoader modules:
#
#   abc.__loader__.__name__.__len__() == 14  ('FrozenImporter' has 14 chars)
#   abc.__spec__.origin == 'frozen'          (NOT a file path)
#   abc.__spec__.submodule_search_locations is None  (non-package)
#   abc.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType'
#   abc.__spec__.has_location == False       (not file-backed)
#
# No prior abc spec has captured these wave 226 checks. Extra55 introduces
# the wave 226 theme in the abcspec55 namespace.
# ---------------------------------------------------------------------------

table abc_extra55.spec_origin_locations:
  description: "abc __spec__.origin + submodule_search_locations + loader name length checks in abcspec55 namespace — abc is a frozen module (FrozenImporter); __spec__.origin == 'frozen' (NOT a file path); submodule_search_locations is None (NoneType) because abc is a non-package; has_location is False because frozen modules are not file-backed; __loader__.__name__.__len__() == 14 for 'FrozenImporter'; wave 226 theme: __spec__.origin values + submodule_search_locations + loader name length; first origin/locations/has_location checks in any abc spec"
  kind: python_call_eq
  category: spec_origin
  id_prefix: abcspec55

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name_len,       __loader__.__name__.__len__,                             [],              14,    "abc.__loader__.__name__.__len__() == 14 — 'FrozenImporter' has 14 characters; abc.__loader__ is the FrozenImporter class object; __loader__.__name__ is the class attribute 'FrozenImporter'; cross-checks the __loader__.__name__.__eq__('FrozenImporter') assertion in extra54; wave 226 first __loader__.__name__.__len__ check in any abc spec"]
    - [origin_eq,             __spec__.origin.__eq__,                                  ["frozen"],      true,  "abc.__spec__.origin == 'frozen' — FrozenImporter sets the module spec origin to the string 'frozen' for all frozen modules (NOT a file path); __spec__.origin.__eq__('frozen') returns True; contrast with SourceFileLoader modules where origin is an absolute file path; wave 226 first __spec__.origin string equality check in any abc spec"]
    - [locations_cls_name,    __spec__.submodule_search_locations.__class__.__name__.__eq__, ["NoneType"], true, "abc.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType' — abc is a non-package module; submodule_search_locations is None; None.__class__.__name__ == 'NoneType'; contrast with packages where submodule_search_locations is a list; wave 226 first submodule_search_locations class name check in any abc spec"]
    - [has_location,          __spec__.has_location.__eq__,                            [false],         true,  "abc.__spec__.has_location == False — abc is a frozen module loaded by FrozenImporter; frozen modules are not backed by a file on disk; has_location is False; contrast with SourceFileLoader modules where has_location is True; __spec__.has_location.__eq__(False) returns True; wave 226 first has_location check in any abc spec"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra55
# ---------------------------------------------------------------------------

invariant abc_extra55.loader_name_len:
  description: "abc.__loader__.__name__.__len__() == 14 — 'FrozenImporter' has 14 characters; abc.__loader__ is the FrozenImporter class object (not an instance); __loader__.__name__ is the class name 'FrozenImporter'; cross-checks the string equality assertion in extra54; wave 226 first __loader__.__name__.__len__ invariant in any abc spec"
  category: spec_origin
  kind: python_call_eq
  function: __loader__.__name__.__len__
  args: []
  expected: 14

invariant abc_extra55.origin_eq:
  description: "abc.__spec__.origin.__eq__('frozen') returns True — FrozenImporter sets module spec origin to 'frozen' for all frozen modules; NOT a file path; wave 226 first __spec__.origin string equality invariant in any abc spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant abc_extra55.locations_class_name_eq:
  description: "abc.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') returns True — abc is a non-package; submodule_search_locations is None; None.__class__.__name__ == 'NoneType'; contrast with packages where this is a list; wave 226 first submodule_search_locations class name invariant in any abc spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant abc_extra55.has_location_eq:
  description: "abc.__spec__.has_location.__eq__(False) returns True — abc is a frozen module loaded by FrozenImporter; frozen modules are not file-backed; has_location is False; contrast with SourceFileLoader modules where has_location is True; wave 226 first has_location invariant in any abc spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true
