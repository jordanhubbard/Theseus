spec: decimal_extra197
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra196.zspec.zsdl — covers decimal class __doc__.__class__.__name__ identity"
  notes:
    - "This spec covers decimal class __class__.__name__ (metaclass) identity not covered by prior decimal_extra specs."
    - "decimal.Decimal.__class__.__name__ == 'type'; the main decimal type; metaclass is type; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__class__.__name__ == 'type'; the arithmetic context class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__class__.__name__ == 'type'; the InvalidOperation signal class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__class__.__name__ == 'type'; the DivisionByZero signal class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "decimal.Overflow.__class__.__name__ == 'type'; the Overflow signal class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "decimal.Underflow.__class__.__name__ == 'type'; the Underflow signal class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "decimal.Inexact.__class__.__name__ == 'type'; the Inexact signal class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "decimal.DecimalException.__class__.__name__ == 'type'; the base signal exception class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal core class __class__.__name__ identity
# Decimal, Context, DecimalException — all 'type'
# ---------------------------------------------------------------------------

table decimal_extra197.core_class_names:
  description: "decimal core class __class__.__name__: Decimal, Context, DecimalException — all 'type'"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: decimalclasses197

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_class_name,          decimal.Decimal.__class__.__name__.__eq__,          ["type"], true, "decimal.Decimal.__class__.__name__ == 'type'; the main arbitrary-precision decimal type; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [context_class_name,          decimal.Context.__class__.__name__.__eq__,          ["type"], true, "decimal.Context.__class__.__name__ == 'type'; the arithmetic context controlling precision and rounding; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [decimalexception_class_name, decimal.DecimalException.__class__.__name__.__eq__, ["type"], true, "decimal.DecimalException.__class__.__name__ == 'type'; the base class for all decimal signal exceptions; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [decimal_class_name_len,      decimal.Decimal.__class__.__name__.__len__,          [], 4, "decimal.Decimal.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [context_class_name_len,      decimal.Context.__class__.__name__.__len__,          [], 4, "decimal.Context.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]

