  rows:
    - [invalidoperation_class_name,     decimal.InvalidOperation.__class__.__name__.__eq__, ["type"], true, "decimal.InvalidOperation.__class__.__name__ == 'type'; raised for invalid operations such as 0/0; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [divisionbyzero_class_name,       decimal.DivisionByZero.__class__.__name__.__eq__,  ["type"], true, "decimal.DivisionByZero.__class__.__name__ == 'type'; raised when division by zero is attempted; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [invalidoperation_class_name_len, decimal.InvalidOperation.__class__.__name__.__len__, [], 4, "decimal.InvalidOperation.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [divisionbyzero_class_name_len,   decimal.DivisionByZero.__class__.__name__.__len__,  [], 4, "decimal.DivisionByZero.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [decimalexception_class_name_len, decimal.DecimalException.__class__.__name__.__len__, [], 4, "decimal.DecimalException.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]

