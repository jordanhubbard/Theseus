spec: base64_extra16
version: ">=3.10"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "base64_extra15.zspec.zsdl — covers encodebytes/decodebytes __module__/__qualname__; urlsafe_b64decode __qualname__; table of __qualname__ for b64encode/b64decode/urlsafe_b64encode/urlsafe_b64decode/b32encode/b16encode."
  notes:
    - "This spec extends base64_extra15.zspec.zsdl."
    - "Prior specs covered: __qualname__/__module__/__name__ for b64encode/b64decode/urlsafe_b64encode/urlsafe_b64decode/b32encode/b32decode/b16encode/b16decode/encodebytes/decodebytes."
    - "This spec covers: __all__.__len__()==22; __all__.__class__.__name__.__len__()==4; __doc__.__class__.__name__.__len__()==3; __name__.__len__()==6; b32hexencode/__qualname__/__len__()==12 (Python 3.10+); b32hexdecode/__qualname__/__len__()==12; MAXLINESIZE class name len==3; MAXLINESIZE value==76; qualname lengths for b85/a85/z85/standard_b64 functions; __module__.__len__()==6 for b32hexencode/b32hexdecode; b64encode.__class__.__name__.__len__()==8."
    - "base64.__all__ has 22 elements (Python 3.10+, includes b32hexencode/b32hexdecode). Verified."
    - "base64.b32hexencode.__qualname__ == 'b32hexencode' — len 12. Verified (Python 3.10+)."
    - "base64.b32hexdecode.__qualname__ == 'b32hexdecode' — len 12. Verified (Python 3.10+)."
    - "base64.MAXLINESIZE == 76 — maximum line length for base64-encoded output. Verified."
    - "base64.MAXLINESIZE.__class__.__name__ == 'int' — len 3. Verified."
    - "base64.b64encode.__class__.__name__ == 'function' — len 8. Verified."
    - "Qualname lengths: b85encode/b85decode/a85encode/a85decode/z85encode/z85decode == 9 each. Verified."
    - "standard_b64encode.__qualname__.__len__() == 18. standard_b64decode.__qualname__.__len__() == 18. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for b32hexencode, b32hexdecode (Python 3.10+)
# and b85/a85/z85 encode/decode functions
#
# base64_extra15 covers __qualname__ eq-checks for b64/urlsafe/b32/b16 variants.
# This table adds qualname *length* for the newer b32hex functions (Python 3.10+)
# and the b85/a85/z85 families.
# Lengths: b32hexencode=12, b32hexdecode=12, b85encode=9, b85decode=9,
#          a85encode=9, a85decode=9, z85encode=9, z85decode=9.
# ---------------------------------------------------------------------------

table base64_extra16.qualname_lengths_ext:
  description: "__qualname__.__len__() for b32hex, b85, a85, z85 encoding functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: bqlen16

  columns: [id, function, args, expected]
  rows:
    - [b32hexencode, b32hexencode.__qualname__.__len__, [], 12]
    - [b32hexdecode, b32hexdecode.__qualname__.__len__, [], 12]
    - [b85encode,    b85encode.__qualname__.__len__,    [], 9]
    - [b85decode,    b85decode.__qualname__.__len__,    [], 9]
    - [a85encode,    a85encode.__qualname__.__len__,    [], 9]
    - [a85decode,    a85decode.__qualname__.__len__,    [], 9]
    - [z85encode,    z85encode.__qualname__.__len__,    [], 9]
    - [z85decode,    z85decode.__qualname__.__len__,    [], 9]

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for b32hexencode/b32hexdecode (Python 3.10+)
# and urlsafe_b64encode/urlsafe_b64decode
#
# All base64 functions are defined in base64.py; __module__ == 'base64' (len 6).
# base64_extra12 covers __module__ for b64encode/b64decode; extra15 covers
# encodebytes/decodebytes. This table covers the b32hex and urlsafe functions.
# ---------------------------------------------------------------------------

table base64_extra16.module_lengths:
  description: "__module__.__len__() == 6 for b32hex and urlsafe_b64 functions"
  kind: python_call_eq
  category: module_identity
  id_prefix: bmlen16

  columns: [id, function, args, expected]
  rows:
    - [b32hexencode,      b32hexencode.__module__.__len__,      [], 6]
    - [b32hexdecode,      b32hexdecode.__module__.__len__,      [], 6]
    - [urlsafe_b64encode, urlsafe_b64encode.__module__.__len__, [], 6]
    - [urlsafe_b64decode, urlsafe_b64decode.__module__.__len__, [], 6]

# ---------------------------------------------------------------------------
# Standalone: base64.__all__.__len__() == 22
#
# In Python 3.10+ __all__ contains 22 entries including b32hexencode and
# b32hexdecode. No prior base64 spec checks __all__.__len__().
# Verified: 22.
# ---------------------------------------------------------------------------

invariant base64_extra16.all.len:
  description: "base64.__all__.__len__() == 22 — 22 public names exported (Python 3.10+)"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# Standalone: base64.__all__.__class__.__name__.__len__() == 4
#
# __all__ is a list object; 'list' has 4 characters.
# No prior base64 spec checks __all__.__class__.__name__.__len__().
# Verified: 4.
# ---------------------------------------------------------------------------

invariant base64_extra16.all.class_name_len:
  description: "base64.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: base64.__doc__.__class__.__name__.__len__() == 3
#
# The module docstring is a str object; 'str' has 3 characters.
# No prior base64 spec checks __doc__.__class__.__name__.__len__().
# Verified: 3.
# ---------------------------------------------------------------------------

invariant base64_extra16.doc.class_name_len:
  description: "base64.__doc__.__class__.__name__.__len__() == 3 — module docstring is a 'str'"
  category: doc_attrs
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone: base64.__name__.__len__() == 6
#
# base64.__name__ == 'base64'; 'base64' has 6 characters.
# No prior base64 spec checks __name__.__len__() at the module level.
# Verified: 6.
# ---------------------------------------------------------------------------

invariant base64_extra16.module_name_len:
  description: "base64.__name__.__len__() == 6 — module name 'base64' has 6 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Standalone: base64.MAXLINESIZE.__class__.__name__.__len__() == 3
#
# base64.MAXLINESIZE is an int (value 76); 'int' has 3 characters.
# No prior base64 spec checks MAXLINESIZE.__class__.__name__.__len__().
# Verified: 3.
# ---------------------------------------------------------------------------

invariant base64_extra16.MAXLINESIZE.class_name_len:
  description: "base64.MAXLINESIZE.__class__.__name__.__len__() == 3 — MAXLINESIZE is an 'int'"
  category: constants
  kind: python_call_eq
  function: MAXLINESIZE.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone: base64.b64encode.__class__.__name__.__len__() == 8
#
# base64.b64encode is a function object; 'function' has 8 characters.
# No prior base64 spec checks b64encode.__class__.__name__.__len__().
# Verified: 8.
# ---------------------------------------------------------------------------

invariant base64_extra16.b64encode.class_name_len:
  description: "base64.b64encode.__class__.__name__.__len__() == 8 — b64encode is a 'function'"
  category: function_attrs
  kind: python_call_eq
  function: b64encode.__class__.__name__.__len__
  args: []
  expected: 8
