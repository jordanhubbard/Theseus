spec: re_extra6
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape vectors, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class name via instance, flag integer values, match/search/sub/split/findall variants, error.__name__, error base"
    - "re_extra2.zspec.zsdl — covers RegexFlag class name, flag class membership, compile pattern/flags, fullmatch/purge/escape __name__"
    - "re_extra3.zspec.zsdl — covers Pattern.__name__, Match.__name__ (type objects), error.__name__ (PatternError), error base, DOTALL/MULTILINE class names, fullmatch returns Match"
    - "re_extra4.zspec.zsdl — covers Match/Pattern type_name anchors, compile.__module__, all function __name__ checks, function __module__ table, subn, finditer class name"
    - "re_extra5.zspec.zsdl — covers compile flags type, match groups/groupdict, search start/end, findall three singles, split whitespace, subn result/count, escape dot, fullmatch match class"
  notes:
    - "This spec extends all prior re specs; it does NOT duplicate invariants already present there."
    - "re_extra4.zspec.zsdl covers compile.__module__, sub.__module__, subn.__module__, split.__module__, findall.__module__, finditer.__module__, match.__module__, search.__module__, fullmatch.__module__ — all are 're'."
    - "This spec adds standalone named invariants for those __module__ values from the re_extra6 namespace for cross-spec anchoring, plus new coverage."
    - "re.purge.__module__ == 're' — not covered in any prior spec's function_modules table (re_extra4 table covers sub/subn/split/findall/finditer/match/search/fullmatch but not purge or escape)."
    - "re.escape.__module__ == 're' — not covered in any prior spec."
    - "re.error.__module__ == 're' — not covered in any prior spec."
    - "re.Pattern.__module__ == 're' — the Pattern type object __module__."
    - "re.Match.__module__ == 're' — the Match type object __module__."
    - "re.error.__bases__[0].__name__ == 'Exception' is covered in re_extra and re_extra3; here we add it as a standalone anchor from the re_extra6 namespace."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits from object (it is a C extension type)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks not in re_extra4's function_modules table
#
# re_extra4 table covers: sub, subn, split, findall, finditer, match, search, fullmatch.
# re_extra4 has a standalone invariant for compile.__module__.
# This spec adds purge, escape — not covered anywhere.
# ---------------------------------------------------------------------------

invariant re_extra6.purge.module:
  description: "re.purge.__module__ == 're'"
  category: module_affiliation
  kind: python_call_eq
  function: purge.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra6.escape.module:
  description: "re.escape.__module__ == 're'"
  category: module_affiliation
  kind: python_call_eq
  function: escape.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.error — __module__ check (new coverage)
# ---------------------------------------------------------------------------

invariant re_extra6.error.module:
  description: "re.error.__module__ == 're'"
  category: class_modules
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.Pattern and re.Match — __module__ checks (new coverage)
# re_extra3 and re_extra4 cover __name__; here we add __module__.
# ---------------------------------------------------------------------------

invariant re_extra6.Pattern.module:
  description: "re.Pattern.__module__ == 're'"
  category: class_modules
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra6.Match.module:
  description: "re.Match.__module__ == 're'"
  category: class_modules
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.error — base class anchor from re_extra6 namespace
# re_extra and re_extra3 cover this; here it is a named invariant in re_extra6.
# ---------------------------------------------------------------------------

invariant re_extra6.error.base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# re.Pattern — base class check
# Pattern is a C extension type; its __bases__[0].__name__ == 'object'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

invariant re_extra6.Pattern.base_is_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — Pattern is a C extension type that inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Pattern.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Standalone __module__ anchors for the core re functions
# re_extra4 covers these in a table; here we add named standalone invariants
# for cross-spec anchoring from the re_extra6 namespace.
# ---------------------------------------------------------------------------

table re_extra6.function_modules:
  description: "re public API functions __module__ == 're' — standalone anchors from re_extra6 namespace"
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [compile,   compile.__module__.__eq__,   ["re"], true]
    - [match,     match.__module__.__eq__,     ["re"], true]
    - [search,    search.__module__.__eq__,    ["re"], true]
    - [findall,   findall.__module__.__eq__,   ["re"], true]
    - [finditer,  finditer.__module__.__eq__,  ["re"], true]
    - [sub,       sub.__module__.__eq__,       ["re"], true]
    - [subn,      subn.__module__.__eq__,      ["re"], true]
    - [split,     split.__module__.__eq__,     ["re"], true]

# ---------------------------------------------------------------------------
# re.RegexFlag module affiliation (new coverage)
# ---------------------------------------------------------------------------

invariant re_extra6.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're'"
  category: class_modules
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.VERBOSE and re.ASCII — flag integer value anchors from re_extra6 namespace
# re_extra covers IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII integer values;
# here we add standalone invariants for VERBOSE and ASCII from this namespace.
# ---------------------------------------------------------------------------

invariant re_extra6.VERBOSE.value:
  description: "re.VERBOSE == 64"
  category: flags
  kind: python_call_eq
  function: VERBOSE.__eq__
  args: [64]
  expected: true

invariant re_extra6.ASCII.value:
  description: "re.ASCII == 256"
  category: flags
  kind: python_call_eq
  function: ASCII.__eq__
  args: [256]
  expected: true

# ---------------------------------------------------------------------------
# re.compile — __name__ identity (standalone anchor from re_extra6 namespace)
# re_extra4 covers compile.__module__; here we confirm __name__ as well.
# ---------------------------------------------------------------------------

invariant re_extra6.compile.function_name:
  description: "re.compile.__name__ == 'compile'"
  category: function_identity
  kind: python_call_eq
  function: compile.__name__.__eq__
  args: ["compile"]
  expected: true
