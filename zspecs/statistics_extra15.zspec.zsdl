spec: statistics_extra15
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras through statistics_extra14.zspec.zsdl."
    - "statistics_extra / extra2 / extra13: NormalDist(0,1) mean/stdev/variance/cdf/pdf; NormalDist(5,2) mean/stdev/variance."
    - "statistics_extra6: NormalDist(2,1) mean/stdev/variance/median; NormalDist(0,1).median."
    - "statistics_extra8: NormalDist(0,1).pdf(0.0)==0.3989...; NormalDist(0,1).inv_cdf(0.5)==0.0."
    - "statistics_extra11: NormalDist(3,4) mean/stdev/variance; NormalDist(0,1).zscore(0)==0.0 and zscore(1)==1.0; NormalDist(5,2).zscore(7)==1.0; NormalDist(5,2).pdf(5); NormalDist(5,2).cdf(5)==0.5."
    - "No prior spec covers NormalDist(1, 0.5) parameter set (mu=1, sigma=0.5)."
    - "No prior spec covers NormalDist(10, 3) parameter set (mu=10, sigma=3)."
    - "No prior spec covers NormalDist(0,1).zscore(-1) == -1.0 (negative z-score)."
    - "No prior spec covers NormalDist(5,2).zscore(5) == 0.0 (z-score at the mean is always 0)."
    - "No prior spec covers NormalDist(0,1).pdf(0).__class__.__name__ == 'float' (return type of pdf)."
    - "No prior spec covers NormalDist(10,3).cdf(10) == 0.5 (CDF at mean for N(10,3))."
    - "NormalDist(1, 0.5).mean == 1.0 — location parameter mu for N(1, 0.5)."
    - "NormalDist(1, 0.5).stdev == 0.5 — scale parameter sigma for N(1, 0.5)."
    - "NormalDist(1, 0.5).variance == 0.25 — variance == sigma**2 == 0.5**2 == 0.25."
    - "NormalDist(1, 0.5).median == 1.0 — median equals mean for symmetric normal."
    - "NormalDist(10, 3).mean == 10.0 — location parameter mu for N(10, 3)."
    - "NormalDist(10, 3).stdev == 3.0 — scale parameter sigma for N(10, 3)."
    - "NormalDist(10, 3).variance == 9.0 — variance == sigma**2 == 3**2 == 9."
    - "NormalDist(10, 3).cdf(10) == 0.5 — CDF at the mean is 0.5 for any normal distribution."
    - "NormalDist(0,1).zscore(-1) == -1.0 — point one sigma below the mean gives z-score -1."
    - "NormalDist(5,2).zscore(5) == 0.0 — z-score at the mean is always zero."
    - "NormalDist(0,1).pdf(0).__class__.__name__ == 'float' — pdf always returns a float."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist(1, 0.5) — new parameter set: mu=1, sigma=0.5
#
# Prior specs cover NormalDist(0,1), NormalDist(2,1), NormalDist(3,4), NormalDist(5,2).
# New: mu=1, sigma=0.5 gives variance=0.25 and median==mean==1.0.
# ---------------------------------------------------------------------------

invariant statistics_extra15.NormalDist_1_05.mean:
  description: "NormalDist(1, 0.5).mean == 1.0 — location parameter mu for N(1, 0.5)"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [1, 0.5]
  method: mean
  expected: 1.0

invariant statistics_extra15.NormalDist_1_05.stdev:
  description: "NormalDist(1, 0.5).stdev == 0.5 — scale parameter sigma for N(1, 0.5)"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [1, 0.5]
  method: stdev
  expected: 0.5

invariant statistics_extra15.NormalDist_1_05.variance:
  description: "NormalDist(1, 0.5).variance == 0.25 — variance == sigma**2 == 0.5**2 == 0.25"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [1, 0.5]
  method: variance
  expected: 0.25

invariant statistics_extra15.NormalDist_1_05.median:
  description: "NormalDist(1, 0.5).median == 1.0 — median equals mean for a symmetric normal"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [1, 0.5]
  method: median
  expected: 1.0

# ---------------------------------------------------------------------------
# NormalDist(10, 3) — new parameter set: mu=10, sigma=3
#
# No prior spec covers this parameterization.
# variance == 3**2 == 9.0; CDF at mean == 0.5 for any normal.
# ---------------------------------------------------------------------------

invariant statistics_extra15.NormalDist_10_3.mean:
  description: "NormalDist(10, 3).mean == 10.0 — location parameter mu for N(10, 3)"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [10, 3]
  method: mean
  expected: 10.0

invariant statistics_extra15.NormalDist_10_3.stdev:
  description: "NormalDist(10, 3).stdev == 3.0 — scale parameter sigma for N(10, 3)"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [10, 3]
  method: stdev
  expected: 3.0

invariant statistics_extra15.NormalDist_10_3.variance:
  description: "NormalDist(10, 3).variance == 9.0 — variance == sigma**2 == 3**2 == 9"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [10, 3]
  method: variance
  expected: 9.0

invariant statistics_extra15.NormalDist_10_3.cdf_at_mean:
  description: "NormalDist(10, 3).cdf(10) == 0.5 — CDF at the mean is 0.5 for any normal distribution"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [10, 3]
  method: cdf
  method_args: [10]
  expected: 0.5

# ---------------------------------------------------------------------------
# NormalDist — zscore additional vectors
#
# statistics_extra11 covers zscore(0)==0.0 and zscore(1)==1.0 for N(0,1),
# and zscore(7)==1.0 for N(5,2).
# New: zscore(-1)==-1.0 for N(0,1) (negative z-score) and zscore(5)==0.0 for N(5,2)
# (z-score at the mean of a non-standard normal is always 0).
# ---------------------------------------------------------------------------

invariant statistics_extra15.NormalDist_0_1.zscore_neg_one:
  description: "NormalDist(0,1).zscore(-1) == -1.0 — one sigma below the mean gives z-score -1"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: zscore
  method_args: [-1]
  expected: -1.0

invariant statistics_extra15.NormalDist_5_2.zscore_at_mean:
  description: "NormalDist(5,2).zscore(5) == 0.0 — z-score at the mean is always zero"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [5, 2]
  method: zscore
  method_args: [5]
  expected: 0.0

# ---------------------------------------------------------------------------
# NormalDist.pdf — return type check
#
# statistics_extra8 covers NormalDist(0,1).pdf(0.0)==0.3989... (the value).
# No prior spec checks the return type of pdf().
# pdf always returns a Python float.
# ---------------------------------------------------------------------------

invariant statistics_extra15.NormalDist_0_1.pdf_class_name:
  description: "NormalDist(0,1).pdf(0).__class__.__name__ == 'float' — pdf always returns a float"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: pdf
  method_args: [0]
  method_chain: __class__.__name__
  expected: "float"
