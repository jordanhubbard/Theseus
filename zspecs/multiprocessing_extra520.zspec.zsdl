spec: multiprocessing_extra520
backend: python_module(multiprocessing.shared_memory)

table:
  id: sharedmemory_identity
  columns: [id, function, expected]
  rows:
    - [shm_name,    multiprocessing.shared_memory.SharedMemory.__name__,    SharedMemory]
    - [shm_module,  multiprocessing.shared_memory.SharedMemory.__module__,  multiprocessing.shared_memory]
  invariant:
    kind: python_call_eq

invariants:
  - id: shm_base
    kind: python_call_eq
    function: "multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__"
    expected: object

table:
  id: shareablelist_identity
  columns: [id, function, expected]
  rows:
    - [sl_name,   multiprocessing.shared_memory.ShareableList.__name__,   ShareableList]
    - [sl_module, multiprocessing.shared_memory.ShareableList.__module__,  multiprocessing.shared_memory]
  invariant:
    kind: python_call_eq

invariants:
  - id: sl_base
    kind: python_call_eq
    function: "multiprocessing.shared_memory.ShareableList.__bases__[0].__name__"
    expected: object

table:
  id: sharedmemory_properties
  columns: [id, function, expected]
  rows:
    - [shm_name_prop, multiprocessing.shared_memory.SharedMemory.name.__class__.__name__, property]
    - [shm_size_prop, multiprocessing.shared_memory.SharedMemory.size.__class__.__name__, property]
    - [shm_buf_prop,  multiprocessing.shared_memory.SharedMemory.buf.__class__.__name__,  property]
  invariant:
    kind: python_call_eq
