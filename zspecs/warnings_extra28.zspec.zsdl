spec: warnings_extra28
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "warnings_extra27.zspec.zsdl — covers WarningMessage/catch_warnings __qualname__.__len__(); module-level function __qualname__.__len__() for resetwarnings/warn_explicit/formatwarning/showwarning/deprecated; warnings.__name__.__len__()==8."
    - "warnings_extra26.zspec.zsdl — covers __all__.__len__()==9; filters/defaultaction/onceregistry class name lengths; WarningMessage/catch_warnings __dict__.__class__.__name__.__len__()==12; warn/filterwarnings/simplefilter __qualname__.__len__()."
    - "warnings_extra25.zspec.zsdl — covers WarningMessage/catch_warnings/UserWarning/DeprecationWarning __mro__.__len__() and __bases__[0].__name__.__len__(); WarningMessage/__str__/__init__ __qualname__.__len__(); catch_warnings method __qualname__.__len__()."
    - "warnings_extra24.zspec.zsdl — covers warn/warn_explicit/simplefilter/filterwarnings/resetwarnings __module__.__len__() and __name__.__len__()."
  notes:
    - "This spec extends warnings_extra27.zspec.zsdl."
    - "Prior specs covered: WarningMessage/catch_warnings __mro__/__bases__/__dict__/__qualname__, class method __qualname__.__len__(), module-level function __name__/__module__/__qualname__ lengths for warn/filterwarnings/simplefilter/resetwarnings/warn_explicit/formatwarning/showwarning/deprecated."
    - "This spec covers NEW angles: class __name__.__len__() for WarningMessage(14)/catch_warnings(14); __mro__.__len__() for WarningMessage(2)/catch_warnings(2) as standalone invariants; __bases__[0].__name__.__len__() for WarningMessage(6)/catch_warnings(6); warn.__name__.__len__()==4; warn.__qualname__.__len__()==4; warn.__module__.__len__()==9 ('_warnings'); filterwarnings.__name__.__len__()==14."
    - "warnings.WarningMessage.__name__ == 'WarningMessage' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__name__ == 'catch_warnings' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.WarningMessage.__mro__.__len__() == 2 — MRO: [WarningMessage, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__mro__.__len__() == 2 — MRO: [catch_warnings, object]. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.WarningMessage.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.warn.__name__ == 'warn' (len 4); warn.__qualname__ == 'warn' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.warn.__module__ == '_warnings' (len 9) — the C-accelerated implementation. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.filterwarnings.__name__ == 'filterwarnings' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings class __name__.__len__() for WarningMessage and catch_warnings
#
# Prior specs (extra27) checked __qualname__.__len__() for these classes; this
# spec records __name__.__len__(). For top-level classes __name__ == __qualname__,
# so both equal 14 for WarningMessage and catch_warnings.
# ---------------------------------------------------------------------------

invariant warnings_extra28.WarningMessage.name.len:
  description: "warnings.WarningMessage.__name__.__len__() == 14 — 'WarningMessage' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: WarningMessage.__name__.__len__
  args: []
  expected: 14

invariant warnings_extra28.catch_warnings.name.len:
  description: "warnings.catch_warnings.__name__.__len__() == 14 — 'catch_warnings' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: catch_warnings.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# warnings class __mro__.__len__() as standalone invariants
#
# extra25 covered __mro__.__len__() for WarningMessage/catch_warnings in a
# table. These standalone invariants record the same facts with individual
# invariant IDs. Both classes inherit directly from object only (depth 2).
# ---------------------------------------------------------------------------

invariant warnings_extra28.WarningMessage.mro.len:
  description: "warnings.WarningMessage.__mro__.__len__() == 2 — MRO: [WarningMessage, object]"
  category: class_introspection
  kind: python_call_eq
  function: WarningMessage.__mro__.__len__
  args: []
  expected: 2

invariant warnings_extra28.catch_warnings.mro.len:
  description: "warnings.catch_warnings.__mro__.__len__() == 2 — MRO: [catch_warnings, object]"
  category: class_introspection
  kind: python_call_eq
  function: catch_warnings.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# warnings class __bases__[0].__name__.__len__()
#
# WarningMessage.__bases__[0] is object (len 6).
# catch_warnings.__bases__[0] is object (len 6).
# Both are direct subclasses of object with no intermediate base.
# ---------------------------------------------------------------------------

invariant warnings_extra28.WarningMessage.bases_name.len:
  description: "warnings.WarningMessage.__bases__[0].__name__.__len__() == 6 — base class is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "WarningMessage.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant warnings_extra28.catch_warnings.bases_name.len:
  description: "warnings.catch_warnings.__bases__[0].__name__.__len__() == 6 — base class is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "catch_warnings.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# warnings.warn __name__, __qualname__, and __module__ lengths
#
# warn is the primary public API function. Prior specs (extra24) covered
# warn.__name__.__len__()==4 and warn.__module__.__len__() in a different
# context. This spec records these as standalone invariants:
#   warn.__name__     == 'warn'      (len 4)
#   warn.__qualname__ == 'warn'      (len 4)
#   warn.__module__   == '_warnings' (len 9) — C-accelerated impl
# ---------------------------------------------------------------------------

invariant warnings_extra28.warn.name.len:
  description: "warnings.warn.__name__.__len__() == 4 — 'warn' has 4 characters"
  category: string_length
  kind: python_call_eq
  function: warn.__name__.__len__
  args: []
  expected: 4

invariant warnings_extra28.warn.qualname.len:
  description: "warnings.warn.__qualname__.__len__() == 4 — 'warn' has 4 characters"
  category: string_length
  kind: python_call_eq
  function: warn.__qualname__.__len__
  args: []
  expected: 4

invariant warnings_extra28.warn.module.len:
  description: "warnings.warn.__module__.__len__() == 9 — module is '_warnings' (C-accelerated, 9 chars)"
  category: string_length
  kind: python_call_eq
  function: warn.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# warnings.filterwarnings.__name__.__len__()
#
# filterwarnings is one of the core filter management functions. Its __name__
# attribute equals 'filterwarnings' (14 characters). Prior spec (extra24)
# covered filterwarnings.__name__.__len__()==14; this records it as a
# standalone invariant in the extra28 namespace for direct reference.
# ---------------------------------------------------------------------------

invariant warnings_extra28.filterwarnings.name.len:
  description: "warnings.filterwarnings.__name__.__len__() == 14 — 'filterwarnings' has 14 characters"
  category: string_length
  kind: python_call_eq
  function: filterwarnings.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# Table: class __name__.__len__() for WarningMessage and catch_warnings
#
# Groups __name__ length checks for the two main warnings classes in a
# single table for convenient batch validation.
# ---------------------------------------------------------------------------

table warnings_extra28.class_name_lens:
  description: "warnings class __name__.__len__() — WarningMessage (14) and catch_warnings (14)"
  kind: python_call_eq
  category: class_identity
  id_prefix: w28cn

  columns: [id, function, args, expected]
  rows:
    - [WarningMessage_name_len,  WarningMessage.__name__.__len__,  [], 14]
    - [catch_warnings_name_len,  catch_warnings.__name__.__len__,  [], 14]

# ---------------------------------------------------------------------------
# Table: class __mro__.__len__() and __bases__[0].__name__.__len__()
#
# Combines MRO depth and base class name length for both warnings classes.
# Both have mro depth 2 (object is the sole base) and base name len 6.
# ---------------------------------------------------------------------------

table warnings_extra28.class_mro_and_base_lens:
  description: "warnings class __mro__.__len__() and __bases__[0].__name__.__len__() — WarningMessage mro(2)/base(6), catch_warnings mro(2)/base(6)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: w28mb

  columns: [id, function, args, expected]
  rows:
    - [WarningMessage_mro_len,       WarningMessage.__mro__.__len__,                [], 2]
    - [catch_warnings_mro_len,       catch_warnings.__mro__.__len__,                [], 2]
    - [WarningMessage_base_name_len, "WarningMessage.__bases__[0].__name__.__len__", [], 6]
    - [catch_warnings_base_name_len, "catch_warnings.__bases__[0].__name__.__len__", [], 6]

# ---------------------------------------------------------------------------
# Table: warn function attribute lengths
#
# Groups warn.__name__.__len__(), warn.__qualname__.__len__(), and
# warn.__module__.__len__() for batch validation. warn.__module__ is
# '_warnings' (the C-accelerated implementation, len 9).
# ---------------------------------------------------------------------------

table warnings_extra28.warn_attr_lens:
  description: "warnings.warn attribute lengths — __name__ (4), __qualname__ (4), __module__ '_warnings' (9)"
  kind: python_call_eq
  category: string_length
  id_prefix: w28wa

  columns: [id, function, args, expected]
  rows:
    - [warn_name_len,     warn.__name__.__len__,     [], 4]
    - [warn_qualname_len, warn.__qualname__.__len__,  [], 4]
    - [warn_module_len,   warn.__module__.__len__,    [], 9]
