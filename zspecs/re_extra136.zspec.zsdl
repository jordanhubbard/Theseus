spec: re_extra136
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module-level wrapper functions (compile, fullmatch, match, search, findall, finditer, sub, subn, split, escape, purge) — __qualname__, __module__, __class__.__name__, co_argcount, and co_varnames.__len__() checks."
    - "All re module-level functions are pure Python wrappers defined in Lib/re/__init__.py, so __class__.__name__ == 'function' and __module__ == 're'."
    - "For module-level functions, __qualname__ == __name__ (no class prefix), unlike methods where qualname includes 'ClassName.'."
    - "re.compile.__qualname__ == 'compile' (length 7), co_argcount == 2 ('pattern', 'flags')."
    - "re.fullmatch.__qualname__ == 'fullmatch' (length 9), co_argcount == 3 ('pattern', 'string', 'flags')."
    - "re.match.__qualname__ == 'match' (length 5), co_argcount == 3."
    - "re.search.__qualname__ == 'search' (length 6), co_argcount == 3."
    - "re.findall.__qualname__ == 'findall' (length 7), co_argcount == 3."
    - "re.finditer.__qualname__ == 'finditer' (length 8), co_argcount == 3."
    - "re.sub.__qualname__ == 'sub' (length 3), co_argcount == 3, co_varnames.__len__() == 7."
    - "re.subn.__qualname__ == 'subn' (length 4), co_argcount == 3, co_varnames.__len__() == 7."
    - "re.split.__qualname__ == 'split' (length 5), co_argcount == 2, co_varnames.__len__() == 6."
    - "re.escape.__qualname__ == 'escape' (length 6), co_argcount == 1."
    - "re.purge.__qualname__ == 'purge' (length 5), co_argcount == 0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __qualname__ equality and lengths
# For module-level functions, __qualname__ == function name (no class prefix).
# compile (7), fullmatch (9), match (5), search (6), findall (7), finditer (8).
# ---------------------------------------------------------------------------

table re_extra136.re_function_qualnames_part1:
  description: "re module-level function __qualname__ string equality and lengths: compile=7, fullmatch=9, match=5, search=6, findall=7, finditer=8"
  kind: python_call_eq
  category: function_identity
  id_prefix: refunc136

  columns: [id, function, args, expected]
  rows:
    - [compile_qn_eq,    compile.__qualname__.__eq__,    ["compile"],   true]
    - [compile_qn_len,   compile.__qualname__.__len__,   [],            7]
    - [fullmatch_qn_eq,  fullmatch.__qualname__.__eq__,  ["fullmatch"], true]
    - [fullmatch_qn_len, fullmatch.__qualname__.__len__, [],            9]
    - [match_qn_eq,      match.__qualname__.__eq__,      ["match"],     true]
    - [match_qn_len,     match.__qualname__.__len__,     [],            5]
    - [search_qn_eq,     search.__qualname__.__eq__,     ["search"],    true]
    - [search_qn_len,    search.__qualname__.__len__,    [],            6]
    - [findall_qn_eq,    findall.__qualname__.__eq__,    ["findall"],   true]
    - [findall_qn_len,   findall.__qualname__.__len__,   [],            7]
    - [finditer_qn_eq,   finditer.__qualname__.__eq__,   ["finditer"],  true]
    - [finditer_qn_len,  finditer.__qualname__.__len__,  [],            8]

# ---------------------------------------------------------------------------
