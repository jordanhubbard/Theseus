# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra136.compile.qualname_eq:
  description: "re.compile.__qualname__ == 'compile' (length 7; module-level functions have __qualname__ == __name__, with no class prefix)"
  category: function_identity
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra136.compile.module_is_re:
  description: "re.compile.__module__ == 're' (length 2; all re module-level wrapper functions are defined in Lib/re/__init__.py and report module 're')"
  category: function_identity
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra136.compile.is_function:
  description: "re.compile.__class__.__name__ == 'function' (re module-level functions are pure Python wrapper functions, not C builtins or method_descriptors)"
  category: function_identity
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra136.sub.co_varnames_len_7:
  description: "re.sub.__code__.co_varnames.__len__() == 7 (locals: 'pattern', 'repl', 'string', 'count', 'flags', 'args', 'warnings')"
  category: function_code
  kind: python_call_eq
  function: sub.__code__.co_varnames.__len__
  args: []
  expected: 7

invariant re_extra136.purge.co_argcount_0:
  description: "re.purge.__code__.co_argcount == 0 (purge takes no arguments; it clears the compiled regex cache)"
  category: function_code
  kind: python_call_eq
  function: purge.__code__.co_argcount.__eq__
  args: [0]
  expected: true

