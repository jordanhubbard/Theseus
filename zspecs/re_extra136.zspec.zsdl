    - [subn_qn_len,    subn.__qualname__.__len__,      [],         4]
    - [split_qn_eq,    split.__qualname__.__eq__,     ["split"],  true]
    - [split_qn_len,   split.__qualname__.__len__,    [],         5]
    - [escape_qn_eq,   escape.__qualname__.__eq__,    ["escape"], true]
    - [escape_qn_len,  escape.__qualname__.__len__,   [],         6]
    - [purge_qn_eq,    purge.__qualname__.__eq__,     ["purge"],  true]
