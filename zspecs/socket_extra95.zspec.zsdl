spec: socket_extra95
version: ">=3.9"
backend: python_module(socket)
extends: socket_extra94

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values (pure-Python vs C builtins) / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/recv/send/etc. (table + invariants)."
    - "socket_extra92.zspec.zsdl — covers socket.socket class string identity / exception hierarchy / AddressFamily/SocketKind class identity (table + invariants)."
    - "socket_extra91.zspec.zsdl — covers socket module string identity cross-checks / socket.socket dunder method class names / socket constant class names and values (table + invariants)."
    - "socket_extra90.zspec.zsdl — covers socket.socket Python-level method __class__.__name__ identity (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra94; it does NOT duplicate invariants present in those files."
    - "Wave 258 theme: socket.AddressFamily and socket.SocketKind enum member values and names."
    - "socket.AF_UNSPEC.value == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.value == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.value == 30. Verified Python 3.14.3 macOS/Darwin 25.4.0. NOTE: macOS value is 30; Linux value is 10 — this is platform-specific."
    - "socket.AF_UNIX.value == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.name == 'AF_UNSPEC'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.name == 'AF_INET'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.name == 'AF_INET6'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.name == 'AF_UNIX'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.value == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.value == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.value == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_SEQPACKET.value == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.name == 'SOCK_STREAM'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.name == 'SOCK_DGRAM'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.name == 'SOCK_RAW'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_SEQPACKET.name == 'SOCK_SEQPACKET'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__class__.__name__ == 'list'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__len__() == 238. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.value == 0
# socket.AF_INET.value == 2
# socket.AF_INET6.value == 30   (macOS; Linux: 10)
# socket.AF_UNIX.value == 1
#
# Wave 258 theme: AddressFamily enum member values.
#
# socket.AddressFamily is an IntEnum wrapping the OS address family constants.
# AF_UNSPEC (0) means unspecified. AF_UNIX (1) is for UNIX domain sockets.
# AF_INET (2) is for IPv4. AF_INET6 (30) is for IPv6 on macOS/Darwin — Linux
# assigns 10. These values come from the OS headers via the _socket C extension.
# No prior socket spec anchors these four AF_* enum values together under
# socketenums95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra95.socket_af_enum_values:
  description: "socket.AF_UNSPEC/value.__eq__(0)==True / AF_INET/value.__eq__(2)==True / AF_INET6/value.__eq__(30)==True / AF_UNIX/value.__eq__(1)==True — AddressFamily is an IntEnum wrapping OS address family constants; AF_UNSPEC=0 (unspecified), AF_UNIX=1 (UNIX domain), AF_INET=2 (IPv4), AF_INET6=30 (IPv6 on macOS/Darwin — Linux assigns 10); values sourced from OS headers via _socket; no prior socket spec anchors these four AF_* enum values together; first socketenums95 anchor for AddressFamily enum values"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketenums95

  columns: [id, function, args, expected]
  rows:
    - [af_unspec_value, AF_UNSPEC.value.__eq__, [0],  true]
    - [af_inet_value,   AF_INET.value.__eq__,   [2],  true]
    - [af_inet6_value,  AF_INET6.value.__eq__,  [30], true]
    - [af_unix_value,   AF_UNIX.value.__eq__,   [1],  true]

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.name == 'AF_UNSPEC'
# socket.AF_INET.name == 'AF_INET'
# socket.AF_INET6.name == 'AF_INET6'
# socket.AF_UNIX.name == 'AF_UNIX'
#
# Wave 258 theme: AddressFamily enum member names.
#
# Each AddressFamily enum member's .name attribute returns the string name
# of the member as defined in the enum. These names are the canonical
# address family identifiers used in socket programming. They are guaranteed
# to be the same across all platforms (even if the .value differs).
# No prior socket spec anchors these four .name checks together under
# socketenums95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra95.socket_af_enum_names:
  description: "socket.AF_UNSPEC/name.__eq__('AF_UNSPEC')==True / AF_INET/name.__eq__('AF_INET')==True / AF_INET6/name.__eq__('AF_INET6')==True / AF_UNIX/name.__eq__('AF_UNIX')==True — the .name attribute of each AddressFamily member returns its canonical string identifier; names are platform-independent (even when .value differs across OSes); no prior socket spec anchors these four .name checks together; first socketenums95 anchor for AddressFamily enum member names"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketenums95

  columns: [id, function, args, expected]
  rows:
    - [af_unspec_name, AF_UNSPEC.name.__eq__, ["AF_UNSPEC"], true]
    - [af_inet_name,   AF_INET.name.__eq__,   ["AF_INET"],   true]
    - [af_inet6_name,  AF_INET6.name.__eq__,  ["AF_INET6"],  true]
    - [af_unix_name,   AF_UNIX.name.__eq__,   ["AF_UNIX"],   true]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.value == 1
# socket.SOCK_DGRAM.value == 2
# socket.SOCK_RAW.value == 3
# socket.SOCK_SEQPACKET.value == 5
#
# Wave 258 theme: SocketKind enum member values.
#
# socket.SocketKind is an IntEnum wrapping the OS socket type constants.
# SOCK_STREAM (1) is for TCP-like sequenced, reliable streams. SOCK_DGRAM (2)
# is for UDP-like connectionless datagrams. SOCK_RAW (3) provides access to
# raw network protocols. SOCK_SEQPACKET (5) is a reliable sequenced packet
# service. These values are stable across macOS and Linux for these four types.
# No prior socket spec anchors these four SOCK_* enum values together under
# socketenums95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra95.socket_sk_enum_values:
  description: "socket.SOCK_STREAM/value.__eq__(1)==True / SOCK_DGRAM/value.__eq__(2)==True / SOCK_RAW/value.__eq__(3)==True / SOCK_SEQPACKET/value.__eq__(5)==True — SocketKind is an IntEnum wrapping OS socket type constants; SOCK_STREAM=1 (TCP-like reliable stream), SOCK_DGRAM=2 (UDP-like datagram), SOCK_RAW=3 (raw protocol access), SOCK_SEQPACKET=5 (reliable sequenced packets); values stable across macOS and Linux; no prior socket spec anchors these four together; first socketenums95 anchor for SocketKind enum values"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketenums95

  columns: [id, function, args, expected]
  rows:
    - [sock_stream_value,    SOCK_STREAM.value.__eq__,    [1], true]
    - [sock_dgram_value,     SOCK_DGRAM.value.__eq__,     [2], true]
    - [sock_raw_value,       SOCK_RAW.value.__eq__,       [3], true]
    - [sock_seqpacket_value, SOCK_SEQPACKET.value.__eq__, [5], true]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.name == 'SOCK_STREAM'
# socket.SOCK_DGRAM.name == 'SOCK_DGRAM'
# socket.SOCK_RAW.name == 'SOCK_RAW'
# socket.SOCK_SEQPACKET.name == 'SOCK_SEQPACKET'
# socket.__all__.__class__.__name__ == 'list'
# socket.__all__.__len__() == 238
#
# Wave 258 theme: SocketKind enum member names + socket.__all__ class and length.
#
# Each SocketKind member's .name attribute returns its canonical string. The
# four SOCK_* names are the same on all platforms. socket.__all__ is a list
# (not a tuple) with 238 entries on macOS/Darwin 25.4.0 under Python 3.14.3.
# No prior socket spec anchors these together under socketenums95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra95.socket_sk_enum_names_and_all:
  description: "socket.SOCK_STREAM/name.__eq__('SOCK_STREAM')==True / SOCK_DGRAM/name.__eq__('SOCK_DGRAM')==True / SOCK_RAW/name.__eq__('SOCK_RAW')==True / SOCK_SEQPACKET/name.__eq__('SOCK_SEQPACKET')==True / __all__/__class__/__name__.__eq__('list')==True / __all__/__len__()==238 — SocketKind member names are platform-independent; socket.__all__ is a list with 238 entries on macOS/Darwin 25.4.0; no prior socket spec anchors these together; first socketenums95 anchor for SocketKind names and __all__ class/length"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketenums95

  columns: [id, function, args, expected]
  rows:
    - [sock_stream_name,    SOCK_STREAM.name.__eq__,         ["SOCK_STREAM"],    true]
    - [sock_dgram_name,     SOCK_DGRAM.name.__eq__,          ["SOCK_DGRAM"],     true]
    - [sock_raw_name,       SOCK_RAW.name.__eq__,            ["SOCK_RAW"],       true]
    - [sock_seqpacket_name, SOCK_SEQPACKET.name.__eq__,      ["SOCK_SEQPACKET"], true]
    - [all_class_name,      __all__.__class__.__name__.__eq__, ["list"],          true]
    - [all_len,             __all__.__len__,                 [],                 238]

# ---------------------------------------------------------------------------
# socket.AF_INET.value.__eq__(2) — standalone
#
# socket.AF_INET.value is 2. AF_INET (Address Family Internet) is the address
# family for IPv4 sockets. Its value of 2 is consistent across all major
# POSIX platforms (macOS, Linux, FreeBSD). AF_INET is by far the most
# commonly used address family in network programming. No prior socket spec
# anchors AF_INET.value.__eq__(2) as a standalone under socketenums95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra95.af_inet_value_is_2:
  description: "socket.AF_INET.value.__eq__(2) == True — AF_INET is the address family for IPv4 sockets; its value is 2, consistent across all major POSIX platforms; it is the most commonly used address family in network programming; no prior socket spec anchors this as a standalone; first standalone for AF_INET.value under socketenums95"
  category: module_identity
  kind: python_call_eq
  function: AF_INET.value.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNIX.name.__eq__('AF_UNIX') — standalone
#
# socket.AF_UNIX.name is 'AF_UNIX'. AF_UNIX is the address family for UNIX
# domain sockets — inter-process communication on the same machine without
# going through the network stack. Its enum .name attribute is 'AF_UNIX',
# which is the same on all platforms that support it. No prior socket spec
# anchors AF_UNIX.name.__eq__ as a standalone under socketenums95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra95.af_unix_name:
  description: "socket.AF_UNIX.name.__eq__('AF_UNIX') == True — AF_UNIX is the address family for UNIX domain sockets (IPC on the same machine); its .name is 'AF_UNIX', platform-independent; no prior socket spec anchors this as a standalone; first standalone for AF_UNIX.name under socketenums95"
  category: module_identity
  kind: python_call_eq
  function: AF_UNIX.name.__eq__
  args: ["AF_UNIX"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.value.__eq__(1) — standalone
#
# socket.SOCK_STREAM.value is 1. SOCK_STREAM is the socket type for reliable,
# ordered, bidirectional byte-stream connections (used by TCP). Its value of 1
# is consistent across macOS and Linux. It is the most widely used socket type.
# No prior socket spec anchors SOCK_STREAM.value.__eq__(1) as a standalone
# under socketenums95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra95.sock_stream_value_is_1:
  description: "socket.SOCK_STREAM.value.__eq__(1) == True — SOCK_STREAM is the socket type for reliable ordered byte-stream connections (TCP); its value is 1, consistent across macOS and Linux; it is the most widely used socket type; no prior socket spec anchors this as a standalone; first standalone for SOCK_STREAM.value under socketenums95"
  category: module_identity
  kind: python_call_eq
  function: SOCK_STREAM.value.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_DGRAM.name.__eq__('SOCK_DGRAM') — standalone
#
# socket.SOCK_DGRAM.name is 'SOCK_DGRAM'. SOCK_DGRAM is the socket type for
# connectionless, unreliable datagrams (used by UDP). Its .name attribute is
# the canonical string 'SOCK_DGRAM'. No prior socket spec anchors
# SOCK_DGRAM.name.__eq__ as a standalone under socketenums95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra95.sock_dgram_name:
  description: "socket.SOCK_DGRAM.name.__eq__('SOCK_DGRAM') == True — SOCK_DGRAM is the socket type for connectionless datagram sockets (UDP); its .name is 'SOCK_DGRAM'; no prior socket spec anchors this as a standalone; first standalone for SOCK_DGRAM.name under socketenums95"
  category: module_identity
  kind: python_call_eq
  function: SOCK_DGRAM.name.__eq__
  args: ["SOCK_DGRAM"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__all__.__class__.__name__.__eq__('list') — standalone
#
# socket.__all__.__class__.__name__ is 'list'. socket defines __all__ as a
# list (not a tuple, unlike hashlib which uses a tuple). This list enumerates
# the public API surface of the socket module. No prior socket spec anchors
# __all__.__class__.__name__.__eq__('list') as a standalone under socketenums95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra95.all_class_name_list:
  description: "socket.__all__.__class__.__name__.__eq__('list') == True — socket defines __all__ as a list (not a tuple) enumerating the module's public API; this differs from hashlib which uses a tuple; no prior socket spec anchors this as a standalone; first standalone for socket.__all__ class name under socketenums95"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true
