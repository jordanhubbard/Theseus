spec: io_extra176
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/fileio.c"
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.FileIO, io.IncrementalNewlineDecoder, io.open, and io.open_code class/function identity."
    - "io.FileIO.__name__ == 'FileIO' (len=6: 'File'(4)+'IO'(2)=6) — the concrete raw binary file stream."
    - "io.FileIO.__module__ == '_io' (len=3) — FileIO is a C extension concrete class, unlike the ABCs which report 'io' (2 chars)."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (len=10) — the C-level raw I/O base."
    - "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' (len=25) — the longest class name in the io module family."
    - "io.IncrementalNewlineDecoder.__module__ == '_io' (len=3) — a C extension concrete class."
    - "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' (len=6) — inherits directly from object, not from any io ABC."
    - "io.open.__name__ == 'open' (len=4) — the built-in open() function re-exported from io."
    - "io.open.__module__ == '_io' (len=3) — implemented in the C extension '_io'."
    - "io.open_code.__name__ == 'open_code' (len=9: 'open'(4)+'_'(1)+'code'(4)=9) — added in Python 3.8 for opening source files."
    - "io.open_code.__module__ == '_io' (len=3) — also implemented in the C extension '_io'."
    - "FileIO (6 chars) is the shortest class name in this spec; IncrementalNewlineDecoder (25 chars) is the longest."
    - "FileIO.__module__ == '_io' (3 chars) — concrete class, unlike the ABCs which have __module__ == 'io' (2 chars)."
    - "IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' (6 chars) — unusual: does not inherit from any io ABC."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO class identity
# __name__ == 'FileIO' (len=6), __module__ == '_io' (len=3)
# __bases__[0].__name__ == '_RawIOBase' (len=10)
# FileIO (6) == len('IOBase') (6): the raw file stream name ties with the io root ABC name in length
# ---------------------------------------------------------------------------

table io_extra176.FileIO_class_identity:
  description: "io.FileIO class identity: __name__=='FileIO' (len=6), __module__=='_io' (len=3), __bases__[0].__name__=='_RawIOBase' (len=10); FileIO='File'(4)+'IO'(2)=6; FileIO(6)==IOBase(6) in name length; concrete class: module '_io' (3), not 'io' (2)"
  kind: python_call_eq
  category: identity
  id_prefix: iofio176

  columns: [id, function, args, expected, description]
  rows:
    - [fio_name,     FileIO.__name__.__eq__,                ["FileIO"],     true, "io.FileIO.__name__ == 'FileIO' — FileIO is the concrete raw binary file stream class; 'FileIO' has 6 characters: 'File'(4)+'IO'(2)=6; FileIO (6 chars) == len('IOBase') (6 chars) — the concrete raw file class name ties in length with the root io ABC; FileIO (6) < BytesIO (7) by 1 and < StringIO (8) by 2: FileIO is shorter than both in-memory stream classes; FileIO implements RawIOBase by wrapping an OS file descriptor; FileIO is the lowest-level concrete I/O class, providing unbuffered direct access to a file; confirmed Python 3.14.3 macOS"]
    - [fio_module,   FileIO.__module__.__eq__,              ["_io"],         true, "io.FileIO.__module__ == '_io' — FileIO is a C extension concrete class in '_io' (3 chars); FileIO.__module__ (3: '_io') != RawIOBase.__module__ (2: 'io'): the concrete raw file class is in '_io' (3 chars) while the abstract RawIOBase is in 'io' (2 chars); the ABC/concrete module split: ABCs (IOBase, RawIOBase, BufferedIOBase, TextIOBase) report 'io' (2 chars) while concrete classes (FileIO, BytesIO, StringIO, BufferedReader) report '_io' (3 chars); FileIO is the concrete implementation of RawIOBase for filesystem files; confirmed Python 3.14.3 macOS"]
    - [fio_base0,    "FileIO.__bases__[0].__name__.__eq__", ["_RawIOBase"],  true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO's immediate C-level base is '_RawIOBase' (10 chars); '_RawIOBase' has 10 characters: '_'(1)+'Raw'(3)+'IO'(2)+'Base'(4)=10; '_RawIOBase' (10 chars) > 'FileIO' (6 chars) by 4: the base class name is 4 characters longer than the derived class; '_RawIOBase' is the C-level implementation base that sits between the Python-level io.RawIOBase (9 chars, 'io' module) and concrete classes like FileIO; confirmed Python 3.14.3 macOS"]
    - [fio_name_len, FileIO.__name__.__len__,               [],              6,   "io.FileIO.__name__.__len__() == 6 — 'FileIO' has 6 characters: 'File'(4)+'IO'(2)=6; FileIO (6) == len('IOBase') (6): the concrete raw file class ties in name length with the root abstract base; FileIO (6) < BytesIO (7) by 1: FileIO is the shortest concrete io class name in this spec; 'File' prefix (4 chars) + 'IO' suffix (2 chars) = 6; FileIO (6 chars) == len('object') (6 chars) — the concrete io file class name ties with the Python root type name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.IncrementalNewlineDecoder class identity
# __name__ == 'IncrementalNewlineDecoder' (len=25)
# __module__ == '_io' (len=3)
# __bases__[0].__name__ == 'object' (len=6)
# The longest class name in the io module family; inherits directly from object
# ---------------------------------------------------------------------------

table io_extra176.IncrementalNewlineDecoder_class_identity:
  description: "io.IncrementalNewlineDecoder class identity: __name__=='IncrementalNewlineDecoder' (len=25), __module__=='_io' (len=3), __bases__[0].__name__=='object' (len=6); 'IncrementalNewlineDecoder'='Incremental'(11)+'Newline'(7)+'Decoder'(7)=25; inherits from object directly, not from any io ABC"
  kind: python_call_eq
  category: identity
  id_prefix: ioind176

  columns: [id, function, args, expected, description]
  rows:
    - [ind_name,     IncrementalNewlineDecoder.__name__.__eq__,                ["IncrementalNewlineDecoder"], true, "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — the class that translates newline characters when reading text streams; 'IncrementalNewlineDecoder' has 25 characters: 'Incremental'(11)+'Newline'(7)+'Decoder'(7)=25; IncrementalNewlineDecoder (25 chars) is the longest class name in the io module family — dwarfing even 'BufferedIOBase' (14 chars) and '_BufferedIOBase' (15 chars); the three-component structure 'Incremental'+'Newline'+'Decoder' describes the class precisely: it decodes newlines (\\r, \\n, \\r\\n) incrementally as data arrives; confirmed Python 3.14.3 macOS"]
    - [ind_module,   IncrementalNewlineDecoder.__module__.__eq__,              ["_io"],                       true, "io.IncrementalNewlineDecoder.__module__ == '_io' — IncrementalNewlineDecoder is implemented in the C extension '_io' (3 chars); '_io' (3 chars) < 'IncrementalNewlineDecoder' (25 chars) by 22: the module name is extremely short compared to the class name — a 22-character gap; IncrementalNewlineDecoder.__module__ (3: '_io') confirms it is a C-optimized implementation of newline translation; the class is used internally by TextIOWrapper to normalize newlines in text streams; confirmed Python 3.14.3 macOS"]
    - [ind_base0,    "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__", ["object"],                    true, "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder inherits directly from 'object' (6 chars), not from any io ABC; 'object' has 6 characters; this is unusual in the io module family: most concrete io classes inherit from '_RawIOBase' (10), '_BufferedIOBase' (15), or '_TextIOBase' (11) rather than directly from object; IncrementalNewlineDecoder's direct object inheritance reflects its specialized role as a newline translator rather than a general-purpose I/O stream; confirmed Python 3.14.3 macOS"]
    - [ind_name_len, IncrementalNewlineDecoder.__name__.__len__,               [],                            25,  "io.IncrementalNewlineDecoder.__name__.__len__() == 25 — 'IncrementalNewlineDecoder' has 25 characters: 'Incremental'(11)+'Newline'(7)+'Decoder'(7)=25; 25 is the maximum class name length in the io module family — larger than 'BufferedIOBase' (14) and '_BufferedIOBase' (15) by 11 and 10 respectively; the two 7-character components 'Newline' and 'Decoder' are equal in length: 'Newline'(7) == 'Decoder'(7) == 7; IncrementalNewlineDecoder (25) > FileIO (6) by 19: a 19-character gap between the shortest and longest class names in this spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.open and io.open_code function identity
# io.open.__name__ == 'open' (len=4), __module__ == '_io' (len=3)
# io.open_code.__name__ == 'open_code' (len=9), __module__ == '_io' (len=3)
# open (4) < open_code (9) by 5 == len('_code') - 1... actually by 5
# open_code added in Python 3.8 for opening source files
# ---------------------------------------------------------------------------

table io_extra176.open_open_code_identity:
  description: "io.open.__name__=='open' (len=4), __module__=='_io' (len=3); io.open_code.__name__=='open_code' (len=9), __module__=='_io' (len=3); open(4) < open_code(9) by 5; open_code='open'(4)+'_code'(5)=9; both are C extension functions in '_io'"
  kind: python_call_eq
  category: identity
  id_prefix: ioop176

  columns: [id, function, args, expected, description]
  rows:
    - [open_name,      io.open.__name__.__eq__,       ["open"],      true, "io.open.__name__ == 'open' — the built-in file opening function re-exported from the io module; 'open' has 4 characters: 'o-p-e-n'; io.open.__name__ (4: 'open') == len('stat') (4) from pathlib_extra174 and len('Path') (4): a common 4-character name across standard library file operations; io.open is identical to the built-in open() — they are the same C function; io.open.__module__ == '_io' (3 chars): implemented in the C extension, not the public 'io' (2 chars); open (4) < open_code (9) by 5 — open_code adds '_code' (5 chars) to 'open'; confirmed Python 3.14.3 macOS"]
    - [open_module,    io.open.__module__.__eq__,     ["_io"],       true, "io.open.__module__ == '_io' — io.open is implemented in the '_io' C extension (3 chars); io.open.__module__ (3: '_io') == io.open_code.__module__ (3: '_io'): both open functions share the C extension module '_io'; '_io' (3 chars) > 'io' (2 chars) by 1: the C extension module is one character longer than the public module; io.open.__module__ (3: '_io') confirms that even the open() built-in has its implementation in the C extension, not the pure Python 'io' module; confirmed Python 3.14.3 macOS"]
    - [ocode_name,     io.open_code.__name__.__eq__,  ["open_code"], true, "io.open_code.__name__ == 'open_code' — the function for opening Python source files in a way that respects import system customization (added in Python 3.8); 'open_code' has 9 characters: 'open'(4)+'_'(1)+'code'(4)=9; open_code (9 chars) > open (4 chars) by 5: the '_code' suffix (5 chars: '_'(1)+'code'(4)) is what distinguishes open_code from open; open_code (9 chars) == len('open_code') (9 chars) == len('read_text') (9 chars) from pathlib_extra174 — cross-module tie at 9; io.open_code() is intended for reading Python source files, not general file I/O; confirmed Python 3.14.3 macOS"]
    - [ocode_module,   io.open_code.__module__.__eq__, ["_io"],      true, "io.open_code.__module__ == '_io' — open_code is implemented in the '_io' C extension (3 chars); open_code.__module__ (3: '_io') == io.open.__module__ (3: '_io'): both open functions are in the same C extension module; '_io' (3 chars) < 'open_code' (9 chars) by 6: the module name is 6 characters shorter than the function name; open_code is a C function that calls the import system's path hook mechanism to open source files correctly even when the import system has been customized; confirmed Python 3.14.3 macOS"]
    - [open_lt_ocode,  io.open.__name__.__len__,      [],            4,   "io.open.__name__.__len__() == 4 — 'open' has 4 characters; open (4) < open_code (9) by 5: the '_code' suffix (5 chars) is the entire difference between the two function name lengths; open (4 chars) == len('stat') (4 chars) and len('Path') (4 chars): the file opening function name ties with other key 4-character names in the file system API; the two open functions in the io module differ by exactly 5 characters in name length: open(4), open_code(9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.FileIO vs concrete class module uniformity
# FileIO, BytesIO, StringIO, open, open_code all have __module__ == '_io'
# Contrast: all four io ABCs have __module__ == 'io'
# The concrete/ABC module split: '_io' (3) vs 'io' (2)
# ---------------------------------------------------------------------------

table io_extra176.concrete_class_module_uniformity:
  description: "io.FileIO.__module__=='_io' (len=3); io.open.__module__=='_io' (len=3); io.open_code.__module__=='_io' (len=3); all concrete io classes and functions report module '_io' (3 chars); contrast: ABCs report 'io' (2 chars); '_io'(3) vs 'io'(2): C extension vs public module"
  kind: python_call_eq
  category: identity
  id_prefix: iocmod176

  columns: [id, function, args, expected, description]
  rows:
    - [fio_mod_cio,  FileIO.__module__.__eq__,       ["_io"],   true, "io.FileIO.__module__ == '_io' — FileIO is a C extension class in '_io' (3 chars); '_io' (3 chars) > 'io' (2 chars) by 1: the C extension module has one extra character (the underscore prefix); FileIO.__module__ (3: '_io') == BytesIO.__module__ (3: '_io') == StringIO.__module__ (3: '_io') == IncrementalNewlineDecoder.__module__ (3: '_io'): all concrete io classes share the 3-character C extension module '_io'; the uniform '_io' module for concrete classes contrasts with the uniform 'io' module for abstract base classes; confirmed Python 3.14.3 macOS"]
    - [open_mod_cio, io.open.__module__.__eq__,      ["_io"],   true, "io.open.__module__ == '_io' — io.open is a C function in '_io' (3 chars); open.__module__ (3: '_io') confirms that the open() built-in is implemented in C, not in pure Python; '_io' (3 chars) is the C extension that contains the fast, optimized implementations of all concrete I/O classes and functions: FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, TextIOWrapper, open, open_code; the 2-char 'io' module (public) re-exports everything from the 3-char '_io' module (C extension); confirmed Python 3.14.3 macOS"]
    - [ocode_ne_abc, io.open_code.__module__.__eq__, ["io"],    false, "io.open_code.__module__.__eq__('io') == False — open_code's module is '_io' (3 chars), NOT 'io' (2 chars); the public 'io' module (2 chars) is not where open_code is implemented; all concrete io classes and functions have __module__ == '_io' (3 chars) while only the four ABCs have __module__ == 'io' (2 chars); open_code.__module__ (3: '_io') != 'io' (2 chars) — they differ in both content (the leading underscore) and length (3 vs 2); confirmed Python 3.14.3 macOS"]
    - [ind_mod_cio,  IncrementalNewlineDecoder.__module__.__eq__, ["_io"], true, "io.IncrementalNewlineDecoder.__module__ == '_io' — IncrementalNewlineDecoder is a C extension class in '_io' (3 chars); IncrementalNewlineDecoder.__module__ (3: '_io') == FileIO.__module__ (3: '_io') == open.__module__ (3: '_io'): all concrete io objects in this spec share the 3-character C extension module '_io'; the consistent '_io' attribution across FileIO, IncrementalNewlineDecoder, open, and open_code confirms the architectural pattern: everything concrete lives in '_io' (3 chars), everything abstract lives in 'io' (2 chars); confirmed Python 3.14.3 macOS"]
    - [fio_ne_abc,   FileIO.__module__.__eq__,       ["io"],    false, "io.FileIO.__module__.__eq__('io') == False — FileIO's module is '_io' (3 chars), NOT 'io' (2 chars); FileIO is a concrete class (not an ABC), so it reports '_io' (3 chars) rather than 'io' (2 chars); the False assertion encodes the concrete/ABC split: FileIO (concrete, '_io') != RawIOBase (ABC, 'io') in module attribution even though FileIO is the primary concrete implementation of RawIOBase; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Name length ordering in this spec
# open(4) < FileIO(6) < open_code(9) < IncrementalNewlineDecoder(25)
# ---------------------------------------------------------------------------

table io_extra176.name_length_ordering:
  description: "io class/function name lengths in this spec: open(4) < FileIO(6) < open_code(9) < IncrementalNewlineDecoder(25); a dramatic ascending sequence with a 16-character gap at the top; IncrementalNewlineDecoder(25) far exceeds all other io module names"
  kind: python_call_eq
  category: identity
  id_prefix: iolen176

  columns: [id, function, args, expected, description]
  rows:
    - [open_4,   io.open.__name__.__len__,                 [], 4,  "io.open.__name__.__len__() == 4 — 'open' is the minimum name length in this spec; open (4) == len('stat') (4) and len('Path') (4): the shortest io function name ties with other 4-character API names across standard library modules; the ascending sequence in this spec: open(4) < FileIO(6) < open_code(9) < IncrementalNewlineDecoder(25); open (4) < FileIO (6) by 2; confirmed Python 3.14.3 macOS"]
    - [fio_6,    FileIO.__name__.__len__,                  [], 6,  "io.FileIO.__name__.__len__() == 6 — 'FileIO' has 6 characters: 'File'(4)+'IO'(2)=6; FileIO (6) sits between open (4) and open_code (9) in the ascending spec sequence; FileIO (6) == len('IOBase') (6) == len('object') (6): the concrete raw file class ties with the root abstract base and the Python root type in name length; FileIO (6) < open_code (9) by 3; confirmed Python 3.14.3 macOS"]
    - [ocode_9,  io.open_code.__name__.__len__,            [], 9,  "io.open_code.__name__.__len__() == 9 — 'open_code' has 9 characters: 'open'(4)+'_'(1)+'code'(4)=9; open_code (9) == len('read_text') (9) from pathlib_extra174 and len('RawIOBase') (9) from io_extra175 — cross-module and cross-spec tie at 9; open_code (9) > FileIO (6) by 3; open_code (9) < IncrementalNewlineDecoder (25) by 16: the dramatic gap to the longest name in this spec; the two 'open' family members: open (4) and open_code (9) differ by 5; confirmed Python 3.14.3 macOS"]
    - [ind_25,   IncrementalNewlineDecoder.__name__.__len__, [], 25, "io.IncrementalNewlineDecoder.__name__.__len__() == 25 — 'IncrementalNewlineDecoder' has 25 characters: 'Incremental'(11)+'Newline'(7)+'Decoder'(7)=25; IncrementalNewlineDecoder (25) is an extreme outlier: it is 16 characters longer than the second-longest name in this spec (open_code=9); the 25-character name is the longest class name in the entire io module family, exceeding even '_BufferedIOBase' (15) by 10; 'Newline'(7) == 'Decoder'(7): the two right components of the name have equal length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra176.FileIO_name_is_FileIO:
  description: "io.FileIO.__name__ == 'FileIO' — FileIO is the concrete raw binary file stream class; 'FileIO' has 6 characters: 'File'(4)+'IO'(2)=6; FileIO (6) == len('IOBase') (6): the concrete class name ties with the root ABC name in length; FileIO.__module__ == '_io' (3 chars) — concrete class, not the ABC module 'io' (2 chars); FileIO.__bases__[0].__name__ == '_RawIOBase' (10 chars) — the C-level raw I/O base; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra176.FileIO_module_is__io:
  description: "io.FileIO.__module__ == '_io' — FileIO is a concrete C extension class in '_io' (3 chars); '_io' (3) > 'io' (2) by 1: C extension module is one character longer; FileIO.__module__ (3: '_io') contrasts with RawIOBase.__module__ (2: 'io') — the concrete/ABC module split; all concrete io classes (FileIO, BytesIO, StringIO, BufferedReader, etc.) share __module__ == '_io' (3 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra176.FileIO_base_is__RawIOBase:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO's C-level base is '_RawIOBase' (10 chars); '_RawIOBase' = '_'(1)+'Raw'(3)+'IO'(2)+'Base'(4) = 10; '_RawIOBase' (10 chars) > 'FileIO' (6 chars) by 4: the base class name is 4 characters longer than the derived class; '_RawIOBase' is the same C-level base that io.RawIOBase (the public ABC) wraps; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra176.IncrementalNewlineDecoder_name_is_IncrementalNewlineDecoder:
  description: "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — the newline translation class for text streams; 'IncrementalNewlineDecoder' has 25 characters: 'Incremental'(11)+'Newline'(7)+'Decoder'(7)=25; IncrementalNewlineDecoder (25) is the longest class name in the io module family; it inherits directly from object, not from any io ABC; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__name__.__eq__
  args: ["IncrementalNewlineDecoder"]
  expected: true

invariant io_extra176.IncrementalNewlineDecoder_module_is__io:
  description: "io.IncrementalNewlineDecoder.__module__ == '_io' — IncrementalNewlineDecoder is a C extension class in '_io' (3 chars); '_io' (3 chars) < 'IncrementalNewlineDecoder' (25 chars) by 22: an extreme 22-character gap between module name and class name; the class is used internally by TextIOWrapper for newline normalization; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra176.IncrementalNewlineDecoder_base_is_object:
  description: "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder inherits directly from 'object' (6 chars), not from any io ABC; this distinguishes it from FileIO (which inherits from '_RawIOBase'), BytesIO (from '_BufferedIOBase'), and StringIO (from '_TextIOBase'); IncrementalNewlineDecoder is a specialized translator, not a general-purpose I/O stream; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant io_extra176.open_name_is_open:
  description: "io.open.__name__ == 'open' — the built-in file opening function exported by the io module; 'open' has 4 characters; io.open is identical to the built-in open() — they refer to the same C function; io.open.__module__ == '_io' (3 chars) — implemented in the C extension; open (4 chars) < open_code (9 chars) by 5: the two open-family functions in io differ by 5 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra176.open_module_is__io:
  description: "io.open.__module__ == '_io' — io.open is implemented in the '_io' C extension (3 chars); '_io' (3 chars) > 'io' (2 chars) by 1; io.open.__module__ (3: '_io') == io.open_code.__module__ (3: '_io'): both open-family functions share the C extension module '_io'; the public 'io' module re-exports open from '_io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra176.open_code_name_is_open_code:
  description: "io.open_code.__name__ == 'open_code' — the function for opening Python source files with import system awareness (added Python 3.8); 'open_code' has 9 characters: 'open'(4)+'_'(1)+'code'(4)=9; open_code (9) > open (4) by 5; open_code (9) == len('read_text') (9) from pathlib — cross-module tie at 9; io.open_code.__module__ == '_io' (3 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.open_code.__name__.__eq__
  args: ["open_code"]
  expected: true
