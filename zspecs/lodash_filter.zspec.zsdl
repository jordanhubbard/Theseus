spec: lodash_filter
version: ">=4.0.0"
backend: node(lodash.filter)

docs: https://lodash.com/docs/#filter

provenance:
  derived_from:
    - "lodash.filter README — https://www.npmjs.com/package/lodash.filter"
    - "Test vectors verified with lodash.filter@4.7.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.filter exports the _.filter function directly as module.exports."
    - "filter(collection, predicate) returns elements matching the predicate."
    - "Object predicate uses match shorthand: includes elements where all given properties match."
    - "String predicate returns elements where that property is truthy."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns filtered array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_filter.filter:
  kind: node_module_call_eq
  function: ~
  category: filter
  id_prefix: lflt

  columns: [id, args, expected]
  rows:
    - [by_obj,   [[{"n": 1, "x": "a"}, {"n": 2, "x": "b"}, {"n": 1, "x": "c"}], {"n": 1}],
       [{"n": 1, "x": "a"}, {"n": 1, "x": "c"}]]
    - [by_prop,  [[{"active": true, "n": "a"}, {"active": false, "n": "b"}, {"active": true, "n": "c"}], "active"],
       [{"active": true, "n": "a"}, {"active": true, "n": "c"}]]

