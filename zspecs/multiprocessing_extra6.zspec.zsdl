spec: multiprocessing_extra6
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl, multiprocessing_extra.zspec.zsdl, multiprocessing_extra2.zspec.zsdl, multiprocessing_extra3.zspec.zsdl, multiprocessing_extra4.zspec.zsdl, multiprocessing_extra5.zspec.zsdl."
    - "multiprocessing_extra5 covers __qualname__ for: Process, Pool, Manager, Pipe, Lock, Queue, Value, Array, ProcessError, AuthenticationError, TimeoutError."
    - "multiprocessing_extra4 covers Process.__module__ == 'multiprocessing.process'."
    - "This spec adds __qualname__ for the remaining requested symbols: Event, Semaphore, current_process, active_children, cpu_count — not previously covered."
    - "multiprocessing.Event.__qualname__ == 'Event' — top-level synchronization primitive."
    - "multiprocessing.Semaphore.__qualname__ == 'Semaphore' — top-level synchronization primitive."
    - "multiprocessing.current_process.__qualname__ == 'current_process' — module-level function."
    - "multiprocessing.active_children.__qualname__ == 'active_children' — module-level function."
    - "multiprocessing.cpu_count.__qualname__ == 'cpu_count' — module-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table for remaining multiprocessing synchronization classes
#
# Event and Semaphore were not included in multiprocessing_extra5.
# For top-level (non-nested) classes, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table multiprocessing_extra6.sync_qualnames:
  description: "Remaining multiprocessing synchronization classes have correct __qualname__"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Event,     Event.__qualname__.__eq__,     ["Event"],     true]
    - [Semaphore, Semaphore.__qualname__.__eq__, ["Semaphore"], true]

# ---------------------------------------------------------------------------
# __qualname__ for multiprocessing module-level functions
#
# current_process, active_children, and cpu_count are ordinary Python
# functions at module scope; their __qualname__ equals their __name__.
# Prior specs checked __name__; this spec adds __qualname__.
# ---------------------------------------------------------------------------

table multiprocessing_extra6.function_qualnames:
  description: "multiprocessing module-level functions have correct __qualname__"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [current_process, current_process.__qualname__.__eq__, ["current_process"], true]
    - [active_children, active_children.__qualname__.__eq__, ["active_children"], true]
    - [cpu_count,       cpu_count.__qualname__.__eq__,       ["cpu_count"],       true]
