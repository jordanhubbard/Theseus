spec: enum_extra35
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra34.zspec.zsdl."
    - "Prior specs covered: Enum/IntEnum/Flag/IntFlag/StrEnum/EnumType __name__/__module__/__qualname__/__mro__/__bases__[0].__name__/__dict__.__class__.__name__.__len__(); all __mro__.__len__() values; Enum dunder method __qualname__.__len__() for __new__/__str__/__repr__/__hash__/__format__; EnumType method __qualname__.__len__() for __call__/__prepare__/__repr__/__setattr__/__delattr__/__iter__/__new__/__getitem__; Enum._missing_ (14) and _generate_next_value_ (26) qualname lengths; helper symbol qualname lens (auto/unique/member/nonmember); enum.__all__.__len__()==30; EnumType.__bases__[0].__name__.__len__()==4; IntEnum.__bases__[0].__name__.__len__()==3; Flag.__bases__[0].__name__.__len__()==4."
    - "This spec covers NEW angles: Enum.__reduce_ex__ (18), Enum.__copy__ (13), Enum.__deepcopy__ (17), Enum.__dir__ (12), Enum._add_alias_ (16), Enum._add_value_alias_ (22), Enum.__init_subclass__ (22) qualname lengths; EnumType._check_for_existing_members_ (37), EnumType.__init_subclass__ (26), EnumType.__subclasshook__ (25), EnumType._find_data_repr_ (25), EnumType._find_data_type_ (25), EnumType._get_mixins_ (21), EnumType._add_member_ (21), EnumType._find_new_ (19), EnumType._convert_ (18), EnumType._create_ (17), EnumType.__bool__ (17), EnumType.__len__ (16), EnumType.__dir__ (16) qualname lengths."
    - "Python 3.14 SURPRISE: IntFlag.__mro__.__len__() == 6 (not 5 as in prior docs). MRO is: IntFlag, int, ReprEnum, Flag, Enum, object. ReprEnum is now an explicit MRO member."
    - "Python 3.14 SURPRISE: IntEnum.__mro__.__len__() == 5. MRO is: IntEnum, int, ReprEnum, Enum, object. ReprEnum appears."
    - "Python 3.14 SURPRISE: StrEnum.__mro__.__len__() == 5. MRO is: StrEnum, str, ReprEnum, Enum, object."
    - "EnumType._check_for_existing_members_.__qualname__ == 'EnumType._check_for_existing_members_' (len=37) — the longest method qualname found in the entire enum spec series so far."
    - "Enum._add_value_alias_.__qualname__ == 'Enum._add_value_alias_' (len=22) — tied with Enum.__init_subclass__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Enum instance-method __qualname__.__len__() table (extra35 namespace)
#
# These eight Enum methods appear directly in Enum.__dict__ and have not
# been recorded in any prior spec:
#   __reduce_ex__         -> 'Enum.__reduce_ex__'         (18)
#   __deepcopy__          -> 'Enum.__deepcopy__'          (17)
#   _add_alias_           -> 'Enum._add_alias_'           (16)
#   __copy__              -> 'Enum.__copy__'              (13)
#   __dir__               -> 'Enum.__dir__'               (12)
#   _add_value_alias_     -> 'Enum._add_value_alias_'     (22)
#   __init_subclass__     -> 'Enum.__init_subclass__'     (22)
# No prior enum spec records any of these in the extra35 namespace.
# ---------------------------------------------------------------------------

table enum_extra35.Enum_instance_method_qualname_lens:
  description: "__qualname__.__len__() for Enum instance methods not previously covered"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: Enum_inst_qlen

  columns: [id, function, args, expected]
  rows:
    - [reduce_ex,         Enum.__reduce_ex__.__qualname__.__len__,     [], 18]
    - [deepcopy,          Enum.__deepcopy__.__qualname__.__len__,      [], 17]
    - [add_alias,         Enum._add_alias_.__qualname__.__len__,       [], 16]
    - [copy,              Enum.__copy__.__qualname__.__len__,           [], 13]
    - [dir,               Enum.__dir__.__qualname__.__len__,            [], 12]
    - [add_value_alias,   Enum._add_value_alias_.__qualname__.__len__,  [], 22]
    - [init_subclass,     Enum.__init_subclass__.__qualname__.__len__,  [], 22]

# ---------------------------------------------------------------------------
# EnumType helper/utility method __qualname__.__len__() table (extra35 namespace)
#
# These EnumType methods are defined directly in EnumType.__dict__ and have
# not been covered in any prior enum spec:
#   _check_for_existing_members_ -> len=37 (longest in series)
#   __subclasshook__             -> len=25
#   _find_data_repr_             -> len=25 (tied)
#   _find_data_type_             -> len=25 (tied)
#   __init_subclass__            -> len=26
#   _get_mixins_                 -> len=21
#   _add_member_                 -> len=21 (tied)
#   _find_new_                   -> len=19
#   _convert_                    -> len=18
#   _create_                     -> len=17
#   __bool__                     -> len=17 (tied)
#   __len__                      -> len=16
#   __dir__                      -> len=16 (tied)
# ---------------------------------------------------------------------------

table enum_extra35.EnumType_utility_method_qualname_lens:
  description: "__qualname__.__len__() for EnumType utility and dunder methods not previously covered"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: EnumType_util_qlen

  columns: [id, function, args, expected]
  rows:
    - [check_for_existing_members, EnumType._check_for_existing_members_.__qualname__.__len__, [], 37]
    - [init_subclass,              EnumType.__init_subclass__.__qualname__.__len__,             [], 26]
    - [subclasshook,               EnumType.__subclasshook__.__qualname__.__len__,              [], 25]
    - [find_data_repr,             EnumType._find_data_repr_.__qualname__.__len__,              [], 25]
    - [find_data_type,             EnumType._find_data_type_.__qualname__.__len__,              [], 25]
    - [get_mixins,                 EnumType._get_mixins_.__qualname__.__len__,                  [], 21]
    - [add_member,                 EnumType._add_member_.__qualname__.__len__,                  [], 21]
    - [find_new,                   EnumType._find_new_.__qualname__.__len__,                    [], 19]
    - [convert,                    EnumType._convert_.__qualname__.__len__,                     [], 18]
    - [create,                     EnumType._create_.__qualname__.__len__,                      [], 17]
    - [bool,                       EnumType.__bool__.__qualname__.__len__,                      [], 17]
    - [len,                        EnumType.__len__.__qualname__.__len__,                       [], 16]
    - [dir,                        EnumType.__dir__.__qualname__.__len__,                       [], 16]

# ---------------------------------------------------------------------------
# __mro__.__len__() for IntEnum, StrEnum, IntFlag — standalone (extra35 namespace)
#
# Python 3.14 introduced ReprEnum as an explicit MRO member. As a result the
# MRO lengths differ from older documentation:
#   IntEnum.__mro__ = [IntEnum, int, ReprEnum, Enum, object]     -> 5
#   StrEnum.__mro__ = [StrEnum, str, ReprEnum, Enum, object]     -> 5
#   IntFlag.__mro__ = [IntFlag, int, ReprEnum, Flag, Enum, object] -> 6
# No prior enum spec records any of these in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra35.IntEnum.mro_len:
  description: "enum.IntEnum.__mro__.__len__() == 5 — [IntEnum, int, ReprEnum, Enum, object] on Python 3.14"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__mro__.__len__
  args: []
  expected: 5

invariant enum_extra35.StrEnum.mro_len:
  description: "enum.StrEnum.__mro__.__len__() == 5 — [StrEnum, str, ReprEnum, Enum, object] on Python 3.14"
  category: class_hierarchy
  kind: python_call_eq
  function: StrEnum.__mro__.__len__
  args: []
  expected: 5

invariant enum_extra35.IntFlag.mro_len:
  description: "enum.IntFlag.__mro__.__len__() == 6 — [IntFlag, int, ReprEnum, Flag, Enum, object] on Python 3.14 (ReprEnum is explicit)"
  category: class_hierarchy
  kind: python_call_eq
  function: IntFlag.__mro__.__len__
  args: []
  expected: 6
