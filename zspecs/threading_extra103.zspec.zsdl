spec: threading_extra103
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra102

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra102.zspec.zsdl."
    - "This spec covers: threading module __spec__ and __loader__ class identity; threading.__package__ empty string; threading.__spec__.name and has_location; threading.__file__ class name; threading object __module__ string lengths; wave 259."
    - "threading.__spec__.__class__.__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "threading.__spec__.__class__.__module__ == '_frozen_importlib'. Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__module__ == '_frozen_importlib_external'. Verified with Python 3.14.3."
    - "threading.__package__ == '' (empty string). Verified with Python 3.14.3."
    - "threading.__spec__.name == 'threading' (len 9). Verified with Python 3.14.3."
    - "threading.__spec__.has_location == True. Verified with Python 3.14.3."
    - "threading.__file__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' (len 7) — Lock is the C extension class _thread.lock. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' (len 9) — pure-Python class. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading' (len 9) — pure-Python class. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' (len 9) — pure-Python function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__spec__ and __loader__ class identity
#
# Wave 259 theme: threading module import-machinery attribute identity.
#
# threading.__spec__.__class__.__name__ == 'ModuleSpec'
# threading.__spec__.__class__.__module__ == '_frozen_importlib'
# threading.__loader__.__class__.__name__ == 'SourceFileLoader'
# threading.__loader__.__class__.__module__ == '_frozen_importlib_external'
# threading.__spec__.name == 'threading' (len 9)
# threading.__spec__.has_location == True
# threading.__file__.__class__.__name__ == 'str'
#
# threading is a pure-Python module loaded by SourceFileLoader; its ModuleSpec
# lives in _frozen_importlib; has_location is True. New to extra103.
# ---------------------------------------------------------------------------

table threading_extra103.spec_loader_class_identity:
  description: "threading __spec__/__loader__ class names and modules; spec.name=='threading'; spec.has_location==True; __file__ is str; wave 259; new to extra103"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingspec103

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — threading.__spec__ is the ModuleSpec created by the import system when threading was first imported; ModuleSpec is defined in importlib._bootstrap (frozen as _frozen_importlib); __spec__.__class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra103"]
    - [spec_class_module_eq_frozen_importlib,
       "__spec__.__class__.__module__.__eq__",
       ["_frozen_importlib"],
       true,
       "threading.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is defined in importlib._bootstrap which CPython freezes as '_frozen_importlib'; the ModuleSpec class's __module__ is '_frozen_importlib'; str.__eq__('_frozen_importlib') returns True; new to extra103"]
    - [loader_class_name_eq_SourceFileLoader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading is a pure-Python source module loaded from Lib/threading.py; CPython uses SourceFileLoader for .py source files; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra103"]
    - [loader_class_module_eq_frozen_importlib_external,
       "__loader__.__class__.__module__.__eq__",
       ["_frozen_importlib_external"],
       true,
       "threading.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True — SourceFileLoader is defined in importlib._bootstrap_external, frozen as '_frozen_importlib_external'; the loader class's __module__ is '_frozen_importlib_external'; str.__eq__('_frozen_importlib_external') returns True; new to extra103"]
    - [spec_name_len_eq_9,
       "__spec__.name.__len__",
       [],
       9,
       "threading.__spec__.name.__len__() == 9 — __spec__.name is 'threading'; len('threading') == 9 (t-h-r-e-a-d-i-n-g); new to extra103"]
    - [spec_has_location_eq_true,
       "__spec__.has_location.__eq__",
       [true],
       true,
       "threading.__spec__.has_location.__eq__(True) == True — threading is a pure-Python module loaded from Lib/threading.py on the filesystem; has_location is True because the origin is a file path; bool.__eq__(True) returns True; new to extra103"]
    - [file_class_name_eq_str,
       "__file__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.__file__.__class__.__name__.__eq__('str') == True — threading.__file__ is the path string to the .py file on disk; the path is a plain Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra103"]

# ---------------------------------------------------------------------------
# Table 2: threading.__package__ and __name__ string identity
#
# Wave 259 theme: threading module top-level name and package attrs.
#
# threading.__package__ == '' (empty string, len 0)
# threading.__package__.__class__.__name__ == 'str'
# threading.__name__ == 'threading' (len 9)
# threading.__spec__.name == 'threading'
#
# threading is a top-level stdlib module with no parent package;
# __package__ is the empty string. New to extra103.
# ---------------------------------------------------------------------------

table threading_extra103.module_name_package:
  description: "threading.__package__=='' (len 0); __package__.__class__.__name__=='str'; __name__=='threading' (len 9); spec.name=='threading'; wave 259; new to extra103"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingspec103

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "threading.__package__.__eq__('') == True — threading is a top-level stdlib module with no parent package; its __package__ attribute is the empty string ''; str.__eq__('') returns True; new to extra103"]
    - [package_len_eq_0,
       "__package__.__len__",
       [],
       0,
       "threading.__package__.__len__() == 0 — __package__ is the empty string ''; len('') == 0; a zero-length __package__ indicates a top-level module; new to extra103"]
    - [package_class_name_eq_str,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.__package__.__class__.__name__.__eq__('str') == True — threading.__package__ is the empty string ''; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra103"]
    - [name_len_eq_9,
       "__name__.__len__",
       [],
       9,
       "threading.__name__.__len__() == 9 — threading.__name__ is 'threading'; len('threading') == 9 (t-h-r-e-a-d-i-n-g); new to extra103"]
    - [name_eq_threading,
       "__name__.__eq__",
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — the module's __name__ is its dotted name; as a top-level module it is simply 'threading'; str.__eq__('threading') returns True; new to extra103"]
    - [spec_name_eq_threading,
       "__spec__.name.__eq__",
       ["threading"],
       true,
       "threading.__spec__.name.__eq__('threading') == True — the ModuleSpec.name attribute holds the module's dotted name; for the threading module it is 'threading'; str.__eq__('threading') returns True; new to extra103"]

# ---------------------------------------------------------------------------
# Table 3: threading object __module__ string lengths
#
# Wave 259 theme: threading objects __module__ length distinguishes C from Python.
#
# threading.Lock.__module__ == '_thread' (len 7) — C extension class
# threading.Semaphore.__module__ == 'threading' (len 9) — pure-Python class
# threading.Thread.__module__ == 'threading' (len 9) — pure-Python class
# threading.Event.__module__ == 'threading' (len 9) — pure-Python class
# threading.Condition.__module__ == 'threading' (len 9) — pure-Python class
# threading.current_thread.__module__ == 'threading' (len 9) — pure-Python function
#
# threading.Lock is _thread.lock, a C extension type with __module__ == '_thread'.
# All pure-Python objects defined in Lib/threading.py have __module__ == 'threading'.
# New to extra103.
# ---------------------------------------------------------------------------

table threading_extra103.object_module_lengths:
  description: "threading object __module__ lengths: Lock is '_thread' (7); Semaphore/Thread/Event/Condition/current_thread are 'threading' (9); wave 259; new to extra103"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmod103

  columns: [id, function, args, expected, description]
  rows:
    - [lock_module_len_eq_7,
       "Lock.__module__.__len__",
       [],
       7,
       "threading.Lock.__module__.__len__() == 7 — threading.Lock is the C extension class _thread.lock from Modules/_threadmodule.c; its __module__ is '_thread'; len('_thread') == 7 (_-t-h-r-e-a-d); new to extra103"]
    - [semaphore_module_len_eq_9,
       "Semaphore.__module__.__len__",
       [],
       9,
       "threading.Semaphore.__module__.__len__() == 9 — Semaphore is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; len('threading') == 9; new to extra103"]
    - [thread_module_len_eq_9,
       "Thread.__module__.__len__",
       [],
       9,
       "threading.Thread.__module__.__len__() == 9 — Thread is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; len('threading') == 9; new to extra103"]
    - [event_module_len_eq_9,
       "Event.__module__.__len__",
       [],
       9,
       "threading.Event.__module__.__len__() == 9 — Event is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; len('threading') == 9; new to extra103"]
    - [condition_module_len_eq_9,
       "Condition.__module__.__len__",
       [],
       9,
       "threading.Condition.__module__.__len__() == 9 — Condition is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; len('threading') == 9; new to extra103"]
    - [current_thread_module_len_eq_9,
       "current_thread.__module__.__len__",
       [],
       9,
       "threading.current_thread.__module__.__len__() == 9 — current_thread is a pure-Python function defined in Lib/threading.py that returns the currently executing Thread; its __module__ is 'threading'; len('threading') == 9; new to extra103"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra103
# ---------------------------------------------------------------------------

invariant threading_extra103.spec_class_name:
  description: "threading.__spec__.__class__.__name__ == 'ModuleSpec' — threading is a pure-Python module; wave 259; new to extra103"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant threading_extra103.loader_class_name:
  description: "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading.py loaded via SourceFileLoader; wave 259; new to extra103"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra103.package_len:
  description: "len(threading.__package__) == 0 — threading is a top-level module; __package__ is empty string; wave 259; new to extra103"
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

invariant threading_extra103.spec_has_location:
  description: "threading.__spec__.has_location == True — threading.py has a filesystem path; wave 259; new to extra103"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant threading_extra103.lock_module_len:
  description: "len(threading.Lock.__module__) == 7 — Lock.__module__ is '_thread'; C extension class; wave 259; new to extra103"
  kind: python_call_eq
  function: Lock.__module__.__len__
  args: []
  expected: 7

invariant threading_extra103.spec_name_len:
  description: "len(threading.__spec__.name) == 9 — spec.name is 'threading'; wave 259; new to extra103"
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 9
