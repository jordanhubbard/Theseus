spec: datetime_extra6
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras."
    - "Focus: __qualname__ for datetime/date/time/timedelta/timezone classes. __qualname__ for module-level classes equals __name__ (flat, no dotted prefix). Prior specs cover __name__, __module__, __bases__ for these classes but not __qualname__."
    - "datetime.datetime.__qualname__ == 'datetime' — module-level class has a flat qualname."
    - "datetime.date.__qualname__ == 'date' — module-level class has a flat qualname."
    - "datetime.time.__qualname__ == 'time' — module-level class has a flat qualname."
    - "datetime.timedelta.__qualname__ == 'timedelta' — module-level class has a flat qualname."
    - "datetime.timezone.__qualname__ == 'timezone' — module-level class has a flat qualname."
    - "datetime.tzinfo.__qualname__ == 'tzinfo' — abstract base class has a flat qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — core datetime classes
#
# For module-level classes, __qualname__ is always equal to __name__
# (no enclosing class scope to prefix it). Prior specs cover __name__ for
# these classes but not __qualname__. All six checks are new.
# ---------------------------------------------------------------------------

invariant datetime_extra6.datetime.qualname:
  description: "datetime.datetime.__qualname__ == 'datetime' — flat qualname for module-level class"
  category: qualnames
  kind: python_call_eq
  function: datetime.__qualname__.__eq__
  args: ["datetime"]
  expected: true

invariant datetime_extra6.date.qualname:
  description: "datetime.date.__qualname__ == 'date' — flat qualname for module-level class"
  category: qualnames
  kind: python_call_eq
  function: date.__qualname__.__eq__
  args: ["date"]
  expected: true

invariant datetime_extra6.time.qualname:
  description: "datetime.time.__qualname__ == 'time' — flat qualname for module-level class"
  category: qualnames
  kind: python_call_eq
  function: time.__qualname__.__eq__
  args: ["time"]
  expected: true

invariant datetime_extra6.timedelta.qualname:
  description: "datetime.timedelta.__qualname__ == 'timedelta' — flat qualname for module-level class"
  category: qualnames
  kind: python_call_eq
  function: timedelta.__qualname__.__eq__
  args: ["timedelta"]
  expected: true

invariant datetime_extra6.timezone.qualname:
  description: "datetime.timezone.__qualname__ == 'timezone' — flat qualname for module-level class"
  category: qualnames
  kind: python_call_eq
  function: timezone.__qualname__.__eq__
  args: ["timezone"]
  expected: true

invariant datetime_extra6.tzinfo.qualname:
  description: "datetime.tzinfo.__qualname__ == 'tzinfo' — flat qualname for abstract base class"
  category: qualnames
  kind: python_call_eq
  function: tzinfo.__qualname__.__eq__
  args: ["tzinfo"]
  expected: true

# ---------------------------------------------------------------------------
# Table: qualname cross-checks for the four primary classes
# ---------------------------------------------------------------------------

table datetime_extra6.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [datetime,  datetime.__qualname__.__eq__,  ["datetime"],  true]
    - [date,      date.__qualname__.__eq__,      ["date"],      true]
    - [time,      time.__qualname__.__eq__,      ["time"],      true]
    - [timedelta, timedelta.__qualname__.__eq__,  ["timedelta"], true]
    - [timezone,  timezone.__qualname__.__eq__,  ["timezone"],  true]
    - [tzinfo,    tzinfo.__qualname__.__eq__,    ["tzinfo"],    true]
