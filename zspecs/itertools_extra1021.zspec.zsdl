spec: itertools_extra1021
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks itertools iterator __reduce__.__qualname__ and __sizeof__.__qualname__ for builtin iterator types"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1021.reduce_qualnames:
  description: "itertools iterator types __reduce__.__qualname__ identity"
  kind: python_call_eq
  category: reduce_qualnames
  id_prefix: it1021rq
  columns: [id, function, args, expected]
  rows:
    - [it1021rq001, itertools.starmap.__reduce__.__qualname__.__eq__,    ["starmap.__reduce__"],    true]
    - [it1021rq002, itertools.zip_longest.__reduce__.__qualname__.__eq__, ["zip_longest.__reduce__"], true]
    - [it1021rq003, itertools.accumulate.__reduce__.__qualname__.__eq__, ["accumulate.__reduce__"], true]
    - [it1021rq004, itertools.chain.__reduce__.__qualname__.__eq__,      ["chain.__reduce__"],      true]
    - [it1021rq005, itertools.product.__reduce__.__qualname__.__eq__,    ["product.__reduce__"],    true]
    - [it1021rq006, itertools.permutations.__reduce__.__qualname__.__eq__, ["permutations.__reduce__"], true]
    - [it1021rq007, itertools.combinations.__reduce__.__qualname__.__eq__, ["combinations.__reduce__"], true]

table itertools_extra1021.sizeof_qualnames:
  description: "itertools iterator types __sizeof__.__qualname__ identity"
  kind: python_call_eq
  category: sizeof_qualnames
  id_prefix: it1021sq
  columns: [id, function, args, expected]
  rows:
    - [it1021sq001, itertools.count.__sizeof__.__qualname__.__eq__,        ["count.__sizeof__"],        true]
    - [it1021sq002, itertools.repeat.__sizeof__.__qualname__.__eq__,       ["repeat.__sizeof__"],       true]
    - [it1021sq003, itertools.cycle.__sizeof__.__qualname__.__eq__,        ["cycle.__sizeof__"],        true]
    - [it1021sq004, itertools.chain.__sizeof__.__qualname__.__eq__,        ["chain.__sizeof__"],        true]
    - [it1021sq005, itertools.combinations.__sizeof__.__qualname__.__eq__, ["combinations.__sizeof__"], true]
    - [it1021sq006, itertools.islice.__sizeof__.__qualname__.__eq__,       ["islice.__sizeof__"],       true]
    - [it1021sq007, itertools.groupby.__sizeof__.__qualname__.__eq__,      ["groupby.__sizeof__"],      true]

table itertools_extra1021.class_identity:
  description: "itertools iterator type class name and module identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: it1021ci
  columns: [id, function, args, expected]
  rows:
    - [it1021ci001, itertools.count.__class__.__name__.__eq__,        ["type"],     true]
    - [it1021ci002, itertools.repeat.__class__.__name__.__eq__,       ["type"],     true]
    - [it1021ci003, itertools.chain.__module__.__eq__,                ["itertools"], true]
    - [it1021ci004, itertools.accumulate.__module__.__eq__,           ["itertools"], true]
    - [it1021ci005, itertools.starmap.__module__.__eq__,              ["itertools"], true]
