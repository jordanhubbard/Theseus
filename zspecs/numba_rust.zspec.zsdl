spec: numba_rust
version: ">=3.9"
backend: rust_module(numba_rust)

docs: https://numba.pydata.org/

provenance:
  derived_from:
    - "https://numba.pydata.org/ — Numba JIT compiler"
  notes:
    - "Numba is a JIT compiler for Python/NumPy."
    - "numba.jit is a decorator."
    - "numba.njit is a decorator."
    - "numba.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant numba_rust.has_jit:
  description: "numba.jit is callable"
  category: presence
  kind: python_call_eq
  function: numba_has_jit
  args: []
  expected: true

invariant numba_rust.has_njit:
  description: "numba.njit is callable"
  category: presence
  kind: python_call_eq
  function: numba_has_njit
  args: []
  expected: true

invariant numba_rust.version_nonempty:
  description: "numba.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: numba_version_nonempty
  args: []
  expected: true

