spec: decimal_extra23
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra through decimal_extra22."
    - "decimal_extra22 covers __qualname__ for Decimal.__sub__, __truediv__, __neg__, __abs__, quantize, to_eng_string."
    - "No prior spec covers __qualname__ for decimal.Context methods or the DecimalException hierarchy."
    - "Context.__qualname__ == 'Context'; all Context methods follow 'Context.<name>' pattern."
    - "DecimalException and its subclasses have flat __qualname__ (no enclosing scope)."
    - "Rounding mode constants (ROUND_HALF_UP etc.) are plain str instances; __class__.__name__ == 'str'."
    - "DecimalException.__bases__[0].__name__ == 'ArithmeticError' — standard Python exception hierarchy."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context class __qualname__
#
# No prior spec records __qualname__ for the Context class itself or its
# __init__ method.  Context is defined at module level; its qualname is
# simply 'Context'.
# ---------------------------------------------------------------------------

invariant decimal_extra23.Context.qualname:
  description: "decimal.Context.__qualname__ == 'Context' — top-level class, no enclosing scope"
  category: class_identity
  kind: python_call_eq
  function: Context.__qualname__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra23.Context.qualname_len:
  description: "len(decimal.Context.__qualname__) == 7 — 'Context' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Context.__qualname__.__len__
  args: []
  expected: 7

invariant decimal_extra23.Context.init_qualname:
  description: "decimal.Context.__init__.__qualname__ == 'Context.__init__' — method defined directly on Context"
  category: method_identity
  kind: python_call_eq
  function: Context.__init__.__qualname__.__eq__
  args: ["Context.__init__"]
  expected: true

invariant decimal_extra23.Context.init_qualname_len:
  description: "len(decimal.Context.__init__.__qualname__) == 16 — 'Context.__init__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Context.__init__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Context method __qualname__ values
#
# No prior spec records __qualname__ for Context arithmetic/math methods.
# All are defined directly on Context; qualname follows 'Context.<name>'.
# ---------------------------------------------------------------------------

table decimal_extra23.context_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [create_decimal, Context.create_decimal.__qualname__.__eq__, ["Context.create_decimal"], true, "Context.create_decimal.__qualname__ == 'Context.create_decimal'"]
    - [sqrt,           Context.sqrt.__qualname__.__eq__,           ["Context.sqrt"],           true, "Context.sqrt.__qualname__ == 'Context.sqrt'"]
    - [add,            Context.add.__qualname__.__eq__,            ["Context.add"],            true, "Context.add.__qualname__ == 'Context.add'"]
    - [multiply,       Context.multiply.__qualname__.__eq__,       ["Context.multiply"],       true, "Context.multiply.__qualname__ == 'Context.multiply'"]
    - [subtract,       Context.subtract.__qualname__.__eq__,       ["Context.subtract"],       true, "Context.subtract.__qualname__ == 'Context.subtract'"]
    - [quantize,       Context.quantize.__qualname__.__eq__,       ["Context.quantize"],       true, "Context.quantize.__qualname__ == 'Context.quantize'"]

# ---------------------------------------------------------------------------
# Context method __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant decimal_extra23.Context.create_decimal.qualname_len:
  description: "len(decimal.Context.create_decimal.__qualname__) == 22 — 'Context.create_decimal' is 22 chars"
  category: method_identity
  kind: python_call_eq
  function: Context.create_decimal.__qualname__.__len__
  args: []
  expected: 22

invariant decimal_extra23.Context.sqrt.qualname_len:
  description: "len(decimal.Context.sqrt.__qualname__) == 12 — 'Context.sqrt' is 12 chars"
  category: method_identity
  kind: python_call_eq
  function: Context.sqrt.__qualname__.__len__
  args: []
  expected: 12

invariant decimal_extra23.Context.add.qualname_len:
  description: "len(decimal.Context.add.__qualname__) == 11 — 'Context.add' is 11 chars"
  category: method_identity
  kind: python_call_eq
  function: Context.add.__qualname__.__len__
  args: []
  expected: 11

invariant decimal_extra23.Context.multiply.qualname_len:
  description: "len(decimal.Context.multiply.__qualname__) == 16 — 'Context.multiply' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Context.multiply.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Rounding constant type identity
#
# No prior spec records the __class__.__name__ of the ROUND_* string constants.
# They are plain str instances, not a custom rounding type.
# ---------------------------------------------------------------------------

table decimal_extra23.rounding_constant_class:
  kind: python_call_eq
  category: type_identity
  id_prefix: class_name

  columns: [id, function, args, expected, description]
  rows:
    - [half_up,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true, "decimal.ROUND_HALF_UP is an instance of str"]
    - [down,      ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true, "decimal.ROUND_DOWN is an instance of str"]
    - [ceiling,   ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true, "decimal.ROUND_CEILING is an instance of str"]
    - [floor,     ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true, "decimal.ROUND_FLOOR is an instance of str"]
    - [half_even, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true, "decimal.ROUND_HALF_EVEN is an instance of str"]

# ---------------------------------------------------------------------------
# DecimalException hierarchy __qualname__ and base class
#
# No prior spec records __qualname__ for DecimalException as a standalone
# invariant (only the exception subclasses in decimal_extra20 were covered via
# a table).  No prior spec records DecimalException.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant decimal_extra23.DecimalException.qualname:
  description: "decimal.DecimalException.__qualname__ == 'DecimalException' — top-level exception class"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__qualname__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra23.DecimalException.qualname_len:
  description: "len(decimal.DecimalException.__qualname__) == 16 — 'DecimalException' is 16 chars"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra23.DecimalException.base_name:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — inherits from ArithmeticError"
  category: class_identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra23.DecimalException.module:
  description: "decimal.DecimalException.__module__ == 'decimal'"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra23.InvalidOperation.module:
  description: "decimal.InvalidOperation.__module__ == 'decimal'"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__module__.__eq__
  args: ["decimal"]
  expected: true
