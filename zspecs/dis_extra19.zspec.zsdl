spec: dis_extra19
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra18.zspec.zsdl — covers distb/code_info/show_code __qualname__ and __module__; Instruction.__bases__[0].__name__ == '_Instruction'; _Instruction.__bases__[0].__name__ == 'tuple'; Bytecode.__name__; Bytecode.__bases__[0].__name__ == 'object'"
    - "dis_extra17.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __name__ and __module__; Instruction/__name__; opname/opmap class"
    - "dis_extra16.zspec.zsdl — covers Bytecode/__module__ and Instruction/__module__; class_qualnames table (Bytecode/Instruction); COMPILER_FLAG_NAMES/__class__/__name__; has* lists class"
    - "dis_extra15.zspec.zsdl — covers Bytecode/__qualname__; Instruction/__qualname__; function_modules table; opname item0 type; opmap class/len"
  notes:
    - "This spec extends dis_extra18.zspec.zsdl."
    - "Focus: __qualname__.__len__() for dis functions; Positions/ArgResolver/Formatter class qualnames; stack_effect/pretty_flags qualnames."
    - "dis.stack_effect.__qualname__ == 'stack_effect' — no prior dis spec covers stack_effect/__qualname__ as a standalone invariant."
    - "dis.pretty_flags.__qualname__ == 'pretty_flags' — not covered in any prior dis spec."
    - "dis.print_instructions.__qualname__ == 'print_instructions' — not covered in any prior dis spec."
    - "dis.Positions.__qualname__ == 'Positions' and __bases__[0].__name__ == 'tuple' — Positions is a NamedTuple."
    - "dis.ArgResolver.__qualname__ == 'ArgResolver' and __bases__[0].__name__ == 'object'."
    - "dis.Formatter.__qualname__ == 'Formatter' and __bases__[0].__name__ == 'object'."
    - "dis.Bytecode.__qualname__.__len__() == 8; dis.Instruction.__qualname__.__len__() == 11."
    - "dis.get_instructions.__qualname__.__len__() == 16; dis.findlinestarts.__qualname__.__len__() == 14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Additional function __qualname__ — stack_effect, pretty_flags, print_instructions
# (dis_extra19 namespace)
#
# dis_extra18 covers distb/code_info/show_code __qualname__.
# dis_extra17 covers dis/disassemble/get_instructions/findlinestarts/findlabels.
# stack_effect/pretty_flags/print_instructions are not covered in any prior dis spec.
# ---------------------------------------------------------------------------

table dis_extra19.extra_function_qualnames:
  description: "__qualname__ for additional dis module functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: extqualname

  columns: [id, function, args, expected]
  rows:
    - [stack_effect,       stack_effect.__qualname__.__eq__,       ["stack_effect"],       true]
    - [pretty_flags,       pretty_flags.__qualname__.__eq__,       ["pretty_flags"],       true]
    - [print_instructions, print_instructions.__qualname__.__eq__, ["print_instructions"], true]

# ---------------------------------------------------------------------------
# Class __qualname__ — Positions, ArgResolver, Formatter
# (dis_extra19 namespace)
#
# dis_extra16 covers Bytecode and Instruction __qualname__ in a table.
# Positions/ArgResolver/Formatter are not covered in any prior dis spec.
# Positions is a NamedTuple (bases: tuple); ArgResolver and Formatter are
# plain Python classes (bases: object).
# ---------------------------------------------------------------------------

table dis_extra19.aux_class_qualnames:
  description: "__qualname__ for auxiliary dis module classes"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: auxqualname

  columns: [id, function, args, expected]
  rows:
    - [Positions,    Positions.__qualname__.__eq__,    ["Positions"],    true]
    - [ArgResolver,  ArgResolver.__qualname__.__eq__,  ["ArgResolver"],  true]
    - [Formatter,    Formatter.__qualname__.__eq__,    ["Formatter"],    true]

# ---------------------------------------------------------------------------
# Auxiliary class __bases__[0].__name__ — Positions, ArgResolver, Formatter
# (dis_extra19 namespace)
#
# No prior dis spec covers Positions/ArgResolver/Formatter __bases__ at all.
# Positions inherits from tuple (NamedTuple-style). ArgResolver and Formatter
# are plain Python classes inheriting from object.
# ---------------------------------------------------------------------------

invariant dis_extra19.Positions.base_is_tuple:
  description: "dis.Positions.__bases__[0].__name__ == 'tuple' — Positions is a NamedTuple"
  category: class_hierarchy
  kind: python_call_eq
  function: "Positions.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant dis_extra19.ArgResolver.base_is_object:
  description: "dis.ArgResolver.__bases__[0].__name__ == 'object' — ArgResolver is a plain Python class"
  category: class_hierarchy
  kind: python_call_eq
  function: "ArgResolver.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant dis_extra19.Formatter.base_is_object:
  description: "dis.Formatter.__bases__[0].__name__ == 'object' — Formatter is a plain Python class"
  category: class_hierarchy
  kind: python_call_eq
  function: "Formatter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() — selected dis functions
# (dis_extra19 namespace)
#
# No prior dis spec covers __qualname__.__len__() for any dis function.
# get_instructions has the longest qualname (16); findlinestarts is 14;
# Bytecode is 8; Instruction is 11.
# ---------------------------------------------------------------------------

invariant dis_extra19.get_instructions.qualname_len:
  description: "dis.get_instructions.__qualname__.__len__() == 16"
  category: function_qualname_lengths
  kind: python_call_eq
  function: get_instructions.__qualname__.__len__
  args: []
  expected: 16

invariant dis_extra19.Bytecode.qualname_len:
  description: "dis.Bytecode.__qualname__.__len__() == 8 — qualname 'Bytecode' has 8 characters"
  category: class_qualname_lengths
  kind: python_call_eq
  function: Bytecode.__qualname__.__len__
  args: []
  expected: 8

invariant dis_extra19.Instruction.qualname_len:
  description: "dis.Instruction.__qualname__.__len__() == 11 — qualname 'Instruction' has 11 characters"
  category: class_qualname_lengths
  kind: python_call_eq
  function: Instruction.__qualname__.__len__
  args: []
  expected: 11
