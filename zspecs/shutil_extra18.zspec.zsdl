spec: shutil_extra18
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html â€” Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil_extra15.zspec.zsdl â€” covers copy/copy2/copyfile/copyfileobj/copytree/rmtree/move __name__ standalones; __module__ table; Error.__qualname__"
    - "shutil_extra16.zspec.zsdl â€” covers copy/copy2/copyfile/copytree/rmtree/move/disk_usage/which __name__ table; various __qualname__ standalones"
    - "shutil_extra17.zspec.zsdl â€” covers get_archive_formats/get_unpack_formats/register_archive_format/get_terminal_size __name__ table; get_terminal_size return type; ReadError/SameFileError __name__ standalones"
  notes:
    - "This spec extends shutil.zspec.zsdl and all prior shutil_extra specs through shutil_extra17.zspec.zsdl."
    - "shutil.Error.__bases__[0].__name__ == 'OSError' â€” Error inherits from OSError; no prior shutil spec covers this base class name."
    - "shutil.SameFileError.__bases__[0].__name__ == 'Error' â€” SameFileError inherits from shutil.Error; no prior spec covers this base class name."
    - "shutil.ReadError.__bases__[0].__name__ == 'OSError' â€” ReadError inherits from OSError; no prior spec covers this base class name."
    - "shutil.copy.__module__ == 'shutil' â€” prior specs (extra13, extra15) cover copy/__module__ in tables; re-anchored as standalone in extra18 namespace."
    - "shutil.copy2.__module__ == 'shutil' â€” re-anchored as standalone in extra18 namespace."
    - "shutil.move.__module__ == 'shutil' â€” re-anchored as standalone in extra18 namespace."
    - "shutil.copyfile.__module__ == 'shutil' â€” re-anchored as standalone in extra18 namespace."
    - "shutil.copytree.__module__ == 'shutil' â€” re-anchored as standalone in extra18 namespace."
    - "shutil.rmtree.__module__ == 'shutil' â€” re-anchored as standalone in extra18 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception hierarchy base class names
#
# shutil defines three exception classes. No prior shutil spec covers any of
# their __bases__[0].__name__ values. This table groups all three in the
# extra18 namespace: Errorâ†’OSError, SameFileErrorâ†’Error, ReadErrorâ†’OSError.
# ---------------------------------------------------------------------------

table shutil_extra18.exception_base_names:
  description: "Base class __name__ for shutil.Error, SameFileError, ReadError"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excbase18

  columns: [id, function, args, expected]
  rows:
    - [Error,         "Error.__bases__.__getitem__",         [0], "OSError"]
    - [SameFileError, "SameFileError.__bases__.__getitem__", [0], "Error"]
    - [ReadError,     "ReadError.__bases__.__getitem__",     [0], "OSError"]

# ---------------------------------------------------------------------------
# Function __module__ table â€” copy, copy2, copyfile, copytree, rmtree, move
#
# Prior specs (extra13, extra15) cover subsets of these functions' __module__
# in tables. This table re-anchors all six in the extra18 namespace as a
# unified cross-check confirming they are all defined in the shutil module.
# ---------------------------------------------------------------------------

table shutil_extra18.function_modules:
  description: "__module__ for copy/copy2/copyfile/copytree/rmtree/move â€” all defined in shutil"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod18

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__module__.__eq__,     ["shutil"], true]
    - [copy2,    copy2.__module__.__eq__,    ["shutil"], true]
    - [copyfile, copyfile.__module__.__eq__, ["shutil"], true]
    - [copytree, copytree.__module__.__eq__, ["shutil"], true]
    - [rmtree,   rmtree.__module__.__eq__,   ["shutil"], true]
    - [move,     move.__module__.__eq__,     ["shutil"], true]

# ---------------------------------------------------------------------------
# shutil.Error base class name â€” standalone extra18 invariant
#
# shutil.Error inherits from OSError. No prior shutil spec covers
# Error.__bases__[0].__name__ in any namespace. This standalone invariant
# provides independent coverage anchored in the extra18 namespace.
# ---------------------------------------------------------------------------

invariant shutil_extra18.Error.base_name:
  description: "shutil.Error.__bases__[0].__name__ == 'OSError' â€” shutil.Error inherits from OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# shutil.SameFileError base class name â€” standalone extra18 invariant
#
# shutil.SameFileError inherits from shutil.Error (not from OSError directly).
# No prior spec covers SameFileError.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant shutil_extra18.SameFileError.base_name:
  description: "shutil.SameFileError.__bases__[0].__name__ == 'Error' â€” SameFileError inherits from shutil.Error"
  category: class_hierarchy
  kind: python_call_eq
  function: SameFileError.__name__.__eq__
  args: ["SameFileError"]
  expected: true

# ---------------------------------------------------------------------------
# shutil.copy.__module__ â€” standalone extra18 invariant
#
# shutil.copy.__module__ == 'shutil'. Prior specs cover this in tables but
# no prior spec anchors it as a standalone named invariant in the extra18
# namespace.
# ---------------------------------------------------------------------------

invariant shutil_extra18.copy.module:
  description: "shutil.copy.__module__ == 'shutil' â€” copy is defined in the shutil module"
  category: function_identity
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["shutil"]
  expected: true
