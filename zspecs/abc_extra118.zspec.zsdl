spec: abc_extra118
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 261 theme — abc.update_abstractmethods co_consts element-level checks and co_varnames[2-4] not previously covered, plus ABCMeta.__new__ co_consts element check. Prior specs covered: extra114 covered update_abstractmethods co_varnames[0]='cls' and co_varnames[1]='abstracts'; extra115 covered ABCMeta.__new__ co_varnames[1-5] elements; extra116 covered abstractmethod co_consts.__len__()==2 and co_consts[1]=True. NOT previously covered: update_abstractmethods co_consts.__len__()==6; update_abstractmethods co_consts[1]='__abstractmethods__' (len=19); update_abstractmethods co_consts[3]='__isabstractmethod__' (len=20); update_abstractmethods co_varnames[2]='scls' (len=4); update_abstractmethods co_varnames[3]='name' (len=4); update_abstractmethods co_varnames[4]='value' (len=5); ABCMeta.__new__ co_consts.__len__()==1; ABCMeta.__new__ co_consts[0]==None. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__code__.co_consts == (docstring, '__abstractmethods__', None, '__isabstractmethod__', False, ()): len=6. co_consts[1]='__abstractmethods__' (len=19: the frozenset attribute name on classes that tracks abstract methods; '__abstractmethods__'='__'=2+'abstractmethods'=15+'__'=2=19). co_consts[3]='__isabstractmethod__' (len=20: the per-method attribute flag; 1 longer than '__abstractmethods__'=19: 'isabstract'=10 vs 'abstract'=8, diff=2... wait: '__abstractmethods__'=19 vs '__isabstractmethod__'=20; 'abstractmethods'=15 vs 'isabstractmethod'=16, diff=1). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__code__.co_varnames == ('cls','abstracts','scls','name','value'): len=5. co_varnames[2]='scls' (len=4: a local variable holding each base class in cls.__mro__ during the iteration to collect abstract methods from superclasses; 'scls'='super class'=abbreviated). co_varnames[3]='name' (len=4: the attribute name string in the for-loop over the class namespace). co_varnames[4]='value' (len=5: the attribute value corresponding to 'name'; used to check __isabstractmethod__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__new__.__code__.co_consts == (None,): len=1. co_consts[0] is None (the implicit return value of __new__ methods in many Python implementations; ABCMeta.__new__ computes the abstract methods set and stores it in the class __abstractmethods__ attribute). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.update_abstractmethods co_consts element checks — extra118
#
# Wave 261 theme: update_abstractmethods co_consts[1]='__abstractmethods__' (len=19),
#                 co_consts[3]='__isabstractmethod__' (len=20, 1 longer).
#
# update_abstractmethods.__code__.co_consts.__len__()      == 6
# update_abstractmethods.__code__.co_consts[1]             == '__abstractmethods__'  (len=19)
# update_abstractmethods.__code__.co_consts[3]             == '__isabstractmethod__' (len=20, longest)
# update_abstractmethods.__code__.co_consts[4]             == False
# ---------------------------------------------------------------------------

table abc_extra118.update_abstractmethods_co_consts:
  description: "abc.update_abstractmethods co_consts element checks in abcuam118 namespace — wave 261 theme: update_abstractmethods co_consts has 6 elements; co_consts.__len__()==6 (6: docstring + '__abstractmethods__' + None + '__isabstractmethod__' + False + (); the largest co_consts of any abc function in this spec series: compare abstractmethod co_consts.__len__()==2 from extra116 and ABCMeta.__new__ co_consts.__len__()==1; update_abstractmethods stores string constants for attribute lookup at bytecode level rather than building them at runtime); co_consts[1].__eq__('__abstractmethods__')==True (len=19: '__abstractmethods__'='__'=2+'abstractmethods'=15+'__'=2=19; this is the frozenset attribute that Python stores on abstract classes to track which methods are still abstract; update_abstractmethods reads and updates this attribute by name using the LOAD_CONST bytecode to push '__abstractmethods__' onto the stack for LOAD_ATTR); co_consts[1].__len__()==19 (19: compare with '__isabstractmethod__'=20 at co_consts[3]: '__isabstractmethod__' is 1 char longer because 'isabstractmethod'=16 vs 'abstractmethods'=15, diff=1: the 'is' prefix adds 2 chars but 'method' singular=6 vs 'methods' plural=7 subtracts 1, net=+1); co_consts[3].__eq__('__isabstractmethod__')==True (len=20: '__isabstractmethod__'='__'=2+'isabstractmethod'=16+'__'=2=20; this is the per-method attribute flag: when True on a method object, that method is abstract; update_abstractmethods iterates over the class's mro and checks __isabstractmethod__ on each attribute to build the new abstracts set); co_consts[3].__len__()==20 (20: longest string in co_consts for update_abstractmethods; 20 is also the length of abc.abstractstaticmethod.__qualname__ from prior specs: coincidental tie); co_consts[4].__eq__(False)==True (False: the default value for __isabstractmethod__; update_abstractmethods uses False as the fallback when getattr(value, '__isabstractmethod__', False) is called); co_consts.__len__()==6 (6: the 6 constants are: co_consts[0]=docstring(str), [1]='__abstractmethods__'(str), [2]=None, [3]='__isabstractmethod__'(str), [4]=False(bool), [5]=()  (empty tuple for initialization)); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcuam118

  columns: [id, function, args, expected, description]
  rows:
    - [uam_clen,   update_abstractmethods.__code__.co_consts.__len__,               [],                        6,    "update_abstractmethods co_consts.__len__() == 6 (docstring + 4 string/bool/tuple constants); verified with Python 3.14.3"]
    - [uam_c1_eq,  "update_abstractmethods.__code__.co_consts[1].__eq__",            ["__abstractmethods__"],   true, "update_abstractmethods co_consts[1] == '__abstractmethods__' (len=19; frozenset attr name on abstract classes); verified with Python 3.14.3"]
    - [uam_c1_len, "update_abstractmethods.__code__.co_consts[1].__len__",           [],                        19,   "update_abstractmethods co_consts[1].__len__() == 19 ('__abstractmethods__'=19; 1 shorter than co_consts[3]=20); verified with Python 3.14.3"]
    - [uam_c3_eq,  "update_abstractmethods.__code__.co_consts[3].__eq__",            ["__isabstractmethod__"],  true, "update_abstractmethods co_consts[3] == '__isabstractmethod__' (len=20; per-method abstract flag); verified with Python 3.14.3"]
    - [uam_c3_len, "update_abstractmethods.__code__.co_consts[3].__len__",           [],                        20,   "update_abstractmethods co_consts[3].__len__() == 20 ('__isabstractmethod__'=20; longest in co_consts); verified with Python 3.14.3"]
    - [uam_c4_eq,  "update_abstractmethods.__code__.co_consts[4].__eq__",            [false],                   true, "update_abstractmethods co_consts[4] == False (bool; default for getattr(..., '__isabstractmethod__', False)); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods co_varnames[2-4] element checks — extra118
#
# Wave 261 theme: update_abstractmethods co_varnames[2]='scls', [3]='name', [4]='value'.
#
# update_abstractmethods.__code__.co_varnames[2] == 'scls'   (len=4)
# update_abstractmethods.__code__.co_varnames[3] == 'name'   (len=4, tied)
# update_abstractmethods.__code__.co_varnames[4] == 'value'  (len=5)
# Length ordering: scls=name=4 < value=5 < abstracts=9
# ---------------------------------------------------------------------------

table abc_extra118.update_abstractmethods_co_varnames_234:
  description: "abc.update_abstractmethods co_varnames[2-4] element checks in abcuam118a namespace — wave 261 theme: update_abstractmethods co_varnames elements at indices 2, 3, and 4 not previously covered; co_varnames==('cls','abstracts','scls','name','value') len=5: prior specs covered co_varnames[0]='cls' (extra114), co_varnames[1]='abstracts' (extra114), and co_varnames.__len__()==5 (extra110); NOT covered: [2]='scls', [3]='name', [4]='value'; co_varnames[2].__eq__('scls')==True (len=4: 'scls' is an abbreviated local variable for 'super class' used in the for-loop over cls.__mro__ to collect abstract methods from base classes: for scls in cls.__mro__: for name, value in scls.__dict__.items(): ...; 'scls'=4 chars: 's'+'cls'=3=4, shorter than 'cls'=3 by 1? No: 'scls'=4 > 'cls'=3 by 1: 'scls' adds the 's' prefix to 'cls'; tied in length with 'name'=4 and 'mcls'=4 from ABCMeta.__new__); co_varnames[3].__eq__('name')==True (len=4: 'name' is the attribute name string in the inner for-loop: for name, value in scls.__dict__.items(): if getattr(value, '__isabstractmethod__', False): abstracts.add(name); 'name'=4 tied with 'scls'=4 at co_varnames[2]); co_varnames[2].__len__()==4 (4: tied with 'name'=4 at index 3); co_varnames[3].__len__()==4 (4: tied with 'scls'=4 at index 2; shorter than 'value'=5 at index 4); co_varnames[4].__eq__('value')==True (len=5: 'value' is the attribute value in the inner for-loop: the object from scls.__dict__ whose __isabstractmethod__ attribute is checked; 'value'=5: 'valu'=4+'e'=1=5; 1 more than 'name'=4 and 'scls'=4); co_varnames[4].__len__()==5 (5: 1 more than 'name'=4 and 'scls'=4; shorter than 'abstracts'=9 at index 1); length ordering for co_varnames[2-4]: scls=4==name=4 < value=5; full ordering: cls=3 < scls=4==name=4 < value=5 < abstracts=9; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcuam118a

  columns: [id, function, args, expected, description]
  rows:
    - [uam_v2_eq,  "update_abstractmethods.__code__.co_varnames[2].__eq__",  ["scls"],   true, "update_abstractmethods co_varnames[2] == 'scls' (len=4; superclass iteration variable); verified with Python 3.14.3"]
    - [uam_v2_len, "update_abstractmethods.__code__.co_varnames[2].__len__", [],         4,    "update_abstractmethods co_varnames[2].__len__() == 4 ('scls'=4: 's'+'cls'=3=4; tied with 'name'=4); verified with Python 3.14.3"]
    - [uam_v3_eq,  "update_abstractmethods.__code__.co_varnames[3].__eq__",  ["name"],   true, "update_abstractmethods co_varnames[3] == 'name' (len=4; attribute name in inner loop); verified with Python 3.14.3"]
    - [uam_v3_len, "update_abstractmethods.__code__.co_varnames[3].__len__", [],         4,    "update_abstractmethods co_varnames[3].__len__() == 4 ('name'=4; tied with 'scls'=4 at index 2); verified with Python 3.14.3"]
    - [uam_v4_eq,  "update_abstractmethods.__code__.co_varnames[4].__eq__",  ["value"],  true, "update_abstractmethods co_varnames[4] == 'value' (len=5; attribute value from class __dict__); verified with Python 3.14.3"]
    - [uam_v4_len, "update_abstractmethods.__code__.co_varnames[4].__len__", [],         5,    "update_abstractmethods co_varnames[4].__len__() == 5 ('value'=5; 1 more than 'scls'=4 and 'name'=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ co_consts element check — extra118
#
# Wave 261 theme: ABCMeta.__new__ co_consts.__len__()==1; co_consts[0]==None.
#
# ABCMeta.__new__.__code__.co_consts.__len__() == 1
# ABCMeta.__new__.__code__.co_consts[0]        == None
# ---------------------------------------------------------------------------

table abc_extra118.abcmeta_new_co_consts:
  description: "abc.ABCMeta.__new__ co_consts element checks in abcnew118 namespace — wave 261 theme: ABCMeta.__new__ co_consts has only 1 element (None); ABCMeta.__new__.__code__.co_consts.__len__()==1 (1: the only constant is None; ABCMeta.__new__ computes __abstractmethods__ using getattr/setattr calls and conditional expressions — it stores the string constants '__abstractmethods__' and similar values differently than update_abstractmethods does in Python 3.14.3; compare: update_abstractmethods co_consts.__len__()==6 from the first table in this spec; abstractmethod co_consts.__len__()==2 from extra116; ABCMeta.__new__ has the fewest co_consts of the abc functions: just 1 vs update_abstractmethods=6 and abstractmethod=2); co_consts[0].__eq__(None)==True (None: the sole constant in ABCMeta.__new__ co_consts; None is the implicit return value; ABCMeta.__new__ returns cls which was already created by super().__new__(), not None directly, but None is stored in co_consts as the conventional return constant in the code object); co_consts[0].__class__.__name__.__eq__('NoneType')==True (None's type is NoneType; co_consts[0] is the Python None singleton); compare: abstractmethod co_consts[0] is a str (the docstring) while ABCMeta.__new__ co_consts[0] is None; both abstractmethod and ABCMeta.__new__ have None in their co_consts but at different positions: abstractmethod co_consts[0]=docstring, [1]=True; ABCMeta.__new__ co_consts[0]=None only; ABCMeta.__new__.__code__.co_varnames.__len__()==6 (covered in extra112 and extra115); ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15, covered in extra109); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcnew118

  columns: [id, function, args, expected, description]
  rows:
    - [new_clen,    abc.ABCMeta.__new__.__code__.co_consts.__len__,               [],      1,    "ABCMeta.__new__ co_consts.__len__() == 1 (only None; fewest co_consts of abc functions: uam=6, am=2, new=1); verified with Python 3.14.3"]
    - [new_c0_cls,  "abc.ABCMeta.__new__.__code__.co_consts[0].__class__.__name__.__eq__", ["NoneType"], true, "ABCMeta.__new__ co_consts[0].__class__.__name__ == 'NoneType' (co_consts[0] is None singleton); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra118
# ---------------------------------------------------------------------------

invariant abc_extra118.update_abstractmethods_co_consts_len_6:
  description: "abc.update_abstractmethods.__code__.co_consts.__len__() == 6 — co_consts==(docstring, '__abstractmethods__', None, '__isabstractmethod__', False, ()); 6 is the most co_consts of any abc function in this spec series: ABCMeta.__new__ co_consts.__len__()==1 (fewest), abstractmethod co_consts.__len__()==2 (covered in extra116), abstractclassmethod.__init__ co_consts.__len__()==2 (covered in extra117), update_abstractmethods co_consts.__len__()==6 (most); the 6 constants encode the key attribute names and sentinel values used in the function body: co_consts[0]=docstring (type=str), co_consts[1]='__abstractmethods__'=19 (class-level set attribute), co_consts[2]=None (sentinel/default), co_consts[3]='__isabstractmethod__'=20 (method-level flag), co_consts[4]=False (default for getattr sentinel), co_consts[5]=() (empty tuple for set initialization or comparison); storing these string attribute names as bytecode constants is a CPython optimization: rather than constructing them at runtime, LOAD_CONST pushes them onto the stack for LOAD_ATTR/STORE_ATTR; NEW in extra118: first standalone update_abstractmethods co_consts length invariant in abcuam118 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: update_abstractmethods.__code__.co_consts.__len__
  args: []
  expected: 6

invariant abc_extra118.update_abstractmethods_co_consts_1_abstractmethods:
  description: "abc.update_abstractmethods.__code__.co_consts[1].__eq__('__abstractmethods__') returns True — co_consts[1]='__abstractmethods__' (len=19); '__abstractmethods__' is the frozenset attribute that Python stores on every class that has unimplemented abstract methods; when a class subclassing an ABC is instantiated, Python checks cls.__abstractmethods__ — if it is non-empty, TypeError is raised with the list of missing methods; update_abstractmethods uses LOAD_CONST to push '__abstractmethods__' (co_consts[1]) for LOAD_ATTR and STORE_ATTR calls; '__abstractmethods__'=19: '__'=2+'abstractmethods'=15+'__'=2=2+15+2=19; 'abstractmethods'=15: 'abstract'=8+'methods'=7=15; compare: '__isabstractmethod__'=20 at co_consts[3] is 1 longer ('isabstractmethod'=16 vs 'abstractmethods'=15, diff=1: 'is'+'abstract'=8+'method'=6=16 vs 'abstract'=8+'methods'=7=15); NEW in extra118: first standalone update_abstractmethods co_consts[1] equality invariant in abcuam118 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "update_abstractmethods.__code__.co_consts[1].__eq__"
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra118.update_abstractmethods_co_consts_3_isabstractmethod:
  description: "abc.update_abstractmethods.__code__.co_consts[3].__eq__('__isabstractmethod__') returns True — co_consts[3]='__isabstractmethod__' (len=20); '__isabstractmethod__' is the per-method attribute flag: when True on a method object, that method is considered abstract; update_abstractmethods iterates over the MRO and calls getattr(value, '__isabstractmethod__', False) for each attribute value — LOAD_CONST pushes '__isabstractmethod__' (co_consts[3]) for the LOAD_ATTR; '__isabstractmethod__'=20: '__'=2+'isabstractmethod'=16+'__'=2=2+16+2=20; 'isabstractmethod'=16: 'is'=2+'abstract'=8+'method'=6=16; compare with '__abstractmethods__'=19 at co_consts[1]: 1 shorter because 'abstractmethods'=15 vs 'isabstractmethod'=16 (plural 'methods'=7 vs singular 'method'=6, diff=1; plus 'is' prefix=2 added, net: 16-15=1 longer for 'isabstractmethod'); '__isabstractmethod__'=20 is the longest constant string in update_abstractmethods co_consts; coincidentally tied with the qualname length of abc.abstractstaticmethod (len=20, covered in extra107); NEW in extra118: first standalone update_abstractmethods co_consts[3] equality invariant in abcuam118 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "update_abstractmethods.__code__.co_consts[3].__eq__"
  args: ["__isabstractmethod__"]
  expected: true

invariant abc_extra118.update_abstractmethods_co_varnames_2_scls:
  description: "abc.update_abstractmethods.__code__.co_varnames[2].__eq__('scls') returns True — co_varnames[2]='scls' (len=4); 'scls' is an abbreviation for 'super class' used as the iteration variable in: for scls in cls.__mro__: for name, value in scls.__dict__.items(): ...; the loop iterates over the class's MRO to collect abstract methods from each base class in the hierarchy; 'scls'=4: 's'=1+'cls'=3=4 — the 's' prefix (for 'super') added to 'cls'=3 makes 'scls'=4 (1 more than 'cls'=3; compare: ABCMeta.__new__ co_varnames[0]='mcls'=4: both 'scls' and 'mcls' are 4-char variations of 'cls' with 1-char prefixes: 's'=super and 'm'=metaclass); co_varnames[2]='scls'=4 is tied in length with co_varnames[3]='name'=4 (both at len=4); shorter than co_varnames[4]='value'=5 and co_varnames[1]='abstracts'=9; prior spec extra114 covered co_varnames[0]='cls' (len=3) and co_varnames[1]='abstracts' (len=9); indices 2, 3, 4 are first covered in this spec; NEW in extra118: first standalone update_abstractmethods co_varnames[2] equality invariant in abcuam118a namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "update_abstractmethods.__code__.co_varnames[2].__eq__"
  args: ["scls"]
  expected: true

invariant abc_extra118.ABCMeta_new_co_consts_len_1:
  description: "abc.ABCMeta.__new__.__code__.co_consts.__len__() == 1 — ABCMeta.__new__ co_consts has only one element: None; this is the fewest co_consts of the main abc functions covered in this spec: abstractmethod=2 (extra116), abstractclassmethod.__init__=2 (extra117), update_abstractmethods=6 (this spec), ABCMeta.__new__=1 (fewest); ABCMeta.__new__ stores the string constants '__abstractmethods__' and '__isabstractmethod__' differently than update_abstractmethods does in Python 3.14.3 — Python 3.14.3 may compile ABCMeta.__new__ with fewer or different constants depending on the CPython version's optimizations; ABCMeta.__new__.__code__.co_varnames.__len__()==6 (covered in extra112: mcls, name, bases, namespace, kwargs, cls); ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15, covered in extra109); the single co_consts[0]==None represents the implicit return constant; compare: abstractmethod has 2 co_consts (docstring + True) because it is a decorator that stores True into the function object; ABCMeta.__new__ performs more complex operations (setting __abstractmethods__ on the class) but the Python 3.14.3 compiler inlines some of the attribute lookups; NEW in extra118: first standalone ABCMeta.__new__ co_consts length invariant in abcnew118 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_consts.__len__
  args: []
  expected: 1

