spec: queue_extra15
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "CPython source: Modules/_queuemodule.c"
    - "queue_extra14.zspec.zsdl — covers __module__.__eq__ for all 4 classes; __bases__[0].__name__ for Queue/LifoQueue/PriorityQueue; Empty/Full module, qualname, bases."
    - "queue_extra13.zspec.zsdl — covers Queue/__init__/__repr__ qualnames; LifoQueue/PriorityQueue __init__ qualnames; SimpleQueue.put/get qualnames."
    - "queue_extra12.zspec.zsdl — covers Queue instance method __qualname__.__eq__ for all 9 methods (put/get/put_nowait/get_nowait/empty/full/qsize/task_done/join); LifoQueue/PriorityQueue __qualname__ standalone."
    - "queue_extra6/extra7 — cover Queue method __name__ (put, get, task_done, join, put_nowait, get_nowait)."
  notes:
    - "This spec extends queue.zspec.zsdl through queue_extra14.zspec.zsdl."
    - "Prior specs cover: __qualname__.__eq__ for all 9 Queue instance methods (extra12); __init__/__repr__ qualnames (extra13); __module__ for all classes (extra14); __bases__ for all classes."
    - "NOT yet covered: __qualname__.__len__() for Queue instance methods in extra15 namespace; __qualname__.__len__() for SimpleQueue.put_nowait and SimpleQueue.get_nowait."
    - "Focus: __qualname__.__len__() table for all 9 Queue instance methods; SimpleQueue method __qualname__.__len__() for put_nowait and get_nowait."
    - "queue.Queue.put.__qualname__ = 'Queue.put'; len = 9. Verified Python 3.14.3 macOS."
    - "queue.Queue.get.__qualname__ = 'Queue.get'; len = 9. Verified."
    - "queue.Queue.put_nowait.__qualname__ = 'Queue.put_nowait'; len = 16. Verified."
    - "queue.Queue.get_nowait.__qualname__ = 'Queue.get_nowait'; len = 16. Verified."
    - "queue.Queue.qsize.__qualname__ = 'Queue.qsize'; len = 11. Verified."
    - "queue.Queue.empty.__qualname__ = 'Queue.empty'; len = 11. Verified."
    - "queue.Queue.full.__qualname__ = 'Queue.full'; len = 10. Verified."
    - "queue.Queue.join.__qualname__ = 'Queue.join'; len = 10. Verified."
    - "queue.Queue.task_done.__qualname__ = 'Queue.task_done'; len = 15. Verified."
    - "queue.SimpleQueue.put_nowait.__qualname__ = 'SimpleQueue.put_nowait'; len = 22. Verified."
    - "queue.SimpleQueue.get_nowait.__qualname__ = 'SimpleQueue.get_nowait'; len = 22. Verified."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue instance method __qualname__.__len__() — all 9 methods
#
# queue_extra12 covers __qualname__.__eq__ for all 9 Queue instance methods.
# No prior queue spec checks __qualname__.__len__() for Queue methods. The
# qualname pattern is 'Queue.<method>', so lengths include the 'Queue.' prefix
# (7 chars) plus the method name length. id_prefix qmqlen15 is novel.
# ---------------------------------------------------------------------------

table queue_extra15.queue_method_qualname_lengths:
  description: "__qualname__.__len__() for all 9 Queue instance methods — 'Queue.<method>' pattern"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qmqlen15

  columns: [id, function, args, expected]
  rows:
    - [put,       "Queue.put.__qualname__.__len__",       [], 9]
    - [get,       "Queue.get.__qualname__.__len__",       [], 9]
    - [put_nowait,"Queue.put_nowait.__qualname__.__len__",[], 16]
    - [get_nowait,"Queue.get_nowait.__qualname__.__len__",[], 16]
    - [qsize,     "Queue.qsize.__qualname__.__len__",     [], 11]
    - [empty,     "Queue.empty.__qualname__.__len__",     [], 11]
    - [full,      "Queue.full.__qualname__.__len__",      [], 10]
    - [join,      "Queue.join.__qualname__.__len__",      [], 10]
    - [task_done, "Queue.task_done.__qualname__.__len__", [], 15]

# ---------------------------------------------------------------------------
# SimpleQueue.put_nowait and SimpleQueue.get_nowait __qualname__.__len__()
#
# queue_extra13 covers SimpleQueue.put.__qualname__ and SimpleQueue.get.__qualname__.
# No prior queue spec covers __qualname__ for SimpleQueue.put_nowait or
# SimpleQueue.get_nowait. These are C-level wrapper methods on SimpleQueue.
# Their __qualname__ follows 'SimpleQueue.<method>': len('SimpleQueue.put_nowait')
# == 22 and len('SimpleQueue.get_nowait') == 22.
# ---------------------------------------------------------------------------

invariant queue_extra15.SimpleQueue.put_nowait_qualname_eq:
  description: "queue.SimpleQueue.put_nowait.__qualname__ == 'SimpleQueue.put_nowait' — C-level method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: "SimpleQueue.put_nowait.__qualname__.__eq__"
  args: ["SimpleQueue.put_nowait"]
  expected: true

invariant queue_extra15.SimpleQueue.put_nowait_qualname_len:
  description: "queue.SimpleQueue.put_nowait.__qualname__.__len__() == 22 — len('SimpleQueue.put_nowait') == 22"
  category: method_qualnames
  kind: python_call_eq
  function: "SimpleQueue.put_nowait.__qualname__.__len__"
  args: []
  expected: 22

invariant queue_extra15.SimpleQueue.get_nowait_qualname_eq:
  description: "queue.SimpleQueue.get_nowait.__qualname__ == 'SimpleQueue.get_nowait' — C-level method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: "SimpleQueue.get_nowait.__qualname__.__eq__"
  args: ["SimpleQueue.get_nowait"]
  expected: true

invariant queue_extra15.SimpleQueue.get_nowait_qualname_len:
  description: "queue.SimpleQueue.get_nowait.__qualname__.__len__() == 22 — len('SimpleQueue.get_nowait') == 22"
  category: method_qualnames
  kind: python_call_eq
  function: "SimpleQueue.get_nowait.__qualname__.__len__"
  args: []
  expected: 22
