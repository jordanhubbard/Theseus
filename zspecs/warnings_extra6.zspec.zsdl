spec: warnings_extra6
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Python/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl and prior extras."
    - "Prior specs cover: __name__ for warn/warn_explicit/filterwarnings/simplefilter/resetwarnings/showwarning/formatwarning/catch_warnings/WarningMessage (warnings.zspec + warnings_extra + warnings_extra4); __module__ for warn (warnings_extra); __qualname__ for warn/warn_explicit/filterwarnings/simplefilter/resetwarnings/catch_warnings/WarningMessage (warnings_extra5); warning category __class__.__name__ (warnings_extra5)."
    - "This spec adds __module__ for filterwarnings, simplefilter, resetwarnings, showwarning, formatwarning — all in '_py_warnings'."
    - "This spec adds __module__ and __qualname__ for showwarning and formatwarning."
    - "This spec adds __qualname__ for warning category classes DeprecationWarning, UserWarning, RuntimeWarning, FutureWarning, PendingDeprecationWarning."
    - "warnings.showwarning.__module__ == '_py_warnings' — implemented in the Python-layer warnings module, exposed as _py_warnings internally."
    - "warnings.warn_explicit.__module__ == '_warnings' — implemented in the C extension _warnings."
    - "DeprecationWarning.__qualname__ == 'DeprecationWarning' — built-in exception class, top-level definition."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — functions whose __module__ was not previously covered
# filterwarnings, simplefilter, resetwarnings, showwarning, formatwarning
# are all defined in the Python-layer of warnings, reported as '_py_warnings'.
# ---------------------------------------------------------------------------

table warnings_extra6.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [filterwarnings, filterwarnings.__module__.__eq__, ["_py_warnings"], true]
    - [simplefilter,   simplefilter.__module__.__eq__,   ["_py_warnings"], true]
    - [resetwarnings,  resetwarnings.__module__.__eq__,  ["_py_warnings"], true]
    - [showwarning,    showwarning.__module__.__eq__,    ["_py_warnings"], true]
    - [formatwarning,  formatwarning.__module__.__eq__,  ["_py_warnings"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — showwarning and formatwarning (not in extra5)
# ---------------------------------------------------------------------------

invariant warnings_extra6.showwarning.qualname:
  description: "warnings.showwarning.__qualname__ == 'showwarning'"
  category: qualnames
  kind: python_call_eq
  function: showwarning.__qualname__.__eq__
  args: ["showwarning"]
  expected: true

invariant warnings_extra6.formatwarning.qualname:
  description: "warnings.formatwarning.__qualname__ == 'formatwarning'"
  category: qualnames
  kind: python_call_eq
  function: formatwarning.__qualname__.__eq__
  args: ["formatwarning"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — built-in warning category classes
# These are top-level built-in exception subclasses; __qualname__ == __name__.
# ---------------------------------------------------------------------------

table warnings_extra6.warning_category_qualnames:
  kind: python_call_eq
  category: warning_category_qualnames
  id_prefix: wqualname

  columns: [id, function, args, expected]
  rows:
    - [DeprecationWarning,        DeprecationWarning.__qualname__.__eq__,        ["DeprecationWarning"],        true]
    - [UserWarning,               UserWarning.__qualname__.__eq__,               ["UserWarning"],               true]
    - [RuntimeWarning,            RuntimeWarning.__qualname__.__eq__,            ["RuntimeWarning"],            true]
    - [FutureWarning,             FutureWarning.__qualname__.__eq__,             ["FutureWarning"],             true]
    - [PendingDeprecationWarning, PendingDeprecationWarning.__qualname__.__eq__,  ["PendingDeprecationWarning"],  true]
