spec: itertools_extra54
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra53.zspec.zsdl."
    - "Prior specs covered __dict__.__class__.__name__.__len__()==12 for groupby/chain/count/product/accumulate/combinations (various specs). No prior itertools spec records __dict__.__class__.__name__.__eq__('mappingproxy') as an explicit invariant row for any itertools type."
    - "No prior itertools spec records __dict__.__class__.__qualname__.__eq__('mappingproxy') for any itertools type."
    - "No prior itertools spec records __doc__.__class__.__module__.__eq__('builtins') for the module itself or any itertools type."
    - "This spec covers: itertools.groupby.__dict__.__class__.__name__.__eq__('mappingproxy')==true; itertools.chain.__dict__.__class__.__name__.__eq__('mappingproxy')==true; itertools.count.__dict__.__class__.__name__.__eq__('mappingproxy')==true; itertools.product.__dict__.__class__.__name__.__eq__('mappingproxy')==true; itertools.accumulate.__dict__.__class__.__name__.__eq__('mappingproxy')==true; itertools.combinations.__dict__.__class__.__name__.__eq__('mappingproxy')==true; itertools.groupby.__dict__.__class__.__qualname__.__eq__('mappingproxy')==true; itertools.chain.__dict__.__class__.__qualname__.__eq__('mappingproxy')==true; itertools.__doc__.__class__.__module__.__eq__('builtins')==true; itertools.groupby.__doc__.__class__.__module__.__eq__('builtins')==true; itertools.chain.__doc__.__class__.__module__.__eq__('builtins')==true."
    - "Key findings: Python C-extension class __dict__ is always a mappingproxy whose type is builtins.mappingproxy. mappingproxy.__name__ == 'mappingproxy' (12 chars) and mappingproxy.__qualname__ == 'mappingproxy' (12 chars; top-level type). Prior itertools specs only recorded the length (12) via __len__(). The string equality form .__eq__('mappingproxy') is new for all itertools types. The __qualname__ form is entirely new. Additionally, itertools docstrings are Python str objects, and the str type belongs to the builtins module, so str.__module__ == 'builtins'; this __doc__.__class__.__module__ chain has not been recorded for any itertools object. All eleven invariants are new to extra54."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools type __dict__.__class__.__name__ == 'mappingproxy' — extra54
#
# All itertools types are C-level types defined in Modules/itertoolsmodule.c.
# Their class __dict__ is a mappingproxy object whose type is builtins.mappingproxy.
# mappingproxy.__name__ == 'mappingproxy' (12 chars). Prior specs recorded
# __dict__.__class__.__name__.__len__()==12 for groupby/chain/count/product/
# accumulate/combinations, but no prior itertools spec records the string
# equality form __dict__.__class__.__name__.__eq__('mappingproxy') for any
# itertools type. All six checks below are new to extra54.
# ---------------------------------------------------------------------------

table itertools_extra54.dict_class_name_eq:
  description: "itertools type __dict__.__class__.__name__ == 'mappingproxy' — C-level class __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior specs recorded __len__()==12; string equality form is new to extra54"
  kind: python_call_eq
  category: identity
  id_prefix: itertdict54

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_dict_class_name,
       groupby.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.groupby.__dict__.__class__.__name__ == 'mappingproxy' — groupby is a C-level type in Modules/itertoolsmodule.c that groups consecutive elements of an iterable sharing a common key; its __dict__ is a mappingproxy (Python's read-only class namespace wrapper); mappingproxy.__name__ == 'mappingproxy' (12 chars); prior specs confirmed groupby.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first __dict__.__class__.__name__.__eq__('mappingproxy') row for groupby; new to extra54"]
    - [chain_dict_class_name,
       chain.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.chain.__dict__.__class__.__name__ == 'mappingproxy' — chain is a C-level type in Modules/itertoolsmodule.c that chains multiple iterables into one; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior specs confirmed chain.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first __dict__.__class__.__name__.__eq__('mappingproxy') row for chain; new to extra54"]
    - [count_dict_class_name,
       count.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.count.__dict__.__class__.__name__ == 'mappingproxy' — count is a C-level type in Modules/itertoolsmodule.c that counts up from a start value with an optional step; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior specs confirmed count.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first __dict__.__class__.__name__.__eq__('mappingproxy') row for count; new to extra54"]
    - [product_dict_class_name,
       product.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.product.__dict__.__class__.__name__ == 'mappingproxy' — product is a C-level type in Modules/itertoolsmodule.c that yields the Cartesian product of input iterables; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior specs confirmed product.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first __dict__.__class__.__name__.__eq__('mappingproxy') row for product; new to extra54"]
    - [accumulate_dict_class_name,
       accumulate.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.accumulate.__dict__.__class__.__name__ == 'mappingproxy' — accumulate is a C-level type in Modules/itertoolsmodule.c that yields accumulated sums (or other binary function results) from an iterable; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior specs confirmed accumulate.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first __dict__.__class__.__name__.__eq__('mappingproxy') row for accumulate; new to extra54"]
    - [combinations_dict_class_name,
       combinations.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.combinations.__dict__.__class__.__name__ == 'mappingproxy' — combinations is a C-level type in Modules/itertoolsmodule.c that yields r-length subsequences of elements without replacement; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior specs confirmed combinations.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first __dict__.__class__.__name__.__eq__('mappingproxy') row for combinations; new to extra54"]

# ---------------------------------------------------------------------------
# itertools type __dict__.__class__.__qualname__ == 'mappingproxy' — extra54
#
# The mappingproxy type is a top-level type in the builtins module with no
# enclosing class scope, so its __qualname__ == __name__ == 'mappingproxy'
# (12 chars). No prior itertools spec records __dict__.__class__.__qualname__
# for any itertools type. The two checks below establish this new dimension.
# ---------------------------------------------------------------------------

table itertools_extra54.dict_class_qualname_eq:
  description: "itertools type __dict__.__class__.__qualname__ == 'mappingproxy' — mappingproxy is a top-level type so __qualname__ == __name__ == 'mappingproxy' (12 chars); __qualname__ form not recorded in any prior itertools spec"
  kind: python_call_eq
  category: identity
  id_prefix: itertdict54

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_dict_class_qualname,
       groupby.__dict__.__class__.__qualname__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.groupby.__dict__.__class__.__qualname__ == 'mappingproxy' — groupby's class __dict__ is a mappingproxy; the mappingproxy type is a top-level type with __qualname__ == __name__ == 'mappingproxy' (12 chars; no enclosing class scope); consistent with extra54's groupby.__dict__.__class__.__name__.__eq__('mappingproxy'); no prior itertools spec records __dict__.__class__.__qualname__ for groupby; new to extra54"]
    - [chain_dict_class_qualname,
       chain.__dict__.__class__.__qualname__.__eq__,
       ["mappingproxy"],
       true,
       "itertools.chain.__dict__.__class__.__qualname__ == 'mappingproxy' — chain's class __dict__ is a mappingproxy; the mappingproxy type is a top-level type with __qualname__ == __name__ == 'mappingproxy' (12 chars); consistent with extra54's chain.__dict__.__class__.__name__.__eq__('mappingproxy'); no prior itertools spec records __dict__.__class__.__qualname__ for chain; new to extra54"]

# ---------------------------------------------------------------------------
# itertools __doc__.__class__.__module__ == 'builtins' — extra54
#
# itertools docstrings are Python str objects. The str built-in type belongs
# to the builtins module, so str.__module__ == 'builtins' (8 chars). The chain:
#   obj.__doc__.__class__.__module__
# yields the module name of the type of the docstring — always 'builtins' for
# any Python str object. No prior itertools spec records this __doc__.__class__
# .__module__ dimension for the module itself or any itertools type. All three
# checks below are new to extra54.
# ---------------------------------------------------------------------------

table itertools_extra54.doc_class_module_eq:
  description: "itertools __doc__.__class__.__module__ == 'builtins' — itertools docstrings are str objects; str.__module__ == 'builtins' (8 chars); no prior itertools spec records this __doc__.__class__.__module__ chain; new to extra54"
  kind: python_call_eq
  category: identity
  id_prefix: itertdict54

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class_module,
       __doc__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.__doc__.__class__.__module__ == 'builtins' — the itertools module itself has a __doc__ docstring that is a Python str object; the str built-in type has __module__ == 'builtins' (8 chars); this chain __doc__.__class__.__module__ measures the module ownership of the str type; no prior itertools spec records this invariant for the module-level __doc__; new to extra54"]
    - [groupby_doc_class_module,
       groupby.__doc__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.groupby.__doc__.__class__.__module__ == 'builtins' — groupby is a C-level type whose __doc__ is a Python str object (C-extension docstrings are exposed as Python str objects); the str built-in type has __module__ == 'builtins' (8 chars); no prior itertools spec records __doc__.__class__.__module__ for groupby; new to extra54"]
    - [chain_doc_class_module,
       chain.__doc__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.chain.__doc__.__class__.__module__ == 'builtins' — chain is a C-level type whose __doc__ is a Python str object; the str built-in type has __module__ == 'builtins' (8 chars); no prior itertools spec records __doc__.__class__.__module__ for chain; new to extra54"]
