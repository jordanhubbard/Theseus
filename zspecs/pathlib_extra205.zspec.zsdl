spec: pathlib_extra205
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib class __name__ lengths not covered by prior pathlib_extra specs."
    - "pathlib.Path.__name__ == 'Path' (len=4); the main concrete path class; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__name__ == 'PurePath' (len=8); pure (non-I/O) base class for all path types; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13); pure POSIX path; confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15); pure Windows path; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (len=9); concrete POSIX path; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (len=11); concrete Windows path; confirmed Python 3.14.3 macOS."
    - "pathlib.__name__ == 'pathlib' (len=7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS."
    - "pathlib.__package__ == 'pathlib' (len=7); pathlib is a top-level package; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib pure path class __name__ lengths
# PurePath(8), PurePosixPath(13), PureWindowsPath(15)
# ---------------------------------------------------------------------------

table pathlib_extra205.pure_path_name_lengths:
  description: "pathlib pure path class __name__ lengths: PurePath(8), PurePosixPath(13), PureWindowsPath(15)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibnamelens205

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_name_len,        pathlib.PurePath.__name__.__len__,        [], 8,  "pathlib.PurePath.__name__.__len__() == 8 — P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); pure base class for all path types; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_name_len,   pathlib.PurePosixPath.__name__.__len__,   [], 13, "pathlib.PurePosixPath.__name__.__len__() == 13 — P(1)u(2)r(3)e(4)P(5)o(6)s(7)i(8)x(9)P(10)a(11)t(12)h(13); pure POSIX path; confirmed Python 3.14.3 macOS"]
    - [purewindowspath_name_len, pathlib.PureWindowsPath.__name__.__len__, [], 15, "pathlib.PureWindowsPath.__name__.__len__() == 15 — P(1)u(2)r(3)e(4)W(5)i(6)n(7)d(8)o(9)w(10)s(11)P(12)a(13)t(14)h(15); pure Windows path; confirmed Python 3.14.3 macOS"]
    - [purepath_name_eq,         pathlib.PurePath.__name__.__eq__,         ["PurePath"], true, "pathlib.PurePath.__name__ == 'PurePath' (len=8); confirmed Python 3.14.3 macOS"]
    - [pureposixpath_name_eq,    pathlib.PurePosixPath.__name__.__eq__,    ["PurePosixPath"], true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib concrete path class __name__ lengths
# Path(4), PosixPath(9), WindowsPath(11)
# ---------------------------------------------------------------------------

table pathlib_extra205.concrete_path_name_lengths:
  description: "pathlib concrete path class __name__ lengths: Path(4), PosixPath(9), WindowsPath(11)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibnamelens205

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_len,        pathlib.Path.__name__.__len__,        [], 4,  "pathlib.Path.__name__.__len__() == 4 — P(1)a(2)t(3)h(4); main concrete path class; confirmed Python 3.14.3 macOS"]
    - [posixpath_name_len,   pathlib.PosixPath.__name__.__len__,   [], 9,  "pathlib.PosixPath.__name__.__len__() == 9 — P(1)o(2)s(3)i(4)x(5)P(6)a(7)t(8)h(9); concrete POSIX path; confirmed Python 3.14.3 macOS"]
    - [windowspath_name_len, pathlib.WindowsPath.__name__.__len__, [], 11, "pathlib.WindowsPath.__name__.__len__() == 11 — W(1)i(2)n(3)d(4)o(5)w(6)s(7)P(8)a(9)t(10)h(11); concrete Windows path; confirmed Python 3.14.3 macOS"]
    - [path_name_eq,         pathlib.Path.__name__.__eq__,         ["Path"], true, "pathlib.Path.__name__ == 'Path' (len=4); confirmed Python 3.14.3 macOS"]
    - [posixpath_name_eq,    pathlib.PosixPath.__name__.__eq__,    ["PosixPath"], true, "pathlib.PosixPath.__name__ == 'PosixPath' (len=9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib module __name__ and __package__ lengths
# __name__(7), __package__(7)
# ---------------------------------------------------------------------------

table pathlib_extra205.module_name_lengths:
  description: "pathlib module __name__ and __package__ lengths: both 'pathlib'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibnamelens205

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,       pathlib.__name__.__len__,       [], 7, "pathlib.__name__.__len__() == 7 — p(1)a(2)t(3)h(4)l(5)i(6)b(7); the module's own __name__; confirmed Python 3.14.3 macOS"]
    - [module_package_len,    pathlib.__package__.__len__,    [], 7, "pathlib.__package__.__len__() == 7 — same string as __name__; pathlib is a top-level package; confirmed Python 3.14.3 macOS"]
    - [module_name_eq,        pathlib.__name__.__eq__,        ["pathlib"], true, "pathlib.__name__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS"]
    - [module_package_eq,     pathlib.__package__.__eq__,     ["pathlib"], true, "pathlib.__package__ == 'pathlib' (len=7); confirmed Python 3.14.3 macOS"]
    - [purewindowspath_name_eq, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true, "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra205.path_name_len:
  description: "pathlib.Path.__name__.__len__() == 4 — 'Path' has 4 characters: P(1)a(2)t(3)h(4); Path is the main concrete filesystem path class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra205.purepath_name_len:
  description: "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' has 8 characters: P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); PurePath is the pure (non-I/O) base class for all path types; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra205.pureposixpath_name_len:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters; pure POSIX path class with no I/O operations; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__name__.__len__
  args: []
  expected: 13

invariant pathlib_extra205.purewindowspath_name_len:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' has 15 characters; the longest name in the pathlib class hierarchy; pure Windows path; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra205.posixpath_name_len:
  description: "pathlib.PosixPath.__name__.__len__() == 9 — 'PosixPath' has 9 characters: P(1)o(2)s(3)i(4)x(5)P(6)a(7)t(8)h(9); concrete POSIX path class available on Unix systems; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PosixPath.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra205.windowspath_name_len:
  description: "pathlib.WindowsPath.__name__.__len__() == 11 — 'WindowsPath' has 11 characters: W(1)i(2)n(3)d(4)o(5)w(6)s(7)P(8)a(9)t(10)h(11); concrete Windows path class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__name__.__len__
  args: []
  expected: 11

invariant pathlib_extra205.module_name_len:
  description: "pathlib.__name__.__len__() == 7 — 'pathlib' has 7 characters: p(1)a(2)t(3)h(4)l(5)i(6)b(7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__name__.__len__
  args: []
  expected: 7

invariant pathlib_extra205.module_package_len:
  description: "pathlib.__package__.__len__() == 7 — 'pathlib' has 7 characters; __package__ equals __name__ for a top-level package; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__package__.__len__
  args: []
  expected: 7
