spec: multiprocessing_extra68
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Python multiprocessing Pool documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra67.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__/__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/active_children/current_process __qualname__, Pool/Queue __doc__.__class__.__name__=='str', exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process/Pool method tables, __mro__.__len__() tables, __all__ metadata, class __dict__ tables, class __class__ identity, __repr__/__weakref__/__eq__ class names, mp.__all__ membership and length, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, exception hierarchy (__name__/__bases__[0]/__mro__.__len__()) for all mp exceptions."
    - "This spec covers (mpmore68 namespace): wave 236 theme — multiprocessing Process and Pool class doc content + Pool.__init__ code object attributes. NEW in extra68: Process.__doc__.__class__.__name__.__eq__('str'); Process.__doc__.__contains__('daemon')==True; Pool.__doc__.__class__.__name__.__eq__('str'); Pool.__doc__.__contains__('Pool')==True; Pool.__doc__.__contains__('worker')==True; Pool.__init__.__code__.co_name.__eq__('__init__'); Pool.__init__.__code__.co_argcount==6; Pool.__init__.__defaults__.__class__.__name__.__eq__('tuple'); Pool.__init__.__defaults__.__len__()==5."
    - "multiprocessing.Process.__doc__.__class__.__name__ == 'str'. Process is a pure Python class in multiprocessing/process.py with a docstring; Process.__doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__doc__.__contains__('daemon') == True. Process has a daemon attribute that is a key feature; the docstring references 'daemon'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__doc__.__class__.__name__ == 'str'. Pool is a pure Python class in multiprocessing/pool.py with a docstring; Pool.__doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__doc__.__contains__('Pool') == True. Pool's docstring references the class name 'Pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__doc__.__contains__('worker') == True. Pool manages a pool of worker processes; the docstring references 'worker'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__init__.__code__.co_name == '__init__'. Pool.__init__ is a Python function; its code object's co_name is the function's simple name '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__init__.__code__.co_argcount == 6. Pool.__init__ signature is def __init__(self, processes=None, initializer=None, initargs=(), maxtasksperchild=None, context=None): — 6 positional parameters including self; co_argcount is 6. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__init__.__defaults__.__class__.__name__ == 'tuple'. Pool.__init__ has 5 default arguments (processes, initializer, initargs, maxtasksperchild, context); __defaults__ is a tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__init__.__defaults__.__len__() == 5. Pool.__init__ has defaults for all 5 non-self parameters; __defaults__.__len__() returns 5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process __doc__ extended checks — extra68
#
# Wave 236 theme: Process class doc content.
#
# Process.__doc__.__class__.__name__ == 'str'  (already known, new vector here)
# Process.__doc__.__contains__('daemon') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra68.Process_doc_extended:
  description: "multiprocessing Process/__doc__.__class__.__name__ and __doc__.__contains__('daemon') checks in mpmore68 namespace — wave 236 theme: Process class doc content; Process.__doc__.__class__.__name__=='str' (Process is a pure Python class with a docstring); Process.__doc__.__contains__('daemon')==True (Process.daemon is a key attribute described in the docstring); NEW in extra68: first __doc__.__class__.__name__ and __doc__.__contains__('daemon') checks for Process in the mpmore68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: mpmore68

  columns: [id, function, args, expected, description]
  rows:
    - [process_doc_class,  Process.__doc__.__class__.__name__.__eq__, ["str"],    true, "Process.__doc__.__class__.__name__ == 'str' — multiprocessing.Process is a pure Python class in multiprocessing/process.py with a docstring; Process.__doc__ is a str; __doc__.__class__.__name__ is 'str'; NEW in extra68: first __doc__.__class__.__name__.__eq__('str') check for Process in the mpmore68 namespace; verified with Python 3.14.3"]
    - [process_doc_daemon, Process.__doc__.__contains__,              ["daemon"], true, "Process.__doc__.__contains__('daemon') == True — multiprocessing.Process has a daemon attribute that is a key feature; the docstring references 'daemon'; __doc__.__contains__('daemon') returns True; NEW in extra68: first __doc__.__contains__('daemon') check for Process in the mpmore68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Pool __doc__ checks — extra68
#
# Wave 236 theme: Pool class doc content.
#
# Pool.__doc__.__class__.__name__ == 'str'
# Pool.__doc__.__contains__('Pool') == True
# Pool.__doc__.__contains__('worker') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra68.Pool_doc:
  description: "multiprocessing Pool/__doc__.__class__.__name__ and __doc__.__contains__ checks in mpmore68 namespace — wave 236 theme: Pool class doc content; Pool.__doc__.__class__.__name__=='str' (Pool is a pure Python class in multiprocessing/pool.py with a docstring); Pool.__doc__.__contains__('Pool')==True (docstring references the class name); Pool.__doc__.__contains__('worker')==True (Pool manages worker processes, referenced in docstring); NEW in extra68: first __doc__.__class__.__name__ and __doc__.__contains__ checks for Pool in the mpmore68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: mpmore68a

  columns: [id, function, args, expected, description]
  rows:
    - [pool_doc_class,   Pool.__doc__.__class__.__name__.__eq__, ["str"],    true,  "Pool.__doc__.__class__.__name__ == 'str' — multiprocessing.Pool is a pure Python class in multiprocessing/pool.py with a docstring; Pool.__doc__ is a str; __doc__.__class__.__name__ is 'str'; NEW in extra68: first __doc__.__class__.__name__.__eq__('str') check for Pool in the mpmore68 namespace; verified with Python 3.14.3"]
    - [pool_doc_Pool,    Pool.__doc__.__contains__,              ["Pool"],   true,  "Pool.__doc__.__contains__('Pool') == True — multiprocessing.Pool's docstring references the class name 'Pool'; __doc__.__contains__('Pool') returns True; NEW in extra68: first __doc__.__contains__('Pool') check for Pool in the mpmore68 namespace; verified with Python 3.14.3"]
    - [pool_doc_worker,  Pool.__doc__.__contains__,              ["worker"], true,  "Pool.__doc__.__contains__('worker') == True — multiprocessing.Pool manages a pool of worker processes; the docstring references 'worker'; __doc__.__contains__('worker') returns True; NEW in extra68: first __doc__.__contains__('worker') check for Pool in the mpmore68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Pool.__init__ code object checks — extra68
#
# Wave 236 theme: Pool.__init__ code object identity.
#
# Pool.__init__.__code__.co_name == '__init__'
# Pool.__init__.__code__.co_argcount == 6
# Pool.__init__.__defaults__.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table multiprocessing_extra68.Pool_init_code:
  description: "multiprocessing Pool.__init__ code object attribute checks in mpmore68 namespace — wave 236 theme: Pool.__init__ code object identity; Pool.__init__.__code__.co_name=='__init__' (the code object's name is the function's simple name '__init__'); Pool.__init__.__code__.co_argcount==6 (self + processes + initializer + initargs + maxtasksperchild + context = 6); Pool.__init__.__defaults__.__class__.__name__=='tuple' (Pool.__init__ has 5 default arguments stored as a tuple); NEW in extra68: first co_name/co_argcount/__defaults__ class checks for Pool.__init__ in the mpmore68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpmore68b

  columns: [id, function, args, expected, description]
  rows:
    - [pool_init_co_name,         Pool.__init__.__code__.co_name.__eq__,                      ["__init__"], true, "Pool.__init__.__code__.co_name == '__init__' — Pool.__init__ is a Python function; its code object stores the function's simple name as co_name; co_name is '__init__'; __eq__('__init__') returns True; NEW in extra68: first co_name.__eq__('__init__') check for Pool.__init__ in the mpmore68 namespace; verified with Python 3.14.3"]
    - [pool_init_co_argcount,     Pool.__init__.__code__.co_argcount.__eq__,                  [6],          true, "Pool.__init__.__code__.co_argcount == 6 — Pool.__init__ has signature def __init__(self, processes=None, initializer=None, initargs=(), maxtasksperchild=None, context=None): with 6 positional parameters including self; co_argcount is 6; __eq__(6) returns True; NEW in extra68: first co_argcount.__eq__(6) check for Pool.__init__ in the mpmore68 namespace; verified with Python 3.14.3"]
    - [pool_init_defaults_class,  Pool.__init__.__defaults__.__class__.__name__.__eq__,       ["tuple"],    true, "Pool.__init__.__defaults__.__class__.__name__ == 'tuple' — Pool.__init__ has 5 default arguments (processes=None, initializer=None, initargs=(), maxtasksperchild=None, context=None); __defaults__ is a tuple; __defaults__.__class__.__name__ is 'tuple'; NEW in extra68: first __defaults__.__class__.__name__.__eq__('tuple') check for Pool.__init__ in the mpmore68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
