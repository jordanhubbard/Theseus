table multiprocessing_extra68.Pool_init_defaults:
  description: "multiprocessing Pool.__init__.__defaults__.__len__() check in mpmore68 namespace — wave 236 theme: Pool.__init__ defaults count; Pool.__init__.__defaults__.__len__()==5 (Pool.__init__ has 5 default arguments: processes=None, initializer=None, initargs=(), maxtasksperchild=None, context=None; __defaults__ is a tuple of 5 elements); NEW in extra68: first __defaults__.__len__()==5 check for Pool.__init__ in the mpmore68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpmore68c

  columns: [id, function, args, expected, description]
  rows:
    - [pool_init_defaults_len, Pool.__init__.__defaults__.__len__, [], 5, "Pool.__init__.__defaults__.__len__() == 5 — Pool.__init__ has default arguments for all 5 non-self parameters: processes=None, initializer=None, initargs=(), maxtasksperchild=None, context=None; __defaults__ is a tuple of 5 elements; __defaults__.__len__() returns 5; NEW in extra68: first __defaults__.__len__()==5 check for Pool.__init__ in the mpmore68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra68
# ---------------------------------------------------------------------------

invariant multiprocessing_extra68.Process_doc_daemon:
  description: "multiprocessing.Process.__doc__.__contains__('daemon') returns True — multiprocessing.Process has a daemon attribute that is a key feature; the docstring references 'daemon'; __doc__.__contains__('daemon') returns True; NEW in extra68: first standalone __doc__.__contains__('daemon') invariant for Process in the mpmore68 namespace; wave 236 first doc content invariant for Process.daemon; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: Process.__doc__.__contains__
  args: ["daemon"]
  expected: true

invariant multiprocessing_extra68.Pool_doc_str:
  description: "multiprocessing.Pool.__doc__.__class__.__name__.__eq__('str') returns True — multiprocessing.Pool is a pure Python class in multiprocessing/pool.py with a docstring; Pool.__doc__ is a str; __doc__.__class__.__name__.__eq__('str') returns True; NEW in extra68: first standalone __doc__.__class__.__name__.__eq__('str') invariant for Pool in the mpmore68 namespace; wave 236 first doc class name invariant for Pool; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: Pool.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra68.Pool_doc_Pool:
  description: "multiprocessing.Pool.__doc__.__contains__('Pool') returns True — multiprocessing.Pool's docstring references the class name 'Pool'; __doc__.__contains__('Pool') returns True; NEW in extra68: first standalone __doc__.__contains__('Pool') invariant for Pool in the mpmore68 namespace; wave 236 first doc content invariant for Pool; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: Pool.__doc__.__contains__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra68.Pool_init_co_argcount_6:
  description: "multiprocessing.Pool.__init__.__code__.co_argcount.__eq__(6) returns True — Pool.__init__ has signature def __init__(self, processes=None, initializer=None, initargs=(), maxtasksperchild=None, context=None): with 6 positional parameters including self; co_argcount is 6; __eq__(6) returns True; NEW in extra68: first standalone co_argcount.__eq__(6) invariant for Pool.__init__ in the mpmore68 namespace; wave 236 first co_argcount invariant for Pool.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Pool.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant multiprocessing_extra68.Pool_init_defaults_len_5:
  description: "multiprocessing.Pool.__init__.__defaults__.__len__() == 5 — Pool.__init__ has default arguments for all 5 non-self parameters: processes=None, initializer=None, initargs=(), maxtasksperchild=None, context=None; __defaults__ is a tuple of 5 elements; __defaults__.__len__() returns 5; NEW in extra68: first standalone __defaults__.__len__()==5 invariant for Pool.__init__ in the mpmore68 namespace; wave 236 first defaults length invariant for Pool.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
