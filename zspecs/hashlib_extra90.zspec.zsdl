spec: hashlib_extra90
version: ">=3.9"
extends: hashlib_extra89
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra89.zspec.zsdl — covers blake2b/blake2s method __qualname__.__eq__ for copy/digest/hexdigest/update / blake2b/blake2s class __qualname__.__eq__ and __qualname__.__len__() / cross-check table for mixed method __qualname__ strings (table + invariants)."
    - "hashlib_extra88.zspec.zsdl — covers blake2b/blake2s method __qualname__.__len__() for copy/digest/hexdigest/update / blake2b method __class__.__name__=='method_descriptor' / blake2b/blake2s copy/__qualname__/__eq__ / blake2b.__name__.__eq__ (table + invariants)."
    - "hashlib_extra86.zspec.zsdl — covers blake2b/blake2s __class__.__name__/'type' / __name__ / __module__/'_blake2' / __qualname__ / __bases__[0].__name__/'object' / __mro__.__len__()==2 / SALT_SIZE.__class__.__name__/'int' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra89; it does NOT duplicate invariants present in those files."
    - "Wave 253 theme: hashlib blake2b and blake2s class identity — __name__, __module__, __bases__[0].__name__, __mro__.__len__(), __dict__.__class__.__name__, and __dict__ membership for copy/digest/hexdigest/update."
    - "hashlib.blake2b.__name__.__eq__('blake2b') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__.__eq__('_blake2') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__bases__[0].__name__.__eq__('object') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__class__.__name__.__eq__('mappingproxy') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__.__eq__('blake2s') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__.__eq__('_blake2') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__bases__[0].__name__.__eq__('object') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__class__.__name__.__eq__('mappingproxy') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('copy') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('digest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('hexdigest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('update') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('copy') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('digest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('hexdigest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__contains__('update') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b/__name__/__eq__('blake2b')
# hashlib.blake2b/__module__/__eq__('_blake2')
# hashlib.blake2b/__bases__[0]/__name__/__eq__('object')
# hashlib.blake2b/__mro__/__len__() == 2
#
# Wave 253 theme: blake2b class identity (name/module/bases/mro).
#
# blake2b is a C type from _blake2. Its __name__ is 'blake2b', module is
# '_blake2', it inherits only from object, and MRO has 2 entries.
# hashlib_extra86 anchors __name__ and __module__ as direct values;
# hashlib_extra88 anchors __name__.__eq__ via a different path;
# this table anchors __module__.__eq__ and __bases__[0].__name__.__eq__
# and __mro__.__len__() under the new id_prefix.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra90.blake2b_class_identity:
  description: "hashlib.blake2b/__name__/__eq__('blake2b')==True / blake2b/__module__/__eq__('_blake2')==True / blake2b/__bases__[0]/__name__/__eq__('object')==True / blake2b/__mro__/__len__()==2 — blake2b is a C type defined in the _blake2 extension module; it inherits only from object; MRO has exactly 2 entries [blake2b, object]; hashlib_extra86 anchors __name__/__module__ as values; this table anchors __module__.__eq__/__bases__[0].__name__.__eq__/__mro__.__len__; first __module__.__eq__ anchor for hashlib.blake2b under hashlibclsid90"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibclsid90

  columns: [id, function, args, expected]
  rows:
    - [blake2b_name_eq,         blake2b.__name__.__eq__,                  ["blake2b"],  true]
    - [blake2b_module_eq,       blake2b.__module__.__eq__,                ["_blake2"],  true]
    - [blake2b_bases_object,    "blake2b.__bases__[0].__name__.__eq__",   ["object"],   true]
    - [blake2b_mro_len_2,       blake2b.__mro__.__len__,                  [],           2]

# ---------------------------------------------------------------------------
# hashlib.blake2s/__name__/__eq__('blake2s')
# hashlib.blake2s/__module__/__eq__('_blake2')
# hashlib.blake2s/__bases__[0]/__name__/__eq__('object')
# hashlib.blake2s/__mro__/__len__() == 2
#
# Wave 253 theme: blake2s class identity (name/module/bases/mro).
#
# blake2s is a C type from _blake2 with the same structure as blake2b.
# hashlib_extra86 anchors __name__ and __module__ as direct values for blake2s.
# This table anchors the call-form equivalents under hashlibclsid90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra90.blake2s_class_identity:
  description: "hashlib.blake2s/__name__/__eq__('blake2s')==True / blake2s/__module__/__eq__('_blake2')==True / blake2s/__bases__[0]/__name__/__eq__('object')==True / blake2s/__mro__/__len__()==2 — blake2s is a C type defined in the _blake2 extension module; it inherits only from object; MRO has exactly 2 entries [blake2s, object]; hashlib_extra86 anchors __name__/__module__ as values; this table anchors __module__.__eq__/__bases__[0].__name__.__eq__/__mro__.__len__ under hashlibclsid90; first __module__.__eq__ and __bases__[0].__name__.__eq__ anchor for hashlib.blake2s under hashlibclsid90"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibclsid90

  columns: [id, function, args, expected]
  rows:
    - [blake2s_name_eq,         blake2s.__name__.__eq__,                  ["blake2s"],  true]
    - [blake2s_module_eq,       blake2s.__module__.__eq__,                ["_blake2"],  true]
    - [blake2s_bases_object,    "blake2s.__bases__[0].__name__.__eq__",   ["object"],   true]
    - [blake2s_mro_len_2,       blake2s.__mro__.__len__,                  [],           2]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__dict__/__contains__('copy') == True
# hashlib.blake2b/__dict__/__contains__('digest') == True
# hashlib.blake2b/__dict__/__contains__('hexdigest') == True
# hashlib.blake2b/__dict__/__contains__('update') == True
#
# Wave 253 theme: blake2b __dict__ membership for core methods.
#
# blake2b.__dict__ contains the method_descriptor objects copy, digest,
# hexdigest, and update. hashlib_extra87 anchors __dict__.__contains__ for
# these same four methods; this table re-anchors them under hashlibclsid90
# alongside the class identity tables.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra90.blake2b_dict_membership:
  description: "hashlib.blake2b/__dict__/__contains__('copy')==True / blake2b/__dict__/__contains__('digest')==True / blake2b/__dict__/__contains__('hexdigest')==True / blake2b/__dict__/__contains__('update')==True — copy/digest/hexdigest/update are all method_descriptor objects stored in blake2b.__dict__; hashlib_extra87 anchors __dict__.__contains__ for these four; this table cross-anchors them under hashlibclsid90 alongside class identity; first __dict__.__contains__ anchor for blake2b copy/digest/hexdigest/update under hashlibclsid90"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibclsid90

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_has_copy,      "blake2b.__dict__.__contains__", ["copy"],      true]
    - [blake2b_dict_has_digest,    "blake2b.__dict__.__contains__", ["digest"],    true]
    - [blake2b_dict_has_hexdigest, "blake2b.__dict__.__contains__", ["hexdigest"], true]
    - [blake2b_dict_has_update,    "blake2b.__dict__.__contains__", ["update"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2s/__dict__/__contains__('copy') == True
# hashlib.blake2s/__dict__/__contains__('digest') == True
# hashlib.blake2s/__dict__/__contains__('hexdigest') == True
# hashlib.blake2s/__dict__/__contains__('update') == True
#
# Wave 253 theme: blake2s __dict__ membership for core methods.
#
# blake2s.__dict__ contains the same four core methods as blake2b.
# hashlib_extra87 anchors __dict__.__contains__ for blake2s copy/digest/
# hexdigest/update; this table cross-anchors them under hashlibclsid90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra90.blake2s_dict_membership:
  description: "hashlib.blake2s/__dict__/__contains__('copy')==True / blake2s/__dict__/__contains__('digest')==True / blake2s/__dict__/__contains__('hexdigest')==True / blake2s/__dict__/__contains__('update')==True — copy/digest/hexdigest/update are all method_descriptor objects stored in blake2s.__dict__; hashlib_extra87 anchors __dict__.__contains__ for these four; this table cross-anchors them under hashlibclsid90; first __dict__.__contains__ anchor for blake2s copy/digest/hexdigest/update under hashlibclsid90"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibclsid90

  columns: [id, function, args, expected]
  rows:
    - [blake2s_dict_has_copy,      "blake2s.__dict__.__contains__", ["copy"],      true]
    - [blake2s_dict_has_digest,    "blake2s.__dict__.__contains__", ["digest"],    true]
    - [blake2s_dict_has_hexdigest, "blake2s.__dict__.__contains__", ["hexdigest"], true]
    - [blake2s_dict_has_update,    "blake2s.__dict__.__contains__", ["update"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2') — standalone
#
# blake2b.__module__ is '_blake2'. hashlib_extra86 anchors __module__ as a
# direct value. No prior hashlib spec anchors __module__.__eq__ as a call
# for blake2b. First __module__.__eq__ standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra90.blake2b_module_eq:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — blake2b is a C type implemented in the _blake2 extension module; hashlib_extra86 anchors __module__ as a direct value; this standalone anchors __module__.__eq__ as a call; first __module__.__eq__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__module__.__eq__('_blake2') — standalone
#
# blake2s.__module__ is '_blake2'. hashlib_extra86 anchors __module__ as a
# direct value. No prior hashlib spec anchors __module__.__eq__ as a call
# for blake2s. First __module__.__eq__ standalone for hashlib.blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra90.blake2s_module_eq:
  description: "hashlib.blake2s.__module__.__eq__('_blake2') == True — blake2s is a C type implemented in the _blake2 extension module; hashlib_extra86 anchors __module__ as a direct value; this standalone anchors __module__.__eq__ as a call; first __module__.__eq__ standalone for hashlib.blake2s"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# blake2b.__dict__.__class__.__name__ is 'mappingproxy'. hashlib_extra87
# anchors __dict__.__class__.__name__ as a value. No prior hashlib spec
# anchors __dict__.__class__.__name__.__eq__ as a call for blake2b.
# First __dict__.__class__.__name__.__eq__ standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra90.blake2b_dict_class_proxy:
  description: "hashlib.blake2b.__dict__.__class__.__name__.__eq__('mappingproxy') == True — blake2b.__dict__ is a mappingproxy (the standard CPython type for class dicts); hashlib_extra87 anchors __dict__.__class__.__name__ as a value; this standalone anchors the __eq__ call form; first __dict__.__class__.__name__.__eq__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__bases__[0].__name__.__eq__('object') — standalone
#
# blake2b.__bases__[0].__name__ is 'object'. blake2b has a single base class,
# object. hashlib_extra86 anchors __bases__[0].__name__ as a value.
# No prior hashlib spec anchors __bases__[0].__name__.__eq__ as a call for
# blake2b. First __bases__[0].__name__.__eq__ standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra90.blake2b_bases_object:
  description: "hashlib.blake2b.__bases__[0].__name__.__eq__('object') == True — blake2b has a single base class, object; hashlib_extra86 anchors __bases__[0].__name__ as a value; this standalone anchors __bases__[0].__name__.__eq__ as a call; first __bases__[0].__name__.__eq__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: "blake2b.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# blake2s.__dict__.__class__.__name__ is 'mappingproxy'. hashlib_extra87
# anchors __dict__.__class__.__name__ as a value. No prior hashlib spec
# anchors __dict__.__class__.__name__.__eq__ as a call for blake2s.
# First __dict__.__class__.__name__.__eq__ standalone for hashlib.blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra90.blake2s_dict_class_proxy:
  description: "hashlib.blake2s.__dict__.__class__.__name__.__eq__('mappingproxy') == True — blake2s.__dict__ is a mappingproxy (the standard CPython type for class dicts); hashlib_extra87 anchors __dict__.__class__.__name__ as a value; this standalone anchors the __eq__ call form; first __dict__.__class__.__name__.__eq__ standalone for hashlib.blake2s"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
