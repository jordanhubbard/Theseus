# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal has full arithmetic dunders including rounding-to-integer protocols
# Contrasts Decimal's rounding hooks with the absent __trunc__/__floor__/__ceil__ on Context and DecimalException
# ---------------------------------------------------------------------------

table decimal_extra2731.decimal_has_full_rounding_numeric_protocol:
  description: "decimal.Decimal defines __add__/__sub__/__mul__ and also __trunc__/__floor__/__ceil__; decimal.Context and decimal.DecimalException define none of __trunc__/__floor__/__ceil__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2731

  columns: [id, function, args, expected]
  rows:
    - ["dc2731010", "decimal.Decimal.__dict__.__contains__", ["__add__"],   true]
    - ["dc2731011", "decimal.Decimal.__dict__.__contains__", ["__sub__"],   true]
    - ["dc2731012", "decimal.Decimal.__dict__.__contains__", ["__mul__"],   true]
    - ["dc2731013", "decimal.Decimal.__dict__.__contains__", ["__trunc__"], true]
    - ["dc2731014", "decimal.Decimal.__dict__.__contains__", ["__floor__"], true]
    - ["dc2731015", "decimal.Decimal.__dict__.__contains__", ["__ceil__"],  true]
    - ["dc2731016", "decimal.Context.__dict__.__contains__", ["__trunc__"], false]
    - ["dc2731017", "decimal.Context.__dict__.__contains__", ["__floor__"], false]
    - ["dc2731018", "decimal.Context.__dict__.__contains__", ["__ceil__"],  false]
    - ["dc2731019", "decimal.DecimalException.__dict__.__contains__", ["__trunc__"], false]
    - ["dc2731020", "decimal.DecimalException.__dict__.__contains__", ["__floor__"], false]
    - ["dc2731021", "decimal.DecimalException.__dict__.__contains__", ["__ceil__"],  false]
