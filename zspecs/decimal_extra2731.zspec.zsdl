spec: decimal_extra2731
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
    - "decimal_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 629 (decimal_extra2731) theme: __trunc__, __floor__, and __ceil__ dict-presence checks."
    - "decimal.Decimal DOES define __trunc__, __floor__, and __ceil__ in its own __dict__ — Decimal implements the full numeric tower including rounding-to-integer protocols."
    - "decimal.Context and decimal.DecimalException do NOT define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "__trunc__ (math.trunc()) on Decimal truncates toward zero and returns an integer."
    - "__floor__ (math.floor()) on Decimal returns the greatest integer less than or equal to the value."
    - "__ceil__ (math.ceil()) on Decimal returns the least integer greater than or equal to the value."
    - "decimal.Context provides context-level control for arithmetic but does not itself support rounding-to-integer protocols."
    - "decimal.DecimalException is an exception base class with no numeric operator semantics."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2731.trunc_presence_in_decimal_classes:
  description: "__trunc__ is present in decimal.Decimal __dict__ (full numeric tower) but absent from decimal.Context and decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2731

  columns: [id, function, args, expected]
  rows:
    - ["dc2731001", "decimal.Decimal.__dict__.__contains__",          ["__trunc__"], true]
    - ["dc2731002", "decimal.Context.__dict__.__contains__",          ["__trunc__"], false]
    - ["dc2731003", "decimal.DecimalException.__dict__.__contains__", ["__trunc__"], false]

