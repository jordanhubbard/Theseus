spec: argparse_extra_rust
version: ">=3.9"
backend: rust_module(argparse_extra_rust)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — argparse documentation"
  not_derived_from:
    - "argparse source: Lib/argparse.py"
  notes:
    - "argparse provides argument parsing for Python CLI programs."
    - "ArgumentParser(prog='myapp').prog == 'myapp'."
    - "ArgumentParser(description='test').description == 'test'."
    - "parser.add_argument('--foo'); parser.parse_args(['--foo', 'bar']).foo == 'bar'."
    - "Expose argparse_prog(prog) -> str: ArgumentParser(prog=prog).prog."
    - "Expose argparse_description(desc) -> str: ArgumentParser(description=desc).description."
    - "Expose argparse_parse_str(arg, val) -> str: parse_args(['--'+arg, val]).attr."
    - "All test vectors verified against Python 3.12."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# argparse_prog — prog attribute
table argparse_extra_rust.parser.prog:
  kind: python_call_eq
  category: prog
  id_prefix: ap_prog
  function: argparse_prog

  columns: [id, args, expected]
  rows:
    - [myapp,  ["myapp"],  "myapp"]
    - [tool,   ["tool"],   "tool"]

# argparse_description — description attribute
table argparse_extra_rust.parser.description:
  kind: python_call_eq
  category: description
  id_prefix: ap_desc
  function: argparse_description

  columns: [id, args, expected]
  rows:
    - [test,   ["test description"],   "test description"]
    - [empty,  [""],                   ""]

# argparse_parse_str — parse string argument
invariant argparse_extra_rust.parse.string_arg:
  description: "parse_args(['--foo', 'bar']).foo == 'bar'"
  category: parse
  kind: python_call_eq
  function: argparse_parse_str
  args: ["foo", "bar"]
  expected: "bar"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
