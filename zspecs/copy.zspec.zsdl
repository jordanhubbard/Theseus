spec: copy
version: ">=3.0"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "Python copy documentation — https://docs.python.org/3/library/copy.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "copy.copy(x) creates a shallow copy; for immutable types (int, str, float, bool, None) the same object may be returned."
    - "copy.deepcopy(x) creates a deep copy; all nested structures are recursively duplicated."
    - "For JSON-serializable types, copy() and deepcopy() return values equal to the input."
    - "copy.error is an alias for copy.Error — the exception raised when an object cannot be copied."
    - "copy.replace() is a generic shallow-replace helper added in Python 3.13."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy.copy — shallow copy of primitives, sequences, and mappings
# ---------------------------------------------------------------------------

table copy.copy.primitives:
  description: "copy.copy() returns equal value for primitive types"
  kind: python_call_eq
  category: copy
  id_prefix: copy
  function: copy

  columns: [id, args, expected]
  rows:
    - [int,    [42],      42]
    - [str,    ["hello"], "hello"]
    - [none,   [null],    null]
    - [bool_t, [true],    true]
    - [bool_f, [false],   false]
    - [float,  [3.14],    3.14]
    - [zero,   [0],       0]
    - [empty_str, [""],   ""]

table copy.copy.containers:
  description: "copy.copy() returns equal value for container types"
  kind: python_call_eq
  category: copy
  id_prefix: copy
  function: copy

  columns: [id, args, expected]
  rows:
    - [list,       [[1, 2, 3]],   [1, 2, 3]]
    - [empty_list, [[]],          []]
    - [dict,       [{"a": 1}],    {"a": 1}]
    - [empty_dict, [{}],          {}]

# ---------------------------------------------------------------------------
# copy.deepcopy — deep copy of primitives and nested structures
# ---------------------------------------------------------------------------

table copy.deepcopy.primitives:
  description: "copy.deepcopy() returns equal value for primitive types"
  kind: python_call_eq
  category: deepcopy
  id_prefix: dcopy
  function: deepcopy

  columns: [id, args, expected]
  rows:
    - [int,    [42],      42]
    - [str,    ["hello"], "hello"]
    - [none,   [null],    null]
    - [bool_t, [true],    true]
    - [float,  [3.14],    3.14]

table copy.deepcopy.nested:
  description: "copy.deepcopy() recursively copies nested structures"
  kind: python_call_eq
  category: deepcopy
  id_prefix: dcopy
  function: deepcopy

  columns: [id, args, expected]
  rows:
    - [nested_list, [[1, [2, 3]]],        [1, [2, 3]]]
    - [nested_dict, [{"a": {"b": 1}}],    {"a": {"b": 1}}]
    - [flat_list,   [[1, 2, 3]],          [1, 2, 3]]
    - [empty_list,  [[]],                 []]

# ---------------------------------------------------------------------------
# copy.error — exception class
# ---------------------------------------------------------------------------

invariant copy.error.name:
  description: "copy.error.__name__ == 'Error' — the copy exception class is named Error"
  category: error
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# function types — copy and deepcopy are Python functions
# ---------------------------------------------------------------------------

invariant copy.types.copy_is_function:
  description: "type(copy.copy).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: copy.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant copy.types.deepcopy_is_function:
  description: "type(copy.deepcopy).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: deepcopy.__class__.__name__.__eq__
  args: ["function"]
  expected: true
