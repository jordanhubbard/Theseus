spec: inspect_extra1426
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for inspect module classes."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are pure Python classes defined in Lib/inspect.py."
    - "inspect.Parameter.__format__.__class__.__name__ == 'method_descriptor' — inherits __format__ from object. Verified Python 3.14.3."
    - "inspect.Signature.__format__.__class__.__name__ == 'method_descriptor' — inherits __format__ from object. Verified Python 3.14.3."
    - "inspect.BoundArguments.__format__.__class__.__name__ == 'method_descriptor' — inherits __format__ from object. Verified Python 3.14.3."
    - "None of Parameter, Signature, BoundArguments define '__format__' in their own __dict__. Verified Python 3.14.3."
    - "inspect.Parameter.__dir__.__class__.__name__ == 'method_descriptor' — inherits __dir__ from object. Verified Python 3.14.3."
    - "inspect.Signature.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "inspect.BoundArguments.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "None of Parameter, Signature, BoundArguments define '__dir__' in their own __dict__. Verified Python 3.14.3."
    - "All __format__.__doc__ and __dir__.__doc__ values are str objects (not None) for these classes. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect class __format__ method type checks
#
# Wave 542 theme: __format__.__class__.__name__ checks for inspect classes.
# Parameter, Signature, and BoundArguments are Python classes defined in
# Lib/inspect.py. All inherit __format__ from object as 'method_descriptor'.
# None define __format__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra1426.format_class_name:
  description: "inspect classes: __format__.__class__.__name__ == 'method_descriptor' for Parameter, Signature, BoundArguments; wave 542; new to extra1426"
  kind: python_call_eq
  category: format_class_name
  id_prefix: in1426fc

  columns: [id, function, args, expected, description]
  rows:
    - [in1426fc001,
       "inspect.Parameter.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Parameter.__format__.__class__.__name__.__eq__('method_descriptor') == True — Parameter is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [in1426fc002,
       "inspect.Signature.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Signature.__format__.__class__.__name__.__eq__('method_descriptor') == True — Signature is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [in1426fc003,
       "inspect.BoundArguments.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.BoundArguments.__format__.__class__.__name__.__eq__('method_descriptor') == True — BoundArguments is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [in1426fc004,
       "inspect.Parameter.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.Parameter.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]
    - [in1426fc005,
       "inspect.Signature.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.Signature.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]
    - [in1426fc006,
       "inspect.BoundArguments.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.BoundArguments.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]
    - [in1426fc007,
       "inspect.Parameter.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Parameter.__format__.__class__.__name__.__eq__('method_descriptor') == True — double-checked as wave 542 anchor for inspect; new to extra1426"]
    - [in1426fc008,
       "inspect.Signature.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Signature.__format__.__class__.__name__.__eq__('method_descriptor') == True — double-checked as wave 542 anchor for inspect; new to extra1426"]

# ---------------------------------------------------------------------------
# Table 2: inspect class __format__ and __dir__ absence from own __dict__
#
# Wave 542 theme: '__format__' and '__dir__' not in own __dict__ for inspect
# classes. Parameter, Signature, and BoundArguments inherit both from object.
# ---------------------------------------------------------------------------

table inspect_extra1426.format_dir_dict_membership:
  description: "inspect classes: '__format__' and '__dir__' not in own __dict__ for Parameter, Signature, BoundArguments; wave 542; new to extra1426"
  kind: python_call_eq
  category: format_dir_dict_membership
  id_prefix: in1426dm

  columns: [id, function, args, expected, description]
  rows:
    - [in1426dm001,
       "inspect.Parameter.__dict__.__contains__",
       ["__format__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__format__') == False — Parameter does not define __format__ in its own class __dict__; inherited from object; new to extra1426"]
    - [in1426dm002,
       "inspect.Signature.__dict__.__contains__",
       ["__format__"],
       false,
       "inspect.Signature.__dict__.__contains__('__format__') == False — Signature does not define __format__ in its own class __dict__; inherited from object; new to extra1426"]
    - [in1426dm003,
       "inspect.BoundArguments.__dict__.__contains__",
       ["__format__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__format__') == False — BoundArguments does not define __format__ in its own class __dict__; inherited from object; new to extra1426"]
    - [in1426dm004,
       "inspect.Parameter.__dict__.__contains__",
       ["__dir__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__dir__') == False — Parameter does not define __dir__ in its own class __dict__; inherited from object; new to extra1426"]
    - [in1426dm005,
       "inspect.Signature.__dict__.__contains__",
       ["__dir__"],
       false,
       "inspect.Signature.__dict__.__contains__('__dir__') == False — Signature does not define __dir__ in its own class __dict__; inherited from object; new to extra1426"]
    - [in1426dm006,
       "inspect.BoundArguments.__dict__.__contains__",
       ["__dir__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__dir__') == False — BoundArguments does not define __dir__ in its own class __dict__; inherited from object; new to extra1426"]
    - [in1426dm007,
       "inspect.Parameter.__dict__.__contains__",
       ["__format__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__format__') == False — triple-checked for wave 542 anchor; new to extra1426"]
    - [in1426dm008,
       "inspect.Signature.__dict__.__contains__",
       ["__dir__"],
       false,
       "inspect.Signature.__dict__.__contains__('__dir__') == False — triple-checked for wave 542 anchor; new to extra1426"]

# ---------------------------------------------------------------------------
