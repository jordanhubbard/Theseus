# ---------------------------------------------------------------------------
# Standalone invariants — extra1426
# ---------------------------------------------------------------------------

invariant inspect_extra1426.Parameter_format_is_method_descriptor:
  description: "inspect.Parameter.__format__.__class__.__name__ == 'method_descriptor' — __format__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: inspect.Parameter.__format__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant inspect_extra1426.Parameter_format_not_in_dict:
  description: "'__format__' not in inspect.Parameter.__dict__ — Parameter does not override __format__; wave 542; new to extra1426"
  kind: python_call_eq
  function: inspect.Parameter.__dict__.__contains__
  args: ["__format__"]
  expected: false

invariant inspect_extra1426.Signature_dir_is_method_descriptor:
  description: "inspect.Signature.__dir__.__class__.__name__ == 'method_descriptor' — __dir__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: inspect.Signature.__dir__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant inspect_extra1426.BoundArguments_dir_not_in_dict:
  description: "'__dir__' not in inspect.BoundArguments.__dict__ — BoundArguments does not override __dir__; wave 542; new to extra1426"
  kind: python_call_eq
  function: inspect.BoundArguments.__dict__.__contains__
  args: ["__dir__"]
  expected: false
