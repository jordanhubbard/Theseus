       ["str"],
       true,
       "inspect.Parameter.__dir__.__doc__.__class__.__name__.__eq__('str') == True — __dir__ docstring is a str object; new to extra1426"]
    - [in1426dc005,
       "inspect.Signature.__dir__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.Signature.__dir__.__doc__.__class__.__name__.__eq__('str') == True — __dir__ docstring is a str object; new to extra1426"]
    - [in1426dc006,
       "inspect.BoundArguments.__dir__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.BoundArguments.__dir__.__doc__.__class__.__name__.__eq__('str') == True — __dir__ docstring is a str object; new to extra1426"]
    - [in1426dc007,
       "inspect.Parameter.__dir__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Parameter.__dir__.__class__.__name__.__eq__('method_descriptor') == True — double-checked as wave 542 anchor for inspect; new to extra1426"]
