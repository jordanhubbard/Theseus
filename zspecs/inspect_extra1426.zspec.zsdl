  description: "inspect classes: __dir__.__class__.__name__ == 'method_descriptor' and __dir__.__doc__.__class__.__name__ == 'str' for Parameter, Signature, BoundArguments; wave 542; new to extra1426"
  kind: python_call_eq
  category: dir_class_name
  id_prefix: in1426dc

  columns: [id, function, args, expected, description]
  rows:
    - [in1426dc001,
