# ---------------------------------------------------------------------------
# Combined per-type view — Thread and Barrier vs. all three protocols
# ---------------------------------------------------------------------------

table threading_extra2656.thread_barrier_combined:
  description: "threading.Thread, threading.Barrier, and threading.Timer define none of __contains__, __add__, __mul__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2656

  columns: [id, function, args, expected]
  rows:
    - ["th2656028", "threading.Thread.__dict__.__contains__",  ["__contains__"], false]
    - ["th2656029", "threading.Thread.__dict__.__contains__",  ["__add__"],      false]
    - ["th2656030", "threading.Thread.__dict__.__contains__",  ["__mul__"],      false]
