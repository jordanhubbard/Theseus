spec: threading_extra2656
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 624 theme: __contains__, __add__, and __mul__ dict-presence checks (container membership and sequence arithmetic)."
    - "threading.Thread is a runnable object; it does not define container membership or sequence arithmetic protocols."
    - "threading.Lock (accessed as threading.Lock, actual type is _thread.lock) is a synchronization primitive; it defines acquire/release but not __contains__, __add__, or __mul__."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore are synchronization primitives; none define __contains__, __add__, or __mul__."
    - "threading.Timer is a Thread subclass for deferred execution; it inherits from Thread but defines none of these protocols."
    - "threading.Barrier is a synchronization barrier; it does not define __contains__, __add__, or __mul__."
    - "threading.local is a thread-local storage object; it does not define container membership or arithmetic protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __contains__ dict-presence — absent from all threading synchronization types
# ---------------------------------------------------------------------------

table threading_extra2656.contains_protocol:
  description: "__contains__ is absent from all threading type __dict__s — synchronization primitives do not implement container membership"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2656

  columns: [id, function, args, expected]
  rows:
    - ["th2656001", "threading.Thread.__dict__.__contains__",          ["__contains__"], false]
    - ["th2656002", "threading.Lock.__dict__.__contains__",            ["__contains__"], false]
    - ["th2656003", "threading.Event.__dict__.__contains__",           ["__contains__"], false]
    - ["th2656004", "threading.Condition.__dict__.__contains__",       ["__contains__"], false]
    - ["th2656005", "threading.Semaphore.__dict__.__contains__",       ["__contains__"], false]
    - ["th2656006", "threading.BoundedSemaphore.__dict__.__contains__", ["__contains__"], false]
    - ["th2656007", "threading.Timer.__dict__.__contains__",           ["__contains__"], false]
    - ["th2656008", "threading.Barrier.__dict__.__contains__",         ["__contains__"], false]
    - ["th2656009", "threading.local.__dict__.__contains__",           ["__contains__"], false]

