spec: socket_extra96
version: ">=3.9"
backend: python_module(socket)
extends: socket_extra95

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily enum member values (AF_UNSPEC/AF_INET/AF_INET6/AF_UNIX) and names / socket.SocketKind enum member values (SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET) and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/recv/send/etc. (table + invariants)."
    - "socket_extra92.zspec.zsdl — covers socket.socket class string identity / exception hierarchy / AddressFamily/SocketKind class identity (table + invariants)."
    - "socket_extra91.zspec.zsdl — covers socket module string identity cross-checks / socket.socket dunder method class names / socket constant class names and values (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra95; it does NOT duplicate invariants present in those files."
    - "Wave 259 theme: socket module constant identity and function class names — AF_INET/SOCK_STREAM/AF_UNIX/__class__.__name__ cross-check / IPPROTO_TCP/IPPROTO_UDP plain int class / gethostname/gethostbyname builtin / getaddrinfo/create_connection pure-Python function / AddressFamily/SocketKind bases."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: IPPROTO_TCP, IPPROTO_UDP, and SOL_SOCKET are plain int (not IntEnum) on macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily')
# socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily')
# socket.AF_INET6.__class__.__name__.__eq__('AddressFamily')
# socket.AF_UNSPEC.__class__.__name__.__eq__('AddressFamily')
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind')
# socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind')
# socket.SOCK_RAW.__class__.__name__.__eq__('SocketKind')
#
# Wave 259 theme: AddressFamily and SocketKind enum member class names.
#
# All AddressFamily members (AF_INET, AF_UNIX, AF_INET6, AF_UNSPEC) have
# __class__.__name__ == 'AddressFamily'. All SocketKind members (SOCK_STREAM,
# SOCK_DGRAM, SOCK_RAW) have __class__.__name__ == 'SocketKind'.
# socket_extra91 and socket_extra95 first anchor individual member class names;
# this table cross-checks all seven together under socketconstident96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra96.socket_af_sk_member_class_names:
  description: "socket.AF_INET/__class__.__name__.__eq__('AddressFamily')==True / AF_UNIX/__class__.__name__.__eq__==True / AF_INET6/__class__.__name__.__eq__==True / AF_UNSPEC/__class__.__name__.__eq__==True / SOCK_STREAM/__class__.__name__.__eq__('SocketKind')==True / SOCK_DGRAM/__class__.__name__.__eq__==True / SOCK_RAW/__class__.__name__.__eq__==True — all AddressFamily members are 'AddressFamily' (IntEnum subtype); all SocketKind members are 'SocketKind' (IntEnum subtype); socket_extra91/95 first anchor some; this table cross-checks all seven together; first socketconstident96 anchor for AF_*/SOCK_* class name cross-check"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketconstident96

  columns: [id, function, args, expected]
  rows:
    - [af_inet_class,    AF_INET.__class__.__name__.__eq__,    ["AddressFamily"], true]
    - [af_unix_class,    AF_UNIX.__class__.__name__.__eq__,    ["AddressFamily"], true]
    - [af_inet6_class,   AF_INET6.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [af_unspec_class,  AF_UNSPEC.__class__.__name__.__eq__,  ["AddressFamily"], true]
    - [sock_stream_class, SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"],  true]
    - [sock_dgram_class,  SOCK_DGRAM.__class__.__name__.__eq__,  ["SocketKind"],  true]
    - [sock_raw_class,    SOCK_RAW.__class__.__name__.__eq__,    ["SocketKind"],  true]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int')
# socket.IPPROTO_UDP.__class__.__name__.__eq__('int')
# socket.SOL_SOCKET.__class__.__name__.__eq__('int')
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum')
# socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum')
#
# Wave 259 theme: IPPROTO/SOL constants are plain int + AddressFamily/SocketKind bases.
#
# Unlike AF_INET and SOCK_STREAM which are IntEnum members, IPPROTO_TCP,
# IPPROTO_UDP, and SOL_SOCKET are plain int constants on macOS/Darwin 25.4.0
# (not wrapped in an IntEnum). AddressFamily and SocketKind both inherit from
# IntEnum (not directly from int). No prior socket spec anchors these five
# checks together under socketconstident96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra96.socket_ipproto_sol_and_enum_bases:
  description: "socket.IPPROTO_TCP/__class__.__name__.__eq__('int')==True / IPPROTO_UDP/__class__.__name__.__eq__('int')==True / SOL_SOCKET/__class__.__name__.__eq__('int')==True / AddressFamily/__bases__[0]/__name__.__eq__('IntEnum')==True / SocketKind/__bases__[0]/__name__.__eq__('IntEnum')==True — IPPROTO_TCP/IPPROTO_UDP/SOL_SOCKET are plain int (not IntEnum) on macOS/Darwin; AddressFamily and SocketKind both inherit from IntEnum; no prior socket spec anchors these five together; first socketconstident96 anchor for IPPROTO/SOL class names and enum bases"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketconstident96

  columns: [id, function, args, expected]
  rows:
    - [ipproto_tcp_class,      IPPROTO_TCP.__class__.__name__.__eq__,           ["int"],     true]
    - [ipproto_udp_class,      IPPROTO_UDP.__class__.__name__.__eq__,           ["int"],     true]
    - [sol_socket_class,       SOL_SOCKET.__class__.__name__.__eq__,            ["int"],     true]
    - [addressfamily_base,     "AddressFamily.__bases__[0].__name__.__eq__",    ["IntEnum"], true]
    - [socketkind_base,        "SocketKind.__bases__[0].__name__.__eq__",       ["IntEnum"], true]

# ---------------------------------------------------------------------------
# socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method')
# socket.gethostbyname.__class__.__name__.__eq__('builtin_function_or_method')
# socket.setdefaulttimeout.__class__.__name__.__eq__('builtin_function_or_method')
# socket.getdefaulttimeout.__class__.__name__.__eq__('builtin_function_or_method')
# socket.getaddrinfo.__class__.__name__.__eq__('function')
# socket.create_connection.__class__.__name__.__eq__('function')
#
# Wave 259 theme: socket module-level function class names — C builtins vs Python functions.
#
# gethostname, gethostbyname, setdefaulttimeout, and getdefaulttimeout are C
# extension builtins (builtin_function_or_method). getaddrinfo and create_connection
# are pure-Python functions (class 'function') defined in Lib/socket.py. This
# two-tier architecture is a key characteristic of the socket module.
# No prior socket spec anchors these six together under socketconstident96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra96.socket_module_fn_class_names:
  description: "socket.gethostname/__class__.__name__.__eq__('builtin_function_or_method')==True / gethostbyname/__class__.__name__.__eq__==True / setdefaulttimeout/__class__.__name__.__eq__==True / getdefaulttimeout/__class__.__name__.__eq__==True / getaddrinfo/__class__.__name__.__eq__('function')==True / create_connection/__class__.__name__.__eq__('function')==True — gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout are C builtins; getaddrinfo/create_connection are pure-Python functions (Lib/socket.py); no prior socket spec anchors these six together; first socketconstident96 anchor for socket function class name cross-check"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketconstident96

  columns: [id, function, args, expected]
  rows:
    - [gethostname_class,       gethostname.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [gethostbyname_class,     gethostbyname.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [setdefaulttimeout_class, setdefaulttimeout.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [getdefaulttimeout_class, getdefaulttimeout.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [getaddrinfo_class,       getaddrinfo.__class__.__name__.__eq__,       ["function"],                   true]
    - [create_connection_class, create_connection.__class__.__name__.__eq__, ["function"],                   true]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET.__class__.__name__ is 'AddressFamily'. AF_INET is an IntEnum
# member of socket.AddressFamily, the enum wrapping OS address family constants.
# Its __class__.__name__ is 'AddressFamily' (the enum class name), not 'int',
# because IntEnum members carry the enum type as their class. No prior socket
# spec anchors AF_INET.__class__.__name__.__eq__('AddressFamily') as a standalone
# under socketconstident96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra96.af_inet_class_addressfamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is an IntEnum member of AddressFamily; its __class__.__name__ is 'AddressFamily', not 'int', because IntEnum members carry the enum type as their class; no prior socket spec anchors this as a standalone; first standalone for AF_INET class name under socketconstident96"
  category: module_identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') — standalone
#
# socket.IPPROTO_TCP.__class__.__name__ is 'int'. On macOS/Darwin 25.4.0, the
# IPPROTO_* constants are plain int values (not IntEnum members), unlike AF_*
# and SOCK_* which are wrapped in IntEnum. IPPROTO_TCP has the value 6.
# No prior socket spec anchors IPPROTO_TCP.__class__.__name__.__eq__('int') as
# a standalone under socketconstident96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra96.ipproto_tcp_class_int:
  description: "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — IPPROTO_TCP is a plain int (value 6) on macOS/Darwin, not an IntEnum member; unlike AF_*/SOCK_* which are wrapped in IntEnum; no prior socket spec anchors this as a standalone; first standalone for IPPROTO_TCP class name under socketconstident96"
  category: module_identity
  kind: python_call_eq
  function: IPPROTO_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__class__.__name__.__eq__('function') — standalone
#
# socket.getaddrinfo.__class__.__name__ is 'function'. getaddrinfo is a
# pure-Python wrapper function defined in Lib/socket.py that calls the C-level
# _socket.getaddrinfo and handles IDNA encoding. This distinguishes it from C
# builtins like gethostname. socket_extra94 first anchors getaddrinfo.__module__
# and __qualname__; this invariant anchors the class name as a standalone under
# socketconstident96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra96.getaddrinfo_class_function:
  description: "socket.getaddrinfo.__class__.__name__.__eq__('function') == True — getaddrinfo is a pure-Python wrapper (Lib/socket.py) around _socket.getaddrinfo, handling IDNA encoding; it is class 'function', not 'builtin_function_or_method'; socket_extra94 anchors its __module__ and __qualname__; this invariant anchors the class name; first standalone for getaddrinfo __class__.__name__ under socketconstident96"
  category: module_identity
  kind: python_call_eq
  function: getaddrinfo.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') — standalone
#
# socket.AddressFamily.__bases__[0].__name__ is 'IntEnum'. AddressFamily inherits
# from IntEnum (from the enum module), which itself inherits from both int and
# Enum. This makes AddressFamily members comparable to plain ints while also
# being proper enum members with .name and .value. No prior socket spec anchors
# AddressFamily.__bases__[0].__name__.__eq__('IntEnum') as a standalone under
# socketconstident96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra96.addressfamily_base_intenum:
  description: "socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') == True — AddressFamily inherits from IntEnum (which inherits from int and Enum); this makes AF_* members both int-comparable and proper enum members with .name/.value; no prior socket spec anchors this as a standalone; first standalone for AddressFamily base class name under socketconstident96"
  category: module_identity
  kind: python_call_eq
  function: "AddressFamily.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# socket.gethostname.__class__.__name__ is 'builtin_function_or_method'. gethostname
# is a C extension function from Modules/socketmodule.c that calls the POSIX
# gethostname(2) syscall directly. It is one of the most basic socket module
# functions. No prior socket spec anchors gethostname.__class__.__name__ as a
# standalone under socketconstident96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra96.gethostname_class_builtin:
  description: "socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') == True — gethostname is a C extension function wrapping POSIX gethostname(2); it is a builtin_function_or_method; no prior socket spec anchors this as a standalone; first standalone for gethostname __class__.__name__ under socketconstident96"
  category: module_identity
  kind: python_call_eq
  function: gethostname.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
