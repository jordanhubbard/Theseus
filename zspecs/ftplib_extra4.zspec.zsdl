spec: ftplib_extra4
version: ">=3.9"
backend: python_module(ftplib)

docs: https://docs.python.org/3/library/ftplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ftplib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ftplib.py internal socket handling"
    - "ftplib.zspec.zsdl — covers class names table (FTP/FTP_TLS/error_reply/error_temp/error_perm/error_proto), FTP.__module__, FTP.port, Error hierarchy, exception_bases table, method names"
    - "ftplib_extra.zspec.zsdl — covers FTP_TLS.__module__, FTP_TLS.__bases__[0].__name__, all_errors.__class__.__name__, all_errors.__len__, all_errors element names [0-2], error_proto.__module__"
    - "ftplib_extra2.zspec.zsdl — covers error_reply/error_temp/error_perm __module__, Error.__name__, Error.__module__, MSG_OOB.__class__.__name__, FTP.port.__class__.__name__, exception __name__ table, all_errors[3].__name__"
    - "ftplib_extra3.zspec.zsdl — covers __qualname__ table for FTP/FTP_TLS/Error/error_reply/error_temp/error_perm/error_proto; FTP_PORT.__class__.__name__; FTP_PORT.__eq__(21)"
  notes:
    - "This spec extends the ftplib chain with metatype and __bases__ length vectors not present in any prior spec."
    - "FTP.__class__.__name__ == 'type' — FTP is a plain Python class (metaclass is 'type')."
    - "FTP_TLS.__class__.__name__ == 'type' — FTP_TLS is a plain Python class."
    - "Error.__class__.__name__ == 'type' — Error is a plain Python class."
    - "FTP.__bases__ has exactly one element (object) — FTP does not inherit from any specialised base."
    - "FTP_TLS.__bases__ has exactly one element (FTP)."
    - "Error.__bases__ has exactly one element (Exception)."
    - "error_reply.__bases__ has exactly one element (Error)."
    - "FTP.sanitize.__name__ == 'sanitize' — the method that strips control chars from responses."
    - "FTP.sanitize.__qualname__ == 'FTP.sanitize' — nested qualname for an instance method."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Metatype checks — FTP, FTP_TLS, Error
# No prior ftplib spec checks __class__.__name__ for these classes.
# (ftplib_extra3 checks __qualname__; ftplib_extra2 covers Error.__name__ and __module__.)
# ---------------------------------------------------------------------------

table ftplib_extra4.class_metatypes:
  kind: python_call_eq
  category: metatypes
  id_prefix: metatype

  columns: [id, function, args, expected]
  rows:
    - [FTP,     FTP.__class__.__name__.__eq__,     ["type"], true]
    - [FTP_TLS, FTP_TLS.__class__.__name__.__eq__, ["type"], true]
    - [Error,   Error.__class__.__name__.__eq__,   ["type"], true]

# ---------------------------------------------------------------------------
# __bases__ length checks — FTP, FTP_TLS, Error, error_reply
# No prior ftplib spec checks __len__ of __bases__ for any class.
# ftplib.zspec checks __bases__[0].__name__ only (via getitem + method chain).
# ---------------------------------------------------------------------------

invariant ftplib_extra4.FTP.bases_len:
  description: "len(ftplib.FTP.__bases__) == 1 — FTP has exactly one direct base class (object)"
  category: hierarchy
  kind: python_call_eq
  function: FTP.__bases__.__len__
  args: []
  expected: 1

invariant ftplib_extra4.FTP_TLS.bases_len:
  description: "len(ftplib.FTP_TLS.__bases__) == 1 — FTP_TLS has exactly one direct base class (FTP)"
  category: hierarchy
  kind: python_call_eq
  function: FTP_TLS.__bases__.__len__
  args: []
  expected: 1

invariant ftplib_extra4.Error.bases_len:
  description: "len(ftplib.Error.__bases__) == 1 — Error has exactly one direct base class (Exception)"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__len__
  args: []
  expected: 1

invariant ftplib_extra4.error_reply.bases_len:
  description: "len(ftplib.error_reply.__bases__) == 1 — error_reply has exactly one direct base class (Error)"
  category: hierarchy
  kind: python_call_eq
  function: error_reply.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# FTP.sanitize — method name and qualname
# No prior ftplib spec checks FTP.sanitize at all.
# sanitize() is the method that strips non-printable control characters from
# FTP server response strings before logging or displaying them.
# ---------------------------------------------------------------------------

invariant ftplib_extra4.FTP.sanitize.name:
  description: "ftplib.FTP.sanitize.__name__ == 'sanitize' — the response sanitization method"
  category: method_names
  kind: python_call_eq
  function: FTP.sanitize.__name__.__eq__
  args: ["sanitize"]
  expected: true

invariant ftplib_extra4.FTP.sanitize.qualname:
  description: "ftplib.FTP.sanitize.__qualname__ == 'FTP.sanitize' — method qualname includes enclosing class"
  category: qualnames
  kind: python_call_eq
  function: FTP.sanitize.__qualname__.__eq__
  args: ["FTP.sanitize"]
  expected: true
