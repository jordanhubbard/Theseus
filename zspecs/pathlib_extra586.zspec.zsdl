spec: pathlib_extra586
version: ">=3.9"
backend: python_module(pathlib)
docs: "Behavioral spec covering pathlib class __module__ and method __qualname__ identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All classes in the pathlib module should report __module__ == 'pathlib'"
    - "Method __qualname__ must match the canonical dotted class.method form"
  created_at: "2026-04-12T00:00:00Z"

table pl586md:
  description: "pathlib class __module__ identity checks"
  columns: [id, function, args, expected]
  rows:
    - [pl586md01, pathlib.Path.__module__.__eq__, ["pathlib"], true]
    - [pl586md02, pathlib.PurePath.__module__.__eq__, ["pathlib"], true]
    - [pl586md03, pathlib.PosixPath.__module__.__eq__, ["pathlib"], true]
    - [pl586md04, pathlib.WindowsPath.__module__.__eq__, ["pathlib"], true]
    - [pl586md05, pathlib.PurePosixPath.__module__.__eq__, ["pathlib"], true]
    - [pl586md06, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"], true]

table pl586qn:
  description: "pathlib.Path method __qualname__ identity checks"
  columns: [id, function, args, expected]
  rows:
    - [pl586qn01, pathlib.Path.rename.__qualname__.__eq__, ["Path.rename"], true]
    - [pl586qn02, pathlib.Path.replace.__qualname__.__eq__, ["Path.replace"], true]
    - [pl586qn03, pathlib.Path.unlink.__qualname__.__eq__, ["Path.unlink"], true]
    - [pl586qn04, pathlib.Path.rmdir.__qualname__.__eq__, ["Path.rmdir"], true]
    - [pl586qn05, pathlib.Path.stat.__qualname__.__eq__, ["Path.stat"], true]
    - [pl586qn06, pathlib.Path.chmod.__qualname__.__eq__, ["Path.chmod"], true]
    - [pl586qn07, pathlib.Path.glob.__qualname__.__eq__, ["Path.glob"], true]
    - [pl586qn08, pathlib.Path.iterdir.__qualname__.__eq__, ["Path.iterdir"], true]
