spec: functools_extra259
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.wraps and functools.update_wrapper function identity behavioral contracts."
    - "functools.wraps.__name__ == 'wraps' — wraps is a pure Python function; __name__ is 'wraps'. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' — wraps is defined in the functools module; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' — wraps is a module-level function; __qualname__ is 'wraps'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper' — update_wrapper is a pure Python function; __name__ is 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined in the functools module; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' — update_wrapper is a module-level function; __qualname__ is 'update_wrapper'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps function identity
#
# functools.wraps.__name__ == 'wraps'
# functools.wraps.__module__ == 'functools'
# functools.wraps.__class__.__name__ == 'function'
# functools.wraps.__qualname__ == 'wraps'
#
# wraps is a module-level pure Python decorator factory function.
# New to extra259.
# ---------------------------------------------------------------------------

table functools_extra259.wraps_identity:
  description: "functools.wraps __name__, __module__, __class__.__name__, __qualname__ identity contracts; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: wraps259

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_eq,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — wraps is a pure Python decorator factory; __name__ is 'wraps'; new to extra259"]
    - [wraps_module_eq,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in the functools module; __module__ is 'functools'; new to extra259"]
    - [wraps_class_eq,
       wraps.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a plain Python function; __class__.__name__ is 'function'; new to extra259"]
    - [wraps_qualname_eq,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is a module-level function; __qualname__ is 'wraps'; new to extra259"]
    - [wraps_name_len_5,
       wraps.__name__.__len__,
       [],
       5,
       "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters; new to extra259"]

# ---------------------------------------------------------------------------
# Table 2: functools.update_wrapper function identity
#
# functools.update_wrapper.__name__ == 'update_wrapper'
# functools.update_wrapper.__module__ == 'functools'
# functools.update_wrapper.__class__.__name__ == 'function'
# functools.update_wrapper.__qualname__ == 'update_wrapper'
#
# update_wrapper is a module-level pure Python function that copies
# attributes from wrapped to wrapper. New to extra259.
# ---------------------------------------------------------------------------

table functools_extra259.update_wrapper_identity:
  description: "functools.update_wrapper __name__, __module__, __class__.__name__, __qualname__ identity contracts; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: updwrap259

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_name_eq,
       update_wrapper.__name__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — update_wrapper is a pure Python function; __name__ is 'update_wrapper'; new to extra259"]
    - [update_wrapper_module_eq,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in the functools module; __module__ is 'functools'; new to extra259"]
    - [update_wrapper_class_eq,
       update_wrapper.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a plain Python function; __class__.__name__ is 'function'; new to extra259"]
    - [update_wrapper_qualname_eq,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is a module-level function; __qualname__ is 'update_wrapper'; new to extra259"]
    - [update_wrapper_name_len_16,
       update_wrapper.__name__.__len__,
       [],
       16,
       "functools.update_wrapper.__name__.__len__() == 16 — 'update_wrapper' has 16 characters; new to extra259"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra259
# ---------------------------------------------------------------------------

invariant functools_extra259.wraps.name_eq:
  description: "functools.wraps.__name__ == 'wraps' — pure Python decorator factory; new to extra259"
  category: identity
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra259.wraps.module_eq:
  description: "functools.wraps.__module__ == 'functools' — defined in the functools module; new to extra259"
  category: identity
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra259.wraps.class_is_function:
  description: "functools.wraps.__class__.__name__ == 'function' — wraps is a plain Python function; new to extra259"
  category: identity
  kind: python_call_eq
  function: wraps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra259.wraps.qualname_eq:
  description: "functools.wraps.__qualname__ == 'wraps' — module-level function; __qualname__ matches __name__; new to extra259"
  category: identity
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra259.update_wrapper.name_eq:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' — pure Python function; new to extra259"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra259.update_wrapper.module_eq:
  description: "functools.update_wrapper.__module__ == 'functools' — defined in the functools module; new to extra259"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra259.update_wrapper.class_is_function:
  description: "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a plain Python function; new to extra259"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra259.update_wrapper.qualname_eq:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper' — module-level function; __qualname__ matches __name__; new to extra259"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true
