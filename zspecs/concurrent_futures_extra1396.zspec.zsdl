spec: concurrent_futures_extra1396
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures: Launching parallel tasks"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method presence and type checks."
    - "concurrent.futures.Future has __class_getitem__ in its own __dict__ — type is 'method' (bound GenericAlias)."
    - "concurrent.futures.Executor, ThreadPoolExecutor, ProcessPoolExecutor do NOT have __class_getitem__ in their __dict__."
    - "All four classes have __init_subclass__ inherited from object — NOT in their own __dict__; type is 'builtin_function_or_method'."
    - "Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor are concrete subclasses."
    - "ProcessPoolExecutor.__init_subclass__ is inherited from object, same as all other Executor subclasses."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1396.future_class_getitem_checks:
  description: "concurrent.futures.Future has __class_getitem__ in __dict__ as 'method'; Executor subclasses do not"
  kind: python_call_eq
  category: class_getitem_check
  id_prefix: cf1396fc
  columns: [id, function, args, expected]
  rows:
    - [cf1396fc001, concurrent.futures.Future.__dict__.__contains__,                      ["__class_getitem__"], true]
    - [cf1396fc002, concurrent.futures.Future.__class_getitem__.__class__.__name__.__eq__, ["method"],            true]
    - [cf1396fc003, concurrent.futures.Executor.__dict__.__contains__,                     ["__class_getitem__"], false]
    - [cf1396fc004, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,           ["__class_getitem__"], false]
    - [cf1396fc005, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,          ["__class_getitem__"], false]
    - [cf1396fc006, concurrent.futures.Future.__dict__.__contains__,                       ["__init_subclass__"],  false]

table concurrent_futures_extra1396.init_subclass_type_checks:
  description: "All concurrent.futures classes have __init_subclass__ as builtin_function_or_method, not in own __dict__"
  kind: python_call_eq
  category: init_subclass_check
  id_prefix: cf1396is
  columns: [id, function, args, expected]
  rows:
    - [cf1396is001, concurrent.futures.Future.__init_subclass__.__class__.__name__.__eq__,              ["builtin_function_or_method"], true]
    - [cf1396is002, concurrent.futures.Executor.__init_subclass__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [cf1396is003, concurrent.futures.ThreadPoolExecutor.__init_subclass__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [cf1396is004, concurrent.futures.ProcessPoolExecutor.__init_subclass__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [cf1396is005, concurrent.futures.Executor.__dict__.__contains__,                                   ["__init_subclass__"],           false]
    - [cf1396is006, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,                         ["__init_subclass__"],           false]

table concurrent_futures_extra1396.executor_class_getitem_absent_and_inheritance:
  description: "Executor subclasses do not define __class_getitem__ themselves; ProcessPoolExecutor inherits __init_subclass__ from object"
  kind: python_call_eq
  category: class_getitem_inheritance
  id_prefix: cf1396ei
  columns: [id, function, args, expected]
  rows:
    - [cf1396ei001, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,           ["__init_subclass__"],  false]
    - [cf1396ei002, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,           ["__class_getitem__"],  false]
    - [cf1396ei003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,            ["__init_subclass__"],  false]
    - [cf1396ei004, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,            ["__class_getitem__"],  false]
    - [cf1396ei005, concurrent.futures.Executor.__dict__.__contains__,                      ["__init_subclass__"],  false]
    - [cf1396ei006, concurrent.futures.Future.__class_getitem__.__class__.__name__.__eq__,  ["method"],             true]
