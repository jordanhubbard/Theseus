spec: lodash_deburr
version: ">=4.0.0"
backend: node(lodash.deburr)

docs: https://lodash.com/docs/#deburr

provenance:
  derived_from:
    - "lodash.deburr README — https://www.npmjs.com/package/lodash.deburr"
    - "Test vectors verified with lodash.deburr@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.deburr exports the _.deburr function directly as module.exports."
    - "deburr(string) removes Latin extended-A and extended-B diacritical marks."
    - "Converts accented characters to their ASCII base equivalents."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns ASCII-normalized string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_deburr.deburr:
  kind: node_module_call_eq
  function: ~
  category: deburr
  id_prefix: ldbr

  columns: [id, args, expected]
  rows:
    - [accented,   ["déjà vu"],    "deja vu"]
    - [ring,       ["Ångström"],   "Angstrom"]
    - [plain,      ["hello"],      "hello"]
    - [umlaut,     ["über"],       "uber"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:21:28Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
