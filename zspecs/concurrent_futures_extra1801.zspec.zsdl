spec: concurrent_futures_extra1801
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and context manager protocol dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra1801.truth_protocol:
  description: "concurrent.futures types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1801

  columns: [id, function, args, expected]
  rows:
    - ["cf1801001", "concurrent.futures.Future.__dict__.__contains__", ["__bool__"], false]
    - ["cf1801002", "concurrent.futures.Future.__dict__.__contains__", ["__len__"], false]
    - ["cf1801003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__bool__"], false]
    - ["cf1801004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__len__"], false]
    - ["cf1801005", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__bool__"], false]
    - ["cf1801006", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__len__"], false]

table concurrent_futures_extra1801.context_manager_protocol:
  description: "concurrent.futures Executor context manager protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1801

  columns: [id, function, args, expected]
  rows:
    - ["cf1801007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__enter__"], true]
    - ["cf1801008", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__exit__"], true]
    - ["cf1801009", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__enter__"], true]
    - ["cf1801010", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__exit__"], true]
    - ["cf1801011", "concurrent.futures.Future.__dict__.__contains__", ["__enter__"], false]
    - ["cf1801012", "concurrent.futures.Future.__dict__.__contains__", ["__exit__"], false]
    - ["cf1801013", "concurrent.futures.Executor.__dict__.__contains__", ["__enter__"], true]
    - ["cf1801014", "concurrent.futures.Executor.__dict__.__contains__", ["__exit__"], true]

table concurrent_futures_extra1801.future_attrs:
  description: "concurrent.futures Future specific attribute dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1801

  columns: [id, function, args, expected]
  rows:
    - ["cf1801015", "concurrent.futures.Future.__dict__.__contains__", ["result"], true]
    - ["cf1801016", "concurrent.futures.Future.__dict__.__contains__", ["exception"], true]
    - ["cf1801017", "concurrent.futures.Future.__dict__.__contains__", ["done"], true]
    - ["cf1801018", "concurrent.futures.Future.__dict__.__contains__", ["running"], true]
    - ["cf1801019", "concurrent.futures.Future.__dict__.__contains__", ["cancelled"], true]
    - ["cf1801020", "concurrent.futures.Future.__dict__.__contains__", ["cancel"], true]
    - ["cf1801021", "concurrent.futures.Future.__dict__.__contains__", ["add_done_callback"], true]
    - ["cf1801022", "concurrent.futures.Future.__dict__.__contains__", ["__iter__"], false]
    - ["cf1801023", "concurrent.futures.Future.__dict__.__contains__", ["__await__"], false]
