spec: re_extra342
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.__name__ == 're' — the module name attribute."
    - "re.__package__ == 're' — re is a package (contains sub-modules); verified with Python 3.14.3."
    - "re.__spec__.name == 're' — the ModuleSpec name matches the module name."
    - "re.__all__ is a list with 31 elements; verified with Python 3.14.3."
    - "re.__all__.__contains__('compile') == True — compile is in the public API."
    - "re.__all__.__contains__('match') == True — match is in the public API."
    - "re.__all__.__contains__('search') == True — search is in the public API."
    - "re.__all__.__contains__('sub') == True — sub is in the public API."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__name__ — module identity
# ---------------------------------------------------------------------------

invariant re_extra342.module_name:
  description: "re.__name__ == 're'"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.__package__ — re is itself a package
# ---------------------------------------------------------------------------

invariant re_extra342.module_package:
  description: "re.__package__ == 're' — re is a package"
  category: module_metadata
  kind: python_call_eq
  function: __package__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.__spec__.name — ModuleSpec name
# ---------------------------------------------------------------------------

invariant re_extra342.spec_name:
  description: "re.__spec__.name == 're'"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.__all__ — class and length
# ---------------------------------------------------------------------------

invariant re_extra342.all_is_list:
  description: "re.__all__.__class__.__name__ == 'list'"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant re_extra342.all_len:
  description: "len(re.__all__) == 31"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 31

# ---------------------------------------------------------------------------
# re.__all__ membership — selected public names
# ---------------------------------------------------------------------------

invariant re_extra342.all_contains_compile:
  description: "re.__all__.__contains__('compile') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["compile"]
  expected: true

invariant re_extra342.all_contains_match:
  description: "re.__all__.__contains__('match') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["match"]
  expected: true

invariant re_extra342.all_contains_search:
  description: "re.__all__.__contains__('search') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["search"]
  expected: true

invariant re_extra342.all_contains_sub:
  description: "re.__all__.__contains__('sub') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["sub"]
  expected: true
