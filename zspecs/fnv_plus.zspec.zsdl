spec: fnv_plus
version: ">=1.0.0"
backend: node(fnv-plus)

docs: https://www.npmjs.com/package/fnv-plus

provenance:
  derived_from:
    - "fnv-plus README — https://www.npmjs.com/package/fnv-plus"
    - "Test vectors verified with fnv-plus via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fnv-plus source"
  notes:
    - "fnv-plus is an npm package. Install: npm install fnv-plus"
    - "fnv.hash(str, bits) computes an FNV-1a hash at the given bit width."
    - ".hex() returns the hash as a hex string; .dec() as a decimal string."
    - "The 32-bit empty-string hash is the FNV offset basis: 0x811c9dc5."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns hash object with hex/dec methods."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fnv_plus.hash_hex:
  kind: node_factory_call_eq
  factory: hash
  method: hex
  id_prefix: fnvhex

  columns: [id, factory_args, expected]
  rows:
    - [hello32,  ["hello", 32], "4f9f2cab"]
    - [world32,  ["world", 32], "37a3e893"]
    - [empty32,  ["", 32],      "811c9dc5"]

table fnv_plus.hash_dec:
  kind: node_factory_call_eq
  factory: hash
  method: dec
  id_prefix: fnvdec

  columns: [id, factory_args, expected]
  rows:
    - [hello32, ["hello", 32], "1335831723"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:18:03Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
