spec: warnings_extra23
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends warnings_extra22.zspec.zsdl."
    - "Prior specs covered: warn/warn_explicit/simplefilter/filterwarnings/resetwarnings __name__/__module__/__qualname__, catch_warnings __name__/__module__/__qualname__/__bases__[0].__name__, warnings.filters type, warn/warn_explicit __module__=='_warnings', simplefilter/filterwarnings/resetwarnings __module__=='_py_warnings', catch_warnings.__init__.__name__."
    - "This spec covers: warn.__module__.__len__() == 9, warn_explicit.__module__.__len__() == 9, simplefilter.__module__.__len__() == 12, filterwarnings.__module__.__len__() == 12, resetwarnings.__module__.__len__() == 12, warn.__name__.__len__() == 4, warn_explicit.__name__.__len__() == 13, simplefilter.__name__.__len__() == 12, filterwarnings.__name__.__len__() == 14, resetwarnings.__name__.__len__() == 13, catch_warnings.__module__.__len__() == 12, catch_warnings.__name__.__len__() == 14."
    - "warnings.warn.__module__ == '_warnings' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.warn_explicit.__module__ == '_warnings' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.simplefilter.__module__ == '_py_warnings' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.filterwarnings.__module__ == '_py_warnings' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.resetwarnings.__module__ == '_py_warnings' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.warn.__name__ == 'warn' (len 4). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.warn_explicit.__name__ == 'warn_explicit' (len 13). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.simplefilter.__name__ == 'simplefilter' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.filterwarnings.__name__ == 'filterwarnings' (len 14). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.resetwarnings.__name__ == 'resetwarnings' (len 13). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.catch_warnings.__module__ == '_py_warnings' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.catch_warnings.__name__ == 'catch_warnings' (len 14). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings.warn.__module__.__len__()
#
# warn.__module__ == '_warnings', which has length 9.
# Prior specs record the __module__ string value; this spec records its length
# via the __len__ method as a fresh extra23-namespace invariant.
# ---------------------------------------------------------------------------

invariant warnings_extra23.warn.module.len:
  description: "warnings.warn.__module__.__len__() == 9 — '_warnings' has 9 characters"
  category: string_length
  kind: python_call_eq
  function: warn.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# warnings.warn_explicit.__module__.__len__()
#
# warn_explicit.__module__ == '_warnings', which has length 9.
# ---------------------------------------------------------------------------

invariant warnings_extra23.warn_explicit.module.len:
  description: "warnings.warn_explicit.__module__.__len__() == 9 — '_warnings' has 9 characters"
  category: string_length
  kind: python_call_eq
  function: warn_explicit.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# warnings.simplefilter.__module__.__len__()
#
# simplefilter.__module__ == '_py_warnings', which has length 12.
# ---------------------------------------------------------------------------

invariant warnings_extra23.simplefilter.module.len:
  description: "warnings.simplefilter.__module__.__len__() == 12 — '_py_warnings' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: simplefilter.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# warnings.filterwarnings.__module__.__len__()
#
# filterwarnings.__module__ == '_py_warnings', which has length 12.
# ---------------------------------------------------------------------------

invariant warnings_extra23.filterwarnings.module.len:
  description: "warnings.filterwarnings.__module__.__len__() == 12 — '_py_warnings' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: filterwarnings.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# warnings.resetwarnings.__module__.__len__()
#
# resetwarnings.__module__ == '_py_warnings', which has length 12.
# ---------------------------------------------------------------------------

invariant warnings_extra23.resetwarnings.module.len:
  description: "warnings.resetwarnings.__module__.__len__() == 12 — '_py_warnings' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: resetwarnings.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# warnings.warn.__name__.__len__()
#
# warn.__name__ == 'warn', which has length 4.
# ---------------------------------------------------------------------------

invariant warnings_extra23.warn.name.len:
  description: "warnings.warn.__name__.__len__() == 4 — 'warn' has 4 characters"
  category: string_length
  kind: python_call_eq
  function: warn.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# warnings.warn_explicit.__name__.__len__()
#
# warn_explicit.__name__ == 'warn_explicit', which has length 13.
# ---------------------------------------------------------------------------

invariant warnings_extra23.warn_explicit.name.len:
  description: "warnings.warn_explicit.__name__.__len__() == 13 — 'warn_explicit' has 13 characters"
  category: string_length
  kind: python_call_eq
  function: warn_explicit.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# warnings.simplefilter.__name__.__len__()
#
# simplefilter.__name__ == 'simplefilter', which has length 12.
# ---------------------------------------------------------------------------

invariant warnings_extra23.simplefilter.name.len:
  description: "warnings.simplefilter.__name__.__len__() == 12 — 'simplefilter' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: simplefilter.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# warnings.filterwarnings.__name__.__len__()
#
# filterwarnings.__name__ == 'filterwarnings', which has length 14.
# ---------------------------------------------------------------------------

invariant warnings_extra23.filterwarnings.name.len:
  description: "warnings.filterwarnings.__name__.__len__() == 14 — 'filterwarnings' has 14 characters"
  category: string_length
  kind: python_call_eq
  function: filterwarnings.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# warnings.resetwarnings.__name__.__len__()
#
# resetwarnings.__name__ == 'resetwarnings', which has length 13.
# ---------------------------------------------------------------------------

invariant warnings_extra23.resetwarnings.name.len:
  description: "warnings.resetwarnings.__name__.__len__() == 13 — 'resetwarnings' has 13 characters"
  category: string_length
  kind: python_call_eq
  function: resetwarnings.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# warnings.catch_warnings.__module__.__len__()
#
# catch_warnings.__module__ == '_py_warnings', which has length 12.
# ---------------------------------------------------------------------------

invariant warnings_extra23.catch_warnings.module.len:
  description: "warnings.catch_warnings.__module__.__len__() == 12 — '_py_warnings' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: catch_warnings.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# warnings.catch_warnings.__name__.__len__()
#
# catch_warnings.__name__ == 'catch_warnings', which has length 14.
# ---------------------------------------------------------------------------

invariant warnings_extra23.catch_warnings.name.len:
  description: "warnings.catch_warnings.__name__.__len__() == 14 — 'catch_warnings' has 14 characters"
  category: string_length
  kind: python_call_eq
  function: catch_warnings.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# Consolidated table — all twelve __len__ invariants
#
# Covers __module__.__len__() for warn/warn_explicit (9) and
# simplefilter/filterwarnings/resetwarnings/catch_warnings (12),
# __name__.__len__() for warn (4)/warn_explicit (13)/simplefilter (12)/
# filterwarnings (14)/resetwarnings (13)/catch_warnings (14).
# ---------------------------------------------------------------------------

table warnings_extra23.string_lengths:
  description: "String lengths of __module__ and __name__ attributes for warnings functions and catch_warnings class"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected]
  rows:
    - [warn_module_len,            warn.__module__.__len__,            [], 9]
    - [warn_explicit_module_len,   warn_explicit.__module__.__len__,   [], 9]
    - [simplefilter_module_len,    simplefilter.__module__.__len__,    [], 12]
    - [filterwarnings_module_len,  filterwarnings.__module__.__len__,  [], 12]
    - [resetwarnings_module_len,   resetwarnings.__module__.__len__,   [], 12]
    - [warn_name_len,              warn.__name__.__len__,              [], 4]
    - [warn_explicit_name_len,     warn_explicit.__name__.__len__,     [], 13]
    - [simplefilter_name_len,      simplefilter.__name__.__len__,      [], 12]
    - [filterwarnings_name_len,    filterwarnings.__name__.__len__,    [], 14]
    - [resetwarnings_name_len,     resetwarnings.__name__.__len__,     [], 13]
    - [catch_warnings_module_len,  catch_warnings.__module__.__len__,  [], 12]
    - [catch_warnings_name_len,    catch_warnings.__name__.__len__,    [], 14]
