spec: struct_extra151
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra150.zspec.zsdl — covers struct.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('struct') / __name__.__eq__('struct') / pack.__module__.__eq__('_struct') / pack/__class__.__name__.__eq__('builtin_function_or_method') / unpack/__class__.__name__ / calcsize/__module__ (table + invariants)."
    - "struct_extra149.zspec.zsdl — covers struct.Struct.pack_into/__unpack_from/__iter_unpack qualnames / Struct.size/__format/__class__.__name__.__eq__('getset_descriptor') (table + invariants)."
    - "struct_extra148.zspec.zsdl — covers struct.Struct.__name__/__module__/__bases__[0].__name__ / Struct.pack/__qualname__ / Struct.unpack/__qualname__ / struct.error.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "struct_extra143.zspec.zsdl — covers struct.pack.__module__.__eq__('_struct') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra150."
    - "Wave 337 theme: struct module __all__ contents and error class hierarchy details — struct.__all__.__class__.__name__.__eq__('list') / struct.__all__.__contains__('pack') / struct.__all__.__len__()==8 / struct.error.__name__.__eq__('error') / struct.error.__qualname__.__eq__('error') / struct.pack.__qualname__.__eq__('pack') / struct.unpack.__qualname__.__eq__('unpack') / struct.calcsize.__qualname__.__eq__('calcsize')."
    - "struct.__all__.__class__.__name__ == 'list'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__all__ is a list (not a tuple), __all__ == ['calcsize', 'pack', 'pack_into', 'unpack', 'unpack_from', 'iter_unpack', 'Struct', 'error']. This contrasts with hashlib.__all__ which is a tuple (extra157 anchors hashlib.__all__.__class__.__name__=='tuple'). struct uses a list for __all__; the 8 elements are the public names exported by the module: the five module-level functions (calcsize, pack, pack_into, unpack, unpack_from, iter_unpack), the Struct class, and the error exception class."
    - "Note: struct.error.__bases__[0].__name__ == 'Exception' (9 chars). struct.error is NOT a subclass of OSError (unlike socket exceptions). It directly subclasses Exception. struct.error.__module__ == 'struct' (6 chars). struct.error.__qualname__ == 'error' (5 chars; matches __name__; top-level class in the struct module so no dotted prefix)."
    - "Note: struct.pack.__qualname__ == 'pack' (4 chars). Module-level C extension functions have __qualname__ equal to __name__ (the bare function name, no module prefix). This is the same pattern as hashlib.sha256.__qualname__ == 'openssl_sha256' — both are builtin_function_or_method objects. struct.pack.__qualname__ == 'pack' (NOT '_struct.pack' or 'struct.pack'). Same for unpack (6 chars) and calcsize (8 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list')
# struct.__all__.__contains__('pack')
# struct.__all__.__len__()==8
# struct.__all__.__contains__('error')
#
# Wave 337 theme: struct.__all__ is a list with 8 elements including 'pack' and 'error'.
#
# struct.__all__.__class__.__name__ == 'list' (4 chars; NOT 'tuple' like hashlib.__all__).
# struct.__all__.__contains__('pack') == True. struct.__all__.__len__() == 8.
# struct.__all__.__contains__('error') == True (error exception class is public).
# No prior struct spec anchors struct.__all__ class name or contents as a table under
# structall151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra151.all_class_contents_and_length:
  description: "struct.__all__.__class__.__name__.__eq__('list')==True / __all__.__contains__('pack')==True / __all__.__len__()==8 / __all__.__contains__('error')==True — __all__ is a 'list' (4 chars; contrasts with hashlib.__all__ which is 'tuple'; extra157 anchors hashlib's tuple); 8 elements: calcsize/pack/pack_into/unpack/unpack_from/iter_unpack/Struct/error; 'pack' is public; 'error' is public (exception class); first structall151 anchor for struct.__all__ class name, contents, and length"
  kind: python_call_eq
  category: identity
  id_prefix: structall151

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_list,          "__all__.__class__.__name__.__eq__", ["list"],  true, "struct.__all__.__class__.__name__ == 'list' (4 chars; struct uses list, not tuple; contrasts with hashlib.__all__ tuple)"]
    - [all_contains_pack,       "__all__.__contains__",              ["pack"],  true, "struct.__all__.__contains__('pack') == True (pack is a public module-level function in struct.__all__)"]
    - [all_len_8,               "__all__.__len__",                   [],        8,    "struct.__all__.__len__() is 8 (calcsize/pack/pack_into/unpack/unpack_from/iter_unpack/Struct/error)"]
    - [all_contains_error,      "__all__.__contains__",              ["error"], true, "struct.__all__.__contains__('error') == True (struct.error exception class is included in __all__)"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__bases__[0].__name__.__eq__('Exception')
# struct.error.__qualname__.__eq__('error')
#
# Wave 337 theme: struct.error class hierarchy and identity.
#
# struct.error.__name__ == 'error' (5 chars; lowercase, as opposed to OSError-based socket exceptions).
# struct.error.__module__ == 'struct' (6 chars; defined in struct module, not '_struct' C extension).
# struct.error.__bases__[0].__name__ == 'Exception' (9 chars; NOT OSError).
# struct.error.__qualname__ == 'error' (5 chars; equals __name__; top-level class, no dotted prefix).
# extra148 anchors error.__name__/__module__/__bases__[0].__name__ as table rows;
# no prior struct spec anchors error.__qualname__ or the combined set as a table under structall151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra151.error_class_hierarchy_and_qualname:
  description: "struct.error.__name__.__eq__('error')==True / error.__module__.__eq__('struct')==True / error.__bases__[0].__name__.__eq__('Exception')==True / error.__qualname__.__eq__('error')==True — error.__name__ is 'error' (5 chars; lowercase; distinct from socket exceptions which match OSError); error.__module__ is 'struct' (6 chars; note: NOT '_struct'; the exception is defined in the pure-Python stub/wrapper); error.__bases__[0] is 'Exception' (9 chars; NOT OSError; simpler hierarchy than socket exceptions); error.__qualname__ == 'error' (5 chars; qualname equals name for top-level class); extra148 anchors error.__name__/__module__/__bases__[0].__name__ as table rows; first structall151 anchor for error.__qualname__"
  kind: python_call_eq
  category: identity
  id_prefix: structall151

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_error,           "error.__name__.__eq__",              ["error"],     true, "struct.error.__name__ == 'error' (5 chars; lowercase; extra148 anchors this; confirmed here in structall151 context)"]
    - [error_module_struct,        "error.__module__.__eq__",            ["struct"],    true, "struct.error.__module__ == 'struct' (6 chars; defined in struct module, not '_struct' C extension; extra148 anchors this)"]
    - [error_bases_Exception,      "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception' (9 chars; NOT OSError; extra148 anchors this; simpler than socket hierarchy)"]
    - [error_qualname_error,       "error.__qualname__.__eq__",          ["error"],     true, "struct.error.__qualname__ == 'error' (5 chars; qualname == name for top-level class; no 'struct.' prefix in qualname)"]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack')
# struct.unpack.__qualname__.__eq__('unpack')
# struct.calcsize.__qualname__.__eq__('calcsize')
#
# Wave 337 theme: module-level function qualnames are bare names (no module prefix).
#
# struct.pack.__qualname__ == 'pack' (4 chars). struct.unpack.__qualname__ == 'unpack' (6 chars).
# struct.calcsize.__qualname__ == 'calcsize' (8 chars). These are C extension callables
# (builtin_function_or_method) whose __qualname__ equals __name__ (bare function name,
# no 'struct.' or '_struct.' prefix). extra150 anchors pack/__module__=='_struct';
# no prior struct spec anchors these qualname values as a table under structall151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra151.pack_unpack_calcsize_qualnames:
  description: "struct.pack.__qualname__.__eq__('pack')==True / unpack.__qualname__.__eq__('unpack')==True / calcsize.__qualname__.__eq__('calcsize')==True / pack.__qualname__.__len__()==4 — all three module-level functions are builtin_function_or_method; __qualname__==__name__ for C extension callables (no 'struct.' or '_struct.' prefix); pack(4 chars) < unpack(6 chars) < calcsize(8 chars); contrasts with Struct instance methods (e.g., 'Struct.pack'=11 chars, extra148); extra150 anchors pack/__module__=='_struct'; first structall151 anchor for module-level function qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: structall151

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_pack,       "pack.__qualname__.__eq__",      ["pack"],     true, "struct.pack.__qualname__ == 'pack' (4 chars; __qualname__==__name__ for builtin_function_or_method; no module prefix)"]
    - [unpack_qualname_unpack,   "unpack.__qualname__.__eq__",    ["unpack"],   true, "struct.unpack.__qualname__ == 'unpack' (6 chars; __qualname__==__name__ for C extension callable; no module prefix)"]
    - [calcsize_qualname_calcsize,"calcsize.__qualname__.__eq__", ["calcsize"], true, "struct.calcsize.__qualname__ == 'calcsize' (8 chars; __qualname__==__name__; longest of the three module-level functions)"]
    - [pack_qualname_len_4,      "pack.__qualname__.__len__",     [],           4,    "struct.pack.__qualname__.__len__() is 4 ('pack' = 4 chars; shortest module-level function qualname in struct)"]

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list') — standalone
#
# struct.__all__.__class__.__name__ is 'list' (4 chars). struct.__all__ is defined in
# Lib/struct.py as a list (not a tuple). This contrasts with hashlib.__all__ which is a
# tuple (extra157 anchors hashlib.__all__.__class__.__name__ == 'tuple'). The struct
# module defines __all__ = ['calcsize', 'pack', 'pack_into', 'unpack', 'unpack_from',
# 'iter_unpack', 'Struct', 'error']. This list contains 8 public names: the 6
# module-level functions plus the Struct class and the error exception. No prior struct
# spec anchors struct.__all__.__class__.__name__ as a standalone under structall151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra151.all_class_name_list:
  description: "struct.__all__.__class__.__name__.__eq__('list') == True — 'list' (4 chars); struct uses list for __all__ (NOT tuple); contrasts with hashlib.__all__ which is 'tuple' (extra157 anchors tuple); struct.__all__ has 8 elements: calcsize/pack/pack_into/unpack/unpack_from/iter_unpack/Struct/error; struct.__all__.__len__()==8; no prior struct spec anchors __all__.__class__.__name__ as a standalone; first standalone under structall151"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# struct.error.__qualname__ is 'error' (5 chars). For a top-level class (not a nested
# class), __qualname__ equals __name__. struct.error is defined at module scope in the
# struct module (or _struct C extension), so its __qualname__ is simply 'error' — the
# bare class name with no module prefix or enclosing class prefix. This contrasts with
# methods like struct.Struct.pack whose __qualname__ is 'Struct.pack' (dotted, 11 chars).
# extra148 anchors error.__name__=='error' and error.__module__=='struct'; no prior struct
# spec anchors error.__qualname__ as a standalone under structall151.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra151.error_qualname_eq_error:
  description: "struct.error.__qualname__.__eq__('error') == True — 'error' (5 chars); __qualname__==__name__ for top-level class (no enclosing class or dotted prefix); contrasts with Struct.pack.__qualname__=='Struct.pack' (11 chars, dotted; extra148 anchors); error.__module__=='struct' (extra148 anchors); error subclasses Exception (NOT OSError; extra148 anchors); no prior struct spec anchors error.__qualname__ as a standalone; first standalone under structall151"
  category: identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__qualname__.__eq__('calcsize') — standalone
#
# struct.calcsize.__qualname__ is 'calcsize' (8 chars). Like struct.pack and struct.unpack,
# calcsize is a builtin_function_or_method from the _struct C extension module, and its
# __qualname__ equals its __name__ (the bare function name, no module prefix). calcsize()
# returns the size in bytes for a struct described by a format string — for example,
# calcsize('>I') == 4. It is the longest qualname among the three module-level struct
# functions: pack(4) < unpack(6) < calcsize(8). extra150 anchors calcsize.__module__==
# '_struct'; no prior struct spec anchors calcsize.__qualname__ as a standalone under
# structall151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra151.calcsize_qualname_eq_calcsize:
  description: "struct.calcsize.__qualname__.__eq__('calcsize') == True — 'calcsize' (8 chars); __qualname__==__name__ for builtin_function_or_method; no module prefix; longest module-level function qualname: pack(4) < unpack(6) < calcsize(8); calcsize('> I')==4, calcsize('>Q')==8; extra150 anchors calcsize.__module__=='_struct'; no prior struct spec anchors calcsize.__qualname__ as a standalone; first standalone under structall151"
  category: identity
  kind: python_call_eq
  function: calcsize.__qualname__.__eq__
  args: ["calcsize"]
  expected: true

