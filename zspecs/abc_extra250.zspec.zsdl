table abc_extra250.set_class_identity:
  description: "collections.abc Set(len=3) and MutableSet(len=10) class identity — Set inherits from Collection (not object); MutableSet inherits from Set; all in collections.abc(len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc250st

  columns: [id, function, args, expected, description]
  rows:
    - [st_name_eq,    Set.__name__.__eq__,                             ["Set"],                true, "collections.abc.Set.__name__ == 'Set'; verified with Python 3.14.3"]
    - [st_name_len,   Set.__name__.__len__,                            [],                     3,    "collections.abc.Set.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [st_mod_eq,     Set.__module__.__eq__,                           ["collections.abc"],    true, "collections.abc.Set.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [st_mod_len,    Set.__module__.__len__,                          [],                     15,   "collections.abc.Set.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [st_base_eq,    "Set.__bases__[0].__name__.__eq__",              ["Collection"],         true, "collections.abc.Set.__bases__[0].__name__ == 'Collection' — Set inherits from Collection, not directly from object; verified with Python 3.14.3"]
    - [ms_name_eq,    MutableSet.__name__.__eq__,                      ["MutableSet"],         true, "collections.abc.MutableSet.__name__ == 'MutableSet'; verified with Python 3.14.3"]
    - [ms_name_len,   MutableSet.__name__.__len__,                     [],                     10,   "collections.abc.MutableSet.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ms_mod_eq,     MutableSet.__module__.__eq__,                    ["collections.abc"],    true, "collections.abc.MutableSet.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [ms_mod_len,    MutableSet.__module__.__len__,                   [],                     15,   "collections.abc.MutableSet.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [ms_base_eq,    "MutableSet.__bases__[0].__name__.__eq__",       ["Set"],                true, "collections.abc.MutableSet.__bases__[0].__name__ == 'Set' — MutableSet extends Set; verified with Python 3.14.3"]

