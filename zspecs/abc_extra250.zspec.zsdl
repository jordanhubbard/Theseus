spec: abc_extra250
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.MutableSequence.__name__ == 'MutableSequence' (len=15); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Sequence' — MutableSequence name length (15) equals module string length (15)."
    - "collections.abc.MutableMapping.__name__ == 'MutableMapping' (len=14); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Mapping'."
    - "collections.abc.Set.__name__ == 'Set' (len=3); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Collection' — Set inherits from Collection (not object directly)."
    - "collections.abc.MutableSet.__name__ == 'MutableSet' (len=10); __bases__[0].__name__ == 'Set'."
    - "collections.abc.Sized.__name__ == 'Sized' (len=5); __bases__[0].__name__ == 'object'."
    - "collections.abc.Container.__name__ == 'Container' (len=9); __bases__[0].__name__ == 'object'."
    - "collections.abc.Collection.__name__ == 'Collection' (len=10); __bases__ == ['Sized', 'Iterable', 'Container'] — Collection is the three-way join of Sized, Iterable, and Container."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

