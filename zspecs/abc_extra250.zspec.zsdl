# Collection.__bases__[1].__name__ == 'Iterable'
# Collection.__bases__[2].__name__ == 'Container'
# ---------------------------------------------------------------------------

table abc_extra250.sized_container_collection_identity:
  description: "collections.abc Sized(len=5), Container(len=9), and Collection(len=10) class identity — Sized and Container both inherit from object; Collection joins Sized, Iterable, and Container via multiple inheritance; all in collections.abc(len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc250sc

  columns: [id, function, args, expected, description]
  rows:
    - [sz_name_eq,    Sized.__name__.__eq__,                           ["Sized"],              true, "collections.abc.Sized.__name__ == 'Sized'; verified with Python 3.14.3"]
    - [sz_name_len,   Sized.__name__.__len__,                          [],                     5,    "collections.abc.Sized.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [sz_mod_eq,     Sized.__module__.__eq__,                         ["collections.abc"],    true, "collections.abc.Sized.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [sz_base_eq,    "Sized.__bases__[0].__name__.__eq__",            ["object"],             true, "collections.abc.Sized.__bases__[0].__name__ == 'object' — Sized inherits directly from object; verified with Python 3.14.3"]
    - [ct_name_eq,    Container.__name__.__eq__,                       ["Container"],          true, "collections.abc.Container.__name__ == 'Container'; verified with Python 3.14.3"]
    - [ct_name_len,   Container.__name__.__len__,                      [],                     9,    "collections.abc.Container.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [ct_mod_eq,     Container.__module__.__eq__,                     ["collections.abc"],    true, "collections.abc.Container.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [ct_base_eq,    "Container.__bases__[0].__name__.__eq__",        ["object"],             true, "collections.abc.Container.__bases__[0].__name__ == 'object' — Container inherits directly from object; verified with Python 3.14.3"]
    - [co_name_eq,    Collection.__name__.__eq__,                      ["Collection"],         true, "collections.abc.Collection.__name__ == 'Collection'; verified with Python 3.14.3"]
    - [co_name_len,   Collection.__name__.__len__,                     [],                     10,   "collections.abc.Collection.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [co_mod_eq,     Collection.__module__.__eq__,                    ["collections.abc"],    true, "collections.abc.Collection.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [co_mod_len,    Collection.__module__.__len__,                   [],                     15,   "collections.abc.Collection.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [co_base0_eq,   "Collection.__bases__[0].__name__.__eq__",       ["Sized"],              true, "collections.abc.Collection.__bases__[0].__name__ == 'Sized' — Collection's first base; verified with Python 3.14.3"]
    - [co_base1_eq,   "Collection.__bases__[1].__name__.__eq__",       ["Iterable"],           true, "collections.abc.Collection.__bases__[1].__name__ == 'Iterable' — Collection's second base; verified with Python 3.14.3"]
    - [co_base2_eq,   "Collection.__bases__[2].__name__.__eq__",       ["Container"],          true, "collections.abc.Collection.__bases__[2].__name__ == 'Container' — Collection's third base; Collection joins Sized, Iterable, and Container; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra250
# ---------------------------------------------------------------------------

invariant abc_extra250.set_base_is_collection:
  description: "collections.abc.Set.__bases__[0].__name__.__eq__('Collection') returns True — Set(len=3) inherits from Collection(len=10), not directly from object; this places Set in the Collection sub-hierarchy rather than as a primitive ABC; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Set.__bases__[0].__name__.__eq__"
  args: ["Collection"]
  expected: true

invariant abc_extra250.collection_has_three_bases:
  description: "collections.abc.Collection.__bases__[2].__name__.__eq__('Container') returns True — Collection(len=10) is the three-way join of Sized, Iterable, and Container; its bases[2] being Container confirms the full multiple-inheritance tuple; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Collection.__bases__[2].__name__.__eq__"
  args: ["Container"]
  expected: true
