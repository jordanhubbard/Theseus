table abc_extra250.mutable_sequence_mapping_identity:
  description: "collections.abc MutableSequence(len=15) and MutableMapping(len=14) class identity — MutableSequence.__name__ length (15) equals its __module__ length (15); MutableMapping inherits from Mapping; both in collections.abc(len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc250ms

  columns: [id, function, args, expected, description]
  rows:
    - [ms_name_eq,    MutableSequence.__name__.__eq__,                     ["MutableSequence"],    true, "collections.abc.MutableSequence.__name__ == 'MutableSequence'; verified with Python 3.14.3"]
    - [ms_name_len,   MutableSequence.__name__.__len__,                    [],                     15,   "collections.abc.MutableSequence.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [ms_mod_eq,     MutableSequence.__module__.__eq__,                   ["collections.abc"],    true, "collections.abc.MutableSequence.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [ms_mod_len,    MutableSequence.__module__.__len__,                  [],                     15,   "collections.abc.MutableSequence.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [ms_base_eq,    "MutableSequence.__bases__[0].__name__.__eq__",      ["Sequence"],           true, "collections.abc.MutableSequence.__bases__[0].__name__ == 'Sequence' — MutableSequence extends Sequence; verified with Python 3.14.3"]
    - [mm_name_eq,    MutableMapping.__name__.__eq__,                      ["MutableMapping"],     true, "collections.abc.MutableMapping.__name__ == 'MutableMapping'; verified with Python 3.14.3"]
    - [mm_name_len,   MutableMapping.__name__.__len__,                     [],                     14,   "collections.abc.MutableMapping.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [mm_mod_eq,     MutableMapping.__module__.__eq__,                    ["collections.abc"],    true, "collections.abc.MutableMapping.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [mm_mod_len,    MutableMapping.__module__.__len__,                   [],                     15,   "collections.abc.MutableMapping.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [mm_base_eq,    "MutableMapping.__bases__[0].__name__.__eq__",       ["Mapping"],            true, "collections.abc.MutableMapping.__bases__[0].__name__ == 'Mapping' — MutableMapping extends Mapping; verified with Python 3.14.3"]

