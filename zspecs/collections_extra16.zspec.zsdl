spec: collections_extra16
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra15.zspec.zsdl."
    - "collections_extra15 covers: UserDict instance class name; deque.maxlen (None, bounded, zero); Counter.most_common top pair and len; namedtuple._asdict field values by key; ChainMap.maps length (2 and 3); Counter.subtract returns None."
    - "No prior collections spec covers __qualname__ for OrderedDict, defaultdict, Counter, ChainMap, deque, namedtuple, UserDict, UserList, or UserString."
    - "No prior collections spec covers collections.abc.__name__ == 'collections.abc'."
    - "collections.OrderedDict.__qualname__ == 'OrderedDict' — top-level class."
    - "collections.defaultdict.__qualname__ == 'defaultdict' — C-level type."
    - "collections.Counter.__qualname__ == 'Counter' — subclass of dict."
    - "collections.ChainMap.__qualname__ == 'ChainMap' — pure-Python class."
    - "collections.deque.__qualname__ == 'deque' — C-level type."
    - "collections.namedtuple.__qualname__ == 'namedtuple' — factory function."
    - "collections.UserDict.__qualname__ == 'UserDict' — pure-Python wrapper."
    - "collections.UserList.__qualname__ == 'UserList' — pure-Python wrapper."
    - "collections.UserString.__qualname__ == 'UserString' — pure-Python wrapper."
    - "collections.abc.__name__ == 'collections.abc' — sub-module full name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections class and function __qualname__ attributes
#
# No prior collections spec covers __qualname__ for any of these names.
# For top-level classes and functions, __qualname__ equals __name__.
# All of these are defined at module scope so qualname == simple name.
# ---------------------------------------------------------------------------

invariant collections_extra16.OrderedDict.qualname:
  description: "collections.OrderedDict.__qualname__ == 'OrderedDict' — top-level class"
  category: qualnames
  kind: python_call_eq
  function: OrderedDict.__qualname__.__eq__
  args: ["OrderedDict"]
  expected: true

invariant collections_extra16.defaultdict.qualname:
  description: "collections.defaultdict.__qualname__ == 'defaultdict' — C-level type"
  category: qualnames
  kind: python_call_eq
  function: defaultdict.__qualname__.__eq__
  args: ["defaultdict"]
  expected: true

invariant collections_extra16.Counter.qualname:
  description: "collections.Counter.__qualname__ == 'Counter' — dict subclass"
  category: qualnames
  kind: python_call_eq
  function: Counter.__qualname__.__eq__
  args: ["Counter"]
  expected: true

invariant collections_extra16.ChainMap.qualname:
  description: "collections.ChainMap.__qualname__ == 'ChainMap' — pure-Python class"
  category: qualnames
  kind: python_call_eq
  function: ChainMap.__qualname__.__eq__
  args: ["ChainMap"]
  expected: true

invariant collections_extra16.deque.qualname:
  description: "collections.deque.__qualname__ == 'deque' — C-level type"
  category: qualnames
  kind: python_call_eq
  function: deque.__qualname__.__eq__
  args: ["deque"]
  expected: true

invariant collections_extra16.namedtuple.qualname:
  description: "collections.namedtuple.__qualname__ == 'namedtuple' — factory function"
  category: qualnames
  kind: python_call_eq
  function: namedtuple.__qualname__.__eq__
  args: ["namedtuple"]
  expected: true

invariant collections_extra16.UserDict.qualname:
  description: "collections.UserDict.__qualname__ == 'UserDict' — pure-Python wrapper class"
  category: qualnames
  kind: python_call_eq
  function: UserDict.__qualname__.__eq__
  args: ["UserDict"]
  expected: true

invariant collections_extra16.UserList.qualname:
  description: "collections.UserList.__qualname__ == 'UserList' — pure-Python wrapper class"
  category: qualnames
  kind: python_call_eq
  function: UserList.__qualname__.__eq__
  args: ["UserList"]
  expected: true

invariant collections_extra16.UserString.qualname:
  description: "collections.UserString.__qualname__ == 'UserString' — pure-Python wrapper class"
  category: qualnames
  kind: python_call_eq
  function: UserString.__qualname__.__eq__
  args: ["UserString"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.__name__ — sub-module name attribute
#
# No prior collections spec covers the collections.abc sub-module itself.
# collections.abc is a module accessible as a module-level attribute of
# collections (via import). Its __name__ is the fully qualified 'collections.abc'.
# ---------------------------------------------------------------------------

invariant collections_extra16.abc.module_name:
  description: "collections.abc.__name__ == 'collections.abc' — fully qualified sub-module name"
  category: submodule
  kind: python_call_eq
  function: abc.__name__.__eq__
  args: ["collections.abc"]
  expected: true

# ---------------------------------------------------------------------------
# Additional qualname length checks — sanity cross-checks
#
# These complement the equality invariants above and provide a second
# behavioral axis: string length rather than string content.
# OrderedDict.__qualname__.__len__() == 11; deque.__qualname__.__len__() == 5.
# ---------------------------------------------------------------------------

invariant collections_extra16.OrderedDict.qualname_len:
  description: "collections.OrderedDict.__qualname__.__len__() == 11 — len('OrderedDict')"
  category: qualname_lengths
  kind: python_call_eq
  function: OrderedDict.__qualname__.__len__
  args: []
  expected: 11

invariant collections_extra16.deque.qualname_len:
  description: "collections.deque.__qualname__.__len__() == 5 — len('deque')"
  category: qualname_lengths
  kind: python_call_eq
  function: deque.__qualname__.__len__
  args: []
  expected: 5
