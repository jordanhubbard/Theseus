spec: re_extra200
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, and compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class names, error class, flag constants, match/search/sub/split/findall"
    - "re_extra199.zspec.zsdl — covers Match method qualnames: group, groups, start, end, span, groupdict, __repr__, __getitem__"
  notes:
    - "This spec covers re.Pattern method name lengths not already in previous re_extra specs."
    - "re.Pattern.match.__name__ == 'match' — method name length 5."
    - "re.Pattern.search.__name__ == 'search' — method name length 6."
    - "re.Pattern.findall.__name__ == 'findall' — method name length 7."
    - "re.Pattern.finditer.__name__ == 'finditer' — method name length 8."
    - "re.Pattern.sub.__name__ == 'sub' — method name length 3 (shortest)."
    - "re.Pattern.subn.__name__ == 'subn' — method name length 4."
    - "re.Pattern.split.__name__ == 'split' — method name length 5."
    - "re.Pattern.fullmatch.__name__ == 'fullmatch' — method name length 9 (longest)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern core method name lengths — match, search, findall, finditer
# ---------------------------------------------------------------------------

table re_extra200.pattern_core_name_lens:
  description: "re.Pattern core method name lengths in repatternnamelens200 namespace — match=5, search=6, findall=7, finditer=8; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name_lengths
  id_prefix: repatternnamelens200

  columns: [id, function, args, expected, description]
  rows:
    - [match_name_len,   Pattern.match.__name__.__len__,    [], 5, "re.Pattern.match.__name__.__len__() == 5 ('match' has 5 chars); verified with Python 3.14.3"]
    - [search_name_len,  Pattern.search.__name__.__len__,   [], 6, "re.Pattern.search.__name__.__len__() == 6 ('search' has 6 chars); verified with Python 3.14.3"]
    - [findall_name_len, Pattern.findall.__name__.__len__,  [], 7, "re.Pattern.findall.__name__.__len__() == 7 ('findall' has 7 chars); verified with Python 3.14.3"]
    - [finditer_name_len,Pattern.finditer.__name__.__len__, [], 8, "re.Pattern.finditer.__name__.__len__() == 8 ('finditer' has 8 chars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.Pattern substitution method name lengths — sub, subn
# ---------------------------------------------------------------------------

table re_extra200.pattern_sub_name_lens:
  description: "re.Pattern substitution method name lengths in repatternnamelens200b namespace — sub=3 (shortest), subn=4; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name_lengths
  id_prefix: repatternnamelens200b

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name_len,  Pattern.sub.__name__.__len__,  [], 3, "re.Pattern.sub.__name__.__len__() == 3 ('sub' has 3 chars — shortest in spec); verified with Python 3.14.3"]
    - [subn_name_len, Pattern.subn.__name__.__len__, [], 4, "re.Pattern.subn.__name__.__len__() == 4 ('subn' has 4 chars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.Pattern split/fullmatch method name lengths
# ---------------------------------------------------------------------------

table re_extra200.pattern_split_fullmatch_name_lens:
  description: "re.Pattern split and fullmatch method name lengths in repatternnamelens200c namespace — split=5, fullmatch=9 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name_lengths
  id_prefix: repatternnamelens200c

  columns: [id, function, args, expected, description]
  rows:
    - [split_name_len,     Pattern.split.__name__.__len__,     [], 5, "re.Pattern.split.__name__.__len__() == 5 ('split' has 5 chars); verified with Python 3.14.3"]
    - [fullmatch_name_len, Pattern.fullmatch.__name__.__len__, [], 9, "re.Pattern.fullmatch.__name__.__len__() == 9 ('fullmatch' has 9 chars — longest in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — repatternnamelens200
# ---------------------------------------------------------------------------

invariant re_extra200.Pattern.match_name_eq:
  description: "re.Pattern.match.__name__.__eq__('match') returns True — match() tries to apply the pattern at the start of the string; __name__ is 'match' with len=5; compare: split.__name__=='split' also len=5; sub.__name__=='sub' len=3 (shortest); fullmatch.__name__=='fullmatch' len=9 (longest); NEW in re_extra200: first standalone Pattern.match.__name__ invariant in repatternnamelens200 namespace; verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra200.Pattern.search_name_eq:
  description: "re.Pattern.search.__name__.__eq__('search') returns True — search() scans through the string looking for the first location where the pattern matches; __name__ is 'search' with len=6; compare: findall.__name__=='findall' len=7; match.__name__=='match' len=5; verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.search.__name__.__eq__
  args: ["search"]
  expected: true

invariant re_extra200.Pattern.findall_name_len:
  description: "re.Pattern.findall.__name__.__len__() == 7 — 'findall' has 7 chars; findall() returns all non-overlapping matches as a list; if there is one group, returns a list of groups; if multiple groups, returns a list of tuples of groups; compare: search len=6; finditer len=8; verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.findall.__name__.__len__
  args: []
  expected: 7

invariant re_extra200.Pattern.finditer_name_len:
  description: "re.Pattern.finditer.__name__.__len__() == 8 — 'finditer' has 8 chars; finditer() returns an iterator yielding match objects; compare: findall len=7; fullmatch len=9; sub len=3 (shortest); verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.finditer.__name__.__len__
  args: []
  expected: 8

invariant re_extra200.Pattern.sub_name_len:
  description: "re.Pattern.sub.__name__.__len__() == 3 — 'sub' has 3 chars — shortest method name in this spec; sub() returns the string obtained by replacing the leftmost non-overlapping occurrences of the pattern in string by the replacement repl; compare: subn len=4; match/split len=5; fullmatch len=9 (longest); verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.sub.__name__.__len__
  args: []
  expected: 3

invariant re_extra200.Pattern.subn_name_len:
  description: "re.Pattern.subn.__name__.__len__() == 4 — 'subn' has 4 chars; subn() is like sub() but returns a 2-tuple (new_string, number_of_subs_made); compare: sub len=3; match/split len=5; search len=6; compare all name lengths in spec: sub=3, subn=4, match=5, split=5, search=6, findall=7, finditer=8, fullmatch=9; verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.subn.__name__.__len__
  args: []
  expected: 4

invariant re_extra200.Pattern.split_name_eq:
  description: "re.Pattern.split.__name__.__eq__('split') returns True — split() splits the string by the occurrences of the pattern; __name__ is 'split' with len=5; compare: match.__name__=='match' also len=5; search len=6; subn len=4; fullmatch len=9 (longest); verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.split.__name__.__eq__
  args: ["split"]
  expected: true

invariant re_extra200.Pattern.fullmatch_name_len:
  description: "re.Pattern.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 chars — longest method name in this spec; fullmatch() tries to apply the pattern to the entire string; compare qualname lengths: sub=3, subn=4, match=5, split=5, search=6, findall=7, finditer=8, fullmatch=9; verified with Python 3.14.3"
  category: method_name_lengths
  kind: python_call_eq
  function: Pattern.fullmatch.__name__.__len__
  args: []
  expected: 9
