spec: multiprocessing_extra232
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers multiprocessing.AuthenticationError and multiprocessing.ProcessError exception identity."
    - "AuthenticationError.__name__ == 'AuthenticationError' — 19 characters."
    - "AuthenticationError.__module__ == 'multiprocessing.context' — 23 characters."
    - "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — inherits from ProcessError."
    - "AuthenticationError.__qualname__ == 'AuthenticationError' — 19 characters; matches __name__."
    - "ProcessError.__name__ == 'ProcessError' — 12 characters."
    - "ProcessError.__module__ == 'multiprocessing.context' — 23 characters."
    - "ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits directly from Exception."
    - "ProcessError.__qualname__ == 'ProcessError' — 12 characters; matches __name__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: AuthenticationError class identity contracts
#
# AuthenticationError.__name__, __module__, __qualname__ and string lengths.
# ---------------------------------------------------------------------------

table multiprocessing_extra232.auth_error_identity:
  description: "multiprocessing.AuthenticationError class identity: name, module, qualname; new to extra232"
  kind: python_call_eq
  category: exception_identity
  id_prefix: mpexc232

  columns: [id, function, args, expected, description]
  rows:
    - [auth_name_eq,
       AuthenticationError.__name__.__eq__,
       ["AuthenticationError"],
       true,
       "multiprocessing.AuthenticationError.__name__.__eq__('AuthenticationError') == True — 19 characters; new to extra232"]
    - [auth_module_eq,
       AuthenticationError.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.AuthenticationError.__module__.__eq__('multiprocessing.context') == True — 23 characters; new to extra232"]
    - [auth_qualname_eq,
       AuthenticationError.__qualname__.__eq__,
       ["AuthenticationError"],
       true,
       "multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError') == True — qualname matches __name__; new to extra232"]
    - [auth_name_len_19,
       AuthenticationError.__name__.__len__,
       [],
       19,
       "multiprocessing.AuthenticationError.__name__.__len__() == 19 — 'AuthenticationError' has 19 characters; new to extra232"]
    - [auth_module_len_23,
       AuthenticationError.__module__.__len__,
       [],
       23,
       "multiprocessing.AuthenticationError.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra232"]

# ---------------------------------------------------------------------------
# Table 2: AuthenticationError base class contract
#
# AuthenticationError.__bases__[0].__name__ == 'ProcessError'.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table multiprocessing_extra232.auth_error_base:
  description: "multiprocessing.AuthenticationError base class identity; new to extra232"
  kind: python_call_eq
  category: exception_identity
  id_prefix: mpexc232

  columns: [id, function, args, expected, description]
  rows:
    - [auth_base_name_eq,
       "AuthenticationError.__bases__[0].__name__.__eq__",
       ["ProcessError"],
       true,
       "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__('ProcessError') == True — AuthenticationError inherits from ProcessError; new to extra232"]

# ---------------------------------------------------------------------------
# Table 3: ProcessError class identity contracts
#
# ProcessError.__name__, __module__, __qualname__ and string lengths.
# ---------------------------------------------------------------------------

table multiprocessing_extra232.process_error_identity:
  description: "multiprocessing.ProcessError class identity: name, module, qualname; new to extra232"
  kind: python_call_eq
  category: exception_identity
  id_prefix: mpexc232

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name_eq,
       ProcessError.__name__.__eq__,
       ["ProcessError"],
       true,
       "multiprocessing.ProcessError.__name__.__eq__('ProcessError') == True — 12 characters; new to extra232"]
    - [proc_module_eq,
       ProcessError.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.ProcessError.__module__.__eq__('multiprocessing.context') == True — 23 characters; new to extra232"]
    - [proc_qualname_eq,
       ProcessError.__qualname__.__eq__,
       ["ProcessError"],
       true,
       "multiprocessing.ProcessError.__qualname__.__eq__('ProcessError') == True — qualname matches __name__; new to extra232"]
    - [proc_name_len_12,
       ProcessError.__name__.__len__,
       [],
       12,
       "multiprocessing.ProcessError.__name__.__len__() == 12 — 'ProcessError' has 12 characters; new to extra232"]
    - [proc_module_len_23,
       ProcessError.__module__.__len__,
       [],
       23,
       "multiprocessing.ProcessError.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra232"]

# ---------------------------------------------------------------------------
# Table 4: ProcessError base class contract
#
# ProcessError.__bases__[0].__name__ == 'Exception'.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table multiprocessing_extra232.process_error_base:
  description: "multiprocessing.ProcessError base class identity; new to extra232"
  kind: python_call_eq
  category: exception_identity
  id_prefix: mpexc232

  columns: [id, function, args, expected, description]
  rows:
    - [proc_base_name_eq,
       "ProcessError.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception') == True — ProcessError inherits from Exception; new to extra232"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra232
# ---------------------------------------------------------------------------

invariant multiprocessing_extra232.AuthenticationError.name:
  description: "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: AuthenticationError.__name__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra232.AuthenticationError.module:
  description: "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context'; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: AuthenticationError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra232.AuthenticationError.qualname:
  description: "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError'; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra232.AuthenticationError.name_len:
  description: "multiprocessing.AuthenticationError.__name__.__len__() == 19 — 'AuthenticationError' has 19 characters; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: AuthenticationError.__name__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra232.AuthenticationError.base_name:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError' — inherits from ProcessError; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: "AuthenticationError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra232.ProcessError.name:
  description: "multiprocessing.ProcessError.__name__ == 'ProcessError'; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: ProcessError.__name__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra232.ProcessError.module:
  description: "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: ProcessError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra232.ProcessError.qualname:
  description: "multiprocessing.ProcessError.__qualname__ == 'ProcessError'; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: ProcessError.__qualname__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra232.ProcessError.name_len:
  description: "multiprocessing.ProcessError.__name__.__len__() == 12 — 'ProcessError' has 12 characters; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: ProcessError.__name__.__len__
  args: []
  expected: 12

invariant multiprocessing_extra232.ProcessError.base_name:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits from Exception; new to extra232"
  category: exception_identity
  kind: python_call_eq
  function: "ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
