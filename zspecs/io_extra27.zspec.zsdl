spec: io_extra27
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra26.zspec.zsdl — covers __qualname__ table for seven concrete classes; open_code __name__/__qualname__/__module__; BufferedRandom __name__/__module__."
    - "io_extra25.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __bases__[0].__name__ table; FileIO/StringIO/BytesIO base names; open.__module__; DEFAULT_BUFFER_SIZE class name."
    - "io_extra22.zspec.zsdl — covers DEFAULT_BUFFER_SIZE and class __module__ table."
  notes:
    - "This spec extends io through io_extra26 with UnsupportedOperation class attributes and SEEK_* constant vectors."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError': multiple-inheritance class; first base is OSError."
    - "len(io.UnsupportedOperation.__bases__) == 2: UnsupportedOperation inherits from both OSError and ValueError."
    - "len(io.UnsupportedOperation.__mro__) == 6: MRO is UnsupportedOperation, OSError, ValueError, Exception, BaseException, object."
    - "io.SEEK_SET == 0: seek to absolute position (POSIX convention)."
    - "io.SEEK_CUR == 1: seek relative to current position."
    - "io.SEEK_END == 2: seek relative to end of stream."
    - "io.SEEK_SET.__class__.__name__ == 'int': SEEK_* constants are plain Python ints."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' and __module__ == 'io'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UnsupportedOperation — bases count and first base name (extra27 namespace)
#
# io.UnsupportedOperation is a multiple-inheritance exception that inherits
# from both OSError and ValueError, giving it two bases. Its first base
# (index 0) is OSError. No prior io spec covers UnsupportedOperation.__bases__.
# Verified: len(io.UnsupportedOperation.__bases__) == 2
#           io.UnsupportedOperation.__bases__[0].__name__ == 'OSError'
# ---------------------------------------------------------------------------

invariant io_extra27.UnsupportedOperation.bases.len:
  description: "len(io.UnsupportedOperation.__bases__) == 2 — inherits from both OSError and ValueError"
  category: class_hierarchy
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__.__len__"
  args: []
  expected: 2

invariant io_extra27.UnsupportedOperation.bases0.name:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — first base is OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# UnsupportedOperation MRO length (extra27 namespace)
#
# MRO: UnsupportedOperation → OSError → ValueError → Exception →
#      BaseException → object  (6 entries total).
# No prior io spec covers UnsupportedOperation.__mro__.
# Verified: len(io.UnsupportedOperation.__mro__) == 6.
# ---------------------------------------------------------------------------

invariant io_extra27.UnsupportedOperation.mro.len:
  description: "len(io.UnsupportedOperation.__mro__) == 6 — six-entry MRO including both exception branches"
  category: class_hierarchy
  kind: python_call_eq
  function: "UnsupportedOperation.__mro__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# UnsupportedOperation — __name__ and __module__ (extra27 namespace)
#
# No prior io spec covers UnsupportedOperation.__name__ or __module__ as
# standalone invariants.
# Verified: io.UnsupportedOperation.__name__ == 'UnsupportedOperation'
#           io.UnsupportedOperation.__module__ == 'io'
# ---------------------------------------------------------------------------

invariant io_extra27.UnsupportedOperation.name:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra27.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io' — class is defined in the io module"
  category: module_identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

# ---------------------------------------------------------------------------
# Table: SEEK_* constant values (extra27 namespace)
#
# POSIX defines three seek modes: SEEK_SET=0, SEEK_CUR=1, SEEK_END=2.
# No prior io spec covers the integer values of io.SEEK_SET, io.SEEK_CUR,
# or io.SEEK_END, nor their __class__.__name__.
# ---------------------------------------------------------------------------

table io_extra27.seek_constants:
  description: "io SEEK_* constants have POSIX-specified integer values 0, 1, 2"
  kind: python_call_eq
  category: constants

  columns: [id, function, args, expected]
  rows:
    - [SEEK_SET_value,  SEEK_SET.__eq__,               [0],     true]
    - [SEEK_CUR_value,  SEEK_CUR.__eq__,               [1],     true]
    - [SEEK_END_value,  SEEK_END.__eq__,               [2],     true]
    - [SEEK_SET_class,  SEEK_SET.__class__.__name__.__eq__, ["int"], true]
    - [SEEK_CUR_class,  SEEK_CUR.__class__.__name__.__eq__, ["int"], true]
    - [SEEK_END_class,  SEEK_END.__class__.__name__.__eq__, ["int"], true]
