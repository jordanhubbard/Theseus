spec: warnings_extra19
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends prior warnings specs through warnings_extra18.zspec.zsdl."
    - "warnings_extra18 covers: warn/warn_explicit/filterwarnings/simplefilter/resetwarnings module-level function __qualname__ values and catch_warnings class __qualname__."
    - "Focus: __qualname__ values for catch_warnings class-bound methods (__enter__, __exit__, __init__), WarningMessage class and its __str__ method, and builtin warning classes UserWarning/RuntimeWarning/FutureWarning."
    - "warnings.catch_warnings.__enter__.__qualname__ == 'catch_warnings.__enter__' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.catch_warnings.__exit__.__qualname__ == 'catch_warnings.__exit__' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.catch_warnings.__init__.__qualname__ == 'catch_warnings.__init__' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.WarningMessage.__qualname__ == 'WarningMessage' — top-level class."
    - "warnings.WarningMessage.__str__.__qualname__ == 'WarningMessage.__str__' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "UserWarning, RuntimeWarning, and FutureWarning are builtin exception classes; warnings.UserWarning raises AttributeError — they must be accessed via builtins. Their __qualname__ equals their class name."
    - "UserWarning.__qualname__ == 'UserWarning' — builtin class."
    - "RuntimeWarning.__qualname__ == 'RuntimeWarning' — builtin class."
    - "FutureWarning.__qualname__ == 'FutureWarning' — builtin class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings.catch_warnings class-bound method __qualname__ values
#
# catch_warnings is a context manager class. warnings_extra18 records
# catch_warnings.__qualname__ as a class. No prior warnings spec records
# __qualname__ for __enter__, __exit__, or __init__ on catch_warnings.
# ---------------------------------------------------------------------------

invariant warnings_extra19.catch_warnings.__enter__.qualname:
  description: "warnings.catch_warnings.__enter__.__qualname__ == 'catch_warnings.__enter__'"
  category: method_qualname
  kind: python_call_eq
  function: "catch_warnings.__enter__.__qualname__.__eq__"
  args: ["catch_warnings.__enter__"]
  expected: true

invariant warnings_extra19.catch_warnings.__exit__.qualname:
  description: "warnings.catch_warnings.__exit__.__qualname__ == 'catch_warnings.__exit__'"
  category: method_qualname
  kind: python_call_eq
  function: "catch_warnings.__exit__.__qualname__.__eq__"
  args: ["catch_warnings.__exit__"]
  expected: true

invariant warnings_extra19.catch_warnings.__init__.qualname:
  description: "warnings.catch_warnings.__init__.__qualname__ == 'catch_warnings.__init__'"
  category: method_qualname
  kind: python_call_eq
  function: "catch_warnings.__init__.__qualname__.__eq__"
  args: ["catch_warnings.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# warnings.WarningMessage class and method __qualname__ values
#
# WarningMessage is a top-level class used to hold warning details.
# Its __qualname__ equals its class name.
# WarningMessage.__str__ provides the string representation.
# No prior warnings spec records __qualname__ for WarningMessage or its
# __str__ method.
# ---------------------------------------------------------------------------

invariant warnings_extra19.WarningMessage.qualname:
  description: "warnings.WarningMessage.__qualname__ == 'WarningMessage' — top-level class"
  category: class_qualname
  kind: python_call_eq
  function: WarningMessage.__qualname__.__eq__
  args: ["WarningMessage"]
  expected: true

invariant warnings_extra19.WarningMessage.__str__.qualname:
  description: "warnings.WarningMessage.__str__.__qualname__ == 'WarningMessage.__str__'"
  category: method_qualname
  kind: python_call_eq
  function: "WarningMessage.__str__.__qualname__.__eq__"
  args: ["WarningMessage.__str__"]
  expected: true

# ---------------------------------------------------------------------------
# Builtin warning class __qualname__ values
#
# UserWarning, RuntimeWarning, and FutureWarning are builtin exception
# classes. They are NOT attributes of the warnings module (accessing
# warnings.UserWarning raises AttributeError). Their __qualname__ equals
# their class name.
# No prior warnings spec records __qualname__ for these builtin classes.
# ---------------------------------------------------------------------------

invariant warnings_extra19.UserWarning.qualname:
  description: "UserWarning.__qualname__ == 'UserWarning' — builtin warning class"
  category: class_qualname
  kind: python_call_eq
  function: UserWarning.__qualname__.__eq__
  args: ["UserWarning"]
  expected: true

invariant warnings_extra19.RuntimeWarning.qualname:
  description: "RuntimeWarning.__qualname__ == 'RuntimeWarning' — builtin warning class"
  category: class_qualname
  kind: python_call_eq
  function: RuntimeWarning.__qualname__.__eq__
  args: ["RuntimeWarning"]
  expected: true

invariant warnings_extra19.FutureWarning.qualname:
  description: "FutureWarning.__qualname__ == 'FutureWarning' — builtin warning class"
  category: class_qualname
  kind: python_call_eq
  function: FutureWarning.__qualname__.__eq__
  args: ["FutureWarning"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all eight __qualname__ checks
#
# Covers catch_warnings.__enter__/__exit__/__init__ (context manager methods),
# WarningMessage class and WarningMessage.__str__ (class and method), and
# UserWarning/RuntimeWarning/FutureWarning (builtin classes).
# ---------------------------------------------------------------------------

table warnings_extra19.qualnames:
  description: "__qualname__ values for catch_warnings methods, WarningMessage, and builtin warning classes"
  kind: python_call_eq
  category: method_qualname

  columns: [id, function, args, expected]
  rows:
    - [catch_warnings.__enter__, "catch_warnings.__enter__.__qualname__.__eq__", ["catch_warnings.__enter__"], true]
    - [catch_warnings.__exit__,  "catch_warnings.__exit__.__qualname__.__eq__",  ["catch_warnings.__exit__"],  true]
    - [catch_warnings.__init__,  "catch_warnings.__init__.__qualname__.__eq__",  ["catch_warnings.__init__"],  true]
    - [WarningMessage,           WarningMessage.__qualname__.__eq__,              ["WarningMessage"],           true]
    - [WarningMessage.__str__,   "WarningMessage.__str__.__qualname__.__eq__",    ["WarningMessage.__str__"],   true]
    - [UserWarning,              UserWarning.__qualname__.__eq__,                 ["UserWarning"],              true]
    - [RuntimeWarning,           RuntimeWarning.__qualname__.__eq__,              ["RuntimeWarning"],           true]
    - [FutureWarning,            FutureWarning.__qualname__.__eq__,               ["FutureWarning"],            true]
