# ---------------------------------------------------------------------------
# Behavioral: compile_command — complete statement returns a code object
# ---------------------------------------------------------------------------

invariant code.compile_command.complete_returns_code:
  description: "code.compile_command('x = 1').__class__.__name__ == 'code' — returns a code object for complete input"
  category: behavioral
  kind: python_call_eq
  function: compile_command
  args: ["x = 1"]
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: compile_command — incomplete statement returns None
# ---------------------------------------------------------------------------

invariant code.compile_command.incomplete_returns_none:
  description: "code.compile_command('if True:') is None — incomplete statement returns None"
  category: behavioral
  kind: python_call_eq
  function: compile_command
  args: ["if True:"]
  expected: null

