spec: code
version: ">=3.0"
backend: python_module(code)

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/code.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "code source: Lib/code.py (PSF; source inspection permitted)"
  not_derived_from:
    - "code source: internal readline/completion hook integration"
  notes:
    - "code.interact() is a convenience function that starts an interactive console session."
    - "code.compile_command() compiles a source string; returns a code object if complete, None if incomplete, raises SyntaxError on error."
    - "code.InteractiveConsole inherits from InteractiveInterpreter and adds line-buffering and readline support."
    - "code.InteractiveInterpreter provides runsource(), runcode(), showtraceback(), showsyntaxerror(), and write()."
    - "code.CommandCompiler wraps codeop.CommandCompiler and remembers future import flags across calls."
    - "compile_command('x = 1') returns a code object whose __class__.__name__ is 'code'."
    - "compile_command('if True:') returns None because the statement is syntactically incomplete."
    - "InteractiveConsole.__bases__[0].__name__ == 'InteractiveInterpreter' — direct single inheritance."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

