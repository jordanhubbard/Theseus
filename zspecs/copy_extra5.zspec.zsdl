spec: copy_extra5
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy.zspec.zsdl, copy_extra.zspec.zsdl, copy_extra2.zspec.zsdl, copy_extra4.zspec.zsdl."
    - "Focus: __qualname__ checks for copy functions and Error class; new copy/deepcopy value vectors."
    - "copy.copy.__qualname__ == 'copy' — module-level function qualname equals its simple name."
    - "copy.deepcopy.__qualname__ == 'deepcopy' — module-level function."
    - "copy.Error.__qualname__ == 'Error' — top-level exception class."
    - "copy.replace was added in Python 3.13; skipped here for >=3.9 compatibility."
    - "copy.copy((1,2,3)) == (1,2,3) — shallow copy of a tuple."
    - "copy.deepcopy({'a': [1,2]}) == {'a': [1,2]} — deep copy of a dict with list value."
    - "copy.deepcopy([1,[2,3]]) == [1,[2,3]] — deep copy of a nested list (distinct from [[1,2],[3,4]])."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for copy functions (table)
# ---------------------------------------------------------------------------

table copy_extra5.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__qualname__.__eq__,     ["copy"],     true]
    - [deepcopy, deepcopy.__qualname__.__eq__, ["deepcopy"], true]

# ---------------------------------------------------------------------------
# __qualname__ for Error exception class
# ---------------------------------------------------------------------------

invariant copy_extra5.Error.qualname:
  description: "copy.Error.__qualname__ == 'Error'"
  category: qualnames
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# copy.copy — shallow copy of a tuple (not covered in prior specs)
# ---------------------------------------------------------------------------

invariant copy_extra5.copy.tuple_value:
  description: "copy.copy((1,2,3)) == (1,2,3) — shallow copy of a tuple"
  category: copy
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# copy.deepcopy — new vectors not covered in prior specs
# ---------------------------------------------------------------------------

invariant copy_extra5.deepcopy.dict_with_list_value:
  description: "copy.deepcopy({'a': [1,2]}) == {'a': [1,2]} — deep copy of dict with list value"
  category: deepcopy
  kind: python_call_eq
  function: deepcopy
  args: [{a: [1, 2]}]
  expected: {a: [1, 2]}

invariant copy_extra5.deepcopy.nested_list_mixed:
  description: "copy.deepcopy([1,[2,3]]) == [1,[2,3]] — deep copy of list with nested sublist"
  category: deepcopy
  kind: python_call_eq
  function: deepcopy
  args: [[1, [2, 3]]]
  expected: [1, [2, 3]]
