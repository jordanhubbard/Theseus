spec: re_extra242
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra241.zspec.zsdl — covers Pattern class identity and method name/qualname checks"
  notes:
    - "This spec covers: re.fullmatch and re.finditer function identity contracts and re.fullmatch behavioral contracts."
    - "re.fullmatch.__name__ == 'fullmatch' — the function name is 9 characters; verified Python 3.14.3 macOS."
    - "re.fullmatch.__module__ == 're' — defined in the re module, length 2; verified Python 3.14.3 macOS."
    - "re.fullmatch.__qualname__ == 'fullmatch' — matches __name__ for a module-level function; verified Python 3.14.3 macOS."
    - "re.finditer.__name__ == 'finditer' — the function name is 8 characters; verified Python 3.14.3 macOS."
    - "re.finditer.__module__ == 're' — defined in the re module, length 2; verified Python 3.14.3 macOS."
    - "re.finditer.__qualname__ == 'finditer' — matches __name__ for a module-level function; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'\\d+', '123') returns a Match object — class name is 'Match'; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'\\d+', '12a') returns None — class name is 'NoneType'; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.fullmatch function identity contracts
# These verify the function's identity attributes from the re module.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra242.fullmatch.name_eq:
  description: "re.fullmatch.__name__ == 'fullmatch' — function name is 'fullmatch'; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__name__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra242.fullmatch.name_len:
  description: "len(re.fullmatch.__name__) == 9 — 'fullmatch' has 9 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__name__.__len__
  args: []
  expected: 9

invariant re_extra242.fullmatch.module_eq:
  description: "re.fullmatch.__module__ == 're' — fullmatch is defined in the 're' module; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra242.fullmatch.module_len:
  description: "len(re.fullmatch.__module__) == 2 — 're' has 2 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__module__.__len__
  args: []
  expected: 2

invariant re_extra242.fullmatch.qualname_eq:
  description: "re.fullmatch.__qualname__ == 'fullmatch' — qualname matches __name__ for a module-level function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__qualname__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra242.fullmatch.qualname_len:
  description: "len(re.fullmatch.__qualname__) == 9 — 'fullmatch' has 9 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__qualname__.__len__
  args: []
  expected: 9

invariant re_extra242.fullmatch.class_is_function:
  description: "re.fullmatch.__class__.__name__ == 'function' — fullmatch is a plain Python function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# re.finditer function identity contracts
# These verify the function's identity attributes from the re module.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra242.finditer.name_eq:
  description: "re.finditer.__name__ == 'finditer' — function name is 'finditer'; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: finditer.__name__.__eq__
  args: ["finditer"]
  expected: true

invariant re_extra242.finditer.name_len:
  description: "len(re.finditer.__name__) == 8 — 'finditer' has 8 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: finditer.__name__.__len__
  args: []
  expected: 8

invariant re_extra242.finditer.module_eq:
  description: "re.finditer.__module__ == 're' — finditer is defined in the 're' module; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: finditer.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra242.finditer.module_len:
  description: "len(re.finditer.__module__) == 2 — 're' has 2 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: finditer.__module__.__len__
  args: []
  expected: 2

invariant re_extra242.finditer.qualname_eq:
  description: "re.finditer.__qualname__ == 'finditer' — qualname matches __name__ for a module-level function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: finditer.__qualname__.__eq__
  args: ["finditer"]
  expected: true

invariant re_extra242.finditer.qualname_len:
  description: "len(re.finditer.__qualname__) == 8 — 'finditer' has 8 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: finditer.__qualname__.__len__
  args: []
  expected: 8

invariant re_extra242.finditer.class_is_function:
  description: "re.finditer.__class__.__name__ == 'function' — finditer is a plain Python function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: finditer.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# re.fullmatch behavioral contracts
# Verifying match/non-match behavior using __class__.__name__ pattern.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra242.fullmatch.match_is_match:
  description: "re.fullmatch(r'\\d+', '123').__class__.__name__ == 'Match' — fullmatch of all-digits returns a Match object; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "123"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

invariant re_extra242.fullmatch.no_match_is_none:
  description: "re.fullmatch(r'\\d+', '12a').__class__.__name__ == 'NoneType' — fullmatch of mixed string returns None; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "12a"]
  method: __class__.__name__.__eq__
  method_args: ["NoneType"]
  expected: true

invariant re_extra242.fullmatch.alpha_match_is_match:
  description: "re.fullmatch(r'[a-z]+', 'abc').__class__.__name__ == 'Match' — fullmatch of all-lowercase returns a Match; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: fullmatch
  args: ["[a-z]+", "abc"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

invariant re_extra242.fullmatch.alpha_no_match_is_none:
  description: "re.fullmatch(r'[a-z]+', 'ABC').__class__.__name__ == 'NoneType' — fullmatch of uppercase against lowercase pattern returns None; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: fullmatch
  args: ["[a-z]+", "ABC"]
  method: __class__.__name__.__eq__
  method_args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# Table: re.fullmatch and re.finditer function __name__ lengths
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra242.re_function_name_lengths:
  description: "re.fullmatch and re.finditer function __name__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: refullmatch242

  columns: [id, function, args, expected]
  rows:
    - [fullmatch_name_len, fullmatch.__name__.__len__, [], 9]
    - [finditer_name_len,  finditer.__name__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# Table: re.fullmatch and re.finditer function __qualname__ lengths
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra242.re_function_qualname_lengths:
  description: "re.fullmatch and re.finditer function __qualname__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: refinditer242

  columns: [id, function, args, expected]
  rows:
    - [fullmatch_qualname_len, fullmatch.__qualname__.__len__, [], 9]
    - [finditer_qualname_len,  finditer.__qualname__.__len__,  [], 8]
