spec: http_rust
version: ">=3.9"
backend: rust_module(http_rust)

docs: https://docs.python.org/3/library/http.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.html — Python http module documentation"
  not_derived_from:
    - "CPython source: Lib/http/__init__.py"
  notes:
    - "Clean-room Rust reimplementation of Python http module, exposed via PyO3."
    - "HTTPStatus is an IntEnum where each member represents an HTTP response code."
    - "HTTPStatus(200) looks up the member by integer value."
    - "HTTPStatus(200).value == 200 — the numeric HTTP status code."
    - "HTTPStatus(200).name == 'OK' — the constant name."
    - "HTTPStatus(200).phrase == 'OK' — human-readable phrase."
    - "HTTPStatus(404).name == 'NOT_FOUND', phrase == 'Not Found'."
    - "HTTPStatus(500).name == 'INTERNAL_SERVER_ERROR'."
    - "HTTPStatus(201).name == 'CREATED', phrase == 'Created'."
    - "HTTPStatus(301).name == 'MOVED_PERMANENTLY', phrase == 'Moved Permanently'."
    - "All test vectors verified against Python 3.14.3 http module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# HTTPStatus — value property (numeric code)
table http_rust.HTTPStatus.value:
  kind: python_call_eq
  category: HTTPStatus
  id_prefix: status_value
  function: HTTPStatus
  method: value

  columns: [id, args, expected]
  rows:
    - [ok,                    [200], 200]
    - [created,               [201], 201]
    - [moved_permanently,     [301], 301]
    - [not_found,             [404], 404]
    - [internal_server_error, [500], 500]

# HTTPStatus — name property (constant name)
table http_rust.HTTPStatus.name:
  kind: python_call_eq
  category: HTTPStatus
  id_prefix: status_name
  function: HTTPStatus
  method: name

  columns: [id, args, expected]
  rows:
    - [ok,                    [200], "OK"]
    - [created,               [201], "CREATED"]
    - [not_found,             [404], "NOT_FOUND"]
    - [internal_server_error, [500], "INTERNAL_SERVER_ERROR"]

# HTTPStatus — phrase property (human-readable description)
table http_rust.HTTPStatus.phrase:
  kind: python_call_eq
  category: HTTPStatus
  id_prefix: status_phrase
  function: HTTPStatus
  method: phrase

  columns: [id, args, expected]
  rows:
    - [ok,       [200], "OK"]
    - [created,  [201], "Created"]
    - [not_found,[404], "Not Found"]

