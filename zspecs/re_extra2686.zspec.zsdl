spec: re_extra2686
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2671.zspec.zsdl — covers __sub__/__floordiv__/__mod__ dict-presence"
  notes:
    - "Wave 626 (re_extra2686) theme: __and__, __or__, and __xor__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __and__, __or__, or __xor__ in its own __dict__."
    - "__and__ is the bitwise AND operator; regex objects are pattern-matching types, not integers or sets."
    - "__or__ is the bitwise OR operator; regex objects do not implement bitwise OR semantics."
    - "__xor__ is the bitwise XOR operator; regex objects do not implement bitwise XOR semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2686.no_and_in_re_classes:
  description: "__and__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the bitwise AND protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2686

  columns: [id, function, args, expected]
  rows:
    - ["re2686001", "re.Pattern.__dict__.__contains__", ["__and__"], false]
    - ["re2686002", "re.Match.__dict__.__contains__",   ["__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2686.no_or_in_re_classes:
  description: "__or__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the bitwise OR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2686

  columns: [id, function, args, expected]
  rows:
    - ["re2686003", "re.Pattern.__dict__.__contains__", ["__or__"], false]
    - ["re2686004", "re.Match.__dict__.__contains__",   ["__or__"], false]

# ---------------------------------------------------------------------------
# __xor__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2686.no_xor_in_re_classes:
  description: "__xor__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the bitwise XOR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2686

  columns: [id, function, args, expected]
  rows:
    - ["re2686005", "re.Pattern.__dict__.__contains__", ["__xor__"], false]
    - ["re2686006", "re.Match.__dict__.__contains__",   ["__xor__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not bitwise operator hooks
# Confirms that regex objects are pattern-matching types, not integer or set types
# ---------------------------------------------------------------------------

table re_extra2686.re_has_regex_methods_not_bitwise_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __and__/__or__/__xor__; re.Match defines group/groups/start/end but NOT __and__/__or__/__xor__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2686

  columns: [id, function, args, expected]
  rows:
    - ["re2686007", "re.Pattern.__dict__.__contains__", ["match"],   true]
    - ["re2686008", "re.Pattern.__dict__.__contains__", ["search"],  true]
    - ["re2686009", "re.Pattern.__dict__.__contains__", ["sub"],     true]
    - ["re2686010", "re.Pattern.__dict__.__contains__", ["findall"], true]
    - ["re2686011", "re.Pattern.__dict__.__contains__", ["__and__"], false]
    - ["re2686012", "re.Pattern.__dict__.__contains__", ["__or__"],  false]
    - ["re2686013", "re.Pattern.__dict__.__contains__", ["__xor__"], false]
    - ["re2686014", "re.Match.__dict__.__contains__",   ["group"],   true]
    - ["re2686015", "re.Match.__dict__.__contains__",   ["groups"],  true]
    - ["re2686016", "re.Match.__dict__.__contains__",   ["start"],   true]
    - ["re2686017", "re.Match.__dict__.__contains__",   ["end"],     true]
    - ["re2686018", "re.Match.__dict__.__contains__",   ["__and__"], false]
    - ["re2686019", "re.Match.__dict__.__contains__",   ["__or__"],  false]
    - ["re2686020", "re.Match.__dict__.__contains__",   ["__xor__"], false]
