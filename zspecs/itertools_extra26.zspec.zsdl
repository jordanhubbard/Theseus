spec: itertools_extra26
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra25.zspec.zsdl."
    - "itertools_extra25 covers: __module__ attributes for chain/islice/starmap/takewhile/dropwhile/zip_longest/product/groupby/cycle/repeat."
    - "itertools_extra24 covers: dropwhile/takewhile/filterfalse/accumulate class qualnames; pairwise qualname (Python >= 3.10)."
    - "itertools_extra23 covers: chain.from_iterable/count.__next__/count.__iter__/product.__next__ method qualnames; combinations/permutations/combinations_with_replacement class qualnames."
    - "itertools_extra22 covers: __qualname__.__eq__ for chain/islice/starmap/groupby/count/cycle/repeat/product."
    - "No prior itertools spec records __qualname__ for count/cycle/repeat/permutations/combinations/combinations_with_replacement/accumulate/compress/filterfalse/pairwise together as a cross-namespace group in the extra26 namespace."
    - "Focus: class __qualname__ for count/cycle/repeat (extra22 covers these in extra22 namespace; extra26 records them as a table plus standalones); and the full set of combination-class qualnames; plus count.__bases__[0].__name__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
    - "spec version >=3.10 required for pairwise."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — infinite iterator class qualnames
#
# itertools.count, cycle, and repeat are C-level types that produce infinite
# (or bounded-repeat) iterators. Their qualnames are simple names equal to
# their class names. extra22 records these in the extra22 namespace; this table
# records them in the extra26 namespace.
# No prior itertools spec records all three together in the extra26 namespace.
# ---------------------------------------------------------------------------

table itertools_extra26.infinite_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra26.infinite_qualnames.count,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__ == 'count'"]
    - [itertools_extra26.infinite_qualnames.cycle,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__ == 'cycle'"]
    - [itertools_extra26.infinite_qualnames.repeat,
       repeat.__qualname__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__qualname__ == 'repeat'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — combinatoric iterator class qualnames
#
# itertools.permutations, combinations, and combinations_with_replacement are
# C-level types implementing combinatorial algorithms. Each has a simple
# qualname equal to its class name. extra23 records these in the extra23
# namespace; this table records them in the extra26 namespace.
# No prior itertools spec records all three together in the extra26 namespace.
# ---------------------------------------------------------------------------

table itertools_extra26.combinatoric_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra26.combinatoric_qualnames.permutations,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__ == 'permutations'"]
    - [itertools_extra26.combinatoric_qualnames.combinations,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__ == 'combinations'"]
    - [itertools_extra26.combinatoric_qualnames.combinations_with_replacement,
       combinations_with_replacement.__qualname__.__eq__,
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — filtering and windowing iterator class qualnames
#
# itertools.accumulate, compress, filterfalse, and pairwise are C-level types.
# accumulate performs running totals; compress filters by a selector; filterfalse
# is the inverse of filter; pairwise (Python 3.10+) yields overlapping pairs.
# extra24 records accumulate/filterfalse/pairwise qualnames in the extra24
# namespace; this table groups all four in the extra26 namespace.
# No prior itertools spec records all four together in the extra26 namespace.
# ---------------------------------------------------------------------------

table itertools_extra26.filtering_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra26.filtering_qualnames.accumulate,
       accumulate.__qualname__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__ == 'accumulate'"]
    - [itertools_extra26.filtering_qualnames.compress,
       compress.__qualname__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__qualname__ == 'compress'"]
    - [itertools_extra26.filtering_qualnames.filterfalse,
       filterfalse.__qualname__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__ == 'filterfalse'"]
    - [itertools_extra26.filtering_qualnames.pairwise,
       pairwise.__qualname__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__qualname__ == 'pairwise'"]

# ---------------------------------------------------------------------------
# count.__bases__[0].__name__.__eq__ — standalone inheritance
#
# itertools.count is a C-level type that inherits directly from object. It has
# no intermediate base class, confirming it is a standalone C extension type
# rather than a subclass of any Python ABC.
# No prior itertools spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra26.count.base:
  description: "itertools.count.__bases__[0].__name__ == 'object'"
  category: inheritance
  kind: python_call_eq
  function: "count.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# count.__qualname__.__eq__ — standalone class qualname
#
# itertools.count is a C-level infinite counter type. Its qualname is 'count',
# a simple name confirming module-level (non-nested) definition.
# No prior itertools spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra26.count.qualname:
  description: "itertools.count.__qualname__ == 'count'"
  category: qualnames
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

# ---------------------------------------------------------------------------
# combinations_with_replacement.__qualname__.__eq__ — standalone class qualname
#
# itertools.combinations_with_replacement has the longest qualname among the
# itertools combinatoric types. Its qualname is 'combinations_with_replacement',
# equal to its class name, confirming it is defined at module scope.
# No prior itertools spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra26.combinations_with_replacement.qualname:
  description: "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'"
  category: qualnames
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__eq__
  args: ["combinations_with_replacement"]
  expected: true
