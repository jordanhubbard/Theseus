spec: collections_abc_extra3
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "This spec extends collections_abc.zspec.zsdl, collections_abc_extra.zspec.zsdl, and collections_abc_extra2.zspec.zsdl."
    - "collections_abc covers: __name__ for all ABCs; __module__ for Sequence/Mapping/Hashable/Iterable/Callable/Set."
    - "collections_abc_extra covers: __name__ and __module__ standalone invariants for Callable/Iterable/Iterator/Generator/Sequence/MutableSequence/Mapping/MutableMapping/Set/MutableSet; hierarchy checks for Iterator->Iterable, Generator->Iterator, MutableSequence->Sequence, MutableMapping->Mapping."
    - "collections_abc_extra2 covers: __module__ for Awaitable/Coroutine/AsyncIterable/AsyncIterator/AsyncGenerator; module table for Sequence/Mapping/MutableSequence/MutableMapping/Set/MutableSet/Iterable/Iterator/Generator/Callable; hierarchy checks for Coroutine->Awaitable, AsyncIterator->AsyncIterable, AsyncGenerator->AsyncIterator, MutableSet->Set."
    - "This spec adds: __qualname__ checks for Sequence, MutableSequence, Mapping, MutableMapping, Set, MutableSet, Iterable, Iterator, Generator, Awaitable, Coroutine, Callable, Hashable, Sized — not covered in any prior collections.abc spec."
    - "For top-level classes defined directly in a module, __qualname__ == __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for collections.abc ABCs
# None of the prior specs cover __qualname__ for any collections.abc class.
# For module-level class definitions, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table collections_abc_extra3.qualname_checks:
  kind: python_call_eq
  category: qualname
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Sequence,        Sequence.__qualname__.__eq__,        ["Sequence"],        true]
    - [MutableSequence, MutableSequence.__qualname__.__eq__, ["MutableSequence"], true]
    - [Mapping,         Mapping.__qualname__.__eq__,         ["Mapping"],         true]
    - [MutableMapping,  MutableMapping.__qualname__.__eq__,  ["MutableMapping"],  true]
    - [Set,             Set.__qualname__.__eq__,             ["Set"],             true]
    - [MutableSet,      MutableSet.__qualname__.__eq__,      ["MutableSet"],      true]
    - [Iterable,        Iterable.__qualname__.__eq__,        ["Iterable"],        true]
    - [Iterator,        Iterator.__qualname__.__eq__,        ["Iterator"],        true]
    - [Generator,       Generator.__qualname__.__eq__,       ["Generator"],       true]
    - [Awaitable,       Awaitable.__qualname__.__eq__,       ["Awaitable"],       true]
    - [Coroutine,       Coroutine.__qualname__.__eq__,       ["Coroutine"],       true]
    - [Callable,        Callable.__qualname__.__eq__,        ["Callable"],        true]
    - [Hashable,        Hashable.__qualname__.__eq__,        ["Hashable"],        true]
    - [Sized,           Sized.__qualname__.__eq__,           ["Sized"],           true]
