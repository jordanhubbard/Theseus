spec: itertools_extra2581
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2581 (_extra2581): __call__ dict-presence checks — callable functor classification."
    - "All itertools types (chain, count, cycle, repeat, accumulate, etc.) are callable as constructors via the normal type.__call__ inherited from type, but NONE define __call__ in their own __dict__."
    - "This is the canonical pattern for C extension types that only need to be instantiated, not called as functors after creation."
    - "itertools types produce iterator objects; the resulting instances are iterable (define __iter__ and __next__) but not callable."
    - "itertools.chain.from_iterable is a classmethod descriptor in chain.__dict__, not a __call__ override."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — iterator types (accumulate through islice)
#
# All itertools iterator types are C extension types callable as constructors
# (type.__call__ from the metaclass) but do not define __call__ in their own
# __dict__.  Instances produced are iterators, not callable objects.
# ---------------------------------------------------------------------------

table itertools_extra2581.call_absent_a:
  description: "itertools iterator types __call__ dict-presence (accumulate..islice) — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2581

  columns: [id, function, args, expected]
  rows:
    - ["it2581001", "itertools.accumulate.__dict__.__contains__", ["__call__"], false]
    - ["it2581002", "itertools.chain.__dict__.__contains__", ["__call__"], false]
    - ["it2581003", "itertools.combinations.__dict__.__contains__", ["__call__"], false]
    - ["it2581004", "itertools.combinations_with_replacement.__dict__.__contains__", ["__call__"], false]
    - ["it2581005", "itertools.compress.__dict__.__contains__", ["__call__"], false]
    - ["it2581006", "itertools.count.__dict__.__contains__", ["__call__"], false]
    - ["it2581007", "itertools.cycle.__dict__.__contains__", ["__call__"], false]
    - ["it2581008", "itertools.dropwhile.__dict__.__contains__", ["__call__"], false]
    - ["it2581009", "itertools.filterfalse.__dict__.__contains__", ["__call__"], false]
    - ["it2581010", "itertools.groupby.__dict__.__contains__", ["__call__"], false]
    - ["it2581011", "itertools.islice.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 2: __call__ dict-presence — iterator types (pairwise through zip_longest)
#
# Continuation of the survey across all remaining itertools types.
# No itertools type defines __call__ in its own __dict__; the pattern is
# uniform across the entire module.
# ---------------------------------------------------------------------------

