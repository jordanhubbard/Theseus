spec: struct_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - struct module CPython source
    - Python documentation for struct
  not_derived_from:
    - any third-party binary packing library
  notes:
    - covers qualname and module identity for pack, unpack, pack_into, unpack_from, iter_unpack, calcsize, and Struct class
  created_at: "2026-04-12"

table struct_extra811.qualnames_and_modules:
  description: struct module top-level function qualnames
  kind: python_call_eq
  category: identity
  id_prefix: st811xx
  columns: [id, function, args, expected]
  rows:
    - [st811xx001, struct.pack.__qualname__.__eq__, ["pack"], true]
    - [st811xx002, struct.unpack.__qualname__.__eq__, ["unpack"], true]
    - [st811xx003, struct.pack_into.__qualname__.__eq__, ["pack_into"], true]
    - [st811xx004, struct.unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [st811xx005, struct.iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
    - [st811xx006, struct.calcsize.__qualname__.__eq__, ["calcsize"], true]
    - [st811xx007, struct.pack.__module__.__eq__, ["struct"], true]
    - [st811xx008, struct.unpack.__module__.__eq__, ["struct"], true]
    - [st811xx009, struct.pack_into.__module__.__eq__, ["struct"], true]
    - [st811xx010, struct.unpack_from.__module__.__eq__, ["struct"], true]
    - [st811xx011, struct.calcsize.__module__.__eq__, ["struct"], true]
    - [st811xx012, struct.Struct.__qualname__.__eq__, ["Struct"], true]
