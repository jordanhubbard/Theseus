spec: io_extra235
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/fileio.c"
  notes:
    - "This spec covers: io.FileIO/RawIOBase/BufferedIOBase/TextIOBase/IOBase class name contracts — __name__ identity, __name__ length."
    - "io.FileIO.__name__ == 'FileIO' — class name is 'FileIO', length 6; verified Python 3.14.3 macOS."
    - "io.RawIOBase.__name__ == 'RawIOBase' — class name is 'RawIOBase', length 9; verified Python 3.14.3 macOS."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' — class name is 'BufferedIOBase', length 14; verified Python 3.14.3 macOS."
    - "io.TextIOBase.__name__ == 'TextIOBase' — class name is 'TextIOBase', length 10; verified Python 3.14.3 macOS."
    - "io.IOBase.__name__ == 'IOBase' — class name is 'IOBase', length 6; verified Python 3.14.3 macOS."
    - "io.RawIOBase.__module__ == 'io' — public module name is 'io' for RawIOBase; verified Python 3.14.3 macOS."
    - "io.IOBase.__module__ == 'io' — public module name is 'io' for IOBase; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __name__ identity contracts
# FileIO, RawIOBase, BufferedIOBase, TextIOBase, IOBase class name strings.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra235.class_names:
  description: "io class __name__ identity contracts — FileIO, RawIOBase, BufferedIOBase, TextIOBase, IOBase; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioclsname235

  columns: [id, function, args, expected]
  rows:
    - [fileio_name,        FileIO.__name__.__eq__,        ["FileIO"],        true]
    - [rawiobase_name,     RawIOBase.__name__.__eq__,     ["RawIOBase"],     true]
    - [bufferediobase_name, BufferedIOBase.__name__.__eq__, ["BufferedIOBase"], true]
    - [textiobase_name,    TextIOBase.__name__.__eq__,    ["TextIOBase"],    true]
    - [iobase_name,        IOBase.__name__.__eq__,        ["IOBase"],        true]

# ---------------------------------------------------------------------------
# io class __name__ length contracts
# FileIO len 6, RawIOBase len 9, BufferedIOBase len 14, TextIOBase len 10,
# IOBase len 6.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra235.class_name_lengths:
  description: "io class __name__ length contracts — character count of each class name string; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioclsnamelen235

  columns: [id, function, args, expected]
  rows:
    - [fileio_namelen,        FileIO.__name__.__len__,        [], 6]
    - [rawiobase_namelen,     RawIOBase.__name__.__len__,     [], 9]
    - [bufferediobase_namelen, BufferedIOBase.__name__.__len__, [], 14]
    - [textiobase_namelen,    TextIOBase.__name__.__len__,    [], 10]
    - [iobase_namelen,        IOBase.__name__.__len__,        [], 6]

# ---------------------------------------------------------------------------
# io class __module__ contracts
# RawIOBase, BufferedIOBase, TextIOBase, IOBase report module 'io'.
# FileIO reports '_io' (C extension); omitted here to avoid false contracts.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra235.RawIOBase.module_io:
  description: "io.RawIOBase.__module__ == 'io' — RawIOBase reports module as 'io' (public wrapper module); verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra235.BufferedIOBase.module_io:
  description: "io.BufferedIOBase.__module__ == 'io' — BufferedIOBase reports module as 'io' (public wrapper module); verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra235.TextIOBase.module_io:
  description: "io.TextIOBase.__module__ == 'io' — TextIOBase reports module as 'io' (public wrapper module); verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra235.IOBase.module_io:
  description: "io.IOBase.__module__ == 'io' — IOBase reports module as 'io' (public wrapper module); verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true
