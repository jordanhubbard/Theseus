spec: pathlib_extra74
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra73.zspec.zsdl — covers Path.open/__defaults__.__class__.__name__=='tuple' and __len__()==5; Path.iterdir/__defaults__.__class__.__name__=='NoneType'; Path.read_text/__defaults__.__class__.__name__=='tuple'; Path.mkdir/__defaults__.__class__.__name__=='tuple'; PurePosixPath/__class__.__name__=='type'; PurePosixPath/__module__.__eq__('pathlib'); PurePosixPath/__qualname__=='PurePosixPath'; PurePosixPath/__bases__[0].__name__=='PurePath'; PureWindowsPath/__bases__[0].__name__=='PurePath'."
    - "pathlib_extra72.zspec.zsdl — covers PurePath/__bases__[0].__name__=='object'; Path/__bases__[0].__name__=='PurePath'; PurePath/__mro__.__len__()==2; Path/__mro__.__len__()==3."
    - "pathlib_extra71.zspec.zsdl — covers co_varnames/__class__.__name__=='tuple'; co_varnames[0].__eq__('self'); co_filename/__contains__('.py'); co_flags/__class__.__name__=='int'."
  notes:
    - "This spec extends pathlib_extra73.zspec.zsdl."
    - "Theme: __kwdefaults__ for pathlib Path methods and PosixPath/WindowsPath (concrete) class identity."
    - "Path.open, Path.read_text, Path.mkdir, Path.iterdir are pure Python functions. __kwdefaults__ is None for all four — they have no keyword-only arguments with defaults. No prior pathlib spec checks __kwdefaults__ for any Path method in pathlibkw74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PosixPath is the concrete path class used on POSIX systems (Linux, macOS). It is a class object: __class__.__name__ == 'type'. No prior pathlib spec checks PosixPath.__class__.__name__ in pathlibkw74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "PosixPath.__module__ == 'pathlib' — PosixPath is defined in the pathlib module. No prior pathlib spec checks PosixPath.__module__.__eq__('pathlib') in pathlibkw74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "PosixPath.__qualname__ == 'PosixPath' — top-level class, qualname equals simple name. No prior pathlib spec checks PosixPath.__qualname__ in pathlibkw74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits directly from Path. No prior pathlib spec checks PosixPath.__bases__[0].__name__ in pathlibkw74 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.WindowsPath is the concrete path class used on Windows. It is a class object: __class__.__name__ == 'type'. WindowsPath.__module__ == 'pathlib'. WindowsPath.__qualname__ == 'WindowsPath'. WindowsPath.__bases__[0].__name__ == 'Path'. No prior pathlib spec checks WindowsPath identity in pathlibkw74 namespace. Novel anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path method __kwdefaults__: __class__.__name__ == 'NoneType'
#
# Path.open, Path.read_text, Path.mkdir, and Path.iterdir are pure Python
# functions. None of them define keyword-only arguments with defaults, so
# their __kwdefaults__ attribute is None:
#   Path.open.__kwdefaults__.__class__.__name__    == 'NoneType'
#   Path.read_text.__kwdefaults__.__class__.__name__ == 'NoneType'
#   Path.mkdir.__kwdefaults__.__class__.__name__   == 'NoneType'
#   Path.iterdir.__kwdefaults__.__class__.__name__ == 'NoneType'
#
# No prior pathlib spec checks __kwdefaults__ for any Path method in the
# pathlibkw74 namespace. Novel __kwdefaults__ anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra74.none_kwdefaults:
  description: "Path.open/read_text/mkdir/iterdir __kwdefaults__.__class__.__name__=='NoneType' — all four Path methods have no keyword-only defaults; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; no prior pathlib spec checks __kwdefaults__ for any Path method in pathlibkw74 namespace; novel __kwdefaults__ anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_kwdefaults
  id_prefix: pathlibkw74none

  columns: [id, function, args, expected]
  rows:
    - [open_kwdefaults_none,     Path.open.__kwdefaults__.__class__.__name__.__eq__,    ["NoneType"], true]
    - [read_text_kwdefaults,     Path.read_text.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [mkdir_kwdefaults_none,    Path.mkdir.__kwdefaults__.__class__.__name__.__eq__,   ["NoneType"], true]
    - [iterdir_kwdefaults_none,  Path.iterdir.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# pathlib.PosixPath class identity: __class__.__name__, __module__, __qualname__
#
# PosixPath is the concrete Path class for POSIX systems. As a class object
# its type is 'type'. It is top-level in the pathlib module:
#   PosixPath.__class__.__name__ == 'type'
#   PosixPath.__module__         == 'pathlib'
#   PosixPath.__qualname__       == 'PosixPath'
#
# No prior pathlib spec checks these identity attributes for PosixPath in
# pathlibkw74 namespace. Novel identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra74.PosixPath_identity:
  description: "PosixPath/__class__.__name__=='type'; PosixPath/__module__.__eq__('pathlib')==True; PosixPath/__qualname__.__eq__('PosixPath')==True — PosixPath is the concrete POSIX path class; it is a type object defined in pathlib; top-level so qualname equals simple name; no prior pathlib spec checks these identity attributes for PosixPath in pathlibkw74 namespace; novel identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibkw74posix

  columns: [id, function, args, expected]
  rows:
    - [posix_class_type,      PosixPath.__class__.__name__.__eq__,  ["type"],       true]
    - [posix_module_pathlib,  PosixPath.__module__.__eq__,          ["pathlib"],    true]
    - [posix_qualname,        PosixPath.__qualname__.__eq__,        ["PosixPath"],  true]

# ---------------------------------------------------------------------------
# pathlib.WindowsPath class identity: __class__.__name__, __module__, __qualname__
#
# WindowsPath is the concrete Path class for Windows systems. As a class
# object its type is 'type'. It is top-level in the pathlib module:
#   WindowsPath.__class__.__name__ == 'type'
#   WindowsPath.__module__         == 'pathlib'
#   WindowsPath.__qualname__       == 'WindowsPath'
#
# No prior pathlib spec checks these identity attributes for WindowsPath in
# pathlibkw74 namespace. Novel identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra74.WindowsPath_identity:
  description: "WindowsPath/__class__.__name__=='type'; WindowsPath/__module__.__eq__('pathlib')==True; WindowsPath/__qualname__.__eq__('WindowsPath')==True — WindowsPath is the concrete Windows path class; it is a type object defined in pathlib; top-level so qualname equals simple name; no prior pathlib spec checks these identity attributes for WindowsPath in pathlibkw74 namespace; novel identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibkw74win

  columns: [id, function, args, expected]
  rows:
    - [win_class_type,      WindowsPath.__class__.__name__.__eq__,  ["type"],         true]
    - [win_module_pathlib,  WindowsPath.__module__.__eq__,          ["pathlib"],      true]
    - [win_qualname,        WindowsPath.__qualname__.__eq__,        ["WindowsPath"],  true]

# ---------------------------------------------------------------------------
# PosixPath and WindowsPath hierarchy: __bases__[0].__name__ == 'Path'
#
# Both PosixPath and WindowsPath are concrete subclasses of Path:
#   PosixPath.__bases__[0].__name__   == 'Path'
#   WindowsPath.__bases__[0].__name__ == 'Path'
#
# Function values containing '[' must be double-quoted in table rows.
# No prior pathlib spec checks __bases__[0].__name__ for PosixPath or
# WindowsPath in pathlibkw74 namespace. Novel hierarchy anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra74.concrete_path_bases:
  description: "PosixPath/__bases__[0].__name__=='Path'; WindowsPath/__bases__[0].__name__=='Path' — both concrete path classes inherit directly from Path; __bases__[0] is Path; Path.__name__ is 'Path'; no prior pathlib spec checks __bases__[0].__name__ for PosixPath or WindowsPath in pathlibkw74 namespace; function values with '[' are double-quoted; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibkw74hier

  columns: [id, function, args, expected]
  rows:
    - [posix_bases_path,  "PosixPath.__bases__[0].__name__.__eq__",   ["Path"], true]
    - [win_bases_path,    "WindowsPath.__bases__[0].__name__.__eq__", ["Path"], true]

invariant pathlib_extra74.Path_open_kwdefaults_NoneType:
  description: "Path.open.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — Path.open is a pure Python function with no keyword-only defaults; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; no prior pathlib spec checks Path.open.__kwdefaults__.__class__.__name__ in pathlibkw74 namespace; novel __kwdefaults__ class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_kwdefaults
  kind: python_call_eq
  function: Path.open.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant pathlib_extra74.PosixPath_class_type:
  description: "PosixPath.__class__.__name__.__eq__('type') == True — PosixPath is the concrete POSIX path class; as a class object its own type is 'type'; no prior pathlib spec checks PosixPath.__class__.__name__ in pathlibkw74 namespace; novel class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra74.PosixPath_module_pathlib:
  description: "PosixPath.__module__.__eq__('pathlib') == True — PosixPath is defined in the pathlib module (Lib/pathlib/__init__.py); __module__ is 'pathlib'; no prior pathlib spec checks PosixPath.__module__.__eq__('pathlib') in pathlibkw74 namespace; novel module identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra74.WindowsPath_module_pathlib:
  description: "WindowsPath.__module__.__eq__('pathlib') == True — WindowsPath is defined in the pathlib module (Lib/pathlib/__init__.py); __module__ is 'pathlib'; no prior pathlib spec checks WindowsPath.__module__.__eq__('pathlib') in pathlibkw74 namespace; novel module identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: WindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra74.PosixPath_bases_Path:
  description: "PosixPath.__bases__[0].__name__.__eq__('Path') == True — PosixPath inherits directly from Path; __bases__[0] is Path; Path.__name__ is 'Path'; no prior pathlib spec checks PosixPath.__bases__[0].__name__ in pathlibkw74 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: "PosixPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true
