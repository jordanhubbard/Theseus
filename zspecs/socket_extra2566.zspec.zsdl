spec: socket_extra2566
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "socket.socket is a pure-Python class (defined in Lib/socket.py) that wraps the C-level _socket.socket type."
    - "socket.socket defines NONE of __getattr__, __setattr__, __delattr__, or __getattribute__ in its own __dict__."
    - "Attribute access on socket.socket instances goes through the normal Python attribute mechanism — no custom guards."
    - "socket.socket uses __slots__ = ('_io_refs', '_closed') to restrict the instance namespace to those two fields."
    - "socket.socket defines __init__, __enter__, __exit__, __repr__, __getstate__ for lifecycle management."
    - "socket.socket defines context manager support (__enter__/__exit__) so it can be used with 'with' statements."
    - "socket.socket does NOT define __eq__ or __hash__ — two socket objects are equal only if they are identical (identity semantics from object)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Core attribute access protocol — all four absent from socket.socket
# ---------------------------------------------------------------------------

table socket_extra2566.attr_access_protocol:
  description: "socket.socket defines none of __getattr__, __setattr__, __delattr__, __getattribute__ — plain attribute access"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2566

  columns: [id, function, args, expected]
  rows:
    - ["sk2566001", "socket.socket.__dict__.__contains__", ["__getattr__"],      false]
    - ["sk2566002", "socket.socket.__dict__.__contains__", ["__setattr__"],      false]
    - ["sk2566003", "socket.socket.__dict__.__contains__", ["__delattr__"],      false]
    - ["sk2566004", "socket.socket.__dict__.__contains__", ["__getattribute__"], false]

# ---------------------------------------------------------------------------
# Lifecycle protocol — __init__, __slots__, context manager support
# ---------------------------------------------------------------------------

table socket_extra2566.lifecycle_protocol:
  description: "socket.socket defines __init__, __slots__, __enter__, __exit__, __repr__, __getstate__ in its __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2566

  columns: [id, function, args, expected]
  rows:
    - ["sk2566005", "socket.socket.__dict__.__contains__", ["__init__"],     true]
    - ["sk2566006", "socket.socket.__dict__.__contains__", ["__slots__"],    true]
    - ["sk2566007", "socket.socket.__dict__.__contains__", ["__enter__"],    true]
    - ["sk2566008", "socket.socket.__dict__.__contains__", ["__exit__"],     true]
    - ["sk2566009", "socket.socket.__dict__.__contains__", ["__repr__"],     true]
    - ["sk2566010", "socket.socket.__dict__.__contains__", ["__getstate__"], true]

