spec: platform_extra2
version: ">=3.3"
backend: python_module(platform)

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/platform.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/platform.py"
    - "platform.zspec.zsdl — base coverage"
    - "platform_extra.zspec.zsdl — first extension coverage"
  notes:
    - "Complements platform.zspec.zsdl and platform_extra.zspec.zsdl."
    - "Checks __name__ of functions not yet covered: system, node, machine, processor, python_version, python_implementation."
    - "platform.python_version() always returns a str of the form 'major.minor.micro'."
    - "platform.system() always returns a str (e.g. 'Darwin', 'Linux', 'Windows', '')."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table platform_extra2.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, description, function, args, expected]
  rows:
    - [system,                 "system.__name__ == 'system'",                                 system.__name__.__eq__,                 ["system"],                 true]
    - [node,                   "node.__name__ == 'node'",                                     node.__name__.__eq__,                   ["node"],                   true]
    - [release,                "release.__name__ == 'release'",                               release.__name__.__eq__,                ["release"],                true]
    - [version,                "version.__name__ == 'version'",                               version.__name__.__eq__,                ["version"],                true]
    - [machine,                "machine.__name__ == 'machine'",                               machine.__name__.__eq__,                ["machine"],                true]
    - [processor,              "processor.__name__ == 'processor'",                           processor.__name__.__eq__,              ["processor"],              true]
    - [python_version,         "python_version.__name__ == 'python_version'",                 python_version.__name__.__eq__,         ["python_version"],         true]
    - [python_implementation,  "python_implementation.__name__ == 'python_implementation'",   python_implementation.__name__.__eq__,  ["python_implementation"],  true]

# ---------------------------------------------------------------------------
# Return-type checks — python_version() and system() return str
# ---------------------------------------------------------------------------

invariant platform_extra2.python_version.return_is_str:
  description: "python_version().__class__.__name__ == 'str' — python_version() always returns a str"
  category: return_types
  kind: python_call_eq
  function: python_version().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra2.system.return_is_str:
  description: "system().__class__.__name__ == 'str' — system() always returns a str"
  category: return_types
  kind: python_call_eq
  function: system().__class__.__name__.__eq__
  args: ["str"]
  expected: true
