spec: platform_extra2
version: ">=3.9"
backend: python_module(platform)

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/platform.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/platform.py"
  notes:
    - "Extends platform.zspec.zsdl and platform_extra.zspec.zsdl."
    - "platform.zspec.zsdl covers __name__ for: system, machine, processor, architecture, node, uname, python_version, python_implementation, python_version_tuple; return types and values."
    - "platform_extra.zspec.zsdl covers __name__ for: release, version, python_build; return types for system/machine/processor/release/version/python_implementation; uname_result type checks."
    - "This spec focuses on __module__ checks: every callable in the platform module has __module__ == 'platform'."
    - "platform.system.__module__ == 'platform' — system is defined in the platform module."
    - "platform.node.__module__ == 'platform' — node is defined in the platform module."
    - "platform.release.__module__ == 'platform' — release is defined in the platform module."
    - "platform.version.__module__ == 'platform' — version is defined in the platform module."
    - "platform.machine.__module__ == 'platform' — machine is defined in the platform module."
    - "platform.processor.__module__ == 'platform' — processor is defined in the platform module."
    - "platform.python_version.__module__ == 'platform' — python_version is defined in the platform module."
    - "platform.python_implementation.__module__ == 'platform' — python_implementation is defined in the platform module."
    - "platform.python_compiler.__module__ == 'platform' — python_compiler is defined in the platform module."
    - "platform.architecture.__module__ == 'platform' — architecture is defined in the platform module."
    - "platform.uname.__module__ == 'platform' — uname is defined in the platform module."
    - "Individual invariants for __name__ of system, node, release, machine as cross-reference spot-checks."
    - "platform.python_compiler() returns a non-empty str describing the compiler used to build CPython."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — all platform callables belong to the platform module
# ---------------------------------------------------------------------------

table platform_extra2.function_modules:
  description: "platform callables all have __module__ == 'platform'"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [system,                system.__module__.__eq__,                ["platform"], true]
    - [node,                  node.__module__.__eq__,                  ["platform"], true]
    - [release,               release.__module__.__eq__,               ["platform"], true]
    - [version,               version.__module__.__eq__,               ["platform"], true]
    - [machine,               machine.__module__.__eq__,               ["platform"], true]
    - [processor,             processor.__module__.__eq__,             ["platform"], true]
    - [python_version,        python_version.__module__.__eq__,        ["platform"], true]
    - [python_implementation, python_implementation.__module__.__eq__, ["platform"], true]
    - [python_compiler,       python_compiler.__module__.__eq__,       ["platform"], true]
    - [architecture,          architecture.__module__.__eq__,          ["platform"], true]
    - [uname,                 uname.__module__.__eq__,                 ["platform"], true]

# ---------------------------------------------------------------------------
# __name__ spot-checks — individual invariants for system, node, release, machine
# ---------------------------------------------------------------------------

invariant platform_extra2.system_name:
  description: "platform.system.__name__ == 'system'"
  category: function_names
  kind: python_call_eq
  function: system.__name__.__eq__
  args: ["system"]
  expected: true

invariant platform_extra2.node_name:
  description: "platform.node.__name__ == 'node'"
  category: function_names
  kind: python_call_eq
  function: node.__name__.__eq__
  args: ["node"]
  expected: true

invariant platform_extra2.release_name:
  description: "platform.release.__name__ == 'release'"
  category: function_names
  kind: python_call_eq
  function: release.__name__.__eq__
  args: ["release"]
  expected: true

invariant platform_extra2.machine_name:
  description: "platform.machine.__name__ == 'machine'"
  category: function_names
  kind: python_call_eq
  function: machine.__name__.__eq__
  args: ["machine"]
  expected: true

# ---------------------------------------------------------------------------
# python_compiler() — returns a str describing the compiler used to build Python
# ---------------------------------------------------------------------------

invariant platform_extra2.python_compiler_name:
  description: "platform.python_compiler.__name__ == 'python_compiler'"
  category: function_names
  kind: python_call_eq
  function: python_compiler.__name__.__eq__
  args: ["python_compiler"]
  expected: true

invariant platform_extra2.python_compiler_is_str:
  description: "platform.python_compiler().__class__.__name__ == 'str'"
  category: python_info
  kind: python_call_eq
  function: python_compiler().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra2.python_compiler_nonempty:
  description: "len(platform.python_compiler()) > 0 — compiler string is non-empty"
  category: python_info
  kind: python_call_eq
  function: python_compiler().__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true
