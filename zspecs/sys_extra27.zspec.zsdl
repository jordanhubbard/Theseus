spec: sys_extra27
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra7.zspec.zsdl — covers __qualname__ for exc_info/getsizeof/getrecursionlimit/setrecursionlimit/intern in a table; NOT their __module__ attributes."
    - "sys_extra23.zspec.zsdl — covers stdout.__class__.__qualname__=='TextIOWrapper'; NOT stdin/stderr class names nor __module__ of functions."
    - "sys_extra26.zspec.zsdl — covers __class__.__name__/__qualname__ for version_info fields and sys.implementation; NOT stream class names or function __module__."
  notes:
    - "This spec extends sys.zspec.zsdl through sys_extra26.zspec.zsdl."
    - "Focus: __class__.__name__ for sys.stdin/sys.stdout/sys.stderr (all 'TextIOWrapper'); __module__ attributes for sys.exc_info, sys.getsizeof, sys.getrecursionlimit, sys.setrecursionlimit, sys.intern; and the default recursion limit value via sys.getrecursionlimit() == 1000."
    - "sys.stdin.__class__.__name__ == 'TextIOWrapper' — standard input stream type name; not covered in any prior sys spec."
    - "sys.stdout.__class__.__name__ == 'TextIOWrapper' — standard output stream type name; sys_extra23 covers __qualname__ for stdout but not stdin or stderr class __name__."
    - "sys.stderr.__class__.__name__ == 'TextIOWrapper' — standard error stream type name; not covered in any prior sys spec."
    - "sys.exc_info.__module__ == 'sys' — built-in function is attributed to the sys module; sys_extra7 covers __qualname__ but NOT __module__ for exc_info."
    - "sys.getsizeof.__module__ == 'sys' — built-in function is attributed to the sys module; sys_extra7 covers __qualname__ but NOT __module__."
    - "sys.getrecursionlimit.__module__ == 'sys' — built-in function; sys_extra7 covers __qualname__ but NOT __module__."
    - "sys.setrecursionlimit.__module__ == 'sys' — built-in function; sys_extra7 covers __qualname__ but NOT __module__."
    - "sys.intern.__module__ == 'sys' — built-in function; sys_extra7 covers __qualname__ but NOT __module__."
    - "sys.getrecursionlimit() == 1000 — the default Python recursion limit is 1000; sys_extra10 checks positivity (> 0) but no prior sys spec checks the exact value."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.stdin / sys.stdout / sys.stderr — __class__.__name__
#
# sys_extra23 covers sys.stdout.__class__.__qualname__ == 'TextIOWrapper'.
# No prior sys spec covers __class__.__name__ for stdin or stderr, and none
# covers __class__.__name__ (as opposed to __qualname__) for stdout.
# All three standard streams are io.TextIOWrapper instances, so their
# __class__.__name__ is 'TextIOWrapper'.
# ---------------------------------------------------------------------------

table sys_extra27.stream_class_names:
  description: "__class__.__name__ for sys.stdin, sys.stdout, and sys.stderr is 'TextIOWrapper'"
  kind: python_call_eq
  category: type_attrs
  id_prefix: stream27

  columns: [id, function, args, expected]
  rows:
    - [stdin_name,  stdin.__class__.__name__.__eq__,  ["TextIOWrapper"], true]
    - [stdout_name, stdout.__class__.__name__.__eq__, ["TextIOWrapper"], true]
    - [stderr_name, stderr.__class__.__name__.__eq__, ["TextIOWrapper"], true]

# ---------------------------------------------------------------------------
# sys built-in function __module__ attributes
#
# sys_extra7 covers __qualname__ for exc_info, getsizeof, getrecursionlimit,
# setrecursionlimit, and intern in a table. No prior sys spec covers their
# __module__ attribute. These are all built-in functions attributed to the
# 'sys' module, so their __module__ is 'sys'.
# ---------------------------------------------------------------------------

table sys_extra27.builtin_function_modules:
  description: "__module__ for sys built-in functions is 'sys'"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnmod27

  columns: [id, function, args, expected]
  rows:
    - [exc_info,          exc_info.__module__.__eq__,          ["sys"], true]
    - [getsizeof,         getsizeof.__module__.__eq__,         ["sys"], true]
    - [getrecursionlimit, getrecursionlimit.__module__.__eq__,  ["sys"], true]
    - [setrecursionlimit, setrecursionlimit.__module__.__eq__, ["sys"], true]
    - [intern,            intern.__module__.__eq__,            ["sys"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — stream class names
# ---------------------------------------------------------------------------

invariant sys_extra27.stdin.class_name:
  description: "sys.stdin.__class__.__name__ == 'TextIOWrapper' — standard input is a TextIOWrapper instance"
  category: type_attrs
  kind: python_call_eq
  function: stdin.__class__.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant sys_extra27.stdout.class_name:
  description: "sys.stdout.__class__.__name__ == 'TextIOWrapper' — standard output is a TextIOWrapper instance"
  category: type_attrs
  kind: python_call_eq
  function: stdout.__class__.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant sys_extra27.stderr.class_name:
  description: "sys.stderr.__class__.__name__ == 'TextIOWrapper' — standard error is a TextIOWrapper instance"
  category: type_attrs
  kind: python_call_eq
  function: stderr.__class__.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — built-in function __module__
# ---------------------------------------------------------------------------

invariant sys_extra27.exc_info.module:
  description: "sys.exc_info.__module__ == 'sys' — built-in function attributed to the sys module"
  category: function_attrs
  kind: python_call_eq
  function: exc_info.__module__.__eq__
  args: ["sys"]
  expected: true

invariant sys_extra27.getsizeof.module:
  description: "sys.getsizeof.__module__ == 'sys' — built-in function attributed to the sys module"
  category: function_attrs
  kind: python_call_eq
  function: getsizeof.__module__.__eq__
  args: ["sys"]
  expected: true

invariant sys_extra27.getrecursionlimit.module:
  description: "sys.getrecursionlimit.__module__ == 'sys' — built-in function attributed to the sys module"
  category: function_attrs
  kind: python_call_eq
  function: getrecursionlimit.__module__.__eq__
  args: ["sys"]
  expected: true

invariant sys_extra27.intern.module:
  description: "sys.intern.__module__ == 'sys' — built-in function attributed to the sys module"
  category: function_attrs
  kind: python_call_eq
  function: intern.__module__.__eq__
  args: ["sys"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariant — sys.getrecursionlimit() exact default value
#
# sys_extra10 covers getrecursionlimit() > 0 (positivity only). No prior sys
# spec checks the exact default value. The default is 1000 on all CPython
# builds. Uses method/method_args to apply __eq__ to the return value.
# ---------------------------------------------------------------------------

invariant sys_extra27.getrecursionlimit.default_1000:
  description: "sys.getrecursionlimit() == 1000 — the default Python recursion limit is 1000"
  category: runtime_values
  kind: python_call_eq
  function: getrecursionlimit
  args: []
  method: __eq__
  method_args: [1000]
  expected: true
