spec: hashlib_extra386
version: ">=3.11"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.file_digest.__name__ == 'file_digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new('invalid_algorithm_xyz') raises ValueError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.file_digest was added in Python 3.11. It is a pure-Python function in Lib/hashlib.py that reads a file-like object and returns the digest. Its __class__.__name__ is 'function'."
    - "Note: hashlib.new raises ValueError (not KeyError) for unknown algorithm names. The error message is 'unsupported hash type <name>'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.file_digest — function identity (Python 3.11+)
# hashlib.new error behavior for invalid algorithm names
#
# Wave 386 theme: hashlib.file_digest identity and hashlib.new error behavior.
#
# hashlib.file_digest was added in Python 3.11 (PEP 594 / bpo-47009). It
# accepts a file-like object and a hash algorithm name (or callable), reads
# the file in chunks, and returns the completed hash digest. It is implemented
# as a pure-Python function in Lib/hashlib.py, so its __class__.__name__ is
# 'function' and its __module__ is 'hashlib'.
#
# hashlib.new raises ValueError for unrecognized algorithm names. The lookup
# is performed via the _hashlib OpenSSL extension; if neither OpenSSL nor a
# built-in fallback recognizes the name, ValueError is raised with the message
# "unsupported hash type <name>".
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra386.file_digest_identity:
  description: "hashlib.file_digest function identity — __name__ is 'file_digest', __module__ is 'hashlib', __class__.__name__ is 'function'; added in Python 3.11; pure-Python function in Lib/hashlib.py; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibfd386

  columns: [id, function, args, expected]
  rows:
    - [fd_name,       file_digest.__name__.__eq__,              ["file_digest"], true]
    - [fd_module,     file_digest.__module__.__eq__,            ["hashlib"],     true]
    - [fd_class_name, file_digest.__class__.__name__.__eq__,    ["function"],    true]

# ---------------------------------------------------------------------------
# hashlib.new raises ValueError for invalid algorithm names
#
# hashlib.new is a Python dispatcher function that calls OpenSSL (via _hashlib)
# or a built-in fallback to find the requested hash algorithm. When the
# algorithm name is not recognized by any provider, it raises ValueError with
# the message "unsupported hash type <name>".
#
# This is distinct from KeyError — hashlib.new uses ValueError to signal
# an unknown algorithm, consistent with other Python stdlib pattern where
# ValueError signals a value is invalid for the expected type.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra386.new_invalid_algorithm_raises:
  description: "hashlib.new('invalid_algorithm_xyz') raises ValueError — hashlib.new raises ValueError (not KeyError) for unrecognized algorithm names; dispatches through OpenSSL/_hashlib; 'unsupported hash type' message; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: error_behavior
  kind: python_call_raises
  function: new
  args: ["invalid_algorithm_xyz"]
  raises: ValueError
