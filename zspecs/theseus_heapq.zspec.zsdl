spec: theseus_heapq
version: ">=3.9"
backend: python_cleanroom(theseus_heapq)
blocks: heapq

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html"
  notes:
    - "Clean-room min-heap. Do NOT import heapq."
    - "Implement binary min-heap with heappush/heappop/heapify."
    - "heapify([3,1,4,1,5]) transforms list in-place to a valid heap."
    - "heappop returns smallest element; heap property maintained after push/pop."
    - "heapq_min_of_three(): heappop after pushing 3,1,2 returns 1."
    - "heapq_heapify_min(): min of heapified [5,3,1,4,2] == 1."
    - "heapq_nsmallest(): nsmallest(3, [5,3,1,4,2]) == [1,2,3]."
    - "Export: heappush(heap, item), heappop(heap) -> item, heapify(x), nsmallest(n, iterable)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_heapq.min_of_three:
  description: "heappop after heappush(3,1,2) returns 1"
  category: push_pop
  kind: python_call_eq
  function: heapq_min_of_three
  args: []
  expected: 1

invariant theseus_heapq.heapify_min:
  description: "min element of heapify([5,3,1,4,2]) == 1"
  category: heapify
  kind: python_call_eq
  function: heapq_heapify_min
  args: []
  expected: 1

invariant theseus_heapq.nsmallest:
  description: "nsmallest(3, [5,3,1,4,2]) == [1,2,3]"
  category: nsmallest
  kind: python_call_eq
  function: heapq_nsmallest
  args: []
  expected: [1, 2, 3]
