spec: struct_extra1366
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks."
    - "struct.Struct is a C extension type; __flags__, __basicsize__, and __itemsize__ are C-level integer attributes present on every type object."
    - "struct.Struct.__flags__.__class__.__name__ == 'int' — __flags__ is always an int on all CPython type objects."
    - "struct.Struct.__basicsize__.__class__.__name__ == 'int' — __basicsize__ reports the C struct size in bytes; always an int."
    - "struct.Struct.__itemsize__.__class__.__name__ == 'int' — __itemsize__ is 0 for Struct (fixed-size type); the value is int regardless."
    - "struct.error is a subclass of Exception (a Python class); its __flags__, __basicsize__, and __itemsize__ are also int."
    - "Exact integer values are not checked; they are platform-specific and may vary across CPython builds."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra1366.struct_class_flags_basicsize_itemsize:
  description: "struct.Struct C extension class __flags__, __basicsize__, __itemsize__ type-name checks; all three C-type attributes must be int"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: st1366sf
  columns: [id, function, args, expected]
  rows:
    - [st1366sf001, struct.Struct.__flags__.__class__.__name__.__eq__,     ["int"], true]
    - [st1366sf002, struct.Struct.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [st1366sf003, struct.Struct.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
    - [st1366sf004, struct.Struct.__flags__.__class__.__name__.__eq__,     ["int"], true]
    - [st1366sf005, struct.Struct.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [st1366sf006, struct.Struct.__itemsize__.__class__.__name__.__eq__,  ["int"], true]

table struct_extra1366.error_class_flags_basicsize_itemsize:
  description: "struct.error exception class __flags__, __basicsize__, __itemsize__ type-name checks; struct.error is a Python Exception subclass and still exposes int C-type attributes on its type object"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: st1366ef
  columns: [id, function, args, expected]
  rows:
    - [st1366ef001, struct.error.__flags__.__class__.__name__.__eq__,     ["int"], true]
    - [st1366ef002, struct.error.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [st1366ef003, struct.error.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
    - [st1366ef004, struct.Struct.__flags__.__class__.__name__.__eq__,    ["int"], true]
    - [st1366ef005, struct.Struct.__basicsize__.__class__.__name__.__eq__,["int"], true]
    - [st1366ef006, struct.Struct.__itemsize__.__class__.__name__.__eq__, ["int"], true]

table struct_extra1366.struct_error_class_name_type_checks:
  description: "struct.Struct and struct.error __name__ and __qualname__ type-name checks; verifies the class name attributes are str and flags are int"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: st1366nc
  columns: [id, function, args, expected]
  rows:
    - [st1366nc001, struct.Struct.__name__.__class__.__name__.__eq__,      ["str"],  true]
    - [st1366nc002, struct.error.__name__.__class__.__name__.__eq__,       ["str"],  true]
    - [st1366nc003, struct.Struct.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [st1366nc004, struct.error.__flags__.__class__.__name__.__eq__,      ["int"],  true]
    - [st1366nc005, struct.Struct.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [st1366nc006, struct.error.__basicsize__.__class__.__name__.__eq__,  ["int"],  true]
