    - [it1081cm004, itertools.combinations.__module__.__eq__,                ["itertools"],                    true]
    - [it1081cm005, itertools.combinations.__qualname__.__eq__,              ["combinations"],                 true]
    - [it1081cm006, itertools.permutations.__module__.__eq__,                ["itertools"],                    true]
