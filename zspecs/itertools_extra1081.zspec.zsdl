    - [it1081sf002, itertools.islice.__qualname__.__eq__,                    ["islice"],                       true]
    - [it1081sf003, itertools.islice.__new__.__qualname__.__eq__,            ["islice.__new__"],               true]
    - [it1081sf004, itertools.compress.__module__.__eq__,                    ["itertools"],                    true]
    - [it1081sf005, itertools.compress.__qualname__.__eq__,                  ["compress"],                     true]
    - [it1081sf006, itertools.compress.__new__.__qualname__.__eq__,          ["compress.__new__"],             true]
    - [it1081sf007, itertools.compress.__doc__.__class__.__name__.__eq__,    ["str"],                          true]

table itertools_extra1081.combinatoric_module_identity:
