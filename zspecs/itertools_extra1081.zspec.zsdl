spec: itertools_extra1081
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks itertools class __module__ identity (cycle, islice, product, compress, count), __new__ qualnames, and iterator __doc__ class names — not covered in _extra976/_extra991"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1081.infinite_iterator_module_identity:
  description: "itertools infinite iterator classes __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: it1081im
  columns: [id, function, args, expected]
  rows:
    - [it1081im001, itertools.count.__module__.__eq__,                       ["itertools"],                    true]
    - [it1081im002, itertools.cycle.__module__.__eq__,                       ["itertools"],                    true]
    - [it1081im003, itertools.repeat.__module__.__eq__,                      ["itertools"],                    true]
    - [it1081im004, itertools.count.__new__.__qualname__.__eq__,             ["count.__new__"],                true]
    - [it1081im005, itertools.cycle.__new__.__qualname__.__eq__,             ["cycle.__new__"],                true]
    - [it1081im006, itertools.repeat.__new__.__qualname__.__eq__,            ["repeat.__new__"],               true]
    - [it1081im007, itertools.count.__doc__.__class__.__name__.__eq__,       ["str"],                          true]

table itertools_extra1081.slicing_filtering_module_identity:
