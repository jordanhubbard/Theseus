spec: re_extra1471
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c, Lib/re/__init__.py, Lib/re/_compiler.py"
  notes:
    - "Wave 545 (_extra1471): focuses on __len__ and __getitem__ method presence and type checks for re module classes."
    - "re.Match defines __getitem__ in its own __dict__ as a wrapper_descriptor; it supports m[group] syntax for group access."
    - "re.Match.__getitem__.__class__.__name__ == 'wrapper_descriptor' (C-level slot implementation in _sre.c)."
    - "re.Match does NOT define __len__ in its own __dict__; match objects are not sized containers."
    - "re.Pattern does NOT define __len__ or __getitem__ in its own __dict__; patterns are not sequences."
    - "re.error does NOT define __len__ or __getitem__ in its own __dict__; it is an exception class."
    - "Only re.Match defines __getitem__; no re class defines __len__ in its own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra1471.match_getitem_class_name:
  description: "re.Match __getitem__ __class__.__name__ identity — re.Match defines __getitem__ in its own __dict__ as a C-level wrapper_descriptor supporting m[group] syntax; __class__.__name__ == 'wrapper_descriptor'; verified with Python 3.14.4"
  kind: python_call_eq
  category: getitem_class_name
  id_prefix: re1471mg
  columns: [id, function, args, expected]
  rows:
    - [re1471mg001, re.Match.__getitem__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [re1471mg002, re.Match.__getitem__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [re1471mg003, re.Match.__getitem__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [re1471mg004, re.Match.__getitem__.__class__.__name__.__eq__, ["method_descriptor"],  false]
    - [re1471mg005, re.Match.__getitem__.__class__.__name__.__eq__, ["function"],            false]
    - [re1471mg006, re.Match.__getitem__.__class__.__name__.__eq__, ["builtin_function_or_method"], false]

table re_extra1471.match_dict_membership:
  description: "re.Match __dict__ membership for __getitem__ and __len__ — re.Match defines __getitem__ in its own __dict__ (True) but does not define __len__ (False); match objects support group indexing but have no length; verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re1471md
  columns: [id, function, args, expected]
  rows:
    - [re1471md001, re.Match.__dict__.__contains__, ["__getitem__"], true]
    - [re1471md002, re.Match.__dict__.__contains__, ["__len__"],     false]
    - [re1471md003, re.Match.__dict__.__contains__, ["__getitem__"], true]
    - [re1471md004, re.Match.__dict__.__contains__, ["__len__"],     false]
    - [re1471md005, re.Match.__dict__.__contains__, ["__getitem__"], true]
    - [re1471md006, re.Match.__dict__.__contains__, ["__len__"],     false]

table re_extra1471.pattern_error_not_in_dict:
  description: "re.Pattern and re.error __dict__ membership for __len__ and __getitem__ — Pattern objects are not sequences and error is an exception class; neither defines __len__ or __getitem__ in its own __dict__; all return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re1471pe
  columns: [id, function, args, expected]
  rows:
    - [re1471pe001, re.Pattern.__dict__.__contains__, ["__len__"],     false]
    - [re1471pe002, re.Pattern.__dict__.__contains__, ["__getitem__"], false]
    - [re1471pe003, re.error.__dict__.__contains__,   ["__len__"],     false]
    - [re1471pe004, re.error.__dict__.__contains__,   ["__getitem__"], false]
    - [re1471pe005, re.Pattern.__dict__.__contains__, ["__len__"],     false]
    - [re1471pe006, re.Pattern.__dict__.__contains__, ["__getitem__"], false]
