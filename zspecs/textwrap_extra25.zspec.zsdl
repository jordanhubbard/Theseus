spec: textwrap_extra25
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra24.zspec.zsdl."
    - "textwrap_extra14 covers: TextWrapper.__qualname__ == 'TextWrapper' standalone invariant."
    - "textwrap_extra17 covers: wrap/fill/dedent/indent/shorten __qualname__ standalone invariants and table."
    - "textwrap_extra22 covers: wrap/fill/dedent/indent/shorten __qualname__ (extra22 anchor); TextWrapper.wrap/fill/__qualname__; TextWrapper.__qualname__."
    - "textwrap_extra23 covers: TextWrapper._wrap_chunks/_split/_split_chunks/__repr__/__init__ __qualname__."
    - "textwrap_extra24 covers: TextWrapper.__module__; TextWrapper.__bases__[0].__name__; wrap/fill/dedent/indent/shorten __module__; TextWrapper._handle_long_word/__qualname__; TextWrapper._munge_whitespace/__qualname__."
    - "No prior spec covers TextWrapper.__init__.__qualname__ as a standalone invariant."
    - "No prior spec covers TextWrapper().__class__.__name__ as a standalone invariant."
    - "No prior spec covers TextWrapper().width, TextWrapper().break_long_words, TextWrapper().break_on_hyphens, TextWrapper().expand_tabs, TextWrapper().tabsize, or TextWrapper().max_lines as standalone invariants."
    - "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — TextWrapper defines its own __init__. Verified at runtime."
    - "textwrap.TextWrapper().__class__.__name__ == 'TextWrapper' — a fresh instance has class name TextWrapper. Verified at runtime."
    - "textwrap.TextWrapper().width == 70 — the default line-wrapping width. Verified at runtime."
    - "textwrap.TextWrapper().break_long_words == True — long words are broken by default. Verified at runtime."
    - "textwrap.TextWrapper().break_on_hyphens == True — breaks on hyphens by default. Verified at runtime."
    - "textwrap.TextWrapper().expand_tabs == True — tab expansion is enabled by default. Verified at runtime."
    - "textwrap.TextWrapper().tabsize == 8 — the default tab size in spaces. Verified at runtime."
    - "textwrap.TextWrapper().max_lines == None — no maximum line count by default. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.__init__ — __qualname__
#
# textwrap_extra23 covers TextWrapper.__init__.__qualname__ as a table entry
# but no prior spec captures it as a standalone invariant. TextWrapper defines
# its own __init__, so __qualname__ == 'TextWrapper.__init__'.
# Verified at runtime: 'TextWrapper.__init__'.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.init_qualname:
  description: "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — TextWrapper defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.__init__.__qualname__.__eq__
  args: ["TextWrapper.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper().__class__.__name__
#
# No prior spec verifies the __class__.__name__ of a fresh TextWrapper instance
# as a standalone invariant. A default-constructed TextWrapper instance must
# report its class as 'TextWrapper'.
# Verified at runtime: 'TextWrapper'.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.instance_class_name:
  description: "textwrap.TextWrapper().__class__.__name__ == 'TextWrapper' — a default-constructed instance reports class name 'TextWrapper'"
  category: instance_identity
  kind: python_call_eq
  function: TextWrapper.__class__.__name__.__eq__
  args: ["TextWrapper"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper().width — default value
#
# No prior spec verifies the default value of the width attribute on a fresh
# TextWrapper instance. The documented default is 70. Verified at runtime: 70.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.default_width:
  description: "textwrap.TextWrapper().width == 70 — the default line-wrapping width"
  category: default_values
  kind: python_call_eq
  function: TextWrapper.width.__eq__
  args: [70]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper().break_long_words — default value
#
# No prior spec verifies the default value of break_long_words as a standalone
# invariant. The documented default is True (words longer than width are
# broken). Verified at runtime: True.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.default_break_long_words:
  description: "textwrap.TextWrapper().break_long_words == True — long words are broken across lines by default"
  category: default_values
  kind: python_call_eq
  function: TextWrapper.break_long_words.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper().break_on_hyphens — default value
#
# No prior spec verifies the default value of break_on_hyphens as a standalone
# invariant. The documented default is True (breaks on whitespace around
# hyphens in compound words). Verified at runtime: True.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.default_break_on_hyphens:
  description: "textwrap.TextWrapper().break_on_hyphens == True — line breaks on hyphens in compound words by default"
  category: default_values
  kind: python_call_eq
  function: TextWrapper.break_on_hyphens.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper().expand_tabs — default value
#
# No prior spec verifies the default value of expand_tabs as a standalone
# invariant. The documented default is True (tabs in input text are expanded
# to spaces). Verified at runtime: True.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.default_expand_tabs:
  description: "textwrap.TextWrapper().expand_tabs == True — tab characters in input are expanded by default"
  category: default_values
  kind: python_call_eq
  function: TextWrapper.expand_tabs.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper().tabsize — default value
#
# No prior spec verifies the default value of tabsize as a standalone invariant.
# The documented default is 8 (tabs expand to multiples of 8 spaces).
# Verified at runtime: 8.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.default_tabsize:
  description: "textwrap.TextWrapper().tabsize == 8 — the default tab expansion size in spaces"
  category: default_values
  kind: python_call_eq
  function: TextWrapper.tabsize.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper().max_lines — default value
#
# No prior spec verifies the default value of max_lines as a standalone
# invariant. The documented default is None (no limit on output line count).
# Verified at runtime: None.
# ---------------------------------------------------------------------------

invariant textwrap_extra25.TextWrapper.default_max_lines:
  description: "textwrap.TextWrapper().max_lines is None — no maximum output line count by default"
  category: default_values
  kind: python_call_eq
  function: TextWrapper.max_lines.__eq__
  args: [~]
  expected: true

# ---------------------------------------------------------------------------
# Table: TextWrapper default instance attribute values
#
# No prior spec groups width, break_long_words, break_on_hyphens, expand_tabs,
# tabsize, and max_lines default values into a single table.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra25.default_instance_attrs:
  description: "textwrap.TextWrapper default instance attribute values — width, break_long_words, break_on_hyphens, expand_tabs, tabsize, max_lines"
  kind: python_call_eq
  category: default_values
  columns: [id, function, args, expected, description]
  rows:
    - [width,
       TextWrapper.width.__eq__,
       [70],
       true,
       "TextWrapper().width == 70"]
    - [break_long_words,
       TextWrapper.break_long_words.__eq__,
       [true],
       true,
       "TextWrapper().break_long_words == True"]
    - [break_on_hyphens,
       TextWrapper.break_on_hyphens.__eq__,
       [true],
       true,
       "TextWrapper().break_on_hyphens == True"]
    - [expand_tabs,
       TextWrapper.expand_tabs.__eq__,
       [true],
       true,
       "TextWrapper().expand_tabs == True"]
    - [tabsize,
       TextWrapper.tabsize.__eq__,
       [8],
       true,
       "TextWrapper().tabsize == 8"]
    - [max_lines,
       TextWrapper.max_lines.__eq__,
       [~],
       true,
       "TextWrapper().max_lines is None"]
