spec: socket_extra249
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
    - "socket_extra248.zspec.zsdl — covers socket error class identity (timeout/error/gaierror) / AF_UNIX and SHUT_RD/SHUT_WR/SHUT_RDWR constants / SOL_SOCKET and SOMAXCONN constants (table + invariants)."
  notes:
    - "Wave 295 theme: socket module convenience functions identity — __name__ and __module__ for all major functions."
    - "socket.gethostname.__name__ == 'gethostname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__name__ == 'gethostbyname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__name__ == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__name__ == 'create_connection'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socketpair.__name__ == 'socketpair'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socketpair.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Socket module functions fall into two groups by __module__: (1) C builtins from Modules/socketmodule.c with __module__=='_socket': gethostname, gethostbyname, setdefaulttimeout, getdefaulttimeout; (2) pure Python functions from Lib/socket.py with __module__=='socket': getfqdn, getaddrinfo, create_connection, socketpair."
    - "Note: socket.getaddrinfo has __module__=='socket' because on CPython it is defined as a Python wrapper in Lib/socket.py (it wraps _socket.getaddrinfo with additional processing). On some builds it may be a C builtin; on macOS/Python 3.14.3 it is the Python wrapper."
    - "Note: socket.getfqdn is a pure Python helper defined in Lib/socket.py that resolves the fully-qualified domain name for a host by calling gethostname() and gethostbyaddr(). It has no C counterpart."
    - "Note: socket.create_connection is a pure Python convenience function in Lib/socket.py that handles connecting to a (host, port) pair, with optional timeout and source_address, abstracting over getaddrinfo and socket() construction."
    - "Note: socket.socketpair is defined in Lib/socket.py as a Python wrapper on macOS/BSD (wrapping os.socketpair or _socket.socketpair). Its __module__=='socket'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket C-builtin function identity: gethostname, gethostbyname,
# setdefaulttimeout, getdefaulttimeout
#
# Wave 295 theme: socket module C-builtin functions (__module__=='_socket').
#
# gethostname, gethostbyname, setdefaulttimeout, and getdefaulttimeout are
# C builtin functions from Modules/socketmodule.c. Their __module__ is '_socket'
# (the C extension module) rather than 'socket' (the Python wrapper). No prior
# spec anchors __name__ and __module__ for these four functions together as a
# grouped table under sockfunc295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra249.c_builtin_function_identity:
  description: "gethostname.__name__.__eq__('gethostname')==True / gethostname.__module__.__eq__('_socket')==True / gethostbyname.__name__.__eq__('gethostbyname')==True / gethostbyname.__module__.__eq__('_socket')==True / setdefaulttimeout.__name__.__eq__('setdefaulttimeout')==True / setdefaulttimeout.__module__.__eq__('_socket')==True / getdefaulttimeout.__name__.__eq__('getdefaulttimeout')==True / getdefaulttimeout.__module__.__eq__('_socket')==True — these four are C builtins from socketmodule.c; __module__=='_socket' (not 'socket'); no prior spec anchors these; first sockfunc295 anchor for C-builtin function identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockfunc295

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_name_eq,        "gethostname.__name__.__eq__",        ["gethostname"],        true, "socket.gethostname.__name__ is 'gethostname' (C builtin in _socket)"]
    - [gethostname_module_eq,      "gethostname.__module__.__eq__",      ["_socket"],            true, "socket.gethostname.__module__ is '_socket' (C extension, not 'socket' wrapper)"]
    - [gethostbyname_name_eq,      "gethostbyname.__name__.__eq__",      ["gethostbyname"],      true, "socket.gethostbyname.__name__ is 'gethostbyname' (C builtin in _socket)"]
    - [gethostbyname_module_eq,    "gethostbyname.__module__.__eq__",    ["_socket"],            true, "socket.gethostbyname.__module__ is '_socket' (C extension)"]
    - [setdefaulttimeout_name_eq,  "setdefaulttimeout.__name__.__eq__",  ["setdefaulttimeout"],  true, "socket.setdefaulttimeout.__name__ is 'setdefaulttimeout' (C builtin in _socket)"]
    - [setdefaulttimeout_mod_eq,   "setdefaulttimeout.__module__.__eq__", ["_socket"],           true, "socket.setdefaulttimeout.__module__ is '_socket' (C extension)"]
    - [getdefaulttimeout_name_eq,  "getdefaulttimeout.__name__.__eq__",  ["getdefaulttimeout"],  true, "socket.getdefaulttimeout.__name__ is 'getdefaulttimeout' (C builtin in _socket)"]
    - [getdefaulttimeout_mod_eq,   "getdefaulttimeout.__module__.__eq__", ["_socket"],           true, "socket.getdefaulttimeout.__module__ is '_socket' (C extension)"]

# ---------------------------------------------------------------------------
# socket pure Python function identity: getfqdn, getaddrinfo,
# create_connection, socketpair
#
# Wave 295 theme: socket module pure Python functions (__module__=='socket').
#
# getfqdn, getaddrinfo, create_connection, and socketpair are defined in
# Lib/socket.py (pure Python). Their __module__ is 'socket' (not '_socket').
# This contrasts with the C-builtin group above. socket_extra248 and earlier
# specs anchor socket constants and error classes; no prior spec anchors the
# __name__ and __module__ for these four Python-level functions together as
# a grouped table under sockfunc295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra249.python_function_identity:
  description: "getfqdn.__name__.__eq__('getfqdn')==True / getfqdn.__module__.__eq__('socket')==True / getaddrinfo.__name__.__eq__('getaddrinfo')==True / getaddrinfo.__module__.__eq__('socket')==True / create_connection.__name__.__eq__('create_connection')==True / create_connection.__module__.__eq__('socket')==True / socketpair.__name__.__eq__('socketpair')==True / socketpair.__module__.__eq__('socket')==True — these four are pure Python functions from Lib/socket.py; __module__=='socket' (not '_socket'); contrasts with C-builtin group; first sockfunc295 anchor for Python-level function identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockfunc295

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_name_eq,             "getfqdn.__name__.__eq__",             ["getfqdn"],             true, "socket.getfqdn.__name__ is 'getfqdn' (pure Python helper in Lib/socket.py)"]
    - [getfqdn_module_eq,           "getfqdn.__module__.__eq__",           ["socket"],              true, "socket.getfqdn.__module__ is 'socket' (defined in Lib/socket.py, not C extension)"]
    - [getaddrinfo_name_eq,         "getaddrinfo.__name__.__eq__",         ["getaddrinfo"],         true, "socket.getaddrinfo.__name__ is 'getaddrinfo' (Python wrapper in Lib/socket.py on macOS)"]
    - [getaddrinfo_module_eq,       "getaddrinfo.__module__.__eq__",       ["socket"],              true, "socket.getaddrinfo.__module__ is 'socket' (Python-level wrapper on macOS/Python 3.14.3)"]
    - [create_connection_name_eq,   "create_connection.__name__.__eq__",   ["create_connection"],   true, "socket.create_connection.__name__ is 'create_connection' (pure Python in Lib/socket.py)"]
    - [create_connection_module_eq, "create_connection.__module__.__eq__", ["socket"],              true, "socket.create_connection.__module__ is 'socket' (pure Python convenience function)"]
    - [socketpair_name_eq,          "socketpair.__name__.__eq__",          ["socketpair"],          true, "socket.socketpair.__name__ is 'socketpair' (Python wrapper on macOS in Lib/socket.py)"]
    - [socketpair_module_eq,        "socketpair.__module__.__eq__",        ["socket"],              true, "socket.socketpair.__module__ is 'socket' (Python-level on macOS/Python 3.14.3)"]

# ---------------------------------------------------------------------------
# socket.gethostname.__name__.__eq__('gethostname') — standalone
#
# socket.gethostname.__name__ is 'gethostname'. gethostname() returns the
# hostname of the machine where Python is running. It is a C builtin from
# Modules/socketmodule.c, so __module__ is '_socket'. It takes no arguments.
# The returned value is platform-dependent (the machine's configured hostname).
# No prior spec anchors socket.gethostname.__name__.__eq__ as a standalone
# under sockfunc295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra249.gethostname_name_eq:
  description: "socket.gethostname.__name__.__eq__('gethostname') == True — gethostname() returns the machine hostname; C builtin from Modules/socketmodule.c; __module__=='_socket' (not 'socket'); takes no arguments; returned value is platform-dependent; no prior spec anchors gethostname.__name__ as standalone; first standalone under sockfunc295"
  category: function_identity
  kind: python_call_eq
  function: "gethostname.__name__.__eq__"
  args: ["gethostname"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__module__.__eq__('socket') — standalone
#
# socket.create_connection.__module__ is 'socket'. create_connection(address,
# timeout, source_address) is a convenience function defined in Lib/socket.py
# that creates a TCP/IP connection to the given (host, port) address. It calls
# getaddrinfo() to resolve the address, then creates and connects a socket.
# Its __module__ is 'socket' (not '_socket') because it is pure Python.
# socket_extra.zspec does not anchor create_connection; no prior spec anchors
# create_connection.__module__ as a standalone under sockfunc295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra249.create_connection_module_eq:
  description: "socket.create_connection.__module__.__eq__('socket') == True — create_connection is a pure Python convenience function in Lib/socket.py; resolves address via getaddrinfo(), creates and connects a socket; __module__=='socket' (not '_socket'); contrasts with C builtins (gethostname, gethostbyname) which have __module__=='_socket'; no prior spec anchors create_connection.__module__ as standalone; first standalone under sockfunc295"
  category: function_identity
  kind: python_call_eq
  function: "create_connection.__module__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__module__.__eq__('socket') — standalone
#
# socket.getfqdn.__module__ is 'socket'. getfqdn(name='') is defined in
# Lib/socket.py and resolves the fully-qualified domain name for the given
# hostname (or the local host if name is empty or ''). It calls gethostname()
# and gethostbyaddr() internally. Because it is pure Python, __module__ is
# 'socket'. There is no corresponding _socket.getfqdn C builtin. No prior spec
# anchors socket.getfqdn.__module__ as a standalone under sockfunc295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra249.getfqdn_module_eq:
  description: "socket.getfqdn.__module__.__eq__('socket') == True — getfqdn is a pure Python function in Lib/socket.py; resolves fully-qualified domain name by calling gethostname()+gethostbyaddr(); __module__=='socket' (no _socket C counterpart); contrasts with gethostname and gethostbyname (__module__=='_socket'); no prior spec anchors getfqdn.__module__ as standalone; first standalone under sockfunc295"
  category: function_identity
  kind: python_call_eq
  function: "getfqdn.__module__.__eq__"
  args: ["socket"]
  expected: true
