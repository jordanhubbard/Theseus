spec: hashlib_extra93
version: ">=3.9"
extends: hashlib_extra92
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra92.zspec.zsdl — covers hashlib.sha256/sha512/md5/sha1/sha224/sha384 class identity (__class__.__name__=='builtin_function_or_method', __module__=='_hashlib', __qualname__) (table + invariants)."
    - "hashlib_extra91.zspec.zsdl — covers hashlib.new function identity / algorithms_available/algorithms_guaranteed set identity / blake2b BLAKE2 constant attrs / blake2b and blake2s doc class identity (table + invariants)."
    - "hashlib_extra90.zspec.zsdl — covers blake2b/blake2s class identity __name__/__module__/__bases__[0].__name__/__mro__.__len__() / blake2b/blake2s __dict__.__contains__ for copy/digest/hexdigest/update (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra92; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: hashlib.blake2b and hashlib.blake2s integer class constants — MAX_DIGEST_SIZE, MAX_KEY_SIZE, SALT_SIZE, PERSON_SIZE class identity and values."
    - "hashlib.blake2b.MAX_DIGEST_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_KEY_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.SALT_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.PERSON_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_DIGEST_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_KEY_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.SALT_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.PERSON_SIZE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_DIGEST_SIZE == 64 (blake2b maximum output is 64 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_KEY_SIZE == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.SALT_SIZE == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.PERSON_SIZE == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_DIGEST_SIZE == 32 (blake2s maximum output is 32 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_KEY_SIZE == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.SALT_SIZE == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.PERSON_SIZE == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: BLOCK_SIZE and DIGEST_SIZE are NOT in blake2b.__dict__; the available class constants are MAX_DIGEST_SIZE, MAX_KEY_SIZE, SALT_SIZE, PERSON_SIZE."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.MAX_DIGEST_SIZE/__class__/__name__.__eq__('int')
# hashlib.blake2b.MAX_KEY_SIZE/__class__/__name__.__eq__('int')
# hashlib.blake2b.SALT_SIZE/__class__/__name__.__eq__('int')
# hashlib.blake2b.PERSON_SIZE/__class__/__name__.__eq__('int')
#
# Wave 256 theme: blake2b integer class constant class identity.
#
# blake2b.MAX_DIGEST_SIZE, MAX_KEY_SIZE, SALT_SIZE, and PERSON_SIZE are all
# plain int class constants. Their __class__.__name__ is 'int'. No prior
# hashlib spec anchors these attribute __class__.__name__.__eq__ calls under
# hashlibblakeconst93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra93.blake2b_const_class_names:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE/__class__.__name__.__eq__('int')==True / blake2b.MAX_KEY_SIZE/__class__.__name__.__eq__('int')==True / blake2b.SALT_SIZE/__class__.__name__.__eq__('int')==True / blake2b.PERSON_SIZE/__class__.__name__.__eq__('int')==True — blake2b class constants MAX_DIGEST_SIZE/MAX_KEY_SIZE/SALT_SIZE/PERSON_SIZE are all plain ints; BLOCK_SIZE/DIGEST_SIZE are not present in blake2b.__dict__; first hashlibblakeconst93 anchor for blake2b constant class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibblakeconst93

  columns: [id, function, args, expected]
  rows:
    - [b2b_max_digest_size_class,  blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__,  ["int"], true]
    - [b2b_max_key_size_class,     blake2b.MAX_KEY_SIZE.__class__.__name__.__eq__,     ["int"], true]
    - [b2b_salt_size_class,        blake2b.SALT_SIZE.__class__.__name__.__eq__,        ["int"], true]
    - [b2b_person_size_class,      blake2b.PERSON_SIZE.__class__.__name__.__eq__,      ["int"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2s.MAX_DIGEST_SIZE/__class__/__name__.__eq__('int')
# hashlib.blake2s.MAX_KEY_SIZE/__class__/__name__.__eq__('int')
# hashlib.blake2s.SALT_SIZE/__class__/__name__.__eq__('int')
# hashlib.blake2s.PERSON_SIZE/__class__/__name__.__eq__('int')
#
# Wave 256 theme: blake2s integer class constant class identity.
#
# blake2s.MAX_DIGEST_SIZE, MAX_KEY_SIZE, SALT_SIZE, and PERSON_SIZE are all
# plain int class constants, just like their blake2b counterparts.
# Their __class__.__name__ is 'int'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra93.blake2s_const_class_names:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE/__class__.__name__.__eq__('int')==True / blake2s.MAX_KEY_SIZE/__class__.__name__.__eq__('int')==True / blake2s.SALT_SIZE/__class__.__name__.__eq__('int')==True / blake2s.PERSON_SIZE/__class__.__name__.__eq__('int')==True — blake2s class constants MAX_DIGEST_SIZE/MAX_KEY_SIZE/SALT_SIZE/PERSON_SIZE are all plain ints (same pattern as blake2b); first hashlibblakeconst93 anchor for blake2s constant class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibblakeconst93

  columns: [id, function, args, expected]
  rows:
    - [b2s_max_digest_size_class,  blake2s.MAX_DIGEST_SIZE.__class__.__name__.__eq__,  ["int"], true]
    - [b2s_max_key_size_class,     blake2s.MAX_KEY_SIZE.__class__.__name__.__eq__,     ["int"], true]
    - [b2s_salt_size_class,        blake2s.SALT_SIZE.__class__.__name__.__eq__,        ["int"], true]
    - [b2s_person_size_class,      blake2s.PERSON_SIZE.__class__.__name__.__eq__,      ["int"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64)
# hashlib.blake2b.MAX_KEY_SIZE.__eq__(64)
# hashlib.blake2b.SALT_SIZE.__eq__(16)
# hashlib.blake2b.PERSON_SIZE.__eq__(16)
#
# Wave 256 theme: blake2b constant values.
#
# blake2b.MAX_DIGEST_SIZE is 64 (max output 64 bytes), MAX_KEY_SIZE is 64,
# SALT_SIZE is 16, PERSON_SIZE is 16. These are the actual integer values
# of the class constants.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra93.blake2b_const_values:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64)==True / blake2b.MAX_KEY_SIZE.__eq__(64)==True / blake2b.SALT_SIZE.__eq__(16)==True / blake2b.PERSON_SIZE.__eq__(16)==True — blake2b supports 64-byte max output and 64-byte max key; salt and personalization are both 16 bytes; first hashlibblakeconst93 anchor for blake2b constant integer values"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibblakeconst93

  columns: [id, function, args, expected]
  rows:
    - [b2b_max_digest_size_val,  blake2b.MAX_DIGEST_SIZE.__eq__,  [64], true]
    - [b2b_max_key_size_val,     blake2b.MAX_KEY_SIZE.__eq__,     [64], true]
    - [b2b_salt_size_val,        blake2b.SALT_SIZE.__eq__,        [16], true]
    - [b2b_person_size_val,      blake2b.PERSON_SIZE.__eq__,      [16], true]

# ---------------------------------------------------------------------------
# hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32)
# hashlib.blake2s.MAX_KEY_SIZE.__eq__(32)
# hashlib.blake2s.SALT_SIZE.__eq__(8)
# hashlib.blake2s.PERSON_SIZE.__eq__(8)
#
# Wave 256 theme: blake2s constant values.
#
# blake2s.MAX_DIGEST_SIZE is 32 (max output 32 bytes), MAX_KEY_SIZE is 32,
# SALT_SIZE is 8, PERSON_SIZE is 8. blake2s uses half the sizes of blake2b
# for max digest/key and half the salt/person sizes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra93.blake2s_const_values:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32)==True / blake2s.MAX_KEY_SIZE.__eq__(32)==True / blake2s.SALT_SIZE.__eq__(8)==True / blake2s.PERSON_SIZE.__eq__(8)==True — blake2s supports 32-byte max output and 32-byte max key; salt and personalization are both 8 bytes (half of blake2b); first hashlibblakeconst93 anchor for blake2s constant integer values"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibblakeconst93

  columns: [id, function, args, expected]
  rows:
    - [b2s_max_digest_size_val,  blake2s.MAX_DIGEST_SIZE.__eq__,  [32], true]
    - [b2s_max_key_size_val,     blake2s.MAX_KEY_SIZE.__eq__,     [32], true]
    - [b2s_salt_size_val,        blake2s.SALT_SIZE.__eq__,        [8],  true]
    - [b2s_person_size_val,      blake2s.PERSON_SIZE.__eq__,      [8],  true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__('int') — standalone
#
# blake2b.MAX_DIGEST_SIZE is a plain int class constant (value 64). Its
# __class__.__name__ is 'int'. No prior hashlib spec anchors this __eq__ call
# under hashlibblakeconst93. First standalone for blake2b.MAX_DIGEST_SIZE class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra93.b2b_max_digest_size_class:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__('int') == True — MAX_DIGEST_SIZE is a plain int class constant on blake2b (value 64); its __class__.__name__ is 'int'; no prior hashlib spec anchors this __eq__ call; first standalone for blake2b.MAX_DIGEST_SIZE class identity under hashlibblakeconst93"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.MAX_DIGEST_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) — standalone
#
# blake2b.MAX_DIGEST_SIZE is 64 — the maximum output size for blake2b in bytes.
# No prior hashlib spec anchors this value __eq__ call under hashlibblakeconst93.
# First standalone for blake2b.MAX_DIGEST_SIZE value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra93.b2b_max_digest_size_val:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) == True — MAX_DIGEST_SIZE is 64 (the blake2b algorithm produces up to 64 bytes of output); no prior hashlib spec anchors this value __eq__ call; first standalone for blake2b.MAX_DIGEST_SIZE integer value under hashlibblakeconst93"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.MAX_DIGEST_SIZE.__eq__
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) — standalone
#
# blake2s.MAX_DIGEST_SIZE is 32 — the maximum output size for blake2s in bytes.
# No prior hashlib spec anchors this value __eq__ call under hashlibblakeconst93.
# First standalone for blake2s.MAX_DIGEST_SIZE value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra93.b2s_max_digest_size_val:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) == True — MAX_DIGEST_SIZE is 32 (the blake2s algorithm produces up to 32 bytes of output, half of blake2b); no prior hashlib spec anchors this value __eq__ call; first standalone for blake2s.MAX_DIGEST_SIZE integer value under hashlibblakeconst93"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.MAX_DIGEST_SIZE.__eq__
  args: [32]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.SALT_SIZE.__eq__(16) — standalone
#
# blake2b.SALT_SIZE is 16 — the salt field is 16 bytes for blake2b.
# No prior hashlib spec anchors this value __eq__ call under hashlibblakeconst93.
# First standalone for blake2b.SALT_SIZE value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra93.b2b_salt_size_val:
  description: "hashlib.blake2b.SALT_SIZE.__eq__(16) == True — SALT_SIZE is 16 (blake2b uses a 16-byte salt field for domain separation); no prior hashlib spec anchors this value __eq__ call; first standalone for blake2b.SALT_SIZE integer value under hashlibblakeconst93"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.SALT_SIZE.__eq__
  args: [16]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.SALT_SIZE.__eq__(8) — standalone
#
# blake2s.SALT_SIZE is 8 — the salt field is 8 bytes for blake2s (half of blake2b).
# No prior hashlib spec anchors this value __eq__ call under hashlibblakeconst93.
# First standalone for blake2s.SALT_SIZE value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra93.b2s_salt_size_val:
  description: "hashlib.blake2s.SALT_SIZE.__eq__(8) == True — SALT_SIZE is 8 (blake2s uses an 8-byte salt field, half of blake2b's 16 bytes); no prior hashlib spec anchors this value __eq__ call; first standalone for blake2s.SALT_SIZE integer value under hashlibblakeconst93"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.SALT_SIZE.__eq__
  args: [8]
  expected: true
