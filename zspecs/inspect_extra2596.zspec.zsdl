spec: inspect_extra2596
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2596 (_extra2596): __get__, __set__, __delete__ descriptor-protocol dict-presence checks for inspect module types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "inspect.Parameter, inspect.BoundArguments, inspect.Signature: pure-Python introspection types; none define descriptor dunders."
    - "inspect.FrameInfo, inspect.FullArgSpec, inspect.ArgInfo: namedtuple-derived or dataclass types; none define descriptor dunders."
    - "inspect.Attribute, inspect.ClosureVars: named-tuple types representing introspection results; none define descriptor dunders."
    - "No inspect module type acts as a descriptor (data or non-data). These types model introspection data, not attribute-binding behavior."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __get__ dict-presence for inspect introspection types
#
# inspect.Parameter, BoundArguments, and Signature are the core callable
# introspection types introduced in PEP 362. None define __get__ in their
# own __dict__; they are not descriptors. They model signature metadata,
# not attribute binding.
# ---------------------------------------------------------------------------

table inspect_extra2596.get_protocol:
  description: "inspect types __get__ dict-presence — all False, no inspect type is a descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2596

  columns: [id, function, args, expected]
  rows:
    - ["in2596001", "inspect.Parameter.__dict__.__contains__", ["__get__"], false]
    - ["in2596002", "inspect.BoundArguments.__dict__.__contains__", ["__get__"], false]
    - ["in2596003", "inspect.Signature.__dict__.__contains__", ["__get__"], false]
    - ["in2596004", "inspect.FrameInfo.__dict__.__contains__", ["__get__"], false]
    - ["in2596005", "inspect.FullArgSpec.__dict__.__contains__", ["__get__"], false]
    - ["in2596006", "inspect.ArgInfo.__dict__.__contains__", ["__get__"], false]
    - ["in2596007", "inspect.Attribute.__dict__.__contains__", ["__get__"], false]

# ---------------------------------------------------------------------------
# Table 2: __set__ dict-presence for inspect introspection types
#
# None of the inspect types define __set__. The absence of both __get__
# and __set__ confirms these types participate in no part of the descriptor
# protocol. inspect types are immutable-ish value objects (or namedtuples)
# that carry introspection results.
# ---------------------------------------------------------------------------

table inspect_extra2596.set_protocol:
  description: "inspect types __set__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2596

  columns: [id, function, args, expected]
  rows:
    - ["in2596008", "inspect.Parameter.__dict__.__contains__", ["__set__"], false]
    - ["in2596009", "inspect.BoundArguments.__dict__.__contains__", ["__set__"], false]
    - ["in2596010", "inspect.Signature.__dict__.__contains__", ["__set__"], false]
    - ["in2596011", "inspect.FrameInfo.__dict__.__contains__", ["__set__"], false]
    - ["in2596012", "inspect.FullArgSpec.__dict__.__contains__", ["__set__"], false]
    - ["in2596013", "inspect.ArgInfo.__dict__.__contains__", ["__set__"], false]
    - ["in2596014", "inspect.Attribute.__dict__.__contains__", ["__set__"], false]

# ---------------------------------------------------------------------------
# Table 3: __delete__ dict-presence for inspect introspection types
#
# None of the inspect types define __delete__. These types model introspection
# results (frames, arguments, attributes, closures) and have no role in
# attribute deletion mechanics.
# ---------------------------------------------------------------------------

table inspect_extra2596.delete_protocol:
  description: "inspect types __delete__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2596

  columns: [id, function, args, expected]
  rows:
    - ["in2596015", "inspect.Parameter.__dict__.__contains__", ["__delete__"], false]
    - ["in2596016", "inspect.BoundArguments.__dict__.__contains__", ["__delete__"], false]
    - ["in2596017", "inspect.Signature.__dict__.__contains__", ["__delete__"], false]
    - ["in2596018", "inspect.FrameInfo.__dict__.__contains__", ["__delete__"], false]
    - ["in2596019", "inspect.FullArgSpec.__dict__.__contains__", ["__delete__"], false]
    - ["in2596020", "inspect.ClosureVars.__dict__.__contains__", ["__delete__"], false]

# ---------------------------------------------------------------------------
# Table 4: Full descriptor protocol cross-check for inspect.Parameter
#
# inspect.Parameter is the most widely used inspect type. It uses slots
# and properties internally to validate its fields, but it does NOT
# expose __get__, __set__, or __delete__ in its own __dict__. Its
# properties (kind, default, annotation, name) are defined in the class
# but do not make the class itself a descriptor for use on other classes.
# ---------------------------------------------------------------------------

table inspect_extra2596.parameter_descriptor_cross_check:
  description: "inspect.Parameter full descriptor protocol check — not a descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2596

  columns: [id, function, args, expected]
  rows:
    - ["in2596021", "inspect.Parameter.__dict__.__contains__", ["__get__"], false]
    - ["in2596022", "inspect.Parameter.__dict__.__contains__", ["__set__"], false]
    - ["in2596023", "inspect.Parameter.__dict__.__contains__", ["__delete__"], false]
    - ["in2596024", "inspect.Signature.__dict__.__contains__", ["__get__"], false]
    - ["in2596025", "inspect.Signature.__dict__.__contains__", ["__set__"], false]
    - ["in2596026", "inspect.Signature.__dict__.__contains__", ["__delete__"], false]
    - ["in2596027", "inspect.ClosureVars.__dict__.__contains__", ["__get__"], false]
    - ["in2596028", "inspect.ClosureVars.__dict__.__contains__", ["__set__"], false]
