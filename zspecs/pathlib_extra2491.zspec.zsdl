spec: pathlib_extra2491
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether pathlib classes define mutable item access and missing-key protocol in their class __dict__."
    - "pathlib path objects are immutable value types — they define no mutable item access in their class __dict__."
    - "pathlib.PurePath.__dict__ does NOT contain '__setitem__' (False) — paths are not mutable mappings."
    - "pathlib.PurePath.__dict__ does NOT contain '__delitem__' (False) — item deletion is not supported."
    - "pathlib.PurePath.__dict__ does NOT contain '__missing__' (False) — no missing-key protocol."
    - "pathlib.Path.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False)."
    - "pathlib.PurePosixPath.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False)."
    - "pathlib.PosixPath.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False)."
    - "pathlib.PurePath.__dict__ DOES contain '__truediv__', '__str__', '__repr__', '__hash__', '__eq__', '__fspath__' — path operators and protocol hooks."
    - "pathlib.PurePath.__dict__ DOES contain 'parent', 'name', 'stem', 'suffix', 'parts' — path component properties."
    - "pathlib.Path.__dict__ DOES contain 'stat', 'open', 'exists', 'glob', 'iterdir', 'is_file', 'is_dir', 'mkdir', 'unlink' — filesystem methods."
    - "Accessing '__setitem__' via pathlib.PurePath.__dict__.__getitem__ raises KeyError — the key is absent."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ — mutable item access protocol absence
# PurePath is an immutable pure path-manipulation object.
# __setitem__, __delitem__, and __missing__ are absent from its class __dict__.
# ---------------------------------------------------------------------------

table pathlib_extra2491.PurePath_mutable_item_absence:
  description: "pathlib.PurePath.__dict__ does not contain __setitem__, __delitem__, or __missing__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pp2491

  columns: [id, function, args, expected]
  rows:
    - ["pp2491001", pathlib.PurePath.__dict__.__contains__, ["__setitem__"], false]
    - ["pp2491002", pathlib.PurePath.__dict__.__contains__, ["__delitem__"], false]
    - ["pp2491003", pathlib.PurePath.__dict__.__contains__, ["__missing__"], false]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ — operator and protocol hooks that ARE present
# __truediv__ enables the / operator; __fspath__ enables os.fspath() support.
# These contrast with the absent mutable-mapping protocol entries.
# ---------------------------------------------------------------------------

table pathlib_extra2491.PurePath_operator_presence:
  description: "pathlib.PurePath.__dict__ contains operator hooks and protocol methods: __truediv__, __str__, __repr__, __hash__, __eq__, __fspath__"
  kind: python_call_eq
