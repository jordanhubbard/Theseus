    - ["pp2491005", pathlib.PurePath.__dict__.__contains__, ["__str__"],     true]
    - ["pp2491006", pathlib.PurePath.__dict__.__contains__, ["__repr__"],    true]
    - ["pp2491007", pathlib.PurePath.__dict__.__contains__, ["__hash__"],    true]
    - ["pp2491008", pathlib.PurePath.__dict__.__contains__, ["__eq__"],      true]
    - ["pp2491009", pathlib.PurePath.__dict__.__contains__, ["__fspath__"],  true]
    - ["pp2491010", pathlib.PurePath.__dict__.__contains__, ["parent"],      true]
    - ["pp2491011", pathlib.PurePath.__dict__.__contains__, ["name"],        true]
    - ["pp2491012", pathlib.PurePath.__dict__.__contains__, ["stem"],        true]
    - ["pp2491013", pathlib.PurePath.__dict__.__contains__, ["suffix"],      true]
    - ["pp2491014", pathlib.PurePath.__dict__.__contains__, ["parts"],       true]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__getitem__ — KeyError for mutable-item keys
# Accessing an absent key via __getitem__ raises KeyError, consistent with
# mappingproxy semantics. Confirms the protocol keys are genuinely absent.
# ---------------------------------------------------------------------------

table pathlib_extra2491.PurePath_dict_getitem_raises:
  description: "pathlib.PurePath.__dict__.__getitem__ raises KeyError for __setitem__, __delitem__, __missing__"
  kind: python_call_raises
  category: dict_membership
  id_prefix: pp2491

  columns: [id, function, args, expected]
  rows:
    - ["pp2491015", pathlib.PurePath.__dict__.__getitem__, ["__setitem__"], KeyError]
    - ["pp2491016", pathlib.PurePath.__dict__.__getitem__, ["__delitem__"], KeyError]
    - ["pp2491017", pathlib.PurePath.__dict__.__getitem__, ["__missing__"], KeyError]

