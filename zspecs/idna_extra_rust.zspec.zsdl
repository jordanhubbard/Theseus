spec: idna_extra_rust
version: ">=3.9"
backend: rust_module(idna_extra_rust)

docs: https://github.com/kjd/idna

provenance:
  derived_from:
    - "https://github.com/kjd/idna — idna library"
  notes:
    - "idna provides Internationalized Domain Names support."
    - "idna.encode('python.org') == b'python.org'."
    - "idna.decode(b'python.org') == 'python.org'."
    - "idna.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant idna_extra_rust.encode_python_org:
  description: "idna.encode('python.org') == b'python.org'"
  category: encode
  kind: python_call_eq
  function: idna_extra_encode_python_org
  args: []
  expected: true

invariant idna_extra_rust.decode_python_org:
  description: "idna.decode(b'python.org') == 'python.org'"
  category: decode
  kind: python_call_eq
  function: idna_extra_decode_python_org
  args: []
  expected: true

invariant idna_extra_rust.version_nonempty:
  description: "idna.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: idna_extra_version_nonempty
  args: []
  expected: true

