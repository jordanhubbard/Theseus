spec: abc_extra196
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers __code__.co_name values for abc functions and methods with Python-level __code__ objects."
    - "abc.abstractmethod.__code__.co_name == 'abstractmethod' — abstractmethod is a plain Python function; co_name matches the function name. Verified with Python 3.14.3."
    - "abc.abstractmethod.__code__.co_argcount == 1 — abstractmethod takes exactly one parameter ('funcobj'). Verified with Python 3.14.3."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' — top-level function; qualname equals simple name. Verified with Python 3.14.3."
    - "abc.ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__' — ABCMeta.__instancecheck__ is a Python-level method with __code__. Verified with Python 3.14.3."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_name == '__subclasscheck__' — ABCMeta.__subclasscheck__ is a Python-level method with __code__. Verified with Python 3.14.3."
    - "abc.ABCMeta.register.__code__.co_name == 'register' — ABCMeta.register is a Python-level method with __code__. Verified with Python 3.14.3."
    - "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods' — update_abstractmethods is a Python-level function with __code__. Verified with Python 3.14.3."
    - "abc.ABCMeta.__new__.__code__.co_name == '__new__' — ABCMeta.__new__ is a Python-level method with __code__. Verified with Python 3.14.3."
    - "abc.ABC.__init_subclass__ and abc.ABC.__subclasshook__ are builtin_function_or_method objects without __code__; only the eight Python-level callables above have __code__."
    - "abstractmethod co_name 'abstractmethod' has length 14; update_abstractmethods co_name has length 22."
    - "ABCMeta.__instancecheck__ and ABCMeta.__subclasscheck__ co_names each have length 17."
    - "Prior abc specs cover __doc__.__class__.__name__, __name__, __qualname__, __module__, and __bases__ checks. No prior spec covers __code__.co_name values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

