spec: functools_extra258
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.partial method/slot identity (__call__, __new__, __repr__, __reduce__, __setstate__), descriptor types for partial.func/args/keywords, and functools.partialmethod class identity behavioral contracts."
    - "functools.partial.__call__.__name__ == '__call__' — partial.__call__ is a wrapper_descriptor slot; __name__ is '__call__'. Verified with Python 3.14.3."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' — qualname reflects that __call__ is defined on the partial C class. Verified with Python 3.14.3."
    - "functools.partial.__new__.__name__ == '__new__' — partial.__new__ is a builtin_function_or_method; __name__ is '__new__'. Verified with Python 3.14.3."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' — qualname reflects that __new__ is defined on the partial C class. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__name__ == '__repr__' — partial.__repr__ is a wrapper_descriptor slot; __name__ is '__repr__'. Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__name__ == '__reduce__' — partial.__reduce__ is a method_descriptor; __name__ is '__reduce__'. Verified with Python 3.14.3."
    - "functools.partial.__setstate__.__name__ == '__setstate__' — partial.__setstate__ is a method_descriptor used for pickle support; __name__ is '__setstate__'. Verified with Python 3.14.3."
    - "type(functools.partial.func).__name__ == 'member_descriptor' — partial.func is a C-level member_descriptor exposing the stored callable. Verified with Python 3.14.3."
    - "type(functools.partial.args).__name__ == 'member_descriptor' — partial.args is a C-level member_descriptor exposing the stored positional args tuple. Verified with Python 3.14.3."
    - "type(functools.partial.keywords).__name__ == 'member_descriptor' — partial.keywords is a C-level member_descriptor exposing the stored keyword args dict. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__ == 'partialmethod' — partialmethod is a pure Python class; __name__ is 'partialmethod'. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in the functools module; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod directly inherits from object; first base __name__ is 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial __call__ and __new__ method identity
#
# functools.partial.__call__.__name__ == '__call__'
# functools.partial.__call__.__qualname__ == 'partial.__call__'
# functools.partial.__new__.__name__ == '__new__'
# functools.partial.__new__.__qualname__ == 'partial.__new__'
# functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor'
#
# partial is a C-level type; __call__ and __repr__ are wrapper_descriptor
# slots; __new__ is a builtin_function_or_method. New to extra258.
# ---------------------------------------------------------------------------

table functools_extra258.partial_call_new_identity:
  description: "functools.partial.__call__ and __new__ __name__, __qualname__, __class__.__name__ identity contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: partialcallnew258

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_name_eq,
       partial.__call__.__name__.__eq__,
       ["__call__"],
       true,
       "functools.partial.__call__.__name__.__eq__('__call__') == True — partial.__call__ is a wrapper_descriptor slot; __name__ is '__call__'; new to extra258"]
    - [partial_call_qualname_eq,
       partial.__call__.__qualname__.__eq__,
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — qualname reflects that __call__ is defined on the partial C class; new to extra258"]
    - [partial_call_class_eq,
       partial.__call__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__call__ is a C slot wrapper (wrapper_descriptor); new to extra258"]
    - [partial_new_name_eq,
       partial.__new__.__name__.__eq__,
       ["__new__"],
       true,
       "functools.partial.__new__.__name__.__eq__('__new__') == True — partial.__new__ is a builtin_function_or_method; __name__ is '__new__'; new to extra258"]
    - [partial_new_qualname_eq,
       partial.__new__.__qualname__.__eq__,
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — qualname reflects that __new__ is defined on the partial C class; new to extra258"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial __repr__, __reduce__, __setstate__ identity
#
# functools.partial.__repr__.__name__ == '__repr__'
# functools.partial.__repr__.__qualname__ == 'partial.__repr__'
# functools.partial.__reduce__.__name__ == '__reduce__'
# functools.partial.__setstate__.__name__ == '__setstate__'
# functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor'
#
# __repr__ is a wrapper_descriptor; __reduce__ and __setstate__ are
# method_descriptor objects used for pickling support. New to extra258.
# ---------------------------------------------------------------------------

table functools_extra258.partial_repr_reduce_setstate_identity:
  description: "functools.partial.__repr__, __reduce__, __setstate__ __name__, __qualname__, __class__.__name__ identity contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: partialrrs258

  columns: [id, function, args, expected, description]
  rows:
    - [partial_repr_name_eq,
       partial.__repr__.__name__.__eq__,
       ["__repr__"],
       true,
       "functools.partial.__repr__.__name__.__eq__('__repr__') == True — partial.__repr__ is a wrapper_descriptor slot; __name__ is '__repr__'; new to extra258"]
    - [partial_repr_qualname_eq,
       partial.__repr__.__qualname__.__eq__,
       ["partial.__repr__"],
       true,
       "functools.partial.__repr__.__qualname__.__eq__('partial.__repr__') == True — qualname reflects that __repr__ is defined on the partial C class; new to extra258"]
    - [partial_repr_class_eq,
       partial.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "functools.partial.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__repr__ is a C slot wrapper (wrapper_descriptor); new to extra258"]
    - [partial_reduce_name_eq,
       partial.__reduce__.__name__.__eq__,
       ["__reduce__"],
       true,
       "functools.partial.__reduce__.__name__.__eq__('__reduce__') == True — partial.__reduce__ is a method_descriptor for pickle support; __name__ is '__reduce__'; new to extra258"]
    - [partial_setstate_name_eq,
       partial.__setstate__.__name__.__eq__,
       ["__setstate__"],
       true,
       "functools.partial.__setstate__.__name__.__eq__('__setstate__') == True — partial.__setstate__ is a method_descriptor used when unpickling a partial; __name__ is '__setstate__'; new to extra258"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial member descriptor attributes: func, args, keywords
#
# type(functools.partial.func).__name__ == 'member_descriptor'
# type(functools.partial.args).__name__ == 'member_descriptor'
# type(functools.partial.keywords).__name__ == 'member_descriptor'
#
# partial.func, partial.args, and partial.keywords are C-level member
# descriptors that expose the internal state of a partial object. New to extra258.
# ---------------------------------------------------------------------------

table functools_extra258.partial_member_descriptors:
  description: "functools.partial.func, .args, .keywords member_descriptor type identity contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: partialmember258

  columns: [id, function, args, expected, description]
  rows:
    - [partial_func_class_eq,
       partial.func.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.func.__class__.__name__.__eq__('member_descriptor') == True — partial.func is a C-level member_descriptor exposing the stored callable; new to extra258"]
    - [partial_args_class_eq,
       partial.args.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.args.__class__.__name__.__eq__('member_descriptor') == True — partial.args is a C-level member_descriptor exposing the stored positional args tuple; new to extra258"]
    - [partial_keywords_class_eq,
       partial.keywords.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — partial.keywords is a C-level member_descriptor exposing the stored keyword args dict; new to extra258"]
    - [partial_reduce_class_eq,
       partial.__reduce__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "functools.partial.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — partial.__reduce__ is a C-level method_descriptor (not a wrapper_descriptor); new to extra258"]
    - [partial_setstate_class_eq,
       partial.__setstate__.__class__.__name__.__eq__,
       ["method_descriptor"],
       true,
       "functools.partial.__setstate__.__class__.__name__.__eq__('method_descriptor') == True — partial.__setstate__ is a C-level method_descriptor for pickle restore; new to extra258"]

# ---------------------------------------------------------------------------
# Table 4: functools.partialmethod class identity
#
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__module__ == 'functools'
# functools.partialmethod.__bases__[0].__name__ == 'object'
#
# partialmethod is a pure Python class (unlike partial which is C-level).
# It directly inherits from object. New to extra258.
# ---------------------------------------------------------------------------

table functools_extra258.partialmethod_identity:
  description: "functools.partialmethod __name__, __module__, __bases__[0].__name__ identity contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: partialmethod258

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq,
       partialmethod.__name__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a pure Python class; __name__ is 'partialmethod'; new to extra258"]
    - [partialmethod_module_eq,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in the functools module; __module__ is 'functools'; new to extra258"]
    - ["partialmethod_base0_name_eq",
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod directly inherits from object; first base __name__ is 'object'; new to extra258"]
    - [partialmethod_name_len_13,
       partialmethod.__name__.__len__,
       [],
       13,
       "functools.partialmethod.__name__.__len__() == 13 — 'partialmethod' has 13 characters; new to extra258"]
    - [partialmethod_module_len_9,
       partialmethod.__module__.__len__,
       [],
       9,
       "functools.partialmethod.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra258"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra258
# ---------------------------------------------------------------------------

invariant functools_extra258.partial.__call__.name_eq:
  description: "functools.partial.__call__.__name__ == '__call__' — wrapper_descriptor slot on the C partial type; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__call__.__name__.__eq__
  args: ["__call__"]
  expected: true

invariant functools_extra258.partial.__call__.qualname_eq:
  description: "functools.partial.__call__.__qualname__ == 'partial.__call__' — qualname shows definition on the partial C class; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__call__.__qualname__.__eq__
  args: ["partial.__call__"]
  expected: true

invariant functools_extra258.partial.__call__.class_is_wrapper_descriptor:
  description: "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — partial.__call__ is a C slot wrapper; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__call__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra258.partial.__new__.name_eq:
  description: "functools.partial.__new__.__name__ == '__new__' — builtin_function_or_method on the C partial type; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__new__.__name__.__eq__
  args: ["__new__"]
  expected: true

invariant functools_extra258.partial.__new__.qualname_eq:
  description: "functools.partial.__new__.__qualname__ == 'partial.__new__' — qualname shows definition on the partial C class; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__new__.__qualname__.__eq__
  args: ["partial.__new__"]
  expected: true

invariant functools_extra258.partial.__repr__.name_eq:
  description: "functools.partial.__repr__.__name__ == '__repr__' — wrapper_descriptor slot on the C partial type; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true

invariant functools_extra258.partial.__repr__.qualname_eq:
  description: "functools.partial.__repr__.__qualname__ == 'partial.__repr__' — qualname shows definition on the partial C class; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__repr__.__qualname__.__eq__
  args: ["partial.__repr__"]
  expected: true

invariant functools_extra258.partial.__reduce__.name_eq:
  description: "functools.partial.__reduce__.__name__ == '__reduce__' — method_descriptor for pickle support on the C partial type; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__reduce__.__name__.__eq__
  args: ["__reduce__"]
  expected: true

invariant functools_extra258.partial.__setstate__.name_eq:
  description: "functools.partial.__setstate__.__name__ == '__setstate__' — method_descriptor for pickle restore on the C partial type; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.__setstate__.__name__.__eq__
  args: ["__setstate__"]
  expected: true

invariant functools_extra258.partial.func.class_is_member_descriptor:
  description: "functools.partial.func.__class__.__name__ == 'member_descriptor' — partial.func is a C-level member_descriptor exposing the stored callable; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.func.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra258.partial.args.class_is_member_descriptor:
  description: "functools.partial.args.__class__.__name__ == 'member_descriptor' — partial.args is a C-level member_descriptor exposing the stored positional args; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.args.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra258.partial.keywords.class_is_member_descriptor:
  description: "functools.partial.keywords.__class__.__name__ == 'member_descriptor' — partial.keywords is a C-level member_descriptor exposing the stored keyword args; new to extra258"
  category: identity
  kind: python_call_eq
  function: partial.keywords.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra258.partialmethod.name_eq:
  description: "functools.partialmethod.__name__ == 'partialmethod' — pure Python class for creating partial descriptors; new to extra258"
  category: identity
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra258.partialmethod.module_eq:
  description: "functools.partialmethod.__module__ == 'functools' — defined in the functools module; new to extra258"
  category: identity
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra258.partialmethod.base0_is_object:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod directly inherits from object; new to extra258"
  category: identity
  kind: python_call_eq
  function: "partialmethod.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
