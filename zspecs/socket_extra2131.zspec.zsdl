spec: socket_extra2131
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket.zspec.zsdl — covers socket construction, AF_INET/AF_UNIX constants, SOCK_STREAM"
    - "socket_extra.zspec.zsdl — covers getaddrinfo, gethostname, setblocking, timeout attrs"
    - "socket_extra2.zspec.zsdl — covers additional socket method and attr coverage"
  notes:
    - "Wave extra2131, theme: exception protocol dict-presence."
    - "Checks whether exception-related protocol attributes (__cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback) appear in the __dict__ of socket types."
    - "socket.error is an alias for OSError; its __dict__ contains __new__, __str__, __init__, __reduce__, errno, strerror, filename, filename2, characters_written, __doc__."
    - "socket.timeout is an alias for TimeoutError (subclasses OSError); its __dict__ contains only __doc__."
    - "socket.gaierror subclasses OSError; its __dict__ contains __module__, __weakref__, __doc__."
    - "socket.herror subclasses OSError; its __dict__ contains __module__, __weakref__, __doc__."
    - "socket.socket is a non-exception Python class; its __dict__ contains instance management methods but none of the exception protocol attributes."
    - "__cause__, __context__, __traceback__, __suppress_context__ are instance attrs set by CPython — NOT in any class __dict__."
    - "args and with_traceback are defined in BaseException.__dict__, not in any of the socket exception subclass __dict__ entries."
    - "socket.error does define __init__, __new__, __str__, __reduce__ in its own __dict__ (OSError overrides these); but NOT args or with_traceback."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.error (OSError) — exception protocol attributes absent from __dict__
# socket.error overrides __new__, __init__, __str__, __reduce__ but NOT the
# exception chaining attributes or args/with_traceback.
# ---------------------------------------------------------------------------

table socket_extra2131.error_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: sk2131

  columns: [id, function, args, expected]
  rows:
    - ["sk2131001", error.__dict__.__contains__, ["__cause__"],             false]
    - ["sk2131002", error.__dict__.__contains__, ["__context__"],           false]
    - ["sk2131003", error.__dict__.__contains__, ["__traceback__"],         false]
    - ["sk2131004", error.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["sk2131005", error.__dict__.__contains__, ["__notes__"],             false]
    - ["sk2131006", error.__dict__.__contains__, ["args"],                  false]
    - ["sk2131007", error.__dict__.__contains__, ["with_traceback"],        false]

# ---------------------------------------------------------------------------
# socket.timeout (TimeoutError) — exception protocol attributes absent from __dict__
# socket.timeout.__dict__ contains only __doc__; no overrides at all.
# ---------------------------------------------------------------------------

table socket_extra2131.timeout_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: sk2131

  columns: [id, function, args, expected]
  rows:
    - ["sk2131008", timeout.__dict__.__contains__, ["__cause__"],             false]
    - ["sk2131009", timeout.__dict__.__contains__, ["__context__"],           false]
    - ["sk2131010", timeout.__dict__.__contains__, ["__traceback__"],         false]
    - ["sk2131011", timeout.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["sk2131012", timeout.__dict__.__contains__, ["__notes__"],             false]
    - ["sk2131013", timeout.__dict__.__contains__, ["args"],                  false]
    - ["sk2131014", timeout.__dict__.__contains__, ["with_traceback"],        false]

