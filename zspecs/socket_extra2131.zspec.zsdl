# ---------------------------------------------------------------------------
# socket.error — positive presence: OSError-specific attrs ARE in __dict__
# socket.error (OSError) defines errno, strerror, filename, filename2,
# characters_written, __new__, __init__, __str__, __reduce__ in its own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2131.error_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2131

  columns: [id, function, args, expected]
  rows:
    - ["sk2131036", error.__dict__.__contains__, ["errno"],                true]
    - ["sk2131037", error.__dict__.__contains__, ["strerror"],             true]
    - ["sk2131038", error.__dict__.__contains__, ["filename"],             true]
    - ["sk2131039", error.__dict__.__contains__, ["__new__"],              true]
    - ["sk2131040", error.__dict__.__contains__, ["__init__"],             true]
    - ["sk2131041", error.__dict__.__contains__, ["__str__"],              true]
    - ["sk2131042", error.__dict__.__contains__, ["__reduce__"],           true]

# ---------------------------------------------------------------------------
# socket.gaierror and socket.herror — own attrs present in __dict__
# Both define __module__ and __doc__ in their own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2131.gaierror_herror_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2131

  columns: [id, function, args, expected]
  rows:
    - ["sk2131043", gaierror.__dict__.__contains__, ["__module__"],  true]
    - ["sk2131044", gaierror.__dict__.__contains__, ["__doc__"],     true]
    - ["sk2131045", herror.__dict__.__contains__,   ["__module__"],  true]
    - ["sk2131046", herror.__dict__.__contains__,   ["__doc__"],     true]
