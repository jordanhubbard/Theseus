spec: concurrent_futures_extra2146
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
    - "concurrent_futures_extra2116.zspec.zsdl — covers bitwise operator protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "concurrent.futures classes are executor and future abstractions for parallel execution; none define numeric conversion protocol methods."
    - "concurrent.futures.Future.__dict__ does not define __bool__; the class does not support truthiness via the numeric protocol dunder."
    - "concurrent.futures.Executor is an abstract base class; its __dict__ contains submit, map, shutdown, and __enter__/__exit__ only."
    - "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor are concrete executors; neither defines any numeric conversion dunder."
    - "All expected values (false) verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2146.trunc_floor_ceil:
  description: "concurrent.futures classes __dict__ numeric conversion dict-presence — __trunc__, __floor__, __ceil__ absent from all class dicts"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2146

  columns: [id, function, args, expected]
  rows:
    - ["cf2146001", "concurrent.futures.Future.__dict__.__contains__", ["__trunc__"], false]
    - ["cf2146002", "concurrent.futures.Future.__dict__.__contains__", ["__floor__"], false]
    - ["cf2146003", "concurrent.futures.Future.__dict__.__contains__", ["__ceil__"], false]
    - ["cf2146004", "concurrent.futures.Executor.__dict__.__contains__", ["__trunc__"], false]
    - ["cf2146005", "concurrent.futures.Executor.__dict__.__contains__", ["__floor__"], false]
    - ["cf2146006", "concurrent.futures.Executor.__dict__.__contains__", ["__ceil__"], false]
    - ["cf2146007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__trunc__"], false]
    - ["cf2146008", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__floor__"], false]
    - ["cf2146009", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__ceil__"], false]
    - ["cf2146010", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__trunc__"], false]
    - ["cf2146011", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__floor__"], false]
