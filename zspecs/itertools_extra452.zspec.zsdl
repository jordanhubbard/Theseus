spec: itertools_extra452
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers combinations, permutations, groupby, islice, compress, dropwhile, takewhile identity"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra452.name_identity:
  description: "itertools class __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: iname

  columns: [id, function, args, expected]
  rows:
    - [iname001, itertools.combinations.__name__.__eq__, ["combinations"], true]
    - [iname002, itertools.permutations.__name__.__eq__, ["permutations"], true]
    - [iname003, itertools.groupby.__name__.__eq__, ["groupby"], true]
    - [iname004, itertools.islice.__name__.__eq__, ["islice"], true]
    - [iname005, itertools.compress.__name__.__eq__, ["compress"], true]
    - [iname006, itertools.dropwhile.__name__.__eq__, ["dropwhile"], true]
    - [iname007, itertools.takewhile.__name__.__eq__, ["takewhile"], true]

table itertools_extra452.module_identity:
  description: "itertools class __module__ identity checks"
  kind: python_call_eq
