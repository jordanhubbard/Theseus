  columns: [id, function, args, expected]
  rows:
    - [ibas001, "itertools.combinations.__bases__[0].__name__.__eq__", ["object"], true]
    - [ibas002, "itertools.permutations.__bases__[0].__name__.__eq__", ["object"], true]
