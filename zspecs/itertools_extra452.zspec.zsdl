  rows:
    - [imod001, itertools.combinations.__module__.__eq__, ["itertools"], true]
    - [imod002, itertools.permutations.__module__.__eq__, ["itertools"], true]
    - [imod003, itertools.groupby.__module__.__eq__, ["itertools"], true]
    - [imod004, itertools.islice.__module__.__eq__, ["itertools"], true]
    - [imod005, itertools.compress.__module__.__eq__, ["itertools"], true]

table itertools_extra452.bases_identity:
  description: "itertools class __bases__ identity checks"
  kind: python_call_eq
  category: identity
