spec: hashlib_extra1681
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol dict-presence checks."
    - "hashlib hash types (SHA256, MD5, etc.) are C extension types; instances are not callable — __call__ not in dict → False."
    - "hashlib._hashlib.HASH is the C-level base hash type; it does not define __call__ in its own dict."
    - "Hash types define update, digest, hexdigest, copy, block_size, digest_size in their own dicts."
    - "hashlib.md5 and hashlib.sha256 are C-level constructor functions (HASH type), not classes with __call__ in their own dict."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: callable_protocol
#
# hashlib hash types are C extension types.  None define __call__ in their
# own __dict__; instances of hash types are not callable.
# ---------------------------------------------------------------------------

table hashlib_extra1681.callable_protocol:
  description: "hashlib hash types __call__ dict-presence checks (wave 559 _extra1681) — hashlib._hashlib.HASH.__dict__.__contains__('__call__')==False (HASH is a C extension type; it does not expose tp_call via its Python-visible __dict__; hash objects such as sha256 instances are not designed to be called as functions); verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1681

  columns: [id, function, args, expected]
  rows:
    - ["hl1681001", "hashlib._hashlib.HASH.__dict__.__contains__", ["__call__"],  false]
    - ["hl1681002", "hashlib._hashlib.HASH.__dict__.__contains__", ["update"],    true]
    - ["hl1681003", "hashlib._hashlib.HASH.__dict__.__contains__", ["digest"],    true]
    - ["hl1681004", "hashlib._hashlib.HASH.__dict__.__contains__", ["hexdigest"], true]
    - ["hl1681005", "hashlib._hashlib.HASH.__dict__.__contains__", ["copy"],      true]

# ---------------------------------------------------------------------------
# Table 2: hash_method_attrs
#
# Verifies further method and attribute presence in hashlib._hashlib.HASH.
# block_size and digest_size are numeric attributes (not methods) exposed
# on the C-level HASH type.  __reduce__ may or may not be defined at the
# C level; the presence of digest/hexdigest/update/copy is stable.
# ---------------------------------------------------------------------------

table hashlib_extra1681.hash_method_attrs:
  description: "hashlib._hashlib.HASH own-dict method and attribute presence (wave 559 _extra1681) — verifies that the C-level HASH type exposes its core cryptographic API (update, digest, hexdigest, copy) and standard descriptor attributes (block_size, digest_size, name) in its own __dict__; __call__ is absent because HASH instances are not callable; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1681

  columns: [id, function, args, expected]
  rows:
    - ["hl1681010", "hashlib._hashlib.HASH.__dict__.__contains__", ["__call__"],    false]
    - ["hl1681011", "hashlib._hashlib.HASH.__dict__.__contains__", ["update"],      true]
    - ["hl1681012", "hashlib._hashlib.HASH.__dict__.__contains__", ["digest"],      true]
    - ["hl1681013", "hashlib._hashlib.HASH.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl1681014", "hashlib._hashlib.HASH.__dict__.__contains__", ["copy"],        true]
    - ["hl1681015", "hashlib._hashlib.HASH.__dict__.__contains__", ["block_size"],  true]
    - ["hl1681016", "hashlib._hashlib.HASH.__dict__.__contains__", ["digest_size"], true]
    - ["hl1681017", "hashlib._hashlib.HASH.__dict__.__contains__", ["name"],        true]

# ---------------------------------------------------------------------------
# Table 3: hash_type_identity
#
# Verifies module and metatype identity for hashlib._hashlib.HASH.
# HASH is a C extension type; its __module__ is '_hashlib'.
# ---------------------------------------------------------------------------

table hashlib_extra1681.hash_type_identity:
  description: "hashlib._hashlib.HASH module and metatype identity checks (wave 559 _extra1681) — verifies __name__, __module__, and __class__.__name__ for the C-level HASH type; HASH.__module__ == '_hashlib' because it is defined in the _hashlib C accelerator module; HASH.__class__.__name__ == 'type' confirming it is a regular Python type object; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1681

  columns: [id, function, args, expected]
  rows:
    - ["hl1681020", "hashlib._hashlib.HASH.__dict__.__contains__", ["__call__"],  false]
    - ["hl1681021", "hashlib._hashlib.HASH.__name__.__eq__",        ["HASH"],      true]
    - ["hl1681022", "hashlib._hashlib.HASH.__module__.__eq__",      ["_hashlib"],  true]
    - ["hl1681023", "hashlib._hashlib.HASH.__class__.__name__.__eq__", ["type"],  true]
