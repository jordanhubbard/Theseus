spec: country_list
version: ">=2.0.0"
backend: node(country-list)

docs: https://www.npmjs.com/package/country-list

provenance:
  derived_from:
    - "country-list README — https://www.npmjs.com/package/country-list"
    - "Test vectors verified with country-list via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "country-list source"
  notes:
    - "country-list is an npm package. Install: npm install country-list"
    - "getName(code) returns the country name for a 2-letter ISO code."
    - "getCode(name) returns the ISO code for a country name."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns country name string or ISO code string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table country_list.getName:
  kind: node_module_call_eq
  function: getName
  category: lookup
  id_prefix: clgn

  columns: [id, args, expected]
  rows:
    - [us, ["US"], "United States of America (the)"]
    - [de, ["DE"], "Germany"]
    - [jp, ["JP"], "Japan"]

table country_list.getCode:
  kind: node_module_call_eq
  function: getCode
  category: lookup
  id_prefix: clgc

  columns: [id, args, expected]
  rows:
    - [germany, ["Germany"], "DE"]
    - [france,  ["France"],  "FR"]

