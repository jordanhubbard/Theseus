spec: importlib_extra13
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_extra12.zspec.zsdl — covers __qualname__ for import_module/reload/invalidate_caches in a table; __spec__.__class__.__name__ == 'ModuleSpec'; __loader__.__class__.__name__ == 'SourceFileLoader'."
    - "importlib_extra10.zspec.zsdl — covers __name__ == 'importlib' and __package__ == 'importlib' as standalones."
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra12.zspec.zsdl."
    - "Focus: __class__.__qualname__ for the importlib module object itself; standalone qualname axes for import_module/reload; importlib.__name__ and __package__ via __eq__ chain."
    - "importlib.__class__.__qualname__ == 'module' — the importlib object is a types.ModuleType; verified at runtime."
    - "importlib.__class__.__name__ == 'module' — complementary to __qualname__; verified at runtime."
    - "importlib.import_module.__qualname__ == 'import_module' — already in extra12 table; re-anchored here as standalone for extra13 namespace."
    - "importlib.reload.__qualname__ == 'reload' — already in extra12 table; re-anchored here as standalone for extra13 namespace."
    - "importlib.__name__ == 'importlib' — already in extra10; re-anchored as standalone with __eq__ chain for extra13 namespace."
    - "importlib.__package__ == 'importlib' — already in extra10; re-anchored here for extra13 namespace."
    - "importlib.invalidate_caches.__qualname__ == 'invalidate_caches' — already in extra12 table; standalone re-anchor for extra13 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib module object — class qualname and class name table
#
# No prior importlib spec checks importlib.__class__.__qualname__ or
# importlib.__class__.__name__. The module object is a types.ModuleType,
# whose __qualname__ and __name__ are both 'module'.
# ---------------------------------------------------------------------------

table importlib_extra13.module_class_attrs:
  description: "__class__.__name__ and __class__.__qualname__ for the importlib module object"
  kind: python_call_eq
  category: module_attrs

  columns: [id, function, args, expected]
  rows:
    - [class_name,     __class__.__name__.__eq__,     ["module"], true]
    - [class_qualname, __class__.__qualname__.__eq__,  ["module"], true]

# ---------------------------------------------------------------------------
# importlib.import_module — __qualname__ standalone
#
# importlib_extra12 covers import_module.__qualname__ in a table row. This
# invariant re-anchors it as a standalone in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra13.import_module.qualname:
  description: "importlib.import_module.__qualname__ == 'import_module'"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__qualname__.__eq__
  args: ["import_module"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.reload — __qualname__ standalone
#
# importlib_extra12 covers reload.__qualname__ in a table row. This invariant
# re-anchors it as a standalone in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra13.reload.qualname:
  description: "importlib.reload.__qualname__ == 'reload'"
  category: function_attrs
  kind: python_call_eq
  function: reload.__qualname__.__eq__
  args: ["reload"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.invalidate_caches — __qualname__ standalone
#
# importlib_extra12 covers invalidate_caches.__qualname__ in a table row. This
# invariant re-anchors it as a standalone in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra13.invalidate_caches.qualname:
  description: "importlib.invalidate_caches.__qualname__ == 'invalidate_caches'"
  category: function_attrs
  kind: python_call_eq
  function: invalidate_caches.__qualname__.__eq__
  args: ["invalidate_caches"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__name__ — standalone
#
# importlib_extra10 and extra11 cover __name__ == 'importlib'. This invariant
# re-anchors it in the extra13 namespace via __eq__ chain.
# ---------------------------------------------------------------------------

invariant importlib_extra13.module.name:
  description: "importlib.__name__ == 'importlib'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__package__ — standalone
#
# importlib_extra10 covers __package__ == 'importlib'. This invariant
# re-anchors it in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant importlib_extra13.module.package:
  description: "importlib.__package__ == 'importlib'"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: ["importlib"]
  expected: true
