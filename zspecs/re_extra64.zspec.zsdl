spec: re_extra64
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra63.zspec.zsdl — covers re.error.__init__.__qualname__.__eq__('PatternError.__init__'); Pattern.subn.__qualname__.__eq__('Pattern.subn'); Match.span/groupdict/expand __qualname__.__eq__(); module-level search/compile/match/fullmatch/sub/findall __qualname__.__eq__() re-anchors."
    - "re_extra62.zspec.zsdl — covers re.__loader__.__class__.__name__.__eq__('SourceFileLoader'); re.__spec__ class identity checks."
    - "re_extra56.zspec.zsdl — covers search/compile/sub/findall __qualname__.__eq__() as namespace re-anchors; Pattern/Match/error/RegexFlag __dict__.__class__.__name__.__eq__('mappingproxy')."
    - "re_extra55.zspec.zsdl — covers search/compile/match/fullmatch/sub/findall/subn/split/escape/purge __qualname__.__eq__()."
    - "re_extra8.zspec.zsdl — covers search.__qualname__.__eq__('search') and related module-level function qualnames."
  notes:
    - "This spec extends re_extra63.zspec.zsdl."
    - "Wave 228 theme: __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks."
    - "re.search.__annotations__.__class__.__name__.__eq__('dict') — re module is implemented in pure Python (Lib/re/__init__.py). re.search is a regular Python function and has __annotations__ as a dict. search.__annotations__ is {} (empty dict) because no parameter annotations are declared. __annotations__.__class__.__name__ is 'dict'. No prior re spec checks search.__annotations__.__class__.__name__.__eq__('dict'). Novel annotation class identity anchor in reann64 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.compile.__annotations__.__class__.__name__.__eq__('dict') — same pattern as re.search; compile is a pure Python function with __annotations__ == {} (empty dict). Novel annotation class identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__globals__.__class__.__name__.__eq__('dict') — re.search is a pure Python function and carries __globals__ (the re module namespace dict). __globals__.__class__.__name__ is 'dict'. No prior re spec checks search.__globals__.__class__.__name__.__eq__('dict'). Novel __globals__ class identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__globals__.__contains__('search') — the re module namespace contains 'search' as a key. No prior re spec checks search.__globals__.__contains__('search'). Novel __globals__ key content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__globals__.__contains__('compile') — the re module namespace also contains 'compile' as a key. Novel __globals__ key content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__doc__.__contains__('pattern') — re.error.__doc__ contains the text 'pattern: The regular expression pattern'. The word 'pattern' appears. No prior re spec checks re.error.__doc__.__contains__(). Novel __doc__ content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.search and re.compile __annotations__.__class__.__name__.__eq__('dict')
#
# re module is pure Python (Lib/re/__init__.py). search and compile are regular
# Python functions. Python functions always have __annotations__ which is a dict.
# With no parameter annotations the dict is empty {}.
#
#   re.search.__annotations__.__class__.__name__ == 'dict'
#   re.compile.__annotations__.__class__.__name__ == 'dict'
#
# No prior re spec checks __annotations__.__class__.__name__.__eq__('dict') for
# any re module function. Novel annotation class identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra64.func_annotations_class:
  description: "re.search and re.compile __annotations__.__class__.__name__.__eq__('dict') — re module is pure Python; search and compile are Python functions with __annotations__=={} (empty dict); __annotations__.__class__.__name__ is 'dict'; no prior re spec checks __annotations__.__class__.__name__.__eq__('dict') for any re function; novel annotation class identity anchors in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: annotation_class_identity
  id_prefix: reann64ann

  columns: [id, function, args, expected]
  rows:
    - [search_ann_class_eq,  search.__annotations__.__class__.__name__.__eq__,  ["dict"], true]
    - [compile_ann_class_eq, compile.__annotations__.__class__.__name__.__eq__, ["dict"], true]

# ---------------------------------------------------------------------------
# re.search.__globals__ class identity and key content
#
# re.search is a pure Python function and carries __globals__ pointing at the
# re module namespace dict. The namespace contains 'search' and 'compile' as keys.
#
#   re.search.__globals__.__class__.__name__ == 'dict'
#   'search'  in re.search.__globals__        == True
#   'compile' in re.search.__globals__        == True
#
# No prior re spec checks search.__globals__ class identity or key content.
# Novel __globals__ anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra64.search_globals:
  description: "re.search.__globals__.__class__.__name__.__eq__('dict') and __contains__('search') and __contains__('compile') — re.search is a pure Python function; __globals__ is the re module namespace dict; __class__.__name__ is 'dict'; 'search' and 'compile' are keys in the namespace; no prior re spec checks search.__globals__ class identity or key content; novel __globals__ anchors in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: globals_dict_identity
  id_prefix: reann64glb

  columns: [id, function, args, expected]
  rows:
    - [globals_class_eq,          search.__globals__.__class__.__name__.__eq__, ["dict"],    true]
    - [globals_contains_search,   search.__globals__.__contains__,              ["search"],  true]
    - [globals_contains_compile,  search.__globals__.__contains__,              ["compile"], true]

# ---------------------------------------------------------------------------
# re.error.__doc__.__contains__ content check
#
# re.error.__doc__ is:
#   'Exception raised for invalid regular expressions.\n\nAttributes:\n\n
#    msg: The unformatted error message\n    pattern: The regular expression pattern\n...'
#
# The word 'pattern' appears in the docstring. 'Exception' also appears.
# No prior re spec checks re.error.__doc__.__contains__(). Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra64.error_doc_contains:
  description: "re.error.__doc__.__contains__('pattern') and __contains__('Exception') — re.error.__doc__ describes the exception and lists attributes including 'pattern: The regular expression pattern'; both 'pattern' and 'Exception' appear; no prior re spec checks re.error.__doc__.__contains__(); novel __doc__ content anchors in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: reann64errdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_pattern,   error.__doc__.__contains__, ["pattern"],   true]
    - [doc_contains_exception, error.__doc__.__contains__, ["Exception"], true]

invariant re_extra64.search_annotations_class:
  description: "re.search.__annotations__.__class__.__name__.__eq__('dict') == True — re module is pure Python; search.__annotations__=={} (empty dict); __class__.__name__ is 'dict'; no prior re spec checks search.__annotations__.__class__.__name__.__eq__('dict'); novel annotation class identity anchor in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: annotation_class_identity
  kind: python_call_eq
  function: search.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant re_extra64.compile_annotations_class:
  description: "re.compile.__annotations__.__class__.__name__.__eq__('dict') == True — re module is pure Python; compile.__annotations__=={} (empty dict); __class__.__name__ is 'dict'; no prior re spec checks compile.__annotations__.__class__.__name__.__eq__('dict'); novel annotation class identity anchor in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: annotation_class_identity
  kind: python_call_eq
  function: compile.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant re_extra64.search_globals_class:
  description: "re.search.__globals__.__class__.__name__.__eq__('dict') == True — re.search is a pure Python function; __globals__ is the re module namespace dict; __class__.__name__ is 'dict'; no prior re spec checks search.__globals__.__class__.__name__.__eq__('dict'); novel __globals__ class identity anchor in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: globals_dict_identity
  kind: python_call_eq
  function: search.__globals__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant re_extra64.search_globals_contains_search:
  description: "re.search.__globals__.__contains__('search') == True — re.search.__globals__ is the re module namespace dict; 'search' is a key in the namespace because the re module defines search at module level; no prior re spec checks search.__globals__.__contains__('search'); novel __globals__ key content anchor in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: globals_dict_identity
  kind: python_call_eq
  function: search.__globals__.__contains__
  args: ["search"]
  expected: true

invariant re_extra64.error_doc_contains_pattern:
  description: "re.error.__doc__.__contains__('pattern') == True — re.error.__doc__ lists attributes including 'pattern: The regular expression pattern'; 'pattern' appears; no prior re spec checks re.error.__doc__.__contains__(); novel __doc__ content anchor in reann64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: error.__doc__.__contains__
  args: ["pattern"]
  expected: true
