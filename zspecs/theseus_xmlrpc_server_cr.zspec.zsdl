spec: theseus_xmlrpc_server_cr
version: ">=3.0"
backend: python_cleanroom(theseus_xmlrpc_server_cr)
blocks: xmlrpc.server

docs: https://docs.python.org/3/library/xmlrpc.server.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xmlrpc.server.html"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/server.py"
  notes:
    - "Clean-room xmlrpc.server module. Do NOT import xmlrpc.server."

error_model: python_exceptions

invariant theseus_xmlrpc_server_cr.xmlrpcserver2_classes:
  description: "SimpleXMLRPCServer and MultiPathXMLRPCServer classes exist"
  category: behavior
  kind: python_call_eq
  function: xmlrpcserver2_classes
  args: []
  expected: true

invariant theseus_xmlrpc_server_cr.xmlrpcserver2_dispatcher:
  description: "SimpleXMLRPCDispatcher can be created and methods registered"
  category: behavior
  kind: python_call_eq
  function: xmlrpcserver2_dispatcher
  args: []
  expected: true

invariant theseus_xmlrpc_server_cr.xmlrpcserver2_dispatch:
  description: "_dispatch() resolves and calls a registered method"
  category: behavior
  kind: python_call_eq
  function: xmlrpcserver2_dispatch
  args: []
  expected: true
