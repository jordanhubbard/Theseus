spec: concurrent_futures_extra60
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __defaults__ and __code__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra59.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__/__module__=='builtins' tables (extra47/extra49), ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins') (extra52), as_completed/__class__.__module__.__eq__('builtins') (extra52), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function') (extra52), class __repr__.__class__.__name__ tables (extra53), class __weakref__.__class__.__name__ tables (extra53), exception __repr__.__class__.__name__ tables (extra53), cf.__all__.__class__.__name__.__eq__('list') (extra54), cf.__all__.__len__()==14 (extra54), __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra54), cf.__all__.__contains__ membership checks (extra55), cf.__package__.__eq__('concurrent.futures') (extra55), Future/Executor __doc__.__class__.__name__.__eq__('str') (extra55), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra56), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra57), Future/__init__ and ThreadPoolExecutor/__init__ and Future.result/done/cancel/exception and ThreadPoolExecutor.submit/shutdown __qualname__.__eq__ (extra58), wait/as_completed __annotations__.__class__.__name__.__eq__('dict'), wait __globals__.__class__.__name__.__eq__('dict'), wait __globals__.__contains__('wait'), Future.__doc__.__contains__('Represents'), ThreadPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType') (extra59)."
    - "This spec covers (cfcode60 namespace): wave 229 theme — __defaults__ and __code__ checks for function parameters + __closure__ identity. NEW in extra60: wait.__defaults__.__class__.__name__.__eq__('tuple') — wait(fs, timeout=None, return_when=ALL_COMPLETED) has __defaults__==(None, 'ALL_COMPLETED') a two-element tuple; no prior cf spec has checked wait.__defaults__.__class__.__name__ via __eq__; as_completed.__defaults__.__class__.__name__.__eq__('tuple') — as_completed(fs, timeout=None) has __defaults__==(None,) a one-element tuple; wait.__code__.__class__.__name__.__eq__('code') and as_completed.__code__.__class__.__name__.__eq__('code') — both are pure-Python functions with code objects; Future.__init__.__defaults__.__class__.__name__.__eq__('NoneType') — Future() takes no default arguments so __defaults__ is None."
    - "concurrent.futures.wait.__defaults__ == (None, 'ALL_COMPLETED'). wait(fs, timeout=None, return_when=ALL_COMPLETED) has two positional-or-keyword parameters with defaults. __defaults__ is a two-element tuple (None, 'ALL_COMPLETED'). __defaults__.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__defaults__ == (None,). as_completed(fs, timeout=None) has one positional-or-keyword parameter with a default (timeout=None). __defaults__ is a one-element tuple (None,). __defaults__.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.__class__.__name__ == 'code'. wait is a pure-Python function defined in Lib/concurrent/futures/_base.py. All pure-Python functions have a __code__ attribute that is a code object. __class__.__name__ of a code object is 'code'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.__class__.__name__ == 'code'. as_completed is a pure-Python generator function defined in Lib/concurrent/futures/_base.py. Its __code__ attribute is a code object with __class__.__name__ == 'code'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__init__.__defaults__ is None. Future() accepts no arguments with defaults — Future.__init__ takes only self. __defaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures function __defaults__.__class__.__name__ checks — extra60
#
# Wave 229 theme: __defaults__ and __code__ checks for function parameters.
#
# wait(fs, timeout=None, return_when=ALL_COMPLETED) has __defaults__==
# (None, 'ALL_COMPLETED'), a two-element tuple.
# as_completed(fs, timeout=None) has __defaults__==(None,), a one-element tuple.
# Future.__init__ takes no default arguments so __defaults__ is None (NoneType).
#
# NEW: no prior cf spec has checked __defaults__.__class__.__name__ via __eq__
# for wait, as_completed, or Future.__init__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra60.function_defaults_class_name:
  description: "concurrent.futures function __defaults__.__class__.__name__.__eq__ checks in cfcode60 namespace — wave 229 theme: __defaults__ class identity; wait(fs, timeout=None, return_when=ALL_COMPLETED) has __defaults__==(None, 'ALL_COMPLETED') a two-element tuple; as_completed(fs, timeout=None) has __defaults__==(None,) a one-element tuple; Future.__init__ has no defaults so __defaults__ is None (NoneType); NEW in extra60: no prior cf spec has checked __defaults__.__class__.__name__ via __eq__ for these; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: cfcode60

  columns: [id, function, args, expected, description]
  rows:
    - [wait_defaults_class,         wait.__defaults__.__class__.__name__.__eq__,         ["tuple"],    true, "wait.__defaults__.__class__.__name__ == 'tuple' — wait(fs, timeout=None, return_when=ALL_COMPLETED) has two positional-or-keyword parameters with defaults; __defaults__ is the two-element tuple (None, 'ALL_COMPLETED'); tuple.__class__.__name__ is 'tuple'; NEW in extra60: first __defaults__.__class__.__name__.__eq__ check for wait in any cf spec; verified with Python 3.14.3"]
    - [as_completed_defaults_class, as_completed.__defaults__.__class__.__name__.__eq__, ["tuple"],    true, "as_completed.__defaults__.__class__.__name__ == 'tuple' — as_completed(fs, timeout=None) has one positional-or-keyword parameter with a default (timeout=None); __defaults__ is the one-element tuple (None,); tuple.__class__.__name__ is 'tuple'; NEW in extra60: first __defaults__.__class__.__name__.__eq__ check for as_completed in any cf spec; verified with Python 3.14.3"]
    - [future_init_defaults_class,  Future.__init__.__defaults__.__class__.__name__.__eq__, ["NoneType"], true, "Future.__init__.__defaults__.__class__.__name__ == 'NoneType' — Future() accepts no arguments with defaults; Future.__init__ takes only self; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra60: first __defaults__.__class__.__name__.__eq__ check for Future.__init__ in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures function __code__.__class__.__name__ checks — extra60
#
# Wave 229 theme: __code__ checks for function parameters.
#
# wait and as_completed are pure-Python functions. All pure-Python functions
# have a __code__ attribute that is a code object. The type of a code object
# is <class 'code'>, so __class__.__name__ is 'code'.
#
# NEW: no prior cf spec has checked __code__.__class__.__name__ via __eq__
# for wait or as_completed.
# ---------------------------------------------------------------------------

table concurrent_futures_extra60.function_code_class_name:
  description: "concurrent.futures function __code__.__class__.__name__.__eq__('code') checks in cfcode60 namespace — wave 229 theme: __code__ class identity; wait and as_completed are pure-Python functions defined in Lib/concurrent/futures/_base.py; all pure-Python functions have a __code__ attribute that is a code object; __class__.__name__ of a code object is 'code'; NEW in extra60: no prior cf spec has checked __code__.__class__.__name__ via __eq__ for wait or as_completed; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfcode60c

  columns: [id, function, args, expected, description]
  rows:
    - [wait_code_class,         wait.__code__.__class__.__name__.__eq__,         ["code"], true, "wait.__code__.__class__.__name__ == 'code' — wait is a pure-Python function defined in Lib/concurrent/futures/_base.py; all pure-Python functions have a __code__ attribute that is a code object; the type of a code object is <class 'code'>, so __class__.__name__ is 'code'; NEW in extra60: first __code__.__class__.__name__.__eq__ check for wait in any cf spec; verified with Python 3.14.3"]
    - [as_completed_code_class, as_completed.__code__.__class__.__name__.__eq__, ["code"], true, "as_completed.__code__.__class__.__name__ == 'code' — as_completed is a pure-Python generator function defined in Lib/concurrent/futures/_base.py; its __code__ attribute is a code object with __class__.__name__ == 'code'; NEW in extra60: first __code__.__class__.__name__.__eq__ check for as_completed in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra60
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra60.wait_defaults_class_name_eq:
  description: "concurrent.futures.wait.__defaults__.__class__.__name__.__eq__('tuple') returns True — wait(fs, timeout=None, return_when=ALL_COMPLETED) has two positional-or-keyword parameters with defaults; __defaults__ is the two-element tuple (None, 'ALL_COMPLETED'); tuple.__class__.__name__ is 'tuple'; NEW in extra60: no prior cf spec has checked wait.__defaults__.__class__.__name__ via __eq__; wave 229 first __defaults__ class identity invariant for wait in any cf spec; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: wait.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra60.as_completed_defaults_class_name_eq:
  description: "concurrent.futures.as_completed.__defaults__.__class__.__name__.__eq__('tuple') returns True — as_completed(fs, timeout=None) has one positional-or-keyword parameter with a default (timeout=None); __defaults__ is the one-element tuple (None,); tuple.__class__.__name__ is 'tuple'; NEW in extra60: no prior cf spec has checked as_completed.__defaults__.__class__.__name__ via __eq__; wave 229 invariant alongside wait defaults check; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: as_completed.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra60.future_init_defaults_class_name_eq:
  description: "concurrent.futures.Future.__init__.__defaults__.__class__.__name__.__eq__('NoneType') returns True — Future() accepts no arguments with defaults; Future.__init__ takes only self; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra60: no prior cf spec has checked Future.__init__.__defaults__.__class__.__name__ via __eq__; wave 229 first __defaults__ NoneType identity invariant for Future.__init__ in any cf spec; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: Future.__init__.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant concurrent_futures_extra60.wait_code_class_name_eq:
  description: "concurrent.futures.wait.__code__.__class__.__name__.__eq__('code') returns True — wait is a pure-Python function defined in Lib/concurrent/futures/_base.py; all pure-Python functions have a __code__ attribute that is a code object; __class__.__name__ of a code object is 'code'; NEW in extra60: no prior cf spec has checked wait.__code__.__class__.__name__ via __eq__; wave 229 first __code__ class identity invariant for wait in any cf spec; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant concurrent_futures_extra60.as_completed_code_class_name_eq:
  description: "concurrent.futures.as_completed.__code__.__class__.__name__.__eq__('code') returns True — as_completed is a pure-Python generator function defined in Lib/concurrent/futures/_base.py; its __code__ attribute is a code object with __class__.__name__ == 'code'; NEW in extra60: no prior cf spec has checked as_completed.__code__.__class__.__name__ via __eq__; wave 229 invariant alongside wait code check; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: as_completed.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true
