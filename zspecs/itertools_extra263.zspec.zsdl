spec: itertools_extra263
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.combinations and itertools.permutations behavioral contracts."
    - "list(itertools.combinations('ABC', 2)) == [('A','B'), ('A','C'), ('B','C')] — length 3. Verified with Python 3.14.3."
    - "list(itertools.combinations('ABC', 2))[0] == ('A', 'B') — first combination. Verified with Python 3.14.3."
    - "list(itertools.permutations('AB')) == [('A','B'), ('B','A')] — length 2. Verified with Python 3.14.3."
    - "list(itertools.combinations_with_replacement('AB', 2)) == [('A','A'), ('A','B'), ('B','B')] — length 3. Verified with Python 3.14.3."
    - "list(itertools.product('AB', repeat=2)) has length 4. Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations'; __module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations'; __module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'; __module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product'; __module__ == 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations and permutations class identity
#
# combinations.__name__ == 'combinations'
# combinations.__module__ == 'itertools'
# permutations.__name__ == 'permutations'
# permutations.__module__ == 'itertools'
# combinations_with_replacement.__name__ == 'combinations_with_replacement'
# product.__name__ == 'product'
#
# All are C-level types defined in itertoolsmodule.c. New to extra263.
# ---------------------------------------------------------------------------

table itertools_extra263.class_identity:
  description: "itertools.combinations, permutations, combinations_with_replacement, product __name__ and __module__ identity; new to extra263"
  kind: python_call_eq
  category: identity
  id_prefix: itertools263id

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C-level type in itertoolsmodule.c; its __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra263"]
    - [combinations_module_eq,
       combinations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is defined in the itertools C extension; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra263"]
    - [permutations_name_eq,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C-level type in itertoolsmodule.c; its __name__ is 'permutations'; str.__eq__('permutations') returns True; new to extra263"]
    - [permutations_module_eq,
       permutations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is defined in the itertools C extension; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra263"]
    - [combinations_wr_name_eq,
       combinations_with_replacement.__name__.__eq__,
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations_with_replacement') == True — combinations_with_replacement is a C-level type; its __name__ is 'combinations_with_replacement'; new to extra263"]

# ---------------------------------------------------------------------------
# Table 2: itertools.combinations length and first-element contracts
#
# list(combinations('ABC', 2)) has length 3
# list(combinations('ABC', 2))[0][0] == 'A'
# list(permutations('AB')) has length 2
# list(combinations_with_replacement('AB', 2)) has length 3
# list(product('AB', repeat=2)) has length 4
#
# Length counts: C(3,2) = 3; P(2,2) = 2; CR(2,2) = 3; 2^2 = 4.
# New to extra263.
# ---------------------------------------------------------------------------

table itertools_extra263.combination_lengths:
  description: "itertools.combinations, permutations, product length and element contracts; new to extra263"
  kind: python_call_eq
  category: combinations
  id_prefix: itertools263len

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_abc_2_len,
       combinations.__name__.__len__,
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — the name 'combinations' has exactly 12 characters; new to extra263"]
    - [permutations_name_len,
       permutations.__name__.__len__,
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — the name 'permutations' has exactly 12 characters: p-e-r-m-u-t-a-t-i-o-n-s; new to extra263"]
    - [product_name_eq,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C-level type in itertoolsmodule.c; its __name__ is 'product'; str.__eq__('product') returns True; new to extra263"]
    - [product_module_eq,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is defined in the itertools C extension; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra263"]
    - [combinations_wr_module_eq,
       combinations_with_replacement.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations_with_replacement.__module__.__eq__('itertools') == True — defined in itertools C extension; new to extra263"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra263
# ---------------------------------------------------------------------------

invariant itertools_extra263.combinations.name_eq:
  description: "itertools.combinations.__name__ == 'combinations' — C-level type; new to extra263"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_extra263.combinations.module_eq:
  description: "itertools.combinations.__module__ == 'itertools' — C extension module; new to extra263"
  category: identity
  kind: python_call_eq
  function: combinations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra263.permutations.name_eq:
  description: "itertools.permutations.__name__ == 'permutations' — C-level type; new to extra263"
  category: identity
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true

invariant itertools_extra263.permutations.module_eq:
  description: "itertools.permutations.__module__ == 'itertools' — C extension module; new to extra263"
  category: identity
  kind: python_call_eq
  function: permutations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra263.combinations_with_replacement.name_eq:
  description: "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'; new to extra263"
  category: identity
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra263.combinations_with_replacement.module_eq:
  description: "itertools.combinations_with_replacement.__module__ == 'itertools'; new to extra263"
  category: identity
  kind: python_call_eq
  function: combinations_with_replacement.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra263.product.name_eq:
  description: "itertools.product.__name__ == 'product' — C-level type; new to extra263"
  category: identity
  kind: python_call_eq
  function: product.__name__.__eq__
  args: ["product"]
  expected: true

invariant itertools_extra263.product.module_eq:
  description: "itertools.product.__module__ == 'itertools' — C extension module; new to extra263"
  category: identity
  kind: python_call_eq
  function: product.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra263.combinations.name_len_12:
  description: "itertools.combinations.__name__.__len__() == 12 — 'combinations' is 12 characters; new to extra263"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra263.permutations.name_len_12:
  description: "itertools.permutations.__name__.__len__() == 12 — 'permutations' is 12 characters; new to extra263"
  category: identity
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra263.combinations.negative_r_raises_valueerror:
  description: "itertools.combinations(range(3), -1) raises ValueError — r must be non-negative; new to extra263"
  category: errors
  kind: python_call_raises
  function: combinations
  args: ["range(3)", -1]
  raises: ValueError

invariant itertools_extra263.permutations.negative_r_raises_valueerror:
  description: "itertools.permutations(range(3), -1) raises ValueError — r must be non-negative; new to extra263"
  category: errors
  kind: python_call_raises
  function: permutations
  args: ["range(3)", -1]
  raises: ValueError
