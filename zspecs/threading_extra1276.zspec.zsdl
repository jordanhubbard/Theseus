spec: threading_extra1276
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 532 _extra1276: checks __subclasses__(), __mro__, and __bases__ type names for threading.Thread, threading.Timer, threading.Barrier, threading.Lock, threading.Event, threading.Semaphore, threading.Condition"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1276.thread_timer_barrier_inheritance_types:
  description: "threading.Thread, Timer, and Barrier __subclasses__, __mro__, and __bases__ type name checks"
  kind: python_call_eq
  category: thread_timer_barrier_inheritance_types
  id_prefix: th1276tb
  columns: [id, function, args, expected]
  rows:
    - [th1276tb001, threading.Thread.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [th1276tb002, threading.Thread.__mro__.__class__.__name__.__eq__,          ["tuple"], true]
    - [th1276tb003, threading.Thread.__bases__.__class__.__name__.__eq__,        ["tuple"], true]
    - [th1276tb004, threading.Timer.__subclasses__().__class__.__name__.__eq__,  ["list"],  true]
    - [th1276tb005, threading.Timer.__mro__.__class__.__name__.__eq__,           ["tuple"], true]
    - [th1276tb006, threading.Timer.__bases__.__class__.__name__.__eq__,         ["tuple"], true]
    - [th1276tb007, threading.Barrier.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [th1276tb008, threading.Barrier.__mro__.__class__.__name__.__eq__,          ["tuple"], true]
    - [th1276tb009, threading.Barrier.__bases__.__class__.__name__.__eq__,        ["tuple"], true]

