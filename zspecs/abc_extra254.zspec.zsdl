table abc_extra254.reversible_class_identity:
  description: "collections.abc.Reversible(len=10) class identity — inherits from Iterable(len=8); defined in collections.abc(len=15); __abstractmethods__ has 2 members: __iter__ and __reversed__ — only ABC in spec with 2 abstract methods; verified with Python 3.14.3"
