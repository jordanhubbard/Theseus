    - [rv_base_len,         "Reversible.__bases__[0].__name__.__len__",            [],                    8,    "collections.abc.Reversible.__bases__[0].__name__.__len__() == 8 — Iterable(len=8) is base of both Iterator and Reversible; verified with Python 3.14.3"]
    - [rv_am_len,           Reversible.__abstractmethods__.__len__,                [],                    2,    "collections.abc.Reversible.__abstractmethods__.__len__() == 2 — only ABC in spec with 2 abstract methods; verified with Python 3.14.3"]
