# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra254
# ---------------------------------------------------------------------------

invariant abc_extra254.iterator_base_is_iterable:
  description: "collections.abc.Iterator.__bases__[0].__name__.__eq__('Iterable') returns True — Iterator inherits from Iterable; both Iterator and Iterable have __name__ length 8; Reversible also inherits from Iterable; Iterable is the common base for both Iterator and Reversible; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Iterator.__bases__[0].__name__.__eq__"
  args: ["Iterable"]
  expected: true

invariant abc_extra254.reversible_has_two_abstract_methods:
  description: "collections.abc.Reversible.__abstractmethods__.__len__() == 2 — Reversible is the only ABC in this spec with 2 abstract methods (__iter__ and __reversed__); Iterator, Iterable, and Container each have 1 abstract method; Reversible inherits from Iterable so it must implement __iter__ in addition to __reversed__; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Reversible.__abstractmethods__.__len__
  args: []
  expected: 2

invariant abc_extra254.container_abstract_method_is_contains:
  description: "collections.abc.Container.__abstractmethods__.__contains__('__contains__') returns True — Container's single abstract method is __contains__; Container.__name__ has length 9; Container inherits directly from object; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Container.__abstractmethods__.__contains__"
  args: ["__contains__"]
  expected: true
