table abc_extra254.iterator_class_identity:
  description: "collections.abc.Iterator(len=8) class identity — inherits from Iterable(len=8, same length); defined in collections.abc(len=15); __abstractmethods__ has 1 member: __next__; Iterator and Iterable share name length 8; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc254it

  columns: [id, function, args, expected, description]
  rows:
    - [it_name_eq,          Iterator.__name__.__eq__,                              ["Iterator"],          true, "collections.abc.Iterator.__name__ == 'Iterator'; verified with Python 3.14.3"]
    - [it_name_len,         Iterator.__name__.__len__,                             [],                    8,    "collections.abc.Iterator.__name__.__len__() == 8 — same length as Iterable.__name__; verified with Python 3.14.3"]
    - [it_mod_eq,           Iterator.__module__.__eq__,                            ["collections.abc"],   true, "collections.abc.Iterator.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [it_mod_len,          Iterator.__module__.__len__,                           [],                    15,   "collections.abc.Iterator.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [it_base_eq,          "Iterator.__bases__[0].__name__.__eq__",               ["Iterable"],          true, "collections.abc.Iterator.__bases__[0].__name__ == 'Iterable' — Iterator inherits from Iterable; verified with Python 3.14.3"]
    - [it_base_len,         "Iterator.__bases__[0].__name__.__len__",              [],                    8,    "collections.abc.Iterator.__bases__[0].__name__.__len__() == 8 — Iterable name length equals Iterator name length; verified with Python 3.14.3"]
    - [it_am_len,           Iterator.__abstractmethods__.__len__,                  [],                    1,    "collections.abc.Iterator.__abstractmethods__.__len__() == 1; verified with Python 3.14.3"]
    - [it_am_next,          "Iterator.__abstractmethods__.__contains__",           ["__next__"],          true, "collections.abc.Iterator.__abstractmethods__.__contains__('__next__') == True; verified with Python 3.14.3"]

