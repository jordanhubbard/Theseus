spec: abc_extra254
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Iterator.__name__ == 'Iterator' (len=8); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Iterable' (len=8); __abstractmethods__ == frozenset({'__next__'}) (len=1)."
    - "collections.abc.Iterable.__name__ == 'Iterable' (len=8); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ == frozenset({'__iter__'}) (len=1)."
    - "collections.abc.Container.__name__ == 'Container' (len=9); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ == frozenset({'__contains__'}) (len=1)."
    - "collections.abc.Reversible.__name__ == 'Reversible' (len=10); __bases__[0].__name__ == 'Iterable' (len=8); __abstractmethods__ == frozenset({'__iter__', '__reversed__'}) (len=2)."
    - "Iterator and Iterable share __name__ length 8; Iterator.__bases__[0] is Iterable (Iterator is a subclass of Iterable); Reversible.__bases__[0] is also Iterable."
    - "Iterable, Container both inherit directly from object; Reversible inherits from Iterable; Iterator inherits from Iterable."
    - "Reversible is the only one with 2 abstract methods (__iter__ and __reversed__); the other three have 1 each."
    - "Container has the longest name (len=9); Reversible has the longest name (len=10) and most abstract methods (2)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

