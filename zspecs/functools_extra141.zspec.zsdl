  rows:
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C extension type; its __name__ is 'partial' as registered in _functoolsmodule.c; str.__eq__('partial') returns True; new to extra141"]
    - [partial_name_len_eq_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — __name__ is 'partial' which has 7 characters; len('partial') == 7; new to extra141"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial's __module__ is 'functools'; str.__eq__('functools') returns True; new to extra141"]
    - [partial_module_len_eq_9,
       "partial.__module__.__len__",
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — __module__ is 'functools' which has 9 characters; len('functools') == 9; new to extra141"]
    - [partial_class_name_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra141"]
    - [partial_class_name_len_eq_4,
       "partial.__class__.__name__.__len__",
       [],
       4,
       "functools.partial.__class__.__name__.__len__() == 4 — __class__.__name__ is 'type' which has 4 characters; len('type') == 4; new to extra141"]
    - [partial_qualname_eq,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial's __qualname__ is 'partial', matching its __name__; str.__eq__('partial') returns True; new to extra141"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial MRO and bases
#
# Wave 264 theme: functools.partial MRO length and base class.
#
# len(functools.partial.__mro__) == 2 — MRO is [partial, object]
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__mro__[0].__name__ == 'partial'
# functools.partial.__mro__[1].__name__ == 'object'
#
# partial inherits only from object. New to extra141.
# ---------------------------------------------------------------------------

table functools_extra141.partial_mro:
  description: "functools.partial MRO: len==2, mro[0].__name__=='partial', mro[1].__name__=='object', bases[0].__name__=='object'; wave 264; new to extra141"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialmro141

  columns: [id, function, args, expected, description]
  rows:
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial's MRO is [partial, object]; it inherits only from object; len(__mro__) is 2; new to extra141"]
    - [partial_mro_0_name_eq_partial,
       "partial.__mro__[0].__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__mro__[0].__name__.__eq__('partial') == True — the first entry in the MRO is partial itself; __name__ is 'partial'; str.__eq__('partial') returns True; new to extra141"]
    - [partial_mro_1_name_eq_object,
       "partial.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__mro__[1].__name__.__eq__('object') == True — the second entry in the MRO is the built-in object class; __name__ is 'object'; str.__eq__('object') returns True; new to extra141"]
    - [partial_bases_0_name_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial's sole direct base class is object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra141"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra141
# ---------------------------------------------------------------------------

invariant functools_extra141.cmp_to_key_qualname_len:
  description: "len(functools.cmp_to_key.__qualname__) == 10 — __qualname__ is 'cmp_to_key'; wave 264; new to extra141"
  kind: python_call_eq
  function: cmp_to_key.__qualname__.__len__
  args: []
  expected: 10

invariant functools_extra141.cmp_to_key_module_is_c_extension:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is a C builtin from the private _functools extension; wave 264; new to extra141"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra141.cmp_to_key_is_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin, not a Python function; wave 264; new to extra141"
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra141.partial_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C extension type; wave 264; new to extra141"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra141.partial_mro_len:
  description: "len(functools.partial.__mro__) == 2 — partial's MRO is [partial, object]; wave 264; new to extra141"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

