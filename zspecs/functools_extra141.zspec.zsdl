spec: functools_extra141
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.cmp_to_key C builtin identity; functools.partial C extension type identity, __name__, __module__, __mro__ (Wave 264)."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10) — cmp_to_key is a C builtin in _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' (len 10) — the C builtin's __module__ is '_functools', the private C extension. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' (len 26) — cmp_to_key is a C builtin, not a Python function. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' (len 7) — partial is a C extension type whose __name__ is 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' (len 9) — partial's __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' (len 4) — partial is a C extension type; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial' (len 7) — partial's __qualname__ matches its __name__. Verified with Python 3.14.3."
    - "len(functools.partial.__mro__) == 2 — partial's MRO is [partial, object]. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits only from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cmp_to_key C builtin identity
#
# Wave 264 theme: functools.cmp_to_key qualname, module, and class.
#
# functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10)
# functools.cmp_to_key.__module__ == '_functools' (len 10)
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' (len 26)
#
# cmp_to_key is implemented in Modules/_functoolsmodule.c as a C builtin.
# Its __module__ is '_functools' (the private C extension), not 'functools'.
# New to extra141.
# ---------------------------------------------------------------------------

table functools_extra141.cmp_to_key_identity:
  description: "functools.cmp_to_key C builtin identity: __qualname__ len 10, __module__=='_functools' len 10, __class__.__name__ len 26; wave 264; new to extra141"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscmptokey141

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_qualname_eq,
       "cmp_to_key.__qualname__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — cmp_to_key is a C builtin in _functoolsmodule.c; its __qualname__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra141"]
    - [cmp_to_key_qualname_len_eq_10,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — __qualname__ is 'cmp_to_key' which has 10 characters; len('cmp_to_key') == 10; new to extra141"]
    - [cmp_to_key_module_eq,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is a C builtin; its __module__ is '_functools', the private C extension module, not 'functools'; str.__eq__('_functools') returns True; new to extra141"]
    - [cmp_to_key_module_len_eq_10,
       "cmp_to_key.__module__.__len__",
       [],
       10,
       "functools.cmp_to_key.__module__.__len__() == 10 — __module__ is '_functools' which has 10 characters; len('_functools') == 10; new to extra141"]
    - [cmp_to_key_class_name_eq,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C builtin, not a Python function; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra141"]
    - [cmp_to_key_class_name_len_eq_26,
       "cmp_to_key.__class__.__name__.__len__",
       [],
       26,
       "functools.cmp_to_key.__class__.__name__.__len__() == 26 — __class__.__name__ is 'builtin_function_or_method' which has 26 characters; len('builtin_function_or_method') == 26; new to extra141"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial C extension type identity
#
# Wave 264 theme: functools.partial type identity, __name__, __module__, __class__.__name__.
#
# functools.partial.__name__ == 'partial' (len 7)
# functools.partial.__module__ == 'functools' (len 9)
# functools.partial.__class__.__name__ == 'type' (len 4)
# functools.partial.__qualname__ == 'partial' (len 7)
#
# partial is a C extension type in _functoolsmodule.c. Its metaclass is the
# built-in type. New to extra141.
# ---------------------------------------------------------------------------

table functools_extra141.partial_type_identity:
  description: "functools.partial C extension type identity: __name__ len 7, __module__ len 9, __class__.__name__=='type', __qualname__ len 7; wave 264; new to extra141"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial141

