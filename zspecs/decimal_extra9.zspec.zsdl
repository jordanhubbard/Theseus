spec: decimal_extra9
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras (decimal_extra through decimal_extra8)."
    - "decimal_extra8 covers: __float__, __pow__, is_zero (True/False), is_signed (True/False), adjusted(), normalize(), __round__(ndigits)."
    - "decimal_extra7 covers: __sub__, __mul__, __truediv__, __abs__, __neg__, comparison operators, copy_abs, copy_negate, __int__."
    - "No prior spec covers Decimal.to_integral_value() — round to nearest integer Decimal."
    - "No prior spec covers Decimal.sqrt() — square root."
    - "No prior spec covers Decimal.__mod__() — modulo operation."
    - "No prior spec covers Decimal.__floordiv__() — floor division."
    - "No prior spec covers Decimal.compare() — returns -1, 0, or 1 as a Decimal."
    - "No prior spec covers Decimal.max() — returns the larger of two Decimals."
    - "No prior spec covers Decimal.min() — returns the smaller of two Decimals."
    - "No prior spec covers Decimal.as_tuple().exponent for non-integer inputs."
    - "No prior spec covers Decimal.as_tuple().digits length."
    - "Decimal('1.5').to_integral_value().__str__() == '2' — rounds half-up to nearest integer (default ROUND_HALF_EVEN → 2)."
    - "Decimal('4').sqrt().__str__() == '2' — exact square root of perfect square."
    - "Decimal('10').__mod__(3).__str__() == '1' — 10 mod 3 == 1."
    - "Decimal('10').__floordiv__(3).__str__() == '3' — floor(10/3) == 3."
    - "Decimal('1').compare(2).__str__() == '-1' — 1 < 2 returns Decimal('-1') (int arg accepted)."
    - "Decimal('5').max(3).__str__() == '5' — max(5, 3) is 5 (int arg accepted)."
    - "Decimal('2').min(7).__str__() == '2' — min(2, 7) is 2 (int arg accepted)."
    - "Decimal('1.23').as_tuple().exponent == -2 — two decimal digits means exponent -2."
    - "Decimal('3.14').as_tuple().digits.__len__() == 3 — three significant digits."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# as_tuple — exponent and digits length for fractional values
#
# decimal.zspec.zsdl covers as_tuple().sign and as_tuple().exponent for
# Decimal('3.14') (exponent == -2). decimal_extra3 covers the DecimalTuple
# class name and exponent for Decimal('100') (exponent == 0) and as_tuple()
# class name for '1.5'. No prior spec directly accesses as_tuple().exponent for
# '1.23' or the length of as_tuple().digits as a standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra9.Decimal.as_tuple_exponent_1_23:
  description: "Decimal('1.23').as_tuple().exponent == -2 — two decimal digits give exponent -2"
  category: as_tuple
  kind: python_call_eq
  function: Decimal
  args: ["1.23"]
  method: as_tuple
  method_chain: exponent
  expected: -2

invariant decimal_extra9.Decimal.as_tuple_digits_len:
  description: "len(Decimal('3.14').as_tuple().digits) == 3 — three significant digits"
  category: as_tuple
  kind: python_call_eq
  function: Decimal
  args: ["3.14"]
  method: as_tuple
  method_chain: digits.__len__
  expected: 3

# ---------------------------------------------------------------------------
# to_integral_value — round to nearest integer Decimal
#
# to_integral_value() returns a Decimal with no fractional part.
# Decimal('1.5').to_integral_value() == Decimal('2') under ROUND_HALF_EVEN.
# Decimal('2.0').to_integral_value() == Decimal('2') — already integral.
# ---------------------------------------------------------------------------

invariant decimal_extra9.Decimal.to_integral_value_half:
  description: "Decimal('1.5').to_integral_value().__str__() == '2' — rounds to nearest even integer"
  category: rounding
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: to_integral_value
  method_chain: __str__
  expected: "2"

invariant decimal_extra9.Decimal.to_integral_value_exact:
  description: "Decimal('2.0').to_integral_value().__str__() == '2' — already integral value is unchanged"
  category: rounding
  kind: python_call_eq
  function: Decimal
  args: ["2.0"]
  method: to_integral_value
  method_chain: __str__
  expected: "2"

# ---------------------------------------------------------------------------
# sqrt — square root of a Decimal
#
# Decimal.sqrt() returns a Decimal approximation of the square root.
# For perfect squares the result is exact within the current precision.
# Decimal('4').sqrt() == Decimal('2') — exact.
# Decimal('9').sqrt() == Decimal('3') — exact.
# ---------------------------------------------------------------------------

invariant decimal_extra9.Decimal.sqrt_four:
  description: "Decimal('4').sqrt().__str__() == '2' — exact square root of perfect square 4"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["4"]
  method: sqrt
  method_chain: __str__
  expected: "2"

invariant decimal_extra9.Decimal.sqrt_nine:
  description: "Decimal('9').sqrt().__str__() == '3' — exact square root of perfect square 9"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["9"]
  method: sqrt
  method_chain: __str__
  expected: "3"

# ---------------------------------------------------------------------------
# __mod__ — modulo operation
#
# Decimal supports the modulo operator via __mod__.
# Decimal('10') % 3 == Decimal('1') — remainder of 10 divided by 3.
# Decimal('7') % 4 == Decimal('3') — remainder of 7 divided by 4.
# ---------------------------------------------------------------------------

invariant decimal_extra9.Decimal.mod_ten_three:
  description: "Decimal('10').__mod__(3).__str__() == '1' — 10 mod 3 == 1"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: __mod__
  method_args: [3]
  method_chain: __str__
  expected: "1"

invariant decimal_extra9.Decimal.mod_seven_four:
  description: "Decimal('7').__mod__(4).__str__() == '3' — 7 mod 4 == 3"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["7"]
  method: __mod__
  method_args: [4]
  method_chain: __str__
  expected: "3"

# ---------------------------------------------------------------------------
# __floordiv__ — floor division
#
# Decimal supports floor division via __floordiv__.
# Decimal('10') // 3 == Decimal('3') — floor(10/3) == 3.
# Decimal('7') // 2 == Decimal('3') — floor(7/2) == 3.
# ---------------------------------------------------------------------------

invariant decimal_extra9.Decimal.floordiv_ten_three:
  description: "Decimal('10').__floordiv__(3).__str__() == '3' — floor(10/3) == 3"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: __floordiv__
  method_args: [3]
  method_chain: __str__
  expected: "3"

invariant decimal_extra9.Decimal.floordiv_seven_two:
  description: "Decimal('7').__floordiv__(2).__str__() == '3' — floor(7/2) == 3"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["7"]
  method: __floordiv__
  method_args: [2]
  method_chain: __str__
  expected: "3"

# ---------------------------------------------------------------------------
# compare — returns Decimal(-1), Decimal(0), or Decimal(1)
#
# Decimal.compare(other) uses the IBM GDA compare operation. It returns
# a Decimal indicating the relative ordering: -1, 0, or 1.
# ---------------------------------------------------------------------------

invariant decimal_extra9.Decimal.compare_less:
  description: "Decimal('1').compare(2).__str__() == '-1' — 1 < 2 returns Decimal('-1') (int arg accepted)"
  category: comparison
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: compare
  method_args: [2]
  method_chain: __str__
  expected: "-1"

invariant decimal_extra9.Decimal.compare_equal:
  description: "Decimal('3').compare(3).__str__() == '0' — equal values return Decimal('0') (int arg accepted)"
  category: comparison
  kind: python_call_eq
  function: Decimal
  args: ["3"]
  method: compare
  method_args: [3]
  method_chain: __str__
  expected: "0"

invariant decimal_extra9.Decimal.compare_greater:
  description: "Decimal('5').compare(2).__str__() == '1' — 5 > 2 returns Decimal('1') (int arg accepted)"
  category: comparison
  kind: python_call_eq
  function: Decimal
  args: ["5"]
  method: compare
  method_args: [2]
  method_chain: __str__
  expected: "1"

# ---------------------------------------------------------------------------
# max and min — return the larger/smaller of two Decimals
#
# Decimal.max(other) returns the numerically larger value.
# Decimal.min(other) returns the numerically smaller value.
# These follow GDA rules and return a Decimal.
# ---------------------------------------------------------------------------

invariant decimal_extra9.Decimal.max_returns_larger:
  description: "Decimal('5').max(3).__str__() == '5' — max(5, 3) is 5 (int arg accepted)"
  category: comparison
  kind: python_call_eq
  function: Decimal
  args: ["5"]
  method: max
  method_args: [3]
  method_chain: __str__
  expected: "5"

invariant decimal_extra9.Decimal.min_returns_smaller:
  description: "Decimal('2').min(7).__str__() == '2' — min(2, 7) is 2 (int arg accepted)"
  category: comparison
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: min
  method_args: [7]
  method_chain: __str__
  expected: "2"
