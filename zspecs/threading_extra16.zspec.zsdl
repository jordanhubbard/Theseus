spec: threading_extra16
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra15."
    - "threading_extra covers: Process/__name__, active_count/__name__, etc."
    - "threading_extra3 covers: current_thread/__name__, main_thread/__name__."
    - "threading_extra4 covers: active_count/__name__, enumerate/__name__, settrace/__name__."
    - "threading_extra15 covers: Thread deprecated method __qualname__, module-level function __qualname__."
    - "NOT yet covered in any prior spec: Thread.__name__ == 'Thread' — class __name__."
    - "NOT yet covered: Thread.__module__ == 'threading' — class __module__."
    - "NOT yet covered: Thread.__qualname__ == 'Thread' — class __qualname__."
    - "NOT yet covered: Thread.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: Barrier.__name__ == 'Barrier' — class __name__."
    - "NOT yet covered: Barrier.__module__ == 'threading' — class __module__."
    - "NOT yet covered: Barrier.__qualname__ == 'Barrier' — class __qualname__."
    - "NOT yet covered: Timer.__name__ == 'Timer' — class __name__."
    - "NOT yet covered: Timer.__module__ == 'threading' — class __module__."
    - "NOT yet covered: Timer.__qualname__ == 'Timer' — class __qualname__."
    - "NOT yet covered: Event.__module__ == 'threading' — class __module__."
    - "NOT yet covered: Semaphore.__module__ == 'threading' — class __module__."
    - "NOT yet covered: Condition.__name__ == 'Condition' — class __name__."
    - "NOT yet covered: Condition.__module__ == 'threading' — class __module__."
    - "threading.Lock.__name__ == 'lock' (lowercase) — Lock is a C-implemented type from _thread."
    - "threading.Thread.__class__.__name__ == 'type' — Thread is a plain Python class."
    - "threading.Barrier.__qualname__ == 'Barrier' — top-level class, qualname == name."
    - "threading.Timer.__qualname__ == 'Timer' — Timer is a Thread subclass defined at module level."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread class identity — __name__, __module__, __qualname__, metaclass
#
# threading_extra11 covers Thread method __qualname__ values.
# threading_extra15 covers Thread deprecated method __qualname__.
# No prior spec checks Thread.__name__, Thread.__module__, Thread.__qualname__,
# or Thread.__class__.__name__ directly.
# ---------------------------------------------------------------------------

table threading_extra16.Thread_class_identity:
  description: "threading.Thread class has correct __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_names
  id_prefix: thdclsid

  columns: [id, function, args, expected]
  rows:
    - [name,    Thread.__name__.__eq__,    ["Thread"],    true]
    - [module,  Thread.__module__.__eq__,  ["threading"], true]
    - [qualname, Thread.__qualname__.__eq__, ["Thread"],  true]

invariant threading_extra16.Thread.metaclass:
  description: "threading.Thread.__class__.__name__ == 'type' — Thread is a plain Python class"
  category: class_types
  kind: python_call_eq
  function: Thread.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Lock __name__ — lowercase 'lock'
#
# threading.Lock is actually the C-implemented _thread.lock type. Its __name__
# is lowercase 'lock', not 'Lock'. No prior spec checks Lock.__name__ directly.
# ---------------------------------------------------------------------------

invariant threading_extra16.Lock.name:
  description: "threading.Lock.__name__ == 'lock' — C-implemented type has lowercase name"
  category: class_names
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

# ---------------------------------------------------------------------------
# Barrier and Timer class identity — __name__, __module__, __qualname__
#
# No prior spec checks Barrier or Timer __name__/__module__/__qualname__.
# Both are pure-Python classes defined in Lib/threading.py.
# Timer is a subclass of Thread defined at module level, so __qualname__ == 'Timer'.
# ---------------------------------------------------------------------------

table threading_extra16.Barrier_class_identity:
  description: "threading.Barrier class has correct __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_names
  id_prefix: barrclsid

  columns: [id, function, args, expected]
  rows:
    - [name,     Barrier.__name__.__eq__,     ["Barrier"],   true]
    - [module,   Barrier.__module__.__eq__,   ["threading"], true]
    - [qualname, Barrier.__qualname__.__eq__, ["Barrier"],   true]

table threading_extra16.Timer_class_identity:
  description: "threading.Timer class has correct __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_names
  id_prefix: timerclsid

  columns: [id, function, args, expected]
  rows:
    - [name,     Timer.__name__.__eq__,     ["Timer"],     true]
    - [module,   Timer.__module__.__eq__,   ["threading"], true]
    - [qualname, Timer.__qualname__.__eq__, ["Timer"],     true]

# ---------------------------------------------------------------------------
# Event, Semaphore, Condition __module__ checks
#
# No prior spec checks Event.__module__, Semaphore.__module__, or
# Condition.__module__. All three are pure-Python classes in Lib/threading.py.
# ---------------------------------------------------------------------------

table threading_extra16.sync_primitive_modules:
  description: "threading sync primitives have __module__ == 'threading'"
  kind: python_call_eq
  category: class_modules
  id_prefix: syncmod16

  columns: [id, function, args, expected]
  rows:
    - [Event,     Event.__module__.__eq__,     ["threading"], true]
    - [Semaphore, Semaphore.__module__.__eq__, ["threading"], true]
    - [Condition, Condition.__module__.__eq__, ["threading"], true]

invariant threading_extra16.Condition.name:
  description: "threading.Condition.__name__ == 'Condition'"
  category: class_names
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true
