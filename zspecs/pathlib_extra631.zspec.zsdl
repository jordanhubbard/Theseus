spec: pathlib_extra631
version: ">=3.9"
backend: python_module(pathlib)
docs: "Behavioral spec for pathlib.Path additional method qualnames"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Path methods and attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Qualnames verified via __qualname__ attribute on pathlib.Path method objects"
    - "Covers file system introspection, link, and navigation methods"
  created_at: "2026-04-12T00:00:00Z"

table pathlib_extra631.path_io_qualnames:
  description: "Qualname checks for pathlib.Path I/O methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: pl631qn
  columns: [id, function, args, expected]
  rows:
    - [pl631qn001, pathlib.Path.read_bytes.__qualname__.__eq__, ["Path.read_bytes"], true]
    - [pl631qn002, pathlib.Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true]
    - [pl631qn003, pathlib.Path.touch.__qualname__.__eq__, ["Path.touch"], true]

table pathlib_extra631.path_link_qualnames:
  description: "Qualname checks for pathlib.Path link methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: pl631lk
  columns: [id, function, args, expected]
  rows:
    - [pl631lk001, pathlib.Path.symlink_to.__qualname__.__eq__, ["Path.symlink_to"], true]
    - [pl631lk002, pathlib.Path.hardlink_to.__qualname__.__eq__, ["Path.hardlink_to"], true]

table pathlib_extra631.path_is_qualnames:
  description: "Qualname checks for pathlib.Path is_* predicate methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: pl631dc
  columns: [id, function, args, expected]
  rows:
    - [pl631dc001, pathlib.Path.is_symlink.__qualname__.__eq__, ["Path.is_symlink"], true]
    - [pl631dc002, pathlib.Path.is_mount.__qualname__.__eq__, ["Path.is_mount"], true]
    - [pl631dc003, pathlib.Path.is_block_device.__qualname__.__eq__, ["Path.is_block_device"], true]
    - [pl631dc004, pathlib.Path.is_char_device.__qualname__.__eq__, ["Path.is_char_device"], true]
    - [pl631dc005, pathlib.Path.is_fifo.__qualname__.__eq__, ["Path.is_fifo"], true]
    - [pl631dc006, pathlib.Path.is_socket.__qualname__.__eq__, ["Path.is_socket"], true]

table pathlib_extra631.path_nav_qualnames:
  description: "Qualname checks for pathlib.Path navigation and home methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: pl631nv
  columns: [id, function, args, expected]
  rows:
    - [pl631nv001, pathlib.Path.expanduser.__qualname__.__eq__, ["Path.expanduser"], true]
    - [pl631nv002, pathlib.Path.home.__qualname__.__eq__, ["Path.home"], true]
    - [pl631nv003, pathlib.Path.cwd.__qualname__.__eq__, ["Path.cwd"], true]
