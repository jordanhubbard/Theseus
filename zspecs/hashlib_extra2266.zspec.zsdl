spec: hashlib_extra2266
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of hashlib types."
    - "hashlib.blake2b and hashlib.blake2s are C extension types (_blake2.blake2b, _blake2.blake2s); all pickling/copy/sizeof protocol keys absent from __dict__."
    - "sha256 and md5 are builtin constructor functions returning _hashlib.HASH instances; HASH type also has all pickling/copy/sizeof protocol keys absent from __dict__."
    - "Note: blake2b/blake2s define a 'copy' method (not __copy__) for hash state cloning; this is distinct from the pickle __copy__ protocol key."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2266.blake2b_pickle:
  description: "hashlib.blake2b pickle/copy protocol dict-presence — all pickling and copy protocol keys absent from __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2266

  columns: [id, function, args, expected]
  rows:
    - ["hl2266001", "hashlib.blake2b.__dict__.__contains__", ["__reduce__"], false]
    - ["hl2266002", "hashlib.blake2b.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["hl2266003", "hashlib.blake2b.__dict__.__contains__", ["__getstate__"], false]
    - ["hl2266004", "hashlib.blake2b.__dict__.__contains__", ["__setstate__"], false]
    - ["hl2266005", "hashlib.blake2b.__dict__.__contains__", ["__getnewargs__"], false]
    - ["hl2266006", "hashlib.blake2b.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["hl2266007", "hashlib.blake2b.__dict__.__contains__", ["__copy__"], false]
    - ["hl2266008", "hashlib.blake2b.__dict__.__contains__", ["__deepcopy__"], false]
    - ["hl2266009", "hashlib.blake2b.__dict__.__contains__", ["__sizeof__"], false]
    - ["hl2266010", "hashlib.blake2b.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2266011", "hashlib.blake2b.__dict__.__contains__", ["__init_subclass__"], false]

