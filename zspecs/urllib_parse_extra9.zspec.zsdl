spec: urllib_parse_extra9
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl through urllib_parse_extra8.zspec.zsdl."
    - "urllib_parse.zspec.zsdl covers: urlparse components table, quoting table, urljoin, urlencode, parse_qs."
    - "urllib_parse_extra.zspec.zsdl covers: ParseResult/SplitResult/DefragResult __name__; urlparse/urlsplit/urljoin/urlencode __name__; urldefrag/urlunparse/urlunsplit/parse_qsl; _fields content."
    - "urllib_parse_extra2.zspec.zsdl covers: quote/unquote/quote_plus/unquote_plus/parse_qs/parse_qsl __name__; urlunparse/urlunsplit names."
    - "urllib_parse_extra3.zspec.zsdl covers: urlparse scheme/netloc/path; urlencode({'a': 1}); quote/unquote correctness."
    - "urllib_parse_extra4.zspec.zsdl covers: ParseResult/SplitResult/DefragResult __qualname__; urldefrag qualname; function qualnames; quote/unquote value vectors."
    - "urllib_parse_extra5.zspec.zsdl covers: quote_plus/unquote_plus/parse_qs/parse_qsl qualnames; urlparse.__module__; urlencode({'key': 'val'})."
    - "urllib_parse_extra6.zspec.zsdl covers: result type __module__; function __module__ for urlsplit/urljoin/urlencode/quote/unquote/urlunparse/urlunsplit; urlparse query/fragment/empty_query."
    - "urllib_parse_extra7.zspec.zsdl covers: function __module__ for quote_plus/unquote_plus/parse_qs/parse_qsl/urldefrag; urlsplit behavioral; urldefrag behavioral; parse_qsl two_pairs; urlencode list_of_pairs."
    - "urllib_parse_extra8.zspec.zsdl covers: urlsplit port/fragment/username/password; urlparse port/username; urlunparse/urlunsplit behavioral; quote_plus numeric; unquote_plus plus_to_space."
    - "Focus: __class__.__name__ type checks for urllib.parse functions (none in any prior spec); DefragResult._fields content; parse_qs empty-string behavior."
    - "urlparse.__class__.__name__ == 'function' — verifies urlparse is a plain Python function."
    - "quote.__class__.__name__ == 'function' — verifies quote is a plain Python function."
    - "urlencode.__class__.__name__ == 'function' — verifies urlencode is a plain Python function."
    - "urlsplit.__class__.__name__ == 'function' — verifies urlsplit is a plain Python function."
    - "urljoin.__class__.__name__ == 'function' — verifies urljoin is a plain Python function."
    - "DefragResult._fields[0] == 'url' — first field of the DefragResult named tuple."
    - "DefragResult._fields[1] == 'fragment' — second field of the DefragResult named tuple."
    - "parse_qs('') == {} — empty query string yields an empty dict."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __class__.__name__ type checks
#
# No prior urllib_parse spec checks the type (via __class__.__name__) of any
# urllib.parse function. xml_extra3 and xml_etree_extra3 set the pattern for
# module-level function type checks; this applies the same pattern here.
# ---------------------------------------------------------------------------

table urllib_parse_extra9.function_type_checks:
  kind: python_call_eq
  category: types
  id_prefix: typecheck

  columns: [id, function, args, expected]
  rows:
    - [urlparse,   urlparse.__class__.__name__.__eq__,   ["function"], true]
    - [urlsplit,   urlsplit.__class__.__name__.__eq__,   ["function"], true]
    - [urljoin,    urljoin.__class__.__name__.__eq__,    ["function"], true]
    - [urlencode,  urlencode.__class__.__name__.__eq__,  ["function"], true]
    - [quote,      quote.__class__.__name__.__eq__,      ["function"], true]
    - [unquote,    unquote.__class__.__name__.__eq__,    ["function"], true]
    - [quote_plus, quote_plus.__class__.__name__.__eq__, ["function"], true]
    - [parse_qs,   parse_qs.__class__.__name__.__eq__,   ["function"], true]
    - [parse_qsl,  parse_qsl.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# DefragResult._fields — field name content
#
# urllib_parse_extra.zspec.zsdl checks ParseResult._fields and SplitResult._fields
# content via indexed access. DefragResult._fields content has not been verified.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra9.DefragResult.field_0:
  description: "urllib.parse.DefragResult._fields[0] == 'url'"
  category: DefragResult
  kind: python_call_eq
  function: DefragResult._fields.__getitem__
  args: [0]
  expected: "url"

invariant urllib_parse_extra9.DefragResult.field_1:
  description: "urllib.parse.DefragResult._fields[1] == 'fragment'"
  category: DefragResult
  kind: python_call_eq
  function: DefragResult._fields.__getitem__
  args: [1]
  expected: "fragment"

invariant urllib_parse_extra9.DefragResult.fields_length:
  description: "len(urllib.parse.DefragResult._fields) == 2 — DefragResult has exactly two fields"
  category: DefragResult
  kind: python_call_eq
  function: DefragResult._fields.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# parse_qs — empty string input
#
# urllib_parse.zspec.zsdl tests parse_qs('a=1&b=2&a=3') and parse_qs('key=value').
# No prior spec tests parse_qs with an empty string input.
# parse_qs('') returns {} because there are no key=value pairs to extract.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra9.parse_qs.empty_string:
  description: "urllib.parse.parse_qs('') == {} — empty query string produces empty dict"
  category: parse_qs
  kind: python_call_eq
  function: parse_qs
  args: [""]
  expected: {}

# ---------------------------------------------------------------------------
# ParseResult._fields length — exactly 6 fields
#
# urllib_parse_extra checks each field by index (scheme/netloc/path/params/
# query/fragment). The total count has not been separately verified.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra9.ParseResult.fields_length:
  description: "len(urllib.parse.ParseResult._fields) == 6 — ParseResult has six fields"
  category: ParseResult
  kind: python_call_eq
  function: ParseResult._fields.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# SplitResult._fields length — exactly 5 fields (no params)
#
# urllib_parse_extra checks each field by index. The total count has not
# been separately verified.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra9.SplitResult.fields_length:
  description: "len(urllib.parse.SplitResult._fields) == 5 — SplitResult has five fields (no params)"
  category: SplitResult
  kind: python_call_eq
  function: SplitResult._fields.__len__
  args: []
  expected: 5
