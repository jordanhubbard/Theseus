spec: abbreviate_number
version: ">=0.0.6"
backend: node(abbreviate-number)

docs: https://www.npmjs.com/package/abbreviate-number

provenance:
  derived_from:
    - "abbreviate-number README — https://www.npmjs.com/package/abbreviate-number"
    - "Test vectors verified with abbreviate-number via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "abbreviate-number source"
  notes:
    - "abbreviate-number is an npm package. Install: npm install abbreviate-number"
    - "Abbreviates large numbers using k/m/b suffixes."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table abbreviate_number.abbreviate:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: abbr

  columns: [id, args, expected]
  rows:
    - [thousand,      [1000],    "1k"]
    - [half_million,  [1500000], "1.5m"]
    - [million,       [1000000], "1m"]
    - [half_k,        [1500],    "1.5k"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:24:54Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
