spec: socket_extra33
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra32.zspec.zsdl — covers socket.socket recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex __qualname__.__len__(); getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/create_connection __name__.__len__(); IPPROTO_TCP/UDP __class__.__name__.__len__()==3; AF_UNIX __class__.__name__.__len__()==13."
    - "socket_extra31.zspec.zsdl — covers socket.timeout/herror/gaierror __dict__.__class__.__name__.__len__()==12; socket.socket method qualnames for close/setblocking/getsockname/fileno/detach/shutdown/sendall."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238; AF_INET/AF_INET6 AddressFamily; SOCK_STREAM/SOCK_DGRAM SocketKind; SOL_SOCKET/IPPROTO_TCP values; socket.socket.__dict__.__class__.__name__.__len__()==12."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; error/__mro__.__len__()==4; timeout/__mro__.__len__()==5; setsockopt/getsockopt/settimeout/getpeername qualnames."
    - "socket_extra28.zspec.zsdl — covers socket.socket bind/connect/listen/accept/send/recv qualnames; getaddrinfo/__qualname__.__len__(); setdefaulttimeout/__qualname__.__len__()/__module__.__len__()."
    - "socket_extra27.zspec.zsdl — covers socket.gethostname/__module__.__len__(); inet_aton/inet_ntoa __name__/__module__/__qualname__; socket module-level __name__.__len__() for error."
    - "socket_extra26.zspec.zsdl — covers timeout/herror/gaierror __bases__[0].__name__; socket.socket.__init__.__name__; inet_aton/__name__.__len__()==9; inet_ntoa/__name__.__len__()==9."
    - "socket_extra20.zspec.zsdl — covers __qualname__.__len__() for socket class and module functions: socket/create_connection/create_server/setdefaulttimeout/gethostname/gethostbyname/getaddrinfo."
    - "socket_extra19.zspec.zsdl — covers gaierror/herror/timeout/error __name__.__len__()."
    - "socket_extra18.zspec.zsdl — covers gethostname/__name__.__len__()==11; error/__name__.__len__()==7."
  notes:
    - "This spec extends socket_extra32.zspec.zsdl."
    - "Prior specs covered: all __module__/__name__/__mro__/__bases__[0].__name__/__qualname__ for socket/error/timeout/herror/gaierror; __name__.__len__() and __qualname__.__len__() for most module-level functions including gethostname(11)/inet_aton(9)/inet_ntoa(9)/getaddrinfo(11)/getnameinfo(11)/setdefaulttimeout(17)/getdefaulttimeout(17)/create_connection(17); socket.socket __dict__.__class__.__name__.__len__()==12 (extra30); all socket.socket method qualname lengths for bind/connect/listen/accept/send/recv/setsockopt/getsockopt/settimeout/getpeername/close/setblocking/getsockname/fileno/detach/shutdown/sendall/recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex."
    - "This spec covers: socket.htonl/__name__.__len__() (NOVEL — 'htonl' is 5 chars; no prior spec checks __name__.__len__() for htonl; socket_extra covers htonl via value checks only); socket.htons/__name__.__len__() (NOVEL — same); socket.ntohl/__name__.__len__() (NOVEL — same); socket.ntohs/__name__.__len__() (NOVEL — same); socket.create_server/__name__.__len__() (NOVEL — extra20 covers __qualname__.__len__()==13 but not __name__.__len__()); socket.gethostbyname/__name__.__len__() (NOVEL — extra20 covers __qualname__.__len__()==13 but not __name__.__len__()); socket.socket.__dict__['family'].__class__.__name__.__len__() (NOVEL — 'property' is 8 chars; socket.socket.family is a property descriptor; no prior spec checks descriptor class names for socket.socket attributes); socket.socket.__dict__['type'].__class__.__name__.__len__() (NOVEL — same; socket.socket.type is a property)."
    - "socket.htonl.__name__ == 'htonl' (len 5). C-extension function from _socket. No prior spec checks __name__.__len__() for any byte-order conversion function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.htons.__name__ == 'htons' (len 5). Same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.ntohl.__name__ == 'ntohl' (len 5). Same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.ntohs.__name__ == 'ntohs' (len 5). Same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.create_server.__name__ == 'create_server' (len 13). extra20 covers create_server.__qualname__.__len__()==13 but no prior spec checks __name__.__len__() for create_server. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__name__ == 'gethostbyname' (len 13). extra20 covers gethostbyname.__qualname__.__len__()==13 but no prior spec checks __name__.__len__() for gethostbyname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__['family'].__class__.__name__ == 'property' (len 8). socket.socket.family is a Python property descriptor exposing the address family of the socket instance. No prior spec checks the class name of any socket.socket attribute descriptor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__['type'].__class__.__name__ == 'property' (len 8). socket.socket.type is a Python property descriptor exposing the socket type. Same type as 'family'. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.htonl/htons/ntohl/ntohs __name__.__len__()
#
# The four byte-order conversion functions are C-extension functions from
# _socket. No prior socket spec checks __name__.__len__() for any of them.
# socket_extra covers htonl via value checks (htonl(1) == ...) only.
# socket_extra10 covers __qualname__ for htonl/ntohl/htons/ntohs via __eq__.
# All four have __name__ == their function name (len 5 each).
# htonl -> 'htonl' (5); htons -> 'htons' (5)
# ntohl -> 'ntohl' (5); ntohs -> 'ntohs' (5)
# ---------------------------------------------------------------------------

table socket_extra33.byte_order_func_name_lens:
  description: "socket.htonl/htons/ntohl/ntohs __name__.__len__()==5 — novel; extra10 covers __qualname__ via __eq__ but not __name__.__len__()"
  kind: python_call_eq
  category: string_lengths
  id_prefix: sbofnl33

  columns: [id, function, args, expected]
  rows:
    - [htonl, htonl.__name__.__len__, [], 5]
    - [htons, htons.__name__.__len__, [], 5]
    - [ntohl, ntohl.__name__.__len__, [], 5]
    - [ntohs, ntohs.__name__.__len__, [], 5]

# ---------------------------------------------------------------------------
# socket.create_server and socket.gethostbyname __name__.__len__()
#
# socket_extra20 covers create_server.__qualname__.__len__()==13 and
# gethostbyname.__qualname__.__len__()==13 but does NOT cover __name__.__len__().
# For pure-Python functions, __name__ == __qualname__ (both 'create_server' and
# 'gethostbyname', len 13). These are novel __name__.__len__() checks.
# ---------------------------------------------------------------------------

invariant socket_extra33.create_server_name_len:
  description: "socket.create_server.__name__.__len__() == 13 — 'create_server' has 13 characters; novel __name__.__len__() (extra20 covers __qualname__.__len__() only)"
  category: string_lengths
  kind: python_call_eq
  function: create_server.__name__.__len__
  args: []
  expected: 13

invariant socket_extra33.gethostbyname_name_len:
  description: "socket.gethostbyname.__name__.__len__() == 13 — 'gethostbyname' has 13 characters; novel __name__.__len__() (extra20 covers __qualname__.__len__() only)"
  category: string_lengths
  kind: python_call_eq
  function: gethostbyname.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# socket.socket.__dict__['family'] and __dict__['type'] descriptor class names
#
# socket.socket.family and socket.socket.type are Python property descriptors.
# Accessed via socket.socket.__dict__ to get the raw descriptor objects.
# Both have __class__.__name__ == 'property' (len 8).
# No prior socket spec examines the class name of any socket.socket
# attribute descriptor (prior specs check method __qualname__ only).
# socket.socket.__dict__['family'].__class__.__name__ == 'property' -> 8
# socket.socket.__dict__['type'].__class__.__name__ == 'property' -> 8
# ---------------------------------------------------------------------------

table socket_extra33.socket_class_descriptor_class_names:
  description: "socket.socket.__dict__['family'] and ['type'] are property descriptors (len 8) — novel; no prior spec checks socket.socket attribute descriptor class names"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ssdcn33

  columns: [id, function, args, expected]
  rows:
    - [family_desc_len, "socket.__dict__['family'].__class__.__name__.__len__", [], 8]
    - [type_desc_len,   "socket.__dict__['type'].__class__.__name__.__len__",   [], 8]
