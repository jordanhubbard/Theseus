spec: abc_extra147
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc module class hierarchy details. ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__module__=='abc'; ABCMeta.__bases__[0].__name__=='type' (ABCMeta inherits from type — it is a metaclass; len('type')==4); ABC.__name__=='ABC' (len=3); ABC.__module__=='abc'; ABC.__bases__[0].__name__=='object' (ABC inherits from object — a plain class hierarchy with ABCMeta as its metaclass; len('object')==6); ABC.__class__.__name__=='ABCMeta' (ABC is an instance of ABCMeta — its metaclass; len('ABCMeta')==7); abstractmethod.__name__=='abstractmethod' (len=14); abstractmethod.__module__=='abc'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__bases__[0].__name__=='type' — ABCMeta inherits from type because it IS a metaclass; metaclasses are subclasses of type; ABCMeta.__module__=='abc' (defined in Lib/abc.py using the C implementation from Modules/_abc.c). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__class__.__name__=='ABCMeta' — ABC is a class whose metaclass is ABCMeta; ABC.__class__ returns ABCMeta (not type) because ABC was created using ABCMeta as its metaclass via 'class ABC(metaclass=ABCMeta)'; this is the defining feature of abstract base classes — their metaclass is ABCMeta rather than type. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod is a pure-Python class (abstractmethod.__class__.__name__=='function' — actually 'function' since the decorator is defined as a class but __class__.__name__ reports 'function' for the decorator object). Wait: abstractmethod is a class, not a function. Let me verify: abstractmethod.__module__=='abc' and abstractmethod.__name__=='abstractmethod'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta class hierarchy identity — extra147
#
# abc.ABCMeta.__name__.__eq__('ABCMeta')                == True
# abc.ABCMeta.__module__.__eq__('abc')                  == True
# abc.ABCMeta.__bases__[0].__name__.__eq__('type')      == True
# ---------------------------------------------------------------------------

table abc_extra147.abc_ABCMeta_hierarchy:
  description: "abc.ABCMeta class hierarchy identity checks in abcmeta147 namespace — abc.ABCMeta.__name__=='ABCMeta' (len=7; the metaclass that enables abstract base class functionality; all ABCs use ABCMeta as their metaclass); abc.ABCMeta.__module__=='abc' (len=3; defined in Lib/abc.py with C implementation backing from Modules/_abc.c); abc.ABCMeta.__bases__[0].__name__=='type' (len=4; ABCMeta inherits from type because it IS a metaclass — metaclasses are subclasses of the 'type' metaclass; ABCMeta adds abstract method tracking on top of type's class creation mechanism); abc.ABCMeta.__name__.__len__()==7; abc.ABCMeta.__module__.__len__()==3 (same as the module name 'abc'); name length ordering: ABCMeta(7) > type(4) > abc(3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta147

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,   abc.ABCMeta.__name__.__eq__,                              ["ABCMeta"],  true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abcmeta_mod_eq,    abc.ABCMeta.__module__.__eq__,                             ["abc"],      true,  "abc.ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [abcmeta_base_eq, "abc.ABCMeta.__bases__[0].__name__.__eq__",                   ["type"],     true,  "abc.ABCMeta.__bases__[0].__name__ == 'type' (len=4; ABCMeta inherits from type — it is a metaclass); verified with Python 3.14.3"]
    - [abcmeta_name_len,  abc.ABCMeta.__name__.__len__,                              [],           7,     "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC class identity and metaclass — extra147
#
# abc.ABC.__name__.__eq__('ABC')                          == True
# abc.ABC.__module__.__eq__('abc')                        == True
# abc.ABC.__bases__[0].__name__.__eq__('object')          == True
# abc.ABC.__class__.__name__.__eq__('ABCMeta')            == True
# ---------------------------------------------------------------------------

table abc_extra147.abc_ABC_identity_and_metaclass:
  description: "abc.ABC class identity and metaclass checks in abcclass147 namespace — abc.ABC.__name__=='ABC' (len=3; a convenience class for creating abstract base classes without needing to explicitly set metaclass=ABCMeta); abc.ABC.__module__=='abc' (len=3; defined in Lib/abc.py); abc.ABC.__bases__[0].__name__=='object' (len=6; ABC inherits from object — it is a plain-inheritance class, not a metaclass subclass; ABC.__bases__==(object,)); abc.ABC.__class__.__name__=='ABCMeta' (len=7; the metaclass of ABC is ABCMeta — calling type(ABC).__name__ also gives 'ABCMeta'; this is the defining characteristic: ABC's class (metaclass) is ABCMeta, not the default 'type'; classes inheriting from ABC automatically get ABCMeta as their metaclass too); 'ABC'.__len__()==3; 'object'.__len__()==6; 'ABCMeta'.__len__()==7; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcclass147

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,   abc.ABC.__name__.__eq__,                                    ["ABC"],      true,  "abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [abc_mod_eq,    abc.ABC.__module__.__eq__,                                   ["abc"],      true,  "abc.ABC.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [abc_base_eq,  "abc.ABC.__bases__[0].__name__.__eq__",                        ["object"],   true,  "abc.ABC.__bases__[0].__name__ == 'object' (len=6; ABC inherits from object — plain class, not a metaclass); verified with Python 3.14.3"]
    - [abc_class_eq, "abc.ABC.__class__.__name__.__eq__",                           ["ABCMeta"],  true,  "abc.ABC.__class__.__name__ == 'ABCMeta' (len=7; the metaclass of ABC is ABCMeta, not type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod identity — extra147
#
# abc.abstractmethod.__name__.__eq__('abstractmethod')   == True
# abc.abstractmethod.__module__.__eq__('abc')            == True
# ---------------------------------------------------------------------------

table abc_extra147.abc_abstractmethod_identity:
  description: "abc.abstractmethod class identity checks in abcabsm147 namespace — abc.abstractmethod.__name__=='abstractmethod' (len=14; the primary decorator in the abc module; marks methods as abstract in ABCMeta-governed classes); abc.abstractmethod.__module__=='abc' (len=3; defined in Lib/abc.py); abc.abstractmethod.__name__.__len__()==14 (longest name in this spec: 'abstractmethod'=14 > 'ABCMeta'=7 > 'object'=6 > 'type'=4 > 'ABC'=3); note: abstractmethod is implemented as a class (not a function) in Lib/abc.py — when used as a decorator, the function is wrapped in an abstractmethod instance that sets __isabstractmethod__=True; abc.abstractmethod.__module__.__len__()==3 (same module 'abc' as ABCMeta and ABC); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabsm147

  columns: [id, function, args, expected, description]
  rows:
    - [absm_name_eq,   abc.abstractmethod.__name__.__eq__,                         ["abstractmethod"],  true,  "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [absm_mod_eq,    abc.abstractmethod.__module__.__eq__,                        ["abc"],             true,  "abc.abstractmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [absm_name_len,  abc.abstractmethod.__name__.__len__,                         [],                  14,    "abc.abstractmethod.__name__.__len__() == 14 ('abstractmethod'; longest name in this spec); verified with Python 3.14.3"]
    - [absm_mod_len,   abc.abstractmethod.__module__.__len__,                       [],                  3,     "abc.abstractmethod.__module__.__len__() == 3 ('abc'; same module as ABCMeta and ABC); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra147
# ---------------------------------------------------------------------------

invariant abc_extra147.abc_ABCMeta_name_eq:
  description: "abc.ABCMeta.__name__.__eq__('ABCMeta') returns True — abc.ABCMeta is the metaclass that enables abstract base class functionality in Python; it is defined in Lib/abc.py (backed by Modules/_abc.c for performance); ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__module__=='abc' (len=3); ABCMeta.__bases__[0].__name__=='type' (ABCMeta is itself a subclass of type, making it a metaclass); ABCMeta overrides __new__ to detect abstract methods, and provides register() for virtual subclass registration; abc.__dict__.__contains__('ABCMeta')==True (from extra145); NEW in extra147: first standalone abc.ABCMeta.__name__ identity invariant in abcmeta147 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra147.abc_ABCMeta_bases0_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — ABCMeta inherits from type because metaclasses must subclass type; type is the metaclass of all classes in Python (including ABCMeta itself — type(ABCMeta) is type); ABCMeta.__bases__[0].__name__=='type' (len=4); ABCMeta overrides type's class creation to detect abstract methods (those with __isabstractmethod__==True) and stores them in cls.__abstractmethods__; a class using ABCMeta cannot be instantiated if it has any unimplemented abstract methods; the design is: ABCMeta inherits from type (metaclass) while ABC inherits from object (regular class) — these are two separate hierarchies (metaclass hierarchy and class hierarchy); NEW in extra147: first standalone abc.ABCMeta.__bases__[0] name identity invariant in abcmeta147 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra147.abc_ABC_class_is_ABCMeta:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') returns True — abc.ABC is a class whose metaclass is ABCMeta; ABC.__class__ returns ABCMeta (the metaclass); this is the fundamental purpose of ABC: it is a convenience base class so that subclasses of ABC automatically get ABCMeta as their metaclass without needing to write 'class MyABC(metaclass=ABCMeta)'; ABC.__class__.__name__=='ABCMeta' (len=7) while a regular class would have __class__.__name__=='type' (len=4); ABC.__bases__[0].__name__=='object' (ABC inherits from object in terms of class hierarchy); so ABC is simultaneously: (1) a class inheriting from object, and (2) an instance of ABCMeta as its metaclass; NEW in extra147: first standalone abc.ABC.__class__ name identity invariant in abcclass147 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.ABC.__class__.__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

invariant abc_extra147.abc_ABC_bases0_is_object:
  description: "abc.ABC.__bases__[0].__name__.__eq__('object') returns True — abc.ABC inherits directly from object (single inheritance); ABC.__bases__==(object,) so ABC.__bases__[0].__name__=='object' (len=6); this means ABC is a regular class in terms of inheritance (no special base classes), but with ABCMeta as its metaclass; compare: ABCMeta.__bases__[0].__name__=='type' (ABCMeta inherits from type in the metaclass hierarchy); the two hierarchies are parallel and independent — class hierarchy: ABC > object; metaclass hierarchy: ABCMeta > type > object; ABC.__module__=='abc' (len=3); abc.__dict__.__contains__('ABC')==True (from extra145); NEW in extra147: first standalone abc.ABC.__bases__[0] name identity invariant in abcclass147 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.ABC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra147.abc_abstractmethod_name_eq:
  description: "abc.abstractmethod.__name__.__eq__('abstractmethod') returns True — abc.abstractmethod is a decorator class defined in Lib/abc.py; when applied to a method, it sets __isabstractmethod__=True on the decorated function; ABCMeta then collects all such methods into __abstractmethods__ frozenset on the class; a class using ABCMeta with any non-overridden abstract methods cannot be instantiated; abstractmethod.__name__=='abstractmethod' (len=14; the longest name in this spec: 14 > 7 > 6 > 4 > 3); abstractmethod.__module__=='abc' (len=3; same module as ABCMeta and ABC); abc.__dict__.__contains__('abstractmethod')==True (from extra145); NEW in extra147: first standalone abc.abstractmethod.__name__ identity invariant in abcabsm147 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra147.abc_abstractmethod_module_eq:
  description: "abc.abstractmethod.__module__.__eq__('abc') returns True — abc.abstractmethod is defined in Lib/abc.py and its __module__ is 'abc' (len=3); abstractmethod is a Python class (not a C-level builtin) despite abc having a C extension backend (_abc.c); the C extension backs ABCMeta's internal state management (_abc_init, _abc_register, _abc_instancecheck, _abc_subclasscheck) but abstractmethod itself is pure Python; abstractmethod.__module__=='abc' (same as ABCMeta.__module__ and ABC.__module__ — all three are in 'abc'); abstractmethod.__name__.__len__()==14 (the longest name in abc's primary public API: abstractmethod(14) > ABCMeta(7) > object(6) > type(4) > ABC(3)); NEW in extra147: first standalone abc.abstractmethod.__module__ identity invariant in abcabsm147 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true
