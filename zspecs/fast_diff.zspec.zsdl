spec: fast_diff
version: ">=1.0.0"
backend: node(fast-diff)

docs: https://github.com/jhchen/fast-diff#readme

provenance:
  derived_from:
    - "fast-diff README — https://github.com/jhchen/fast-diff#readme"
    - "Myers' O(ND) Difference Algorithm"
    - "Test vectors verified with fast-diff via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "fast-diff source"
  notes:
    - "fast-diff is a streamlined fork of diff-match-patch's diff_main, exposed as a single function."
    - "Install: npm install fast-diff"
    - "Module export IS the function. Returns array of [op, text]; op is -1 (DELETE), 0 (EQUAL), 1 (INSERT)."
    - "Distinct from diff-match-patch (which exports a constructor); fast-diff trades some features for speed."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table fast_diff.diff:
  kind: node_module_call_eq
  category: diff
  function: ~
  id_prefix: diff

  columns: [id, args, expected]
  rows:
    - [identical_strings,
       ["abc", "abc"],
       [[0, "abc"]]]

    - [single_char_change,
       ["hello", "hxllo"],
       [[0, "h"], [-1, "e"], [1, "x"], [0, "llo"]]]

    - [completely_different,
       ["abc", "xyz"],
       [[-1, "abc"], [1, "xyz"]]]

    - [pure_insertion,
       ["abc", "abcdef"],
       [[0, "abc"], [1, "def"]]]

    - [pure_deletion,
       ["abcdef", "abc"],
       [[0, "abc"], [-1, "def"]]]

    - [empty_to_empty,
       ["", ""],
       []]

    - [empty_to_text,
       ["", "abc"],
       [[1, "abc"]]]

    - [text_to_empty,
       ["abc", ""],
       [[-1, "abc"]]]
