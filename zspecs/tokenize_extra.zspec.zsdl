spec: tokenize_extra
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tokenize.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — that spec covers core and extended token type constants and function names for tokenize/generate_tokens/detect_encoding"
  notes:
    - "This spec covers tokenize aspects not in tokenize.zspec.zsdl."
    - "TokenInfo is a named tuple; its __name__ is 'TokenInfo' and __module__ is 'tokenize'."
    - "TokenError is an exception class whose first base is Exception."
    - "tokenize (the function) has __name__ == 'tokenize' — same as the module name; confirmed via the function object directly."
    - "open in the tokenize module is a distinct function from builtins.open; its __name__ is 'open'."
    - "untokenize.__name__ == 'untokenize' — the inverse function of the tokenizer."
    - "Token type constants (ENCODING, COMMENT, NAME, NUMBER, STRING, NEWLINE, OP, ENDMARKER) are all plain Python ints."
    - "ENCODING and COMMENT are tokenize-specific constants not present in the base token module."
    - "Specific integer values for ENCODING and COMMENT are version-dependent and NOT checked here."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TokenInfo — named tuple for token representation
# ---------------------------------------------------------------------------

invariant tokenize_extra.TokenInfo.name:
  description: "tokenize.TokenInfo.__name__ == 'TokenInfo'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__name__.__eq__
  args: ["TokenInfo"]
  expected: true

invariant tokenize_extra.TokenInfo.module:
  description: "tokenize.TokenInfo.__module__ == 'tokenize'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__module__.__eq__
  args: ["tokenize"]
  expected: true

# ---------------------------------------------------------------------------
# TokenError — exception class with Exception as base
# ---------------------------------------------------------------------------

invariant tokenize_extra.TokenError.name:
  description: "tokenize.TokenError.__name__ == 'TokenError'"
  category: token_error
  kind: python_call_eq
  function: TokenError.__name__.__eq__
  args: ["TokenError"]
  expected: true

invariant tokenize_extra.TokenError.base_is_Exception:
  description: "tokenize.TokenError.__bases__[0].__name__ == 'Exception'"
  category: token_error
  kind: python_call_eq
  function: TokenError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name checks — functions not fully covered in tokenize.zspec.zsdl
# ---------------------------------------------------------------------------

invariant tokenize_extra.tokenize.name:
  description: "tokenize.tokenize.__name__ == 'tokenize' (the function inside the module)"
  category: function_names
  kind: python_call_eq
  function: tokenize.__name__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra.generate_tokens.name:
  description: "tokenize.generate_tokens.__name__ == 'generate_tokens'"
  category: function_names
  kind: python_call_eq
  function: generate_tokens.__name__.__eq__
  args: ["generate_tokens"]
  expected: true

invariant tokenize_extra.detect_encoding.name:
  description: "tokenize.detect_encoding.__name__ == 'detect_encoding'"
  category: function_names
  kind: python_call_eq
  function: detect_encoding.__name__.__eq__
  args: ["detect_encoding"]
  expected: true

invariant tokenize_extra.open.name:
  description: "tokenize.open.__name__ == 'open'"
  category: function_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant tokenize_extra.untokenize.name:
  description: "tokenize.untokenize.__name__ == 'untokenize'"
  category: function_names
  kind: python_call_eq
  function: untokenize.__name__.__eq__
  args: ["untokenize"]
  expected: true

# ---------------------------------------------------------------------------
# Token type constants — all are plain ints
#
# ENCODING and COMMENT are tokenize-specific; NAME/NUMBER/STRING/NEWLINE/OP/
# ENDMARKER are re-exported from the token module. Specific integer values are
# version-dependent and not checked here — only the type is verified.
# ---------------------------------------------------------------------------

table tokenize_extra.token_constant_types:
  kind: python_call_eq
  category: constants
  id_prefix: toktype

  columns: [id, function, args, expected]
  rows:
    - [encoding,  ENCODING.__class__.__name__.__eq__,  ["int"], true]
    - [comment,   COMMENT.__class__.__name__.__eq__,   ["int"], true]
    - [name,      NAME.__class__.__name__.__eq__,      ["int"], true]
    - [number,    NUMBER.__class__.__name__.__eq__,    ["int"], true]
    - [string,    STRING.__class__.__name__.__eq__,    ["int"], true]
    - [newline,   NEWLINE.__class__.__name__.__eq__,   ["int"], true]
    - [op,        OP.__class__.__name__.__eq__,        ["int"], true]
    - [endmarker, ENDMARKER.__class__.__name__.__eq__, ["int"], true]
