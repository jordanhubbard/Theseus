spec: string_score
version: ">=1.0.1"
backend: node(string-score)

docs: https://www.npmjs.com/package/string-score

provenance:
  derived_from:
    - "string-score README — https://www.npmjs.com/package/string-score"
    - "Test vectors verified with string-score via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "string-score source"
  notes:
    - "string-score is an npm package. Install: npm install string-score"
    - "Scores string similarity from 0 (no match) to 1 (exact match) using Jaro-like fuzzy comparison."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number from 0 to 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_score.score:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: strscore

  columns: [id, args, expected]
  rows:
    - [partial,  ["hello", "hell"],   0.87]
    - [exact,    ["hello", "hello"],  1]
    - [no_match, ["hello", "world"],  0]
