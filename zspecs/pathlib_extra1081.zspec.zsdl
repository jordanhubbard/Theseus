spec: pathlib_extra1081
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePosixPath, PureWindowsPath, and Path operator/stat method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks PurePosixPath and PureWindowsPath class identity, Path.__truediv__/__rtruediv__ qualnames (inherited from PurePath), and Path.stat/lstat/chmod/lchmod qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1081.pure_subclass_identity:
  description: "pathlib.PurePosixPath and PureWindowsPath class __name__, __module__, and __qualname__ checks"
  kind: python_call_eq
  category: pure_subclass_identity
  id_prefix: pl1081ps
  columns: [id, function, args, expected]
  rows:
    - [pl1081ps001, pathlib.PurePosixPath.__name__.__eq__,       ["PurePosixPath"],   true]
    - [pl1081ps002, pathlib.PurePosixPath.__module__.__eq__,     ["pathlib"],         true]
    - [pl1081ps003, pathlib.PurePosixPath.__qualname__.__eq__,   ["PurePosixPath"],   true]
    - [pl1081ps004, pathlib.PureWindowsPath.__name__.__eq__,     ["PureWindowsPath"], true]
    - [pl1081ps005, pathlib.PureWindowsPath.__module__.__eq__,   ["pathlib"],         true]
    - [pl1081ps006, pathlib.PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true]
    - [pl1081ps007, pathlib.PosixPath.__module__.__eq__,         ["pathlib"],         true]
    - [pl1081ps008, pathlib.PosixPath.__qualname__.__eq__,       ["PosixPath"],       true]

table pathlib_extra1081.path_division_qualnames:
  description: "pathlib.Path.__truediv__ and __rtruediv__ __qualname__ checks (inherited from PurePath)"
  kind: python_call_eq
  category: path_division_qualnames
  id_prefix: pl1081dv
  columns: [id, function, args, expected]
  rows:
    - [pl1081dv001, pathlib.Path.__truediv__.__qualname__.__eq__,     ["PurePath.__truediv__"],  true]
    - [pl1081dv002, pathlib.Path.__rtruediv__.__qualname__.__eq__,    ["PurePath.__rtruediv__"], true]
    - [pl1081dv003, pathlib.PurePath.__truediv__.__qualname__.__eq__, ["PurePath.__truediv__"],  true]
    - [pl1081dv004, pathlib.PurePath.__rtruediv__.__qualname__.__eq__, ["PurePath.__rtruediv__"], true]
    - [pl1081dv005, pathlib.PurePath.__str__.__qualname__.__eq__,     ["PurePath.__str__"],      true]
    - [pl1081dv006, pathlib.PurePath.__fspath__.__qualname__.__eq__,  ["PurePath.__fspath__"],   true]

table pathlib_extra1081.path_stat_chmod_qualnames:
  description: "pathlib.Path stat and permission method __qualname__ checks"
  kind: python_call_eq
  category: path_stat_chmod_qualnames
  id_prefix: pl1081sc
  columns: [id, function, args, expected]
  rows:
    - [pl1081sc001, pathlib.Path.lstat.__qualname__.__eq__,    ["Path.lstat"],    true]
    - [pl1081sc002, pathlib.Path.chmod.__qualname__.__eq__,    ["Path.chmod"],    true]
    - [pl1081sc003, pathlib.Path.lchmod.__qualname__.__eq__,   ["Path.lchmod"],   true]
    - [pl1081sc004, pathlib.Path.iterdir.__qualname__.__eq__,  ["Path.iterdir"],  true]
    - [pl1081sc005, pathlib.Path.glob.__qualname__.__eq__,     ["Path.glob"],     true]
    - [pl1081sc006, pathlib.Path.rglob.__qualname__.__eq__,    ["Path.rglob"],    true]
    - [pl1081sc007, pathlib.Path.absolute.__qualname__.__eq__, ["Path.absolute"], true]
    - [pl1081sc008, pathlib.Path.walk.__qualname__.__eq__,     ["Path.walk"],     true]
