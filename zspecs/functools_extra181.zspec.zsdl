spec: functools_extra181
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.partial class identity — functools.partial.__name__=='partial' (len=7); functools.partial.__module__=='functools'; functools.partial.__mro__.__len__()==2 (partial > object — C type); functools.partial.__doc__.__class__.__name__=='str'; functools.partialmethod.__name__=='partialmethod' (len=13); functools.partialmethod.__module__=='functools'; functools.partialmethod.__mro__.__len__()==2; functools.singledispatch.__name__=='singledispatch' (len=14); functools.singledispatch.__module__=='functools'."
    - "functools.partial.__name__ == 'partial' — partial is a C extension type defined in Lib/functools.py (backed by _functools module); its __name__ is 'partial', 7 characters. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — partial is re-exported from the functools module; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2 — partial is a C extension type inheriting directly from object; its MRO is (partial, object). Verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — the docstring of partial is a regular Python str object. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__ == 'partialmethod' — partialmethod is a Python class in Lib/functools.py; its __name__ is 'partialmethod', 13 characters. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partialmethod.__mro__.__len__() == 2 — partialmethod inherits directly from object; its MRO is (partialmethod, object). Verified with Python 3.14.3."
    - "functools.singledispatch.__name__ == 'singledispatch' — singledispatch is a Python function (decorator factory) in Lib/functools.py; its __name__ is 'singledispatch', 14 characters. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial class __name__ and __module__
#
# functools.partial.__name__ == 'partial'
# functools.partial.__name__.__len__() == 7
# functools.partial.__module__ == 'functools'
# functools.partial.__module__.__len__() == 9
#
# functools.partial is a C extension type (backed by _functools) that freezes
# some arguments of a callable, producing a new callable. Its __name__ is
# 'partial' (7 chars) and its __module__ is 'functools' (9 chars). New to
# extra181.
# ---------------------------------------------------------------------------

table functools_extra181.partial_name_and_module:
  description: "functools.partial.__name__ 'partial' len 7; __module__ 'functools' len 9; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: funcpartial181

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — functools.partial is a C extension type in the _functools module that freezes some arguments of a callable, producing a new callable with a simpler signature; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra181"]
    - [partial_name_len_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — the name 'partial' has exactly 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; new to extra181"]
    - [partial_module_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — functools.partial is a C extension type re-exported from the functools module; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra181"]
    - [partial_module_len_9,
       "partial.__module__.__len__",
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — the module name 'functools' has exactly 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial __mro__ and __doc__ type
#
# functools.partial.__mro__.__len__() == 2
# functools.partial.__mro__[0].__name__ == 'partial'
# functools.partial.__mro__[1].__name__ == 'object'
# functools.partial.__doc__.__class__.__name__ == 'str'
#
# partial is a C extension type inheriting directly from object; its MRO is
# (partial, object), length 2. The class docstring (__doc__) is a regular
# Python str. New to extra181.
# ---------------------------------------------------------------------------

table functools_extra181.partial_mro_and_doc:
  description: "functools.partial.__mro__ len 2, mro[0] 'partial', mro[1] 'object'; __doc__.__class__.__name__ 'str'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: funcpartial181

  columns: [id, function, args, expected, description]
  rows:
    - [partial_mro_len_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — functools.partial is a C extension type defined in the _functools C module and re-exported by functools; it inherits directly from object with no intermediate base classes; its __mro__ is (partial, object), a tuple of length 2; tuple.__len__() returns 2; new to extra181"]
    - ["partial_mro_0_partial",
       "partial.__mro__[0].__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__mro__[0].__name__.__eq__('partial') == True — the first entry in partial.__mro__ is the partial class itself; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra181"]
    - ["partial_mro_1_object",
       "partial.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__mro__[1].__name__.__eq__('object') == True — the second and final entry in partial.__mro__ is the base class object; its __name__ is 'object'; this confirms partial inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra181"]
    - [partial_doc_class_str,
       "partial.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — the docstring (__doc__) of the partial class is a regular Python str object; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: functools.partialmethod class __name__, __module__, __mro__
#
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__name__.__len__() == 13
# functools.partialmethod.__module__ == 'functools'
# functools.partialmethod.__mro__.__len__() == 2
#
# functools.partialmethod is a Python class in Lib/functools.py that acts as
# a descriptor wrapping a partial call for use as a method definition. Its
# __name__ is 'partialmethod' (13 chars). It inherits directly from object,
# giving MRO length 2. New to extra181.
# ---------------------------------------------------------------------------

table functools_extra181.partialmethod_name_module_mro:
  description: "functools.partialmethod.__name__ 'partialmethod' len 13; __module__ 'functools'; __mro__ len 2; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: funcpartial181

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — functools.partialmethod is a Python descriptor class in Lib/functools.py that wraps a partial call for use inside a class body as a method; its __name__ is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra181"]
    - [partialmethod_name_len_13,
       "partialmethod.__name__.__len__",
       [],
       13,
       "functools.partialmethod.__name__.__len__() == 13 — the name 'partialmethod' has exactly 13 characters: p-a-r-t-i-a-l-m-e-t-h-o-d; str.__len__() returns 13; new to extra181"]
    - [partialmethod_module_functools,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — functools.partialmethod is a Python class defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra181"]
    - [partialmethod_mro_len_2,
       "partialmethod.__mro__.__len__",
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — functools.partialmethod is a Python class defined in Lib/functools.py that inherits directly from object with no intermediate base classes; its __mro__ is (partialmethod, object), a tuple of length 2; tuple.__len__() returns 2; new to extra181"]

# ---------------------------------------------------------------------------
# Table 4: functools.singledispatch __name__ and __module__
#
# functools.singledispatch.__name__ == 'singledispatch'
# functools.singledispatch.__name__.__len__() == 14
# functools.singledispatch.__module__ == 'functools'
# functools.singledispatch.__module__.__len__() == 9
#
# functools.singledispatch is a Python function (decorator factory) in
# Lib/functools.py that transforms a function into a single-dispatch generic
# function. Its __name__ is 'singledispatch' (14 chars, same length as
# total_ordering). Its __module__ is 'functools' (9 chars). New to extra181.
# ---------------------------------------------------------------------------

table functools_extra181.singledispatch_name_and_module:
  description: "functools.singledispatch.__name__ 'singledispatch' len 14; __module__ 'functools' len 9; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: funcpartial181

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_name_eq,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — functools.singledispatch is a Python function (decorator factory) in Lib/functools.py that transforms a plain function into a single-dispatch generic function dispatching on the type of its first argument; its __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra181"]
    - [singledispatch_name_len_14,
       "singledispatch.__name__.__len__",
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — the name 'singledispatch' has exactly 14 characters: s-i-n-g-l-e-d-i-s-p-a-t-c-h; same length as 'total_ordering'; str.__len__() returns 14; new to extra181"]
    - [singledispatch_module_functools,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — functools.singledispatch is a Python function defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra181"]
    - [singledispatch_module_len_9,
       "singledispatch.__module__.__len__",
       [],
       9,
       "functools.singledispatch.__module__.__len__() == 9 — the module name 'functools' has exactly 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra181"]

