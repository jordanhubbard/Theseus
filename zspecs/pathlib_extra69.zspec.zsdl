spec: pathlib_extra69
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra68.zspec.zsdl — covers Path.open/__annotations__.__class__.__name__.__eq__('dict'); Path.read_text/__annotations__.__class__.__name__.__eq__('dict'); Path.open/__globals__.__class__.__name__.__eq__('dict') and __contains__('Path'); PurePath.__doc__.__contains__('path') and __contains__('Base')."
    - "pathlib_extra67.zspec.zsdl — covers PurePath.__str__/__repr__/__fspath__/__eq__/__hash__ __qualname__.__eq__(); Path.open/read_text/write_text __qualname__.__eq__()."
    - "pathlib_extra66.zspec.zsdl — covers pathlib.__loader__/__spec__ class identity checks."
    - "pathlib_extra65.zspec.zsdl — covers pathlib.__loader__/__spec__/__file__/__cached__ class identity."
    - "pathlib_extra63.zspec.zsdl — covers pathlib.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==7; Path/PurePath dunder __class__.__name__.__eq__('function')."
  notes:
    - "This spec extends pathlib_extra68.zspec.zsdl."
    - "Wave 229 theme: __defaults__ and __code__ checks for Python functions + __doc__ content checks for additional classes."
    - "Path is a pure Python class (Lib/pathlib/__init__.py). Path.open and Path.read_text are Python functions with __defaults__ (tuple of default argument values)."
    - "Path.open.__defaults__ == ('r', -1, None, None, None) — mode='r', buffering=-1, encoding=None, errors=None, newline=None. __defaults__.__class__.__name__ is 'tuple'. __defaults__.__len__() is 5. No prior pathlib spec checks Path.open.__defaults__.__class__.__name__.__eq__('tuple') or __defaults__.__len__()==5 in pathlibcode69 namespace. Novel __defaults__ anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.read_text.__defaults__ == (None, None, None) — encoding=None, errors=None, newline=None. __defaults__.__class__.__name__ is 'tuple'. __defaults__.__len__() is 3. No prior pathlib spec checks Path.read_text.__defaults__.__class__.__name__.__eq__('tuple') or __defaults__.__len__()==3 in pathlibcode69 namespace. Novel __defaults__ anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__code__.__class__.__name__.__eq__('code') — Path.open is a pure Python function; its __code__ attribute is a code object; __class__.__name__ is 'code'. No prior pathlib spec checks Path.open.__code__.__class__.__name__.__eq__('code') in pathlibcode69 namespace. Novel __code__ class identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.__init__.__code__.__class__.__name__.__eq__('code') — Path.__init__ is a pure Python method; its __code__ attribute is a code object; __class__.__name__ is 'code'. No prior pathlib spec checks Path.__init__.__code__.__class__.__name__.__eq__('code') in pathlibcode69 namespace. Novel __code__ class identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.__doc__.__contains__('PurePath') — Path.__doc__ begins 'PurePath subclass that can make system calls.' The word 'PurePath' appears. No prior pathlib spec checks Path.__doc__.__contains__('PurePath') in pathlibcode69 namespace. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.__doc__.__contains__('system') — same docstring also contains 'system' (in 'system calls'). No prior pathlib spec checks Path.__doc__.__contains__('system') in pathlibcode69 namespace. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.open.__defaults__ class identity and length
#
# Path is a pure Python class. Path.open is a Python function with defaults:
#   Path.open.__defaults__ == ('r', -1, None, None, None)
# for parameters: mode='r', buffering=-1, encoding=None, errors=None, newline=None.
#
#   Path.open.__defaults__.__class__.__name__ == 'tuple'
#   Path.open.__defaults__.__len__()          == 5
#
# No prior pathlib spec checks Path.open.__defaults__.__class__.__name__.__eq__('tuple')
# or __defaults__.__len__()==5 in the pathlibcode69 namespace. Novel __defaults__ anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra69.path_open_defaults:
  description: "Path.open.__defaults__.__class__.__name__.__eq__('tuple') and __len__()==5 — Path is pure Python; Path.open has defaults ('r',-1,None,None,None) for mode/buffering/encoding/errors/newline; __defaults__.__class__.__name__ is 'tuple'; __defaults__.__len__()==5; no prior pathlib spec checks Path.open.__defaults__.__class__.__name__.__eq__('tuple') or __len__()==5 in pathlibcode69 namespace; novel __defaults__ anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_defaults
  id_prefix: pathlibcode69opndef

  columns: [id, function, args, expected]
  rows:
    - [defaults_class_eq, Path.open.__defaults__.__class__.__name__.__eq__, ["tuple"], true]
    - [defaults_len_eq,   Path.open.__defaults__.__len__,                   [],        5]

# ---------------------------------------------------------------------------
# Path.read_text.__defaults__ class identity and length
#
# Path.read_text is a Python function with defaults:
#   Path.read_text.__defaults__ == (None, None, None)
# for parameters: encoding=None, errors=None, newline=None.
#
#   Path.read_text.__defaults__.__class__.__name__ == 'tuple'
#   Path.read_text.__defaults__.__len__()          == 3
#
# No prior pathlib spec checks Path.read_text.__defaults__.__class__.__name__.__eq__('tuple')
# or __defaults__.__len__()==3 in the pathlibcode69 namespace. Novel __defaults__ anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra69.path_read_text_defaults:
  description: "Path.read_text.__defaults__.__class__.__name__.__eq__('tuple') and __len__()==3 — Path.read_text has defaults (None,None,None) for encoding/errors/newline; __defaults__.__class__.__name__ is 'tuple'; __defaults__.__len__()==3; no prior pathlib spec checks Path.read_text.__defaults__.__class__.__name__.__eq__('tuple') or __len__()==3 in pathlibcode69 namespace; novel __defaults__ anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_defaults
  id_prefix: pathlibcode69rtdef

  columns: [id, function, args, expected]
  rows:
    - [defaults_class_eq, Path.read_text.__defaults__.__class__.__name__.__eq__, ["tuple"], true]
    - [defaults_len_eq,   Path.read_text.__defaults__.__len__,                   [],        3]

# ---------------------------------------------------------------------------
# Path.open and Path.__init__ __code__.__class__.__name__.__eq__('code')
#
# Path.open and Path.__init__ are pure Python functions/methods. Their __code__
# attributes are code objects. __code__.__class__.__name__ is 'code'.
#
#   Path.open.__code__.__class__.__name__    == 'code'
#   Path.__init__.__code__.__class__.__name__ == 'code'
#
# No prior pathlib spec checks __code__.__class__.__name__.__eq__('code') for
# any pathlib function. Novel __code__ class identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra69.path_code_class:
  description: "Path.open and Path.__init__ __code__.__class__.__name__.__eq__('code') — Path is pure Python; Path.open and Path.__init__ are Python functions; __code__ is a code object with __class__.__name__=='code'; no prior pathlib spec checks __code__.__class__.__name__.__eq__('code') for any pathlib function; novel __code__ class identity anchors in pathlibcode69 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_identity
  id_prefix: pathlibcode69cod

  columns: [id, function, args, expected]
  rows:
    - [open_code_class_eq,  Path.open.__code__.__class__.__name__.__eq__,  ["code"], true]
    - [init_code_class_eq,  Path.__init__.__code__.__class__.__name__.__eq__, ["code"], true]

# ---------------------------------------------------------------------------
# Path.__doc__.__contains__ content checks
#
# Path.__doc__ begins:
#   'PurePath subclass that can make system calls.\n\nPath represents a
#    filesystem path but unlike PurePath, also offers\nmethods to do
#    system calls on path objects. ...'
#
# 'PurePath' and 'system' both appear in the docstring.
#
# No prior pathlib spec checks Path.__doc__.__contains__('PurePath') or
# __contains__('system') in the pathlibcode69 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra69.path_doc_contains:
  description: "Path.__doc__.__contains__('PurePath') and __contains__('system') — Path.__doc__ begins 'PurePath subclass that can make system calls.'; 'PurePath' and 'system' both appear; no prior pathlib spec checks Path.__doc__.__contains__('PurePath') or __contains__('system') in pathlibcode69 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: pathlibcode69pathdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_purepath, Path.__doc__.__contains__, ["PurePath"], true]
    - [doc_contains_system,   Path.__doc__.__contains__, ["system"],   true]

invariant pathlib_extra69.path_open_defaults_class:
  description: "Path.open.__defaults__.__class__.__name__.__eq__('tuple') == True — Path is pure Python; Path.open.__defaults__==('r',-1,None,None,None); __defaults__.__class__.__name__ is 'tuple'; no prior pathlib spec checks Path.open.__defaults__.__class__.__name__.__eq__('tuple') in pathlibcode69 namespace; novel __defaults__ class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_defaults
  kind: python_call_eq
  function: Path.open.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant pathlib_extra69.path_open_defaults_len:
  description: "Path.open.__defaults__.__len__() == 5 — Path.open has 5 default argument values ('r',-1,None,None,None) for mode/buffering/encoding/errors/newline; no prior pathlib spec checks Path.open.__defaults__.__len__()==5 in pathlibcode69 namespace; novel __defaults__ length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_defaults
  kind: python_call_eq
  function: Path.open.__defaults__.__len__
  args: []
  expected: 5

invariant pathlib_extra69.path_read_text_defaults_class:
  description: "Path.read_text.__defaults__.__class__.__name__.__eq__('tuple') == True — Path.read_text.__defaults__==(None,None,None); __defaults__.__class__.__name__ is 'tuple'; no prior pathlib spec checks Path.read_text.__defaults__.__class__.__name__.__eq__('tuple') in pathlibcode69 namespace; novel __defaults__ class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_defaults
  kind: python_call_eq
  function: Path.read_text.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant pathlib_extra69.path_read_text_defaults_len:
  description: "Path.read_text.__defaults__.__len__() == 3 — Path.read_text has 3 default argument values (None,None,None) for encoding/errors/newline; no prior pathlib spec checks Path.read_text.__defaults__.__len__()==3 in pathlibcode69 namespace; novel __defaults__ length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_defaults
  kind: python_call_eq
  function: Path.read_text.__defaults__.__len__
  args: []
  expected: 3

invariant pathlib_extra69.path_open_code_class:
  description: "Path.open.__code__.__class__.__name__.__eq__('code') == True — Path.open is a pure Python function; __code__ is a code object; __class__.__name__ is 'code'; no prior pathlib spec checks Path.open.__code__.__class__.__name__.__eq__('code') in pathlibcode69 namespace; novel __code__ class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_identity
  kind: python_call_eq
  function: Path.open.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant pathlib_extra69.path_init_code_class:
  description: "Path.__init__.__code__.__class__.__name__.__eq__('code') == True — Path.__init__ is a pure Python method; __code__ is a code object; __class__.__name__ is 'code'; no prior pathlib spec checks Path.__init__.__code__.__class__.__name__.__eq__('code') in pathlibcode69 namespace; novel __code__ class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_identity
  kind: python_call_eq
  function: Path.__init__.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant pathlib_extra69.path_doc_contains_purepath:
  description: "Path.__doc__.__contains__('PurePath') == True — Path.__doc__ begins 'PurePath subclass that can make system calls.'; 'PurePath' appears; no prior pathlib spec checks Path.__doc__.__contains__('PurePath') in pathlibcode69 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Path.__doc__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra69.path_doc_contains_system:
  description: "Path.__doc__.__contains__('system') == True — Path.__doc__ begins 'PurePath subclass that can make system calls.'; 'system' appears (in 'system calls'); no prior pathlib spec checks Path.__doc__.__contains__('system') in pathlibcode69 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Path.__doc__.__contains__
  args: ["system"]
  expected: true
