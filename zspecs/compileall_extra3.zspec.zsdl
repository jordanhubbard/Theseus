spec: compileall_extra3
version: ">=3.9"
backend: python_module(compileall)

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/compileall.html — Python compileall module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/compileall.py"
  notes:
    - "This spec extends compileall.zspec.zsdl, compileall_extra.zspec.zsdl, and compileall_extra2.zspec.zsdl."
    - "Focus: __name__, __module__, and __qualname__ attributes for compile_file, compile_dir, compile_path."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function_names — compile_file, compile_dir, compile_path
# ---------------------------------------------------------------------------

table compileall_extra3.function_names:
  kind: python_call_eq
  category: names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__name__.__eq__, ["compile_file"], true]
    - [compile_dir,  compile_dir.__name__.__eq__,  ["compile_dir"],  true]
    - [compile_path, compile_path.__name__.__eq__, ["compile_path"], true]

# ---------------------------------------------------------------------------
# function_modules — compile_file, compile_dir, compile_path
# ---------------------------------------------------------------------------

invariant compileall_extra3.compile_file.module:
  description: "compileall.compile_file.__module__ == 'compileall'"
  category: modules
  kind: python_call_eq
  function: compile_file.__module__.__eq__
  args: ["compileall"]
  expected: true

invariant compileall_extra3.compile_dir.module:
  description: "compileall.compile_dir.__module__ == 'compileall'"
  category: modules
  kind: python_call_eq
  function: compile_dir.__module__.__eq__
  args: ["compileall"]
  expected: true

invariant compileall_extra3.compile_path.module:
  description: "compileall.compile_path.__module__ == 'compileall'"
  category: modules
  kind: python_call_eq
  function: compile_path.__module__.__eq__
  args: ["compileall"]
  expected: true

# ---------------------------------------------------------------------------
# qualnames — compile_file, compile_dir, compile_path
# ---------------------------------------------------------------------------

invariant compileall_extra3.compile_file.qualname:
  description: "compileall.compile_file.__qualname__ == 'compile_file'"
  category: qualnames
  kind: python_call_eq
  function: compile_file.__qualname__.__eq__
  args: ["compile_file"]
  expected: true

invariant compileall_extra3.compile_dir.qualname:
  description: "compileall.compile_dir.__qualname__ == 'compile_dir'"
  category: qualnames
  kind: python_call_eq
  function: compile_dir.__qualname__.__eq__
  args: ["compile_dir"]
  expected: true

invariant compileall_extra3.compile_path.qualname:
  description: "compileall.compile_path.__qualname__ == 'compile_path'"
  category: qualnames
  kind: python_call_eq
  function: compile_path.__qualname__.__eq__
  args: ["compile_path"]
  expected: true
