spec: hashlib_extra92
version: ">=3.9"
extends: hashlib_extra91
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra91.zspec.zsdl — covers hashlib.new function identity (__class__.__name__=='function', __qualname__=='__hash_new', __module__=='hashlib') / algorithms_available/algorithms_guaranteed set identity / blake2b BLAKE2 constant attrs / blake2b and blake2s doc class identity (table + invariants)."
    - "hashlib_extra90.zspec.zsdl — covers blake2b/blake2s class identity __name__/__module__/__bases__[0].__name__/__mro__.__len__() / blake2b/blake2s __dict__.__contains__ for copy/digest/hexdigest/update (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra91; it does NOT duplicate invariants present in those files."
    - "Wave 255 theme: hashlib.sha256/sha512/md5/sha1/sha224/sha384 class identity — __class__.__name__, __module__, and __qualname__."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All sha* and md5 hash constructors are OpenSSL-backed builtins in _hashlib; their __class__.__name__ is 'builtin_function_or_method', __module__ is '_hashlib'."
    - "Note: openssl_sha256 qualname length is 14; openssl_md5 is 11; openssl_sha1 is 12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256/__class__/__name__.__eq__('builtin_function_or_method')
# hashlib.sha256/__module__.__eq__('_hashlib')
# hashlib.sha512/__class__/__name__.__eq__('builtin_function_or_method')
# hashlib.sha512/__module__.__eq__('_hashlib')
#
# Wave 255 theme: sha256/sha512 class identity (__class__.__name__ + __module__).
#
# sha256 and sha512 are OpenSSL-backed builtin_function_or_method objects
# sourced from _hashlib. Their __class__.__name__ is 'builtin_function_or_method'
# and their __module__ is '_hashlib'. No prior hashlib spec anchors these
# attributes under hashlibhashid92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra92.sha256_sha512_identity:
  description: "hashlib.sha256/__class__.__name__.__eq__('builtin_function_or_method')==True / sha256/__module__.__eq__('_hashlib')==True / sha512/__class__.__name__.__eq__('builtin_function_or_method')==True / sha512/__module__.__eq__('_hashlib')==True — sha256 and sha512 are OpenSSL-backed C builtins from _hashlib; their __class__.__name__ is 'builtin_function_or_method' and __module__ is '_hashlib'; first hashlibhashid92 anchor for sha256/sha512 class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibhashid92

  columns: [id, function, args, expected]
  rows:
    - [sha256_class_name_eq,  sha256.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha256_module_eq,      sha256.__module__.__eq__,          ["_hashlib"],                   true]
    - [sha512_class_name_eq,  sha512.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha512_module_eq,      sha512.__module__.__eq__,          ["_hashlib"],                   true]

# ---------------------------------------------------------------------------
# hashlib.md5/__class__/__name__.__eq__('builtin_function_or_method')
# hashlib.md5/__module__.__eq__('_hashlib')
# hashlib.sha1/__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha1/__module__.__eq__('_hashlib')
#
# Wave 255 theme: md5/sha1 class identity (__class__.__name__ + __module__).
#
# md5 and sha1 are also OpenSSL-backed builtin_function_or_method objects
# from _hashlib, like sha256/sha512. This table anchors md5 and sha1 alongside
# their shared class name and module attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra92.md5_sha1_identity:
  description: "hashlib.md5/__class__.__name__.__eq__('builtin_function_or_method')==True / md5/__module__.__eq__('_hashlib')==True / sha1/__class__.__name__.__eq__('builtin_function_or_method')==True / sha1/__module__.__eq__('_hashlib')==True — md5 and sha1 are OpenSSL-backed C builtins from _hashlib with the same class identity as sha256/sha512; this table anchors md5/sha1 class name and module under hashlibhashid92; first hashlibhashid92 anchor for md5/sha1 class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibhashid92

  columns: [id, function, args, expected]
  rows:
    - [md5_class_name_eq,   md5.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [md5_module_eq,       md5.__module__.__eq__,           ["_hashlib"],                   true]
    - [sha1_class_name_eq,  sha1.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha1_module_eq,      sha1.__module__.__eq__,          ["_hashlib"],                   true]

# ---------------------------------------------------------------------------
# hashlib.sha224/__class__/__name__.__eq__('builtin_function_or_method')
# hashlib.sha224/__module__.__eq__('_hashlib')
# hashlib.sha384/__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha384/__module__.__eq__('_hashlib')
#
# Wave 255 theme: sha224/sha384 class identity (__class__.__name__ + __module__).
#
# sha224 and sha384 are OpenSSL-backed builtin_function_or_method objects
# from _hashlib, completing the group of 6 standard OpenSSL hash constructors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra92.sha224_sha384_identity:
  description: "hashlib.sha224/__class__.__name__.__eq__('builtin_function_or_method')==True / sha224/__module__.__eq__('_hashlib')==True / sha384/__class__.__name__.__eq__('builtin_function_or_method')==True / sha384/__module__.__eq__('_hashlib')==True — sha224 and sha384 are OpenSSL-backed C builtins from _hashlib; they complete the 6-member group (sha256/sha512/md5/sha1/sha224/sha384) sharing __class__.__name__=='builtin_function_or_method' and __module__=='_hashlib'; first hashlibhashid92 anchor for sha224/sha384 class identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibhashid92

  columns: [id, function, args, expected]
  rows:
    - [sha224_class_name_eq,  sha224.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha224_module_eq,      sha224.__module__.__eq__,          ["_hashlib"],                   true]
    - [sha384_class_name_eq,  sha384.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha384_module_eq,      sha384.__module__.__eq__,          ["_hashlib"],                   true]

# ---------------------------------------------------------------------------
# hashlib.sha256/__qualname__.__eq__('openssl_sha256')
# hashlib.md5/__qualname__.__eq__('openssl_md5')
# hashlib.sha1/__qualname__.__eq__('openssl_sha1')
# hashlib.sha512/__qualname__.__eq__('openssl_sha512')
#
# Wave 255 theme: hash constructor qualname cross-checks.
#
# The OpenSSL-backed hash constructors have __qualname__ values matching their
# internal C function names: openssl_sha256 (14), openssl_md5 (11),
# openssl_sha1 (12), openssl_sha512 (14). This table anchors the qualname
# equality calls as cross-checks.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra92.hash_qualname_cross_checks:
  description: "hashlib.sha256/__qualname__.__eq__('openssl_sha256')==True / md5/__qualname__.__eq__('openssl_md5')==True / sha1/__qualname__.__eq__('openssl_sha1')==True / sha512/__qualname__.__eq__('openssl_sha512')==True — the OpenSSL-backed hash constructors carry __qualname__ values matching their internal C function names (openssl_sha256/openssl_md5/openssl_sha1/openssl_sha512); this table anchors the qualname equality cross-checks across four algorithms; first hashlibhashid92 anchor for hash constructor __qualname__.__eq__ calls"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibhashid92

  columns: [id, function, args, expected]
  rows:
    - [sha256_qualname_eq,  sha256.__qualname__.__eq__,  ["openssl_sha256"], true]
    - [md5_qualname_eq,     md5.__qualname__.__eq__,     ["openssl_md5"],    true]
    - [sha1_qualname_eq,    sha1.__qualname__.__eq__,    ["openssl_sha1"],   true]
    - [sha512_qualname_eq,  sha512.__qualname__.__eq__,  ["openssl_sha512"], true]

# ---------------------------------------------------------------------------
# hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.sha256 is an OpenSSL-backed C builtin from _hashlib. Its
# __class__.__name__ is 'builtin_function_or_method'. No prior hashlib spec
# anchors sha256.__class__.__name__.__eq__ under this id_prefix.
# First __class__.__name__.__eq__ standalone for hashlib.sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra92.sha256_class_name_eq:
  description: "hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') == True — sha256 is an OpenSSL-backed C builtin in _hashlib; its __class__.__name__ is 'builtin_function_or_method' (not 'function'); first __class__.__name__.__eq__ standalone for hashlib.sha256 under hashlibhashid92"
  category: class_attrs
  kind: python_call_eq
  function: sha256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha256.__module__ is '_hashlib', indicating the constructor is
# implemented in the C extension _hashlib. No prior hashlib spec anchors
# sha256.__module__.__eq__ under this id_prefix.
# First __module__.__eq__ standalone for hashlib.sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra92.sha256_module_eq:
  description: "hashlib.sha256.__module__.__eq__('_hashlib') == True — sha256.__module__ is '_hashlib', the C extension module providing OpenSSL-backed hash constructors; first __module__.__eq__ standalone for hashlib.sha256 under hashlibhashid92"
  category: class_attrs
  kind: python_call_eq
  function: sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__eq__('openssl_md5') — standalone
#
# hashlib.md5.__qualname__ is 'openssl_md5'. Its qualname length is 11 chars.
# No prior hashlib spec anchors md5.__qualname__.__eq__ under this id_prefix.
# First __qualname__.__eq__ standalone for hashlib.md5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra92.md5_qualname_eq:
  description: "hashlib.md5.__qualname__.__eq__('openssl_md5') == True — md5.__qualname__ is 'openssl_md5' (the internal C function name, 11 chars); first __qualname__.__eq__ standalone for hashlib.md5 under hashlibhashid92"
  category: class_attrs
  kind: python_call_eq
  function: md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha224.__qualname__.__eq__('openssl_sha224') — standalone
#
# hashlib.sha224.__qualname__ is 'openssl_sha224' (14 chars). No prior hashlib
# spec anchors sha224.__qualname__.__eq__ under this id_prefix.
# First __qualname__.__eq__ standalone for hashlib.sha224.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra92.sha224_qualname_eq:
  description: "hashlib.sha224.__qualname__.__eq__('openssl_sha224') == True — sha224.__qualname__ is 'openssl_sha224' (14 chars, same length as sha256/sha512/sha384 qualnames); first __qualname__.__eq__ standalone for hashlib.sha224 under hashlibhashid92"
  category: class_attrs
  kind: python_call_eq
  function: sha224.__qualname__.__eq__
  args: ["openssl_sha224"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha384.__qualname__.__eq__('openssl_sha384') — standalone
#
# hashlib.sha384.__qualname__ is 'openssl_sha384' (14 chars). No prior hashlib
# spec anchors sha384.__qualname__.__eq__ under this id_prefix.
# First __qualname__.__eq__ standalone for hashlib.sha384.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra92.sha384_qualname_eq:
  description: "hashlib.sha384.__qualname__.__eq__('openssl_sha384') == True — sha384.__qualname__ is 'openssl_sha384' (14 chars, completing the sha224/sha256/sha384/sha512 group of 14-char openssl qualnames); first __qualname__.__eq__ standalone for hashlib.sha384 under hashlibhashid92"
  category: class_attrs
  kind: python_call_eq
  function: sha384.__qualname__.__eq__
  args: ["openssl_sha384"]
  expected: true
