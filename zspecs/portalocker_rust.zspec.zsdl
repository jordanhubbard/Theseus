spec: portalocker_rust
version: ">=3.9"
backend: rust_module(portalocker_rust)

docs: https://portalocker.readthedocs.io/

provenance:
  derived_from:
    - "https://portalocker.readthedocs.io/ — portalocker documentation"
  not_derived_from:
    - "portalocker source: portalocker/portalocker.py"
  notes:
    - "portalocker provides cross-platform file locking and more."
    - "portalocker.LOCK_EX, LOCK_SH, LOCK_UN — lock constants."
    - "portalocker.LOCK_EX == 2 on POSIX (fcntl.LOCK_EX)."
    - "portalocker.LOCK_SH == 1 on POSIX (fcntl.LOCK_SH)."
    - "portalocker.LOCK_UN == 8 on POSIX (fcntl.LOCK_UN)."
    - "Expose lock_ex_const() -> int: portalocker.LOCK_EX."
    - "Expose lock_sh_const() -> int: portalocker.LOCK_SH."
    - "Expose lock_un_const() -> int: portalocker.LOCK_UN."
    - "Expose can_lock_tempfile() -> bool: lock/unlock a temp file without error."
    - "Expose lock_ex_ne_sh() -> bool: LOCK_EX != LOCK_SH."
    - "All test vectors verified against portalocker 3.1.1 on POSIX."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# lock constants
invariant portalocker_rust.const.lock_ex:
  description: "portalocker.LOCK_EX == 2 on POSIX"
  category: const
  kind: python_call_eq
  function: lock_ex_const
  args: []
  expected: 2

invariant portalocker_rust.const.lock_sh:
  description: "portalocker.LOCK_SH == 1 on POSIX"
  category: const
  kind: python_call_eq
  function: lock_sh_const
  args: []
  expected: 1

invariant portalocker_rust.const.lock_un:
  description: "portalocker.LOCK_UN == 8 on POSIX"
  category: const
  kind: python_call_eq
  function: lock_un_const
  args: []
  expected: 8

invariant portalocker_rust.const.ex_ne_sh:
  description: "LOCK_EX != LOCK_SH"
  category: const
  kind: python_call_eq
  function: lock_ex_ne_sh
  args: []
  expected: true

# can_lock_tempfile — functional lock/unlock
invariant portalocker_rust.lock.tempfile_lock:
  description: "can lock and unlock a temporary file without error"
  category: lock
  kind: python_call_eq
  function: can_lock_tempfile
  args: []
  expected: true

