spec: theseus_xml_etree_cr
version: ">=3.8"
backend: python_cleanroom(theseus_xml_etree_cr)
blocks: xml.etree.ElementTree

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xml.etree.elementtree.html"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py (internal implementation)"
  notes:
    - "Clean-room XML module. Do NOT import xml.etree.ElementTree."
    - "Uses Python's _elementtree C extension."
    - "Element: XML element with tag, text, attrib, tail."
    - "parse(file): parse XML file."
    - "fromstring(text): parse XML string."
    - "tostring(element): serialize to bytes."

error_model: python_exceptions

invariant theseus_xml_etree_cr.xml_etree2_fromstring:
  description: "fromstring parses XML and returns Element with tag"
  category: fromstring
  kind: python_call_eq
  function: xml_etree2_fromstring
  args: []
  expected: "root"

invariant theseus_xml_etree_cr.xml_etree2_tostring:
  description: "tostring serializes Element to bytes"
  category: tostring
  kind: python_call_eq
  function: xml_etree2_tostring
  args: []
  expected: true

invariant theseus_xml_etree_cr.xml_etree2_find:
  description: "Element.find() finds child by tag"
  category: Element
  kind: python_call_eq
  function: xml_etree2_find
  args: []
  expected: "child"
