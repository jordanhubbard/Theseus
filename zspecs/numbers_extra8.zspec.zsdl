spec: numbers_extra8
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers documentation"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl and prior extras (numbers_extra through numbers_extra7)."
    - "numbers_extra6 covers: MRO self-entry [0] for all five via table; isinstance negative checks."
    - "numbers_extra7 covers: __name__/__module__/__bases__[0].__name__ as standalone __eq__ invariants."
    - "NEW axes in this spec: Integral intermediate MRO entries [1] through [4]; Number.__dict__ type; Rational abstract methods (numerator/denominator already in numbers.zspec; new: __eq__, __mul__, __rmul__, __pow__, __rpow__); class __dict__ type for Complex and Real."
    - "numbers.Integral.__mro__[1].__name__ == 'Rational' — direct parent in MRO."
    - "numbers.Integral.__mro__[2].__name__ == 'Real' — second ancestor in MRO."
    - "numbers.Integral.__mro__[3].__name__ == 'Complex' — third ancestor in MRO."
    - "numbers.Integral.__mro__[4].__name__ == 'Number' — fourth ancestor in MRO."
    - "numbers.Number.__dict__.__class__.__name__ == 'mappingproxy' — class dict is read-only."
    - "numbers.Complex.__dict__.__class__.__name__ == 'mappingproxy' — class dict is read-only."
    - "numbers.Rational.__abstractmethods__.__contains__('__eq__') == True."
    - "numbers.Rational.__abstractmethods__.__contains__('__mul__') == True."
    - "numbers.Rational.__abstractmethods__.__contains__('__rmul__') == True."
    - "numbers.Rational.__abstractmethods__.__contains__('__pow__') == True."
    - "numbers.Rational.__abstractmethods__.__contains__('__rpow__') == True."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Integral MRO intermediate entries [1] through [4]
#
# numbers_extra5 covers MRO lengths for all five classes.
# numbers_extra6 covers MRO self-entry [0] for all five classes.
# No prior spec checks Integral.__mro__[1] through [4], which encode the
# full inheritance tower: Rational, Real, Complex, Number.
# ---------------------------------------------------------------------------

invariant numbers_extra8.Integral.mro_1:
  description: "numbers.Integral.__mro__[1].__name__ == 'Rational' — direct parent in MRO"
  category: mro_intermediate
  kind: python_call_eq
  function: Integral.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Rational"

invariant numbers_extra8.Integral.mro_2:
  description: "numbers.Integral.__mro__[2].__name__ == 'Real' — second ancestor in MRO"
  category: mro_intermediate
  kind: python_call_eq
  function: Integral.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Real"

invariant numbers_extra8.Integral.mro_3:
  description: "numbers.Integral.__mro__[3].__name__ == 'Complex' — third ancestor in MRO"
  category: mro_intermediate
  kind: python_call_eq
  function: Integral.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Complex"

invariant numbers_extra8.Integral.mro_4:
  description: "numbers.Integral.__mro__[4].__name__ == 'Number' — fourth ancestor in MRO"
  category: mro_intermediate
  kind: python_call_eq
  function: Integral.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "Number"

# ---------------------------------------------------------------------------
# class __dict__ type — mappingproxy
#
# No prior numbers spec checks the type of any class's __dict__.
# Both Number and Complex __dict__ should be mappingproxy instances,
# matching the standard Python class dictionary behavior.
# ---------------------------------------------------------------------------

invariant numbers_extra8.Number.dict_type:
  description: "numbers.Number.__dict__.__class__.__name__ == 'mappingproxy' — Number class dict is read-only"
  category: class_dict
  kind: python_call_eq
  function: Number.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant numbers_extra8.Complex.dict_type:
  description: "numbers.Complex.__dict__.__class__.__name__ == 'mappingproxy' — Complex class dict is read-only"
  category: class_dict
  kind: python_call_eq
  function: Complex.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# Rational abstract methods — arithmetic operators not yet covered
#
# numbers.zspec covers: numerator, denominator (Rational).
# numbers_extra covers: Real __trunc__/__floor__; Complex real/imag.
# numbers_extra3 covers: Real __ceil__.
# numbers_extra5 covers: Real __float__/__le__/__lt__/__rfloordiv__/__rmod__/__round__.
# numbers_extra6 covers: Complex __add__/__radd__/__sub__/__rsub__/__truediv__/__rtruediv__.
# Rational inherits all of Real+Complex abstract methods and adds none new in
# terms of what's already covered. However these specific methods for Rational
# have not been independently verified: __eq__, __mul__, __rmul__, __pow__, __rpow__.
# ---------------------------------------------------------------------------

table numbers_extra8.abstract_methods.rational_arith:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: rational_arith

  columns: [id, function, args, expected]
  rows:
    - [eq,   Rational.__abstractmethods__.__contains__, ["__eq__"],   true]
    - [mul,  Rational.__abstractmethods__.__contains__, ["__mul__"],  true]
    - [rmul, Rational.__abstractmethods__.__contains__, ["__rmul__"], true]
    - [pow,  Rational.__abstractmethods__.__contains__, ["__pow__"],  true]
    - [rpow, Rational.__abstractmethods__.__contains__, ["__rpow__"], true]

# ---------------------------------------------------------------------------
# Real abstract methods — remaining operators
#
# numbers_extra5 covers Real: __float__/__le__/__lt__/__rfloordiv__/__rmod__/__round__.
# numbers_extra covers Real: __trunc__/__floor__.
# numbers_extra3 covers Real: __ceil__.
# New here: __truediv__, __rtruediv__, __mul__, __rmul__, __add__, __radd__.
# (Real inherits these from Complex abstractmethods.)
# ---------------------------------------------------------------------------

table numbers_extra8.abstract_methods.real_arithmetic:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: real_arith

  columns: [id, function, args, expected]
  rows:
    - [truediv,  Real.__abstractmethods__.__contains__, ["__truediv__"],  true]
    - [rtruediv, Real.__abstractmethods__.__contains__, ["__rtruediv__"], true]
    - [mul,      Real.__abstractmethods__.__contains__, ["__mul__"],      true]
    - [rmul,     Real.__abstractmethods__.__contains__, ["__rmul__"],     true]
    - [add,      Real.__abstractmethods__.__contains__, ["__add__"],      true]
    - [radd,     Real.__abstractmethods__.__contains__, ["__radd__"],     true]
