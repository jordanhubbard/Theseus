spec: re_extra318
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern behavioral invariants
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# re.compile(r'\d+').search('abc123').__class__.__name__ == 'Match'
# re.compile(r'\d+').search('abc123').group() == '123'
# re.compile(r'\d+').findall('abc123def456') == ['123', '456']  (len == 2)
# re.compile(r'\d+').sub('N', 'abc123def456') == 'abcNdefN'
# re.compile(r'(\w+)').groups == 1 (int attribute, number of capturing groups)
# re.compile(r'(\w+)(?P<name>\w+)').groups == 2
# re.compile(r'(?P<name>\w+)').groupindex == {'name': 1} (mappingproxy)
# ---------------------------------------------------------------------------

invariant re_extra318.compile.search_class_name:
  description: "re.compile(r'\\d+').search('abc123').__class__.__name__ == 'Match' — search() returns a Match object on success; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('\\d+').search('abc123').__class__.__name__.__eq__"
  args: ["Match"]
  expected: true

invariant re_extra318.compile.search_group:
  description: "re.compile(r'\\d+').search('abc123').group().__eq__('123') == True — search() finds the first digit sequence '123'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('\\d+').search('abc123').group().__eq__"
  args: ["123"]
  expected: true

invariant re_extra318.compile.findall_len:
  description: "re.compile(r'\\d+').findall('abc123def456').__len__() == 2 — findall returns all non-overlapping matches; '123' and '456'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('\\d+').findall('abc123def456').__len__"
  args: []
  expected: 2

invariant re_extra318.compile.findall_eq:
  description: "re.compile(r'\\d+').findall('abc123def456').__eq__(['123', '456']) == True — findall returns the two matched substrings in order; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('\\d+').findall('abc123def456').__eq__"
  args: [["123", "456"]]
  expected: true

invariant re_extra318.compile.sub_eq:
  description: "re.compile(r'\\d+').sub('N', 'abc123def456').__eq__('abcNdefN') == True — sub replaces each digit sequence with 'N'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('\\d+').sub('N', 'abc123def456').__eq__"
  args: ["abcNdefN"]
  expected: true

invariant re_extra318.compile.groups_one_group:
  description: "re.compile(r'(\\w+)').groups == 1 — the .groups attribute is an int counting capturing groups in the pattern; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('(\\w+)').groups.__eq__"
  args: [1]
  expected: true

invariant re_extra318.compile.groups_two_groups:
  description: "re.compile(r'(\\w+)(?P<name>\\w+)').groups == 2 — two capturing groups (one unnamed, one named); verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('(\\w+)(?P<name>\\w+)').groups.__eq__"
  args: [2]
  expected: true

invariant re_extra318.compile.groupindex_eq:
  description: "re.compile(r'(?P<name>\\w+)').groupindex.__eq__({'name': 1}) == True — groupindex maps named groups to their capture-group index; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "compile('(?P<name>\\w+)').groupindex.__eq__"
  args: [{"name": 1}]
  expected: true

invariant re_extra318.compile.groupindex_class_name:
  description: "re.compile(r'(?P<name>\\w+)').groupindex.__class__.__name__ == 'mappingproxy' — groupindex is a read-only mappingproxy; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: "compile('(?P<name>\\w+)').groupindex.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# re.Pattern behavioral vectors — table form
# Groups attribute and groupindex for various patterns
# ---------------------------------------------------------------------------

table re_extra318.pattern_groups_attr:
  description: "re.compile(...).groups attribute values for patterns with 0, 1, 2 capturing groups"
  kind: python_call_eq
  category: behavioral
  id_prefix: reextra318

  columns: [id, function, args, expected]
  rows:
    - [zero_groups,   "compile('\\d+').groups.__eq__",                [0], true]
    - [one_group,     "compile('(\\w+)').groups.__eq__",              [1], true]
    - [two_groups,    "compile('(\\w+)(?P<name>\\w+)').groups.__eq__", [2], true]

# ---------------------------------------------------------------------------
# re.Pattern.sub result class name
# sub() returns a str on success
# ---------------------------------------------------------------------------

table re_extra318.sub_result_class:
  description: "re.compile(...).sub(...) result class names"
  kind: python_call_eq
  category: classnames
  id_prefix: reextra318

  columns: [id, function, args, expected]
  rows:
    - [sub_cls,     "compile('\\d+').sub('N', 'abc123def456').__class__.__name__.__eq__", ["str"], true]
    - [search_cls,  "compile('\\d+').search('abc123').__class__.__name__.__eq__",         ["Match"], true]
    - [findall_cls, "compile('\\d+').findall('abc123def456').__class__.__name__.__eq__",  ["list"], true]
