# ---------------------------------------------------------------------------
# Standalone invariants — extra1426
# ---------------------------------------------------------------------------

invariant functools_extra1426.partial_format_is_method_descriptor:
  description: "functools.partial.__format__.__class__.__name__ == 'method_descriptor' — __format__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: partial.__format__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant functools_extra1426.partial_format_not_in_dict:
  description: "'__format__' not in functools.partial.__dict__ — partial does not override __format__; wave 542; new to extra1426"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__format__"]
  expected: false

invariant functools_extra1426.partial_dir_is_method_descriptor:
  description: "functools.partial.__dir__.__class__.__name__ == 'method_descriptor' — __dir__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: partial.__dir__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant functools_extra1426.partial_dir_not_in_dict:
