# ---------------------------------------------------------------------------

table functools_extra1426.format_dir_dict_membership:
  description: "functools classes: '__format__' and '__dir__' not in own __dict__ for partial, cached_property, singledispatchmethod, partialmethod; wave 542; new to extra1426"
