spec: functools_extra1426
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools_extra1411.zspec.zsdl — covers __sizeof__ and __reduce_ex__ method type and dict-membership for partial, cached_property, singledispatchmethod, partialmethod"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for functools classes."
    - "functools.partial.__format__.__class__.__name__ == 'method_descriptor' — partial is a C extension type; __format__ inherited from object. Verified Python 3.14.3."
    - "functools.cached_property.__format__.__class__.__name__ == 'method_descriptor' — cached_property inherits __format__ from object. Verified Python 3.14.3."
    - "functools.singledispatchmethod.__format__.__class__.__name__ == 'method_descriptor' — singledispatchmethod inherits __format__ from object. Verified Python 3.14.3."
    - "functools.partialmethod.__format__.__class__.__name__ == 'method_descriptor' — partialmethod inherits __format__ from object. Verified Python 3.14.3."
    - "None of partial, cached_property, singledispatchmethod, partialmethod define '__format__' in their own __dict__. Verified Python 3.14.3."
    - "functools.partial.__dir__.__class__.__name__ == 'method_descriptor' — partial inherits __dir__ from object. Verified Python 3.14.3."
    - "functools.cached_property.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "functools.singledispatchmethod.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "functools.partialmethod.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "None of partial, cached_property, singledispatchmethod, partialmethod define '__dir__' in their own __dict__. Verified Python 3.14.3."
    - "functools.partial.__format__.__doc__.__class__.__name__ == 'str' — the __format__ docstring is a str object. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools class __format__ method type checks
#
# Wave 542 theme: __format__.__class__.__name__ checks for functools classes.
# All four classes — partial, cached_property, singledispatchmethod,
# partialmethod — inherit __format__ from object, appearing as 'method_descriptor'.
# None define __format__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1426.format_class_name:
  description: "functools classes: __format__.__class__.__name__ == 'method_descriptor' for partial, cached_property, singledispatchmethod, partialmethod; wave 542; new to extra1426"
  kind: python_call_eq
  category: format_class_name
  id_prefix: fu1426fc

  columns: [id, function, args, expected, description]
  rows:
    - [fu1426fc001,
       "partial.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__format__.__class__.__name__.__eq__('method_descriptor') == True — partial is a C extension type; __format__ is inherited from object as a method_descriptor on the class object; new to extra1426"]
    - [fu1426fc002,
       "cached_property.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.cached_property.__format__.__class__.__name__.__eq__('method_descriptor') == True — cached_property inherits __format__ from object as a method_descriptor; new to extra1426"]
    - [fu1426fc003,
       "singledispatchmethod.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.singledispatchmethod.__format__.__class__.__name__.__eq__('method_descriptor') == True — singledispatchmethod inherits __format__ from object as a method_descriptor; new to extra1426"]
    - [fu1426fc004,
       "partialmethod.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partialmethod.__format__.__class__.__name__.__eq__('method_descriptor') == True — partialmethod inherits __format__ from object as a method_descriptor; new to extra1426"]
    - [fu1426fc005,
       "partial.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__format__.__doc__.__class__.__name__.__eq__('str') == True — the __format__ docstring is a str object; new to extra1426"]
    - [fu1426fc006,
       "cached_property.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.cached_property.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]
    - [fu1426fc007,
       "singledispatchmethod.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.singledispatchmethod.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]
    - [fu1426fc008,
       "partialmethod.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partialmethod.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]

