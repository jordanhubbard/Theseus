# ---------------------------------------------------------------------------

table concurrent_futures_extra223.dict_executor_members:
  description: "concurrent.futures.__dict__.__contains__ checks for executor classes in cf223de namespace"
  kind: python_call_eq
  category: dict_membership
  id_prefix: cf223de

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_Executor,            __dict__.__contains__, ["Executor"],            true,  "concurrent.futures.__dict__.__contains__('Executor') == True — Executor present in module __dict__; verified with Python 3.14.3"]
    - [dict_has_ThreadPoolExecutor,  __dict__.__contains__, ["ThreadPoolExecutor"],  false, "concurrent.futures.__dict__.__contains__('ThreadPoolExecutor') == False — lazily loaded, not in __dict__ in fresh interpreter; verified with Python 3.14.3"]
    - [dict_has_ProcessPoolExecutor, __dict__.__contains__, ["ProcessPoolExecutor"], false, "concurrent.futures.__dict__.__contains__('ProcessPoolExecutor') == False — lazily loaded, not in __dict__ in fresh interpreter; verified with Python 3.14.3"]

