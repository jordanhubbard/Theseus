spec: concurrent_futures_extra223
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "concurrent.futures.__dict__.__contains__('Executor') == True — Executor is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('ThreadPoolExecutor') == False — ThreadPoolExecutor is lazily loaded and NOT in module __dict__ in a fresh interpreter; accessible via attribute but not in __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('ProcessPoolExecutor') == False — ProcessPoolExecutor is lazily loaded and NOT in module __dict__ in a fresh interpreter; accessible via attribute but not in __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('Future') == True — Future is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('as_completed') == True — as_completed is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('wait') == True — wait is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('FIRST_COMPLETED') == True — FIRST_COMPLETED is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('ALL_COMPLETED') == True — ALL_COMPLETED is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('CancelledError') == True — CancelledError is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('TimeoutError') == True — TimeoutError is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('BrokenExecutor') == True — BrokenExecutor is present in module __dict__; verified with Python 3.14.3."
    - "concurrent.futures.__dict__.__contains__('InvalidStateError') == True — InvalidStateError is present in module __dict__; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
