spec: inspect_extra122
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra121.zspec.zsdl."
    - "This spec covers: inspect.stack and inspect.trace function __code__.co_varnames elements not previously covered — stack co_varnames[0]='context'(7), stack co_varnames len=1; trace co_varnames[0]='context'(7), trace co_varnames[1]='exc'(3), trace co_varnames[2]='tb'(2), trace co_varnames len=3; co_consts docstring attributes; wave 273."
    - "Prior spec extra111 covered stack.__code__.co_name=='stack', stack.__code__.co_argcount==1, trace.__code__.co_name=='trace', trace.__code__.co_argcount==1. New here: the co_varnames elements (parameter and local names) for both functions; co_consts lengths."
    - "inspect.stack.__code__.co_varnames[0] == 'context' (len 7). Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_varnames.__len__() == 1. Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_varnames[0] == 'context' (len 7). Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_varnames[1] == 'exc' (len 3). Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_varnames[2] == 'tb' (len 2). Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_varnames.__len__() == 3. Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_consts.__len__() == 1 (docstring only). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.stack __code__.co_varnames[0] and tuple length
#
# Wave 273 theme: inspect.stack(context=1) is a thin wrapper around
# getouterframes(sys._getframe(1), context). Its code object has co_varnames
# with exactly 1 entry: co_varnames[0] == 'context' (7 chars) — the only
# declared parameter controlling how many lines of context to include in each
# FrameInfo. There are no additional internal locals because stack's
# implementation is a single return statement. This makes it the simplest
# co_varnames among the three stack-inspection functions: stack (1 entry),
# getinnerframes (5 entries, extra121), getouterframes (5 entries, extra121).
# Prior extra111 covered stack.__code__.co_argcount==1 and co_name=='stack'.
# New here: the string value and length of co_varnames[0].
#
# stack.__code__.co_varnames[0] == 'context'  (len 7)
# stack.__code__.co_varnames.__len__() == 1
#
# New to extra122.
# ---------------------------------------------------------------------------

table inspect_extra122.stack_co_varnames:
  description: "inspect.stack co_varnames[0]='context'(7); tuple len=1; simplest co_varnames among stack inspection functions; prior extra111 covered co_name and co_argcount; wave 273; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectscv122

  columns: [id, function, args, expected, description]
  rows:
    - [stack_cv0_eq,
       "stack.__code__.co_varnames.__getitem__",
       [0],
       "context",
       "inspect.stack.__code__.co_varnames[0] == 'context' — the sole parameter of stack(context=1); controls how many lines of context to include per FrameInfo; defaults to 1; tuple.__getitem__(0) returns 'context'; new to extra122"]
    - [stack_cv0_len,
       "stack.__code__.co_varnames.__getitem__(0).__len__",
       [],
       7,
       "inspect.stack.__code__.co_varnames[0].__len__() == 7 — 'context' has 7 chars: c-o-n-t-e-x-t; same as trace co_varnames[0] 'context' (also 7); str.__len__() returns 7; new to extra122"]
    - [stack_cv_len,
       "stack.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.stack.__code__.co_varnames.__len__() == 1 — stack has only 1 local variable name: 'context'; no internal locals; the implementation is a single return statement calling getouterframes; tuple.__len__() returns 1; new to extra122"]
    - [stack_cv0_is_context,
       "stack.__code__.co_varnames.__getitem__(0).__eq__",
       ["context"],
       true,
       "inspect.stack.__code__.co_varnames[0].__eq__('context') == True — 'context' is the parameter name; same name as trace co_varnames[0]; both stack and trace share this parameter name and default; str.__eq__('context') returns True; new to extra122"]
    - [stack_co_consts_len,
       "stack.__code__.co_consts.__len__",
       [],
       1,
       "inspect.stack.__code__.co_consts.__len__() == 1 — co_consts for stack contains only the docstring; no numeric literals or string constants in the body; tuple.__len__() returns 1; new to extra122"]

# ---------------------------------------------------------------------------
# Table 2: inspect.trace __code__.co_varnames[0], [1], [2] and tuple length
#
# Wave 273 theme: inspect.trace(context=1) returns the stack trace for the
# current exception. Unlike stack (1 co_varname), trace has 3: co_varnames[0]
# == 'context' (7 chars) — same parameter name as stack; co_varnames[1] ==
# 'exc' (3 chars) — the current exception obtained from sys.exc_info()[1];
# co_varnames[2] == 'tb' (2 chars) — the traceback object from sys.exc_info()[2],
# passed to getinnerframes. 'tb' in trace mirrors 'tb' in getinnerframes
# co_varnames[0] (extra121): both use the standard Python abbreviation for
# traceback. trace has 3 co_varnames while stack has only 1, reflecting that
# trace must unpack sys.exc_info() into local variables.
#
# trace.__code__.co_varnames[0] == 'context'  (len 7)
# trace.__code__.co_varnames[1] == 'exc'      (len 3)
# trace.__code__.co_varnames[2] == 'tb'       (len 2)
# trace.__code__.co_varnames.__len__() == 3
#
# New to extra122.
# ---------------------------------------------------------------------------

table inspect_extra122.trace_co_varnames:
  description: "inspect.trace co_varnames[0]='context'(7), [1]='exc'(3), [2]='tb'(2); tuple len=3; 'tb' mirrors getinnerframes cv[0] (extra121); trace has more locals than stack (1) due to sys.exc_info() unpacking; wave 273; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspecttrCV122

  columns: [id, function, args, expected, description]
  rows:
    - [trace_cv0_eq,
       "trace.__code__.co_varnames.__getitem__",
       [0],
       "context",
       "inspect.trace.__code__.co_varnames[0] == 'context' — the sole parameter of trace(context=1); controls how many lines of context to include per FrameInfo; defaults to 1; same parameter name as stack; tuple.__getitem__(0) returns 'context'; new to extra122"]
    - [trace_cv1_eq,
       "trace.__code__.co_varnames.__getitem__",
       [1],
       "exc",
       "inspect.trace.__code__.co_varnames[1] == 'exc' — the current exception object obtained from sys.exc_info()[1]; stored locally before being passed along; 'exc' is a common Python abbreviation for exception; tuple.__getitem__(1) returns 'exc'; new to extra122"]
    - [trace_cv1_len,
       "trace.__code__.co_varnames.__getitem__(1).__len__",
       [],
       3,
       "inspect.trace.__code__.co_varnames[1].__len__() == 3 — 'exc' has 3 chars: e-x-c; standard abbreviation for exception; one more than 'tb' (2); str.__len__() returns 3; new to extra122"]
    - [trace_cv2_eq,
       "trace.__code__.co_varnames.__getitem__",
       [2],
       "tb",
       "inspect.trace.__code__.co_varnames[2] == 'tb' — the traceback object from sys.exc_info()[2]; passed to getinnerframes(tb, context); mirrors getinnerframes.__code__.co_varnames[0] == 'tb' (extra121); tuple.__getitem__(2) returns 'tb'; new to extra122"]
    - [trace_cv2_len,
       "trace.__code__.co_varnames.__getitem__(2).__len__",
       [],
       2,
       "inspect.trace.__code__.co_varnames[2].__len__() == 2 — 'tb' has 2 chars: t-b; the shortest co_varnames entry in trace; same length as getinnerframes.__code__.co_varnames[0] 'tb' (extra121); str.__len__() returns 2; new to extra122"]
    - [trace_cv_len,
       "trace.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.trace.__code__.co_varnames.__len__() == 3 — trace has 3 local variable names: 1 declared parameter (context) + 2 internal locals (exc, tb from sys.exc_info()); more than stack (1) because trace unpacks sys.exc_info(); tuple.__len__() returns 3; new to extra122"]

# ---------------------------------------------------------------------------
# Table 3: inspect.stack vs inspect.trace co_varnames cross-comparison
#
# Wave 273 theme: A cross-comparison of co_varnames lengths and the shared
# 'context' parameter. Both stack and trace take context=1 as their only
# declared parameter, so co_varnames[0] == 'context' for both. However, trace
# also stores exc and tb as internal locals (from sys.exc_info()). stack has
# co_varnames length 1 (only the parameter); trace has length 3 (parameter +
# 2 locals). The 'context' parameter is identical in string and length for both.
# trace co_varnames[2] == 'tb' (2 chars) is the shortest entry across both
# functions. trace co_varnames[0] == stack co_varnames[0] == 'context'.
#
# stack.__code__.co_varnames.__len__() == 1
# trace.__code__.co_varnames.__len__() == 3
# stack and trace co_varnames[0] are both 'context'
#
# New to extra122.
# ---------------------------------------------------------------------------

table inspect_extra122.stack_vs_trace_co_varnames_comparison:
  description: "inspect stack vs trace co_varnames: both cv[0]='context'(7); stack len=1, trace len=3; trace has 2 extra locals (exc, tb) from sys.exc_info() unpacking; 'tb' cv[2] is shortest entry; wave 273; new to extra122"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectsvtcvc122

  columns: [id, function, args, expected, description]
  rows:
    - [stack_cv_len_1,
       "stack.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.stack.__code__.co_varnames.__len__() == 1 — stack's body is a single return statement; no internal locals; only the 'context' parameter; simpler than trace (3) and getouterframes (5); tuple.__len__() returns 1; new to extra122"]
    - [trace_cv_len_3,
       "trace.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.trace.__code__.co_varnames.__len__() == 3 — trace unpacks sys.exc_info() into exc and tb locals; 1 declared parameter + 2 internal locals; more than stack (1); tuple.__len__() returns 3; new to extra122"]
    - [stack_cv0_eq_trace_cv0,
       "stack.__code__.co_varnames.__getitem__(0).__eq__",
       ["context"],
       true,
       "inspect.stack.__code__.co_varnames[0].__eq__('context') == True — confirming stack cv[0] is 'context', the same as trace cv[0]; both functions share this parameter name and default value of 1; str.__eq__('context') returns True; new to extra122"]
    - [trace_cv2_tb_len,
       "trace.__code__.co_varnames.__getitem__(2).__len__",
       [],
       2,
       "inspect.trace.__code__.co_varnames[2].__len__() == 2 — 'tb' has 2 chars; the shortest co_varnames entry across both stack and trace; matches getinnerframes cv[0] 'tb' (extra121); str.__len__() returns 2; new to extra122"]
    - [trace_cv1_exc_ne_tb,
       "trace.__code__.co_varnames.__getitem__(1).__eq__",
       ["tb"],
       false,
       "inspect.trace.__code__.co_varnames[1].__eq__('tb') == False — cv[1] is 'exc', not 'tb'; 'exc' and 'tb' are distinct locals even though both are common Python abbreviations; str.__eq__('tb') returns False; new to extra122"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra122
# ---------------------------------------------------------------------------

invariant inspect_extra122.stack_cv0_context:
  description: "inspect.stack.__code__.co_varnames[0] == 'context' — sole parameter; controls context lines per FrameInfo; 7 chars; prior extra111 covered co_name and co_argcount; wave 273; new to extra122"
  kind: python_call_eq
  function: "stack.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "context"

invariant inspect_extra122.stack_cv_len:
  description: "inspect.stack.__code__.co_varnames.__len__() == 1 — only the 'context' parameter; no internal locals; single-statement implementation; wave 273; new to extra122"
  kind: python_call_eq
  function: stack.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant inspect_extra122.trace_cv1_exc:
  description: "inspect.trace.__code__.co_varnames[1] == 'exc' — exception object from sys.exc_info()[1]; 3 chars; trace has 2 extra locals vs stack's 0; wave 273; new to extra122"
  kind: python_call_eq
  function: "trace.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "exc"

invariant inspect_extra122.trace_cv2_tb:
  description: "inspect.trace.__code__.co_varnames[2] == 'tb' — traceback object from sys.exc_info()[2]; 2 chars; shortest entry; mirrors getinnerframes cv[0] (extra121); wave 273; new to extra122"
  kind: python_call_eq
  function: "trace.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "tb"

invariant inspect_extra122.trace_cv_len:
  description: "inspect.trace.__code__.co_varnames.__len__() == 3 — 1 param + 2 locals (exc, tb); trace is more complex than stack (1 local); wave 273; new to extra122"
  kind: python_call_eq
  function: trace.__code__.co_varnames.__len__
  args: []
  expected: 3

