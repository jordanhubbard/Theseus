spec: socket_extra57
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra56.zspec.zsdl — covers socket.__all__.__contains__ for 'AF_INET'/'SOCK_STREAM'/'socket'/'herror'/'gaierror' (table); socket.socket/__eq__/__class__/__name__.__eq__('wrapper_descriptor'); herror/gaierror/timeout __eq__.__class__.__name__.__eq__('wrapper_descriptor'); AF_INET/SOCK_STREAM.__eq__.__class__.__name__.__eq__('method-wrapper')."
    - "socket_extra55.zspec.zsdl — covers socket.socket/herror/gaierror/timeout __repr__/__hash__.__class__.__name__.__eq__; SOCK_RAW.__class__.__qualname__.__eq__('SocketKind')."
    - "socket_extra49.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/getfqdn/__doc__/__class__/__name__.__eq__('str') and socket module __doc__.__class__.__name__/__qualname__.__eq__('str')."
    - "socket_extra48.zspec.zsdl — covers socket.herror/gaierror/timeout/socket.socket __doc__.__class__.__name__.__eq__('str')."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238 and socket.__all__.__class__.__name__.__eq__('list') (standalone invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra56; it does NOT duplicate invariants present in those files."
    - "Wave 224 theme: __all__.__contains__ membership + module __package__ identity + class __doc__.__class__.__name__ checks."
    - "NOTE: socket.__package__ covered by early socket specs. NOT duplicated here."
    - "NOTE: socket.socket.__doc__.__class__.__name__.__eq__('str') covered by socket_extra48. NOT duplicated here."
    - "NOTE: socket.gethostname.__doc__.__class__.__name__.__eq__('str') covered by socket_extra49. NOT duplicated here."
    - "NOTE: socket.herror.__doc__ is None on Python 3.14.3 macOS/Darwin 25.4.0 (herror inherits from OSError but has no docstring string at the Python level). socket_extra48 covers herror/gaierror/timeout with expected='str'; this was either for a different Python version or version-specific behavior. The NoneType check below reflects the Python 3.14.3 verified state."
    - "Coverage gap 1: socket_extra56 checks __all__.__contains__ for 'AF_INET'/'SOCK_STREAM'/'socket'/'herror'/'gaierror'. No prior socket spec checks __all__.__contains__ for 'gethostname', 'gethostbyname', 'getaddrinfo', or 'timeout'. socket.__all__ is a list of 238 names (verified: socket_extra30). These names cover module-level functions and the timeout exception class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__contains__('gethostname') == True. 'gethostname' is in socket.__all__; socket_extra56 checks AF_INET/SOCK_STREAM/socket/herror/gaierror but NOT gethostname. No prior socket spec checks __all__.__contains__('gethostname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__contains__('gethostbyname') == True. 'gethostbyname' is in socket.__all__. No prior socket spec checks __all__.__contains__('gethostbyname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__contains__('getaddrinfo') == True. 'getaddrinfo' is in socket.__all__. No prior socket spec checks __all__.__contains__('getaddrinfo'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__all__.__contains__('timeout') == True. 'timeout' (the TimeoutError alias) is in socket.__all__. No prior socket spec checks __all__.__contains__('timeout'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks socket.__dict__.__contains__ for specific public names. socket.__dict__ is the module namespace (a mappingproxy). Checking that 'socket', 'gethostname', 'AF_INET', and 'herror' are present confirms that these objects reside in the module namespace. socket_extra53 (struct module) introduces dict.__contains__ for struct; the same axis applied to socket is novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__dict__.__contains__('socket') == True. The socket class is present in the socket module namespace. No prior socket spec checks socket.__dict__.__contains__('socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__dict__.__contains__('gethostname') == True. The gethostname function is in the socket module namespace. No prior socket spec checks socket.__dict__.__contains__('gethostname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__dict__.__contains__('AF_INET') == True. The AF_INET AddressFamily constant is in the socket module namespace. No prior socket spec checks socket.__dict__.__contains__('AF_INET'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__dict__.__contains__('herror') == True. The herror exception class is in the socket module namespace. No prior socket spec checks socket.__dict__.__contains__('herror'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: socket.herror.__doc__ is None on Python 3.14.3 macOS/Darwin 25.4.0. None.__class__.__name__ == 'NoneType'. No prior socket spec checks herror.__doc__.__class__.__name__.__eq__('NoneType'). This is the verified Python 3.14.3 state. Analogous to struct.error.__doc__ being None (struct_extra53). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__doc__ is None. herror is a Python subclass of OSError with no docstring string at the Python level; its __doc__ is None on Python 3.14.3. None.__class__.__name__ == 'NoneType'. No prior socket spec checks herror.__doc__.__class__.__name__.__eq__('NoneType'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__all__.__contains__ for function and exception names not in extra56
#
# socket_extra56 checks __all__.__contains__ for 'AF_INET', 'SOCK_STREAM',
# 'socket', 'herror', 'gaierror'. No prior socket spec checks __all__.__contains__
# for 'gethostname', 'gethostbyname', 'getaddrinfo', or 'timeout'.
# socket.__all__ is a list of 238 public names (verified: socket_extra30).
# Checking these additional names confirms that module-level functions and
# the timeout exception are in the declared public namespace.
# ---------------------------------------------------------------------------

table socket_extra57.all_contains_functions:
  description: "socket.__all__.__contains__('gethostname'/'gethostbyname'/'getaddrinfo'/'timeout') — confirms module-level functions and timeout exception in the public API list; socket_extra56 checks AF_INET/SOCK_STREAM/socket/herror/gaierror but NOT gethostname/gethostbyname/getaddrinfo/timeout; no prior socket spec checks __all__.__contains__ for any of these four names"
  kind: python_call_eq
  category: module_structure
  id_prefix: socketpkg57

  columns: [id, function, args, expected]
  rows:
    - [all_contains_gethostname,  __all__.__contains__, ["gethostname"],  true]
    - [all_contains_gethostbyname, __all__.__contains__, ["gethostbyname"], true]
    - [all_contains_getaddrinfo,  __all__.__contains__, ["getaddrinfo"],  true]
    - [all_contains_timeout,      __all__.__contains__, ["timeout"],      true]

# ---------------------------------------------------------------------------
# socket.__dict__.__contains__ for specific public names
#
# No prior socket spec checks socket.__dict__.__contains__ for any name.
# socket.__dict__ is the module namespace (a mappingproxy). Checking membership
# for 'socket', 'gethostname', 'AF_INET', and 'herror' confirms these objects
# reside in the module namespace. Distinct from __all__.__contains__ (declared
# API list) and from type/attribute checks.
# ---------------------------------------------------------------------------

table socket_extra57.dict_contains:
  description: "socket.__dict__.__contains__('socket'/'gethostname'/'AF_INET'/'herror') == True — confirms core objects are present in the module namespace; no prior socket spec checks socket.__dict__.__contains__ for any name; distinct from __all__.__contains__ (declared API list axis) and from type/attribute axes"
  kind: python_call_eq
  category: module_structure
  id_prefix: socketpkg57

  columns: [id, function, args, expected]
  rows:
    - [dict_contains_socket,      __dict__.__contains__, ["socket"],      true]
    - [dict_contains_gethostname, __dict__.__contains__, ["gethostname"], true]
    - [dict_contains_AF_INET,     __dict__.__contains__, ["AF_INET"],     true]
    - [dict_contains_herror,      __dict__.__contains__, ["herror"],      true]

# ---------------------------------------------------------------------------
# socket.herror.__doc__.__class__.__name__.__eq__('NoneType')
#
# socket.herror.__doc__ is None on Python 3.14.3 macOS/Darwin 25.4.0.
# herror is a Python subclass of OSError with no Python-level docstring.
# None.__class__.__name__ == 'NoneType'. No prior socket spec checks
# herror.__doc__.__class__.__name__.__eq__('NoneType').
# ---------------------------------------------------------------------------

invariant socket_extra57.herror_doc_class_name_nonetype:
  description: "socket.herror.__doc__.__class__.__name__.__eq__('NoneType') == True — herror.__doc__ is None on Python 3.14.3; None.__class__.__name__ == 'NoneType'; no prior socket spec checks herror.__doc__.__class__.__name__.__eq__('NoneType'); confirms the herror exception class has no Python-level docstring string"
  category: type_structure
  kind: python_call_eq
  function: herror.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
