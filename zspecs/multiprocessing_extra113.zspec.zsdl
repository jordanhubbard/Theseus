invariant multiprocessing_extra113.BaseManager_enter_coqualname_len_21:
  description: "multiprocessing.managers.BaseManager.__enter__.__code__.co_qualname.__len__() == 21 — 'BaseManager.__enter__' = 'BaseManager.'=12 + '__enter__'=9 = 21; this is the longest co_qualname in this spec; multiprocessing.managers.BaseManager.__enter__.__code__.co_qualname.__eq__('BaseManager.__enter__')==True; co_qualname matches BaseManager.__enter__.__qualname__ (both are 'BaseManager.__enter__', len=21); multiprocessing.managers.BaseManager.__enter__.__code__.co_argcount==1 (self only — __enter__ calls self.start() and returns self); compare: __exit__ co_qualname len=20 (one shorter than __enter__=21, because '__exit__'=8 < '__enter__'=9 by 1 char); co_qualname length ordering: start=17 < connect=19 < register==__init__==__exit__==20 (tied) < __enter__=21 (longest); first standalone BaseManager.__enter__ co_qualname length invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__enter__.__code__.co_qualname.__len__
  args: []
  expected: 21

invariant multiprocessing_extra113.BaseManager_register_argc_7:
  description: "multiprocessing.managers.BaseManager.register.__code__.co_argcount == 7 — register takes self, typeid, callable, proxytype, exposed, method_to_typeid, create_method (7 parameters; most args of any BaseManager method); multiprocessing.managers.BaseManager.register.__code__.co_qualname=='BaseManager.register' (len=20, tied); multiprocessing.managers.BaseManager.register.__code__.co_name=='register' (len=8); compare co_argcount values across all BaseManager methods: connect==__enter__==1 (fewest) < __exit__==4 < __init__==5 < start==3 < register==7 (most); note: start=3, __exit__=4, __init__=5, register=7 — register has by far the most parameters because it must describe the full proxy interface; BaseManager.register() is the class method that makes shared server-side objects available to clients; first standalone BaseManager.register argcount invariant in mpbm113 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.register.__code__.co_argcount.__eq__
  args: [7]
  expected: true

invariant multiprocessing_extra113.BaseManager_start_coqualname_len_17:
  description: "multiprocessing.managers.BaseManager.start.__code__.co_qualname.__len__() == 17 — 'BaseManager.start' = 'BaseManager.'=12 + 'start'=5 = 17; this is the shortest co_qualname in this spec; multiprocessing.managers.BaseManager.start.__code__.co_qualname.__eq__('BaseManager.start')==True; co_qualname matches BaseManager.start.__qualname__; multiprocessing.managers.BaseManager.start.__code__.co_argcount==3 (self, initializer, initargs); multiprocessing.managers.BaseManager.start.__code__.co_name=='start' (len=5); compare: 'start'=5 chars (shortest method name) vs '__enter__'=9 chars (longest method name); the difference between start co_qualname len=17 and __enter__ co_qualname len=21 is exactly 4 (corresponding to '__enter__'=9 minus 'start'=5 = 4); first standalone BaseManager.start co_qualname length invariant in mpbm113 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.start.__code__.co_qualname.__len__
  args: []
  expected: 17

invariant multiprocessing_extra113.SyncManager_mro_len_3:
  description: "multiprocessing.managers.SyncManager.__mro__.__len__() == 3 — SyncManager MRO is [SyncManager, BaseManager, object] (length=3); one deeper than BaseManager's MRO of length 2; multiprocessing.managers.SyncManager.__bases__[0].__name__=='BaseManager' (SyncManager inherits directly from BaseManager); multiprocessing.managers.SyncManager.__name__=='SyncManager' (len=11); multiprocessing.managers.SyncManager.__module__=='multiprocessing.managers' (len=24); SyncManager is the standard concrete manager class that registers proxies for Queue, Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier, Value, Array, Namespace, dict, list, and Pool; compare: BaseManager.__mro__.__len__()==2 < SyncManager.__mro__.__len__()==3 (SyncManager adds one level by inheriting from BaseManager); first standalone SyncManager MRO length invariant in mpbm113 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__mro__.__len__
