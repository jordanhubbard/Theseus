spec: multiprocessing_extra113
version: ">=3.11"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#managers

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — Python multiprocessing managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec extends multiprocessing_extra112.zspec.zsdl."
    - "This spec covers: wave 255 theme — multiprocessing.managers.BaseManager method co_qualname attributes (Python 3.11+) not covered in extra106-extra112. Prior specs covered: BaseManager.__name__, __module__, __bases__[0].__name__, __mro__.__len__(), start.__qualname__, connect.__qualname__, register.__qualname__ (in extra106). NOT previously covered: co_qualname values for BaseManager methods. NEW in extra113: BaseManager.start.__code__.co_qualname=='BaseManager.start' (len=17, shortest); BaseManager.connect.__code__.co_qualname=='BaseManager.connect' (len=19); BaseManager.register.__code__.co_qualname=='BaseManager.register' (len=20, tied); BaseManager.__init__.__code__.co_qualname=='BaseManager.__init__' (len=20, tied); BaseManager.__exit__.__code__.co_qualname=='BaseManager.__exit__' (len=20, tied); BaseManager.__enter__.__code__.co_qualname=='BaseManager.__enter__' (len=21, longest); SyncManager.__mro__.__len__()==3; SyncManager.__bases__[0].__name__=='BaseManager'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "BaseManager method co_qualname length ordering: start=17 (shortest) < connect=19 < register==__init__==__exit__==20 (tied) < __enter__=21 (longest). 'BaseManager.'=12 chars prefix. Method name lengths: start=5, connect=7, register=8==__init__=8==__exit__=8 (tied), __enter__=9 (longest). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "BaseManager.register.__code__.co_argcount == 7 (self, typeid, callable, proxytype, exposed, method_to_typeid, create_method — most args of any BaseManager method). BaseManager.start.__code__.co_argcount == 3 (self, initializer, initargs). BaseManager.connect.__code__.co_argcount == 1 (self only). BaseManager.__enter__.__code__.co_argcount == 1 (self only). BaseManager.__exit__.__code__.co_argcount == 4 (self, exc_type, exc_val, exc_tb). BaseManager.__init__.__code__.co_argcount == 5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager method co_qualname — extra113
#
# Wave 255 theme: BaseManager method co_qualname values (Python 3.11+).
#
# BaseManager.start.__code__.co_qualname   == 'BaseManager.start'   (len=17, shortest)
# BaseManager.connect.__code__.co_qualname == 'BaseManager.connect' (len=19)
# BaseManager.register.__code__.co_qualname == 'BaseManager.register' (len=20)
# BaseManager.__init__.__code__.co_qualname == 'BaseManager.__init__' (len=20, tied)
# BaseManager.__exit__.__code__.co_qualname == 'BaseManager.__exit__' (len=20, tied)
# BaseManager.__enter__.__code__.co_qualname == 'BaseManager.__enter__' (len=21, longest)
# ---------------------------------------------------------------------------

