spec: multiprocessing_extra227
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers multiprocessing.Process class identity and method contracts."
    - "multiprocessing.Process.__name__ == 'Process' — the class carries its unqualified name."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context' — verified Python 3.14.3; Process is defined in multiprocessing.context (not multiprocessing.process as in older versions)."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' — Process inherits from BaseProcess (defined in multiprocessing.process)."
    - "multiprocessing.Process.__qualname__ == 'Process' — top-level class; qualname equals __name__."
    - "Process.start.__qualname__ == 'BaseProcess.start' — start is inherited from BaseProcess."
    - "Process.join.__qualname__ == 'BaseProcess.join' — join is inherited from BaseProcess."
    - "Process.is_alive.__qualname__ == 'BaseProcess.is_alive' — is_alive is inherited from BaseProcess."
    - "Process.terminate.__qualname__ == 'BaseProcess.terminate' — terminate is inherited from BaseProcess."
    - "Process.run.__qualname__ == 'BaseProcess.run' — run is inherited from BaseProcess."
    - "Process.kill.__qualname__ == 'BaseProcess.kill' — kill is inherited from BaseProcess."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process class identity contracts
#
# Process.__name__, __module__, __qualname__, and __bases__[0].__name__
# confirm the class lives in multiprocessing.context on Python 3.14 and
# inherits from BaseProcess.
# ---------------------------------------------------------------------------

table multiprocessing_extra227.process_class_identity:
  description: "multiprocessing.Process class identity: name, module, qualname, and base class; new to extra227"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp227proc

  columns: [id, function, args, expected, description]
  rows:
    - [process_name_eq,
       Process.__name__.__eq__,
       ["Process"],
       true,
       "multiprocessing.Process.__name__.__eq__('Process') == True — the class carries the unqualified name 'Process'; new to extra227"]
    - [process_module_eq,
       Process.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.Process.__module__.__eq__('multiprocessing.context') == True — Process is defined in multiprocessing.context in Python 3.14.3; new to extra227"]
    - [process_qualname_eq,
       Process.__qualname__.__eq__,
       ["Process"],
       true,
       "multiprocessing.Process.__qualname__.__eq__('Process') == True — top-level class; qualname equals __name__; new to extra227"]
    - [process_name_len_7,
       Process.__name__.__len__,
       [],
       7,
       "multiprocessing.Process.__name__.__len__() == 7 — 'Process' has exactly 7 characters; new to extra227"]
    - [process_module_len_23,
       Process.__module__.__len__,
       [],
       23,
       "multiprocessing.Process.__module__.__len__() == 23 — 'multiprocessing.context' has exactly 23 characters; new to extra227"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.Process method __name__ contracts
#
# Verifies __name__ for start, join, is_alive, terminate, run, and kill.
# All of these methods are inherited from BaseProcess.
# ---------------------------------------------------------------------------

table multiprocessing_extra227.process_method_names:
  description: "multiprocessing.Process method __name__ contracts (inherited from BaseProcess); new to extra227"
  kind: python_call_eq
  category: method_names
  id_prefix: mp227procm

  columns: [id, function, args, expected, description]
  rows:
    - [start_name_eq,
       Process.start.__name__.__eq__,
       ["start"],
       true,
       "multiprocessing.Process.start.__name__.__eq__('start') == True — method name is 'start' (len=5); inherited from BaseProcess; new to extra227"]
    - [join_name_eq,
       Process.join.__name__.__eq__,
       ["join"],
       true,
       "multiprocessing.Process.join.__name__.__eq__('join') == True — method name is 'join' (len=4); inherited from BaseProcess; new to extra227"]
    - [is_alive_name_eq,
       Process.is_alive.__name__.__eq__,
       ["is_alive"],
       true,
       "multiprocessing.Process.is_alive.__name__.__eq__('is_alive') == True — method name is 'is_alive' (len=8); inherited from BaseProcess; new to extra227"]
    - [terminate_name_eq,
       Process.terminate.__name__.__eq__,
       ["terminate"],
       true,
       "multiprocessing.Process.terminate.__name__.__eq__('terminate') == True — method name is 'terminate' (len=9); inherited from BaseProcess; new to extra227"]
    - [run_name_eq,
       Process.run.__name__.__eq__,
       ["run"],
       true,
       "multiprocessing.Process.run.__name__.__eq__('run') == True — method name is 'run' (len=3); inherited from BaseProcess; new to extra227"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.Process method __qualname__ contracts
#
# Methods inherited from BaseProcess have __qualname__ == 'BaseProcess.<method>'.
# This distinguishes them from methods defined directly on Process.
# ---------------------------------------------------------------------------

table multiprocessing_extra227.process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ contracts (BaseProcess prefix); new to extra227"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mp227procmq

  columns: [id, function, args, expected, description]
  rows:
    - [start_qualname_eq,
       Process.start.__qualname__.__eq__,
       ["BaseProcess.start"],
       true,
       "multiprocessing.Process.start.__qualname__.__eq__('BaseProcess.start') == True — start is inherited from BaseProcess; qualname is 'BaseProcess.start' (len=17); new to extra227"]
    - [join_qualname_eq,
       Process.join.__qualname__.__eq__,
       ["BaseProcess.join"],
       true,
       "multiprocessing.Process.join.__qualname__.__eq__('BaseProcess.join') == True — join is inherited from BaseProcess; qualname is 'BaseProcess.join' (len=16); new to extra227"]
    - [is_alive_qualname_eq,
       Process.is_alive.__qualname__.__eq__,
       ["BaseProcess.is_alive"],
       true,
       "multiprocessing.Process.is_alive.__qualname__.__eq__('BaseProcess.is_alive') == True — is_alive is inherited from BaseProcess; qualname is 'BaseProcess.is_alive' (len=20); new to extra227"]
    - [terminate_qualname_eq,
       Process.terminate.__qualname__.__eq__,
       ["BaseProcess.terminate"],
       true,
       "multiprocessing.Process.terminate.__qualname__.__eq__('BaseProcess.terminate') == True — terminate is inherited from BaseProcess; qualname is 'BaseProcess.terminate' (len=21); new to extra227"]
    - [run_qualname_eq,
       Process.run.__qualname__.__eq__,
       ["BaseProcess.run"],
       true,
       "multiprocessing.Process.run.__qualname__.__eq__('BaseProcess.run') == True — run is inherited from BaseProcess; qualname is 'BaseProcess.run' (len=15); new to extra227"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra227
# ---------------------------------------------------------------------------

invariant multiprocessing_extra227.Process.name:
  description: "multiprocessing.Process.__name__ == 'Process'; new to extra227"
  category: class_identity
  kind: python_call_eq
  function: Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra227.Process.module:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.context'; verified Python 3.14.3; new to extra227"
  category: class_identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra227.Process.qualname:
  description: "multiprocessing.Process.__qualname__ == 'Process' — top-level class; new to extra227"
  category: class_identity
  kind: python_call_eq
  function: Process.__qualname__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra227.Process.base_name:
  description: "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'; new to extra227"
  category: class_identity
  kind: python_call_eq
  function: "Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra227.Process.start_name:
  description: "multiprocessing.Process.start.__name__ == 'start'; new to extra227"
  category: method_names
  kind: python_call_eq
  function: Process.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant multiprocessing_extra227.Process.start_qualname:
  description: "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start'; new to extra227"
  category: method_qualnames
  kind: python_call_eq
  function: Process.start.__qualname__.__eq__
  args: ["BaseProcess.start"]
  expected: true

invariant multiprocessing_extra227.Process.join_name:
  description: "multiprocessing.Process.join.__name__ == 'join'; new to extra227"
  category: method_names
  kind: python_call_eq
  function: Process.join.__name__.__eq__
  args: ["join"]
  expected: true

invariant multiprocessing_extra227.Process.join_qualname:
  description: "multiprocessing.Process.join.__qualname__ == 'BaseProcess.join'; new to extra227"
  category: method_qualnames
  kind: python_call_eq
  function: Process.join.__qualname__.__eq__
  args: ["BaseProcess.join"]
  expected: true

invariant multiprocessing_extra227.Process.is_alive_name:
  description: "multiprocessing.Process.is_alive.__name__ == 'is_alive'; new to extra227"
  category: method_names
  kind: python_call_eq
  function: Process.is_alive.__name__.__eq__
  args: ["is_alive"]
  expected: true

invariant multiprocessing_extra227.Process.is_alive_qualname:
  description: "multiprocessing.Process.is_alive.__qualname__ == 'BaseProcess.is_alive'; new to extra227"
  category: method_qualnames
  kind: python_call_eq
  function: Process.is_alive.__qualname__.__eq__
  args: ["BaseProcess.is_alive"]
  expected: true
