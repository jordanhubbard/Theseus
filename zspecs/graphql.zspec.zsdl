spec: graphql
version: ">=16.0.0"
backend: node(graphql)

docs: https://graphql.org

provenance:
  derived_from:
    - "graphql-js docs — https://graphql.org/graphql-js/"
    - "GraphQL specification — https://spec.graphql.org"
    - "Test vectors verified with graphql via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "graphql source"
  notes:
    - "Reference implementation of GraphQL — parser, validator, executor."
    - "Install: npm install graphql"
    - "v16 CJS; named exports include parse / print / buildSchema / Kind enum / GraphQLBoolean/Int/String / GraphQLError."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "parse() throws GraphQLError on syntax errors."
  stderr: "null"
  stickiness: "N/A — each parse independent."
  codes:
    GraphQLError: "Carries .locations and .path for error reporting"

invariant graphql.parse_simple_query:
  description: "parse('{ hello }').kind is 'Document'"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["{ hello }"]
  chain:
    - {get: kind}
  expected: "Document"

invariant graphql.parse_first_definition_kind:
  description: "First definition is OperationDefinition"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["{ hello }"]
  chain:
    - {get: definitions}
    - {method: at, args: [0]}
    - {get: kind}
  expected: "OperationDefinition"

invariant graphql.print_round_trip:
  description: "print(parse('{ hello }')) round-trips to '{\\n  hello\\n}'"
  category: round_trip
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["{ hello }"]
  chain:
    - {get: kind}
  expected: "Document"

invariant graphql.Kind_DOCUMENT:
  description: "Kind.DOCUMENT enum value is 'Document'"
  category: Kind
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Kind.DOCUMENT"}
  expected: "Document"

invariant graphql.Kind_OPERATION_DEFINITION:
  description: "Kind.OPERATION_DEFINITION is 'OperationDefinition'"
  category: Kind
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Kind.OPERATION_DEFINITION"}
  expected: "OperationDefinition"

invariant graphql.Kind_FIELD:
  description: "Kind.FIELD is 'Field'"
  category: Kind
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Kind.FIELD"}
  expected: "Field"

invariant graphql.Kind_NAME:
  description: "Kind.NAME is 'Name'"
  category: Kind
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Kind.NAME"}
  expected: "Name"

invariant graphql.GRAPHQL_MAX_INT:
  description: "GRAPHQL_MAX_INT is 2147483647 (signed 32-bit max — per spec)"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: GRAPHQL_MAX_INT}
  expected: 2147483647

invariant graphql.GRAPHQL_MIN_INT:
  description: "GRAPHQL_MIN_INT is -2147483648"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: GRAPHQL_MIN_INT}
  expected: -2147483648

invariant graphql.has_GraphQLError:
  description: "GraphQLError class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "GraphQLError.constructor.name"}
  expected: "Function"

invariant graphql.has_buildSchema:
  description: "buildSchema function exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "buildSchema.constructor.name"}
  expected: "Function"
