spec: struct_extra48
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra47.zspec.zsdl — covers Struct/error __mro__[0].__name__/__qualname__; Struct.size/format __class__.__qualname__/__module__; struct function __qualname__ equality."
    - "struct_extra46.zspec.zsdl — covers pack/unpack/calcsize/Struct/error __module__.__class__.__name__/__qualname__ and __module__.__len__()."
    - "struct_extra45.zspec.zsdl — covers Struct/pack/error __doc__.__class__.__qualname__.__eq__('str'), module __doc__.__class__.__name__/__qualname__/__module__, and Struct method qualname table."
    - "struct_extra44.zspec.zsdl — covers Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__name__.__eq__('str')."
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') and pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__qualname__.__eq__('builtin_function_or_method') and Struct/pack/error __class__.__module__.__eq__('builtins')."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra27.zspec.zsdl — covers Struct/error __dict__.__class__.__name__.__len__()==12 (length only, via __name__ chain)."
    - "struct_extra19.zspec.zsdl — covers struct module __name__.__eq__('struct'), __package__.__eq__(''), __name__/__package__.__class__.__name__.__eq__('str')."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all six module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__.__eq__('Struct'), all module-level function __qualname__.__eq__ and error.__qualname__.__eq__('error')."
  notes:
    - "This spec extends struct through struct_extra47; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: struct_extra27 checks Struct.__dict__.__class__.__name__.__len__()==12 (the __len__ axis: len('mappingproxy')==12). But NO prior spec checks Struct.__dict__.__class__.__name__.__eq__('mappingproxy') (the string value axis). These are independent regression vectors — the value eq check catches class renames where the new name has the same length, while the __len__ check catches renames where the name length changes. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'. Struct.__dict__ is a mappingproxy object (CPython's read-only view of a class namespace). struct_extra27 covers __class__.__name__.__len__()==12 (length only). No prior spec checks __class__.__name__.__eq__('mappingproxy') for Struct.__dict__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks __dict__.__class__.__qualname__ for Struct. struct_extra27 checks __dict__.__class__.__name__.__len__()==12 (length axis on __name__). But __class__.__qualname__ is a distinct attribute chain from __class__.__name__. For mappingproxy (a non-nested C type), __qualname__ == __name__ == 'mappingproxy'. The .__qualname__ access path is an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type's __qualname__ is 'mappingproxy'. No prior spec checks __dict__.__class__.__qualname__.__eq__ for Struct or error. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior struct spec checks __dict__.__class__.__module__ for Struct or error. struct_extra43 covers Struct.__class__.__module__.__eq__('builtins') (the class type's __module__, not the __dict__'s __class__'s __module__). The mappingproxy type is a C builtin; its __module__ is 'builtins'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__class__.__module__ == 'builtins'. mappingproxy is a C builtin type; its __module__ is 'builtins'. struct_extra43 covers Struct.__class__.__module__ (the metaclass) not the __dict__'s __class__'s __module__. No prior spec checks Struct.__dict__.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__class__.__module__ == 'builtins'. Same mappingproxy type as Struct.__dict__; __module__ is 'builtins'. No prior spec checks error.__dict__.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ and struct.error.__dict__ __class__.__name__.__eq__
#
# struct_extra27 checks __dict__.__class__.__name__.__len__()==12 (length only).
# No prior struct spec checks the string VALUE: __class__.__name__.__eq__('mappingproxy').
# The __eq__ check is a distinct regression vector from the __len__ check:
# a rename to an 11-char or 13-char name would be caught by __len__ but not
# __eq__, while a rename to another 12-char name would be caught by __eq__ only.
# ---------------------------------------------------------------------------

table struct_extra48.dict_class_name_eq:
  description: "struct.Struct/__dict__/__class__/__name__.__eq__('mappingproxy') and error/__dict__/__class__/__name__.__eq__('mappingproxy') — novel string value axis; extra27 covers __class__.__name__.__len__()==12 (length only); no prior spec checks __class__.__name__.__eq__('mappingproxy') for Struct.__dict__ or error.__dict__"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmod48

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_class_name_eq, Struct.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [error_dict_class_name_eq,  error.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ and struct.error.__dict__ __class__.__qualname__.__eq__
#
# No prior struct spec checks __dict__.__class__.__qualname__ for any struct
# class. struct_extra27 covers __dict__.__class__.__name__.__len__() (a
# different chain: __name__ not __qualname__, and __len__ not __eq__).
# For mappingproxy, a non-nested C type, __qualname__ == __name__ ==
# 'mappingproxy'. The __class__.__qualname__ chain is an independent
# regression vector.
# ---------------------------------------------------------------------------

table struct_extra48.dict_class_qualname_eq:
  description: "struct.Struct/__dict__/__class__/__qualname__.__eq__('mappingproxy') and error/__dict__/__class__/__qualname__.__eq__('mappingproxy') — novel __class__.__qualname__ axis; extra27 covers __class__.__name__.__len__ only; no prior spec checks __dict__.__class__.__qualname__ for Struct or error"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmod48

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_class_qualname_eq, Struct.__dict__.__class__.__qualname__.__eq__, ["mappingproxy"], true]
    - [error_dict_class_qualname_eq,  error.__dict__.__class__.__qualname__.__eq__,  ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ and struct.error.__dict__ __class__.__module__.__eq__
#
# No prior struct spec checks __dict__.__class__.__module__ for any struct
# class. struct_extra43 covers Struct.__class__.__module__.__eq__('builtins')
# (the metaclass's __module__, not the __dict__'s __class__'s __module__).
# mappingproxy is a C builtin type defined in Python's C implementation;
# its __module__ is 'builtins'. This confirms the mappingproxy type
# remains in the builtins namespace.
# ---------------------------------------------------------------------------

table struct_extra48.dict_class_module_eq:
  description: "struct.Struct/__dict__/__class__/__module__.__eq__('builtins') and error/__dict__/__class__/__module__.__eq__('builtins') — mappingproxy is a C builtin type; novel __dict__.__class__.__module__ axis; extra43 covers Struct.__class__.__module__.__eq__('builtins') (metaclass __module__, different chain); no prior spec checks __dict__.__class__.__module__.__eq__ for Struct or error"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmod48

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_class_module_eq, Struct.__dict__.__class__.__module__.__eq__, ["builtins"], true]
    - [error_dict_class_module_eq,  error.__dict__.__class__.__module__.__eq__,  ["builtins"], true]
