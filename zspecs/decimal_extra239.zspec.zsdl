spec: decimal_extra239
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra238.zspec.zsdl — covers decimal rounding mode string constants"
  notes:
    - "This spec covers: decimal.getcontext() and decimal.localcontext identity."
    - "decimal.getcontext.__name__ == 'getcontext' — length 10; verified Python 3.14.3 macOS."
    - "decimal.getcontext.__module__ == '_decimal' — getcontext is a C extension function in _decimal; length 8; verified Python 3.14.3 macOS."
    - "decimal.getcontext.__qualname__ == 'getcontext' — length 10; module-level function so qualname equals name; verified Python 3.14.3 macOS."
    - "decimal.getcontext.__class__.__name__ == 'builtin_function_or_method' — getcontext is a C built-in; verified Python 3.14.3 macOS."
    - "decimal.localcontext.__name__ == 'localcontext' — length 12; verified Python 3.14.3 macOS."
    - "decimal.localcontext.__module__ == '_decimal' — localcontext is a C extension function in _decimal; length 8; verified Python 3.14.3 macOS."
    - "decimal.localcontext.__class__.__name__ == 'builtin_function_or_method' — localcontext is a C built-in; verified Python 3.14.3 macOS."
    - "decimal.getcontext().__class__.__name__ == 'Context' — calling getcontext() returns a decimal.Context instance; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.getcontext function identity: __name__, __module__, __qualname__
# getcontext is a C extension function; __module__ == '_decimal' (not 'decimal').
# __class__.__name__ == 'builtin_function_or_method'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra239.getcontext_name_module_qualname:
  description: "decimal.getcontext function identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: func_identity
  id_prefix: decctxfn239

  columns: [id, function, args, expected]
  rows:
    - [getctx_name_eq,      getcontext.__name__.__eq__,      ["getcontext"], true]
    - [getctx_name_not,     getcontext.__name__.__eq__,      ["setcontext"], false]
    - [getctx_module_eq,    getcontext.__module__.__eq__,    ["_decimal"],   true]
    - [getctx_module_not,   getcontext.__module__.__eq__,    ["decimal"],    false]
    - [getctx_qualname_eq,  getcontext.__qualname__.__eq__,  ["getcontext"], true]

# ---------------------------------------------------------------------------
# decimal.getcontext __name__, __module__, __qualname__ string lengths
# __name__='getcontext' len=10, __module__='_decimal' len=8, __qualname__ len=10.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra239.getcontext_name_lengths:
  description: "decimal.getcontext string lengths: __name__=10, __module__=8, __qualname__=10; verified Python 3.14.3"
  kind: python_call_eq
  category: func_identity
  id_prefix: decctxfn239

  columns: [id, function, args, expected]
  rows:
    - [getctx_name_len,     getcontext.__name__.__len__,     [], 10]
    - [getctx_module_len,   getcontext.__module__.__len__,   [], 8]
    - [getctx_qualname_len, getcontext.__qualname__.__len__, [], 10]

# ---------------------------------------------------------------------------
# decimal.localcontext function identity: __name__, __module__, __qualname__
# localcontext is also a C extension function; __module__ == '_decimal'.
# __class__.__name__ == 'builtin_function_or_method'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra239.localcontext_name_module_qualname:
  description: "decimal.localcontext function identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: func_identity
  id_prefix: decctxfn239

  columns: [id, function, args, expected]
  rows:
    - [lctx_name_eq,      localcontext.__name__.__eq__,      ["localcontext"], true]
    - [lctx_name_not,     localcontext.__name__.__eq__,      ["getcontext"],   false]
    - [lctx_module_eq,    localcontext.__module__.__eq__,    ["_decimal"],     true]
    - [lctx_module_not,   localcontext.__module__.__eq__,    ["decimal"],      false]
    - [lctx_qualname_eq,  localcontext.__qualname__.__eq__,  ["localcontext"], true]

# ---------------------------------------------------------------------------
# decimal.localcontext __name__, __module__, __qualname__ string lengths
# __name__='localcontext' len=12, __module__='_decimal' len=8, __qualname__ len=12.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra239.localcontext_name_lengths:
  description: "decimal.localcontext string lengths: __name__=12, __module__=8, __qualname__=12; verified Python 3.14.3"
  kind: python_call_eq
  category: func_identity
  id_prefix: decctxfn239

  columns: [id, function, args, expected]
  rows:
    - [lctx_name_len,     localcontext.__name__.__len__,     [], 12]
    - [lctx_module_len,   localcontext.__module__.__len__,   [], 8]
    - [lctx_qualname_len, localcontext.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra239.getcontext.name_eq:
  description: "decimal.getcontext.__name__ == 'getcontext' — the function's __name__ attribute; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: getcontext.__name__.__eq__
  args: ["getcontext"]
  expected: true

invariant decimal_extra239.getcontext.module_is_underscore_decimal:
  description: "decimal.getcontext.__module__ == '_decimal' — getcontext is a C extension function in _decimal, not the pure Python module; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: getcontext.__module__.__eq__
  args: ["_decimal"]
  expected: true

invariant decimal_extra239.getcontext.module_not_decimal:
  description: "decimal.getcontext.__module__ != 'decimal' — getcontext is defined in _decimal (C), not the 'decimal' pure Python wrapper; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: getcontext.__module__.__eq__
  args: ["decimal"]
  expected: false

invariant decimal_extra239.getcontext.qualname_eq:
  description: "decimal.getcontext.__qualname__ == 'getcontext' — module-level function so __qualname__ equals __name__; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: getcontext.__qualname__.__eq__
  args: ["getcontext"]
  expected: true

invariant decimal_extra239.getcontext.class_name_eq:
  description: "decimal.getcontext.__class__.__name__ == 'builtin_function_or_method' — getcontext is a C built-in function; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: getcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra239.getcontext.name_len:
  description: "len(decimal.getcontext.__name__) == 10 — 'getcontext' has 10 characters; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: getcontext.__name__.__len__
  args: []
  expected: 10

invariant decimal_extra239.localcontext.name_eq:
  description: "decimal.localcontext.__name__ == 'localcontext' — the function's __name__ attribute; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: localcontext.__name__.__eq__
  args: ["localcontext"]
  expected: true

invariant decimal_extra239.localcontext.module_is_underscore_decimal:
  description: "decimal.localcontext.__module__ == '_decimal' — localcontext is a C extension function in _decimal; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: localcontext.__module__.__eq__
  args: ["_decimal"]
  expected: true

invariant decimal_extra239.localcontext.module_not_decimal:
  description: "decimal.localcontext.__module__ != 'decimal' — localcontext is defined in _decimal (C), not the 'decimal' wrapper; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: localcontext.__module__.__eq__
  args: ["decimal"]
  expected: false

invariant decimal_extra239.localcontext.class_name_eq:
  description: "decimal.localcontext.__class__.__name__ == 'builtin_function_or_method' — localcontext is a C built-in function; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: localcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra239.localcontext.name_len:
  description: "len(decimal.localcontext.__name__) == 12 — 'localcontext' has 12 characters; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: localcontext.__name__.__len__
  args: []
  expected: 12
