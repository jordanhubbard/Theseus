spec: dis_extra5
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis.zspec.zsdl — covers __name__ for Instruction/Bytecode/dis/disassemble/code_info/show_code/get_instructions/stack_effect; opname class/length; opmap contains/values; stack_effect values; haslocal/hasname"
    - "dis_extra.zspec.zsdl — covers dis.__name__ (module name), distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction/__name__/__module__, opname/__class__/__name__, opmap/__class__/__name__, HAVE_ARGUMENT/__class__/__name__"
    - "dis_extra2.zspec.zsdl — covers __module__ for dis/disassemble/get_instructions/findlinestarts/findlabels/code_info; Instruction/__name__/__module__/__bases__[0]; Bytecode/__name__/__module__/__bases__[0]; opname/opmap class checks; HAVE_ARGUMENT class check"
    - "dis_extra3.zspec.zsdl — covers __name__/__module__ for Instruction/Bytecode (table); __name__ for findlinestarts/findlabels/get_instructions/stack_effect (table); opname class/length; opmap class/contains; HAVE_ARGUMENT value; Bytecode.__module__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__, Instruction._fields class/contains-opname/contains-opcode, opname.__len__ >= 100, dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
  notes:
    - "This spec adds: __qualname__ for dis functions not yet covered in dis_extra4 (code_info, show_code, stack_effect, findlabels, distb); Bytecode.__qualname__; Instruction._fields[0] value check; show_code.__module__ cross-check."
    - "dis.code_info.__qualname__ == 'code_info' — module-level function qualname equals its simple name."
    - "dis.show_code.__qualname__ == 'show_code' — module-level function."
    - "dis.stack_effect.__qualname__ == 'stack_effect' — module-level function."
    - "dis.findlabels.__qualname__ == 'findlabels' — module-level function."
    - "dis.distb.__qualname__ == 'distb' — module-level function."
    - "dis.Bytecode.__qualname__ == 'Bytecode' — top-level class qualname equals __name__."
    - "dis.Instruction._fields[0] == 'opname' — first named field of the Instruction namedtuple."
    - "dis.show_code.__module__ == 'dis' — show_code is defined in the dis module (not covered in dis_extra2 which stops at code_info)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for dis functions not covered in dis_extra4
# dis_extra4 table covers: dis, disassemble, get_instructions, findlinestarts.
# New here: code_info, show_code, stack_effect, findlabels, distb.
# ---------------------------------------------------------------------------

table dis_extra5.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [code_info,    code_info.__qualname__.__eq__,    ["code_info"],    true]
    - [show_code,    show_code.__qualname__.__eq__,    ["show_code"],    true]
    - [stack_effect, stack_effect.__qualname__.__eq__, ["stack_effect"], true]
    - [findlabels,   findlabels.__qualname__.__eq__,   ["findlabels"],   true]
    - [distb,        distb.__qualname__.__eq__,        ["distb"],        true]

# ---------------------------------------------------------------------------
# Bytecode.__qualname__
# dis_extra3 and dis_extra2 cover Bytecode.__name__ and __module__;
# __qualname__ has not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant dis_extra5.Bytecode.qualname:
  description: "dis.Bytecode.__qualname__ == 'Bytecode'"
  category: bytecode
  kind: python_call_eq
  function: Bytecode.__qualname__.__eq__
  args: ["Bytecode"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction._fields[0] == 'opname'
# dis_extra4 confirms _fields is a tuple and contains 'opname' and 'opcode'.
# This spec checks the index-0 value directly: the first field is 'opname'.
# ---------------------------------------------------------------------------

invariant dis_extra5.Instruction.fields_index0:
  description: "dis.Instruction._fields[0] == 'opname' — first field of Instruction namedtuple"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__getitem__
  args: [0]
  expected: "opname"

# ---------------------------------------------------------------------------
# show_code.__module__ == 'dis'
# dis_extra2 covers __module__ for dis/disassemble/get_instructions/
# findlinestarts/findlabels/code_info. show_code was not included.
# ---------------------------------------------------------------------------

invariant dis_extra5.show_code.module:
  description: "dis.show_code.__module__ == 'dis' — show_code is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: show_code.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# distb.__module__ == 'dis'
# dis_extra2 does not cover distb.__module__. dis_extra covers only distb.__name__.
# ---------------------------------------------------------------------------

invariant dis_extra5.distb.module:
  description: "dis.distb.__module__ == 'dis' — distb is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: distb.__module__.__eq__
  args: ["dis"]
  expected: true
