spec: asyncio_extra232
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Lock.acquire.__name__ == 'acquire' — 7 characters; module is asyncio.locks; verified with Python 3.14.3."
    - "asyncio.Lock.release.__name__ == 'release' — 7 characters; qualname is 'Lock.release'; verified with Python 3.14.3."
    - "asyncio.Lock.locked.__name__ == 'locked' — 6 characters; qualname is 'Lock.locked'; verified with Python 3.14.3."
    - "asyncio.Event.set.__name__ == 'set' — 3 characters; qualname is 'Event.set'; verified with Python 3.14.3."
    - "asyncio.Event.clear.__name__ == 'clear' — 5 characters; qualname is 'Event.clear'; verified with Python 3.14.3."
    - "asyncio.Event.is_set.__name__ == 'is_set' — 6 characters; qualname is 'Event.is_set'; verified with Python 3.14.3."
    - "asyncio.Event.wait.__name__ == 'wait' — 4 characters; qualname is 'Event.wait'; verified with Python 3.14.3."
    - "asyncio.Condition.notify.__name__ == 'notify' — 6 characters; qualname is 'Condition.notify'; verified with Python 3.14.3."
    - "asyncio.Condition.notify_all.__name__ == 'notify_all' — 10 characters; qualname is 'Condition.notify_all'; verified with Python 3.14.3."
    - "asyncio.Condition.wait.__name__ == 'wait' — 4 characters; qualname is 'Condition.wait'; verified with Python 3.14.3."
    - "asyncio.Condition.wait_for.__name__ == 'wait_for' — 8 characters; qualname is 'Condition.wait_for'; verified with Python 3.14.3."
    - "All sync primitives (Lock, Event, Condition) live in asyncio.locks module; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Lock method name and qualname contracts — extra232 namespace
#
# Lock.acquire, release, locked all live in asyncio.locks.
# Qualnames use 'Lock.' prefix.
# ---------------------------------------------------------------------------

table asyncio_extra232.lock_method_names:
  description: "asyncio.Lock method __name__ and __qualname__ contracts in aio232lmn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio232lmn

  columns: [id, function, args, expected, description]
  rows:
    - [lock_acquire_name_eq,     Lock.acquire.__name__.__eq__,         ["acquire"],       true, "asyncio.Lock.acquire.__name__ == 'acquire'; verified with Python 3.14.3"]
    - [lock_acquire_name_len_7,  Lock.acquire.__name__.__len__,        [],                7,    "asyncio.Lock.acquire.__name__.__len__() == 7 — 'acquire' has 7 characters; verified with Python 3.14.3"]
    - [lock_acquire_qualname_eq, Lock.acquire.__qualname__.__eq__,     ["Lock.acquire"],  true, "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire'; verified with Python 3.14.3"]
    - [lock_release_name_eq,     Lock.release.__name__.__eq__,         ["release"],       true, "asyncio.Lock.release.__name__ == 'release'; verified with Python 3.14.3"]
    - [lock_release_qualname_eq, Lock.release.__qualname__.__eq__,     ["Lock.release"],  true, "asyncio.Lock.release.__qualname__ == 'Lock.release'; verified with Python 3.14.3"]
    - [lock_locked_name_eq,      Lock.locked.__name__.__eq__,          ["locked"],        true, "asyncio.Lock.locked.__name__ == 'locked'; verified with Python 3.14.3"]
    - [lock_locked_name_len_6,   Lock.locked.__name__.__len__,         [],                6,    "asyncio.Lock.locked.__name__.__len__() == 6 — 'locked' has 6 characters; verified with Python 3.14.3"]
    - [lock_locked_qualname_eq,  Lock.locked.__qualname__.__eq__,      ["Lock.locked"],   true, "asyncio.Lock.locked.__qualname__ == 'Lock.locked'; verified with Python 3.14.3"]

