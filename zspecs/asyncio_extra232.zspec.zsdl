    - [cond_notall_qn_eq,       Condition.notify_all.__qualname__.__eq__, ["Condition.notify_all"], true, "asyncio.Condition.notify_all.__qualname__ == 'Condition.notify_all'; verified with Python 3.14.3"]
    - [cond_wait_name_eq,       Condition.wait.__name__.__eq__,         ["wait"],                true, "asyncio.Condition.wait.__name__ == 'wait'; verified with Python 3.14.3"]
    - [cond_wait_qn_eq,         Condition.wait.__qualname__.__eq__,     ["Condition.wait"],      true, "asyncio.Condition.wait.__qualname__ == 'Condition.wait'; verified with Python 3.14.3"]
    - [cond_wait_for_name_eq,   Condition.wait_for.__name__.__eq__,     ["wait_for"],            true, "asyncio.Condition.wait_for.__name__ == 'wait_for'; verified with Python 3.14.3"]
    - [cond_wait_for_len_8,     Condition.wait_for.__name__.__len__,    [],                      8,    "asyncio.Condition.wait_for.__name__.__len__() == 8 — 'wait_for' has 8 characters; verified with Python 3.14.3"]
    - [cond_wait_for_qn_eq,     Condition.wait_for.__qualname__.__eq__, ["Condition.wait_for"],  true, "asyncio.Condition.wait_for.__qualname__ == 'Condition.wait_for'; verified with Python 3.14.3"]
