    - [event_set_qualname_eq,  Event.set.__qualname__.__eq__,    ["Event.set"],    true, "asyncio.Event.set.__qualname__ == 'Event.set'; verified with Python 3.14.3"]
    - [event_clear_name_eq,    Event.clear.__name__.__eq__,      ["clear"],        true, "asyncio.Event.clear.__name__ == 'clear'; verified with Python 3.14.3"]
    - [event_clear_qn_eq,      Event.clear.__qualname__.__eq__,  ["Event.clear"],  true, "asyncio.Event.clear.__qualname__ == 'Event.clear'; verified with Python 3.14.3"]
    - [event_is_set_name_eq,   Event.is_set.__name__.__eq__,     ["is_set"],       true, "asyncio.Event.is_set.__name__ == 'is_set'; verified with Python 3.14.3"]
    - [event_is_set_len_6,     Event.is_set.__name__.__len__,    [],               6,    "asyncio.Event.is_set.__name__.__len__() == 6 — 'is_set' has 6 characters; verified with Python 3.14.3"]
    - [event_is_set_qn_eq,     Event.is_set.__qualname__.__eq__, ["Event.is_set"], true, "asyncio.Event.is_set.__qualname__ == 'Event.is_set'; verified with Python 3.14.3"]
    - [event_wait_name_eq,     Event.wait.__name__.__eq__,       ["wait"],         true, "asyncio.Event.wait.__name__ == 'wait'; verified with Python 3.14.3"]
    - [event_wait_qn_eq,       Event.wait.__qualname__.__eq__,   ["Event.wait"],   true, "asyncio.Event.wait.__qualname__ == 'Event.wait'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
