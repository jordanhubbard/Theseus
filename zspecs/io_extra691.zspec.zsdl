table io_extra691.iobase_class_identity:
  description: "io.IOBase and subclass __class__.__name__, __qualname__, __module__ identity"
  kind: python_call_eq
  category: iobase_class_identity
  id_prefix: io691bc
  columns: [id, function, args, expected]
  rows:
    - [io691bc001, io.IOBase.closed.__class__.__name__.__eq__,       ["property"],      true]
    - [io691bc002, io.IOBase.__class__.__name__.__eq__,              ["type"],          true]
    - [io691bc003, io.IOBase.__qualname__.__eq__,                    ["IOBase"],        true]
    - [io691bc004, io.IOBase.__module__.__eq__,                      ["io"],            true]
    - [io691bc005, io.RawIOBase.__class__.__name__.__eq__,           ["type"],          true]
    - [io691bc006, io.RawIOBase.__qualname__.__eq__,                 ["RawIOBase"],     true]
    - [io691bc007, io.RawIOBase.__module__.__eq__,                   ["io"],            true]
    - [io691bc008, io.BufferedIOBase.__class__.__name__.__eq__,      ["type"],          true]
    - [io691bc009, io.BufferedIOBase.__qualname__.__eq__,            ["BufferedIOBase"], true]
    - [io691bc010, io.TextIOBase.__class__.__name__.__eq__,          ["type"],          true]
    - [io691bc011, io.TextIOBase.__qualname__.__eq__,                ["TextIOBase"],    true]
    - [io691bc012, io.FileIO.__class__.__name__.__eq__,              ["type"],          true]
