spec: io_extra370
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.BufferedWriter.__module__ == '_io' — the concrete buffered I/O classes are implemented in the C extension _io, not the pure Python io wrapper"
    - "io.BufferedRandom.__module__ == '_io' — same C extension backing as BufferedWriter"
    - "io.IncrementalNewlineDecoder.__module__ == '_io' — C extension class; its base is object (not a BufferedIO class)"
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — the C-level private type"
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — the C-level private type"
    - "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — root class, not a buffered IO base"
    - "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer size used by open() and buffered I/O classes; 128 KiB"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedWriter class identity — name, module, base
# ---------------------------------------------------------------------------

table io_extra370.buffered_writer_identity:
  description: "io.BufferedWriter class identity — __name__, __module__, __bases__[0].__name__; BufferedWriter is backed by the C extension _io and inherits from _BufferedIOBase; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iobw370

  columns: [id, function, args, expected]
  rows:
    - [buffered_writer_name,   io.BufferedWriter.__name__.__eq__,   ["BufferedWriter"],  true]
    - [buffered_writer_module, io.BufferedWriter.__module__.__eq__, ["_io"],             true]

invariant io_extra370.buffered_writer_base:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter directly subclasses the C-level _BufferedIOBase type from the _io extension; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "io.BufferedWriter.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# io.BufferedRandom class identity — name, module, base
# ---------------------------------------------------------------------------

table io_extra370.buffered_random_identity:
  description: "io.BufferedRandom class identity — __name__, __module__, __bases__[0].__name__; BufferedRandom is backed by the C extension _io and inherits from _BufferedIOBase; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iobr370

  columns: [id, function, args, expected]
  rows:
    - [buffered_random_name,   io.BufferedRandom.__name__.__eq__,   ["BufferedRandom"], true]
    - [buffered_random_module, io.BufferedRandom.__module__.__eq__, ["_io"],            true]

invariant io_extra370.buffered_random_base:
  description: "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom directly subclasses the C-level _BufferedIOBase type from the _io extension; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "io.BufferedRandom.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# io.IncrementalNewlineDecoder class identity — name, module, base
# ---------------------------------------------------------------------------

table io_extra370.incremental_newline_decoder_identity:
  description: "io.IncrementalNewlineDecoder class identity — __name__, __module__, __bases__[0].__name__; IncrementalNewlineDecoder is a C extension class whose base is object (not a BufferedIO base); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioinld370

  columns: [id, function, args, expected]
  rows:
    - [inld_name,   io.IncrementalNewlineDecoder.__name__.__eq__,   ["IncrementalNewlineDecoder"], true]
    - [inld_module, io.IncrementalNewlineDecoder.__module__.__eq__, ["_io"],                       true]

invariant io_extra370.incremental_newline_decoder_base:
  description: "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder is a root C extension class; its direct base is object, not a buffered I/O abstract base; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "io.IncrementalNewlineDecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE constant
# ---------------------------------------------------------------------------

invariant io_extra370.default_buffer_size:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer size (128 KiB) used by open() and buffered I/O classes when no explicit buffer_size is provided; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: io.DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true
