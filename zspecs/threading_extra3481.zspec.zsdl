spec: th3481
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (th3481): __enter__, __exit__, __call__ dict-presence checks for threading types."
    - "threading.Condition defines __enter__ and __exit__ (true): Condition supports the context manager protocol (with condition:)."
    - "threading.Semaphore defines __enter__ and __exit__ (true): Semaphore supports the context manager protocol."
    - "threading.BoundedSemaphore does NOT define __enter__ or __exit__ in its own __dict__ (false): it inherits them from Semaphore."
    - "type(threading.Lock()) defines __enter__ and __exit__ (true): the lock type supports context manager protocol."
    - "type(threading.RLock()) defines __enter__ and __exit__ (true): the RLock type supports context manager protocol."
    - "threading.Barrier defines __enter__ and __exit__ (true): Barrier supports the context manager protocol."
    - "All threading types: __call__ = false."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3481.enter:
  description: "threading types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3481
  columns: [id, function, args, expected]
  rows:
    - ["th3481001", operator.contains, [threading.Thread.__dict__,           "__enter__"], false]
    - ["th3481002", operator.contains, [threading.Event.__dict__,            "__enter__"], false]
    - ["th3481003", operator.contains, [threading.Condition.__dict__,        "__enter__"], true]
    - ["th3481004", operator.contains, [threading.Semaphore.__dict__,        "__enter__"], true]
    - ["th3481005", operator.contains, [threading.BoundedSemaphore.__dict__, "__enter__"], false]
    - ["th3481006", operator.contains, [threading.Timer.__dict__,            "__enter__"], false]
    - ["th3481007", operator.contains, [threading.Barrier.__dict__,          "__enter__"], true]
    - ["th3481008", operator.contains, [threading.local.__dict__,            "__enter__"], false]
    - ["th3481009", operator.contains, [type(threading.Lock()).__dict__,     "__enter__"], true]
    - ["th3481010", operator.contains, [type(threading.RLock()).__dict__,    "__enter__"], true]

