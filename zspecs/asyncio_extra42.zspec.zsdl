spec: asyncio_extra42
version: ">=3.11"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop interface"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/coroutines.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra41.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths (extra39), Semaphore acquire/release __qualname__ string values and lengths (extra39/extra40), BoundedSemaphore/__name__/__module__/inherited acquire qualname (extra40), Condition/__name__/__module__/wait qualname (extra40), TaskGroup/__name__/__module__/__bases__[0].__name__, Runner/__name__/__module__, shield/ensure_future/create_task __name__/__module__ (extra41)."
    - "This spec covers: get_event_loop/__name__=='get_event_loop'; get_event_loop/__module__=='_asyncio' (8 chars — a C-extension module); get_running_loop/__name__=='get_running_loop'; get_running_loop/__module__=='_asyncio' (8 chars); new_event_loop/__name__=='new_event_loop'; new_event_loop/__module__=='asyncio.events' (14 chars); run/__name__=='run'; run/__module__=='asyncio.runners' (15 chars); iscoroutine/__name__=='iscoroutine'; iscoroutine/__module__=='asyncio.coroutines' (18 chars); iscoroutinefunction/__name__=='iscoroutinefunction'; iscoroutinefunction/__module__=='asyncio.coroutines' (18 chars)."
    - "IMPORTANT: asyncio.get_event_loop.__module__ == '_asyncio', NOT 'asyncio.events'. The get_event_loop function (and get_running_loop) are implemented in the C extension _asyncio (Modules/_asynciomodule.c), so their __module__ attribute reflects the C-level module name '_asyncio' (8 chars with leading underscore). This is distinct from new_event_loop, which is implemented in pure Python in asyncio.events."
    - "asyncio.new_event_loop.__module__ == 'asyncio.events' (14 chars: 'asyncio'(7) + '.'(1) + 'events'(6) = 14). new_event_loop is a pure-Python function in Lib/asyncio/events.py."
    - "asyncio.run.__module__ == 'asyncio.runners' (15 chars: 'asyncio'(7) + '.'(1) + 'runners'(7) = 15). Note: 'runners' is 7 chars, giving a total of 15. This is distinct from asyncio.Runner.__module__ which is also 'asyncio.runners' (14 chars — the string 'asyncio.runners' itself is 15 chars). Wait: len('asyncio.runners') = 15. Verified: 'a'(1)+'s'(2)+'y'(3)+'n'(4)+'c'(5)+'i'(6)+'o'(7)+'.'(8)+'r'(9)+'u'(10)+'n'(11)+'n'(12)+'e'(13)+'r'(14)+'s'(15) = 15 chars."
    - "asyncio.iscoroutine.__module__ == 'asyncio.coroutines' (18 chars: 'asyncio'(7) + '.'(1) + 'coroutines'(10) = 18). iscoroutinefunction shares the same module. Both introspection helpers live in Lib/asyncio/coroutines.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio event loop function __name__ — extra42 namespace
#
# Three event-loop management functions and their __name__ attributes:
#   get_event_loop.__name__   == 'get_event_loop'   (14 chars)
#   get_running_loop.__name__ == 'get_running_loop'  (16 chars)
#   new_event_loop.__name__   == 'new_event_loop'    (14 chars)
# get_event_loop and get_running_loop are C-extension functions in _asyncio.
# new_event_loop is a pure-Python function in asyncio.events.
# ---------------------------------------------------------------------------

table asyncio_extra42.event_loop_func_names:
  description: "asyncio event loop function __name__ string equality in extra42 namespace — get_event_loop, get_running_loop, new_event_loop"
  kind: python_call_eq
  category: function_names
  id_prefix: asyncelfuncname42

  columns: [id, function, args, expected, description]
  rows:
    - [get_event_loop,   get_event_loop.__name__.__eq__,   ["get_event_loop"],   true, "get_event_loop.__name__ == 'get_event_loop' (14 chars)"]
    - [get_running_loop, get_running_loop.__name__.__eq__,  ["get_running_loop"], true, "get_running_loop.__name__ == 'get_running_loop' (16 chars)"]
    - [new_event_loop,   new_event_loop.__name__.__eq__,    ["new_event_loop"],   true, "new_event_loop.__name__ == 'new_event_loop' (14 chars)"]

# ---------------------------------------------------------------------------
# asyncio event loop function __module__ — extra42 namespace
#
# The C-extension functions report '_asyncio' as their module:
#   get_event_loop.__module__   == '_asyncio'        ( 8 chars)
#   get_running_loop.__module__ == '_asyncio'        ( 8 chars)
# The pure-Python function reports its actual submodule:
#   new_event_loop.__module__   == 'asyncio.events'  (14 chars)
# This split shows which event-loop functions are implemented in C vs Python.
# '_asyncio' = underscore(1) + 'asyncio'(7) = 8 chars.
# 'asyncio.events' = 'asyncio'(7) + '.'(1) + 'events'(6) = 14 chars.
# ---------------------------------------------------------------------------

table asyncio_extra42.event_loop_func_modules:
  description: "asyncio event loop function __module__ string equality in extra42 namespace — C-extension vs pure-Python split"
  kind: python_call_eq
  category: module_names
  id_prefix: asyncelfuncmod42

  columns: [id, function, args, expected, description]
  rows:
    - [get_event_loop,   get_event_loop.__module__.__eq__,   ["_asyncio"],       true, "get_event_loop.__module__ == '_asyncio' (8 chars) — C-extension function in _asynciomodule.c"]
    - [get_running_loop, get_running_loop.__module__.__eq__,  ["_asyncio"],       true, "get_running_loop.__module__ == '_asyncio' (8 chars) — C-extension function in _asynciomodule.c"]
    - [new_event_loop,   new_event_loop.__module__.__eq__,    ["asyncio.events"], true, "new_event_loop.__module__ == 'asyncio.events' (14 chars) — pure-Python function in Lib/asyncio/events.py"]

# ---------------------------------------------------------------------------
# asyncio run and coroutine introspection function identity — extra42 namespace
#
# asyncio.run and its __module__:
#   run.__name__                == 'run'               ( 3 chars)
#   run.__module__              == 'asyncio.runners'   (15 chars)
# Two coroutine introspection helpers:
#   iscoroutine.__name__        == 'iscoroutine'       (11 chars)
#   iscoroutine.__module__      == 'asyncio.coroutines'(18 chars)
#   iscoroutinefunction.__name__== 'iscoroutinefunction'(19 chars)
#   iscoroutinefunction.__module__=='asyncio.coroutines'(18 chars)
# 'asyncio.runners' = 'asyncio'(7) + '.'(1) + 'runners'(7) = 15 chars.
# 'asyncio.coroutines' = 'asyncio'(7) + '.'(1) + 'coroutines'(10) = 18 chars.
# ---------------------------------------------------------------------------

table asyncio_extra42.run_coroutine_func_names:
  description: "asyncio run and coroutine introspection function __name__ string equality in extra42 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: asyncruncorname42

  columns: [id, function, args, expected, description]
  rows:
    - [run,                 run.__name__.__eq__,                 ["run"],                 true, "run.__name__ == 'run' (3 chars)"]
    - [iscoroutine,         iscoroutine.__name__.__eq__,          ["iscoroutine"],         true, "iscoroutine.__name__ == 'iscoroutine' (11 chars)"]
    - [iscoroutinefunction, iscoroutinefunction.__name__.__eq__,  ["iscoroutinefunction"], true, "iscoroutinefunction.__name__ == 'iscoroutinefunction' (19 chars)"]

table asyncio_extra42.run_coroutine_func_modules:
  description: "asyncio run and coroutine introspection function __module__ string equality in extra42 namespace"
  kind: python_call_eq
  category: module_names
  id_prefix: asyncruncormod42

  columns: [id, function, args, expected, description]
  rows:
    - [run,                 run.__module__.__eq__,                 ["asyncio.runners"],    true, "run.__module__ == 'asyncio.runners' (15 chars) — asyncio.run lives in Lib/asyncio/runners.py"]
    - [iscoroutine,         iscoroutine.__module__.__eq__,          ["asyncio.coroutines"], true, "iscoroutine.__module__ == 'asyncio.coroutines' (18 chars) — coroutine helpers live in Lib/asyncio/coroutines.py"]
    - [iscoroutinefunction, iscoroutinefunction.__module__.__eq__,  ["asyncio.coroutines"], true, "iscoroutinefunction.__module__ == 'asyncio.coroutines' (18 chars) — same submodule as iscoroutine"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra42
# ---------------------------------------------------------------------------

invariant asyncio_extra42.get_event_loop_name_eq:
  description: "asyncio.get_event_loop.__name__ == 'get_event_loop' — returns the running event loop in the current OS thread; 14 chars"
  category: function_names
  kind: python_call_eq
  function: get_event_loop.__name__.__eq__
  args: ["get_event_loop"]
  expected: true

invariant asyncio_extra42.get_event_loop_module_eq:
  description: "asyncio.get_event_loop.__module__ == '_asyncio' — implemented in the C-extension _asynciomodule.c, not in pure Python (8 chars)"
  category: module_names
  kind: python_call_eq
  function: get_event_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra42.get_running_loop_name_eq:
  description: "asyncio.get_running_loop.__name__ == 'get_running_loop' — returns the running event loop; raises RuntimeError if none; 16 chars"
  category: function_names
  kind: python_call_eq
  function: get_running_loop.__name__.__eq__
  args: ["get_running_loop"]
  expected: true

invariant asyncio_extra42.get_running_loop_module_eq:
  description: "asyncio.get_running_loop.__module__ == '_asyncio' — like get_event_loop, implemented in the C-extension (8 chars)"
  category: module_names
  kind: python_call_eq
  function: get_running_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra42.new_event_loop_name_eq:
  description: "asyncio.new_event_loop.__name__ == 'new_event_loop' — creates and returns a new event loop object; 14 chars"
  category: function_names
  kind: python_call_eq
  function: new_event_loop.__name__.__eq__
  args: ["new_event_loop"]
  expected: true

invariant asyncio_extra42.new_event_loop_module_eq:
  description: "asyncio.new_event_loop.__module__ == 'asyncio.events' — pure-Python implementation in Lib/asyncio/events.py (14 chars)"
  category: module_names
  kind: python_call_eq
  function: new_event_loop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra42.run_name_eq:
  description: "asyncio.run.__name__ == 'run' — the high-level entry point that runs a coroutine and closes the event loop when done (3 chars)"
  category: function_names
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true

invariant asyncio_extra42.run_module_eq:
  description: "asyncio.run.__module__ == 'asyncio.runners' — asyncio.run is implemented in Lib/asyncio/runners.py alongside the Runner class (15 chars)"
  category: module_names
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra42.iscoroutine_name_eq:
  description: "asyncio.iscoroutine.__name__ == 'iscoroutine' — returns True if the argument is a coroutine object (11 chars)"
  category: function_names
  kind: python_call_eq
  function: iscoroutine.__name__.__eq__
  args: ["iscoroutine"]
  expected: true

invariant asyncio_extra42.iscoroutine_module_eq:
  description: "asyncio.iscoroutine.__module__ == 'asyncio.coroutines' — coroutine introspection helpers live in Lib/asyncio/coroutines.py (18 chars)"
  category: module_names
  kind: python_call_eq
  function: iscoroutine.__module__.__eq__
  args: ["asyncio.coroutines"]
  expected: true

invariant asyncio_extra42.iscoroutinefunction_name_eq:
  description: "asyncio.iscoroutinefunction.__name__ == 'iscoroutinefunction' — returns True if the argument is a coroutine function (19 chars)"
  category: function_names
  kind: python_call_eq
  function: iscoroutinefunction.__name__.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant asyncio_extra42.iscoroutinefunction_module_eq:
  description: "asyncio.iscoroutinefunction.__module__ == 'asyncio.coroutines' — same submodule as iscoroutine; both live in Lib/asyncio/coroutines.py (18 chars)"
  category: module_names
  kind: python_call_eq
  function: iscoroutinefunction.__module__.__eq__
  args: ["asyncio.coroutines"]
  expected: true
