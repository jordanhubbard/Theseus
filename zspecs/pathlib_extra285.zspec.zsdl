spec: pathlib_extra285
version: ">=3.12"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib_extra284 covers Path.parts and Path.parent properties."
    - "This spec focuses on Path.suffixes — the list of all file extensions — and Path.suffix."
    - "Path('foo.tar.gz').suffixes == ['.tar', '.gz'] — two-extension archive name yields a two-element list."
    - "Path('foo').suffixes == [] — a name with no dot yields an empty list."
    - "Path('.hidden').suffixes == [] — a leading-dot hidden file has no suffix (the leading dot is not an extension)."
    - "Path('foo.tar.gz').suffix == '.gz' — .suffix returns only the last extension."
    - "Path('foo').suffix == '' — a name with no dot yields an empty string for .suffix."
    - "Path('.hidden').suffix == '' — leading-dot files have an empty .suffix."
    - "Path('foo.bar.baz').suffixes == ['.bar', '.baz'] — three-part name yields two suffixes (stem is 'foo')."
    - "Path('foo.tar.gz').stem == 'foo.tar' — .stem strips only the last extension."
    - "Path('a/b/c.txt').suffixes == ['.txt'] — directory components are ignored; only the final name matters."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.suffixes — list of all extensions
# Path('foo.tar.gz').suffixes == ['.tar', '.gz']
# Path('foo').suffixes == []
# Path('.hidden').suffixes == [] (leading dot is not treated as an extension)
# ---------------------------------------------------------------------------

table pathlib_extra285.suffixes_len:
  description: "pathlib.Path.suffixes length — number of extensions in the suffixes list"
  kind: python_call_eq
  category: components
  id_prefix: suffixes_len
  function: Path
  method: suffixes.__len__

  columns: [id, args, expected, description]
  rows:
    - [two_ext,    ["foo.tar.gz"],     2, "Path('foo.tar.gz').suffixes has 2 elements: ['.tar', '.gz']"]
    - [no_ext,     ["foo"],            0, "Path('foo').suffixes == [] — name with no dot has no suffixes"]
    - [hidden,     [".hidden"],        0, "Path('.hidden').suffixes == [] — leading-dot files have no suffix"]
    - [one_ext,    ["foo.txt"],        1, "Path('foo.txt').suffixes has 1 element: ['.txt']"]
    - [three_part, ["foo.bar.baz"],    2, "Path('foo.bar.baz').suffixes has 2 elements: ['.bar', '.baz']"]
    - [with_dir,   ["a/b/c.txt"],      1, "Path('a/b/c.txt').suffixes has 1 element — directory parts ignored"]

# ---------------------------------------------------------------------------
# Path.suffix — the last extension only
# ---------------------------------------------------------------------------

table pathlib_extra285.suffix_value:
  description: "pathlib.Path.suffix — the final file extension, or empty string when absent"
  kind: python_call_eq
  category: components
  id_prefix: suffix
  function: Path
  method: suffix

  columns: [id, args, expected, description]
  rows:
    - [two_ext,   ["foo.tar.gz"], ".gz",  "Path('foo.tar.gz').suffix == '.gz' — only the last extension"]
    - [no_ext,    ["foo"],        "",     "Path('foo').suffix == '' — no dot means empty suffix"]
    - [hidden,    [".hidden"],    "",     "Path('.hidden').suffix == '' — leading-dot file has empty suffix"]
    - [one_ext,   ["foo.txt"],    ".txt", "Path('foo.txt').suffix == '.txt' — single extension returned"]
    - [with_dir,  ["a/b/c.txt"], ".txt", "Path('a/b/c.txt').suffix == '.txt' — directory parts ignored"]

# ---------------------------------------------------------------------------
# Path.suffixes element access — individual extensions from the list
# ---------------------------------------------------------------------------

invariant pathlib_extra285.Path.suffixes.tar_gz_first:
  description: "pathlib.Path('foo.tar.gz').suffixes[0] == '.tar' — first suffix is the penultimate extension"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo.tar.gz"]
  method: "suffixes.__getitem__"
  method_args: [0]
  expected: ".tar"

invariant pathlib_extra285.Path.suffixes.tar_gz_second:
  description: "pathlib.Path('foo.tar.gz').suffixes[1] == '.gz' — second suffix is the final extension"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo.tar.gz"]
  method: "suffixes.__getitem__"
  method_args: [1]
  expected: ".gz"

invariant pathlib_extra285.Path.suffixes.bar_baz_first:
  description: "pathlib.Path('foo.bar.baz').suffixes[0] == '.bar' — first suffix of three-part name"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo.bar.baz"]
  method: "suffixes.__getitem__"
  method_args: [0]
  expected: ".bar"

invariant pathlib_extra285.Path.suffixes.bar_baz_second:
  description: "pathlib.Path('foo.bar.baz').suffixes[1] == '.baz' — second suffix of three-part name"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo.bar.baz"]
  method: "suffixes.__getitem__"
  method_args: [1]
  expected: ".baz"

# ---------------------------------------------------------------------------
# Path.stem — the final path component without its last extension
# ---------------------------------------------------------------------------

invariant pathlib_extra285.Path.stem.tar_gz:
  description: "pathlib.Path('foo.tar.gz').stem == 'foo.tar' — stem strips only the last extension"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo.tar.gz"]
  method: stem
  expected: "foo.tar"

invariant pathlib_extra285.Path.stem.no_ext:
  description: "pathlib.Path('foo').stem == 'foo' — name with no extension is its own stem"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo"]
  method: stem
  expected: "foo"

invariant pathlib_extra285.Path.name.tar_gz:
  description: "pathlib.Path('foo.tar.gz').name == 'foo.tar.gz' — name is the full final component"
  category: components
  kind: python_call_eq
  function: Path
  args: ["foo.tar.gz"]
  method: name
  expected: "foo.tar.gz"
