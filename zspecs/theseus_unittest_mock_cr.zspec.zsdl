spec: theseus_unittest_mock_cr
version: ">=3.0"
backend: python_cleanroom(theseus_unittest_mock_cr)
blocks: unittest.mock

docs: https://docs.python.org/3/library/unittest.mock.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/unittest.mock.html"
  not_derived_from:
    - "CPython source: Lib/unittest/mock.py"
  notes:
    - "Clean-room unittest.mock module. Do NOT import unittest.mock."

error_model: python_exceptions

invariant theseus_unittest_mock_cr.mock2_mock:
  description: "Mock class can be instantiated and called"
  category: behavior
  kind: python_call_eq
  function: mock2_mock
  args: []
  expected: true

invariant theseus_unittest_mock_cr.mock2_patch:
  description: "patch() decorator works as context manager"
  category: behavior
  kind: python_call_eq
  function: mock2_patch
  args: []
  expected: true

invariant theseus_unittest_mock_cr.mock2_magic_mock:
  description: "MagicMock supports magic methods"
  category: behavior
  kind: python_call_eq
  function: mock2_magic_mock
  args: []
  expected: true
