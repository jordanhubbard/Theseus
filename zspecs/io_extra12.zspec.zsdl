spec: io_extra12
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra11.zspec.zsdl."
    - "io_extra11 covers: BufferedReader/Writer/Random/TextIOWrapper.__bases__[0].__name__; BytesIO/StringIO readable/writable/seekable; DEFAULT_BUFFER_SIZE exact value."
    - "io_extra10 covers: UnsupportedOperation.__bases__ (len, [0], [1]); MRO lengths for StringIO/BufferedReader/BufferedWriter/TextIOWrapper; concrete class modules."
    - "NOT yet covered: UnsupportedOperation.__mro__.__len__() (== 6); UnsupportedOperation.__mro__[1].__name__; BytesIO().getvalue() on empty; StringIO().getvalue() on empty; BytesIO().closed == False; StringIO().closed == False; BytesIO.read() on seeded content; StringIO.read() on seeded content; BufferedRandom.__mro__.__len__() (== 4)."
    - "io.UnsupportedOperation.__mro__.__len__() == 6 — [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]."
    - "io.UnsupportedOperation.__mro__[1].__name__ == 'OSError' — OSError is second in MRO."
    - "io.BytesIO().getvalue() == b'' — empty in-memory binary buffer returns empty bytes."
    - "io.StringIO().getvalue() == '' — empty in-memory text buffer returns empty string."
    - "io.BytesIO().closed == False — a freshly-created BytesIO is open."
    - "io.StringIO().closed == False — a freshly-created StringIO is open."
    - "io.BytesIO(b'hello').read() == b'hello' — pre-seeded BytesIO reads all bytes."
    - "io.StringIO('hello').read() == 'hello' — pre-seeded StringIO reads all text."
    - "io.BufferedRandom.__mro__.__len__() == 4 — [BufferedRandom, BufferedIOBase, IOBase, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UnsupportedOperation.__mro__ — length and second entry
#
# io_extra10 verified __bases__[0].__name__ == 'OSError' and
# __bases__[1].__name__ == 'ValueError'. Not yet verified: the full MRO.
# UnsupportedOperation MRO is [UnsupportedOperation, OSError, ValueError,
# Exception, BaseException, object] — length 6.
# ---------------------------------------------------------------------------

invariant io_extra12.UnsupportedOperation.mro_len:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 — [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]"
  category: mro
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__len__
  args: []
  expected: 6

invariant io_extra12.UnsupportedOperation.mro_second:
  description: "io.UnsupportedOperation.__mro__[1].__name__ == 'OSError' — OSError is second in MRO"
  category: mro
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# BufferedRandom.__mro__ — MRO length
#
# io_extra10 verified MRO lengths for StringIO, BufferedReader, BufferedWriter,
# TextIOWrapper (all == 4). Not yet verified: BufferedRandom.__mro__.__len__().
# BufferedRandom MRO is [BufferedRandom, BufferedIOBase, IOBase, object] — len 4.
# ---------------------------------------------------------------------------

invariant io_extra12.BufferedRandom.mro_len:
  description: "io.BufferedRandom.__mro__.__len__() == 4 — [BufferedRandom, BufferedIOBase, IOBase, object]"
  category: mro
  kind: python_call_eq
  function: BufferedRandom.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# BytesIO().getvalue() and StringIO().getvalue() on empty streams
#
# io_extra11 verified getvalue() is mentioned in the notes but no prior spec
# tested the actual return value. An empty BytesIO returns b''; an empty
# StringIO returns ''.
# ---------------------------------------------------------------------------

invariant io_extra12.BytesIO.getvalue_empty:
  description: "io.BytesIO().getvalue() == b'' — empty in-memory binary buffer"
  category: stream_ops
  kind: python_call_eq
  function: BytesIO
  args: []
  method: getvalue
  expected: !b64 ""

invariant io_extra12.StringIO.getvalue_empty:
  description: "io.StringIO().getvalue() == '' — empty in-memory text buffer"
  category: stream_ops
  kind: python_call_eq
  function: StringIO
  args: []
  method: getvalue
  expected: ""

# ---------------------------------------------------------------------------
# BytesIO().closed and StringIO().closed — freshly created streams are open
#
# A newly constructed in-memory stream is not closed. No prior spec tests
# the .closed property on BytesIO or StringIO instances.
# ---------------------------------------------------------------------------

invariant io_extra12.BytesIO.not_closed:
  description: "io.BytesIO().closed == False — freshly-created BytesIO is open"
  category: stream_state
  kind: python_call_eq
  function: BytesIO
  args: []
  method: closed
  expected: false

invariant io_extra12.StringIO.not_closed:
  description: "io.StringIO().closed == False — freshly-created StringIO is open"
  category: stream_state
  kind: python_call_eq
  function: StringIO
  args: []
  method: closed
  expected: false

# ---------------------------------------------------------------------------
# BytesIO(b'hello').read() and StringIO('hello').read()
#
# When BytesIO or StringIO is constructed with initial content the read
# position starts at 0 and .read() returns the full content. No prior spec
# tests these read operations on pre-seeded in-memory streams.
# ---------------------------------------------------------------------------

invariant io_extra12.BytesIO.read_seeded:
  description: "io.BytesIO(b'hello').read() == b'hello' — reads all pre-seeded bytes"
  category: stream_ops
  kind: python_call_eq
  function: BytesIO
  args: [!b64 aGVsbG8=]
  method: read
  expected: !b64 aGVsbG8=

invariant io_extra12.StringIO.read_seeded:
  description: "io.StringIO('hello').read() == 'hello' — reads all pre-seeded text"
  category: stream_ops
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  expected: "hello"
