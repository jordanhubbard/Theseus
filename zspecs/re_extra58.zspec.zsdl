spec: re_extra58
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra57.zspec.zsdl — covers Pattern/Match/error __class__.__module__.__eq__('builtins'); search/compile/sub/findall __class__.__module__.__eq__('builtins'); RegexFlag.__class__.__module__.__eq__('enum')."
    - "re_extra56.zspec.zsdl — covers Pattern/Match/error/RegexFlag __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); re module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "re_extra55.zspec.zsdl — covers subn __module__.__len__()==2; Pattern/Match/RegexFlag __module__ equality/length namespace anchors."
    - "re_extra54.zspec.zsdl — covers re function __module__.__eq__('re') for all 9 functions + error."
    - "re_extra51.zspec.zsdl — covers RegexFlag member __class__.__module__.__eq__('re') for MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE."
    - "re_extra43.zspec.zsdl — covers search/__module__=='re'; findall/__module__=='re'; IGNORECASE/__class__.__module__=='re'."
    - "re_extra33.zspec.zsdl — covers error/Pattern/Match/RegexFlag __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends re_extra57.zspec.zsdl."
    - "Prior specs collectively covered: Pattern/Match/error __class__.__module__=='builtins' (re_extra57); re function __module__.__eq__('re') (re_extra54); Pattern/Match/RegexFlag __module__ (re_extra55). NOT YET COVERED: Pattern/Match __repr__.__class__.__name__.__eq__('wrapper_descriptor') — Pattern and Match are C-extension types; both define __repr__ in their own __dict__ as a wrapper_descriptor; no prior re spec checks __repr__.__class__.__name__ for Pattern or Match; novel; error.__repr__.__class__.__name__.__eq__('wrapper_descriptor') — re.error (PatternError in Python 3.14) is an Exception subclass; it inherits __repr__ from BaseException as a wrapper_descriptor; novel; Pattern.__hash__.__class__.__name__.__eq__('wrapper_descriptor') — Pattern defines __hash__ in its own __dict__ as a wrapper_descriptor; novel; Match.__hash__.__class__.__name__.__eq__('wrapper_descriptor') — Match inherits __hash__ from object (not in Match.__dict__); novel."
    - "Note on re.error: In Python 3.14.3, re.error is an alias for re.PatternError (re.error.__name__ == 'PatternError'). The 'error' symbol still resolves to the same class and all attribute lookups work the same way."
    - "This spec covers: re.Pattern.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Pattern is a C-extension type; __repr__ is in Pattern.__dict__ as a wrapper_descriptor for 're.Pattern' objects; no prior re spec checks __repr__.__class__.__name__; novel in rerepr58 namespace); re.Match.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Match defines __repr__ in its own __dict__ as a wrapper_descriptor for 're.Match' objects; novel); re.error.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — re.error inherits __repr__ from BaseException; BaseException.__repr__ is a wrapper_descriptor; novel); re.Pattern.__hash__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Pattern defines __hash__ in its own __dict__ as a wrapper_descriptor; Pattern is hashable; no prior re spec checks __hash__.__class__.__name__; novel in rerepr58 namespace); re.Match.__hash__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Match inherits __hash__ from object; object.__hash__ is a wrapper_descriptor; Match is hashable; novel)."
    - "re.Pattern.__repr__.__class__.__name__ == 'wrapper_descriptor'. re.Pattern is a C-extension type (_sre.SRE_Pattern). __repr__ is defined in Pattern.__dict__ as a slot wrapper for 're.Pattern' objects. In Python 3.14.3, the class name is 'wrapper_descriptor'. No prior re spec checks __repr__.__class__.__name__ for Pattern. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__repr__.__class__.__name__ == 'wrapper_descriptor'. re.Match is also a C-extension type. __repr__ is defined in Match.__dict__ as a slot wrapper for 're.Match' objects. Class name is 'wrapper_descriptor'. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__repr__.__class__.__name__ == 'wrapper_descriptor'. re.error (PatternError) is a pure-Python Exception subclass. It does NOT define __repr__ in its own __dict__; it inherits BaseException.__repr__, which is a wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__hash__.__class__.__name__ == 'wrapper_descriptor'. Pattern defines __hash__ in its own __dict__ as a wrapper_descriptor for 're.Pattern' objects. Pattern is hashable. No prior re spec checks __hash__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__hash__.__class__.__name__ == 'wrapper_descriptor'. Match does NOT define __hash__ in its own __dict__; it inherits object.__hash__, which is a wrapper_descriptor. Match is hashable. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re Pattern/Match/error __repr__.__class__.__name__ == 'wrapper_descriptor'
#
# Pattern and Match are C-extension types that each define their own __repr__
# in their __dict__ as a wrapper_descriptor (slot wrapper for their respective
# types). re.error (PatternError) is an Exception subclass that inherits
# __repr__ from BaseException as a wrapper_descriptor.
#
# In Python 3.14.3, the type name is 'wrapper_descriptor', not 'slot_wrapper'.
#
#   Pattern.__repr__.__class__.__name__ == 'wrapper_descriptor'
#   Match.__repr__.__class__.__name__   == 'wrapper_descriptor'
#   error.__repr__.__class__.__name__   == 'wrapper_descriptor'
#
# No prior re spec checks __repr__.__class__.__name__ for Pattern, Match, or error.
# All three anchors are novel in the rerepr58 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra58.repr_class_name_eq:
  description: "re Pattern/Match/error __repr__.__class__.__name__.__eq__('wrapper_descriptor') — Pattern and Match are C-extension types that define __repr__ in their own __dict__; error (PatternError) inherits BaseException.__repr__; all are wrapper_descriptor in Python 3.14.3; no prior re spec checks __repr__.__class__.__name__; all three novel anchors in rerepr58 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerepr58repr

  columns: [id, function, args, expected]
  rows:
    - [Pattern_repr_class_name, "Pattern.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [Match_repr_class_name,   "Match.__repr__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - [error_repr_class_name,   "error.__repr__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# re Pattern/Match __hash__.__class__.__name__ == 'wrapper_descriptor'
#
# Pattern defines __hash__ in its own __dict__ as a wrapper_descriptor
# (a slot wrapper for 're.Pattern' objects). Pattern is hashable.
# Match does NOT define __hash__ in its own __dict__; it inherits
# object.__hash__, which is also a wrapper_descriptor. Match is hashable.
#
#   Pattern.__hash__.__class__.__name__ == 'wrapper_descriptor'
#   Match.__hash__.__class__.__name__   == 'wrapper_descriptor'
#
# No prior re spec checks __hash__.__class__.__name__ for Pattern or Match.
# Both anchors are novel in the rerepr58 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra58.hash_class_name_eq:
  description: "re Pattern/Match __hash__.__class__.__name__.__eq__('wrapper_descriptor') — Pattern defines __hash__ in its own __dict__ as a wrapper_descriptor; Match inherits object.__hash__ which is also a wrapper_descriptor; both Pattern and Match are hashable; no prior re spec checks __hash__.__class__.__name__; both novel anchors in rerepr58 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerepr58hash

  columns: [id, function, args, expected]
  rows:
    - [Pattern_hash_class_name, "Pattern.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [Match_hash_class_name,   "Match.__hash__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]

invariant re_extra58.Pattern_repr_class_name_wrapper_descriptor:
  description: "re.Pattern.__repr__.__class__.__name__ == 'wrapper_descriptor' — Pattern is a C-extension type; __repr__ is defined in Pattern.__dict__ as a slot wrapper for 're.Pattern' objects; in Python 3.14.3 the class name is 'wrapper_descriptor' (not 'slot_wrapper'); no prior re spec checks __repr__.__class__.__name__; novel anchor in rerepr58 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant re_extra58.error_repr_class_name_wrapper_descriptor:
  description: "re.error.__repr__.__class__.__name__ == 'wrapper_descriptor' — re.error (PatternError in Python 3.14) is an Exception subclass that inherits __repr__ from BaseException; BaseException.__repr__ is a wrapper_descriptor; no prior re spec checks error.__repr__.__class__.__name__; novel anchor in rerepr58 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: error.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant re_extra58.Pattern_hash_class_name_wrapper_descriptor:
  description: "re.Pattern.__hash__.__class__.__name__ == 'wrapper_descriptor' — Pattern defines __hash__ in its own __dict__ as a wrapper_descriptor for 're.Pattern' objects; Pattern is hashable; no prior re spec checks __hash__.__class__.__name__; novel anchor in rerepr58 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
