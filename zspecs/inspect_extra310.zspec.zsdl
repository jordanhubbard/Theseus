spec: inspect_extra310
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — _empty is a class (metaclass is type)."
    - "inspect.Parameter.empty.__name__ == '_empty' — the sentinel class is named _empty."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — kind values are _ParameterKind enum members."
    - "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' — .name gives the enum member string."
    - "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY'."
    - "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'."
    - "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD'."
    - "inspect.Signature.empty.__class__.__name__ == 'type' — Signature._empty is also a class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Parameter.empty sentinel — class identity
#
# inspect.Parameter.empty is a sentinel class (_empty). Its metaclass is type,
# so __class__.__name__ == 'type'. Its own __name__ is '_empty'.
# ---------------------------------------------------------------------------

invariant inspect_extra310.parameter_empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — _empty is a class object"
  category: parameter_empty
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra310.parameter_empty_name:
  description: "inspect.Parameter.empty.__name__ == '_empty' — the sentinel class is named _empty"
  category: parameter_empty
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

# ---------------------------------------------------------------------------
# Parameter kind constants — _ParameterKind enum members
#
# Each kind constant (POSITIONAL_ONLY, KEYWORD_ONLY, VAR_POSITIONAL,
# VAR_KEYWORD) is a _ParameterKind enum member. The .name attribute returns
# the member's string name, identical to the attribute name on Parameter.
# ---------------------------------------------------------------------------

invariant inspect_extra310.positional_only_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra310.positional_only_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY'"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.name.__eq__
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect_extra310.keyword_only_name:
  description: "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY'"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.name.__eq__
  args: ["KEYWORD_ONLY"]
  expected: true

invariant inspect_extra310.var_positional_name:
  description: "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.name.__eq__
  args: ["VAR_POSITIONAL"]
  expected: true

invariant inspect_extra310.var_keyword_name:
  description: "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD'"
  category: parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.name.__eq__
  args: ["VAR_KEYWORD"]
  expected: true

# ---------------------------------------------------------------------------
# Signature.empty sentinel — class identity
#
# inspect.Signature.empty is the same _empty sentinel class used by Parameter.
# Its metaclass is type, so __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

invariant inspect_extra310.signature_empty_class_name:
  description: "inspect.Signature.empty.__class__.__name__ == 'type' — Signature._empty is a class object"
  category: signature_empty
  kind: python_call_eq
  function: Signature.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true
