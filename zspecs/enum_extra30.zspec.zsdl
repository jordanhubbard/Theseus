spec: enum_extra30
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra29.zspec.zsdl."
    - "Prior specs covered: Enum.__name__/__module__/__qualname__, IntEnum.__name__, Flag.__name__, IntFlag.__name__, StrEnum.__name__, auto.__name__, unique.__name__, EnumMeta.__name__ (== 'EnumType' in 3.11+), EnumMeta.__qualname__, Enum/__bases__, IntEnum/__bases__, Flag/__bases__, enum.__name__/__package__, various Enum member attributes, EnumMeta/__module__, EnumType bases, Enum/IntEnum/StrEnum combined __module__ table, IntEnum/StrEnum base class names, Enum.__init_subclass__/__qualname__, unique/__qualname__/__module__."
    - "This spec covers: enum.Enum.__init__.__name__, enum.Enum.__str__.__name__, enum.Enum.__repr__.__name__, enum.Enum.__str__.__qualname__, enum.Enum.__repr__.__qualname__, enum.IntEnum.__module__, enum.Flag.__module__, enum.IntFlag.__module__, enum.StrEnum.__module__, enum.auto.__module__, enum.unique.__module__."
    - "Enum.__init__.__name__ == '__init__' — inherited from object.__init__."
    - "Enum.__str__.__qualname__ == 'Enum.__str__'; Enum.__repr__.__qualname__ == 'Enum.__repr__' — both defined on Enum directly."
    - "IntEnum/Flag/IntFlag/StrEnum/auto/unique all have __module__ == 'enum'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum.IntEnum, Flag, IntFlag, StrEnum, auto, unique __module__ — combined table
#
# enum_extra29 covers a combined __module__ table for Enum/IntEnum/StrEnum.
# No prior enum spec collects all six of IntEnum/Flag/IntFlag/StrEnum/auto/unique
# together in a single combined __module__.__eq__ table in the extra30 namespace.
# ---------------------------------------------------------------------------

table enum_extra30.extended_class_modules:
  description: "__module__.__eq__ for enum.IntEnum, Flag, IntFlag, StrEnum, auto, unique — Python 3.11+"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [IntEnum, IntEnum.__module__.__eq__, ["enum"], true]
    - [Flag,    Flag.__module__.__eq__,    ["enum"], true]
    - [IntFlag, IntFlag.__module__.__eq__, ["enum"], true]
    - [StrEnum, StrEnum.__module__.__eq__, ["enum"], true]
    - [auto,    auto.__module__.__eq__,    ["enum"], true]
    - [unique,  unique.__module__.__eq__,  ["enum"], true]

# ---------------------------------------------------------------------------
# enum.Enum.__str__ and __repr__ __name__ and __qualname__ — combined table
#
# Enum defines __str__ and __repr__ directly on the class. Their __name__
# values are the dunder short forms; their __qualname__ values include the
# 'Enum.' class prefix. No prior enum spec records Enum.__str__/__name__,
# Enum.__repr__/__name__, Enum.__str__/__qualname__, or Enum.__repr__/__qualname__
# together in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table enum_extra30.Enum_method_names:
  description: "__name__ and __qualname__ for enum.Enum.__str__ and enum.Enum.__repr__"
  kind: python_call_eq
  category: method_attrs
  id_prefix: attr

  columns: [id, function, args, expected]
  rows:
    - [str_name,    Enum.__str__.__name__.__eq__,    ["__str__"],      true]
    - [str_qualname, Enum.__str__.__qualname__.__eq__, ["Enum.__str__"],  true]
    - [repr_name,   Enum.__repr__.__name__.__eq__,   ["__repr__"],     true]
    - [repr_qualname, Enum.__repr__.__qualname__.__eq__, ["Enum.__repr__"], true]

# ---------------------------------------------------------------------------
# enum.Enum.__init__.__name__ == '__init__' — standalone invariant
#
# Enum.__init__ is inherited from object. Its __name__ is '__init__'.
# No prior enum spec records Enum.__init__.__name__ in any invariant or table
# in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra30.Enum.init_name:
  description: "enum.Enum.__init__.__name__ == '__init__' — inherited from object.__init__"
  category: method_attrs
  kind: python_call_eq
  function: Enum.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# len('Enum.__str__') == 12 — standalone invariant
#
# Enum.__str__.__qualname__ == 'Enum.__str__' has length 12.
# No prior enum spec records the __len__() of Enum.__str__.__qualname__ in
# any invariant or table in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra30.Enum.str_qualname_len:
  description: "len(enum.Enum.__str__.__qualname__) == 12 — len('Enum.__str__') == 12"
  category: method_attr_lengths
  kind: python_call_eq
  function: Enum.__str__.__qualname__.__len__
  args: []
  expected: 12
