spec: array_last
version: ">=1.3.0"
backend: node(array-last)

docs: https://www.npmjs.com/package/array-last

provenance:
  derived_from:
    - "array-last README — https://www.npmjs.com/package/array-last"
    - "Test vectors verified with array-last via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-last source"
  notes:
    - "array-last is an npm package. Install: npm install array-last"
    - "Returns the last element (or last n elements) of an array."
    - "Without n argument: returns the element directly. With n: returns an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a value or array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_last.last:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: alast

  columns: [id, args, expected]
  rows:
    - [single,  [[1, 2, 3]],     3]
    - [two,     [[1, 2, 3], 2],  [2, 3]]
    - [one,     [[5, 6], 1],     6]
