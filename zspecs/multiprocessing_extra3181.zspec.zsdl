    - ["mp3181007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__truediv__"], false]
    - ["mp3181008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__truediv__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — operator.contains(Cls.__dict__, '__floordiv__')
#
# All 8 multiprocessing classes return false for __floordiv__.
# multiprocessing.Process: no floor division semantics.
# multiprocessing.pool.Pool: work partitioning is done via map(chunksize=);
#   pool // n is not a valid expression.
# multiprocessing.pool.AsyncResult/MapResult: result containers; no floor division.
# multiprocessing.managers.SyncManager: manager for shared objects; no //.
# multiprocessing.managers.BaseListProxy: proxies list; list.__floordiv__ is
#   not defined — list // n is a TypeError. The proxy mirrors this absence.
# multiprocessing.managers._BaseDictProxy: dict.__floordiv__ is not defined.
# multiprocessing.managers._BaseSetProxy: set.__floordiv__ is not defined.
# ---------------------------------------------------------------------------

