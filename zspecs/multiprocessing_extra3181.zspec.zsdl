    - ["mp3181013", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__floordiv__"], false]
    - ["mp3181014", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__floordiv__"], false]
    - ["mp3181015", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__floordiv__"], false]
    - ["mp3181016", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — operator.contains(Cls.__dict__, '__mod__')
#
# All 8 multiprocessing classes return false for __mod__.
# multiprocessing.Process: process management object; no % operator.
# multiprocessing.pool.Pool/AsyncResult/MapResult: pool and result objects;
#   no modulo semantics.
# multiprocessing.managers.SyncManager: no modulo protocol.
# multiprocessing.managers.BaseListProxy: proxies list; list.__mod__ is not
#   defined — list % n is a TypeError. The proxy mirrors this absence.
#   (list % n would require __mod__ on list, which Python does not define.)
# multiprocessing.managers._BaseDictProxy: dict.__mod__ is not defined.
#   dict % n is a TypeError (old-style % formatting applies only to str).
# multiprocessing.managers._BaseSetProxy: set.__mod__ is not defined.
#   set % n is a TypeError; sets have no modulo operation.
# ---------------------------------------------------------------------------

