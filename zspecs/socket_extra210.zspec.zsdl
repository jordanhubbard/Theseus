spec: socket_extra210
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "Python 3 socket module documentation — https://docs.python.org/3/library/socket.html"
    - "POSIX.1-2017 — SOL_SOCKET, SO_REUSEADDR, SO_REUSEPORT, SHUT_* constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra2.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX AddressFamily class names; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW SocketKind class names; AF_INET==2; SOCK_STREAM==1; SOCK_DGRAM==2; gethostname/getfqdn return str; error.__name__=='OSError'; timeout.__name__=='TimeoutError'."
    - "SOL_SOCKET.__class__.__name__ == 'int' — SOL_SOCKET is a plain int constant (not an enum member)."
    - "SO_REUSEADDR.__class__.__name__ == 'int' — SO_REUSEADDR is a plain int constant (not an enum member)."
    - "SO_REUSEPORT.__class__.__name__ == 'int' — SO_REUSEPORT is a plain int constant (not an enum member)."
    - "SHUT_RDWR.__class__.__name__ == 'int' — SHUT_RDWR is a plain int (value 2 on macOS/Linux)."
    - "SHUT_RD.__class__.__name__ == 'int' — SHUT_RD is a plain int (value 0 on macOS/Linux)."
    - "AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an IntEnum member (unlike SOL_SOCKET/SO_* which are plain ints)."
    - "SHUT_RD==0, SHUT_WR==1, SHUT_RDWR==2 on macOS/Darwin 25.4.0."
    - "SOL_SOCKET==65535 on macOS/Darwin; SO_REUSEADDR==4 on macOS; SO_REUSEPORT==512 on macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError for I/O failures. Class name checks on constants are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class name or integer value checks on module-level constants."
  codes: {}

# ---------------------------------------------------------------------------
# socket SOL_SOCKET and SO_* constants — class name checks
#
# Unlike AF_* and SOCK_* which are IntEnum members, SOL_SOCKET and SO_*
# are plain int constants (class name 'int').
# ---------------------------------------------------------------------------

table socket_extra210.sol_so_constants_class_names:
  description: "socket SOL_SOCKET and SO_* constants class name checks in socketconst210 namespace — wave 257 theme: SOL_SOCKET.__class__.__name__=='int'; SO_REUSEADDR.__class__.__name__=='int'; SO_REUSEPORT.__class__.__name__=='int'; SO_KEEPALIVE.__class__.__name__=='int'; SO_BROADCAST.__class__.__name__=='int'; all are plain int constants (not IntEnum); compare: AF_* and SOCK_* are IntEnum members with class names 'AddressFamily' and 'SocketKind'; verified with Python 3.14.3 on macOS"
  kind: python_call_eq
  category: constants
  id_prefix: socketconst210

  columns: [id, function, args, expected, description]
  rows:
    - [sol_socket_cls,    SOL_SOCKET.__class__.__name__.__eq__,    ["int"], true, "socket.SOL_SOCKET.__class__.__name__ == 'int' — SOL_SOCKET is a plain int, not an enum member; verified with Python 3.14.3"]
    - [so_reuseaddr_cls,  SO_REUSEADDR.__class__.__name__.__eq__,  ["int"], true, "socket.SO_REUSEADDR.__class__.__name__ == 'int' — SO_REUSEADDR is a plain int, not an enum member; verified with Python 3.14.3"]
    - [so_reuseport_cls,  SO_REUSEPORT.__class__.__name__.__eq__,  ["int"], true, "socket.SO_REUSEPORT.__class__.__name__ == 'int' — SO_REUSEPORT is a plain int, not an enum member; verified with Python 3.14.3"]
    - [so_keepalive_cls,  SO_KEEPALIVE.__class__.__name__.__eq__,  ["int"], true, "socket.SO_KEEPALIVE.__class__.__name__ == 'int' — SO_KEEPALIVE is a plain int, not an enum member; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket SHUT_* constants — class name and value checks
#
# SHUT_RD == 0, SHUT_WR == 1, SHUT_RDWR == 2 on macOS.
# These are plain int constants (not IntEnum members).
# ---------------------------------------------------------------------------

table socket_extra210.shut_constants_class_names:
  description: "socket SHUT_* constants class name checks in socketconst210 namespace — wave 257 theme: SHUT_RD.__class__.__name__=='int'; SHUT_WR.__class__.__name__=='int'; SHUT_RDWR.__class__.__name__=='int'; all are plain int constants (not IntEnum members); compare: AF_UNIX.__class__.__name__=='AddressFamily' (IntEnum); SHUT_RD==0, SHUT_WR==1, SHUT_RDWR==2 on macOS/Darwin 25.4.0; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: socketconst210a

  columns: [id, function, args, expected, description]
  rows:
    - [shut_rd_cls,    SHUT_RD.__class__.__name__.__eq__,   ["int"], true, "socket.SHUT_RD.__class__.__name__ == 'int' — SHUT_RD is a plain int (value 0 on macOS); verified with Python 3.14.3"]
    - [shut_wr_cls,    SHUT_WR.__class__.__name__.__eq__,   ["int"], true, "socket.SHUT_WR.__class__.__name__ == 'int' — SHUT_WR is a plain int (value 1 on macOS); verified with Python 3.14.3"]
    - [shut_rdwr_cls,  SHUT_RDWR.__class__.__name__.__eq__,  ["int"], true, "socket.SHUT_RDWR.__class__.__name__ == 'int' — SHUT_RDWR is a plain int (value 2 on macOS); verified with Python 3.14.3"]
    - [shut_rd_val,    SHUT_RD.__eq__,                      [0],     true, "socket.SHUT_RD == 0 on macOS/Darwin 25.4.0; POSIX SHUT_RD=0; verified with Python 3.14.3"]
    - [shut_wr_val,    SHUT_WR.__eq__,                      [1],     true, "socket.SHUT_WR == 1 on macOS/Darwin 25.4.0; POSIX SHUT_WR=1; verified with Python 3.14.3"]
    - [shut_rdwr_val,  SHUT_RDWR.__eq__,                    [2],     true, "socket.SHUT_RDWR == 2 on macOS/Darwin 25.4.0; POSIX SHUT_RDWR=2; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# AF_UNIX class name — AddressFamily (POSIX only, available on macOS)
# Contrast with SOL_SOCKET and SO_* which are plain int.
# ---------------------------------------------------------------------------

table socket_extra210.af_unix_vs_int_constants:
  description: "socket AF_UNIX class name contrast with int constants in socketconst210 namespace — wave 257 theme: AF_UNIX.__class__.__name__=='AddressFamily' (IntEnum); SOL_SOCKET.__class__.__name__=='int' (plain int); contrast demonstrates that socket module uses IntEnum for address family/socket kind constants but plain int for socket option constants; AF_UNIX value is 1 on macOS; IPPROTO_TCP.__class__.__name__=='int'; IPPROTO_UDP.__class__.__name__=='int'; all verified with Python 3.14.3 on macOS"
  kind: python_call_eq
  category: constants
  id_prefix: socketconst210b

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_cls,     AF_UNIX.__class__.__name__.__eq__,    ["AddressFamily"], true, "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an IntEnum member (POSIX, macOS); verified with Python 3.14.3"]
    - [ipproto_tcp_cls, IPPROTO_TCP.__class__.__name__.__eq__, ["int"],           true, "socket.IPPROTO_TCP.__class__.__name__ == 'int' — IPPROTO_TCP is a plain int constant; verified with Python 3.14.3"]
    - [ipproto_udp_cls, IPPROTO_UDP.__class__.__name__.__eq__, ["int"],           true, "socket.IPPROTO_UDP.__class__.__name__ == 'int' — IPPROTO_UDP is a plain int constant; verified with Python 3.14.3"]
    - [sol_int_cls,     SOL_SOCKET.__class__.__name__.__eq__,  ["int"],           true, "socket.SOL_SOCKET.__class__.__name__ == 'int' — plain int (contrast with AddressFamily IntEnum); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket_extra210
# ---------------------------------------------------------------------------

invariant socket_extra210.AF_UNIX_class_is_AddressFamily:
  description: "socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily') returns True — AF_UNIX is an IntEnum member of socket.AddressFamily; it is available on POSIX platforms (macOS, Linux, FreeBSD) but not on Windows; on macOS AF_UNIX has integer value 1; the class name 'AddressFamily' distinguishes it from plain-int socket option constants like SOL_SOCKET and SO_REUSEADDR; socket.AddressFamily was introduced as an IntEnum in Python 3.4 via PEP 3151; AF_INET and AF_INET6 are also AddressFamily members (covered in socket_extra2.zspec.zsdl); NEW in socket_extra210: first standalone AF_UNIX class name invariant in socketconst210 namespace; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: AF_UNIX.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra210.SOL_SOCKET_class_is_int:
  description: "socket.SOL_SOCKET.__class__.__name__.__eq__('int') returns True — SOL_SOCKET is a plain Python int constant (not an IntEnum member); on macOS its value is 65535 (0xFFFF); SOL_SOCKET is the socket-level option layer used as the 'level' argument in getsockopt/setsockopt calls; unlike AF_* and SOCK_* which are IntEnum members (AddressFamily/SocketKind), the socket option constants (SOL_*, SO_*, SHUT_*, IPPROTO_*) are plain ints; this distinction means SOL_SOCKET.__class__ is int, not AddressFamily; NEW in socket_extra210: first standalone SOL_SOCKET class name invariant; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: SOL_SOCKET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra210.SO_REUSEADDR_class_is_int:
  description: "socket.SO_REUSEADDR.__class__.__name__.__eq__('int') returns True — SO_REUSEADDR is a plain Python int constant; on macOS its value is 4; SO_REUSEADDR is a socket option that allows binding to an address that is in TIME_WAIT state; it is passed as the 'optname' argument to setsockopt(SOL_SOCKET, SO_REUSEADDR, 1); unlike AF_* enum members, SO_REUSEADDR has no enum wrapper; on macOS the value 4 differs from Linux where SO_REUSEADDR == 2; NEW in socket_extra210: first standalone SO_REUSEADDR class name invariant in socketconst210 namespace; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: SO_REUSEADDR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra210.SO_REUSEPORT_class_is_int:
  description: "socket.SO_REUSEPORT.__class__.__name__.__eq__('int') returns True — SO_REUSEPORT is a plain Python int constant; on macOS its value is 512 (0x200); SO_REUSEPORT allows multiple sockets to bind to the same address and port; it is available on macOS, Linux >=3.9, and FreeBSD; on Linux SO_REUSEPORT == 15 (different from macOS); setsockopt(SOL_SOCKET, SO_REUSEPORT, 1) enables this option; compare: SO_REUSEADDR==4 on macOS while SO_REUSEPORT==512; NEW in socket_extra210: first standalone SO_REUSEPORT class name invariant; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: SO_REUSEPORT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra210.SHUT_RDWR_class_is_int:
  description: "socket.SHUT_RDWR.__class__.__name__.__eq__('int') returns True — SHUT_RDWR is a plain Python int constant with value 2 on macOS/Darwin; it is passed to socket.shutdown(how) to disallow further sends and receives on a socket; SHUT_RDWR is the most common argument to shutdown() before close() to ensure orderly TCP connection teardown; compare: SHUT_RD==0 (disallow receives only) and SHUT_WR==1 (disallow sends only); all three SHUT_* constants are plain ints (not IntEnum members); NEW in socket_extra210: first standalone SHUT_RDWR class name invariant; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: SHUT_RDWR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra210.SHUT_RD_class_is_int:
  description: "socket.SHUT_RD.__class__.__name__.__eq__('int') returns True — SHUT_RD is a plain Python int constant with value 0 on macOS/Darwin; it is passed to socket.shutdown(SHUT_RD) to disallow further receives on a socket while still allowing sends; SHUT_RD is defined in POSIX (sys/socket.h); value 0 is consistent across macOS, Linux, and FreeBSD; compare: SHUT_WR==1, SHUT_RDWR==2; NEW in socket_extra210: first standalone SHUT_RD class name invariant; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: SHUT_RD.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra210.SHUT_RD_value_eq_0:
  description: "socket.SHUT_RD.__eq__(0) returns True — SHUT_RD has integer value 0 on macOS/Darwin 25.4.0 and is universally 0 across POSIX platforms (macOS, Linux, FreeBSD, Solaris); defined in POSIX.1-2017 as SHUT_RD=0; the three SHUT_* values are always 0, 1, 2 in that order: SHUT_RD=0 (no more receives), SHUT_WR=1 (no more sends), SHUT_RDWR=2 (no more sends or receives); these values are stable and platform-independent on all POSIX systems; NEW in socket_extra210: first standalone SHUT_RD integer value invariant in socketconst210 namespace; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: SHUT_RD.__eq__
  args: [0]
  expected: true

invariant socket_extra210.SHUT_RDWR_value_eq_2:
  description: "socket.SHUT_RDWR.__eq__(2) returns True — SHUT_RDWR has integer value 2 on macOS/Darwin 25.4.0 and universally across POSIX platforms; defined in POSIX.1-2017 as SHUT_RDWR=2; this is the canonical value to pass to socket.shutdown() for a graceful bidirectional shutdown; the sequence SHUT_RD=0, SHUT_WR=1, SHUT_RDWR=2 is consistent across macOS, Linux, FreeBSD, and Solaris; calling shutdown(SHUT_RDWR) then close() ensures the TCP stack sends a FIN and fully drains the connection; NEW in socket_extra210: first standalone SHUT_RDWR integer value invariant; wave 257; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: SHUT_RDWR.__eq__
  args: [2]
  expected: true

