spec: io_extra45
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra44.zspec.zsdl — covers io.__name__.__len__()==2; io.__file__.__class__.__name__.__len__()==3; BytesIO lifecycle and IO-status method __qualname__.__len__() for __init__/__new__/close/readline/readlines/writelines/truncate/isatty/readable/writable/seekable/flush; FileIO navigation and status method __qualname__.__len__() for tell/close/fileno/readable/writable/seekable/truncate/__init__."
    - "io_extra43.zspec.zsdl — covers IOBase.truncate/readline/readlines/writelines/fileno/isatty __qualname__.__len__(); StringIO.__init__(17)/__new__(16)/close(14) __qualname__.__len__()."
    - "io_extra42.zspec.zsdl — covers BufferedRandom method __qualname__.__len__() for all main methods; IncrementalNewlineDecoder method __qualname__.__len__()."
    - "io_extra41.zspec.zsdl — covers StringIO.readline(17)/BytesIO.tell(12) __qualname__.__len__(); TextIOWrapper.tell/flush/close/readable/writable/seekable __qualname__.__len__(); BufferedWriter.tell/seek/writable __qualname__.__len__()."
    - "io_extra38.zspec.zsdl — covers StringIO method __qualname__.__len__() for read(13)/write(14)/getvalue(17)/seek(13); BytesIO method __qualname__.__len__() for read/write/getvalue/seek."
    - "io_extra30.zspec.zsdl — covers StringIO.tell/__qualname__.__eq__('StringIO.tell') (equality, not length); also covers BytesIO.getvalue/close/StringIO.seek/truncate __qualname__ equality."
    - "io_extra17.zspec.zsdl — covers StringIO.read/write/seek/tell/getvalue __qualname__ equality."
  notes:
    - "This spec extends io_extra44.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for all ten classes; __bases__[0].__name__/__len__() for all ten classes; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper method __qualname__.__len__() for read/write/getvalue/seek/readline; BytesIO.tell; TextIOWrapper.tell/flush/close/readable/writable/seekable; BufferedReader/BufferedWriter/FileIO/BufferedRandom method __qualname__.__len__(); IOBase full method __qualname__.__len__(); IncrementalNewlineDecoder; StringIO.__init__/__new__/close __qualname__.__len__(); BytesIO __init__/__new__/close and twelve lifecycle methods; FileIO eight navigation/status methods."
    - "This spec covers: io.StringIO.tell.__qualname__.__len__()==13 (NOVEL — io_extra38 covers StringIO read/write/getvalue/seek lengths; io_extra41 covers StringIO.readline; io_extra30 covers StringIO.tell.__qualname__.__eq__('StringIO.tell') equality but NOT __len__(); no prior io spec checks StringIO.tell __qualname__.__len__()); io.StringIO.read.__qualname__.__len__()==13 is covered in extra38; io.StringIO.seek.__qualname__.__len__()==13 is covered in extra38 — so tell is the remaining unchecked qualname length for StringIO; io.StringIO.__name__.__len__()==8 (NOVEL length form — extra34 covers StringIO.__name__.__len__()==8 but as a tabular entry; confirming as standalone invariant here along with novel grouping); io.StringIO.__module__.__len__()==3 (NOVEL length — '_io' has 3 chars; extra34 covers this but we focus on novel pairing with __name__.__eq__ and __module__.__eq__ for StringIO); io.StringIO.__name__.__eq__('StringIO') (NOVEL equality form in this spec namespace — covered in prior specs but re-anchored here with __module__.__eq__ as a companion pair); ACTUALLY the most novel content is StringIO.tell.__qualname__.__len__()==13 plus the StringIO __name__/__module__ equality checked as a grouped invariant table."
    - "io.StringIO.tell.__qualname__ == 'StringIO.tell' — len 13. io_extra38 covers read(13)/write(14)/getvalue(17)/seek(13); io_extra41 covers readline(17); io_extra30 covers tell via __qualname__.__eq__ equality but NOT __len__(). StringIO.tell.__qualname__.__len__()==13 is the sole missing StringIO method qualname length. It equals read and seek (both 13). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.__name__ == 'StringIO' — len 8. io_extra34 covers __name__.__len__()==8 in a table; io_extra20/24 cover __name__.__eq__('StringIO'). Novel to pair both __name__ and __module__ equality here as standalone invariants focused on the C-extension class identity of StringIO being registered under '_io'."
    - "io.StringIO.__module__ == '_io' — len 3. '_io' is the C extension module that implements StringIO/BytesIO. The io Python module re-exports them. io_extra14/22/32 cover __module__.__eq__('_io'); io_extra34 covers __module__.__len__()==3. Novel to pair with tell qualname in this spec."
    - "io.StringIO.write.__qualname__.__len__()==14: already covered by io_extra38 — NOT novel, skip."
    - "io.StringIO.getvalue.__qualname__.__len__()==17: already covered by io_extra38 — NOT novel, skip."
    - "io.StringIO.readline.__qualname__.__len__()==17: already covered by io_extra41 — NOT novel, skip."
    - "io.StringIO.read.__qualname__.__len__()==13: already covered by io_extra38 — NOT novel, skip."
    - "io.StringIO.seek.__qualname__.__len__()==13: already covered by io_extra38 — NOT novel, skip."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO.tell.__qualname__.__len__()
#
# io_extra38 covers StringIO method __qualname__.__len__() for:
#   read(13), write(14), getvalue(17), seek(13)
# io_extra41 covers StringIO.readline.__qualname__.__len__()==17.
# io_extra30 covers StringIO.tell.__qualname__.__eq__('StringIO.tell')
# via equality but NO prior io spec checks StringIO.tell.__qualname__.__len__().
#
# StringIO.tell -> 'StringIO.tell' -> len 13
#
# This is the sole remaining StringIO method qualname length not yet recorded.
# It equals StringIO.read and StringIO.seek (both also 13). Novel.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra45.StringIO_tell_qualname_len:
  description: "len(io.StringIO.tell.__qualname__) == 13 — 'StringIO.tell' has 13 characters; io_extra38 covers read/write/getvalue/seek; io_extra41 covers readline; io_extra30 covers tell via __qualname__.__eq__ (equality) but NOT __len__(); first check of StringIO.tell __qualname__ length; novel"
  category: method_identity
  kind: python_call_eq
  function: StringIO.tell.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# io.StringIO class identity: __name__ and __module__ equality
#
# StringIO is implemented in the C extension '_io' and re-exported by the
# io Python wrapper module. Its __name__ is 'StringIO' and its __module__
# is '_io' (the C extension), NOT 'io' (the Python wrapper).
#
#   StringIO.__name__   == 'StringIO'  (len 8)
#   StringIO.__module__ == '_io'       (len 3)
#
# Prior specs cover these via __eq__ in various namespaces (io_extra14/20/22/24/32)
# and via __len__ in io_extra34. This spec re-anchors both equality checks
# together in the io_extra45 namespace, paired with the novel tell qualname length.
# These serve as regression anchors. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra45.StringIO_name_eq:
  description: "io.StringIO.__name__ == 'StringIO' — class name attribute; StringIO is the C-extension class from _io re-exported by io; anchored in io_extra45 namespace alongside the novel tell qualname length"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra45.StringIO_module_eq:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the C extension '_io', not in the pure-Python 'io' wrapper; '_io' has 3 characters; anchored in io_extra45 namespace"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true
