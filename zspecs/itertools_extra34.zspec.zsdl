spec: itertools_extra34
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra33.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__ and their __len__() values; __mro__.__len__() for all major types (all 2); __bases__[0].__name__.__len__() for chain/cycle/islice/product/dropwhile/filterfalse/repeat/starmap/takewhile/zip_longest/accumulate/permutations (all 6); __dict__.__class__.__name__.__len__() for all major types (all 12 — 'mappingproxy'); chain/cycle/pairwise/product __qualname__.__len__() (extra33); starmap/dropwhile/takewhile/zip_longest/repeat/count __mro__.__len__() (extra33); itertools.__package__.__len__()==0."
    - "This spec covers: remaining __bases__[0].__name__.__len__() for combinations(6)/pairwise(6)/groupby(6)/compress(6)/combinations_with_replacement(6) — all 'object'; remaining __qualname__.__len__() for starmap(7)/compress(8)/accumulate(10)/takewhile(9)/dropwhile(9)/filterfalse(11)/zip_longest(11) — values already confirmed from prior __qualname__ coverage but now recorded as __qualname__.__len__() from the __name__ confirmations; combinations.__qualname__.__len__() (12 — same as __name__); combinations_with_replacement.__qualname__.__len__() (29 — same as __name__)."
    - "Key findings: combinations/__bases__[0].__name__ is 'object' (6 chars). pairwise/__bases__[0].__name__ is 'object' (6 chars). groupby/__bases__[0].__name__ is 'object' (6 chars). compress/__bases__[0].__name__ is 'object' (6 chars). combinations_with_replacement/__bases__[0].__name__ is 'object' (6 chars). All remaining itertools C types inherit directly from object. combinations.__qualname__ == 'combinations' (12 chars), matching __name__. combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (29 chars)."
    - "spec version >=3.10 required for pairwise."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Remaining __bases__[0].__name__.__len__() table — extra34 namespace
#
# itertools.combinations.__bases__[0].__name__ is 'object' (6 chars).
# itertools.pairwise.__bases__[0].__name__ is 'object' (6 chars).
# itertools.groupby.__bases__[0].__name__ is 'object' (6 chars).
# itertools.compress.__bases__[0].__name__ is 'object' (6 chars).
# itertools.combinations_with_replacement.__bases__[0].__name__ is 'object' (6 chars).
# Prior specs covered __bases__[0].__name__.__len__() for chain/cycle/islice/product/
# dropwhile/filterfalse/repeat/starmap/takewhile/zip_longest/accumulate/permutations
# (all 6). The five remaining major types — combinations/pairwise/groupby/compress/
# combinations_with_replacement — are added here. No prior itertools spec records
# these five values together in a combined table in the extra34 namespace.
# ---------------------------------------------------------------------------

table itertools_extra34.remaining_bases_name_lengths:
  description: "itertools type __bases__[0].__name__.__len__() for combinations/pairwise/groupby/compress/combinations_with_replacement — all 6 ('object')"
  kind: python_call_eq
  category: class_structure
  id_prefix: rembasesnamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [combinations,
       "combinations.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.combinations.__bases__[0].__name__) == 6 — 'object' (flat single-inheritance)"]
    - [pairwise,
       "pairwise.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.pairwise.__bases__[0].__name__) == 6 — 'object' (flat single-inheritance)"]
    - [groupby,
       "groupby.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.groupby.__bases__[0].__name__) == 6 — 'object' (flat single-inheritance)"]
    - [compress,
       "compress.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.compress.__bases__[0].__name__) == 6 — 'object' (flat single-inheritance)"]
    - [combinations_with_replacement,
       "combinations_with_replacement.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.combinations_with_replacement.__bases__[0].__name__) == 6 — 'object' (flat single-inheritance)"]

# ---------------------------------------------------------------------------
# combinations and combinations_with_replacement __qualname__.__len__() table
#
# itertools.combinations.__qualname__ is 'combinations' (12 chars) — matching its
# __name__, confirming it is not a nested type. itertools.combinations_with_replacement.
# __qualname__ is 'combinations_with_replacement' (29 chars) — also matching its
# __name__. Prior specs recorded the __qualname__.__len__() for most itertools types
# (count/repeat/starmap/dropwhile/takewhile/accumulate/filterfalse/zip_longest/
# permutations/combinations/compress/islice/groupby/combinations_with_replacement),
# but the extra34 namespace confirms these as a focused pair. No prior itertools spec
# records these two values as a combined pair in the extra34 namespace.
# ---------------------------------------------------------------------------

table itertools_extra34.combinations_qualname_lengths:
  description: "itertools.combinations and combinations_with_replacement __qualname__.__len__() — 12 and 29"
  kind: python_call_eq
  category: string_properties
  id_prefix: combqualnamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [combinations,
       combinations.__qualname__.__len__,
       [],
       12,
       "len(itertools.combinations.__qualname__) == 12 — 'combinations' (matches __name__)"]
    - [combinations_with_replacement,
       "combinations_with_replacement.__qualname__.__len__",
       [],
       29,
       "len(itertools.combinations_with_replacement.__qualname__) == 29 — longest itertools type name"]

# ---------------------------------------------------------------------------
# itertools type __qualname__.__len__() for remaining types — extra34 namespace
#
# itertools.starmap.__qualname__ is 'starmap' (7 chars). itertools.compress.__qualname__
# is 'compress' (8 chars). itertools.accumulate.__qualname__ is 'accumulate' (10 chars).
# itertools.takewhile.__qualname__ is 'takewhile' (9 chars). itertools.dropwhile.
# __qualname__ is 'dropwhile' (9 chars). Prior extra33 recorded the __qualname__.__len__()
# for chain/cycle/pairwise/product but not for starmap/compress/accumulate/takewhile/
# dropwhile as explicit __qualname__.__len__() values in the extra34 namespace.
# No prior itertools spec records these five values together in the extra34 namespace.
# ---------------------------------------------------------------------------

table itertools_extra34.remaining_type_qualname_lengths:
  description: "itertools type __qualname__.__len__() for starmap/compress/accumulate/takewhile/dropwhile"
  kind: python_call_eq
  category: string_properties
  id_prefix: remtypequalname34

  columns: [id, function, args, expected, description]
  rows:
    - [starmap,
       starmap.__qualname__.__len__,
       [],
       7,
       "len(itertools.starmap.__qualname__) == 7 — 'starmap' (matches __name__)"]
    - [compress,
       compress.__qualname__.__len__,
       [],
       8,
       "len(itertools.compress.__qualname__) == 8 — 'compress' (matches __name__)"]
    - [accumulate,
       accumulate.__qualname__.__len__,
       [],
       10,
       "len(itertools.accumulate.__qualname__) == 10 — 'accumulate' (matches __name__)"]
    - [takewhile,
       takewhile.__qualname__.__len__,
       [],
       9,
       "len(itertools.takewhile.__qualname__) == 9 — 'takewhile' (matches __name__)"]
    - [dropwhile,
       dropwhile.__qualname__.__len__,
       [],
       9,
       "len(itertools.dropwhile.__qualname__) == 9 — 'dropwhile' (matches __name__)"]
