spec: inspect_extra410
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.stack.__name__ == 'stack' and inspect.stack.__module__ == 'inspect' — stack is a plain Python function defined in Lib/inspect.py. Verified with Python 3.14.0."
    - "inspect.trace.__name__ == 'trace' and inspect.trace.__module__ == 'inspect' — trace is a plain Python function defined in Lib/inspect.py. Verified with Python 3.14.0."
    - "inspect.currentframe.__name__ == 'currentframe' and inspect.currentframe.__module__ == 'inspect' — currentframe is a plain Python function in Lib/inspect.py. Verified with Python 3.14.0."
    - "inspect.getouterframes.__name__ == 'getouterframes' and inspect.getouterframes.__module__ == 'inspect' — getouterframes is a plain Python function in Lib/inspect.py. Verified with Python 3.14.0."
    - "inspect.getinnerframes.__name__ == 'getinnerframes' and inspect.getinnerframes.__module__ == 'inspect' — getinnerframes is a plain Python function in Lib/inspect.py. Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect frame/stack function __name__ values
#
# inspect.stack, trace, currentframe, getouterframes, and getinnerframes
# are all plain Python functions defined in Lib/inspect.py. Their __name__
# attribute equals the bare function name string.
# ---------------------------------------------------------------------------

table inspect_extra410.frame_function_name:
  description: "inspect frame/stack function __name__ values — plain Python functions in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectffn410

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_eq,
       "stack.__name__.__eq__",
       ["stack"],
       true,
       "inspect.stack.__name__.__eq__('stack') == True — stack is a plain Python function in Lib/inspect.py; __name__ is 'stack'; str.__eq__('stack') returns True; new to extra410"]
    - [trace_name_eq,
       "trace.__name__.__eq__",
       ["trace"],
       true,
       "inspect.trace.__name__.__eq__('trace') == True — trace is a plain Python function in Lib/inspect.py; __name__ is 'trace'; str.__eq__('trace') returns True; new to extra410"]
    - [currentframe_name_eq,
       "currentframe.__name__.__eq__",
       ["currentframe"],
       true,
       "inspect.currentframe.__name__.__eq__('currentframe') == True — currentframe is a plain Python function in Lib/inspect.py; __name__ is 'currentframe'; str.__eq__('currentframe') returns True; new to extra410"]
    - [getouterframes_name_eq,
       "getouterframes.__name__.__eq__",
       ["getouterframes"],
       true,
       "inspect.getouterframes.__name__.__eq__('getouterframes') == True — getouterframes is a plain Python function in Lib/inspect.py; __name__ is 'getouterframes'; str.__eq__('getouterframes') returns True; new to extra410"]
    - [getinnerframes_name_eq,
       "getinnerframes.__name__.__eq__",
       ["getinnerframes"],
       true,
       "inspect.getinnerframes.__name__.__eq__('getinnerframes') == True — getinnerframes is a plain Python function in Lib/inspect.py; __name__ is 'getinnerframes'; str.__eq__('getinnerframes') returns True; new to extra410"]

# ---------------------------------------------------------------------------
# Table 2: inspect frame/stack function __module__ values
#
# All five frame/stack functions are defined in Lib/inspect.py, so their
# __module__ attribute is 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra410.frame_function_module:
  description: "inspect frame/stack function __module__ values — all defined in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectffm410

  columns: [id, function, args, expected, description]
  rows:
    - [stack_module_eq,
       "stack.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.stack.__module__.__eq__('inspect') == True — stack is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra410"]
    - [trace_module_eq,
       "trace.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.trace.__module__.__eq__('inspect') == True — trace is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra410"]
    - [currentframe_module_eq,
       "currentframe.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.currentframe.__module__.__eq__('inspect') == True — currentframe is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra410"]
    - [getouterframes_module_eq,
       "getouterframes.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getouterframes.__module__.__eq__('inspect') == True — getouterframes is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra410"]
    - [getinnerframes_module_eq,
       "getinnerframes.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getinnerframes.__module__.__eq__('inspect') == True — getinnerframes is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra410"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra410
# ---------------------------------------------------------------------------

invariant inspect_extra410.stack_name:
  description: "inspect.stack.__name__ == 'stack' — plain Python function in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra410.stack_module:
  description: "inspect.stack.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra410.trace_name:
  description: "inspect.trace.__name__ == 'trace' — plain Python function in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: trace.__name__.__eq__
  args: ["trace"]
  expected: true

invariant inspect_extra410.trace_module:
  description: "inspect.trace.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: trace.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra410.currentframe_name:
  description: "inspect.currentframe.__name__ == 'currentframe' — plain Python function in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra410.currentframe_module:
  description: "inspect.currentframe.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra410.getouterframes_name:
  description: "inspect.getouterframes.__name__ == 'getouterframes' — plain Python function in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: getouterframes.__name__.__eq__
  args: ["getouterframes"]
  expected: true

invariant inspect_extra410.getouterframes_module:
  description: "inspect.getouterframes.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: getouterframes.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra410.getinnerframes_name:
  description: "inspect.getinnerframes.__name__ == 'getinnerframes' — plain Python function in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: getinnerframes.__name__.__eq__
  args: ["getinnerframes"]
  expected: true

invariant inspect_extra410.getinnerframes_module:
  description: "inspect.getinnerframes.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra410"
  kind: python_call_eq
  function: getinnerframes.__module__.__eq__
  args: ["inspect"]
  expected: true
