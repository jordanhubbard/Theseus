spec: hashlib_extra24
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra23.zspec.zsdl — covers sha384/sha224 block_size/digest_size; new('sha224'/'sha384') class name; algorithms_guaranteed sha224/sha384/sha3_256/sha3_512 membership."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__; algorithms_available/guaranteed class name; algorithms_guaranteed membership."
    - "hashlib_extra17.zspec.zsdl — covers sha256 block_size/name via direct constructor; new.__qualname__ == '__hash_new'; algorithms_guaranteed contains md5/sha256."
    - "hashlib_extra15.zspec.zsdl — covers new('sha3_512'/'blake2b'/'shake_128') block_size/name; pbkdf2_hmac __name__/__module__."
  notes:
    - "This spec extends hashlib through hashlib_extra23; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__ string lengths for hashlib constructors (md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac). hashlib_extra17 covers new.__qualname__.__eq__('__hash_new') but not its length. No prior spec checks __qualname__.__len__() for any of these constructors."
    - "hashlib.md5.__qualname__ == 'openssl_md5': len == 11. OpenSSL-backed constructor on CPython 3.12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1': len == 12. OpenSSL-backed constructor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256': len == 14. OpenSSL-backed constructor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__ == 'openssl_sha512': len == 14. OpenSSL-backed constructor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224': len == 14. OpenSSL-backed constructor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384': len == 14. OpenSSL-backed constructor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new': len == 10. CPython internal wrapper alias. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac': len == 11. C built-in. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib constructor __qualname__.__eq__ — md5, sha1, sha256, sha512
#
# hashlib_extra20 verifies __name__ for these constructors (e.g. 'openssl_md5').
# On CPython 3.12, __qualname__ equals __name__ for these C-level functions.
# No prior spec verifies __qualname__.__eq__ as a standalone __eq__ call for
# md5/sha1/sha256/sha512 (extra17 only covers new.__qualname__).
# ---------------------------------------------------------------------------

invariant hashlib_extra24.md5.qualname:
  description: "hashlib.md5.__qualname__ == 'openssl_md5' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra24.sha1.qualname:
  description: "hashlib.sha1.__qualname__ == 'openssl_sha1' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: sha1.__qualname__.__eq__
  args: ["openssl_sha1"]
  expected: true

invariant hashlib_extra24.sha256.qualname:
  description: "hashlib.sha256.__qualname__ == 'openssl_sha256' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra24.sha512.qualname:
  description: "hashlib.sha512.__qualname__ == 'openssl_sha512' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: sha512.__qualname__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlib_extra24.sha224.qualname:
  description: "hashlib.sha224.__qualname__ == 'openssl_sha224' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: sha224.__qualname__.__eq__
  args: ["openssl_sha224"]
  expected: true

invariant hashlib_extra24.sha384.qualname:
  description: "hashlib.sha384.__qualname__ == 'openssl_sha384' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: sha384.__qualname__.__eq__
  args: ["openssl_sha384"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__.__len__() table for hashlib constructors
#
# No prior hashlib spec verifies __qualname__.__len__() for any constructor.
# The lengths are: md5=11, sha1=12, sha256=14, sha512=14, sha224=14, sha384=14,
# new=10 ('__hash_new'), pbkdf2_hmac=11.
# ---------------------------------------------------------------------------

table hashlib_extra24.qualname_lengths:
  description: "Length of __qualname__ strings for hashlib constructor functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hqlen24

  columns: [id, function, args, expected]
  rows:
    - [md5,         md5.__qualname__.__len__,         [], 11]
    - [sha1,        sha1.__qualname__.__len__,        [], 12]
    - [sha256,      sha256.__qualname__.__len__,      [], 14]
    - [sha512,      sha512.__qualname__.__len__,      [], 14]
    - [sha224,      sha224.__qualname__.__len__,      [], 14]
    - [sha384,      sha384.__qualname__.__len__,      [], 14]
    - [new,         new.__qualname__.__len__,         [], 10]
    - [pbkdf2_hmac, pbkdf2_hmac.__qualname__.__len__, [], 11]
