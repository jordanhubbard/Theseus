spec: struct_extra225
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__name__ == 'Struct' — class name is 6 characters."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the C extension _struct."
    - "struct.Struct.__qualname__ == 'Struct' — top-level class; qualname equals name."
    - "struct.error.__name__ == 'error' — exception class name is 5 characters."
    - "struct.error.__module__ == 'struct' — error is defined in the struct module namespace."
    - "struct.error.__bases__[0].__name__ == 'Exception' — error directly subclasses Exception."
    - "struct.Struct('!H').size == 2 — network-order unsigned short; 2 bytes."
    - "struct.Struct('!I').size == 4 — network-order unsigned int; 4 bytes."
    - "struct.Struct('!Q').size == 8 — network-order unsigned long long; 8 bytes."
    - "struct.Struct('4B').size == 4 — four unsigned chars; 4 * 1 = 4 bytes."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct class identity contracts
#
# struct.Struct.__name__    == 'Struct'
# struct.Struct.__module__  == '_struct'
# struct.Struct.__qualname__ == 'Struct'
# struct.Struct.__name__.__len__() == 6
#
# struct.Struct is the compiled struct type implemented in the C extension
# _struct.so. The class name is 'Struct' (6 characters). __module__ is
# '_struct' reflecting the C implementation module. qualname equals name
# since it is a top-level class.
# ---------------------------------------------------------------------------

table struct_extra225.struct_class_identity:
  description: "Struct.__name__=='Struct'; Struct.__module__=='_struct'; Struct.__qualname__=='Struct'; Struct.__name__.__len__()==6; class identity contracts; new to extra225"
  kind: python_call_eq
  category: identity
  id_prefix: struct225

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_name_eq_Struct,
       "Struct.__name__.__eq__",
       ["Struct"],
       true,
       "struct.Struct.__name__.__eq__('Struct') == True — the Struct class name is the 6-character string 'Struct'; Struct is the compiled struct type from the _struct C extension; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [Struct_module_eq_struct,
       "Struct.__module__.__eq__",
       ["_struct"],
       true,
       "struct.Struct.__module__.__eq__('_struct') == True — Struct is implemented in the _struct C extension; __module__ is '_struct'; exposed via the struct module; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [Struct_qualname_eq_Struct,
       "Struct.__qualname__.__eq__",
       ["Struct"],
       true,
       "struct.Struct.__qualname__.__eq__('Struct') == True — Struct is a top-level class so __qualname__ equals __name__; no outer class scope; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [Struct_name_len_6,
       "Struct.__name__.__len__",
       [],
       6,
       "struct.Struct.__name__.__len__() == 6 — the string 'Struct' has 6 characters; portable length anchor for class name; new anchor in extra225 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.error exception class identity contracts
#
# struct.error.__name__    == 'error'
# struct.error.__module__  == 'struct'
# struct.error.__bases__[0].__name__ == 'Exception'
#
# struct.error is the exception class raised by struct functions on errors.
# It is a direct subclass of Exception. __module__ is 'struct' (not '_struct').
# The class name is lowercase 'error' (5 characters).
# ---------------------------------------------------------------------------

table struct_extra225.struct_error_class_identity:
  description: "error.__name__=='error'; error.__module__=='struct'; error.__bases__[0].__name__=='Exception'; exception class identity; new to extra225"
  kind: python_call_eq
  category: identity
  id_prefix: struct225a

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq_error,
       "error.__name__.__eq__",
       ["error"],
       true,
       "struct.error.__name__.__eq__('error') == True — the struct.error exception class name is the lowercase 5-character string 'error'; raised on format string errors and pack/unpack failures; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [error_module_eq_struct,
       "error.__module__.__eq__",
       ["struct"],
       true,
       "struct.error.__module__.__eq__('struct') == True — struct.error is registered in the 'struct' module namespace (not '_struct' C extension); __module__ is 'struct'; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [error_base_is_Exception,
       "error.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error directly subclasses Exception; no intermediate base class; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [error_name_len_5,
       "error.__name__.__len__",
       [],
       5,
       "struct.error.__name__.__len__() == 5 — the string 'error' has 5 characters; lowercase exception name; new anchor in extra225 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct instance .size contracts
#
# struct.Struct('!H').size == 2   (network-order unsigned short)
# struct.Struct('!I').size == 4   (network-order unsigned int)
# struct.Struct('!Q').size == 8   (network-order unsigned long long)
# struct.Struct('4B').size == 4   (four unsigned chars)
#
# Struct.size gives the total bytes required by the compiled format string.
# Network byte order prefix '!' does not change the byte count. The repeat
# count '4B' gives 4 * 1 = 4 bytes.
# ---------------------------------------------------------------------------

table struct_extra225.struct_instance_size:
  description: "Struct('!H').size==2; Struct('!I').size==4; Struct('!Q').size==8; Struct('4B').size==4; compiled format sizes; new to extra225"
  kind: python_call_eq
  category: identity
  id_prefix: struct225b

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_netH_size_2,
       "Struct('!H').size.__eq__",
       [2],
       true,
       "struct.Struct('!H').size.__eq__(2) == True — network-order unsigned short; '!H' compiles to 2 bytes; '!' is network/big-endian prefix; 'H' is unsigned short; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [Struct_netI_size_4,
       "Struct('!I').size.__eq__",
       [4],
       true,
       "struct.Struct('!I').size.__eq__(4) == True — network-order unsigned int; '!I' compiles to 4 bytes; common for protocol fields; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [Struct_netQ_size_8,
       "Struct('!Q').size.__eq__",
       [8],
       true,
       "struct.Struct('!Q').size.__eq__(8) == True — network-order unsigned long long; '!Q' compiles to 8 bytes; 64-bit protocol field; new anchor in extra225 namespace; verified Python 3.14.3"]
    - [Struct_4B_size_4,
       "Struct('4B').size.__eq__",
       [4],
       true,
       "struct.Struct('4B').size.__eq__(4) == True — four unsigned chars; repeat count 4 * 1 byte = 4 bytes; equivalent to 'BBBB'; Struct.size equals calcsize for the same format; new anchor in extra225 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra225.Struct_name_eq_Struct:
  description: "struct.Struct.__name__.__eq__('Struct') == True — Struct is the compiled struct type from the _struct C extension; it provides an efficient way to pack and unpack binary data by compiling the format string once; the class name is 'Struct' (6 characters, capital S); __module__ is '_struct' reflecting the C implementation; prior struct specs anchor calcsize and pack/unpack but extra225 is the first namespace to anchor Struct.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Struct.__name__.__eq__"
  args: ["Struct"]
  expected: true

invariant struct_extra225.error_module_eq_struct:
  description: "struct.error.__module__.__eq__('struct') == True — struct.error is the exception raised by struct pack/unpack operations; although Struct itself has __module__=='_struct' (C extension), struct.error has __module__=='struct'; this distinction is notable: the error class is registered in the Python-level 'struct' namespace; struct.error directly subclasses Exception; extra225 is the first namespace to anchor error.__module__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "error.__module__.__eq__"
  args: ["struct"]
  expected: true

invariant struct_extra225.Struct_netI_size_4:
  description: "struct.Struct('!I').size.__eq__(4) == True — Struct('!I') compiles the network-byte-order unsigned int format; '!' selects network (big-endian) byte order; 'I' is unsigned int (4 bytes); Struct.size gives the total packed size in bytes; the compiled Struct object avoids re-parsing the format string on each call; calcsize('!I') == 4 matches Struct('!I').size == 4; extra225 is the first namespace to anchor Struct().size as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Struct('!I').size.__eq__"
  args: [4]
  expected: true
