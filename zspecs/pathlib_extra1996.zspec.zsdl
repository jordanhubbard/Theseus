# ---------------------------------------------------------------------------
# Cross-protocol summary — all pathlib types lack all five numeric protocols
# Confirms that filesystem path types implement none of the numeric conversion
# or arithmetic protocols defined by the Python data model.
# ---------------------------------------------------------------------------

table pathlib_extra1996.numeric_protocol_summary:
  description: "pathlib.Path: all five numeric conversion protocol methods absent from own __dict__"
  kind: python_call_eq
