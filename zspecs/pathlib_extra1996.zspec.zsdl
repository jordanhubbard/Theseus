spec: pathlib_extra1996
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra1981.zspec.zsdl — covers __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence"
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "pathlib classes represent filesystem paths, not numeric values."
    - "None of pathlib.Path, pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath define numeric conversion protocols."
    - "All five methods (__index__, __complex__, __float__, __round__, __abs__) are absent from every pathlib class own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __index__ dict-presence — pathlib path classes
# __index__ signals the integer-index protocol (PEP 357).
# Path objects represent filesystem paths; none define __index__.
# ---------------------------------------------------------------------------

table pathlib_extra1996.index_protocol:
  description: "pathlib class __dict__.__contains__('__index__') — all False (paths are not integer-like)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1996

  columns: [id, function, args, expected]
  rows:
    - ["pl1996001", "pathlib.PurePath.__dict__.__contains__",          ["__index__"], false]
    - ["pl1996002", "pathlib.PurePosixPath.__dict__.__contains__",     ["__index__"], false]
    - ["pl1996003", "pathlib.PureWindowsPath.__dict__.__contains__",   ["__index__"], false]
    - ["pl1996004", "pathlib.Path.__dict__.__contains__",              ["__index__"], false]

# ---------------------------------------------------------------------------
# __complex__ dict-presence — pathlib path classes
# __complex__ is the numeric conversion protocol for complex numbers.
# Path objects are not numeric; none define __complex__ in their own __dict__.
# ---------------------------------------------------------------------------

table pathlib_extra1996.complex_protocol:
  description: "pathlib class __dict__.__contains__('__complex__') — all False (paths are not numeric)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1996

  columns: [id, function, args, expected]
  rows:
    - ["pl1996005", "pathlib.PurePath.__dict__.__contains__",          ["__complex__"], false]
    - ["pl1996006", "pathlib.PurePosixPath.__dict__.__contains__",     ["__complex__"], false]
    - ["pl1996007", "pathlib.PureWindowsPath.__dict__.__contains__",   ["__complex__"], false]
    - ["pl1996008", "pathlib.Path.__dict__.__contains__",              ["__complex__"], false]

