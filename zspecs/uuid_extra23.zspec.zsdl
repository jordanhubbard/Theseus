spec: uuid_extra23
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra22.zspec.zsdl — covers UUID.__mro__.__len__()==2; UUID.__str__/__repr__/__hash__/__eq__ __qualname__.__len__(); UUID.__slots__.__class__.__name__/.__len__()==3; UUID.hex.__class__.__name__=='property'; UUID.__bases__[0].__name__=='object'."
  notes:
    - "This spec extends uuid through uuid_extra22; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: uuid4() type, UUID fields, UUID.__name__/__module__/__qualname__, uuid.__name__/__package__, uuid1/3/4/5 __name__/__module__, NAMESPACE_DNS/URL/OID/X500 class names, UUID.__bases__[0].__name__, UUID.__init__.__name__, UUID.hex length/urn prefix, UUID integer attributes, uuid1/3/4/5 __qualname__ (extra5), uuid1/3/4/5 __module__ (extra18), UUID/__name__/__qualname__/__module__ lengths (extra19), uuid1/3/4/5 __qualname__ standalone (extra20), UUID.__init__.__qualname__ (extra20), uuid1/3/4/5/UUID __module__.__len__() (extra20), NAMESPACE_DNS __class__.__module__ (extra20), UUID.__qualname__.__len__() (extra20), uuid1/3/4/5 __name__.__len__() (extra21), UUID.__init__.__module__/__qualname__.__len__() (extra21), NAMESPACE_URL/OID/X500 __class__.__module__.__len__() (extra21)."
    - "This spec covers: uuid.UUID.__dict__.__class__.__name__.__len__()==12 (NOVEL); uuid.UUID.hex.fget.__qualname__.__len__()==8 (NOVEL — UUID.hex.fget qualname length); uuid.UUID.bytes.fget.__qualname__.__len__()==10 (NOVEL); uuid.UUID.bytes_le.fget.__qualname__.__len__()==13 (NOVEL); uuid.NAMESPACE_DNS.__class__.__name__.__len__()==4 (NOVEL — class name length for NAMESPACE_DNS); uuid.NAMESPACE_URL.__class__.__name__.__len__()==4 (NOVEL); uuid.RFC_4122.__class__.__name__.__len__()==3 (NOVEL — RFC_4122 is a str; 'str' has 3 chars); uuid.RFC_4122.__len__()==21 (NOVEL — 'specified in RFC 4122' is 21 chars); uuid.uuid1/3/4/5 __qualname__.__len__()==5 (NOVEL — each is the bare function name of 5 chars; prior specs check __qualname__ equality, not length)."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Class __dict__ is always a mappingproxy in CPython. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex is a property descriptor. hex.fget.__qualname__ == 'UUID.hex' (len 8). No prior spec checks the fget qualname length. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' (len 10). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__qualname__ == 'UUID.bytes_le' (len 13). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (len 4). Prior specs verify __class__.__name__.__eq__('UUID') but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' (len 4). Same pattern. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122 == 'specified in RFC 4122' — it is a plain str constant; __class__.__name__ == 'str' (len 3); str value has len 21. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.uuid1/3/4/5.__qualname__.__len__() == 5 each — qualname is the bare function name (uuid1 etc., 5 chars). Prior specs verify __qualname__.__eq__; this checks __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__len__()
#
# UUID.__dict__ is always a mappingproxy in CPython. No prior uuid spec checks
# UUID.__dict__.__class__.__name__ or its length.
# len('mappingproxy') == 12. Novel standalone invariant.
# ---------------------------------------------------------------------------

invariant uuid_extra23.UUID.dict_classname_len:
  description: "uuid.UUID.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters, novel invariant"
  category: class_structure
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# uuid.RFC_4122 — class name length and string length
#
# uuid.RFC_4122 is a str constant equal to 'specified in RFC 4122'. No prior
# uuid spec checks RFC_4122.__class__.__name__.__len__() or RFC_4122.__len__().
# __class__.__name__ == 'str' (len 3); the string itself has len 21. Novel.
# ---------------------------------------------------------------------------

invariant uuid_extra23.RFC_4122.class_name_len:
  description: "uuid.RFC_4122.__class__.__name__.__len__() == 3 — RFC_4122 is a str; 'str' has 3 characters"
  category: string_length
  kind: python_call_eq
  function: RFC_4122.__class__.__name__.__len__
  args: []
  expected: 3

invariant uuid_extra23.RFC_4122.value_len:
  description: "uuid.RFC_4122.__len__() == 21 — 'specified in RFC 4122' is 21 characters"
  category: string_length
  kind: python_call_eq
  function: RFC_4122.__len__
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# Table: uuid1/3/4/5 __qualname__.__len__()
#
# Prior uuid specs (extra20) verify uuid1/3/4/5.__qualname__.__eq__ equality.
# This table provides the parallel __qualname__.__len__() check. Each function
# has a qualname equal to its bare name ('uuid1' etc., 5 chars). Novel.
# ---------------------------------------------------------------------------

table uuid_extra23.uuid_func_qualname_lengths:
  description: "uuid.uuid1/3/4/5 __qualname__.__len__() == 5 each — bare function name qualnames, novel length check"
  kind: python_call_eq
  category: function_identity
  id_prefix: ufqln23

  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__qualname__.__len__, [], 5]
    - [uuid3, uuid3.__qualname__.__len__, [], 5]
    - [uuid4, uuid4.__qualname__.__len__, [], 5]
    - [uuid5, uuid5.__qualname__.__len__, [], 5]

# ---------------------------------------------------------------------------
# Table: UUID property fget __qualname__.__len__()
#
# UUID exposes several attributes as property descriptors. Accessing them on
# the class yields property objects; fget.__qualname__ follows the pattern
# 'UUID.<name>'. No prior uuid spec checks fget.__qualname__.__len__() for
# any UUID property. This table covers hex (8), bytes (10), bytes_le (13).
# ---------------------------------------------------------------------------

table uuid_extra23.UUID_property_fget_qualname_lengths:
  description: "uuid.UUID property fget.__qualname__.__len__() — hex (8), bytes (10), bytes_le (13), novel invariants"
  kind: python_call_eq
  category: method_identity
  id_prefix: upfqln23

  columns: [id, function, args, expected]
  rows:
    - [hex,      UUID.hex.fget.__qualname__.__len__,      [], 8]
    - [bytes,    UUID.bytes.fget.__qualname__.__len__,    [], 10]
    - [bytes_le, UUID.bytes_le.fget.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# Table: NAMESPACE_DNS/URL __class__.__name__.__len__() and UUID.__dict__ class
#
# Prior specs verify NAMESPACE_DNS/URL __class__.__name__.__eq__('UUID') but not
# the __len__(). 'UUID' has 4 characters. uuid.UUID.__dict__.__class__.__name__
# is 'mappingproxy' (12 chars) — also novel. Grouped for compact coverage.
# ---------------------------------------------------------------------------

table uuid_extra23.namespace_class_name_lengths:
  description: "NAMESPACE_DNS/URL __class__.__name__.__len__()==4 and UUID.__dict__ mappingproxy len — novel invariants"
  kind: python_call_eq
  category: string_length
  id_prefix: nscnl23

  columns: [id, function, args, expected]
  rows:
    - [dns_classname_len,  "NAMESPACE_DNS.__class__.__name__.__len__",   [], 4]
    - [url_classname_len,  "NAMESPACE_URL.__class__.__name__.__len__",   [], 4]
    - [dict_proxy_len,     UUID.__dict__.__class__.__name__.__len__,     [], 12]
    - [rfc4122_class_len,  RFC_4122.__class__.__name__.__len__,          [], 3]
