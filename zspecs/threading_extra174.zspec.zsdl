spec: threading_extra174
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.__name__ 'threading'; threading.__package__ '' (empty string); threading.__spec__.__class__.__name__ 'ModuleSpec'; threading.__loader__.__class__.__name__ 'SourceFileLoader'; threading.Thread.__mro__.__len__() 2 (Thread > object); threading.Lock.__mro__.__len__() 2 (_thread.lock > object); threading.Event.__mro__.__len__() 2 (Event > object) (Wave 302)."
    - "threading.__name__ == 'threading' — the threading module's __name__ attribute is the string 'threading'. Verified with Python 3.14.3."
    - "threading.__package__ == '' — threading is a top-level Python module in Lib/threading.py; its __package__ is the empty string ''. Verified with Python 3.14.3."
    - "threading.__spec__.__class__.__name__ == 'ModuleSpec' — threading.__spec__ is an importlib.machinery.ModuleSpec object; its __class__.__name__ is 'ModuleSpec'. Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is a pure Python module loaded from Lib/threading.py; its loader is an instance of importlib._bootstrap_external.SourceFileLoader. Verified with Python 3.14.3."
    - "threading.Thread.__mro__.__len__() == 2 — Thread is a Python class defined in Lib/threading.py that inherits directly from object; its __mro__ is (Thread, object). Verified with Python 3.14.3."
    - "threading.Lock.__mro__.__len__() == 2 — threading.Lock IS the C extension type _thread.lock from Modules/_threadmodule.c; _thread.lock inherits directly from object; its __mro__ is (lock, object). Verified with Python 3.14.3."
    - "threading.Event.__mro__.__len__() == 2 — threading.Event is a Python class defined in Lib/threading.py that inherits directly from object; its __mro__ is (Event, object). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module __name__ and __package__ identity
#
# Wave 302 theme: threading.__name__ is 'threading' (length 9) and
# threading.__package__ is '' (empty string, NOT 'threading').
#
# threading.__name__ == 'threading'
# threading.__name__.__len__() == 9
# threading.__package__ == ''
# threading.__package__ != 'threading'
#
# threading is a top-level Python module defined in Lib/threading.py. Its
# __name__ is 'threading'. As a single source file at the top level, its
# __package__ is '' (empty string). New to extra174.
# ---------------------------------------------------------------------------

table threading_extra174.module_name_and_package:
  description: "threading.__name__ 'threading', len 9; __package__ '', not 'threading'; wave 302; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmnp174

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_threading,
       "__name__.__eq__",
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — the threading module's __name__ attribute is the string 'threading'; str.__eq__('threading') returns True; new to extra174"]
    - [mod_name_len_9,
       "__name__.__len__",
       [],
       9,
       "threading.__name__.__len__() == 9 — the string 'threading' has exactly 9 characters: t-h-r-e-a-d-i-n-g; str.__len__() returns 9; new to extra174"]
    - [mod_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "threading.__package__.__eq__('') == True — threading is a top-level Python module in Lib/threading.py; its __package__ attribute is the empty string '' (a module-level file, not a package directory); str.__eq__('') returns True; new to extra174"]
    - [mod_package_not_threading,
       "__package__.__eq__",
       ["threading"],
       false,
       "threading.__package__.__eq__('threading') == False — threading.__package__ is the empty string '', NOT 'threading'; only if threading were a package directory with __init__.py would __package__ be 'threading'; str.__eq__('threading') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: threading.__spec__ and __loader__ class names
#
# Wave 302 theme: threading.__spec__.__class__.__name__ == 'ModuleSpec';
# threading.__loader__.__class__.__name__ == 'SourceFileLoader'.
#
# threading.__spec__.__class__.__name__ == 'ModuleSpec'
# threading.__spec__.__class__.__name__ != 'BuiltinImporter'
# threading.__loader__.__class__.__name__ == 'SourceFileLoader'
# threading.__loader__.__class__.__name__ != 'type'
#
# threading is a Python source file (Lib/threading.py), so it is loaded by
# importlib._bootstrap_external.SourceFileLoader (not BuiltinImporter, which
# handles C extension built-ins). Its __spec__ is a ModuleSpec object. New to
# extra174.
# ---------------------------------------------------------------------------

table threading_extra174.spec_and_loader_class:
  description: "threading.__spec__ class 'ModuleSpec'; __loader__ class 'SourceFileLoader'; not BuiltinImporter; wave 302; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: threadingslc174

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — threading.__spec__ is an importlib.machinery.ModuleSpec object describing the threading module; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra174"]
    - [spec_class_not_builtin_importer,
       "__spec__.__class__.__name__.__eq__",
       ["BuiltinImporter"],
       false,
       "threading.__spec__.__class__.__name__.__eq__('BuiltinImporter') == False — threading is a Python source module (not a C built-in), so its __spec__.__class__.__name__ is 'ModuleSpec' (not 'BuiltinImporter'); str.__eq__('BuiltinImporter') returns False; new to extra174"]
    - [loader_class_source_file_loader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading is a pure Python module loaded from Lib/threading.py; its loader is an instance of importlib._bootstrap_external.SourceFileLoader; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra174"]
    - [loader_class_not_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       false,
       "threading.__loader__.__class__.__name__.__eq__('type') == False — threading.__loader__ is a SourceFileLoader instance (not a class object like itertools.__loader__ which is the BuiltinImporter class itself); its __class__.__name__ is 'SourceFileLoader', not 'type'; str.__eq__('type') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.__mro__.__len__() == 2 (Thread > object)
#
# Wave 302 theme: threading.Thread is a Python class that inherits directly
# from object; its __mro__ has exactly 2 entries.
#
# threading.Thread.__mro__.__len__() == 2
# threading.Thread.__mro__[0].__name__ == 'Thread'
# threading.Thread.__mro__[1].__name__ == 'object'
# threading.Thread.__mro__.__len__() != 3
#
# threading.Thread is defined in Lib/threading.py and inherits directly from
# object. It is not a C extension type; it is a pure Python class. Despite
# having many methods and property descriptors (28 entries in __dict__), its
# MRO depth is exactly 2. New to extra174.
# ---------------------------------------------------------------------------

table threading_extra174.thread_mro_len:
  description: "threading.Thread.__mro__: len 2, mro[0] 'Thread', mro[1] 'object'; not len 3; wave 302; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthrmro174

  columns: [id, function, args, expected, description]
  rows:
    - [thread_mro_len_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — threading.Thread is a Python class defined in Lib/threading.py representing a thread of control; it inherits directly from object with no intermediate base classes; its __mro__ is (Thread, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["thread_mro_0_thread",
       "Thread.__mro__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__mro__[0].__name__.__eq__('Thread') == True — the first entry in Thread.__mro__ is the Thread class itself; its __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra174"]
    - ["thread_mro_1_object",
       "Thread.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__mro__[1].__name__.__eq__('object') == True — the second entry in Thread.__mro__ is the base class object; its __name__ is 'object'; this confirms Thread inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra174"]
    - [thread_mro_not_3,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 (not 3) — Thread inherits only from object; despite having 28 entries in __dict__ with lifecycle methods and property descriptors, its MRO has exactly 2 entries; tuple.__len__() returns 2; new to extra174"]

# ---------------------------------------------------------------------------
# Table 4: threading.Lock.__mro__.__len__() == 2 (_thread.lock > object)
#
# Wave 302 theme: threading.Lock IS the C extension type _thread.lock; the
# _thread.lock type inherits directly from object; its __mro__ has 2 entries.
#
# threading.Lock.__mro__.__len__() == 2
# threading.Lock.__mro__[0].__name__ == 'lock'
# threading.Lock.__mro__[1].__name__ == 'object'
# threading.Lock.__name__ == 'lock'
#
# threading.Lock is actually the C extension type _thread.lock imported
# directly from Modules/_threadmodule.c. Extra173 established that
# Lock.__class__.__name__ is 'type' and Lock.__name__ is 'lock' (lowercase).
# This spec adds MRO depth: _thread.lock also inherits directly from object.
# New to extra174.
# ---------------------------------------------------------------------------

table threading_extra174.lock_mro_len:
  description: "threading.Lock.__mro__: len 2, mro[0] 'lock', mro[1] 'object'; wave 302; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglockmro174

  columns: [id, function, args, expected, description]
  rows:
    - [lock_mro_len_2,
       "Lock.__mro__.__len__",
       [],
       2,
       "threading.Lock.__mro__.__len__() == 2 — threading.Lock is the C extension type _thread.lock from Modules/_threadmodule.c, re-exported in the threading module; _thread.lock inherits directly from object; its __mro__ is (lock, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["lock_mro_0_lock",
       "Lock.__mro__[0].__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__mro__[0].__name__.__eq__('lock') == True — the first entry in Lock.__mro__ is the _thread.lock C extension type itself; its __name__ is 'lock' (lowercase, as established in extra173); str.__eq__('lock') returns True; new to extra174"]
    - ["lock_mro_1_object",
       "Lock.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "threading.Lock.__mro__[1].__name__.__eq__('object') == True — the second entry in Lock.__mro__ is the base class object; its __name__ is 'object'; _thread.lock inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra174"]
    - [lock_mro_not_3,
       "Lock.__mro__.__len__",
       [],
       2,
       "threading.Lock.__mro__.__len__() == 2 (not 3) — _thread.lock inherits only from object; its MRO has exactly 2 entries; tuple.__len__() returns 2; new to extra174"]

# ---------------------------------------------------------------------------
# Table 5: threading.Event.__mro__.__len__() == 2; uniformity cross-checks
#
# Wave 302 theme: threading.Event is a Python class that inherits directly
# from object; plus cross-checks confirming Thread, Lock, and Event all share
# MRO length 2.
#
# threading.Event.__mro__.__len__() == 2
# threading.Event.__mro__[0].__name__ == 'Event'
# threading.Thread.__mro__.__len__() == 2  (cross-check)
# threading.Lock.__mro__.__len__() == 2  (cross-check)
#
# threading.Event is a synchronization primitive defined in Lib/threading.py.
# One thread signals an event and other threads wait for it. Event inherits
# directly from object. Cross-checks confirm Thread, Lock, and Event all have
# MRO depth 2. New to extra174.
# ---------------------------------------------------------------------------

table threading_extra174.event_mro_and_cross_checks:
  description: "threading.Event: __mro__.__len__() 2, mro[0] 'Event'; Thread and Lock mro len 2 cross-checks; wave 302; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: threadingevmro174

  columns: [id, function, args, expected, description]
  rows:
    - [event_mro_len_2,
       "Event.__mro__.__len__",
       [],
       2,
       "threading.Event.__mro__.__len__() == 2 — threading.Event is a Python class defined in Lib/threading.py representing a synchronization primitive where one thread signals an event and other threads wait for it; it inherits directly from object; its __mro__ is (Event, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["event_mro_0_event",
       "Event.__mro__[0].__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__mro__[0].__name__.__eq__('Event') == True — the first entry in Event.__mro__ is the Event class itself; its __name__ is 'Event'; str.__eq__('Event') returns True; new to extra174"]
    - [thread_mro_len_2_xcheck,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — cross-check confirming MRO uniformity: Thread is a Python class with direct object inheritance, MRO length 2; tuple.__len__() returns 2; new to extra174"]
    - [lock_mro_len_2_xcheck,
       "Lock.__mro__.__len__",
       [],
       2,
       "threading.Lock.__mro__.__len__() == 2 — cross-check confirming MRO uniformity: Lock (_thread.lock C extension type) has direct object inheritance, MRO length 2; tuple.__len__() returns 2; new to extra174"]

