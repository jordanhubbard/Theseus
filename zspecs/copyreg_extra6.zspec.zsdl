spec: copyreg_extra6
version: ">=3.9"
backend: python_module(copyreg)

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copyreg.html — Python copyreg module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copyreg.py"
  notes:
    - "This spec extends copyreg.zspec.zsdl through copyreg_extra5.zspec.zsdl."
    - "copyreg_extra3 covers __qualname__ for pickle/constructor/add_extension/remove_extension/clear_extension_cache/__newobj__/__newobj_ex__ via table."
    - "copyreg_extra5 covers _reconstructor.__qualname__ and pickle_complex.__qualname__ as standalone invariants."
    - "copyreg covers: dispatch_table type check; pickle/__name__/__module__; constructor/add_extension/remove_extension/clear_extension_cache __name__."
    - "copyreg_extra covers: dispatch_table.__class__.__name__ == 'dict' standalone."
    - "Focus: copyreg module-level identity (__name__, __package__) and copyreg_extra6-namespace qualname standalones for __newobj__/__newobj_ex__/__name__/__qualname__ cross-check."
    - "copyreg.__name__ == 'copyreg' — the module self-identifies with its own name."
    - "copyreg.__package__ == '' — copyreg is a pure-Python stdlib module, not a package."
    - "copyreg.__newobj__.__qualname__ == '__newobj__' — re-anchor in extra6 namespace; copyreg_extra3 covers this via table."
    - "copyreg.__newobj_ex__.__qualname__ == '__newobj_ex__' — re-anchor in extra6 namespace; copyreg_extra3 covers this via table."
    - "copyreg._reconstructor.__qualname__ == '_reconstructor' — copyreg_extra5 covers this; re-anchor in extra6 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copyreg module identity — __name__ and __package__
#
# No prior copyreg spec records the module-level __name__ or __package__
# attributes as standalone module-identity invariants. copyreg is a
# pure-Python stdlib module (not a package), so its __package__ is the
# empty string.
# ---------------------------------------------------------------------------

invariant copyreg_extra6.module.name:
  description: "copyreg module __name__ == 'copyreg' — module self-identifies by its own name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["copyreg"]
  expected: true

invariant copyreg_extra6.module.package:
  description: "copyreg module __package__ == '' — pure-Python stdlib module, not a package"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# dispatch_table.__class__.__name__ — extra6 namespace
#
# copyreg_extra and copyreg_extra2 cover this. This re-anchors the invariant
# in the extra6 namespace as a distinct module-level identity check alongside
# the other module-identity invariants.
# ---------------------------------------------------------------------------

invariant copyreg_extra6.dispatch_table.class_name:
  description: "copyreg.dispatch_table.__class__.__name__ == 'dict' — dispatch_table is a plain dict"
  category: module_identity
  kind: python_call_eq
  function: dispatch_table.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# __newobj__ and __newobj_ex__ __qualname__ — extra6 namespace
#
# copyreg_extra3 covers these via a combined qualname table. This provides
# standalone re-anchors in the extra6 namespace for independent coverage.
# __newobj__ is used by pickle protocol 2+ to reconstruct instances;
# __newobj_ex__ is used by pickle protocol 4+ with keyword arguments.
# ---------------------------------------------------------------------------

invariant copyreg_extra6.newobj.qualname:
  description: "copyreg.__newobj__.__qualname__ == '__newobj__' — top-level function for pickle protocol 2+"
  category: qualname
  kind: python_call_eq
  function: __newobj__.__qualname__.__eq__
  args: ["__newobj__"]
  expected: true

invariant copyreg_extra6.newobj_ex.qualname:
  description: "copyreg.__newobj_ex__.__qualname__ == '__newobj_ex__' — top-level function for pickle protocol 4+"
  category: qualname
  kind: python_call_eq
  function: __newobj_ex__.__qualname__.__eq__
  args: ["__newobj_ex__"]
  expected: true

# ---------------------------------------------------------------------------
# _reconstructor.__qualname__ — extra6 namespace
#
# copyreg_extra5 covers this as a standalone invariant. Re-anchored here in
# the extra6 namespace for independent coverage.
# ---------------------------------------------------------------------------

invariant copyreg_extra6._reconstructor.qualname:
  description: "copyreg._reconstructor.__qualname__ == '_reconstructor' — internal pickle reconstruction helper"
  category: qualname
  kind: python_call_eq
  function: _reconstructor.__qualname__.__eq__
  args: ["_reconstructor"]
  expected: true
