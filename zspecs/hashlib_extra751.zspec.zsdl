spec: hashlib_extra751
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions

docs:
  summary: HASH object property qualnames for hashlib algorithms (blake2b, blake2s, sha3_256, shake_128, shake_256)
  tags: [hashlib, qualname, property, hash]

provenance:
  derived_from:
    - python_stdlib_hashlib
  not_derived_from:
    - cpython_source
  notes:
    - Covers __qualname__ of descriptor properties on HASH algorithm types
    - blake2b.__class__.__name__ verifies the type is 'type'
  created_at: "2026-04-12"

table hashlib_extra751.name:
  description: HASH object property qualnames via blake2b, blake2s, sha3_256, shake_128, shake_256
  kind: python_call_eq
  category: qualname
  id_prefix: hl751xx
  columns: [id, function, args, expected]
  rows:
    - [hl751xx001, hashlib.blake2b.name.__qualname__.__eq__, ["blake2b.name"], true]
    - [hl751xx002, hashlib.blake2b.digest_size.__qualname__.__eq__, ["blake2b.digest_size"], true]
    - [hl751xx003, hashlib.blake2b.block_size.__qualname__.__eq__, ["blake2b.block_size"], true]
    - [hl751xx004, hashlib.blake2s.name.__qualname__.__eq__, ["blake2s.name"], true]
    - [hl751xx005, hashlib.blake2s.digest_size.__qualname__.__eq__, ["blake2s.digest_size"], true]
    - [hl751xx006, hashlib.blake2s.block_size.__qualname__.__eq__, ["blake2s.block_size"], true]
    - [hl751xx007, hashlib.sha3_256.name.__qualname__.__eq__, ["sha3_256.name"], true]
    - [hl751xx008, hashlib.sha3_256.digest_size.__qualname__.__eq__, ["sha3_256.digest_size"], true]
    - [hl751xx009, hashlib.sha3_256.block_size.__qualname__.__eq__, ["sha3_256.block_size"], true]
    - [hl751xx010, hashlib.shake_128.name.__qualname__.__eq__, ["shake_128.name"], true]
    - [hl751xx011, hashlib.shake_256.name.__qualname__.__eq__, ["shake_256.name"], true]
    - [hl751xx012, hashlib.blake2b.__class__.__name__.__eq__, ["type"], true]
