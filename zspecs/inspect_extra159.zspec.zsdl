    - "inspect.getsourcefile.__code__.co_argcount == 1 — getsourcefile(object) takes 1 argument; it returns the name of the Python source file in which an object was defined. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__code__.co_name == 'getsourcefile' — the code object co_name for getsourcefile is 'getsourcefile'. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_argcount == 1 — getsourcelines(object) takes 1 argument; it returns a list of source code lines and starting line number for an object. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_name == 'getsourcelines' — the code object co_name for getsourcelines is 'getsourcelines'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature.bind and inspect.Signature.bind_partial code attrs
#
# Wave 288 theme: inspect.Signature.bind and inspect.Signature.bind_partial
# __code__ co_argcount and co_name attributes.
#
# inspect.Signature.bind.__code__.co_argcount == 1
# inspect.Signature.bind.__code__.co_name == 'bind'
# inspect.Signature.bind_partial.__code__.co_argcount == 1
# inspect.Signature.bind_partial.__code__.co_name == 'bind_partial'
#
# Signature.bind(*args, **kwargs) maps positional and keyword call arguments
# to the Signature's parameters and returns a BoundArguments. It raises
# TypeError if the arguments do not match. Signature.bind_partial(*args,
# **kwargs) is the same but allows partial binding (some parameters may remain
# unbound). Both are Python methods in Lib/inspect.py. Their co_argcount is 1
# (self only) because *args and **kwargs are not counted. New to extra159.
# ---------------------------------------------------------------------------

table inspect_extra159.signature_bind_and_bind_partial_code_attrs:
  description: "inspect.Signature.bind: co_argcount 1, co_name 'bind'; inspect.Signature.bind_partial: co_argcount 1, co_name 'bind_partial'; wave 288; new to extra159"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsbsbpca159

  columns: [id, function, args, expected, description]
  rows:
    - [sig_bind_co_argcount_eq_1,
       "Signature.bind.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.Signature.bind.__code__.co_argcount.__eq__(1) == True — Signature.bind(self, /, *args, **kwargs) takes 1 positional-or-keyword argument (self); *args and **kwargs are VAR_POSITIONAL and VAR_KEYWORD and are not counted in co_argcount; co_argcount is 1; int.__eq__(1) returns True; new to extra159"]
    - [sig_bind_co_name_eq,
       "Signature.bind.__code__.co_name.__eq__",
       ["bind"],
       true,
       "inspect.Signature.bind.__code__.co_name.__eq__('bind') == True — Signature.bind is a Python method in Lib/inspect.py that maps positional and keyword call arguments to the Signature's parameters; its code object co_name is 'bind'; str.__eq__('bind') returns True; new to extra159"]
    - [sig_bind_partial_co_argcount_eq_1,
       "Signature.bind_partial.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.Signature.bind_partial.__code__.co_argcount.__eq__(1) == True — Signature.bind_partial(self, /, *args, **kwargs) allows partial binding of arguments; like bind it takes 1 positional-or-keyword argument (self); *args and **kwargs are not counted in co_argcount; co_argcount is 1; int.__eq__(1) returns True; new to extra159"]
    - [sig_bind_partial_co_name_eq,
       "Signature.bind_partial.__code__.co_name.__eq__",
       ["bind_partial"],
       true,
       "inspect.Signature.bind_partial.__code__.co_name.__eq__('bind_partial') == True — Signature.bind_partial is a Python method in Lib/inspect.py that performs partial argument binding without requiring all parameters to be satisfied; its code object co_name is 'bind_partial'; str.__eq__('bind_partial') returns True; new to extra159"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getsourcefile and inspect.getsourcelines code attributes
#
# Wave 288 theme: inspect.getsourcefile and inspect.getsourcelines __code__
# co_argcount and co_name attributes.
#
# inspect.getsourcefile.__code__.co_argcount == 1
# inspect.getsourcefile.__code__.co_name == 'getsourcefile'
# inspect.getsourcelines.__code__.co_argcount == 1
# inspect.getsourcelines.__code__.co_name == 'getsourcelines'
#
# getsourcefile(object) returns the name of the Python source file in which
# an object was defined, or None if the source cannot be determined. It takes
# 1 argument. getsourcelines(object) returns a list of source code lines and
# the starting line number for an object. It also takes 1 argument. Both are
# Python functions in Lib/inspect.py. New to extra159.
# ---------------------------------------------------------------------------

table inspect_extra159.getsourcefile_and_getsourcelines_code_attrs:
  description: "inspect.getsourcefile: co_argcount 1, co_name 'getsourcefile'; inspect.getsourcelines: co_argcount 1, co_name 'getsourcelines'; wave 288; new to extra159"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgsgsca159

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcefile_co_argcount_eq_1,
       "getsourcefile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcefile.__code__.co_argcount.__eq__(1) == True — getsourcefile(object) takes exactly 1 positional-or-keyword argument; it returns the Python source filename where the object was defined, or None if undeterminable; co_argcount is 1; int.__eq__(1) returns True; new to extra159"]
    - [getsourcefile_co_name_eq,
       "getsourcefile.__code__.co_name.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__code__.co_name.__eq__('getsourcefile') == True — getsourcefile is a Python function in Lib/inspect.py that determines the source file for an object; its code object co_name is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra159"]
    - [getsourcelines_co_argcount_eq_1,
       "getsourcelines.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcelines.__code__.co_argcount.__eq__(1) == True — getsourcelines(object) takes exactly 1 positional-or-keyword argument; it returns a pair (lines, lineno) containing the list of source code lines and the starting line number for the object; co_argcount is 1; int.__eq__(1) returns True; new to extra159"]
    - [getsourcelines_co_name_eq,
       "getsourcelines.__code__.co_name.__eq__",
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__code__.co_name.__eq__('getsourcelines') == True — getsourcelines is a Python function in Lib/inspect.py that retrieves source code lines for an object; its code object co_name is 'getsourcelines'; str.__eq__('getsourcelines') returns True; new to extra159"]

