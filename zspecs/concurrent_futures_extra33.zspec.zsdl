spec: concurrent_futures_extra33
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra32.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens for ThreadPoolExecutor/ProcessPoolExecutor/Executor, Future method qualname lens for result/add_done_callback/cancel/done/exception/running/set_result/set_exception/set_running_or_notify_cancel, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__() == 14, __mro__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor, __bases__[0].__name__.__len__() tables, Executor context manager __enter__/__exit__ qualname lens, InvalidStateError hierarchy, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, ThreadPoolExecutor.map/__qualname__.__len__()==12, ProcessPoolExecutor.map/__qualname__.__len__()==23, as_completed/__name__.__len__()==12, wait/__name__.__len__()==4."
    - "This spec covers: Future.result.__name__.__len__()==6; Future.done.__name__.__len__()==4; Future.running.__name__.__len__()==7; Future.cancel.__name__.__len__()==6; Future.exception.__name__.__len__()==9; Future.add_done_callback.__name__.__len__()==17; Future.set_result.__name__.__len__()==10; Future.set_exception.__name__.__len__()==13; ThreadPoolExecutor.__enter__.__name__.__len__()==9; ThreadPoolExecutor.__exit__.__name__.__len__()==8."
    - "Future method __name__ gives the short unqualified name without the 'Future.' prefix. All Future methods in this spec define their own name directly (no inheritance), so __name__ == the method identifier."
    - "Future.result and Future.cancel share __name__ length 6 ('result', 'cancel' — both 6 chars)."
    - "Future.add_done_callback.__name__ == 'add_done_callback' (17 chars) — the longest Future method short name measured in this spec."
    - "ThreadPoolExecutor.__enter__.__name__ == '__enter__' (9 chars); ThreadPoolExecutor.__exit__.__name__ == '__exit__' (8 chars). Both are dunder names defined on the base Executor class; __enter__ is one character longer than __exit__ because 'enter' (5) > 'exit' (4)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Future method __name__.__len__() — extra33 namespace
#
# Prior specs covered Future method __qualname__.__len__() extensively.
# This spec covers __name__.__len__() — the short unqualified method name —
# for all major Future methods:
#   Future.result.__name__            == 'result'            (6 chars)
#   Future.done.__name__              == 'done'              (4 chars)
#   Future.running.__name__           == 'running'           (7 chars)
#   Future.cancel.__name__            == 'cancel'            (6 chars)
#   Future.exception.__name__         == 'exception'         (9 chars)
#   Future.add_done_callback.__name__ == 'add_done_callback' (17 chars)
#   Future.set_result.__name__        == 'set_result'        (10 chars)
#   Future.set_exception.__name__     == 'set_exception'     (13 chars)
# result and cancel share the same length (6); add_done_callback is the longest
# at 17 characters.
# ---------------------------------------------------------------------------

table concurrent_futures_extra33.future_method_name_lengths:
  description: "concurrent.futures Future method __name__.__len__() in extra33 namespace — short names without class prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: futmethodnamelen33

  columns: [id, function, args, expected]
  rows:
    - [result,            Future.result.__name__.__len__,            [], 6]
    - [done,              Future.done.__name__.__len__,              [], 4]
    - [running,           Future.running.__name__.__len__,           [], 7]
    - [cancel,            Future.cancel.__name__.__len__,            [], 6]
    - [exception,         Future.exception.__name__.__len__,         [], 9]
    - [add_done_callback, Future.add_done_callback.__name__.__len__, [], 17]
    - [set_result,        Future.set_result.__name__.__len__,        [], 10]
    - [set_exception,     Future.set_exception.__name__.__len__,     [], 13]

# ---------------------------------------------------------------------------
# concurrent.futures Executor context manager __name__.__len__() — extra33
#
# Executor defines __enter__ and __exit__ for context manager support.
# ThreadPoolExecutor inherits these from Executor. The __name__ values are:
#   ThreadPoolExecutor.__enter__.__name__ == '__enter__' (9 chars)
#   ThreadPoolExecutor.__exit__.__name__  == '__exit__'  (8 chars)
# __enter__ is one character longer than __exit__ because 'enter' (5) is
# longer than 'exit' (4). Prior specs covered __qualname__.__len__() for both
# (Executor.__enter__.__qualname__ == 'Executor.__enter__' == 18 chars;
# Executor.__exit__.__qualname__ == 'Executor.__exit__' == 17 chars) in
# extra29 and extra30, but not __name__.__len__().
# ---------------------------------------------------------------------------

table concurrent_futures_extra33.executor_context_manager_name_lengths:
  description: "concurrent.futures Executor context manager __name__.__len__() in extra33 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execctxnamelen33

  columns: [id, function, args, expected]
  rows:
    - [enter, ThreadPoolExecutor.__enter__.__name__.__len__, [], 9]
    - [exit,  ThreadPoolExecutor.__exit__.__name__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# Standalone invariants — extra33
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra33.Future_add_done_callback_name_len:
  description: "concurrent.futures.Future.add_done_callback.__name__.__len__() == 17 — 'add_done_callback' is 17 characters; the longest Future method short name in this spec"
  category: method_names
  kind: python_call_eq
  function: Future.add_done_callback.__name__.__len__
  args: []
  expected: 17

invariant concurrent_futures_extra33.Future_running_name_len:
  description: "concurrent.futures.Future.running.__name__.__len__() == 7 — 'running' is 7 characters; one longer than 'result' and 'cancel' (both 6)"
  category: method_names
  kind: python_call_eq
  function: Future.running.__name__.__len__
  args: []
  expected: 7

invariant concurrent_futures_extra33.Executor_enter_name_len:
  description: "concurrent.futures.ThreadPoolExecutor.__enter__.__name__.__len__() == 9 — '__enter__' has 9 characters; one longer than '__exit__' (8)"
  category: method_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__enter__.__name__.__len__
  args: []
  expected: 9
