spec: threading_extra8
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra7."
    - "Focus: __qualname__ attributes for threading classes and module-level functions."
    - "threading.Lock() returns a C-level lock object; its type's __qualname__ is 'lock' (lowercase)."
    - "threading.RLock is a Python class; __qualname__ == 'RLock'."
    - "threading.Timer is a subclass of Thread; __qualname__ == 'Timer'."
    - "threading.local is the thread-local storage type; __qualname__ == 'local'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for threading classes
# ---------------------------------------------------------------------------

table threading_extra8.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Thread,           Thread.__qualname__.__eq__,           ["Thread"],           true]
    - [RLock,            RLock.__qualname__.__eq__,            ["RLock"],            true]
    - [Event,            Event.__qualname__.__eq__,            ["Event"],            true]
    - [Condition,        Condition.__qualname__.__eq__,        ["Condition"],        true]
    - [Semaphore,        Semaphore.__qualname__.__eq__,        ["Semaphore"],        true]
    - [BoundedSemaphore, BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]
    - [Timer,            Timer.__qualname__.__eq__,            ["Timer"],            true]
    - [Barrier,          Barrier.__qualname__.__eq__,          ["Barrier"],          true]
    - [local,            local.__qualname__.__eq__,            ["local"],            true]

# ---------------------------------------------------------------------------
# threading.Lock — C-level type; __qualname__ is 'lock' (lowercase)
# Lock is a factory function returning a _thread.lock object, so we check
# the __qualname__ of the returned object's type.
# ---------------------------------------------------------------------------

invariant threading_extra8.Lock.type_qualname:
  description: "threading.Lock().__class__.__qualname__ == 'lock' (C-level lock type)"
  category: qualnames
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["lock"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for threading module-level functions
# ---------------------------------------------------------------------------

table threading_extra8.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: fn_qualname

  columns: [id, function, args, expected]
  rows:
    - [current_thread, current_thread.__qualname__.__eq__, ["current_thread"], true]
    - [main_thread,    main_thread.__qualname__.__eq__,    ["main_thread"],    true]
    - [active_count,   active_count.__qualname__.__eq__,   ["active_count"],   true]
