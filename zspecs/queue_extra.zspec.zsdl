spec: queue_extra
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
  notes:
    - "Queue is a thread-safe FIFO queue. maxsize=0 (the default) means no upper bound."
    - "LifoQueue is a thread-safe LIFO (stack) queue. PriorityQueue retrieves entries in priority order."
    - "SimpleQueue is a simpler unbounded FIFO queue without the advanced features of Queue."
    - "Empty and Full are exceptions raised by queue operations when the queue is empty or full."
    - "Queue().empty() returns True immediately after construction — no items have been put."
    - "Queue().qsize() returns 0 immediately after construction."
    - "Queue(maxsize=N).maxsize == N — the constructor stores maxsize as an attribute."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name invariants — Queue, LifoQueue, PriorityQueue, SimpleQueue
# ---------------------------------------------------------------------------

invariant queue_extra.class_names.Queue:
  description: "Queue.__name__ == 'Queue'"
  category: class_names
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant queue_extra.class_names.Queue_module:
  description: "Queue.__module__ == 'queue'"
  category: class_names
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["queue"]
  expected: true

invariant queue_extra.class_names.LifoQueue:
  description: "LifoQueue.__name__ == 'LifoQueue'"
  category: class_names
  kind: python_call_eq
  function: LifoQueue.__name__.__eq__
  args: ["LifoQueue"]
  expected: true

invariant queue_extra.class_names.PriorityQueue:
  description: "PriorityQueue.__name__ == 'PriorityQueue'"
  category: class_names
  kind: python_call_eq
  function: PriorityQueue.__name__.__eq__
  args: ["PriorityQueue"]
  expected: true

invariant queue_extra.class_names.SimpleQueue:
  description: "SimpleQueue.__name__ == 'SimpleQueue'"
  category: class_names
  kind: python_call_eq
  function: SimpleQueue.__name__.__eq__
  args: ["SimpleQueue"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class names — Empty, Full
# ---------------------------------------------------------------------------

invariant queue_extra.exceptions.Empty_name:
  description: "Empty.__name__ == 'Empty'"
  category: exceptions
  kind: python_call_eq
  function: Empty.__name__.__eq__
  args: ["Empty"]
  expected: true

invariant queue_extra.exceptions.Full_name:
  description: "Full.__name__ == 'Full'"
  category: exceptions
  kind: python_call_eq
  function: Full.__name__.__eq__
  args: ["Full"]
  expected: true

invariant queue_extra.exceptions.Empty_base:
  description: "Empty.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Empty.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant queue_extra.exceptions.Full_base:
  description: "Full.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Full.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Queue constructor and instance behavior
# ---------------------------------------------------------------------------

invariant queue_extra.Queue.maxsize_stored:
  description: "Queue(maxsize=5).maxsize == 5 — constructor stores maxsize attribute"
  category: Queue
  kind: python_call_eq
  function: Queue
  kwargs: {maxsize: 5}
  method: maxsize
  expected: 5

invariant queue_extra.Queue.empty_on_new:
  description: "Queue().empty() == True — a freshly created queue is empty"
  category: Queue
  kind: python_call_eq
  function: Queue
  args: []
  method: empty
  expected: true

invariant queue_extra.Queue.qsize_zero:
  description: "Queue().qsize() == 0 — a freshly created queue has size 0"
  category: Queue
  kind: python_call_eq
  function: Queue
  args: []
  method: qsize
  expected: 0
