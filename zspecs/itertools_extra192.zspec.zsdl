# ---------------------------------------------------------------------------
# Table 1: itertools infinite iterator __qualname__ values
#
# itertools.count.__qualname__   == 'count' (len=5)
# itertools.cycle.__qualname__   == 'cycle' (len=5)
# itertools.repeat.__qualname__  == 'repeat' (len=6)
#
# count, cycle, and repeat are the three infinite iterators in itertools.
# All are C extension types from itertoolsmodule.c. As top-level types,
# __qualname__ equals __name__ with no class nesting prefix. New to extra192.
# ---------------------------------------------------------------------------

table itertools_extra192.infinite_iterator_qualnames:
  description: "itertools infinite iterator __qualname__ values: count/cycle/repeat all have __qualname__ equal to __name__; all are C extension types; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: iterqualnames192

  columns: [id, function, args, expected, description]
  rows:
    - [count_qualname_eq,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C extension type implementing the infinite counter iterator; as a top-level type __qualname__ equals __name__; __qualname__ is 'count' (len=5: c-o-u-n-t); str.__eq__('count') returns True; verified with Python 3.14.3; new to extra192"]
    - [count_qualname_len,
       count.__qualname__.__len__,
       [],
       5,
       "itertools.count.__qualname__.__len__() == 5 — 'count' has 5 characters: c-o-u-n-t; str.__len__() returns 5; verified with Python 3.14.3; new to extra192"]
    - [cycle_qualname_eq,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — cycle is a C extension type that cycles through a finite iterable indefinitely; __qualname__ is 'cycle' (len=5: c-y-c-l-e); str.__eq__('cycle') returns True; verified with Python 3.14.3; new to extra192"]
    - [cycle_qualname_len,
       cycle.__qualname__.__len__,
       [],
       5,
       "itertools.cycle.__qualname__.__len__() == 5 — 'cycle' has 5 characters: c-y-c-l-e; str.__len__() returns 5; verified with Python 3.14.3; new to extra192"]
    - [repeat_qualname_eq,
       repeat.__qualname__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__qualname__.__eq__('repeat') == True — repeat is a C extension type that repeats a value indefinitely or a fixed number of times; __qualname__ is 'repeat' (len=6: r-e-p-e-a-t); str.__eq__('repeat') returns True; verified with Python 3.14.3; new to extra192"]
    - [repeat_qualname_len,
       repeat.__qualname__.__len__,
       [],
       6,
       "itertools.repeat.__qualname__.__len__() == 6 — 'repeat' has 6 characters: r-e-p-e-a-t; str.__len__() returns 6; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 2: itertools chaining and filtering iterator __qualname__ values
#
# itertools.chain.__qualname__     == 'chain' (len=5)
# itertools.islice.__qualname__    == 'islice' (len=6)
# itertools.compress.__qualname__  == 'compress' (len=8)
#
# chain, islice, and compress are sequence-manipulation iterators. All are
# C extension types in itertoolsmodule.c. As top-level types, __qualname__
# equals __name__. New to extra192.
# ---------------------------------------------------------------------------

table itertools_extra192.chain_islice_compress_qualnames:
  description: "itertools chain/islice/compress __qualname__ values: chain=='chain'(len=5); islice=='islice'(len=6); compress=='compress'(len=8); new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: iterqualnames192

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_eq,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C extension type that chains multiple iterables into a single sequence; __qualname__ is 'chain' (len=5: c-h-a-i-n); str.__eq__('chain') returns True; verified with Python 3.14.3; new to extra192"]
    - [chain_qualname_len,
       chain.__qualname__.__len__,
       [],
       5,
       "itertools.chain.__qualname__.__len__() == 5 — 'chain' has 5 characters: c-h-a-i-n; str.__len__() returns 5; verified with Python 3.14.3; new to extra192"]
    - [islice_qualname_eq,
       islice.__qualname__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — islice is a C extension type that slices an iterator like the built-in slice; __qualname__ is 'islice' (len=6: i-s-l-i-c-e); str.__eq__('islice') returns True; verified with Python 3.14.3; new to extra192"]
    - [islice_qualname_len,
       islice.__qualname__.__len__,
       [],
       6,
       "itertools.islice.__qualname__.__len__() == 6 — 'islice' has 6 characters: i-s-l-i-c-e; str.__len__() returns 6; verified with Python 3.14.3; new to extra192"]
    - [compress_qualname_eq,
       compress.__qualname__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — compress is a C extension type that filters elements using a Boolean selector iterable; __qualname__ is 'compress' (len=8: c-o-m-p-r-e-s-s); str.__eq__('compress') returns True; verified with Python 3.14.3; new to extra192"]
    - [compress_qualname_len,
       compress.__qualname__.__len__,
       [],
       8,
       "itertools.compress.__qualname__.__len__() == 8 — 'compress' has 8 characters: c-o-m-p-r-e-s-s; str.__len__() returns 8; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 3: itertools predicate iterator __qualname__ values
#
# itertools.dropwhile.__qualname__  == 'dropwhile' (len=9)
# itertools.takewhile.__qualname__  == 'takewhile' (len=9)
#
# dropwhile and takewhile are predicate-based iterators that complement each
# other. Both are C extension types in itertoolsmodule.c. As top-level types,
# __qualname__ equals __name__. Both have __qualname__ length 9. New to extra192.
# ---------------------------------------------------------------------------

table itertools_extra192.dropwhile_takewhile_qualnames:
  description: "itertools dropwhile/takewhile __qualname__ values: dropwhile=='dropwhile'(len=9); takewhile=='takewhile'(len=9); both are C extension types; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: iterqualnames192

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_qualname_eq,
       dropwhile.__qualname__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__.__eq__('dropwhile') == True — dropwhile is a C extension type that drops elements while a predicate is true then yields the rest; __qualname__ is 'dropwhile' (len=9: d-r-o-p-w-h-i-l-e); str.__eq__('dropwhile') returns True; verified with Python 3.14.3; new to extra192"]
    - [dropwhile_qualname_len,
       dropwhile.__qualname__.__len__,
       [],
       9,
       "itertools.dropwhile.__qualname__.__len__() == 9 — 'dropwhile' has 9 characters: d-r-o-p-w-h-i-l-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra192"]
    - [takewhile_qualname_eq,
       takewhile.__qualname__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__qualname__.__eq__('takewhile') == True — takewhile is a C extension type that yields elements while a predicate is true then stops; __qualname__ is 'takewhile' (len=9: t-a-k-e-w-h-i-l-e); str.__eq__('takewhile') returns True; verified with Python 3.14.3; new to extra192"]
    - [takewhile_qualname_len,
       takewhile.__qualname__.__len__,
       [],
       9,
       "itertools.takewhile.__qualname__.__len__() == 9 — 'takewhile' has 9 characters: t-a-k-e-w-h-i-l-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra192"]

