spec: urllib_error_extra5
version: ">=3.0"
backend: python_module(urllib.error)

docs: https://docs.python.org/3/library/urllib.error.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.error.html — Python urllib.error module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/error.py"
  notes:
    - "This spec extends urllib_error.zspec.zsdl through urllib_error_extra4.zspec.zsdl."
    - "urllib_error.zspec.zsdl covers: class_names table, modules table (all three == 'urllib.error'), URLError reason, HTTPError code/reason/url/code 500, URLError.__bases__[0].__name__ == 'OSError', HTTPError.__bases__[0].__name__ == 'URLError'."
    - "urllib_error_extra.zspec.zsdl covers: URLError/__name__, HTTPError.__name__, HTTPError.__bases__[0].__name__ == 'URLError' (duplicate)."
    - "urllib_error_extra2.zspec.zsdl covers: __qualname__ table (URLError/HTTPError/ContentTooShortError via __eq__ chain), ContentTooShortError.__bases__[0].__name__ == 'URLError', qualname_is_str table, HTTPError code 403/msg 403."
    - "urllib_error_extra3.zspec.zsdl covers: class_type_identity table (__class__.__name__ == 'type'), HTTPError.__bases__.__len__ == 2, HTTPError.__bases__[1].__name__ == 'addinfourl', URLError.__bases__.__len__ == 1, ContentTooShortError.__bases__.__len__ == 1, HTTPError 301 code/msg, HTTPError 500 msg/url."
    - "urllib_error_extra4.zspec.zsdl covers: URLError str repr, URLError.args[0], HTTPError 200 code/msg/url/reason, ContentTooShortError.reason, URLError.__bases__[0].__qualname__ == 'OSError', HTTPError.__bases__[0].__qualname__ == 'URLError'."
    - "Focus: __qualname__ for exception class methods — a new axis not in any prior urllib.error spec."
    - "URLError.__init__.__qualname__ == 'URLError.__init__' — initializer qualname includes the class name."
    - "URLError.__str__.__qualname__ == 'URLError.__str__' — string representation method qualname."
    - "HTTPError.__init__.__qualname__ == 'HTTPError.__init__' — HTTPError initializer qualname."
    - "HTTPError.__str__.__qualname__ == 'HTTPError.__str__' — HTTPError str method qualname."
    - "ContentTooShortError.__init__.__qualname__ == 'ContentTooShortError.__init__' — initializer qualname."
    - "URLError MRO length == 5 — URLError -> OSError -> Exception -> BaseException -> object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Exception classes; raised by urllib.request operations on network failures or HTTP errors."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Exception class method __qualname__ — class.method pattern
#
# No prior urllib.error spec checks __qualname__ for methods defined inside
# the exception classes. Method qualnames follow the pattern 'ClassName.__init__'
# and 'ClassName.__str__' for instance methods.
# Verified at runtime with Python 3.12.
# ---------------------------------------------------------------------------

table urllib_error_extra5.method_qualnames:
  description: "__qualname__ for URLError and HTTPError instance methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: methq

  columns: [id, function, args, expected]
  rows:
    - [URLError_init,              URLError.__init__.__qualname__.__eq__,              ["URLError.__init__"],              true]
    - [URLError_str,               URLError.__str__.__qualname__.__eq__,               ["URLError.__str__"],               true]
    - [HTTPError_init,             HTTPError.__init__.__qualname__.__eq__,             ["HTTPError.__init__"],             true]
    - [HTTPError_str,              HTTPError.__str__.__qualname__.__eq__,              ["HTTPError.__str__"],              true]
    - [ContentTooShortError_init,  ContentTooShortError.__init__.__qualname__.__eq__,  ["ContentTooShortError.__init__"],  true]

# ---------------------------------------------------------------------------
# URLError MRO length
#
# urllib_error_extra3 covers HTTPError.__bases__.__len__ == 2 and
# URLError.__bases__.__len__ == 1. No prior spec checks the full MRO length.
# URLError's MRO is: URLError -> OSError -> Exception -> BaseException -> object
# (length == 5). Verified at runtime.
# ---------------------------------------------------------------------------

invariant urllib_error_extra5.URLError.mro_len:
  description: "len(urllib.error.URLError.__mro__) == 5 — URLError, OSError, Exception, BaseException, object"
  category: hierarchy
  kind: python_call_eq
  function: URLError.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# URLError MRO member names — spot checks at key positions
#
# urllib_error.zspec.zsdl checks URLError.__bases__[0].__name__ == 'OSError'.
# No prior spec checks URLError.__mro__ members by position.
# Verified at runtime: mro[0] == URLError, mro[1] == OSError, mro[2] == Exception.
# ---------------------------------------------------------------------------

table urllib_error_extra5.URLError_mro_names:
  description: "URLError.__mro__ member names at positions 0, 1, 2"
  kind: python_call_eq
  category: hierarchy
  id_prefix: mroname

  columns: [id, function, args, expected]
  rows:
    - [mro0,  "URLError.__mro__[0].__name__.__eq__",  ["URLError"],   true]
    - [mro1,  "URLError.__mro__[1].__name__.__eq__",  ["OSError"],    true]
    - [mro2,  "URLError.__mro__[2].__name__.__eq__",  ["Exception"],  true]
