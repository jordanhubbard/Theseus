spec: re_extra183
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.match('a','abc').__class__.__name__=='Match' (len=5); re.match('a','abc').__class__.__module__=='re'; re.match('a','abc').__class__.__qualname__=='Match'."
    - "re.match('(a)','abc').lastindex==1 and lastindex.__class__.__name__=='int'; re.match('a','abc').pos==0 and pos.__class__.__name__=='int'."
    - "re.match('a','abc').endpos==3 — endpos is the length of the string passed to match() (len('abc')==3), not the end of the match; pos==0 is the start position passed to match()."
    - "len('Match')==5: M(1)a(2)t(3)c(4)h(5); Match (5) is shorter than Pattern (7) from re_extra182."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.match('a', 'abc') class identity
# __class__.__name__=='Match' (len=5); __module__=='re'; __qualname__=='Match'
# ---------------------------------------------------------------------------

table re_extra183.match_class_identity:
  description: "re.match('a','abc') class identity: __class__.__name__=='Match' (len=5); __class__.__module__=='re'; __class__.__qualname__=='Match'; Match (5) < Pattern (7): the Match class name is shorter than the Pattern class name"
  kind: python_call_eq
  category: identity
  id_prefix: rematch183

  columns: [id, function, args, expected, description]
  rows:
    - [cls_name,     "match('a', 'abc').__class__.__name__.__eq__",     ["Match"], true, "re.match('a','abc').__class__.__name__ == 'Match' — a successful match returns a Match object; len('Match')==5: M(1)a(2)t(3)c(4)h(5); Match (5) < Pattern (7); confirmed Python 3.14.3 macOS"]
    - [cls_name_len, "match('a', 'abc').__class__.__name__.__len__",    [],        5,    "re.match('a','abc').__class__.__name__.__len__() == 5 — 'Match' has 5 characters; Match (5) < Pattern (7): the Match class name is 2 chars shorter than Pattern; confirmed Python 3.14.3 macOS"]
    - [cls_module,   "match('a', 'abc').__class__.__module__.__eq__",   ["re"],    true, "re.match('a','abc').__class__.__module__ == 're' — the Match class belongs to the re module; confirmed Python 3.14.3 macOS"]
    - [cls_qualname, "match('a', 'abc').__class__.__qualname__.__eq__", ["Match"], true, "re.match('a','abc').__class__.__qualname__ == 'Match' — Match is a top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"]
    - [cls_name_ne,  "match('a', 'abc').__class__.__name__.__eq__",     ["Pattern"], false, "re.match('a','abc').__class__.__name__.__eq__('Pattern') == False — the result of re.match() is 'Match', not 'Pattern'; Match != Pattern; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.match lastindex and pos attributes
# lastindex for '(a)' match == 1 (int); pos == 0 (int)
# ---------------------------------------------------------------------------

table re_extra183.match_lastindex_and_pos:
  description: "re.match lastindex and pos: match('(a)','abc').lastindex.__eq__(1)==True (int); match('a','abc').pos.__eq__(0)==True (int); lastindex counts capturing groups matched; pos is the start position of the search"
  kind: python_call_eq
  category: identity
  id_prefix: rematch183

  columns: [id, function, args, expected, description]
  rows:
    - [lastindex_val,   "match('(a)', 'abc').lastindex.__eq__",                [1],     true, "re.match('(a)','abc').lastindex.__eq__(1) == True — lastindex is 1 because group 1 was the last group to match; lastindex is an int; confirmed Python 3.14.3 macOS"]
    - [lastindex_cls,   "match('(a)', 'abc').lastindex.__class__.__name__.__eq__", ["int"], true, "re.match('(a)','abc').lastindex.__class__.__name__ == 'int' — lastindex is a plain Python int; confirmed Python 3.14.3 macOS"]
    - [pos_val,         "match('a', 'abc').pos.__eq__",                        [0],     true, "re.match('a','abc').pos.__eq__(0) == True — pos is 0 because match() was called without a start argument; pos is the start position of the search; confirmed Python 3.14.3 macOS"]
    - [pos_cls,         "match('a', 'abc').pos.__class__.__name__.__eq__",     ["int"], true, "re.match('a','abc').pos.__class__.__name__ == 'int' — pos is a plain Python int; confirmed Python 3.14.3 macOS"]
    - [lastindex_ne_2,  "match('(a)', 'abc').lastindex.__eq__",                [2],     false, "re.match('(a)','abc').lastindex.__eq__(2) == False — '(a)' has only 1 group; lastindex == 1, not 2; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.match endpos attribute
# endpos == 3 (length of 'abc'); endpos is an int
# ---------------------------------------------------------------------------

table re_extra183.match_endpos:
  description: "re.match('a','abc').endpos: endpos.__eq__(3)==True (the length of the string 'abc'); endpos.__class__.__name__=='int'; endpos is the end position of the search region, equal to len('abc') when no end argument is given"
  kind: python_call_eq
  category: identity
  id_prefix: rematch183

  columns: [id, function, args, expected, description]
  rows:
    - [endpos_val,      "match('a', 'abc').endpos.__eq__",                 [3],     true, "re.match('a','abc').endpos.__eq__(3) == True — endpos == len('abc') == 3; when match() is called without an end argument endpos equals the string length; confirmed Python 3.14.3 macOS"]
    - [endpos_cls,      "match('a', 'abc').endpos.__class__.__name__.__eq__", ["int"], true, "re.match('a','abc').endpos.__class__.__name__ == 'int' — endpos is a plain Python int; confirmed Python 3.14.3 macOS"]
    - [endpos_ne_pos,   "match('a', 'abc').endpos.__eq__",                 [0],     false, "re.match('a','abc').endpos.__eq__(0) == False — endpos (3) != pos (0); pos is the start and endpos is the end of the search region; confirmed Python 3.14.3 macOS"]
    - [endpos_gt_pos,   "match('a', 'abc').pos.__eq__",                    [0],     true, "re.match('a','abc').pos.__eq__(0) == True — pos==0 and endpos==3; pos < endpos: the search region spans the entire string; confirmed Python 3.14.3 macOS"]
    - [cls_name_match,  "match('a', 'abc').__class__.__name__.__eq__",     ["Match"], true, "re.match('a','abc').__class__.__name__ == 'Match' — cross-check: the object with endpos==3 is a Match instance; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra183.match_class_name_is_match:
  description: "re.match('a','abc').__class__.__name__ == 'Match' — successful match returns a Match instance; len('Match')==5: M(1)a(2)t(3)c(4)h(5); Match (5) < Pattern (7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('a', 'abc').__class__.__name__.__eq__"
  args: ["Match"]
  expected: true

invariant re_extra183.match_class_name_len_is_5:
  description: "re.match('a','abc').__class__.__name__.__len__() == 5 — 'Match' has 5 characters; Match (5) < Pattern (7): Match class name is 2 chars shorter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('a', 'abc').__class__.__name__.__len__"
  args: []
  expected: 5

invariant re_extra183.match_class_module_is_re:
  description: "re.match('a','abc').__class__.__module__ == 're' — the Match class belongs to the re module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('a', 'abc').__class__.__module__.__eq__"
  args: ["re"]
  expected: true

invariant re_extra183.match_class_qualname_is_match:
  description: "re.match('a','abc').__class__.__qualname__ == 'Match' — top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('a', 'abc').__class__.__qualname__.__eq__"
  args: ["Match"]
  expected: true

invariant re_extra183.match_lastindex_eq_1:
  description: "re.match('(a)','abc').lastindex.__eq__(1) == True — lastindex is 1 for a single capturing group that matched; lastindex is an int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('(a)', 'abc').lastindex.__eq__"
  args: [1]
  expected: true

invariant re_extra183.match_lastindex_class_is_int:
  description: "re.match('(a)','abc').lastindex.__class__.__name__ == 'int' — lastindex is a plain Python int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('(a)', 'abc').lastindex.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant re_extra183.match_pos_eq_0:
  description: "re.match('a','abc').pos.__eq__(0) == True — pos == 0 when match() is called without a start argument; pos is an int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('a', 'abc').pos.__eq__"
  args: [0]
  expected: true

invariant re_extra183.match_endpos_eq_3:
  description: "re.match('a','abc').endpos.__eq__(3) == True — endpos == len('abc') == 3 when match() is called without an end argument; endpos is an int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "match('a', 'abc').endpos.__eq__"
  args: [3]
  expected: true

