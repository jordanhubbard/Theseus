spec: uuid_extra1456
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID construction, fields, int, hex, str, bytes attributes"
  notes:
    - "Wave 544 theme: __contains__ and __iter__ method presence and type checks."
    - "uuid.UUID is a pure-Python value type representing a 128-bit UUID; it is not a container."
    - "uuid.SafeUUID is an IntEnum subclass; __iter__ and __contains__ are NOT in SafeUUID.__dict__."
    - "uuid.SafeUUID.__iter__ is accessible via hasattr but comes from the EnumType metaclass, not SafeUUID.__dict__."
    - "uuid.SafeUUID.__contains__ is similarly accessible via the EnumType metaclass, not SafeUUID.__dict__."
    - "uuid.UUID.__dict__ does not contain '__iter__' — UUID is not iterable."
    - "uuid.UUID.__dict__ does not contain '__contains__' — UUID does not support membership testing."
    - "The int attribute of UUID stores the 128-bit integer value; UUID is a scalar, not a sequence."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — __contains__ and __iter__ absence checks
#
# uuid.UUID wraps a 128-bit integer. It exposes fields like .int, .hex,
# .bytes, .version, etc., but is not a sequence or mapping. Neither
# __iter__ nor __contains__ is defined in UUID.__dict__.
# ---------------------------------------------------------------------------

table uuid_extra1456.UUID_contains_iter:
  description: "uuid.UUID has no __contains__ or __iter__ — UUID is a scalar value type, not a container; neither method appears in UUID.__dict__; wave 544 __contains__/__iter__ absence theme; uu1456ci anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1456ci

  columns: [id, function, args, expected, description]
  rows:
    - [uu1456ci001, "uuid.UUID.__dict__.__contains__", ["__contains__"], false, "uuid.UUID.__dict__ does not contain '__contains__' — UUID is not a membership-test container"]
    - [uu1456ci002, "uuid.UUID.__dict__.__contains__", ["__iter__"],     false, "uuid.UUID.__dict__ does not contain '__iter__' — UUID objects are not iterable"]
    - [uu1456ci003, "uuid.UUID.__dict__.__contains__", ["__eq__"],       true,  "uuid.UUID.__dict__ contains '__eq__' — confirms __dict__ lookup works correctly on UUID"]
    - [uu1456ci004, "uuid.UUID.__dict__.__contains__", ["__hash__"],     true,  "uuid.UUID.__dict__ contains '__hash__' — UUID is hashable (scalar value)"]
    - [uu1456ci005, "uuid.UUID.__dict__.__contains__", ["__str__"],      true,  "uuid.UUID.__dict__ contains '__str__' — UUID has a canonical string representation"]
    - [uu1456ci006, "uuid.UUID.__dict__.__contains__", ["__int__"],      true,  "uuid.UUID.__dict__ contains '__int__' — UUID exposes its 128-bit integer value via __int__"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — __contains__ and __iter__ dict checks
#
# SafeUUID is an IntEnum. As an enum class, it IS iterable and supports
# membership testing — but those capabilities come from the EnumType metaclass,
# not from SafeUUID.__dict__ itself. '__iter__' and '__contains__' are absent
# from SafeUUID.__dict__ even though hasattr(SafeUUID, '__iter__') is True.
# ---------------------------------------------------------------------------

table uuid_extra1456.SafeUUID_contains_iter:
  description: "uuid.SafeUUID.__dict__ has no __contains__ or __iter__ — both methods are supplied by the EnumType metaclass, not by SafeUUID itself; SafeUUID.__dict__ does not define them; wave 544 uu1456su anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1456su

  columns: [id, function, args, expected, description]
  rows:
    - [uu1456su001, "uuid.SafeUUID.__dict__.__contains__", ["__contains__"], false, "uuid.SafeUUID.__dict__ does not contain '__contains__' — method comes from EnumType metaclass, not SafeUUID"]
    - [uu1456su002, "uuid.SafeUUID.__dict__.__contains__", ["__iter__"],     false, "uuid.SafeUUID.__dict__ does not contain '__iter__' — method comes from EnumType metaclass, not SafeUUID"]
    - [uu1456su003, "uuid.SafeUUID.__iter__.__class__.__name__.__eq__",    ["method"],   true,  "uuid.SafeUUID.__iter__.__class__.__name__ == 'method' — bound method from EnumType metaclass"]
    - [uu1456su004, "uuid.SafeUUID.__contains__.__class__.__name__.__eq__", ["method"],  true,  "uuid.SafeUUID.__contains__.__class__.__name__ == 'method' — bound method from EnumType metaclass"]
    - [uu1456su005, "uuid.SafeUUID.__iter__.__class__.__name__.__eq__",    ["wrapper_descriptor"], false, "uuid.SafeUUID.__iter__.__class__.__name__ is NOT 'wrapper_descriptor' — it is 'method' (metaclass-bound)"]
    - [uu1456su006, "uuid.SafeUUID.__contains__.__class__.__name__.__eq__", ["wrapper_descriptor"], false, "uuid.SafeUUID.__contains__.__class__.__name__ is NOT 'wrapper_descriptor' — it is 'method' (metaclass-bound)"]

# ---------------------------------------------------------------------------
# uuid.UUID class name and module checks
#
# Anchors the identity of the UUID type and confirms that UUID is not a
# subclass of common container types (list, set, dict), reinforcing the
# non-container theme of wave 544.
# ---------------------------------------------------------------------------

table uuid_extra1456.UUID_class_identity:
  description: "uuid.UUID class name and module identity checks — UUID.__name__ == 'UUID', UUID.__module__ == 'uuid'; UUID not a list/set/dict subclass; wave 544 scalar identity anchor; uu1456id anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1456id

  columns: [id, function, args, expected, description]
  rows:
    - [uu1456id001, "uuid.UUID.__name__.__eq__",   ["UUID"],  true,  "uuid.UUID.__name__ == 'UUID' — confirms the class is named UUID"]
    - [uu1456id002, "uuid.UUID.__module__.__eq__", ["uuid"],  true,  "uuid.UUID.__module__ == 'uuid' — UUID is defined in the uuid module"]
    - [uu1456id003, "uuid.UUID.__dict__.__contains__", ["__iter__"],     false, "uuid.UUID.__dict__ does not contain '__iter__' — duplicate anchor confirming non-iterable scalar"]
    - [uu1456id004, "uuid.UUID.__dict__.__contains__", ["__contains__"], false, "uuid.UUID.__dict__ does not contain '__contains__' — duplicate anchor confirming non-container scalar"]
    - [uu1456id005, "uuid.SafeUUID.__name__.__eq__",   ["SafeUUID"], true,  "uuid.SafeUUID.__name__ == 'SafeUUID' — confirms the enum class name"]
    - [uu1456id006, "uuid.SafeUUID.__module__.__eq__", ["uuid"],     true,  "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in the uuid module"]
