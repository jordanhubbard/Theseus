spec: pathlib_extra149
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __qualname__ values and their lengths, and pathlib.PurePath method __qualname__ values and their lengths. These __qualname__ strings follow the 'ClassName.method_name' pattern and are stable across Python versions >= 3.9."
    - "pathlib.Path.open.__qualname__ == 'Path.open' (9 chars); Path.read_text.__qualname__ == 'Path.read_text' (14 chars); Path.write_text.__qualname__ == 'Path.write_text' (15 chars); Path.mkdir.__qualname__ == 'Path.mkdir' (10 chars); Path.exists.__qualname__ == 'Path.exists' (11 chars)."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' (9 chars); Path.unlink.__qualname__ == 'Path.unlink' (11 chars); Path.rename.__qualname__ == 'Path.rename' (11 chars); Path.iterdir.__qualname__ == 'Path.iterdir' (12 chars); Path.glob.__qualname__ == 'Path.glob' (9 chars)."
    - "pathlib.Path.write_text.__qualname__ length 15 is the longest among the covered Path methods; Path.open, Path.stat, and Path.glob all share length 9 (the shortest)."
    - "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath' (17 chars); PurePath.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (23 chars; the longest covered qualname); PurePath.with_name.__qualname__ == 'PurePath.with_name' (18 chars); PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix' (20 chars)."
    - "All covered methods have __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ values and lengths
# Path.open.__qualname__ == 'Path.open' (9); Path.read_text == 'Path.read_text' (14).
# Path.write_text == 'Path.write_text' (15; longest); Path.mkdir == 'Path.mkdir' (10).
# Path.exists == 'Path.exists' (11); Path.stat == 'Path.stat' (9).
# Path.unlink == 'Path.unlink' (11); Path.rename == 'Path.rename' (11).
# Path.iterdir == 'Path.iterdir' (12); Path.glob == 'Path.glob' (9).
# All have __module__ == 'pathlib'.
# ---------------------------------------------------------------------------

table pathlib_extra149.Path_method_qualnames:
  description: "pathlib.Path method __qualname__ values and lengths: open=9, mkdir=10, exists=11, unlink=11, rename=11, iterdir=12, read_text=14, write_text=15; all __module__='pathlib'"
  kind: python_call_eq
  category: function_identity
  id_prefix: pathlibqn149

  columns: [id, function, args, expected, description]
  rows:
    - [open_qn_eq,        Path.open.__qualname__.__eq__,        ["Path.open"],       true, "pathlib.Path.open.__qualname__ == 'Path.open' (class-qualified; the 'Path.' prefix distinguishes it from the built-in open function)"]
    - [open_qn_len,       Path.open.__qualname__.__len__,       [],                  9,    "pathlib.Path.open.__qualname__.__len__() == 9 ('Path.open' = 'Path.' (5) + 'open' (4))"]
    - [open_mod_eq,       Path.open.__module__.__eq__,          ["pathlib"],         true, "pathlib.Path.open.__module__ == 'pathlib'"]
    - [mkdir_qn_eq,       Path.mkdir.__qualname__.__eq__,       ["Path.mkdir"],      true, "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir'"]
    - [mkdir_qn_len,      Path.mkdir.__qualname__.__len__,      [],                  10,   "pathlib.Path.mkdir.__qualname__.__len__() == 10 ('Path.mkdir' = 'Path.' (5) + 'mkdir' (5))"]
    - [exists_qn_eq,      Path.exists.__qualname__.__eq__,      ["Path.exists"],     true, "pathlib.Path.exists.__qualname__ == 'Path.exists'"]
    - [exists_qn_len,     Path.exists.__qualname__.__len__,     [],                  11,   "pathlib.Path.exists.__qualname__.__len__() == 11 ('Path.exists' = 'Path.' (5) + 'exists' (6))"]
    - [iterdir_qn_eq,     Path.iterdir.__qualname__.__eq__,     ["Path.iterdir"],    true, "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir'"]
    - [iterdir_qn_len,    Path.iterdir.__qualname__.__len__,    [],                  12,   "pathlib.Path.iterdir.__qualname__.__len__() == 12 ('Path.iterdir' = 'Path.' (5) + 'iterdir' (7))"]
    - [read_text_qn_eq,   Path.read_text.__qualname__.__eq__,   ["Path.read_text"],  true, "pathlib.Path.read_text.__qualname__ == 'Path.read_text'"]
    - [read_text_qn_len,  Path.read_text.__qualname__.__len__,  [],                  14,   "pathlib.Path.read_text.__qualname__.__len__() == 14 ('Path.read_text' = 'Path.' (5) + 'read_text' (9))"]
    - [write_text_qn_eq,  Path.write_text.__qualname__.__eq__,  ["Path.write_text"], true, "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (longest __qualname__ among the covered Path methods)"]
    - [write_text_qn_len, Path.write_text.__qualname__.__len__, [],                  15,   "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' = 'Path.' (5) + 'write_text' (10))"]

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ for stat, unlink, rename, glob
# Path.stat.__qualname__ == 'Path.stat' (9); Path.unlink == 'Path.unlink' (11).
# Path.rename == 'Path.rename' (11); Path.glob == 'Path.glob' (9).
# open, stat, and glob all tie at length 9 (the shortest among the ten covered).
# unlink, rename, exists all tie at length 11.
# ---------------------------------------------------------------------------

table pathlib_extra149.Path_method_qualnames_aux:
  description: "pathlib.Path method __qualname__ lengths for stat=9, unlink=11, rename=11, glob=9; all match 'Path.<method>' pattern"
  kind: python_call_eq
  category: function_identity
  id_prefix: pathlibqn149

  columns: [id, function, args, expected, description]
  rows:
    - [stat_qn_eq,    Path.stat.__qualname__.__eq__,   ["Path.stat"],   true, "pathlib.Path.stat.__qualname__ == 'Path.stat'"]
    - [stat_qn_len,   Path.stat.__qualname__.__len__,  [],              9,    "pathlib.Path.stat.__qualname__.__len__() == 9 (same length as Path.open and Path.glob)"]
    - [stat_mod_eq,   Path.stat.__module__.__eq__,     ["pathlib"],     true, "pathlib.Path.stat.__module__ == 'pathlib'"]
    - [unlink_qn_eq,  Path.unlink.__qualname__.__eq__, ["Path.unlink"], true, "pathlib.Path.unlink.__qualname__ == 'Path.unlink'"]
    - [unlink_qn_len, Path.unlink.__qualname__.__len__,[],              11,   "pathlib.Path.unlink.__qualname__.__len__() == 11 (same length as Path.exists and Path.rename)"]
    - [rename_qn_eq,  Path.rename.__qualname__.__eq__, ["Path.rename"], true, "pathlib.Path.rename.__qualname__ == 'Path.rename'"]
    - [rename_qn_len, Path.rename.__qualname__.__len__,[],              11,   "pathlib.Path.rename.__qualname__.__len__() == 11 (ties with Path.exists and Path.unlink)"]
    - [glob_qn_eq,    Path.glob.__qualname__.__eq__,   ["Path.glob"],   true, "pathlib.Path.glob.__qualname__ == 'Path.glob'"]
    - [glob_qn_len,   Path.glob.__qualname__.__len__,  [],              9,    "pathlib.Path.glob.__qualname__.__len__() == 9 (ties with Path.stat and Path.open for shortest among the ten covered Path methods)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath method __qualname__ values and lengths
# PurePath.joinpath == 'PurePath.joinpath' (17).
# PurePath.with_name == 'PurePath.with_name' (18).
# PurePath.with_suffix == 'PurePath.with_suffix' (20).
# PurePath.is_relative_to == 'PurePath.is_relative_to' (23; longest).
# ---------------------------------------------------------------------------

table pathlib_extra149.PurePath_method_qualnames:
  description: "pathlib.PurePath method __qualname__ lengths: joinpath=17, with_name=18, with_suffix=20, is_relative_to=23; all match 'PurePath.<method>' pattern"
  kind: python_call_eq
  category: function_identity
  id_prefix: pathlibqn149

  columns: [id, function, args, expected, description]
  rows:
    - [joinpath_qn_eq,       PurePath.joinpath.__qualname__.__eq__,       ["PurePath.joinpath"],       true, "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath'"]
    - [joinpath_qn_len,      PurePath.joinpath.__qualname__.__len__,      [],                          17,   "pathlib.PurePath.joinpath.__qualname__.__len__() == 17 ('PurePath.joinpath' = 'PurePath.' (9) + 'joinpath' (8))"]
    - [joinpath_mod_eq,      PurePath.joinpath.__module__.__eq__,         ["pathlib"],                 true, "pathlib.PurePath.joinpath.__module__ == 'pathlib'"]
    - [with_name_qn_eq,      PurePath.with_name.__qualname__.__eq__,      ["PurePath.with_name"],      true, "pathlib.PurePath.with_name.__qualname__ == 'PurePath.with_name'"]
    - [with_name_qn_len,     PurePath.with_name.__qualname__.__len__,     [],                          18,   "pathlib.PurePath.with_name.__qualname__.__len__() == 18 ('PurePath.with_name' = 'PurePath.' (9) + 'with_name' (9))"]
    - [with_suffix_qn_eq,    PurePath.with_suffix.__qualname__.__eq__,    ["PurePath.with_suffix"],    true, "pathlib.PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix'"]
    - [with_suffix_qn_len,   PurePath.with_suffix.__qualname__.__len__,   [],                          20,   "pathlib.PurePath.with_suffix.__qualname__.__len__() == 20 ('PurePath.with_suffix' = 'PurePath.' (9) + 'with_suffix' (11))"]
    - [is_rel_to_qn_eq,      PurePath.is_relative_to.__qualname__.__eq__, ["PurePath.is_relative_to"], true, "pathlib.PurePath.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (longest covered PurePath qualname)"]
    - [is_rel_to_qn_len,     PurePath.is_relative_to.__qualname__.__len__,[],                          23,   "pathlib.PurePath.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' = 'PurePath.' (9) + 'is_relative_to' (14))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra149.Path.write_text.qualname_len_15:
  description: "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' is the longest __qualname__ among the ten covered Path methods: 'Path.' prefix (5) + 'write_text' (10) = 15; it is 1 character longer than Path.read_text (14) and 6 longer than Path.open/Path.stat/Path.glob (9))"
  category: function_identity
  kind: python_call_eq
  function: Path.write_text.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra149.Path.read_text.qualname_eq:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (all pathlib.Path methods follow the 'Path.<method_name>' qualname pattern; Path.read_text.__qualname__ confirms this for the convenience method that reads an entire file as a string)"
  category: function_identity
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra149.Path.open.qualname_len_9:
  description: "pathlib.Path.open.__qualname__.__len__() == 9 ('Path.open' = 'Path.' (5) + 'open' (4) = 9; tied with Path.stat and Path.glob for the shortest __qualname__ length among the ten covered Path methods; shorter than Path.mkdir (10) and Path.exists/Path.unlink/Path.rename (all 11))"
  category: function_identity
  kind: python_call_eq
  function: Path.open.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra149.PurePath.is_relative_to.qualname_len_23:
  description: "pathlib.PurePath.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' = 'PurePath.' (9) + 'is_relative_to' (14) = 23; the longest __qualname__ among all covered pathlib methods — 3 more than PurePath.with_suffix (20), 5 more than PurePath.with_name (18), 6 more than PurePath.joinpath (17))"
  category: function_identity
  kind: python_call_eq
  function: PurePath.is_relative_to.__qualname__.__len__
  args: []
  expected: 23

invariant pathlib_extra149.PurePath.joinpath.module_eq_pathlib:
  description: "pathlib.PurePath.joinpath.__module__ == 'pathlib' (all covered pathlib methods — both on Path and PurePath — have __module__ == 'pathlib'; this is consistent with their definition in Lib/pathlib/_abc.py and Lib/pathlib/_local.py which are part of the pathlib package)"
  category: function_identity
  kind: python_call_eq
  function: PurePath.joinpath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra149.Path.exists.qualname_eq:
  description: "pathlib.Path.exists.__qualname__ == 'Path.exists' (confirms the 'Path.<method>' qualname pattern for Path.exists; the method tests whether the path refers to an existing file system entry; __qualname__ length is 11, tied with Path.unlink and Path.rename)"
  category: function_identity
  kind: python_call_eq
  function: Path.exists.__qualname__.__eq__
  args: ["Path.exists"]
  expected: true

invariant pathlib_extra149.Path.iterdir.qualname_len_12:
  description: "pathlib.Path.iterdir.__qualname__.__len__() == 12 ('Path.iterdir' = 'Path.' (5) + 'iterdir' (7) = 12; longer than Path.exists/Path.unlink/Path.rename (all 11), shorter than Path.read_text (14) and Path.write_text (15); iterdir is the directory-listing method that yields child Path objects)"
  category: function_identity
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__len__
  args: []
  expected: 12
