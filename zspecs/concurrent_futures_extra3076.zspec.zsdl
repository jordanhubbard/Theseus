spec: cf3076
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (cf3076): __get__, __set__, __delete__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor."
    - "All four classes return false for __get__, __set__, and __delete__ in their own __dict__."
    - "concurrent.futures classes are thread/process pool abstractions and result holders; none implement the descriptor protocol."
    - "concurrent.futures.Executor defines __enter__/__exit__ (wave 650) for synchronous context management, but no descriptor protocol methods."
    - "concurrent.futures.Future holds a deferred computation result; it is not a descriptor and defines none of __get__, __set__, __delete__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
#
# No concurrent.futures class defines __get__ in its own __dict__; all false.
# concurrent.futures classes are executor and future abstractions; none serve
# as descriptors mediating attribute access on other objects.
# ---------------------------------------------------------------------------

table cf3076.get:
  description: "concurrent.futures types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3076

  columns: [id, function, args, expected]
  rows:
    - ["cf3076001", operator.contains, [concurrent.futures.Future.__dict__,              "__get__"], false]
    - ["cf3076002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__get__"], false]
    - ["cf3076003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__get__"], false]
    - ["cf3076004", operator.contains, [concurrent.futures.Executor.__dict__,            "__get__"], false]

# ---------------------------------------------------------------------------
# __set__ dict-presence — operator.contains(Cls.__dict__, '__set__')
#
# No concurrent.futures class defines __set__ in its own __dict__; all false.
# __set__ is the data-descriptor setter hook; none of these executor or future
# classes act as data descriptors on other objects.
# ---------------------------------------------------------------------------

table cf3076.set:
  description: "concurrent.futures types __set__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3076

  columns: [id, function, args, expected]
  rows:
    - ["cf3076005", operator.contains, [concurrent.futures.Future.__dict__,              "__set__"], false]
    - ["cf3076006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__set__"], false]
    - ["cf3076007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__set__"], false]
    - ["cf3076008", operator.contains, [concurrent.futures.Executor.__dict__,            "__set__"], false]

# ---------------------------------------------------------------------------
# __delete__ dict-presence — operator.contains(Cls.__dict__, '__delete__')
#
# No concurrent.futures class defines __delete__ in its own __dict__; all false.
# __delete__ is the data-descriptor deletion hook; not applicable to any
# concurrent.futures class.
# ---------------------------------------------------------------------------

table cf3076.delete:
  description: "concurrent.futures types __delete__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3076

  columns: [id, function, args, expected]
  rows:
    - ["cf3076009",  operator.contains, [concurrent.futures.Future.__dict__,              "__delete__"], false]
    - ["cf3076010",  operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__delete__"], false]
    - ["cf3076011",  operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__delete__"], false]
    - ["cf3076012",  operator.contains, [concurrent.futures.Executor.__dict__,            "__delete__"], false]

# ---------------------------------------------------------------------------
# combined — __get__, __set__, __delete__ across all 4 cf subjects
#
# Covers the full matrix: 4 classes x 3 methods = 12 rows.
# __get__:    all false — no concurrent.futures class is a descriptor.
# __set__:    all false — no concurrent.futures class is a data descriptor.
# __delete__: all false — no concurrent.futures class defines __delete__.
# All three descriptor protocol methods are absent from all four classes' own __dict__.
# ---------------------------------------------------------------------------

