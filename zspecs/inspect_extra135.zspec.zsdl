# ---------------------------------------------------------------------------
# Table 1: inspect.getdoc and inspect.getfile qualnames and code attributes
#
# Wave 263 theme: inspect.getdoc and inspect.getfile function identity.
#
# inspect.getdoc.__qualname__ == 'getdoc' (len 6)
# inspect.getdoc.__module__ == 'inspect'
# inspect.getdoc.__code__.co_argcount == 1
# len(inspect.getdoc.__code__.co_varnames) == 2
# inspect.getdoc.__code__.co_varnames[0] == 'object'
# inspect.getfile.__qualname__ == 'getfile' (len 7)
# inspect.getfile.__module__ == 'inspect'
# inspect.getfile.__code__.co_argcount == 1
# len(inspect.getfile.__code__.co_varnames) == 2
# inspect.getfile.__code__.co_varnames[0] == 'object'
#
# getdoc retrieves the docstring for an object; getfile retrieves the source
# file for an object. Both are defined at module scope in Lib/inspect.py. New to extra135.
# ---------------------------------------------------------------------------

table inspect_extra135.getdoc_getfile_attrs:
  description: "inspect.getdoc qualname len 6, co_argcount==1, co_varnames len 2; inspect.getfile qualname len 7, co_argcount==1, co_varnames len 2; wave 263; new to extra135"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetdocfile135

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_qualname_eq,
       "getdoc.__qualname__.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__qualname__.__eq__('getdoc') == True — getdoc is defined at module scope in Lib/inspect.py; its __qualname__ is 'getdoc'; str.__eq__('getdoc') returns True; new to extra135"]
    - [getdoc_qualname_len_eq_6,
       "getdoc.__qualname__.__len__",
       [],
       6,
       "inspect.getdoc.__qualname__.__len__() == 6 — __qualname__ is 'getdoc' which has 6 characters; len('getdoc') == 6; new to extra135"]
    - [getdoc_module_eq_inspect,
       "getdoc.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — getdoc is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra135"]
    - [getdoc_co_argcount_eq_1,
       "getdoc.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc takes one positional argument (object); co_argcount is 1; int.__eq__(1) returns True; new to extra135"]
    - [getdoc_co_varnames_len_eq_2,
       "getdoc.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getdoc.__code__.co_varnames.__len__() == 2 — getdoc has 2 local variables: object and doc; len(co_varnames) == 2; new to extra135"]
    - [getdoc_co_varnames_0_eq_object,
       "getdoc.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getdoc.__code__.co_varnames[0].__eq__('object') == True — the first local variable of getdoc is 'object', the thing whose docstring is to be retrieved; str.__eq__('object') returns True; new to extra135"]
    - [getfile_qualname_eq,
       "getfile.__qualname__.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__qualname__.__eq__('getfile') == True — getfile is defined at module scope in Lib/inspect.py; its __qualname__ is 'getfile'; str.__eq__('getfile') returns True; new to extra135"]
    - [getfile_qualname_len_eq_7,
       "getfile.__qualname__.__len__",
       [],
       7,
       "inspect.getfile.__qualname__.__len__() == 7 — __qualname__ is 'getfile' which has 7 characters; len('getfile') == 7; new to extra135"]
    - [getfile_module_eq_inspect,
       "getfile.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra135"]
    - [getfile_co_argcount_eq_1,
       "getfile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile takes one positional argument (object); co_argcount is 1; int.__eq__(1) returns True; new to extra135"]
    - [getfile_co_varnames_len_eq_2,
       "getfile.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getfile.__code__.co_varnames.__len__() == 2 — getfile has 2 local variables: object and module; len(co_varnames) == 2; new to extra135"]
    - [getfile_co_varnames_0_eq_object,
       "getfile.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getfile.__code__.co_varnames[0].__eq__('object') == True — the first local variable of getfile is 'object', the thing whose source file is to be found; str.__eq__('object') returns True; new to extra135"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getsource qualname and code attributes
#
# Wave 263 theme: inspect.getsource function identity and code attributes.
#
# inspect.getsource.__qualname__ == 'getsource' (len 9)
# inspect.getsource.__module__ == 'inspect'
# inspect.getsource.__code__.co_argcount == 1
# len(inspect.getsource.__code__.co_varnames) == 3
# inspect.getsource.__code__.co_varnames[0] == 'object'
#
# getsource returns the source code for a Python object. It calls
# getsourcelines internally. co_varnames has 3 entries: object, lines, lnum.
# New to extra135.
# ---------------------------------------------------------------------------

table inspect_extra135.getsource_attrs:
  description: "inspect.getsource qualname len 9, __module__=='inspect', co_argcount==1, co_varnames len 3, co_varnames[0]=='object'; wave 263; new to extra135"
