       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra135"]
    - [getsource_co_argcount_eq_1,
       "getsource.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsource.__code__.co_argcount.__eq__(1) == True — getsource takes one positional argument (object); co_argcount is 1; int.__eq__(1) returns True; new to extra135"]
    - [getsource_co_varnames_len_eq_3,
       "getsource.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.getsource.__code__.co_varnames.__len__() == 3 — getsource has 3 local variables: object, lines, lnum; len(co_varnames) == 3; new to extra135"]
    - [getsource_co_varnames_0_eq_object,
       "getsource.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getsource.__code__.co_varnames[0].__eq__('object') == True — the first local variable of getsource is 'object', the Python object whose source is to be retrieved; str.__eq__('object') returns True; new to extra135"]

