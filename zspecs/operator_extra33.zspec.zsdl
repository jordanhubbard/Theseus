spec: operator_extra33
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra32.zspec.zsdl."
    - "Prior specs covered: __name__/__module__ for all core functions, __qualname__.__len__() for add/sub/mul/attrgetter/itemgetter/methodcaller, __mro__/__bases__ for attrgetter/itemgetter/methodcaller, __name__.__len__() for ne/gt/ge/le/neg/mod/lshift/rshift/floordiv, __module__.__len__() for itemgetter/methodcaller/sub/mul/neg, __call__/__new__/__repr__/__reduce__ qualname lens for attrgetter/itemgetter/methodcaller, boolean/bitwise qualname lens (and_/or_/xor/not_/concat/matmul/invert/pow), truth qualname len (5), __all__.__len__() (57) and .__class__.__name__.__len__() (4), __doc__.__class__.__name__.__len__() (3), methodcaller.__mro__.__len__() (2), methodcaller.__bases__[0].__name__.__len__() (6), methodcaller.__repr__.__qualname__.__len__() (21), division qualname lens (truediv=7/floordiv=8), in-place qualname lens (iadd/isub/imul/imod/ipow=4, itruediv=8, ifloordiv=9, ilshift=7, irshift=7), callable class qualname lens (attrgetter=10, itemgetter=10, methodcaller=12)."
    - "This spec covers: comparison function __qualname__.__len__() for lt/le/eq/ne/gt/ge (all 2 — short two-letter names); __dict__.__class__.__name__.__len__() for attrgetter/itemgetter/methodcaller (all mappingproxy=12); operator.__name__.__len__() (8 — 'operator'); sequence/item operator __qualname__.__len__() for abs/neg/pos (3 each), index (5), contains (8), getitem/setitem/delitem (7 each), length_hint (11)."
    - "Key findings: All six comparison operators (lt/le/eq/ne/gt/ge) have __qualname__ equal to their 2-character name. attrgetter/itemgetter/methodcaller class __dict__ is mappingproxy (12) — the standard class namespace type. abs/neg/pos share qualname length 3; getitem/setitem/delitem share qualname length 7. length_hint is the longest at 11 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — comparison operator functions
#
# operator.lt, le, eq, ne, gt, ge all have __qualname__ equal to their
# two-character function name. len('lt') == len('le') == len('eq') ==
# len('ne') == len('gt') == len('ge') == 2. These six comparison operators
# are the shortest-named functions in the operator module — shorter even than
# abs/neg/pos (3 chars). No prior operator spec records __qualname__.__len__()
# for any of these six comparison functions.
# ---------------------------------------------------------------------------

table operator_extra33.comparison_qualname_lengths:
  description: "__qualname__.__len__() for comparison operator functions — all 2 (two-letter names)"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [lt,
       lt.__qualname__.__len__,
       [],
       2,
       "len(operator.lt.__qualname__) == 2 — 'lt'"]
    - [le,
       le.__qualname__.__len__,
       [],
       2,
       "len(operator.le.__qualname__) == 2 — 'le'"]
    - [eq,
       eq.__qualname__.__len__,
       [],
       2,
       "len(operator.eq.__qualname__) == 2 — 'eq'"]
    - [ne,
       ne.__qualname__.__len__,
       [],
       2,
       "len(operator.ne.__qualname__) == 2 — 'ne'"]
    - [gt,
       gt.__qualname__.__len__,
       [],
       2,
       "len(operator.gt.__qualname__) == 2 — 'gt'"]
    - [ge,
       ge.__qualname__.__len__,
       [],
       2,
       "len(operator.ge.__qualname__) == 2 — 'ge'"]

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table — callable class types
#
# operator.attrgetter, itemgetter, and methodcaller are C-implemented callable
# classes. Each stores its class namespace as a mappingproxy (length 12),
# consistent with all C-level and Python-level classes in CPython. No prior
# operator spec records __dict__.__class__.__name__.__len__() for any of these
# three callable classes.
# ---------------------------------------------------------------------------

table operator_extra33.callable_class_dict_type_lens:
  description: "__dict__.__class__.__name__.__len__() for operator callable classes — all mappingproxy (12)"
  kind: python_call_eq
  category: dict_type_checks
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [attrgetter,
       attrgetter.__dict__.__class__.__name__.__len__,
       [],
       12,
       "operator.attrgetter.__dict__.__class__.__name__ == 'mappingproxy' (length 12)"]
    - [itemgetter,
       itemgetter.__dict__.__class__.__name__.__len__,
       [],
       12,
       "operator.itemgetter.__dict__.__class__.__name__ == 'mappingproxy' (length 12)"]
    - [methodcaller,
       methodcaller.__dict__.__class__.__name__.__len__,
       [],
       12,
       "operator.methodcaller.__dict__.__class__.__name__ == 'mappingproxy' (length 12)"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — sequence and item operator functions
#
# operator.abs, neg, pos each have __qualname__ length 3. operator.index has
# length 5. operator.contains has length 8. operator.getitem, setitem, and
# delitem all have length 7. operator.length_hint has the longest qualname
# among these at 11. No prior operator spec records __qualname__.__len__() for
# any of these sequence/item operators.
# ---------------------------------------------------------------------------

table operator_extra33.sequence_item_qualname_lengths:
  description: "__qualname__.__len__() for sequence and item operator functions"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [abs,
       abs.__qualname__.__len__,
       [],
       3,
       "len(operator.abs.__qualname__) == 3 — 'abs'"]
    - [neg,
       neg.__qualname__.__len__,
       [],
       3,
       "len(operator.neg.__qualname__) == 3 — 'neg'"]
    - [pos,
       pos.__qualname__.__len__,
       [],
       3,
       "len(operator.pos.__qualname__) == 3 — 'pos'"]
    - [index,
       index.__qualname__.__len__,
       [],
       5,
       "len(operator.index.__qualname__) == 5 — 'index'"]
    - [contains,
       contains.__qualname__.__len__,
       [],
       8,
       "len(operator.contains.__qualname__) == 8 — 'contains'"]
    - [getitem,
       getitem.__qualname__.__len__,
       [],
       7,
       "len(operator.getitem.__qualname__) == 7 — 'getitem'"]
    - [setitem,
       setitem.__qualname__.__len__,
       [],
       7,
       "len(operator.setitem.__qualname__) == 7 — 'setitem'"]
    - [delitem,
       delitem.__qualname__.__len__,
       [],
       7,
       "len(operator.delitem.__qualname__) == 7 — 'delitem'"]
    - [length_hint,
       length_hint.__qualname__.__len__,
       [],
       11,
       "len(operator.length_hint.__qualname__) == 11 — 'length_hint'"]

# ---------------------------------------------------------------------------
# operator.__name__.__len__() — standalone invariant
#
# operator.__name__ == 'operator' (length 8). This anchors the module identity
# string for the operator module. The name 'operator' was mentioned in
# extra32 key findings but not recorded as an invariant or table row.
# No prior operator spec records operator.__name__.__len__() as an invariant.
# ---------------------------------------------------------------------------

invariant operator_extra33.module_name_len:
  description: "len(operator.__name__) == 8 — module name is 'operator' (8 characters)"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 8
