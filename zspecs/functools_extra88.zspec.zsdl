       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is a pure-Python class decorator defined in Lib/functools.py; its __qualname__ attribute is the string 'total_ordering' (14 chars); str.__eq__('total_ordering') returns True; no prior functools spec checks total_ordering.__qualname__.__eq__ via functoolsextra88; new to extra88"]
    - [lru_cache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a pure-Python decorator defined in Lib/functools.py; its __qualname__ attribute is the string 'lru_cache' (9 chars); str.__eq__('lru_cache') returns True; no prior functools spec checks lru_cache.__qualname__.__eq__ via functoolsextra88; new to extra88"]
    - [cache_qualname_eq,
       cache.__qualname__.__eq__,
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — cache is a pure-Python function defined in Lib/functools.py; its __qualname__ attribute is the string 'cache' (5 chars); str.__eq__('cache') returns True; no prior functools spec checks cache.__qualname__.__eq__ via functoolsextra88; new to extra88"]

