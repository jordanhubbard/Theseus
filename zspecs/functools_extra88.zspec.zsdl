  category: type_identity
  id_prefix: functoolsextra88

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a pure-Python decorator defined in Lib/functools.py; its __qualname__ attribute is the string 'singledispatch' (14 chars); str.__eq__('singledispatch') returns True; no prior functools spec checks singledispatch.__qualname__.__eq__ via functoolsextra88; new to extra88"]
    - [total_ordering_qualname_eq,
       total_ordering.__qualname__.__eq__,
