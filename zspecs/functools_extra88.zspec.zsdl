spec: functools_extra88
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra87

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra87.zspec.zsdl."
    - "This spec covers: functools partial C-type __reduce__/__setstate__ qualname strings + cached_property slot descriptor identity (Wave 247)."
    - "partial.__reduce__.__qualname__ == 'partial.__reduce__' — C slot wrapper qualname. Verified with Python 3.14.3."
    - "partial.__setstate__.__qualname__ == 'partial.__setstate__' — C slot wrapper qualname. Verified with Python 3.14.3."
    - "partial.__new__.__qualname__ == 'partial.__new__' — C slot wrapper qualname. Verified with Python 3.14.3."
    - "partial.__repr__.__qualname__ == 'partial.__repr__' — C slot wrapper qualname. Verified with Python 3.14.3."
    - "partial.__call__.__qualname__ == 'partial.__call__' — C slot wrapper qualname. Verified with Python 3.14.3."
    - "cached_property.__get__.__qualname__ == 'cached_property.__get__' — Python descriptor method qualname. Verified with Python 3.14.3."
    - "cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' — Python descriptor method qualname. Verified with Python 3.14.3."
    - "cached_property.__init__.__qualname__ == 'cached_property.__init__' — Python class initializer qualname. Verified with Python 3.14.3."
    - "singledispatch.__qualname__ == 'singledispatch' — pure-Python decorator. Verified with Python 3.14.3."
    - "total_ordering.__qualname__ == 'total_ordering' — pure-Python class decorator. Verified with Python 3.14.3."
    - "lru_cache.__qualname__ == 'lru_cache' — pure-Python decorator. Verified with Python 3.14.3."
    - "cache.__qualname__ == 'cache' — pure-Python function. Verified with Python 3.14.3."
    - "wraps.__qualname__ == 'wraps' — pure-Python decorator. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial C-type method qualname strings — group 1 — extra88
#
# Wave 247 theme: partial C-type __reduce__/__setstate__/__new__ qualname strings.
#
# functools.partial.__reduce__.__qualname__  == 'partial.__reduce__'
# functools.partial.__setstate__.__qualname__ == 'partial.__setstate__'
# functools.partial.__new__.__qualname__     == 'partial.__new__'
# functools.partial.__repr__.__qualname__    == 'partial.__repr__'
#
# No prior functools spec checks partial C-type method qualname strings via functoolsextra88. New to extra88.
# ---------------------------------------------------------------------------

table functools_extra88.partial_method_qualnames_group1:
  description: "partial.__reduce__/__setstate__/__new__/__repr__ qualname strings; wave 247 partial C-type method qualnames; new to extra88"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra88

  columns: [id, function, args, expected, description]
  rows:
    - [partial_reduce_qualname_eq,
       partial.__reduce__.__qualname__.__eq__,
       ["partial.__reduce__"],
       true,
       "functools.partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True — partial is a C extension type; __reduce__ is a slot wrapper; its __qualname__ is 'partial.__reduce__' (16 chars); str.__eq__('partial.__reduce__') returns True; no prior functools spec checks partial.__reduce__.__qualname__ via functoolsextra88; new to extra88"]
    - [partial_setstate_qualname_eq,
       partial.__setstate__.__qualname__.__eq__,
       ["partial.__setstate__"],
       true,
       "functools.partial.__setstate__.__qualname__.__eq__('partial.__setstate__') == True — partial is a C extension type; __setstate__ is a slot wrapper; its __qualname__ is 'partial.__setstate__' (20 chars); str.__eq__('partial.__setstate__') returns True; no prior functools spec checks partial.__setstate__.__qualname__ via functoolsextra88; new to extra88"]
    - [partial_new_qualname_eq,
       partial.__new__.__qualname__.__eq__,
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — partial is a C extension type; __new__ is a slot wrapper; its __qualname__ is 'partial.__new__' (15 chars); str.__eq__('partial.__new__') returns True; no prior functools spec checks partial.__new__.__qualname__ via functoolsextra88; new to extra88"]
    - [partial_repr_qualname_eq,
       partial.__repr__.__qualname__.__eq__,
       ["partial.__repr__"],
       true,
       "functools.partial.__repr__.__qualname__.__eq__('partial.__repr__') == True — partial is a C extension type; __repr__ is a slot wrapper; its __qualname__ is 'partial.__repr__' (16 chars); str.__eq__('partial.__repr__') returns True; no prior functools spec checks partial.__repr__.__qualname__ via functoolsextra88; new to extra88"]

# ---------------------------------------------------------------------------
# partial C-type __call__ qualname + cached_property method qualnames — extra88
#
# Wave 247 theme: partial __call__ qualname and cached_property method qualnames.
#
# functools.partial.__call__.__qualname__             == 'partial.__call__'
# functools.cached_property.__get__.__qualname__      == 'cached_property.__get__'
# functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'
# functools.cached_property.__init__.__qualname__     == 'cached_property.__init__'
#
# No prior functools spec checks partial.__call__ qualname or cached_property method qualnames via functoolsextra88. New to extra88.
# ---------------------------------------------------------------------------

table functools_extra88.partial_call_and_cached_property_qualnames:
  description: "partial.__call__ qualname; cached_property.__get__/__set_name__/__init__ qualnames; wave 247 C-type and cached_property method qualnames; new to extra88"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra88

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_qualname_eq,
       partial.__call__.__qualname__.__eq__,
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — partial is a C extension type; __call__ is a slot wrapper; its __qualname__ is 'partial.__call__' (16 chars); str.__eq__('partial.__call__') returns True; no prior functools spec checks partial.__call__.__qualname__ via functoolsextra88; new to extra88"]
    - [cached_property_get_qualname_eq,
       cached_property.__get__.__qualname__.__eq__,
       ["cached_property.__get__"],
       true,
       "functools.cached_property.__get__.__qualname__.__eq__('cached_property.__get__') == True — cached_property is a pure-Python descriptor class in Lib/functools.py; __get__ is a method; its __qualname__ is 'cached_property.__get__' (23 chars); str.__eq__('cached_property.__get__') returns True; no prior functools spec checks cached_property.__get__.__qualname__ via functoolsextra88; new to extra88"]
    - [cached_property_set_name_qualname_eq,
       cached_property.__set_name__.__qualname__.__eq__,
       ["cached_property.__set_name__"],
       true,
       "functools.cached_property.__set_name__.__qualname__.__eq__('cached_property.__set_name__') == True — cached_property is a pure-Python descriptor class in Lib/functools.py; __set_name__ is a method; its __qualname__ is 'cached_property.__set_name__' (28 chars); str.__eq__('cached_property.__set_name__') returns True; no prior functools spec checks cached_property.__set_name__.__qualname__ via functoolsextra88; new to extra88"]
    - [cached_property_init_qualname_eq,
       cached_property.__init__.__qualname__.__eq__,
       ["cached_property.__init__"],
       true,
       "functools.cached_property.__init__.__qualname__.__eq__('cached_property.__init__') == True — cached_property is a pure-Python descriptor class in Lib/functools.py; __init__ is the initializer; its __qualname__ is 'cached_property.__init__' (24 chars); str.__eq__('cached_property.__init__') returns True; no prior functools spec checks cached_property.__init__.__qualname__ via functoolsextra88; new to extra88"]

# ---------------------------------------------------------------------------
# singledispatch and total_ordering __qualname__ equality — extra88
#
# Wave 247 theme: singledispatch/total_ordering/lru_cache __qualname__ equality.
#
# functools.singledispatch.__qualname__  == 'singledispatch'
# functools.total_ordering.__qualname__  == 'total_ordering'
# functools.lru_cache.__qualname__       == 'lru_cache'
# functools.cache.__qualname__           == 'cache'
#
# No prior functools spec checks singledispatch/total_ordering qualname equality via functoolsextra88. New to extra88.
# ---------------------------------------------------------------------------

