  not_derived_from:
    - "any third-party asyncio extensions"
  notes:
    - "Tests attribute access protocol membership in asyncio types"
    - "asyncio primitives inherit attr protocol from object; none define custom __getattr__"
    - "introspection methods (__dir__, __sizeof__) inherited from object, not in class __dict__"
