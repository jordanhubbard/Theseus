spec: io_extra19
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra18.zspec.zsdl."
    - "io_extra18 covers: StringIO/BytesIO __mro__[1].__name__; __mro__ length; IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__; SEEK_SET/SEEK_CUR/SEEK_END constants; DEFAULT_BUFFER_SIZE type and sign."
    - "No prior io spec covers __qualname__ for StringIO, BytesIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper, or UnsupportedOperation."
    - "No prior io spec covers io.UnsupportedOperation.__bases__[0].__name__ == 'OSError'."
    - "io.StringIO.__qualname__ == 'StringIO' — matches class name since no outer class."
    - "io.BytesIO.__qualname__ == 'BytesIO' — matches class name since no outer class."
    - "io.FileIO.__qualname__ == 'FileIO' — matches class name since no outer class."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — matches class name since no outer class."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — matches class name since no outer class."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — matches class name since no outer class."
    - "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — matches class name."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — primary base is OSError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __qualname__ attributes
#
# No prior io spec covers __qualname__ for any of these classes.
# For top-level classes, __qualname__ equals __name__ (no enclosing class).
# StringIO, BytesIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper,
# and UnsupportedOperation are all top-level classes in the io module.
# ---------------------------------------------------------------------------

invariant io_extra19.StringIO.qualname:
  description: "io.StringIO.__qualname__ == 'StringIO' — top-level class, qualname == name"
  category: qualnames
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra19.BytesIO.qualname:
  description: "io.BytesIO.__qualname__ == 'BytesIO' — top-level class, qualname == name"
  category: qualnames
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra19.FileIO.qualname:
  description: "io.FileIO.__qualname__ == 'FileIO' — top-level class, qualname == name"
  category: qualnames
  kind: python_call_eq
  function: FileIO.__qualname__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra19.BufferedReader.qualname:
  description: "io.BufferedReader.__qualname__ == 'BufferedReader' — top-level class, qualname == name"
  category: qualnames
  kind: python_call_eq
  function: BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra19.BufferedWriter.qualname:
  description: "io.BufferedWriter.__qualname__ == 'BufferedWriter' — top-level class, qualname == name"
  category: qualnames
  kind: python_call_eq
  function: BufferedWriter.__qualname__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra19.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — top-level class, qualname == name"
  category: qualnames
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra19.UnsupportedOperation.qualname:
  description: "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — top-level class"
  category: qualnames
  kind: python_call_eq
  function: UnsupportedOperation.__qualname__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

# ---------------------------------------------------------------------------
# io.UnsupportedOperation.__bases__[0].__name__ — primary base class
#
# No prior io spec covers the base classes of UnsupportedOperation.
# UnsupportedOperation inherits from OSError and ValueError. Its primary
# base (MRO position 1, __bases__[0]) is OSError.
# ---------------------------------------------------------------------------

invariant io_extra19.UnsupportedOperation.base0_name:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — primary base is OSError"
  category: exception_bases
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

invariant io_extra19.UnsupportedOperation.bases_len:
  description: "len(io.UnsupportedOperation.__bases__) == 2 — inherits from OSError and ValueError"
  category: exception_bases
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# io.StringIO instance — read() and getvalue()
#
# No prior io spec tests the read() or getvalue() methods on a StringIO
# instance initialized with a string argument. StringIO('hello').read()
# returns 'hello' (the full contents from position 0). StringIO('hello')
# .getvalue() also returns 'hello' regardless of stream position.
# ---------------------------------------------------------------------------

invariant io_extra19.StringIO.read_full:
  description: "io.StringIO('hello').read() == 'hello' — reads full initial contents"
  category: stringio_instance
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  method_args: []
  expected: "hello"

invariant io_extra19.StringIO.getvalue:
  description: "io.StringIO('hello').getvalue() == 'hello' — getvalue returns full buffer"
  category: stringio_instance
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: getvalue
  method_args: []
  expected: "hello"

invariant io_extra19.BytesIO.getvalue_empty:
  description: "io.BytesIO().getvalue() == b'' — empty BytesIO has empty buffer"
  category: bytesio_instance
  kind: python_call_eq
  function: BytesIO
  args: []
  method: getvalue
  method_args: []
  expected: !b64 ""
