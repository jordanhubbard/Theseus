spec: theseus_contextlib_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_contextlib_cr2)
blocks: contextlib

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html"
  notes:
    - "Clean-room context manager utilities (extended set). Do NOT import contextlib."
    - "suppress(*exceptions): context manager that suppresses given exceptions."
    - "redirect_stdout(new_target): redirect sys.stdout to new_target within block."
    - "ExitStack: dynamically assemble context managers."
    - "contextlib2_suppress_works(): suppress(ValueError) catches ValueError, returns True."
    - "contextlib2_suppress_reraises(): suppress(TypeError) does NOT suppress ValueError."
    - "contextlib2_exitstack(): ExitStack runs cleanup callbacks in LIFO order."
    - "Export: suppress, redirect_stdout, redirect_stderr, ExitStack."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_contextlib_cr2.suppress_works:
  description: "suppress(ValueError) catches ValueError without reraise"
  category: suppress
  kind: python_call_eq
  function: contextlib2_suppress_works
  args: []
  expected: true

invariant theseus_contextlib_cr2.suppress_reraises:
  description: "suppress(TypeError) does not suppress ValueError"
  category: suppress
  kind: python_call_eq
  function: contextlib2_suppress_reraises
  args: []
  expected: true

invariant theseus_contextlib_cr2.exitstack_lifo:
  description: "ExitStack callbacks run in LIFO order"
  category: exitstack
  kind: python_call_eq
  function: contextlib2_exitstack
  args: []
  expected: [2, 1]
