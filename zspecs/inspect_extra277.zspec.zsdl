spec: inspect_extra277
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.getsourcefile, getsourcelines, findsource, and getabsfile are all pure-Python functions."
    - "All four have __module__ == 'inspect' and __class__.__name__ == 'function'."
    - "getsourcefile.__name__ == 'getsourcefile' (13 chars)."
    - "getsourcelines.__name__ == 'getsourcelines' (14 chars)."
    - "findsource.__name__ == 'findsource' (10 chars)."
    - "getabsfile.__name__ == 'getabsfile' (10 chars)."
    - "All four qualnames match their __name__ (each is a top-level function with no enclosing class)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.getsourcefile and inspect.getsourcelines — function identity
#
# Both are pure-Python functions in the inspect module.
# getsourcefile.__name__ == 'getsourcefile' (13 chars); __module__ == 'inspect'.
# getsourcelines.__name__ == 'getsourcelines' (14 chars); __module__ == 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra277.getsourcefile_getsourcelines_identity:
  description: "inspect.getsourcefile and getsourcelines function identity — __name__, __module__, __class__.__name__; name lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex277gsf

  columns: [id, function, args, expected, description]
  rows:
    - [gsf_nm_eq,  getsourcefile.__name__.__eq__,            ["getsourcefile"], true, "inspect.getsourcefile.__name__ == 'getsourcefile'; verified with Python 3.14.3"]
    - [gsf_nm_len, getsourcefile.__name__.__len__,            [],               13,   "inspect.getsourcefile.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [gsf_mod_eq, getsourcefile.__module__.__eq__,           ["inspect"],      true, "inspect.getsourcefile.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gsf_cls_eq, getsourcefile.__class__.__name__.__eq__,   ["function"],     true, "inspect.getsourcefile.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [gsl_nm_eq,  getsourcelines.__name__.__eq__,            ["getsourcelines"], true, "inspect.getsourcelines.__name__ == 'getsourcelines'; verified with Python 3.14.3"]
    - [gsl_nm_len, getsourcelines.__name__.__len__,            [],               14,   "inspect.getsourcelines.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [gsl_mod_eq, getsourcelines.__module__.__eq__,           ["inspect"],      true, "inspect.getsourcelines.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gsl_cls_eq, getsourcelines.__class__.__name__.__eq__,   ["function"],     true, "inspect.getsourcelines.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.findsource and inspect.getabsfile — function identity
#
# Both are pure-Python functions in the inspect module.
# findsource.__name__ == 'findsource' (10 chars); __module__ == 'inspect'.
# getabsfile.__name__ == 'getabsfile' (10 chars); __module__ == 'inspect'.
# Both names share the same length (10), a coincidence to note.
# ---------------------------------------------------------------------------

table inspect_extra277.findsource_getabsfile_identity:
  description: "inspect.findsource and getabsfile function identity — __name__, __module__, __class__.__name__; name lengths both 10; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex277fga

  columns: [id, function, args, expected, description]
  rows:
    - [fs_nm_eq,  findsource.__name__.__eq__,            ["findsource"], true, "inspect.findsource.__name__ == 'findsource'; verified with Python 3.14.3"]
    - [fs_nm_len, findsource.__name__.__len__,            [],            10,   "inspect.findsource.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [fs_mod_eq, findsource.__module__.__eq__,           ["inspect"],   true, "inspect.findsource.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [fs_cls_eq, findsource.__class__.__name__.__eq__,   ["function"],  true, "inspect.findsource.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [ga_nm_eq,  getabsfile.__name__.__eq__,             ["getabsfile"], true, "inspect.getabsfile.__name__ == 'getabsfile'; verified with Python 3.14.3"]
    - [ga_nm_len, getabsfile.__name__.__len__,             [],            10,   "inspect.getabsfile.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ga_mod_eq, getabsfile.__module__.__eq__,            ["inspect"],   true, "inspect.getabsfile.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ga_cls_eq, getabsfile.__class__.__name__.__eq__,    ["function"],  true, "inspect.getabsfile.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra277
# ---------------------------------------------------------------------------

invariant inspect_extra277.getsourcefile_module_is_inspect:
  description: "inspect.getsourcefile.__module__ == 'inspect' — pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: getsourcefile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra277.getsourcefile_name_length_is_13:
  description: "inspect.getsourcefile.__name__.__len__() == 13 — 'getsourcefile' has 13 characters"
  category: identity
  kind: python_call_eq
  function: getsourcefile.__name__.__len__
  args: []
  expected: 13

invariant inspect_extra277.getsourcelines_module_is_inspect:
  description: "inspect.getsourcelines.__module__ == 'inspect' — pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: getsourcelines.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra277.getsourcelines_name_length_is_14:
  description: "inspect.getsourcelines.__name__.__len__() == 14 — 'getsourcelines' has 14 characters"
  category: identity
  kind: python_call_eq
  function: getsourcelines.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra277.findsource_module_is_inspect:
  description: "inspect.findsource.__module__ == 'inspect' — pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: findsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra277.getabsfile_module_is_inspect:
  description: "inspect.getabsfile.__module__ == 'inspect' — pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: getabsfile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra277.findsource_name_length_is_10:
  description: "inspect.findsource.__name__.__len__() == 10 — 'findsource' has 10 characters"
  category: identity
  kind: python_call_eq
  function: findsource.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra277.getabsfile_name_length_is_10:
  description: "inspect.getabsfile.__name__.__len__() == 10 — 'getabsfile' has 10 characters (same length as 'findsource')"
  category: identity
