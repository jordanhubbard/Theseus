spec: pathlib_extra328
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath string operation invariants
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# PurePosixPath('/usr/bin/python').as_posix() == '/usr/bin/python'
# PurePosixPath('relative/path').as_posix() == 'relative/path'
# PurePosixPath('/usr/bin/python').root == '/'
# PurePosixPath('relative/path').root == ''
# PurePosixPath('/usr/bin/python').drive == ''
# PurePosixPath('/usr/bin/python').anchor == '/'
# PurePosixPath('/usr/bin').is_relative_to('/usr') == True (Python 3.9+)
# PurePosixPath('/usr/bin').is_relative_to('/etc') == False
# ---------------------------------------------------------------------------

invariant pathlib_extra328.PurePosixPath.as_posix_absolute:
  description: "pathlib.PurePosixPath('/usr/bin/python').as_posix().__eq__('/usr/bin/python') == True — as_posix() round-trips an absolute POSIX path unchanged; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('/usr/bin/python').as_posix().__eq__"
  args: ["/usr/bin/python"]
  expected: true

invariant pathlib_extra328.PurePosixPath.as_posix_relative:
  description: "pathlib.PurePosixPath('relative/path').as_posix().__eq__('relative/path') == True — as_posix() round-trips a relative path unchanged; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('relative/path').as_posix().__eq__"
  args: ["relative/path"]
  expected: true

invariant pathlib_extra328.PurePosixPath.root_absolute:
  description: "pathlib.PurePosixPath('/usr/bin/python').root.__eq__('/') == True — an absolute POSIX path has root '/'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('/usr/bin/python').root.__eq__"
  args: ["/"]
  expected: true

invariant pathlib_extra328.PurePosixPath.root_relative:
  description: "pathlib.PurePosixPath('relative/path').root.__eq__('') == True — a relative path has an empty root string; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('relative/path').root.__eq__"
  args: [""]
  expected: true

invariant pathlib_extra328.PurePosixPath.drive_empty:
  description: "pathlib.PurePosixPath('/usr/bin/python').drive.__eq__('') == True — POSIX paths never have a drive component; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('/usr/bin/python').drive.__eq__"
  args: [""]
  expected: true

invariant pathlib_extra328.PurePosixPath.anchor_absolute:
  description: "pathlib.PurePosixPath('/usr/bin/python').anchor.__eq__('/') == True — anchor is drive + root; for POSIX absolute paths that is '/'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('/usr/bin/python').anchor.__eq__"
  args: ["/"]
  expected: true

invariant pathlib_extra328.PurePosixPath.is_relative_to_true:
  description: "pathlib.PurePosixPath('/usr/bin').is_relative_to('/usr') == True — /usr/bin is under /usr; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('/usr/bin').is_relative_to"
  args: ["/usr"]
  expected: true

invariant pathlib_extra328.PurePosixPath.is_relative_to_false:
  description: "pathlib.PurePosixPath('/usr/bin').is_relative_to('/etc') == False — /usr/bin is not under /etc; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "PurePosixPath('/usr/bin').is_relative_to"
  args: ["/etc"]
  expected: false

# ---------------------------------------------------------------------------
# PurePosixPath string components — table form
# root, drive, anchor for absolute vs relative paths
# ---------------------------------------------------------------------------

table pathlib_extra328.pure_posix_path_components:
  description: "pathlib.PurePosixPath component attributes: root, drive, anchor for absolute and relative paths"
  kind: python_call_eq
  category: behavioral
  id_prefix: pathlibpp328

  columns: [id, function, args, expected]
  rows:
    - [abs_as_posix,   "PurePosixPath('/usr/bin/python').as_posix().__eq__", ["/usr/bin/python"], true]
    - [rel_as_posix,   "PurePosixPath('relative/path').as_posix().__eq__",  ["relative/path"],   true]
    - [abs_root,       "PurePosixPath('/usr/bin/python').root.__eq__",       ["/"],               true]
    - [rel_root,       "PurePosixPath('relative/path').root.__eq__",         [""],                true]
    - [abs_drive,      "PurePosixPath('/usr/bin/python').drive.__eq__",      [""],                true]
    - [abs_anchor,     "PurePosixPath('/usr/bin/python').anchor.__eq__",     ["/"],               true]

# ---------------------------------------------------------------------------
# PurePosixPath.is_relative_to — table form
# ---------------------------------------------------------------------------

table pathlib_extra328.pure_posix_is_relative_to:
  description: "pathlib.PurePosixPath.is_relative_to checks for /usr/bin against /usr (True) and /etc (False)"
  kind: python_call_eq
  category: behavioral
  id_prefix: pathlibrel328

  columns: [id, function, args, expected]
  rows:
    - [rel_to_usr, "PurePosixPath('/usr/bin').is_relative_to", ["/usr"], true]
    - [rel_to_etc, "PurePosixPath('/usr/bin').is_relative_to", ["/etc"], false]
