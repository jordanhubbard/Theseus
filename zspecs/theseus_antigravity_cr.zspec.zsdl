spec: theseus_antigravity_cr
version: ">=3.0"
backend: python_cleanroom(theseus_antigravity_cr)
blocks: antigravity

docs: https://docs.python.org/3/library/antigravity.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/antigravity.html"
  not_derived_from:
    - "CPython source: Lib/antigravity.py"
  notes:
    - "Clean-room antigravity module. Do NOT import antigravity."

error_model: python_exceptions

invariant theseus_antigravity_cr.antigrav2_url:
  description: "antigravity module exposes a URL constant"
  category: behavior
  kind: python_call_eq
  function: antigrav2_url
  args: []
  expected: true

invariant theseus_antigravity_cr.antigrav2_fly:
  description: "fly() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: antigrav2_fly
  args: []
  expected: true

invariant theseus_antigravity_cr.antigrav2_geohash:
  description: "geohash() function exists and accepts args"
  category: behavior
  kind: python_call_eq
  function: antigrav2_geohash
  args: []
  expected: true
