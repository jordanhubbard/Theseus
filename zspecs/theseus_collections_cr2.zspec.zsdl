spec: theseus_collections_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_collections_cr2)
blocks: collections

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html"
  notes:
    - "Clean-room extended collections. Do NOT import collections."
    - "UserDict: mutable mapping that wraps a dict, easy to subclass."
    - "UserList: mutable sequence that wraps a list, easy to subclass."
    - "UserString: mutable string wrapper."
    - "ChainMap: multiple dict views as a single logical mapping."
    - "collections2_userdict(): UserDict({'a':1})['a'] == 1."
    - "collections2_chainmap(): ChainMap({'a':1}, {'b':2})['b'] == 2."
    - "collections2_userlist(): UserList([1,2,3])[0] == 1."
    - "Export: UserDict, UserList, UserString, ChainMap."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_collections_cr2.userdict:
  description: "UserDict({'a':1})['a'] == 1"
  category: userdict
  kind: python_call_eq
  function: collections2_userdict
  args: []
  expected: 1

invariant theseus_collections_cr2.chainmap:
  description: "ChainMap({'a':1}, {'b':2})['b'] == 2"
  category: chainmap
  kind: python_call_eq
  function: collections2_chainmap
  args: []
  expected: 2

invariant theseus_collections_cr2.userlist:
  description: "UserList([1,2,3])[0] == 1"
  category: userlist
  kind: python_call_eq
  function: collections2_userlist
  args: []
  expected: 1
