#
# Combinatoric and filtering types: product, permutations, combinations,
# combinations_with_replacement, chain, compress, dropwhile, takewhile.
# None define __ixor__ — symmetric-difference has no iterator semantics.
# ---------------------------------------------------------------------------

table itertools_extra2791.ixor_protocol:
