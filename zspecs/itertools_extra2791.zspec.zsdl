spec: itertools_extra2791
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "any proprietary source"
  notes:
    - "Wave 633 (_extra2791): __iand__, __ior__, and __ixor__ dict-presence checks (in-place bitwise AND &=, OR |=, XOR ^=)."
    - "All itertools types are lazy iterator wrappers — none define in-place bitwise operators."
    - "itertools.chain, count, repeat, cycle, islice, compress, dropwhile, takewhile: C-level types; no __iand__/__ior__/__ixor__."
    - "itertools.starmap, groupby, filterfalse, accumulate, zip_longest: C-level types; no __iand__/__ior__/__ixor__."
    - "itertools.pairwise, product, permutations, combinations, combinations_with_replacement: C-level types; no __iand__/__ior__/__ixor__."
    - "Iterator protocol (__iter__/__next__) is unrelated to in-place bitwise/set operators."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __iand__ dict-presence (in-place bitwise AND &=)
#
# Core itertools types: chain, count, repeat, cycle, islice, compress,
# dropwhile, takewhile, starmap, groupby — none define __iand__.
# ---------------------------------------------------------------------------

table itertools_extra2791.iand_protocol_core:
  description: "itertools core types __iand__ dict-presence checks — all False (no in-place bitwise AND protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2791
  columns: [id, function, args, expected]
  rows:
    - ["it2791001", "itertools.chain.__dict__.__contains__",     ["__iand__"], false]
    - ["it2791002", "itertools.count.__dict__.__contains__",     ["__iand__"], false]
    - ["it2791003", "itertools.repeat.__dict__.__contains__",    ["__iand__"], false]
    - ["it2791004", "itertools.cycle.__dict__.__contains__",     ["__iand__"], false]
    - ["it2791005", "itertools.islice.__dict__.__contains__",    ["__iand__"], false]
    - ["it2791006", "itertools.compress.__dict__.__contains__",  ["__iand__"], false]
    - ["it2791007", "itertools.dropwhile.__dict__.__contains__", ["__iand__"], false]
    - ["it2791008", "itertools.takewhile.__dict__.__contains__", ["__iand__"], false]
    - ["it2791009", "itertools.starmap.__dict__.__contains__",   ["__iand__"], false]
    - ["it2791010", "itertools.groupby.__dict__.__contains__",   ["__iand__"], false]

