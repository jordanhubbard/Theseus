spec: functools_extra1846
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, callable type checks"
    - "functools_extra.zspec.zsdl — covers __name__, __module__, partial instance class name"
    - "functools_extra1786.zspec.zsdl — covers __class_getitem__, __init_subclass__, __dict__ membership"
  notes:
    - "Wave 570 theme: arithmetic operator protocol (__add__/__sub__/__mul__/__truediv__/__floordiv__/__mod__) and comparison operator protocol (__gt__/__ge__/__le__/__ne__/__lt__/__eq__)."
    - "functools.partial.__dict__.__contains__('__add__') == False — partial is a C extension type but implements no arithmetic operators."
    - "functools.partial.__dict__.__contains__('__eq__') == True — partial defines __eq__ so two partial objects with the same function and args compare equal."
    - "functools.partial.__dict__.__contains__('__hash__') == False — because partial defines __eq__ without __hash__, Python sets __hash__ to None; it is not in the class own __dict__."
    - "functools.cached_property.__dict__.__contains__('__add__') == False — cached_property is a descriptor class with no arithmetic protocol."
    - "functools.cached_property.__dict__.__contains__('__eq__') == False — cached_property does not define __eq__; uses object identity."
    - "functools.partialmethod.__dict__.__contains__('__add__') == False — partialmethod is a pure Python descriptor with no arithmetic protocol."
    - "functools.partialmethod.__dict__.__contains__('__eq__') == False — partialmethod does not define __eq__."
    - "functools.__dict__.__contains__('total_ordering') == True — total_ordering is a public symbol in the functools namespace."
    - "functools.__dict__.__contains__('cache') == True — cache was added in Python 3.9."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operators for functools types
#
# None of the functools types (partial, cached_property, partialmethod)
# define arithmetic dunder methods in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1846.arithmetic_operators:
  description: "Arithmetic operator dunder methods absent from functools type own __dict__"
  kind: python_call_eq
  category: arithmetic_operators
  id_prefix: fu1846

  columns: [id, function, args, expected]
  rows:
    - ["fu1846001", functools.partial.__dict__.__contains__,          ["__add__"],       false]
    - ["fu1846002", functools.partial.__dict__.__contains__,          ["__sub__"],       false]
    - ["fu1846003", functools.partial.__dict__.__contains__,          ["__mul__"],       false]
    - ["fu1846004", functools.partial.__dict__.__contains__,          ["__truediv__"],   false]
    - ["fu1846005", functools.partial.__dict__.__contains__,          ["__floordiv__"],  false]
    - ["fu1846006", functools.partial.__dict__.__contains__,          ["__mod__"],       false]
    - ["fu1846007", functools.cached_property.__dict__.__contains__,  ["__add__"],       false]
    - ["fu1846008", functools.partialmethod.__dict__.__contains__,    ["__add__"],       false]

# ---------------------------------------------------------------------------
# Table 2: comparison operators for functools types
#
# partial defines __eq__ (so two partial objects with same func+args are equal)
# but does NOT define __hash__ (set to None implicitly), __lt__, __gt__,
# __le__, or __ge__.
# cached_property and partialmethod define none of the comparison operators.
# ---------------------------------------------------------------------------

table functools_extra1846.comparison_operators:
  description: "Comparison operator dunder method presence in functools type own __dict__"
  kind: python_call_eq
  category: comparison_operators
  id_prefix: fu1846

  columns: [id, function, args, expected]
  rows:
    - ["fu1846009", functools.partial.__dict__.__contains__,          ["__eq__"],   true]
    - ["fu1846010", functools.partial.__dict__.__contains__,          ["__hash__"], false]
    - ["fu1846011", functools.partial.__dict__.__contains__,          ["__lt__"],   false]
    - ["fu1846012", functools.partial.__dict__.__contains__,          ["__gt__"],   false]
    - ["fu1846013", functools.partial.__dict__.__contains__,          ["__le__"],   false]
    - ["fu1846014", functools.partial.__dict__.__contains__,          ["__ge__"],   false]
    - ["fu1846015", functools.cached_property.__dict__.__contains__,  ["__eq__"],   false]
    - ["fu1846016", functools.partialmethod.__dict__.__contains__,    ["__eq__"],   false]

# ---------------------------------------------------------------------------
# Table 3: functools module-level attribute membership
#
# Verifies the public API symbols present in the functools module namespace.
# ---------------------------------------------------------------------------

table functools_extra1846.total_ordering_attrs:
  description: "Public functools module symbols present in functools.__dict__"
  kind: python_call_eq
  category: module_attrs
  id_prefix: fu1846

  columns: [id, function, args, expected]
  rows:
    - ["fu1846017", functools.__dict__.__contains__, ["total_ordering"],  true]
    - ["fu1846018", functools.__dict__.__contains__, ["cmp_to_key"],      true]
    - ["fu1846019", functools.__dict__.__contains__, ["reduce"],          true]
    - ["fu1846020", functools.__dict__.__contains__, ["lru_cache"],       true]
    - ["fu1846021", functools.__dict__.__contains__, ["cache"],           true]
    - ["fu1846022", functools.__dict__.__contains__, ["cached_property"], true]
    - ["fu1846023", functools.__dict__.__contains__, ["partial"],         true]
    - ["fu1846024", functools.__dict__.__contains__, ["partialmethod"],   true]
    - ["fu1846025", functools.__dict__.__contains__, ["wraps"],           true]
    - ["fu1846026", functools.__dict__.__contains__, ["update_wrapper"],  true]
