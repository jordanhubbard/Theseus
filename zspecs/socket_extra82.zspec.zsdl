spec: socket_extra82
version: ">=3.9"
extends: socket_extra81
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra81.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/IPV6/SOL_SOCKET __class__.__name__=='int' / IPPROTO_TCP/__eq__(6)/IPPROTO_UDP/__eq__(17)/IPPROTO_IP/__eq__(0)/SOL_SOCKET/__eq__(65535) / SOMAXCONN/__class__/__name__=='int'/SOMAXCONN/__eq__(128) / AF_UNSPEC/__class__/__name__=='AddressFamily'/AF_UNSPEC/__eq__(0) (table + invariants)."
    - "socket_extra80.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/__class__/__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__/__name__=='SocketKind' / AF_INET/__eq__(2)/AF_INET6/__eq__(30)/SOCK_STREAM/__eq__(1)/SOCK_DGRAM/__eq__(2) / AddressFamily/SocketKind class identity (table + invariants)."
    - "socket_extra35.zspec.zsdl — covers AddressFamily/SocketKind/__mro__.__len__()==6 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra81; it does NOT duplicate invariants present in those files."
    - "Wave 249 theme: socket AF_*/SOCK_* __class__.__qualname__ identity / AddressFamily/SocketKind __qualname__ / AddressFamily/SocketKind __bases__[0].__name__ / AddressFamily/SocketKind __mro__.__len__()."
    - "socket.AF_INET.__class__.__qualname__ == 'AddressFamily' — AF_INET is an AddressFamily IntEnum member; __class__.__qualname__ equals the enum class name. No prior socket spec checks AF_INET.__class__.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__class__.__qualname__ == 'AddressFamily' — AF_INET6 is an AddressFamily IntEnum member. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__class__.__qualname__ == 'AddressFamily' — AF_UNIX is an AddressFamily IntEnum member. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.__class__.__qualname__ == 'AddressFamily' — AF_UNSPEC is an AddressFamily IntEnum member. socket_extra81 checks AF_UNSPEC.__class__.__name__; this spec checks __class__.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__qualname__ == 'SocketKind' — SOCK_STREAM is a SocketKind IntEnum member. socket_extra80 checks __class__.__name__; this spec checks __class__.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__qualname__ == 'SocketKind' — SOCK_DGRAM is a SocketKind IntEnum member. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.__class__.__qualname__ == 'SocketKind' — SOCK_RAW is a SocketKind IntEnum member. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__qualname__ == 'AddressFamily' — the AddressFamily enum class's __qualname__ equals its short name. No prior socket spec checks AddressFamily.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__qualname__ == 'SocketKind' — the SocketKind enum class's __qualname__ equals its short name. No prior socket spec checks SocketKind.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' — AddressFamily directly extends IntEnum. No prior socket spec checks AddressFamily.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' — SocketKind directly extends IntEnum. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__mro__.__len__() == 6 — AddressFamily MRO: AddressFamily, IntEnum, int, ReprEnum, Enum, object. socket_extra35 covers this; re-anchored here in wave-249 context alongside novel __qualname__ anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__mro__.__len__() == 6 — SocketKind MRO: SocketKind, IntEnum, int, ReprEnum, Enum, object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET/__class__/__qualname__ / AF_INET6/__class__/__qualname__
# socket.AF_UNIX/__class__/__qualname__ / AF_UNSPEC/__class__/__qualname__
#
# Wave 249 theme: AF_* constant __class__.__qualname__ identity.
#
# AF_INET, AF_INET6, AF_UNIX, AF_UNSPEC are all AddressFamily IntEnum members.
# Their __class__.__qualname__ == 'AddressFamily'.
# socket_extra80 checks __class__.__name__ for AF_INET/AF_INET6/AF_UNIX.
# socket_extra81 checks AF_UNSPEC.__class__.__name__ (not __qualname__).
# No prior socket spec checks __class__.__qualname__ for any AF_* constant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra82.af_constants_class_qualnames:
  description: "socket.AF_INET/__class__/__qualname__.__eq__('AddressFamily')==True / AF_INET6/__class__/__qualname__.__eq__('AddressFamily')==True / AF_UNIX/__class__/__qualname__.__eq__('AddressFamily')==True / AF_UNSPEC/__class__/__qualname__.__eq__('AddressFamily')==True — all four AF_* constants are AddressFamily IntEnum members; __class__.__qualname__ confirms the enum class name; no prior socket spec checks __class__.__qualname__ for any AF_* constant; first __class__.__qualname__ identity anchor for AF_INET/AF_INET6/AF_UNIX/AF_UNSPEC"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra82

  columns: [id, function, args, expected]
  rows:
    - [af_inet_class_qualname_addressfamily,  AF_INET.__class__.__qualname__.__eq__,  ["AddressFamily"], true]
    - [af_inet6_class_qualname_addressfamily, AF_INET6.__class__.__qualname__.__eq__, ["AddressFamily"], true]
    - [af_unix_class_qualname_addressfamily,  AF_UNIX.__class__.__qualname__.__eq__,  ["AddressFamily"], true]
    - [af_unspec_class_qualname_addressfamily, AF_UNSPEC.__class__.__qualname__.__eq__, ["AddressFamily"], true]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM/__class__/__qualname__ / SOCK_DGRAM/__class__/__qualname__
# socket.SOCK_RAW/__class__/__qualname__
#
# Wave 249 theme: SOCK_* constant __class__.__qualname__ identity.
#
# SOCK_STREAM, SOCK_DGRAM, SOCK_RAW are all SocketKind IntEnum members.
# Their __class__.__qualname__ == 'SocketKind'.
# socket_extra80 checks __class__.__name__ (not __qualname__) for these.
# No prior socket spec checks __class__.__qualname__ for any SOCK_* constant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra82.sock_constants_class_qualnames:
  description: "socket.SOCK_STREAM/__class__/__qualname__.__eq__('SocketKind')==True / SOCK_DGRAM/__class__/__qualname__.__eq__('SocketKind')==True / SOCK_RAW/__class__/__qualname__.__eq__('SocketKind')==True — SOCK_STREAM/SOCK_DGRAM/SOCK_RAW are SocketKind IntEnum members; __class__.__qualname__ confirms the SocketKind enum; socket_extra80 checks __class__.__name__; this table checks __class__.__qualname__; first __class__.__qualname__ identity anchor for SOCK_STREAM/SOCK_DGRAM/SOCK_RAW"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra82

  columns: [id, function, args, expected]
  rows:
    - [sock_stream_class_qualname_socketkind, SOCK_STREAM.__class__.__qualname__.__eq__, ["SocketKind"], true]
    - [sock_dgram_class_qualname_socketkind,  SOCK_DGRAM.__class__.__qualname__.__eq__,  ["SocketKind"], true]
    - [sock_raw_class_qualname_socketkind,    SOCK_RAW.__class__.__qualname__.__eq__,    ["SocketKind"], true]

# ---------------------------------------------------------------------------
# socket.AddressFamily/__qualname__ / socket.SocketKind/__qualname__
# socket.AddressFamily/__bases__[0]/__name__ / socket.SocketKind/__bases__[0]/__name__
#
# Wave 249 theme: AddressFamily and SocketKind enum class __qualname__ and __bases__.
#
# AddressFamily.__qualname__ == 'AddressFamily', SocketKind.__qualname__ == 'SocketKind'.
# AddressFamily.__bases__[0].__name__ == 'IntEnum', same for SocketKind.
# No prior socket spec checks __qualname__ or __bases__[0].__name__ for these enums.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra82.enum_class_qualnames_and_bases:
  description: "socket.AddressFamily/__qualname__.__eq__('AddressFamily')==True / SocketKind/__qualname__.__eq__('SocketKind')==True / AddressFamily/__bases__[0]/__name__.__eq__('IntEnum')==True / SocketKind/__bases__[0]/__name__.__eq__('IntEnum')==True — AddressFamily and SocketKind are both IntEnum subclasses; __qualname__ equals the class name; __bases__[0] is IntEnum; no prior socket spec checks __qualname__ or __bases__[0].__name__ for AddressFamily or SocketKind; first __qualname__ and __bases__ identity anchor for these enum classes"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra82

  columns: [id, function, args, expected]
  rows:
    - [addressfamily_qualname_eq,           AddressFamily.__qualname__.__eq__,             ["AddressFamily"], true]
    - [socketkind_qualname_eq,              SocketKind.__qualname__.__eq__,                ["SocketKind"],    true]
    - [addressfamily_bases0_name_intenum,   "AddressFamily.__bases__[0].__name__.__eq__",  ["IntEnum"],       true]
    - [socketkind_bases0_name_intenum,      "SocketKind.__bases__[0].__name__.__eq__",     ["IntEnum"],       true]

# ---------------------------------------------------------------------------
# socket.AddressFamily/__mro__/__len__() / socket.SocketKind/__mro__/__len__()
# socket.AddressFamily/__qualname__/__len__() / socket.SocketKind/__qualname__/__len__()
#
# Wave 249 theme: AddressFamily and SocketKind MRO length and qualname length.
#
# AddressFamily.__mro__.__len__() == 6 (established by socket_extra35).
# SocketKind.__mro__.__len__() == 6.
# AddressFamily.__qualname__.__len__() == 13 ('AddressFamily' is 13 chars).
# SocketKind.__qualname__.__len__() == 10 ('SocketKind' is 10 chars).
# No prior socket spec checks __qualname__.__len__() for AddressFamily or SocketKind.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra82.enum_mro_and_qualname_lengths:
  description: "socket.AddressFamily/__mro__/__len__()==6 / SocketKind/__mro__/__len__()==6 / AddressFamily/__qualname__/__len__()==13 / SocketKind/__qualname__/__len__()==10 — both enums have 6-entry MROs (AddressFamily/IntEnum/int/ReprEnum/Enum/object); 'AddressFamily' is 13 chars and 'SocketKind' is 10 chars; socket_extra35 establishes MRO length 6; this table cross-checks MRO lengths alongside novel __qualname__.__len__() anchors; first __qualname__.__len__() anchor for AddressFamily and SocketKind"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra82

  columns: [id, function, args, expected]
  rows:
    - [addressfamily_mro_len_6,       AddressFamily.__mro__.__len__,      [], 6]
    - [socketkind_mro_len_6,          SocketKind.__mro__.__len__,         [], 6]
    - [addressfamily_qualname_len_13, AddressFamily.__qualname__.__len__,  [], 13]
    - [socketkind_qualname_len_10,    SocketKind.__qualname__.__len__,     [], 10]

