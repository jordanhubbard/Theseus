spec: base64_extra4
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html
rfcs:
  - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
  notes:
    - "This spec extends prior base64 specs."
    - "Focus: __module__ and __name__ for base64 functions not yet covered; URL-safe base64."
    - "base64.urlsafe_b64encode(b'hello') == b'aGVsbG8='."
    - "base64.urlsafe_b64decode(b'aGVsbG8=') == b'hello'."
    - "base64.b16encode(b'hello') == b'68656C6C6F'."
    - "base64.b16decode(b'68656C6C6F') == b'hello'."
    - "base64.b32encode(b'hello') == b'NBSWY3DPEB3W64TMMQ======'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table base64_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [urlsafe_b64encode, urlsafe_b64encode.__name__.__eq__, ["urlsafe_b64encode"], true]
    - [urlsafe_b64decode, urlsafe_b64decode.__name__.__eq__, ["urlsafe_b64decode"], true]
    - [b16encode,         b16encode.__name__.__eq__,         ["b16encode"],         true]
    - [b16decode,         b16decode.__name__.__eq__,         ["b16decode"],         true]
    - [b32encode,         b32encode.__name__.__eq__,         ["b32encode"],         true]
    - [b32decode,         b32decode.__name__.__eq__,         ["b32decode"],         true]

invariant base64_extra4.urlsafe_b64encode.hello:
  description: "base64.urlsafe_b64encode(b'hello') == b'aGVsbG8='"
  category: urlsafe
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!hex 68656c6c6f]
  expected: !ascii "aGVsbG8="

invariant base64_extra4.urlsafe_b64decode.hello:
  description: "base64.urlsafe_b64decode(b'aGVsbG8=') == b'hello'"
  category: urlsafe
  kind: python_call_eq
  function: urlsafe_b64decode
  args: [!ascii "aGVsbG8="]
  expected: !hex 68656c6c6f

invariant base64_extra4.b16encode.hello:
  description: "base64.b16encode(b'hello') == b'68656C6C6F'"
  category: b16
  kind: python_call_eq
  function: b16encode
  args: [!hex 68656c6c6f]
  expected: !ascii "68656C6C6F"

invariant base64_extra4.b16decode.hello:
  description: "base64.b16decode(b'68656C6C6F') == b'hello'"
  category: b16
  kind: python_call_eq
  function: b16decode
  args: [!ascii "68656C6C6F"]
  expected: !hex 68656c6c6f

invariant base64_extra4.b32encode.hello:
  description: "base64.b32encode(b'hello') == b'NBSWY3DPEB3W64TMMQ======'"
  category: b32
  kind: python_call_eq
  function: b32encode
  args: [!hex 68656c6c6f]
  expected: !ascii "NBSWY3DPEB3W64TMMQ======"

invariant base64_extra4.b32decode.hello:
  description: "base64.b32decode(b'NBSWY3DPEB3W64TMMQ======') == b'hello'"
  category: b32
  kind: python_call_eq
  function: b32decode
  args: [!ascii "NBSWY3DPEB3W64TMMQ======"]
  expected: !hex 68656c6c6f

invariant base64_extra4.urlsafe_b64encode.returns_bytes:
  description: "base64.urlsafe_b64encode(b'test').__class__.__name__ == 'bytes'"
  category: urlsafe
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!hex 74657374]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true
