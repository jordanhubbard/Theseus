spec: decimal_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/_pydecimal.py"
    - "cpython/Modules/_decimal/_decimal.c"
  not_derived_from:
    - "any third-party decimal library"
  notes:
    - "Covers __qualname__ values for decimal.Decimal comparison and numeric operator methods"
    - "All qualnames follow the 'Decimal.method_name' pattern"
  created_at: "2026-04-12"

table decimal_extra826.decimal_qualnames:
  description: "Verify __qualname__ strings for decimal.Decimal comparison and operator methods"
  kind: python_call_eq
  category: qualname
  id_prefix: dc826dm
  columns: [id, function, args, expected]
  rows:
    - [dc826dm001, "decimal.Decimal.__eq__.__qualname__.__eq__", ["Decimal.__eq__"], true]
    - [dc826dm002, "decimal.Decimal.__ne__.__qualname__.__eq__", ["Decimal.__ne__"], true]
    - [dc826dm003, "decimal.Decimal.__lt__.__qualname__.__eq__", ["Decimal.__lt__"], true]
    - [dc826dm004, "decimal.Decimal.__le__.__qualname__.__eq__", ["Decimal.__le__"], true]
    - [dc826dm005, "decimal.Decimal.__gt__.__qualname__.__eq__", ["Decimal.__gt__"], true]
    - [dc826dm006, "decimal.Decimal.__ge__.__qualname__.__eq__", ["Decimal.__ge__"], true]
    - [dc826dm007, "decimal.Decimal.__hash__.__qualname__.__eq__", ["Decimal.__hash__"], true]
    - [dc826dm008, "decimal.Decimal.__round__.__qualname__.__eq__", ["Decimal.__round__"], true]
    - [dc826dm009, "decimal.Decimal.__floor__.__qualname__.__eq__", ["Decimal.__floor__"], true]
    - [dc826dm010, "decimal.Decimal.__ceil__.__qualname__.__eq__", ["Decimal.__ceil__"], true]
    - [dc826dm011, "decimal.Decimal.__trunc__.__qualname__.__eq__", ["Decimal.__trunc__"], true]
    - [dc826dm012, "decimal.Decimal.__copy__.__qualname__.__eq__", ["Decimal.__copy__"], true]
