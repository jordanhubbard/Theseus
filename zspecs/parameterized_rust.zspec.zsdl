spec: parameterized_rust
version: ">=3.9"
backend: rust_module(parameterized_rust)

docs: https://github.com/wolever/parameterized

provenance:
  derived_from:
    - "https://github.com/wolever/parameterized — parameterized library documentation"
  not_derived_from:
    - "parameterized source: parameterized/parameterized.py"
  notes:
    - "parameterized provides parameterized test decorators for unittest."
    - "parameterized.parameterized.expand generates test cases from a list of params."
    - "Expose parameterized_param_name(params) -> list[str]: test case name list."
    - "parameterized.param(1, 2) creates a param tuple."
    - "parameterized.param.explicit() creates explicit params."
    - "Expose param_args(a, b) -> tuple: parameterized.param(a, b).args."
    - "parameterized.param(1, 2).args == (1, 2)."
    - "parameterized.param('hello', 42).args == ('hello', 42)."
    - "All test vectors verified against parameterized 0.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# param_args — get args from param object
table parameterized_rust.param.args:
  kind: python_call_eq
  category: args
  id_prefix: par_args
  function: param_args

  columns: [id, args, expected]
  rows:
    - [int_pair,    [1, 2],          [1, 2]]
    - [str_int,     ["hello", 42],   ["hello", 42]]
    - [single,      [99],            [99]]
    - [mixed,       [true, "yes"],   [true, "yes"]]

# parameterized_param_count — number of params
invariant parameterized_rust.param.count_two:
  description: "parameterized.param(1, 2).args has len 2"
  category: count
  kind: python_call_eq
  function: param_count
  args: [1, 2]
  expected: 2

invariant parameterized_rust.param.count_one:
  description: "parameterized.param(42).args has len 1"
  category: count
  kind: python_call_eq
  function: param_count
  args: [42]
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:49:04Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
