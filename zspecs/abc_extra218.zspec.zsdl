spec: abc_extra218
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABC.__mro__.__len__() == 2 — MRO is [ABC, object]; ABC directly subclasses object; verified with Python 3.14.3."
    - "abc.ABC.__mro__[0].__name__ == 'ABC' — first MRO entry is ABC itself; verified with Python 3.14.3."
    - "abc.ABC.__mro__[1].__name__ == 'object' — second MRO entry is object; verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]; verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' — first MRO entry is ABCMeta itself; verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__[1].__name__ == 'type' — second MRO entry is type (ABCMeta subclasses type); verified with Python 3.14.3."
    - "abc.ABCMeta.__mro__[2].__name__ == 'object' — third MRO entry is object; verified with Python 3.14.3."
    - "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is defined as a plain Python function/class; its __class__.__name__ is 'function'; verified with Python 3.14.3."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — get_cache_token is a C-level builtin; verified with Python 3.14.3."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC MRO length and index checks — extra218 namespace
#
# ABC MRO: [ABC, object] — len 2
# MRO[0] is ABC itself, MRO[1] is object.
# Function paths containing '[' must be double-quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant abc_extra218.abc_mro_len:
  description: "abc.ABC.__mro__.__len__() == 2 — MRO is [ABC, object]; ABC directly subclasses object; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra218.abc_mro_0_name:
  description: "abc.ABC.__mro__[0].__name__ == 'ABC'; first MRO entry is ABC itself; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "ABC.__mro__[0].__name__.__eq__"
  args: ["ABC"]
  expected: true

invariant abc_extra218.abc_mro_1_name:
  description: "abc.ABC.__mro__[1].__name__ == 'object'; second MRO entry is object; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "ABC.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABCMeta MRO length and index checks — extra218 namespace
#
# ABCMeta MRO: [ABCMeta, type, object] — len 3
# ABCMeta is a metaclass (subclass of type), so its MRO passes through type.
# Function paths containing '[' must be double-quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant abc_extra218.abcmeta_mro_len:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]; ABCMeta subclasses type; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra218.abcmeta_mro_0_name:
  description: "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta'; first MRO entry is ABCMeta itself; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "ABCMeta.__mro__[0].__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

invariant abc_extra218.abcmeta_mro_1_name:
  description: "abc.ABCMeta.__mro__[1].__name__ == 'type'; second MRO entry is type (ABCMeta subclasses the built-in type); verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "ABCMeta.__mro__[1].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra218.abcmeta_mro_2_name:
  description: "abc.ABCMeta.__mro__[2].__name__ == 'object'; third MRO entry is object; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "ABCMeta.__mro__[2].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# abc module __class__.__name__ checks — extra218 namespace
#
# abstractmethod.__class__.__name__ == 'function' — defined as a Python class
# but classified as 'function' by CPython at the C level.
# get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C builtin.
# ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta itself.
# ---------------------------------------------------------------------------

invariant abc_extra218.abstractmethod_class_name:
  description: "abc.abstractmethod.__class__.__name__ == 'function'; abstractmethod is a plain Python function/class with __class__.__name__ 'function'; verified with Python 3.14.3"
  category: class_types
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra218.get_cache_token_class_name:
  description: "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'; get_cache_token is a C-level builtin; verified with Python 3.14.3"
  category: class_types
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra218.abc_class_name:
  description: "abc.ABC.__class__.__name__ == 'ABCMeta'; ABC is an instance of ABCMeta (its metaclass); verified with Python 3.14.3"
  category: class_types
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true
