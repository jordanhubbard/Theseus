spec: ipaddress_extra9
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"
  - "RFC 4291 — IP Version 6 Addressing Architecture"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress.zspec.zsdl — covers IPv4/IPv6 address/network attributes and error cases"
    - "ipaddress_extra.zspec.zsdl — covers __name__ and __module__ for all 6 public classes (tables), packed_is_bytes, is_private, factory return types"
    - "ipaddress_extra2.zspec.zsdl — covers IPv4/IPv6/Network __name__ (table), ip_address/ip_network/ip_interface __name__ (table), loopback class name, packed_is_bytes"
    - "ipaddress_extra3.zspec.zsdl — covers factory __module__; __bases__[0].__name__ for IPv4/IPv6Address and IPv4/IPv6Network; AddressValueError/NetmaskValueError full coverage"
    - "ipaddress_extra4.zspec.zsdl — covers IPv4Address is_private/is_loopback/is_unspecified/packed type/packed len; IPv6Address is_loopback/packed len; IPv4Network num_addresses/prefixlen/network_address class"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__ for all 6 classes, 3 factory functions, and 2 exception classes"
    - "ipaddress_extra6.zspec.zsdl — covers .version and .max_prefixlen for IPv4Address/IPv6Address/IPv4Network/IPv6Network; IPv6Address.compressed class name and loopback value"
    - "ipaddress_extra7.zspec.zsdl — covers class __name__ for all 8 symbols (table); exception __bases__ parent; IPv4Address/IPv6Address/IPv4Network __module__ (standalone)"
    - "ipaddress_extra8.zspec.zsdl — covers class_names table (4 classes); bases_count table; IPv4Address.is_global; IPv6Address.is_unspecified; IPv4Address.is_multicast; IPv6Address.is_link_local"
  notes:
    - "This spec extends the ipaddress chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: IPv4Address.compressed (not covered in any prior spec; extra6 covers IPv6Address.compressed only); IPv4Network.max_prefixlen == 32 and IPv6Network.max_prefixlen == 128 (extra6 covers these for Address classes only, not Network classes); IPv6Network.prefixlen for a /128; IPv6Network.num_addresses for a /128; IPv4Network('192.168.0.0/16').num_addresses == 65536 (extra4 covers 10.0.0.0/8 with 16777216; new prefix length); IPv4Address.is_reserved for a reserved address; IPv6Address.is_multicast for a multicast IPv6 address."
    - "ipaddress.IPv4Address('10.0.0.1').compressed == '10.0.0.1' — IPv4 compressed form is the same as the str representation. extra6 covers IPv6Address.compressed only."
    - "ipaddress.IPv4Address('10.0.0.1').compressed.__class__.__name__ == 'str' — type check for IPv4Address.compressed; extra6 checks IPv6Address.compressed.__class__.__name__."
    - "ipaddress.IPv4Network('0.0.0.0/0').max_prefixlen == 32 — max_prefixlen is a class-level constant, same regardless of prefix. extra6 covers IPv4Address.max_prefixlen and IPv6Address.max_prefixlen but NOT IPv4Network or IPv6Network."
    - "ipaddress.IPv6Network('2001:db8::/32').max_prefixlen == 128 — same rationale."
    - "ipaddress.IPv6Network('::1/128').prefixlen == 128 — extra4 covers IPv4Network.prefixlen (== 8 for 10.0.0.0/8). IPv6Network.prefixlen not covered."
    - "ipaddress.IPv6Network('::1/128').num_addresses == 1 — a /128 network has exactly one address. extra4 covers IPv4Network.num_addresses (16777216 for /8). IPv6Network.num_addresses not covered."
    - "ipaddress.IPv4Network('192.168.0.0/16').num_addresses == 65536 — extra4 covers 10.0.0.0/8 (16777216). A /16 with 65536 addresses is a new vector."
    - "ipaddress.IPv6Address('ff02::1').is_multicast == True — ff02::/16 is the multicast range. extra8 covers IPv4Address.is_multicast; IPv6Address.is_multicast not covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4Address.compressed — type and value checks
#
# ipaddress_extra6 covers IPv6Address.compressed (class name and loopback value).
# No prior spec touches IPv4Address.compressed at all.
# For IPv4 addresses, .compressed returns the same dotted-decimal string.
# ---------------------------------------------------------------------------

invariant ipaddress_extra9.IPv4Address.compressed_class:
  description: "ipaddress.IPv4Address('10.0.0.1').compressed.__class__.__name__ == 'str'"
  category: address_attributes
  kind: python_call_eq
  function: IPv4Address
  args: ["10.0.0.1"]
  method: compressed.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant ipaddress_extra9.IPv4Address.compressed_value:
  description: "ipaddress.IPv4Address('10.0.0.1').compressed == '10.0.0.1' — IPv4 compressed is dotted-decimal"
  category: address_attributes
  kind: python_call_eq
  function: IPv4Address
  args: ["10.0.0.1"]
  method: compressed.__eq__
  method_args: ["10.0.0.1"]
  expected: true

# ---------------------------------------------------------------------------
# max_prefixlen for Network classes
#
# ipaddress_extra6 covers max_prefixlen for IPv4Address and IPv6Address.
# No prior spec covers max_prefixlen for IPv4Network or IPv6Network.
# max_prefixlen is a class-level constant: 32 for IPv4, 128 for IPv6.
# ---------------------------------------------------------------------------

invariant ipaddress_extra9.IPv4Network.max_prefixlen:
  description: "ipaddress.IPv4Network('0.0.0.0/0').max_prefixlen == 32"
  category: network_attributes
  kind: python_call_eq
  function: IPv4Network
  args: ["0.0.0.0/0"]
  method: max_prefixlen.__eq__
  method_args: [32]
  expected: true

invariant ipaddress_extra9.IPv6Network.max_prefixlen:
  description: "ipaddress.IPv6Network('2001:db8::/32').max_prefixlen == 128"
  category: network_attributes
  kind: python_call_eq
  function: IPv6Network
  args: ["2001:db8::/32"]
  method: max_prefixlen.__eq__
  method_args: [128]
  expected: true

# ---------------------------------------------------------------------------
# IPv6Network attributes — prefixlen and num_addresses
#
# ipaddress_extra4 covers IPv4Network.prefixlen (== 8) and IPv4Network.num_addresses.
# No prior spec covers IPv6Network.prefixlen or IPv6Network.num_addresses.
# A /128 host route has prefixlen == 128 and num_addresses == 1.
# ---------------------------------------------------------------------------

invariant ipaddress_extra9.IPv6Network.prefixlen:
  description: "ipaddress.IPv6Network('::1/128').prefixlen == 128 — host route has full prefix length"
  category: network_attributes
  kind: python_call_eq
  function: IPv6Network
  args: ["::1/128"]
  method: prefixlen.__eq__
  method_args: [128]
  expected: true

invariant ipaddress_extra9.IPv6Network.num_addresses:
  description: "ipaddress.IPv6Network('::1/128').num_addresses == 1 — /128 host route has exactly one address"
  category: network_attributes
  kind: python_call_eq
  function: IPv6Network
  args: ["::1/128"]
  method: num_addresses.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Network num_addresses — new prefix length vector
#
# ipaddress_extra4 covers IPv4Network('10.0.0.0/8').num_addresses == 16777216.
# New: IPv4Network('192.168.0.0/16').num_addresses == 65536 (2^16). Different network.
# ---------------------------------------------------------------------------

invariant ipaddress_extra9.IPv4Network.num_addresses_slash16:
  description: "ipaddress.IPv4Network('192.168.0.0/16').num_addresses == 65536 — /16 has 2^16 addresses"
  category: network_attributes
  kind: python_call_eq
  function: IPv4Network
  args: ["192.168.0.0/16"]
  method: num_addresses.__eq__
  method_args: [65536]
  expected: true

# ---------------------------------------------------------------------------
# IPv6Address.is_multicast — multicast address
#
# ipaddress_extra8 covers IPv4Address.is_multicast (True for 224.0.0.1).
# No prior spec covers IPv6Address.is_multicast.
# ff02::1 is the well-known all-nodes multicast address (link-local scope).
# ---------------------------------------------------------------------------

invariant ipaddress_extra9.IPv6Address.is_multicast:
  description: "ipaddress.IPv6Address('ff02::1').is_multicast == True — all-nodes link-local multicast"
  category: IPv6Address_predicates
  kind: python_call_eq
  function: IPv6Address
  args: ["ff02::1"]
  method: is_multicast.__eq__
  method_args: [true]
  expected: true
