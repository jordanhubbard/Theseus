spec: theseus_statistics_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_statistics_cr3)
blocks: statistics

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html"
    - "https://en.wikipedia.org/wiki/Geometric_mean"
    - "https://en.wikipedia.org/wiki/Harmonic_mean"
  notes:
    - "Clean-room extended statistics utilities. Do NOT import statistics, numpy, or scipy."
    - "NormalDist(mu, sigma): normal distribution with mean mu and standard deviation sigma."
    - "geometric_mean(data): nth root of product of n values."
    - "harmonic_mean(data): n / sum(1/x for x in data)."
    - "statistics3_normaldist(): NormalDist(0, 1).mean == 0."
    - "statistics3_geometric_mean(): round(geometric_mean([1, 4, 9]), 5) == 3.0 (since (1*4*9)^(1/3) = 36^(1/3) ≈ 3.30... wait)."
    - "Actually geometric_mean([1, 4, 9]) = (1*4*9)^(1/3) = 36^(1/3) ≈ 3.3019. Use [1,4,9] carefully."
    - "Use geometric_mean([1, 8]) = (1*8)^(1/2) = sqrt(8) ≈ 2.828... not clean."
    - "Use geometric_mean([1, 1, 1]) = 1.0. Or geometric_mean([4, 9]) = 6.0."
    - "statistics3_geometric_mean(): geometric_mean([4, 9]) == 6.0 (sqrt(36) == 6)."
    - "statistics3_harmonic_mean(): harmonic_mean([1, 2, 4]) == 12/7 ≈ 1.7142857."
    - "harmonic_mean([1,2,4]) = 3 / (1/1 + 1/2 + 1/4) = 3 / (1.75) = 12/7."
    - "Zero-arg invariant signatures — def statistics3_normaldist(): return hardcoded_result"
    - "NormalDist: .mean, .stdev, .pdf(x), .cdf(x) methods."
    - "Export: NormalDist, geometric_mean(data), harmonic_mean(data), fmean(data)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_statistics_cr3.normaldist:
  description: "NormalDist(0, 1).mean == 0"
  category: NormalDist
  kind: python_call_eq
  function: statistics3_normaldist
  args: []
  expected: 0

invariant theseus_statistics_cr3.geometric_mean:
  description: "geometric_mean([4, 9]) == 6.0"
  category: geometric_mean
  kind: python_call_eq
  function: statistics3_geometric_mean
  args: []
  expected: 6.0

invariant theseus_statistics_cr3.harmonic_mean:
  description: "harmonic_mean([1, 2, 4]) == 12/7"
  category: harmonic_mean
  kind: python_call_eq
  function: statistics3_harmonic_mean
  args: []
  expected: true
