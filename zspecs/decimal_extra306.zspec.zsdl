spec: decimal_extra306
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Decimal('1.0').__eq__(decimal.Decimal('1.0')) == True — value equality."
    - "decimal.Decimal('1.0').__lt__(decimal.Decimal('2.0')) == True — 1.0 < 2.0."
    - "decimal.Decimal('1.0').__gt__(decimal.Decimal('2.0')) == False — 1.0 is not greater than 2.0."
    - "decimal.Decimal('0.1').__add__(decimal.Decimal('0.2')).__str__() == '0.3' — exact decimal arithmetic, unlike float."
    - "decimal.Decimal('1.23').quantize(decimal.Decimal('0.1')).__str__() == '1.2' — ROUND_HALF_EVEN rounds 3 down."
    - "decimal.Decimal('1.25').quantize(decimal.Decimal('0.1')).__str__() == '1.2' — ROUND_HALF_EVEN: 5 rounds to even (2 is even)."
    - "decimal.Decimal('1.35').quantize(decimal.Decimal('0.1')).__str__() == '1.4' — ROUND_HALF_EVEN: 5 rounds to even (4 is even)."
    - "decimal.Decimal('3.14159').to_eng_string() == '3.14159' — no engineering notation needed for this value."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Comparison operators: __eq__, __lt__, __gt__
# ---------------------------------------------------------------------------

invariant decimal_extra306.Decimal.eq_equal:
  description: "decimal.Decimal('1.0').__eq__(decimal.Decimal('1.0')) == True; verified with Python 3.14.3"
  category: comparison
  kind: python_call_eq
  function: "Decimal('1.0').__eq__"
  args: ["Decimal('1.0')"]
  expected: true

invariant decimal_extra306.Decimal.lt_true:
  description: "decimal.Decimal('1.0').__lt__(decimal.Decimal('2.0')) == True; 1.0 < 2.0; verified with Python 3.14.3"
  category: comparison
  kind: python_call_eq
  function: "Decimal('1.0').__lt__"
  args: ["Decimal('2.0')"]
  expected: true

invariant decimal_extra306.Decimal.gt_false:
  description: "decimal.Decimal('1.0').__gt__(decimal.Decimal('2.0')) == False; 1.0 is not greater than 2.0; verified with Python 3.14.3"
  category: comparison
  kind: python_call_eq
  function: "Decimal('1.0').__gt__"
  args: ["Decimal('2.0')"]
  expected: false

# ---------------------------------------------------------------------------
# Arithmetic: __add__ — exact decimal result
# ---------------------------------------------------------------------------

invariant decimal_extra306.Decimal.add_0_1_0_2:
  description: "decimal.Decimal('0.1').__add__(decimal.Decimal('0.2')).__str__() == '0.3'; exact decimal arithmetic; verified with Python 3.14.3"
  category: arithmetic
  kind: python_call_eq
  function: "Decimal('0.1').__add__(Decimal('0.2')).__str__"
  args: []
  expected: "0.3"

# ---------------------------------------------------------------------------
# quantize — ROUND_HALF_EVEN (banker's rounding, the default context)
# ---------------------------------------------------------------------------

invariant decimal_extra306.Decimal.quantize_1_23:
  description: "decimal.Decimal('1.23').quantize(decimal.Decimal('0.1')).__str__() == '1.2'; ROUND_HALF_EVEN rounds 3 down; verified with Python 3.14.3"
  category: quantize
  kind: python_call_eq
  function: "Decimal('1.23').quantize(Decimal('0.1')).__str__"
  args: []
  expected: "1.2"

invariant decimal_extra306.Decimal.quantize_1_25:
  description: "decimal.Decimal('1.25').quantize(decimal.Decimal('0.1')).__str__() == '1.2'; ROUND_HALF_EVEN: 5 rounds to even digit (2 is even); verified with Python 3.14.3"
  category: quantize
  kind: python_call_eq
  function: "Decimal('1.25').quantize(Decimal('0.1')).__str__"
  args: []
  expected: "1.2"

invariant decimal_extra306.Decimal.quantize_1_35:
  description: "decimal.Decimal('1.35').quantize(decimal.Decimal('0.1')).__str__() == '1.4'; ROUND_HALF_EVEN: 5 rounds to even digit (4 is even); verified with Python 3.14.3"
  category: quantize
  kind: python_call_eq
  function: "Decimal('1.35').quantize(Decimal('0.1')).__str__"
  args: []
  expected: "1.4"

# ---------------------------------------------------------------------------
# to_eng_string — engineering string representation
# ---------------------------------------------------------------------------

invariant decimal_extra306.Decimal.to_eng_string:
  description: "decimal.Decimal('3.14159').to_eng_string() == '3.14159'; no engineering notation needed for this value; verified with Python 3.14.3"
  category: string_representation
  kind: python_call_eq
  function: "Decimal('3.14159').to_eng_string"
  args: []
  expected: "3.14159"
