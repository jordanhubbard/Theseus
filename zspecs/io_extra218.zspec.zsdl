spec: io_extra218
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper, BufferedRandom, UnsupportedOperation class metadata"
    - "io_extra217.zspec.zsdl — covers io.BufferedWriter and BufferedRandom __dict__ membership, DEFAULT_BUFFER_SIZE value"
  notes:
    - "io.FileIO.__qualname__ == 'FileIO'; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__qualname__ == 'BufferedReader'; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter'; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper'; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__qualname__ == 'BytesIO'; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__qualname__ == 'StringIO'; confirmed Python 3.14.3 macOS."
    - "__qualname__ is a plain str attribute on all io classes; __qualname__.__class__.__name__ == 'str'."
    - "For top-level (non-nested) classes, __qualname__ equals __name__; both are 'FileIO', 'BufferedReader', etc."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __qualname__ equality for raw I/O and buffered I/O classes
# FileIO, BufferedReader, BufferedWriter __qualname__ attribute checks
# ---------------------------------------------------------------------------

table io_extra218.raw_and_buffered_qualname:
  description: "io.FileIO, BufferedReader, BufferedWriter __qualname__ attributes equal their class names"
  kind: python_call_eq
  category: class_metadata
  id_prefix: ioqualname218

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_qualname,          io.FileIO.__qualname__.__eq__,          ["FileIO"],         true,  "io.FileIO.__qualname__.__eq__('FileIO') == True; FileIO is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_qualname,  io.BufferedReader.__qualname__.__eq__,  ["BufferedReader"],  true,  "io.BufferedReader.__qualname__.__eq__('BufferedReader') == True; BufferedReader is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [bufferedwriter_qualname,  io.BufferedWriter.__qualname__.__eq__,  ["BufferedWriter"],  true,  "io.BufferedWriter.__qualname__.__eq__('BufferedWriter') == True; BufferedWriter is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [fileio_qualname_false,    io.FileIO.__qualname__.__eq__,          ["io.FileIO"],       false, "io.FileIO.__qualname__.__eq__('io.FileIO') == False; qualname does not include the module prefix; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __qualname__ equality for text I/O and in-memory I/O classes
# TextIOWrapper, BytesIO, StringIO __qualname__ attribute checks
# ---------------------------------------------------------------------------

table io_extra218.text_and_memory_qualname:
  description: "io.TextIOWrapper, BytesIO, StringIO __qualname__ attributes equal their class names"
  kind: python_call_eq
  category: class_metadata
  id_prefix: ioqualname218

  columns: [id, function, args, expected, description]
  rows:
    - [textiowrapper_qualname,  io.TextIOWrapper.__qualname__.__eq__,  ["TextIOWrapper"],  true,  "io.TextIOWrapper.__qualname__.__eq__('TextIOWrapper') == True; TextIOWrapper is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [bytesio_qualname,        io.BytesIO.__qualname__.__eq__,        ["BytesIO"],         true,  "io.BytesIO.__qualname__.__eq__('BytesIO') == True; BytesIO is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [stringio_qualname,       io.StringIO.__qualname__.__eq__,       ["StringIO"],        true,  "io.StringIO.__qualname__.__eq__('StringIO') == True; StringIO is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [bytesio_qualname_false,  io.BytesIO.__qualname__.__eq__,        ["bytesio"],         false, "io.BytesIO.__qualname__.__eq__('bytesio') == False; qualname is case-sensitive; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __qualname__ is a str — class name type checks for io classes
# __qualname__ on all io classes is a plain str object
# ---------------------------------------------------------------------------

table io_extra218.qualname_type_checks:
  description: "io class __qualname__ attributes are plain str objects"
  kind: python_call_eq
  category: class_metadata
  id_prefix: ioqualname218

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_qualname_type,         io.FileIO.__qualname__.__class__.__name__,         [],  "str",  "io.FileIO.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on FileIO; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_qualname_type,  io.BufferedReader.__qualname__.__class__.__name__,  [],  "str",  "io.BufferedReader.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on BufferedReader; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_qualname_type,  io.TextIOWrapper.__qualname__.__class__.__name__,  [],  "str",  "io.TextIOWrapper.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on TextIOWrapper; confirmed Python 3.14.3 macOS"]
    - [stringio_qualname_type,       io.StringIO.__qualname__.__class__.__name__,       [],  "str",  "io.StringIO.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on StringIO; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra218.fileio_qualname:
  description: "io.FileIO.__qualname__.__eq__('FileIO') == True — FileIO is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.FileIO.__qualname__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra218.bufferedreader_qualname:
  description: "io.BufferedReader.__qualname__.__eq__('BufferedReader') == True — BufferedReader is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra218.bufferedwriter_qualname:
  description: "io.BufferedWriter.__qualname__.__eq__('BufferedWriter') == True — BufferedWriter is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.BufferedWriter.__qualname__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra218.textiowrapper_qualname:
  description: "io.TextIOWrapper.__qualname__.__eq__('TextIOWrapper') == True — TextIOWrapper is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra218.bytesio_qualname:
  description: "io.BytesIO.__qualname__.__eq__('BytesIO') == True — BytesIO is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra218.stringio_qualname:
  description: "io.StringIO.__qualname__.__eq__('StringIO') == True — StringIO is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra218.fileio_qualname_type:
  description: "io.FileIO.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain str attribute on FileIO; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.FileIO.__qualname__.__class__.__name__
  args: []
  expected: "str"

invariant io_extra218.fileio_qualname_not_dotted:
  description: "io.FileIO.__qualname__.__eq__('io.FileIO') == False — __qualname__ does not include the module prefix; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: io.FileIO.__qualname__.__eq__
  args: ["io.FileIO"]
  expected: false
