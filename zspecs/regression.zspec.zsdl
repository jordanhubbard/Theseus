spec: regression
version: ">=2.0.0"
backend: node(regression)

docs: https://github.com/Tom-Alexander/regression-js#readme

provenance:
  derived_from:
    - "regression-js README — https://github.com/Tom-Alexander/regression-js#readme"
    - "Test vectors verified with regression via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "regression source"
  notes:
    - "Curve fitting — linear / exponential / logarithmic / power / polynomial regression on (x, y) pairs."
    - "Install: npm install regression"
    - "v2 CJS; named exports linear / exponential / logarithmic / power / polynomial."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on numeric pair arrays."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant regression.linear_perfect_fit_r2:
  description: "Linear regression on perfectly linear data has r2 = 1"
  category: linear
  kind: node_chain_eq
  entry: named
  function: linear
  entry_args: [[[0, 0], [1, 1], [2, 2]]]
  chain:
    - {get: r2}
  expected: 1

invariant regression.linear_slope_one:
  description: "Linear y=x fit has equation [1, 0] (slope, intercept)"
  category: linear
  kind: node_chain_eq
  entry: named
  function: linear
  entry_args: [[[0, 0], [1, 1], [2, 2]]]
  chain:
    - {get: equation}
  expected: [1, 0]

invariant regression.linear_string_form:
  description: "Linear y=x produces string 'y = 1x'"
  category: linear
  kind: node_chain_eq
  entry: named
  function: linear
  entry_args: [[[0, 0], [1, 1], [2, 2]]]
  chain:
    - {get: string}
  expected: "y = 1x"

invariant regression.linear_predict_passthrough:
  description: "predict(5) on y=x returns [5, 5] (input + output)"
  category: linear
  kind: node_chain_eq
  entry: named
  function: linear
  entry_args: [[[0, 0], [1, 1], [2, 2]]]
  chain:
    - {method: predict, args: [5]}
  expected: [5, 5]

invariant regression.has_linear:
  description: "linear() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "linear.constructor.name"}
  expected: "Function"

invariant regression.has_exponential:
  description: "exponential() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "exponential.constructor.name"}
  expected: "Function"

invariant regression.has_logarithmic:
  description: "logarithmic() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "logarithmic.constructor.name"}
  expected: "Function"

invariant regression.has_power:
  description: "power() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "power.constructor.name"}
  expected: "Function"

invariant regression.has_polynomial:
  description: "polynomial() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "polynomial.constructor.name"}
  expected: "Function"

invariant regression.linear_returns_object:
  description: "linear() returns a result object with points/predict/equation/r2/string"
  category: shape
  kind: node_chain_eq
  entry: named
  function: linear
  entry_args: [[[0, 0], [1, 1]]]
  chain:
    - {method: hasOwnProperty, args: ["r2"]}
  expected: true
