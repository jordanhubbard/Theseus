spec: inspect_extra173
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.__name__ 'inspect'; inspect.__package__ '' (empty string); inspect.__spec__.__class__.__name__ 'ModuleSpec'; inspect.__loader__.__class__.__name__ 'SourceFileLoader'; inspect.Parameter.__mro__.__len__() 2 (Parameter > object); inspect.Signature.__mro__.__len__() 2; inspect.BoundArguments.__mro__.__len__() 2 (Wave 302)."
    - "inspect.__name__ == 'inspect' — the inspect module's __name__ attribute is the string 'inspect'. Verified with Python 3.14.3."
    - "inspect.__package__ == '' — inspect is a top-level Python module in Lib/inspect.py; its __package__ is the empty string ''. Verified with Python 3.14.3."
    - "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — inspect.__spec__ is an importlib.machinery.ModuleSpec object; its __class__.__name__ is 'ModuleSpec'. Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a pure Python module loaded from Lib/inspect.py; its loader is an instance of importlib._bootstrap_external.SourceFileLoader. Verified with Python 3.14.3."
    - "inspect.Parameter.__mro__.__len__() == 2 — inspect.Parameter is a Python class defined in Lib/inspect.py that inherits directly from object; its __mro__ is (Parameter, object). Verified with Python 3.14.3."
    - "inspect.Signature.__mro__.__len__() == 2 — inspect.Signature is a Python class defined in Lib/inspect.py that inherits directly from object; its __mro__ is (Signature, object). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__mro__.__len__() == 2 — inspect.BoundArguments is a Python class defined in Lib/inspect.py that inherits directly from object; its __mro__ is (BoundArguments, object). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect module __name__ and __package__ identity
#
# Wave 302 theme: inspect.__name__ is 'inspect' (length 7) and
# inspect.__package__ is '' (empty string, NOT 'inspect').
#
# inspect.__name__ == 'inspect'
# inspect.__name__.__len__() == 7
# inspect.__package__ == ''
# inspect.__package__ != 'inspect'
#
# inspect is a top-level Python module defined in Lib/inspect.py. Its __name__
# is 'inspect'. As a single source file at the top level of the standard library,
# its __package__ is '' (empty string), NOT 'inspect'. New to extra173.
# ---------------------------------------------------------------------------

table inspect_extra173.module_name_and_package:
  description: "inspect.__name__ 'inspect', len 7; __package__ '', not 'inspect'; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmnp173

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_inspect,
       "__name__.__eq__",
       ["inspect"],
       true,
       "inspect.__name__.__eq__('inspect') == True — the inspect module's __name__ attribute is the string 'inspect'; str.__eq__('inspect') returns True; new to extra173"]
    - [mod_name_len_7,
       "__name__.__len__",
       [],
       7,
       "inspect.__name__.__len__() == 7 — the string 'inspect' has exactly 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; new to extra173"]
    - [mod_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "inspect.__package__.__eq__('') == True — inspect is a top-level Python module in Lib/inspect.py; its __package__ attribute is the empty string '' (a module-level file, not a package directory); str.__eq__('') returns True; new to extra173"]
    - [mod_package_not_inspect,
       "__package__.__eq__",
       ["inspect"],
       false,
       "inspect.__package__.__eq__('inspect') == False — inspect.__package__ is the empty string '', NOT 'inspect'; only if inspect were a package (directory with __init__.py) would __package__ be 'inspect'; str.__eq__('inspect') returns False; new to extra173"]

# ---------------------------------------------------------------------------
# Table 2: inspect.__spec__ and __loader__ class names
#
# Wave 302 theme: inspect.__spec__.__class__.__name__ == 'ModuleSpec';
# inspect.__loader__.__class__.__name__ == 'SourceFileLoader'.
#
# inspect.__spec__.__class__.__name__ == 'ModuleSpec'
# inspect.__spec__.__class__.__name__ != 'BuiltinImporter'
# inspect.__loader__.__class__.__name__ == 'SourceFileLoader'
# inspect.__loader__.__class__.__name__ != 'type'
#
# inspect is a Python source file (Lib/inspect.py), so it is loaded by
# importlib._bootstrap_external.SourceFileLoader (not BuiltinImporter, which
# handles C extension built-ins like itertools). Its __spec__ is a ModuleSpec
# object. New to extra173.
# ---------------------------------------------------------------------------

table inspect_extra173.spec_and_loader_class:
  description: "inspect.__spec__ class 'ModuleSpec'; __loader__ class 'SourceFileLoader'; not BuiltinImporter; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: inspectslc173

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — inspect.__spec__ is an importlib.machinery.ModuleSpec object describing the inspect module; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra173"]
    - [spec_class_not_builtin_importer,
       "__spec__.__class__.__name__.__eq__",
       ["BuiltinImporter"],
       false,
       "inspect.__spec__.__class__.__name__.__eq__('BuiltinImporter') == False — inspect is a Python source module (not a C built-in), so its __spec__.__class__.__name__ is 'ModuleSpec' (not 'BuiltinImporter'); str.__eq__('BuiltinImporter') returns False; new to extra173"]
    - [loader_class_source_file_loader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect is a pure Python module loaded from Lib/inspect.py; its loader is an instance of importlib._bootstrap_external.SourceFileLoader; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra173"]
    - [loader_class_not_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       false,
       "inspect.__loader__.__class__.__name__.__eq__('type') == False — inspect.__loader__ is a SourceFileLoader instance (not a class object like itertools.__loader__ which is the BuiltinImporter class itself); the loader's __class__.__name__ is 'SourceFileLoader', not 'type'; str.__eq__('type') returns False; new to extra173"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.__mro__.__len__() == 2 (Parameter > object)
#
# Wave 302 theme: inspect.Parameter is a Python class that inherits directly
# from object; its __mro__ has exactly 2 entries.
#
# inspect.Parameter.__mro__.__len__() == 2
# inspect.Parameter.__mro__[0].__name__ == 'Parameter'
# inspect.Parameter.__mro__[1].__name__ == 'object'
# inspect.Parameter.__mro__.__len__() != 3
#
# inspect.Parameter is defined in Lib/inspect.py and represents a parameter
# of a callable. It defines POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD,
# VAR_POSITIONAL, KEYWORD_ONLY, and VAR_KEYWORD kinds as class attributes.
# It inherits directly from object. New to extra173.
# ---------------------------------------------------------------------------

table inspect_extra173.parameter_mro_len:
  description: "inspect.Parameter.__mro__: len 2, mro[0] 'Parameter', mro[1] 'object'; not len 3; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparmmro173

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_mro_len_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — inspect.Parameter is a Python class defined in Lib/inspect.py representing a parameter of a callable (with kind, name, default, annotation attributes); it inherits directly from object with no intermediate base classes; its __mro__ is (Parameter, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["parameter_mro_0_parameter",
       "Parameter.__mro__[0].__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__mro__[0].__name__.__eq__('Parameter') == True — the first entry in Parameter.__mro__ is the Parameter class itself; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra173"]
    - ["parameter_mro_1_object",
       "Parameter.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__mro__[1].__name__.__eq__('object') == True — the second entry in Parameter.__mro__ is the base class object; its __name__ is 'object'; this confirms Parameter inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra173"]
    - [parameter_mro_not_3,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 (not 3) — Parameter inherits only from object; there is no intermediate class; tuple.__len__() returns 2; new to extra173"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Signature and inspect.BoundArguments __mro__.__len__() == 2
#
# Wave 302 theme: inspect.Signature and inspect.BoundArguments are Python classes
# that inherit directly from object; their __mro__ has exactly 2 entries.
#
# inspect.Signature.__mro__.__len__() == 2
# inspect.Signature.__mro__[0].__name__ == 'Signature'
# inspect.BoundArguments.__mro__.__len__() == 2
# inspect.BoundArguments.__mro__[0].__name__ == 'BoundArguments'
#
# inspect.Signature represents the call signature of a callable. It is created
# by inspect.signature(). inspect.BoundArguments represents the result of
# calling Signature.bind() and holds the mapping of parameter names to values.
# Both are Python classes in Lib/inspect.py with direct object inheritance. New
# to extra173.
# ---------------------------------------------------------------------------

table inspect_extra173.signature_boundargs_mro_len:
  description: "inspect.Signature and BoundArguments: __mro__.__len__() 2, mro[0] is self; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsigbaml173

  columns: [id, function, args, expected, description]
  rows:
    - [signature_mro_len_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — inspect.Signature is a Python class defined in Lib/inspect.py representing the call signature of a callable (with parameters, return_annotation); it inherits directly from object; its __mro__ is (Signature, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["signature_mro_0_signature",
       "Signature.__mro__[0].__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__mro__[0].__name__.__eq__('Signature') == True — the first entry in Signature.__mro__ is the Signature class itself; its __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra173"]
    - [boundargs_mro_len_2,
       "BoundArguments.__mro__.__len__",
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — inspect.BoundArguments is a Python class defined in Lib/inspect.py representing the result of Signature.bind(); it holds the mapping of parameter names to argument values; it inherits directly from object; its __mro__ is (BoundArguments, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["boundargs_mro_0_boundarguments",
       "BoundArguments.__mro__[0].__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__mro__[0].__name__.__eq__('BoundArguments') == True — the first entry in BoundArguments.__mro__ is the BoundArguments class itself; its __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Table 5: MRO uniformity cross-checks — Parameter, Signature, BoundArguments
# all have __mro__.__len__() == 2 and share 'object' as their sole base
#
# Wave 302 theme: confirming the pattern that Parameter, Signature, and
# BoundArguments all inherit directly from object with MRO length 2.
#
# inspect.Parameter.__mro__[1].__name__ == 'object'
# inspect.Signature.__mro__[1].__name__ == 'object'
# inspect.BoundArguments.__mro__[1].__name__ == 'object'
# inspect.BoundArguments.__mro__.__len__() != 3
#
# These three inspect classes share the same direct inheritance structure:
# each has only object as its base class. This uniformity cross-check confirms
# that none of them has any intermediate class in its MRO. New to extra173.
# ---------------------------------------------------------------------------

table inspect_extra173.mro_uniformity_cross_checks:
  description: "inspect: Parameter, Signature, BoundArguments all have mro[1] 'object'; BoundArguments mro not 3; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmrouc173

  columns: [id, function, args, expected, description]
  rows:
    - ["parameter_mro_1_object_xcheck",
       "Parameter.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__mro__[1].__name__.__eq__('object') == True — cross-check confirming that object is the second MRO entry for Parameter; Parameter inherits directly from object; str.__eq__('object') returns True; new to extra173"]
    - ["signature_mro_1_object_xcheck",
       "Signature.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__mro__[1].__name__.__eq__('object') == True — cross-check confirming that object is the second MRO entry for Signature; Signature inherits directly from object; str.__eq__('object') returns True; new to extra173"]
    - ["boundargs_mro_1_object_xcheck",
       "BoundArguments.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__mro__[1].__name__.__eq__('object') == True — cross-check confirming that object is the second MRO entry for BoundArguments; BoundArguments inherits directly from object; str.__eq__('object') returns True; new to extra173"]
    - [boundargs_mro_not_3,
       "BoundArguments.__mro__.__len__",
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 (not 3) — BoundArguments inherits only from object; there is no intermediate class; the MRO depth is exactly 2; tuple.__len__() returns 2; new to extra173"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra173
# ---------------------------------------------------------------------------

invariant inspect_extra173.mod_name_inspect:
  description: "inspect.__name__ == 'inspect' — the module's name attribute is the string 'inspect'; wave 302; new to extra173"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra173.mod_package_empty:
  description: "inspect.__package__ == '' — inspect is a top-level Python source module; its __package__ is the empty string; wave 302; new to extra173"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant inspect_extra173.spec_class_modulespec:
  description: "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec describing the inspect Python source module; wave 302; new to extra173"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant inspect_extra173.loader_class_source_file_loader:
  description: "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a Python source file loaded by importlib SourceFileLoader; wave 302; new to extra173"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra173.parameter_mro_len_2:
  description: "inspect.Parameter.__mro__.__len__() == 2 — Parameter is a Python class inheriting directly from object; MRO is (Parameter, object); wave 302; new to extra173"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra173.signature_mro_len_2:
  description: "inspect.Signature.__mro__.__len__() == 2 — Signature is a Python class inheriting directly from object; MRO is (Signature, object); wave 302; new to extra173"
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra173.boundargs_mro_len_2:
  description: "inspect.BoundArguments.__mro__.__len__() == 2 — BoundArguments is a Python class inheriting directly from object; MRO is (BoundArguments, object); wave 302; new to extra173"
  kind: python_call_eq
  function: BoundArguments.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra173.mod_name_len_7:
  description: "inspect.__name__.__len__() == 7 — 'inspect' is 7 characters long; wave 302; new to extra173"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7
