spec: st2866
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 638 (_extra2866): __rand__, __ror__, __rxor__ dict-presence checks for struct types."
    - "struct module exposes exactly two types: struct.Struct (C-level compiled format object) and struct.error (exception class)."
    - "struct.Struct is a binary packing type with no numeric operator semantics."
    - "struct.error is an exception subclass of Exception; exception classes do not define bitwise operators."
    - "Neither struct.Struct nor struct.error defines any reflected bitwise AND, OR, or XOR operators in its own __dict__."
    - "The struct module itself is of type 'module'; module types do not define arithmetic operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table st2866.rand:
  description: "struct types __rand__ dict-presence checks; wave 638"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2866
  columns: [id, function, args, expected]
  rows:
    - ["st2866001", "struct.Struct.__dict__.__contains__",             ["__rand__"], false]
    - ["st2866002", "struct.error.__dict__.__contains__",              ["__rand__"], false]
    - ["st2866003", "type(struct).__dict__.__contains__",              ["__rand__"], false]
    - ["st2866004", "type(struct.Struct('>I')).__dict__.__contains__", ["__rand__"], false]
    - ["st2866005", "type(struct.Struct('<H')).__dict__.__contains__", ["__rand__"], false]
    - ["st2866006", "type(struct.Struct('!4s')).__dict__.__contains__", ["__rand__"], false]

