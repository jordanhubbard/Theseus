spec: logging_extra6
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "CPython source: Lib/logging/handlers.py"
  notes:
    - "This spec extends logging.zspec.zsdl, logging_config.zspec.zsdl, logging_extra.zspec.zsdl, logging_extra2.zspec.zsdl, logging_extra3.zspec.zsdl, logging_extra4.zspec.zsdl, logging_extra5.zspec.zsdl, logging_handlers.zspec.zsdl, and logging_nullhandler.zspec.zsdl."
    - "Focus: __qualname__ checks for major logging classes and functions, plus numeric level constants."
    - "logging.NOTSET==0, DEBUG==10, INFO==20, WARNING==30, ERROR==40, CRITICAL==50 — verified with Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# qualname — major logging classes
# ---------------------------------------------------------------------------

table logging_extra6.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Logger,        Logger.__qualname__.__eq__,        ["Logger"],        true]
    - [Handler,       Handler.__qualname__.__eq__,       ["Handler"],       true]
    - [Formatter,     Formatter.__qualname__.__eq__,     ["Formatter"],     true]
    - [Filter,        Filter.__qualname__.__eq__,        ["Filter"],        true]
    - [LogRecord,     LogRecord.__qualname__.__eq__,     ["LogRecord"],     true]
    - [StreamHandler, StreamHandler.__qualname__.__eq__, ["StreamHandler"], true]

# ---------------------------------------------------------------------------
# qualname — additional classes not in the table above
# ---------------------------------------------------------------------------

invariant logging_extra6.FileHandler.qualname:
  description: "logging.FileHandler.__qualname__ == 'FileHandler'"
  category: qualnames
  kind: python_call_eq
  function: FileHandler.__qualname__.__eq__
  args: ["FileHandler"]
  expected: true

invariant logging_extra6.NullHandler.qualname:
  description: "logging.NullHandler.__qualname__ == 'NullHandler'"
  category: qualnames
  kind: python_call_eq
  function: NullHandler.__qualname__.__eq__
  args: ["NullHandler"]
  expected: true

# ---------------------------------------------------------------------------
# qualname — module-level functions
# ---------------------------------------------------------------------------

invariant logging_extra6.getLogger.qualname:
  description: "logging.getLogger.__qualname__ == 'getLogger'"
  category: qualnames
  kind: python_call_eq
  function: getLogger.__qualname__.__eq__
  args: ["getLogger"]
  expected: true

invariant logging_extra6.basicConfig.qualname:
  description: "logging.basicConfig.__qualname__ == 'basicConfig'"
  category: qualnames
  kind: python_call_eq
  function: basicConfig.__qualname__.__eq__
  args: ["basicConfig"]
  expected: true

# ---------------------------------------------------------------------------
# numeric level constants
# ---------------------------------------------------------------------------

table logging_extra6.level_constants:
  kind: python_call_eq
  category: constants
  id_prefix: level

  columns: [id, function, args, expected]
  rows:
    - [NOTSET,   NOTSET.__eq__,   [0],  true]
    - [DEBUG,    DEBUG.__eq__,    [10], true]
    - [INFO,     INFO.__eq__,     [20], true]
    - [WARNING,  WARNING.__eq__,  [30], true]
    - [ERROR,    ERROR.__eq__,    [40], true]
    - [CRITICAL, CRITICAL.__eq__, [50], true]
