spec: nltk_rust
version: ">=3.9"
backend: rust_module(nltk_rust)

docs: https://www.nltk.org/api/nltk.html

provenance:
  derived_from:
    - "https://www.nltk.org/api/nltk.html — NLTK documentation"
  not_derived_from:
    - "nltk source: nltk/tokenize/__init__.py"
  notes:
    - "NLTK provides natural language processing tools."
    - "nltk.word_tokenize('Hello world') == ['Hello', 'world']."
    - "nltk.word_tokenize('I am fine.') == ['I', 'am', 'fine', '.']."
    - "nltk.sent_tokenize('Hello. World.') == ['Hello.', 'World.']."
    - "len(nltk.word_tokenize('one two three')) == 3."
    - "Expose nltk_word_count(text) -> int: len(nltk.word_tokenize(text))."
    - "Expose nltk_word_tokens(text) -> list: nltk.word_tokenize(text)."
    - "Expose nltk_sent_count(text) -> int: len(nltk.sent_tokenize(text))."
    - "All test vectors verified against nltk 3.9.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# nltk_word_count — word token count
table nltk_rust.tokenize.word_count:
  kind: python_call_eq
  category: word_count
  id_prefix: nltk_wc
  function: nltk_word_count

  columns: [id, args, expected]
  rows:
    - [two,   ["Hello world"],     2]
    - [three, ["one two three"],   3]
    - [punct, ["I am fine."],      4]

# nltk_word_tokens — word tokenization
table nltk_rust.tokenize.word_tokens:
  kind: python_call_eq
  category: word_tokens
  id_prefix: nltk_wt
  function: nltk_word_tokens

  columns: [id, args, expected]
  rows:
    - [hello, ["Hello world"], ["Hello", "world"]]

# nltk_sent_count — sentence count
table nltk_rust.tokenize.sent_count:
  kind: python_call_eq
  category: sent_count
  id_prefix: nltk_sc
  function: nltk_sent_count

  columns: [id, args, expected]
  rows:
    - [two,  ["Hello. World."], 2]
    - [one,  ["Hello world"],   1]

