spec: socket_extra1501
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module socket, error, and timeout class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 547 (_extra1501): async protocol method dict-presence checks for socket.socket, socket.error, and socket.timeout."
    - "The stdlib socket module is sync-only; asyncio.streams provides async socket wrappers externally. socket.socket itself does not implement __await__, __aiter__, __anext__, __aenter__, or __aexit__ in its own __dict__."
    - "socket.socket.__enter__ and __exit__ ARE defined directly on the class (context manager protocol), but the async variants are not."
    - "socket.error.__dict__ contains operational attributes: errno, strerror, filename, filename2, characters_written, __init__, __new__, __reduce__, __str__."
    - "socket.timeout.__dict__ contains only __doc__; it inherits all behaviour from socket.error (OSError)."
    - "All results verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — async protocol absent, sync context manager present
# ---------------------------------------------------------------------------

table socket_extra1501.socket.async_protocol_absent:
  description: "socket.socket has no async protocol methods in its __dict__; sync __enter__/__exit__ ARE present"
  kind: python_call_eq
  category: async_protocol
  id_prefix: sk1501sa
  columns: [id, function, args, expected]
  rows:
    - [sk1501sa001, socket.socket.__dict__.__contains__, ["__await__"],  false]
    - [sk1501sa002, socket.socket.__dict__.__contains__, ["__aiter__"],  false]
    - [sk1501sa003, socket.socket.__dict__.__contains__, ["__anext__"],  false]
    - [sk1501sa004, socket.socket.__dict__.__contains__, ["__aenter__"], false]
    - [sk1501sa005, socket.socket.__dict__.__contains__, ["__aexit__"],  false]
    - [sk1501sa006, socket.socket.__dict__.__contains__, ["__enter__"],  true]
    - [sk1501sa007, socket.socket.__dict__.__contains__, ["__exit__"],   true]

# ---------------------------------------------------------------------------
# socket.socket — sync own-dict methods present (positive anchors)
# ---------------------------------------------------------------------------

table socket_extra1501.socket.sync_methods_present:
  description: "socket.socket own-dict sync methods are present"
  kind: python_call_eq
  category: async_protocol
  id_prefix: sk1501ss
  columns: [id, function, args, expected]
  rows:
    - [sk1501ss001, socket.socket.__dict__.__contains__, ["accept"],          true]
    - [sk1501ss002, socket.socket.__dict__.__contains__, ["close"],           true]
    - [sk1501ss003, socket.socket.__dict__.__contains__, ["makefile"],        true]
    - [sk1501ss004, socket.socket.__dict__.__contains__, ["detach"],          true]
    - [sk1501ss005, socket.socket.__dict__.__contains__, ["sendfile"],        true]
    - [sk1501ss006, socket.socket.__dict__.__contains__, ["get_inheritable"], true]

# ---------------------------------------------------------------------------
# socket.error — async protocol absent, own attributes present
# ---------------------------------------------------------------------------

table socket_extra1501.error.async_protocol_absent:
  description: "socket.error has no async protocol methods; own operational attributes ARE present"
  kind: python_call_eq
  category: async_protocol
  id_prefix: sk1501ea
  columns: [id, function, args, expected]
  rows:
    - [sk1501ea001, socket.error.__dict__.__contains__, ["__await__"],  false]
    - [sk1501ea002, socket.error.__dict__.__contains__, ["__aiter__"],  false]
    - [sk1501ea003, socket.error.__dict__.__contains__, ["__anext__"],  false]
    - [sk1501ea004, socket.error.__dict__.__contains__, ["__aenter__"], false]
    - [sk1501ea005, socket.error.__dict__.__contains__, ["__aexit__"],  false]
    - [sk1501ea006, socket.error.__dict__.__contains__, ["errno"],      true]
    - [sk1501ea007, socket.error.__dict__.__contains__, ["strerror"],   true]
