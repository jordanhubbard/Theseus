spec: abc_extra2476
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether abc classes define membership test and item access protocol in their class __dict__."
    - "abc.ABC.__dict__.__contains__('__contains__') == False — ABC does not define __contains__; verified Python 3.14.4."
    - "abc.ABC.__dict__.__contains__('__getitem__') == False — ABC does not define __getitem__; verified Python 3.14.4."
    - "abc.ABCMeta.__dict__.__contains__('__contains__') == False — ABCMeta does not define __contains__; verified Python 3.14.4."
    - "abc.ABCMeta.__dict__.__contains__('__getitem__') == False — ABCMeta does not define __getitem__; verified Python 3.14.4."
    - "abc.ABC.__dict__ keys include __module__, __doc__, __slots__, __abstractmethods__, _abc_impl; verified Python 3.14.4."
    - "abc.ABCMeta.__dict__ keys include __module__, __doc__, __new__, register, __instancecheck__, __subclasscheck__, _dump_registry; verified Python 3.14.4."
    - "ABCMeta defines __instancecheck__ and __subclasscheck__ (for virtual subclass support) but NOT __contains__ or __getitem__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for both abc.ABC and abc.ABCMeta; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC class __dict__ __contains__ checks
#
# abc.ABC is a simple helper class with a minimal __dict__. It defines
# __module__, __doc__, __slots__, __abstractmethods__, and _abc_impl.
# It does NOT define __contains__ or __getitem__.
# ---------------------------------------------------------------------------

table abc_extra2476.abc_dict_contains:
  description: "abc.ABC.__dict__.__contains__ checks — ABC defines __module__, __doc__, __slots__, __abstractmethods__, _abc_impl but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab2476

  columns: [id, function, args, expected]
  rows:
    - ["ab2476001", abc.ABC.__dict__.__contains__, ["__module__"],         true]
    - ["ab2476002", abc.ABC.__dict__.__contains__, ["__doc__"],            true]
    - ["ab2476003", abc.ABC.__dict__.__contains__, ["__slots__"],          true]
    - ["ab2476004", abc.ABC.__dict__.__contains__, ["__abstractmethods__"], true]
    - ["ab2476005", abc.ABC.__dict__.__contains__, ["_abc_impl"],          true]
    - ["ab2476006", abc.ABC.__dict__.__contains__, ["__contains__"],       false]
    - ["ab2476007", abc.ABC.__dict__.__contains__, ["__getitem__"],        false]

# ---------------------------------------------------------------------------
# abc.ABCMeta class __dict__ __contains__ checks
#
# abc.ABCMeta is the metaclass for abstract base classes. It defines
# __instancecheck__ and __subclasscheck__ for virtual subclass dispatch,
# but it does NOT define __contains__ or __getitem__. It also defines
# register, _dump_registry, _abc_registry_clear, and _abc_caches_clear.
# ---------------------------------------------------------------------------

table abc_extra2476.abcmeta_dict_contains:
  description: "abc.ABCMeta.__dict__.__contains__ checks — ABCMeta defines __new__, register, __instancecheck__, __subclasscheck__, _dump_registry but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab2476

  columns: [id, function, args, expected]
  rows:
    - ["ab2476008",  abc.ABCMeta.__dict__.__contains__, ["__module__"],         true]
    - ["ab2476009",  abc.ABCMeta.__dict__.__contains__, ["__new__"],            true]
    - ["ab2476010",  abc.ABCMeta.__dict__.__contains__, ["register"],           true]
    - ["ab2476011",  abc.ABCMeta.__dict__.__contains__, ["__instancecheck__"],  true]
    - ["ab2476012",  abc.ABCMeta.__dict__.__contains__, ["__subclasscheck__"],  true]
    - ["ab2476013",  abc.ABCMeta.__dict__.__contains__, ["_dump_registry"],     true]
    - ["ab2476014",  abc.ABCMeta.__dict__.__contains__, ["__contains__"],       false]
    - ["ab2476015",  abc.ABCMeta.__dict__.__contains__, ["__getitem__"],        false]

# ---------------------------------------------------------------------------
# Cross-class negative checks — keys from one class dict absent in the other
# ---------------------------------------------------------------------------

table abc_extra2476.cross_class_absent:
  description: "abc.ABC and abc.ABCMeta cross-class key absence — register is ABCMeta-only, _abc_impl is ABC-only; neither defines __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab2476

  columns: [id, function, args, expected]
  rows:
    - ["ab2476016", abc.ABC.__dict__.__contains__,    ["register"],       false]
    - ["ab2476017", abc.ABC.__dict__.__contains__,    ["__new__"],        false]
    - ["ab2476018", abc.ABCMeta.__dict__.__contains__, ["_abc_impl"],      false]
    - ["ab2476019", abc.ABCMeta.__dict__.__contains__, ["__slots__"],      false]
    - ["ab2476020", abc.ABC.__dict__.__contains__,    ["__nonexistent__"], false]
    - ["ab2476021", abc.ABCMeta.__dict__.__contains__, ["__nonexistent__"], false]

# ---------------------------------------------------------------------------
# __getitem__ on class __dict__ raises KeyError for missing keys
# ---------------------------------------------------------------------------

table abc_extra2476.dict_getitem_raises:
  description: "abc.ABC and abc.ABCMeta __dict__.__getitem__ raises KeyError for absent __contains__ and __getitem__ keys; verified Python 3.14.4"
  kind: python_call_raises
  category: dict_presence
  id_prefix: ab2476

  columns: [id, function, args, raises]
  rows:
    - ["ab2476022", abc.ABC.__dict__.__getitem__,    ["__contains__"],   KeyError]
    - ["ab2476023", abc.ABC.__dict__.__getitem__,    ["__getitem__"],    KeyError]
    - ["ab2476024", abc.ABCMeta.__dict__.__getitem__, ["__contains__"],  KeyError]
    - ["ab2476025", abc.ABCMeta.__dict__.__getitem__, ["__getitem__"],   KeyError]
    - ["ab2476026", abc.ABCMeta.__dict__.__getitem__, ["__nonexistent__"], KeyError]
    - ["ab2476027", abc.ABC.__dict__.__getitem__,    ["register"],       KeyError]
