    - ["th3121014", operator.contains, [threading.Event.__dict__,            "__repr__"], true]
    - ["th3121015", operator.contains, [threading.Condition.__dict__,        "__repr__"], true]
    - ["th3121016", operator.contains, [threading.Semaphore.__dict__,        "__repr__"], true]
    - ["th3121017", operator.contains, [threading.BoundedSemaphore.__dict__, "__repr__"], true]
    - ["th3121018", operator.contains, [threading.Timer.__dict__,            "__repr__"], false]
    - ["th3121019", operator.contains, [threading.Barrier.__dict__,          "__repr__"], true]
    - ["th3121020", operator.contains, [threading.local.__dict__,            "__repr__"], false]

