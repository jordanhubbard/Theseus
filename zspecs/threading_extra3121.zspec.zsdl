spec: th3121
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (th3121): __ge__, __repr__, __str__ dict-presence checks for threading types."
    - "None of the threading types define __ge__ or __str__ in their own __dict__."
    - "threading.Thread, type(threading.Lock()), type(threading.RLock()), threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, and threading.Barrier define __repr__."
    - "threading.Timer and threading.local do not define __repr__ in their own __dict__; threading.Timer inherits __repr__ from threading.Thread."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3121.ge:
  description: "threading types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3121
  columns: [id, function, args, expected]
  rows:
    - ["th3121001", operator.contains, [threading.Thread.__dict__,           "__ge__"], false]
    - ["th3121002", operator.contains, [type(threading.Lock()).__dict__,     "__ge__"], false]
    - ["th3121003", operator.contains, [type(threading.RLock()).__dict__,    "__ge__"], false]
    - ["th3121004", operator.contains, [threading.Event.__dict__,            "__ge__"], false]
    - ["th3121005", operator.contains, [threading.Condition.__dict__,        "__ge__"], false]
    - ["th3121006", operator.contains, [threading.Semaphore.__dict__,        "__ge__"], false]
    - ["th3121007", operator.contains, [threading.BoundedSemaphore.__dict__, "__ge__"], false]
    - ["th3121008", operator.contains, [threading.Timer.__dict__,            "__ge__"], false]
    - ["th3121009", operator.contains, [threading.Barrier.__dict__,          "__ge__"], false]
    - ["th3121010", operator.contains, [threading.local.__dict__,            "__ge__"], false]

