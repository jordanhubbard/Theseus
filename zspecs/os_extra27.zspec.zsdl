spec: os_extra27
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra26.zspec.zsdl — covers os.error/__name__, result class __name__ and __bases__[0].__name__"
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra26.zspec.zsdl."
    - "os.getcwd.__qualname__ == 'getcwd' — qualname equals bare function name; no prior os spec covers getcwd.__qualname__."
    - "os.listdir.__qualname__ == 'listdir' — qualname equals bare function name; not covered in prior specs."
    - "os.makedirs.__qualname__ == 'makedirs' — makedirs is a pure-Python wrapper defined in os; qualname equals function name."
    - "os.remove.__qualname__ == 'remove' — POSIX-level function; qualname equals function name."
    - "os.rename.__qualname__ == 'rename' — POSIX-level function; qualname equals function name."
    - "os.mkdir.__qualname__ == 'mkdir'; os.rmdir.__qualname__ == 'rmdir'; os.stat.__qualname__ == 'stat'; os.walk.__qualname__ == 'walk'."
    - "Qualname length facts: getcwd=6, listdir=7, makedirs=8, remove=6, rename=6, mkdir=5, rmdir=5, stat=4, walk=4."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ equality table
#
# For all top-level os functions examined here, __qualname__ equals the plain
# function name (no class prefix, no closure suffix). This table verifies that
# property across nine commonly-used os functions. No prior os_extra spec
# covers __qualname__ for any of these nine functions.
# ---------------------------------------------------------------------------

table os_extra27.function_qualnames:
  description: "__qualname__ equals the plain function name for core os functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname27

  columns: [id, function, args, expected]
  rows:
    - [getcwd,   getcwd.__qualname__.__eq__,   ["getcwd"],   true]
    - [listdir,  listdir.__qualname__.__eq__,  ["listdir"],  true]
    - [makedirs, makedirs.__qualname__.__eq__, ["makedirs"], true]
    - [remove,   remove.__qualname__.__eq__,   ["remove"],   true]
    - [rename,   rename.__qualname__.__eq__,   ["rename"],   true]
    - [mkdir,    mkdir.__qualname__.__eq__,    ["mkdir"],    true]
    - [rmdir,    rmdir.__qualname__.__eq__,    ["rmdir"],    true]
    - [stat,     stat.__qualname__.__eq__,     ["stat"],     true]
    - [walk,     walk.__qualname__.__eq__,     ["walk"],     true]

# ---------------------------------------------------------------------------
# __qualname__ length checks — standalone invariants
#
# Length of a qualname string is a distinct axis from equality. These six
# standalone invariants cover the most-referenced os functions and anchor the
# lengths in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant os_extra27.getcwd.qualname_length:
  description: "os.getcwd.__qualname__.__len__() == 6 — 'getcwd' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: getcwd.__qualname__.__len__
  args: []
  expected: 6

invariant os_extra27.listdir.qualname_length:
  description: "os.listdir.__qualname__.__len__() == 7 — 'listdir' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: listdir.__qualname__.__len__
  args: []
  expected: 7

invariant os_extra27.makedirs.qualname_length:
  description: "os.makedirs.__qualname__.__len__() == 8 — 'makedirs' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: makedirs.__qualname__.__len__
  args: []
  expected: 8

invariant os_extra27.remove.qualname_length:
  description: "os.remove.__qualname__.__len__() == 6 — 'remove' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: remove.__qualname__.__len__
  args: []
  expected: 6

invariant os_extra27.walk.qualname_length:
  description: "os.walk.__qualname__.__len__() == 4 — 'walk' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: walk.__qualname__.__len__
  args: []
  expected: 4

invariant os_extra27.rename.qualname_length:
  description: "os.rename.__qualname__.__len__() == 6 — 'rename' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: rename.__qualname__.__len__
  args: []
  expected: 6
