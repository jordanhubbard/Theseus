spec: theseus_wave_cr
version: ">=3.0"
backend: python_cleanroom(theseus_wave_cr)
blocks: wave

docs: https://docs.python.org/3/library/wave.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/wave.html"
  not_derived_from:
    - "CPython source: Lib/wave.py"
  notes:
    - "Clean-room wave module. Do NOT import wave."

error_model: python_exceptions

invariant theseus_wave_cr.wave2_write_read:
  description: "write then read back a WAV file"
  category: behavior
  kind: python_call_eq
  function: wave2_write_read
  args: []
  expected: true

invariant theseus_wave_cr.wave2_params:
  description: "Wave_read.getparams() returns named tuple"
  category: behavior
  kind: python_call_eq
  function: wave2_params
  args: []
  expected: true

invariant theseus_wave_cr.wave2_error:
  description: "wave.Error exception class exists"
  category: behavior
  kind: python_call_eq
  function: wave2_error
  args: []
  expected: true
