spec: pathlib_extra2836
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/pathlib_extra2821.zspec.zsdl — wave 635 predecessor (covered __radd__, __rsub__, __rmul__)"
    - "CPython source: Lib/pathlib/"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "pathlib.PurePath defines __rtruediv__ for right-hand path joining with the / operator (e.g. 'prefix' / PurePath('a'))."
    - "pathlib.PurePath does NOT define __rfloordiv__ or __rmod__ — only the true-division spelling of / is supported."
    - "PurePosixPath, PureWindowsPath, and Path do NOT individually define __rtruediv__, __rfloordiv__, or __rmod__ in their own __dict__s."
    - "PurePosixPath, PureWindowsPath, and Path inherit __rtruediv__ from PurePath rather than defining it themselves."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rtruediv__ dict-presence
# PurePath defines it; subclasses and Path do not define it in their own __dict__
# ---------------------------------------------------------------------------

table pathlib_extra2836.rtruediv_protocol:
  description: "__rtruediv__ is present in pathlib.PurePath.__dict__ for path joining; absent from subclass own __dict__s"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2836

  columns: [id, function, args, expected]
  rows:
    - ["pp2836001", "pathlib.PurePath.__dict__.__contains__",        ["__rtruediv__"], true]
    - ["pp2836002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rtruediv__"], false]
    - ["pp2836003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rtruediv__"], false]
    - ["pp2836004", "pathlib.Path.__dict__.__contains__",            ["__rtruediv__"], false]

# ---------------------------------------------------------------------------
# Table: __rfloordiv__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2836.rfloordiv_protocol:
  description: "__rfloordiv__ is absent from all pathlib path class __dict__s — floor division has no path semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2836

  columns: [id, function, args, expected]
  rows:
    - ["pp2836005", "pathlib.PurePath.__dict__.__contains__",        ["__rfloordiv__"], false]
    - ["pp2836006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rfloordiv__"], false]
    - ["pp2836007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["pp2836008", "pathlib.Path.__dict__.__contains__",            ["__rfloordiv__"], false]

# ---------------------------------------------------------------------------
# Table: __rmod__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2836.rmod_protocol:
  description: "__rmod__ is absent from all pathlib path class __dict__s — modulo has no path semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2836

  columns: [id, function, args, expected]
  rows:
    - ["pp2836009",  "pathlib.PurePath.__dict__.__contains__",        ["__rmod__"], false]
    - ["pp2836010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rmod__"], false]
    - ["pp2836011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rmod__"], false]
    - ["pp2836012", "pathlib.Path.__dict__.__contains__",            ["__rmod__"], false]

# ---------------------------------------------------------------------------
# Table: division operator asymmetry — PurePath supports __rtruediv__ only
# Confirms that only true division (/) is meaningful for paths; floor division
# and modulo are absent even though __rtruediv__ is present
# ---------------------------------------------------------------------------

table pathlib_extra2836.division_operator_asymmetry:
  description: "pathlib.PurePath defines __rtruediv__ for path joining but NOT __rfloordiv__ or __rmod__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2836

  columns: [id, function, args, expected]
  rows:
    - ["pp2836013", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],   true]
    - ["pp2836014", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"],  true]
    - ["pp2836015", "pathlib.PurePath.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["pp2836016", "pathlib.PurePath.__dict__.__contains__", ["__rmod__"],      false]
