invariant asyncio_extra85.AbstractEventLoop_name:
  description: "asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop') returns True — AbstractEventLoop is a top-level class defined in asyncio.events; NEW in extra85: first standalone __name__ invariant for AbstractEventLoop in asyncioextra85 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra85.AbstractEventLoop_module:
  description: "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') returns True — AbstractEventLoop is defined in the asyncio.events submodule; NEW in extra85: first standalone __module__ invariant for AbstractEventLoop in asyncioextra85 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra85.AbstractEventLoop_mro_len:
  description: "asyncio.AbstractEventLoop.__mro__.__len__() == 2 — MRO is [AbstractEventLoop, object], so length is 2; AbstractEventLoop directly subclasses object with no intermediate bases; NEW in extra85: first standalone __mro__.__len__ invariant for AbstractEventLoop in asyncioextra85 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra85.BaseEventLoop_base_name:
  description: "asyncio.BaseEventLoop.__bases__[0].__name__.__eq__('AbstractEventLoop') returns True — BaseEventLoop directly subclasses AbstractEventLoop, forming the primary implementation of the event loop interface; NEW in extra85: first standalone __bases__[0].__name__ invariant for BaseEventLoop in asyncioextra85 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BaseEventLoop.__bases__[0].__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra85.BaseEventLoop_mro_len:
  description: "asyncio.BaseEventLoop.__mro__.__len__() == 3 — MRO is [BaseEventLoop, AbstractEventLoop, object], so length is 3; BaseEventLoop subclasses AbstractEventLoop which subclasses object; NEW in extra85: first standalone __mro__.__len__ invariant for BaseEventLoop in asyncioextra85 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BaseEventLoop.__mro__.__len__
  args: []
  expected: 3
