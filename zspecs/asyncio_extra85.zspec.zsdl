spec: asyncio_extra85
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio Event Loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/base_events.py"
  notes:
    - "This spec extends asyncio_extra84.zspec.zsdl."
    - "This spec covers: wave 246 theme — asyncio event loop class identity. NEW in extra85: AbstractEventLoop.__name__=='AbstractEventLoop'; AbstractEventLoop.__module__=='asyncio.events'; AbstractEventLoop.__bases__[0].__name__=='object' (AbstractEventLoop directly subclasses object, not ABC); AbstractEventLoop.__mro__.__len__()==2; AbstractEventLoop.__qualname__=='AbstractEventLoop'; BaseEventLoop.__name__=='BaseEventLoop'; BaseEventLoop.__module__=='asyncio.base_events'; BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop'; BaseEventLoop.__mro__.__len__()==3; BaseEventLoop.__qualname__=='BaseEventLoop'; AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (internally named with underscore prefix); AbstractEventLoopPolicy.__module__=='asyncio.events'; AbstractEventLoopPolicy.__bases__[0].__name__=='object'; AbstractEventLoopPolicy.__qualname__=='_AbstractEventLoopPolicy'; AbstractEventLoopPolicy.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop'. AbstractEventLoop is a top-level class in asyncio.events. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoop.__module__ == 'asyncio.events'. AbstractEventLoop is defined in the asyncio.events submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object'. AbstractEventLoop directly subclasses object, not ABC. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoop.__mro__.__len__() == 2. MRO is [AbstractEventLoop, object], length 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoop.__qualname__ == 'AbstractEventLoop'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BaseEventLoop.__name__ == 'BaseEventLoop'. BaseEventLoop is a top-level class in asyncio.base_events. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BaseEventLoop.__module__ == 'asyncio.base_events'. BaseEventLoop is defined in the asyncio.base_events submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BaseEventLoop.__bases__[0].__name__ == 'AbstractEventLoop'. BaseEventLoop directly subclasses AbstractEventLoop. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BaseEventLoop.__mro__.__len__() == 3. MRO is [BaseEventLoop, AbstractEventLoop, object], length 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BaseEventLoop.__qualname__ == 'BaseEventLoop'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy'. AbstractEventLoopPolicy is an alias for the internal _AbstractEventLoopPolicy class; its actual __name__ includes the underscore prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoopPolicy.__module__ == 'asyncio.events'. _AbstractEventLoopPolicy is defined in asyncio.events. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__ == 'object'. _AbstractEventLoopPolicy directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoopPolicy.__qualname__ == '_AbstractEventLoopPolicy'. Simple unqualified class name with underscore prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.AbstractEventLoopPolicy.__mro__.__len__() == 2. MRO is [_AbstractEventLoopPolicy, object], length 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio AbstractEventLoop class identity — extra85
#
# Wave 246 theme: asyncio event loop class identity.
#
# AbstractEventLoop.__name__ == 'AbstractEventLoop'
# AbstractEventLoop.__module__ == 'asyncio.events'
# AbstractEventLoop.__bases__[0].__name__ == 'object'
# AbstractEventLoop.__mro__.__len__() == 2
# AbstractEventLoop.__qualname__ == 'AbstractEventLoop'
# ---------------------------------------------------------------------------

table asyncio_extra85.AbstractEventLoop_identity:
  description: "asyncio AbstractEventLoop class identity checks in asyncioextra85 namespace — wave 246 theme: asyncio event loop class identity; AbstractEventLoop.__name__=='AbstractEventLoop'; AbstractEventLoop.__module__=='asyncio.events'; AbstractEventLoop.__bases__[0].__name__=='object' (AbstractEventLoop directly subclasses object, not ABC); AbstractEventLoop.__mro__.__len__()==2 (MRO: [AbstractEventLoop, object]); AbstractEventLoop.__qualname__=='AbstractEventLoop'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra85

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name,       AbstractEventLoop.__name__.__eq__,                ["AbstractEventLoop"], true, "AbstractEventLoop.__name__ == 'AbstractEventLoop' — top-level class name in asyncio.events; verified with Python 3.14.3"]
    - [ael_module,     AbstractEventLoop.__module__.__eq__,              ["asyncio.events"],    true, "AbstractEventLoop.__module__ == 'asyncio.events' — defined in asyncio.events submodule; verified with Python 3.14.3"]
    - [ael_base_name,  "AbstractEventLoop.__bases__[0].__name__.__eq__", ["object"],            true, "AbstractEventLoop.__bases__[0].__name__ == 'object' — AbstractEventLoop directly subclasses object; verified with Python 3.14.3"]
    - [ael_mro_len,    "AbstractEventLoop.__mro__.__len__",              [],                    2,    "AbstractEventLoop.__mro__.__len__() == 2 — MRO is [AbstractEventLoop, object]; verified with Python 3.14.3"]
    - [ael_qualname,   AbstractEventLoop.__qualname__.__eq__,            ["AbstractEventLoop"], true, "AbstractEventLoop.__qualname__ == 'AbstractEventLoop' — simple unqualified class name; verified with Python 3.14.3"]

