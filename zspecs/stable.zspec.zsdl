spec: stable
version: ">=0.1.8"
backend: node(stable)

docs: https://www.npmjs.com/package/stable

provenance:
  derived_from:
    - "stable README — https://www.npmjs.com/package/stable"
    - "Test vectors verified with stable via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "stable source"
  notes:
    - "stable is an npm package. Install: npm install stable"
    - "Performs a stable sort of an array (preserves relative order of equal elements)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a sorted array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table stable.sort:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: stable

  columns: [id, args, expected]
  rows:
    - [nums,    [[3, 1, 4, 1, 5]],       [1, 1, 3, 4, 5]]
    - [simple,  [[5, 2, 8, 1]],          [1, 2, 5, 8]]
    - [sorted,  [[1, 2, 3]],             [1, 2, 3]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:09:53Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
