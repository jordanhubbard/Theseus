spec: pp3391
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (pp3391): __int__, __float__, __complex__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "No pathlib class defines __int__ in its own __dict__: path objects are filesystem path abstractions, not numeric types; int() has no meaning for paths."
    - "No pathlib class defines __float__ in its own __dict__: path objects are not numeric types; float() has no semantic meaning for filesystem path objects."
    - "No pathlib class defines __complex__ in its own __dict__: path objects are not numeric types; complex() has no semantic meaning for filesystem path objects."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all numeric conversion operators absent from pathlib class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __int__ dict-presence — operator.contains(Cls.__dict__, '__int__')
#
# No pathlib class defines __int__ in its own __dict__; all false.
# pathlib path objects are filesystem path abstractions, not numeric types;
# int() has no semantic meaning for path objects.
# ---------------------------------------------------------------------------

table pp3391.int:
  description: "pathlib types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3391

  columns: [id, function, args, expected]
  rows:
    - ["pp3391001", operator.contains, [pathlib.PurePath.__dict__,         "__int__"], false]
    - ["pp3391002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__int__"], false]
    - ["pp3391003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__int__"], false]
    - ["pp3391004", operator.contains, [pathlib.Path.__dict__,             "__int__"], false]
    - ["pp3391005", operator.contains, [pathlib.PosixPath.__dict__,        "__int__"], false]

