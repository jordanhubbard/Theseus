spec: multiprocessing_extra1546
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 550 (_extra1546): bitwise operator dict-presence checks for multiprocessing classes."
    - "multiprocessing.Process and multiprocessing.pool.Pool are not bitwise types."
    - "None of these classes define __and__, __or__, __xor__, __invert__, __lshift__, __rshift__ or reflected variants in their own __dict__."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context' on CPython 3.14."
    - "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' on CPython 3.14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Process — bitwise operator dict-presence (all False)
# ---------------------------------------------------------------------------

table multiprocessing_extra1546.process_bitwise_ops:
  description: "multiprocessing.Process.__dict__ does not contain any bitwise operator dunder"
  kind: python_call_eq
  category: bitwise_presence
  id_prefix: mp1546pr

  columns: [id, function, args, expected]
  rows:
    - [mp1546pr001, multiprocessing.Process.__dict__.__contains__, ["__and__"],     false]
    - [mp1546pr002, multiprocessing.Process.__dict__.__contains__, ["__or__"],      false]
    - [mp1546pr003, multiprocessing.Process.__dict__.__contains__, ["__xor__"],     false]
    - [mp1546pr004, multiprocessing.Process.__dict__.__contains__, ["__invert__"],  false]
    - [mp1546pr005, multiprocessing.Process.__dict__.__contains__, ["__lshift__"],  false]
    - [mp1546pr006, multiprocessing.Process.__dict__.__contains__, ["__rshift__"],  false]
    - [mp1546pr007, multiprocessing.Process.__dict__.__contains__, ["__rand__"],    false]
    - [mp1546pr008, multiprocessing.Process.__dict__.__contains__, ["__ror__"],     false]
    - [mp1546pr009, multiprocessing.Process.__dict__.__contains__, ["__rxor__"],    false]
    - [mp1546pr010, multiprocessing.Process.__dict__.__contains__, ["__rlshift__"], false]
    - [mp1546pr011, multiprocessing.Process.__dict__.__contains__, ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# pool.Pool — bitwise operator dict-presence (all False)
# ---------------------------------------------------------------------------

table multiprocessing_extra1546.pool_bitwise_ops:
  description: "multiprocessing.pool.Pool.__dict__ does not contain any bitwise operator dunder"
  kind: python_call_eq
  category: bitwise_presence
  id_prefix: mp1546po

  columns: [id, function, args, expected]
  rows:
    - [mp1546po001, multiprocessing.pool.Pool.__dict__.__contains__, ["__and__"],     false]
    - [mp1546po002, multiprocessing.pool.Pool.__dict__.__contains__, ["__or__"],      false]
    - [mp1546po003, multiprocessing.pool.Pool.__dict__.__contains__, ["__xor__"],     false]
    - [mp1546po004, multiprocessing.pool.Pool.__dict__.__contains__, ["__invert__"],  false]
    - [mp1546po005, multiprocessing.pool.Pool.__dict__.__contains__, ["__lshift__"],  false]
    - [mp1546po006, multiprocessing.pool.Pool.__dict__.__contains__, ["__rshift__"],  false]
    - [mp1546po007, multiprocessing.pool.Pool.__dict__.__contains__, ["__rand__"],    false]
    - [mp1546po008, multiprocessing.pool.Pool.__dict__.__contains__, ["__ror__"],     false]
    - [mp1546po009, multiprocessing.pool.Pool.__dict__.__contains__, ["__rxor__"],    false]
    - [mp1546po010, multiprocessing.pool.Pool.__dict__.__contains__, ["__rlshift__"], false]
    - [mp1546po011, multiprocessing.pool.Pool.__dict__.__contains__, ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# pool.Pool — class identity and method dict-presence
# ---------------------------------------------------------------------------

table multiprocessing_extra1546.pool_class_identity:
  description: "multiprocessing.pool.Pool class name, module, and method dict-presence"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1546ci

  columns: [id, function, args, expected]
  rows:
    - [mp1546ci001, multiprocessing.pool.Pool.__name__.__eq__,                        ["Pool"],                    true]
    - [mp1546ci002, multiprocessing.pool.Pool.__qualname__.__eq__,                    ["Pool"],                    true]
    - [mp1546ci003, multiprocessing.pool.Pool.__module__.__eq__,                      ["multiprocessing.pool"],    true]
    - [mp1546ci004, multiprocessing.pool.Pool.__dict__.__contains__,                  ["apply"],                   true]
    - [mp1546ci005, multiprocessing.pool.Pool.__dict__.__contains__,                  ["map"],                     true]
    - [mp1546ci006, multiprocessing.pool.Pool.__dict__.__contains__,                  ["terminate"],               true]
