spec: asyncio_extra98
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra97

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra97.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio coroutine function identity and Event/Semaphore class attributes. NEW in extra98: asyncio.sleep.__class__.__name__=='function'; asyncio.sleep.__module__=='asyncio.tasks'; asyncio.gather.__class__.__name__=='function'; asyncio.gather.__module__=='asyncio.tasks'; asyncio.wait.__class__.__name__=='function'; asyncio.wait.__module__=='asyncio.tasks'; asyncio.Event.__class__.__name__=='type'; asyncio.Event.__module__=='asyncio.locks'; asyncio.Event.__mro__.__len__()==3; asyncio.Semaphore.__class__.__name__=='type'; asyncio.Semaphore.__module__=='asyncio.locks'; asyncio.Semaphore.__mro__.__len__()==4; asyncio.Lock.__class__.__name__=='type'; asyncio.Lock.__mro__.__len__()==4; asyncio.BoundedSemaphore.__mro__.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__class__.__name__ == 'function'. sleep is a coroutine function (inspect.iscoroutinefunction returns True) but its __class__.__name__ is still 'function'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__module__ == 'asyncio.tasks'. The sleep coroutine is defined in Lib/asyncio/tasks.py, not asyncio/__init__.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__mro__.__len__() == 3. MRO is [Event, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__mro__.__len__() == 4. MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio coroutine function identity — extra98
#
# Wave 254 theme: asyncio coroutine function identity and Event/Semaphore attrs.
#
# asyncio.sleep.__class__.__name__ == 'function'
# asyncio.sleep.__module__ == 'asyncio.tasks'
# asyncio.gather.__class__.__name__ == 'function'
# asyncio.gather.__module__ == 'asyncio.tasks'
# asyncio.wait.__class__.__name__ == 'function'
# asyncio.wait.__module__ == 'asyncio.tasks'
# ---------------------------------------------------------------------------

table asyncio_extra98.asyncio_coroutine_function_identity:
  description: "asyncio coroutine function identity checks in asynciocoroutineident98 namespace — wave 254 theme: asyncio coroutine function identity; asyncio.sleep, asyncio.gather, and asyncio.wait are all defined in Lib/asyncio/tasks.py; despite being coroutine functions (asyncio.sleep and asyncio.wait are coroutines; gather is not but still has class 'function'), their __class__.__name__ is always 'function' — Python coroutine functions have type 'function' at the class level; asyncio.sleep.__class__.__name__.__eq__('function')==True; asyncio.sleep.__module__.__eq__('asyncio.tasks')==True; asyncio.gather.__class__.__name__.__eq__('function')==True; asyncio.gather.__module__.__eq__('asyncio.tasks')==True; asyncio.wait.__class__.__name__.__eq__('function')==True; asyncio.wait.__module__.__eq__('asyncio.tasks')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocoroutineident98

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_class_nm,   asyncio.sleep.__class__.__name__.__eq__,   ["function"],      true, "asyncio.sleep.__class__.__name__ == 'function' — coroutine function, class is still 'function'; verified with Python 3.14.3"]
    - [sleep_module_eq,  asyncio.sleep.__module__.__eq__,           ["asyncio.tasks"], true, "asyncio.sleep.__module__ == 'asyncio.tasks' — defined in Lib/asyncio/tasks.py; verified with Python 3.14.3"]
    - [gather_class_nm,  asyncio.gather.__class__.__name__.__eq__,  ["function"],      true, "asyncio.gather.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [gather_module_eq, asyncio.gather.__module__.__eq__,          ["asyncio.tasks"], true, "asyncio.gather.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [wait_class_nm,    asyncio.wait.__class__.__name__.__eq__,    ["function"],      true, "asyncio.wait.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [wait_module_eq,   asyncio.wait.__module__.__eq__,            ["asyncio.tasks"], true, "asyncio.wait.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio coroutine function __qualname__ — extra98
#
# asyncio.sleep.__qualname__ == 'sleep' (len=5)
# asyncio.gather.__qualname__ == 'gather' (len=6)
# asyncio.wait.__qualname__ == 'wait' (len=4)
# ---------------------------------------------------------------------------

table asyncio_extra98.asyncio_coroutine_function_qualnames:
  description: "asyncio coroutine function __qualname__ checks in asynciocoroutineident98 namespace — wave 254 theme: asyncio coroutine function qualnames; asyncio.sleep.__qualname__ is 'sleep' (len=5, module-level function so qualname equals name); asyncio.gather.__qualname__ is 'gather' (len=6); asyncio.wait.__qualname__ is 'wait' (len=4, shortest of the three); all three are module-level functions in asyncio.tasks so qualname matches simple name; asyncio.sleep.__qualname__.__eq__('sleep')==True; asyncio.gather.__qualname__.__eq__('gather')==True; asyncio.wait.__qualname__.__eq__('wait')==True; asyncio.sleep.__qualname__.__len__()==5; asyncio.gather.__qualname__.__len__()==6; asyncio.wait.__qualname__.__len__()==4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocoroutineident98a

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_qeq,   asyncio.sleep.__qualname__.__eq__,    ["sleep"],  true, "asyncio.sleep.__qualname__ == 'sleep' (len=5); verified with Python 3.14.3"]
    - [sleep_qlen,  asyncio.sleep.__qualname__.__len__,   [],         5,    "asyncio.sleep.__qualname__.__len__() == 5; verified with Python 3.14.3"]
    - [gather_qeq,  asyncio.gather.__qualname__.__eq__,   ["gather"], true, "asyncio.gather.__qualname__ == 'gather' (len=6); verified with Python 3.14.3"]
    - [gather_qlen, asyncio.gather.__qualname__.__len__,  [],         6,    "asyncio.gather.__qualname__.__len__() == 6; verified with Python 3.14.3"]
    - [wait_qeq,    asyncio.wait.__qualname__.__eq__,     ["wait"],   true, "asyncio.wait.__qualname__ == 'wait' (len=4, shortest); verified with Python 3.14.3"]
    - [wait_qlen,   asyncio.wait.__qualname__.__len__,    [],         4,    "asyncio.wait.__qualname__.__len__() == 4; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Event class attributes — extra98
#
# asyncio.Event.__class__.__name__ == 'type'
# asyncio.Event.__module__ == 'asyncio.locks'
# asyncio.Event.__name__ == 'Event'
# asyncio.Event.__mro__.__len__() == 3
# asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin'
# ---------------------------------------------------------------------------

table asyncio_extra98.asyncio_event_class_attrs:
  description: "asyncio.Event class attribute checks in asynciocoroutineident98 namespace — wave 254 theme: asyncio.Event class identity; asyncio.Event is a pure Python class defined in Lib/asyncio/locks.py; Event.__class__.__name__.__eq__('type')==True (it is a class, so its class is type); Event.__module__.__eq__('asyncio.locks')==True (defined in the locks submodule); Event.__name__.__eq__('Event')==True (len=5); Event.__mro__.__len__()==3 (MRO is [Event, _LoopBoundMixin, object]); Event.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Event inherits from _LoopBoundMixin which provides event loop binding); Event is used to signal between coroutines — waiting coroutines block until the event is set; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocoroutineident98b

  columns: [id, function, args, expected, description]
  rows:
    - [event_class_nm,  asyncio.Event.__class__.__name__.__eq__,              ["type"],            true, "asyncio.Event.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [event_module,    asyncio.Event.__module__.__eq__,                      ["asyncio.locks"],   true, "asyncio.Event.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [event_name,      asyncio.Event.__name__.__eq__,                        ["Event"],           true, "asyncio.Event.__name__ == 'Event' (len=5); verified with Python 3.14.3"]
    - [event_mro_len,   asyncio.Event.__mro__.__len__,                        [],                  3,    "asyncio.Event.__mro__.__len__() == 3 — MRO is [Event, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [event_base0,     "asyncio.Event.__bases__[0].__name__.__eq__",         ["_LoopBoundMixin"], true, "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore class attributes — extra98
#
# asyncio.Semaphore.__class__.__name__ == 'type'
# asyncio.Semaphore.__module__ == 'asyncio.locks'
# asyncio.Semaphore.__name__ == 'Semaphore'
# asyncio.Semaphore.__mro__.__len__() == 4
# asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'
# asyncio.Lock.__mro__.__len__() == 4
# asyncio.BoundedSemaphore.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table asyncio_extra98.asyncio_semaphore_lock_class_attrs:
  description: "asyncio.Semaphore and related lock class attribute checks in asynciocoroutineident98 namespace — wave 254 theme: asyncio Semaphore/Lock class identity; asyncio.Semaphore is a pure Python class in asyncio.locks; Semaphore.__class__.__name__.__eq__('type')==True; Semaphore.__module__.__eq__('asyncio.locks')==True; Semaphore.__name__.__eq__('Semaphore')==True (len=9); Semaphore.__mro__.__len__()==4 (MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object], one deeper than Event's 3-element MRO); Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True; Lock.__mro__.__len__()==4 (same depth as Semaphore: [Lock, _ContextManagerMixin, _LoopBoundMixin, object]); BoundedSemaphore.__mro__.__len__()==5 (deepest: [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocoroutineident98c

  columns: [id, function, args, expected, description]
  rows:
    - [sem_class_nm,  asyncio.Semaphore.__class__.__name__.__eq__,               ["type"],                 true, "asyncio.Semaphore.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [sem_module,    asyncio.Semaphore.__module__.__eq__,                        ["asyncio.locks"],        true, "asyncio.Semaphore.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [sem_name,      asyncio.Semaphore.__name__.__eq__,                          ["Semaphore"],            true, "asyncio.Semaphore.__name__ == 'Semaphore' (len=9); verified with Python 3.14.3"]
    - [sem_mro_len,   asyncio.Semaphore.__mro__.__len__,                          [],                       4,    "asyncio.Semaphore.__mro__.__len__() == 4 — [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [sem_base0,     "asyncio.Semaphore.__bases__[0].__name__.__eq__",           ["_ContextManagerMixin"], true, "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'; verified with Python 3.14.3"]
    - [lock_mro_len,  asyncio.Lock.__mro__.__len__,                               [],                       4,    "asyncio.Lock.__mro__.__len__() == 4 — same depth as Semaphore; verified with Python 3.14.3"]
    - [bsem_mro_len,  asyncio.BoundedSemaphore.__mro__.__len__,                   [],                       5,    "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — deepest: [BoundedSemaphore, Semaphore, ...]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant asyncio_extra98.sleep_is_function_class:
  description: "asyncio.sleep.__class__.__name__.__eq__('function') returns True — asyncio.sleep is a coroutine function defined in Lib/asyncio/tasks.py; despite being a coroutine (inspect.iscoroutinefunction(asyncio.sleep) is True), its __class__.__name__ is 'function' rather than 'coroutine' because coroutine functions are instances of the 'function' type — only the coroutine objects they produce have class 'coroutine'; sleep's __module__ is 'asyncio.tasks' (not 'asyncio') because it is defined in the tasks submodule and re-exported via asyncio/__init__.py; NEW in extra98: first standalone asyncio.sleep class name invariant in asynciocoroutineident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra98.sleep_module_is_asyncio_tasks:
  description: "asyncio.sleep.__module__.__eq__('asyncio.tasks') returns True — asyncio.sleep is defined in Lib/asyncio/tasks.py and its __module__ attribute reflects the defining submodule 'asyncio.tasks', not the public namespace 'asyncio'; this contrasts with the public API where users import asyncio and call asyncio.sleep(); the gather and wait functions share the same module ('asyncio.tasks'); sleep's __qualname__ is 'sleep' (len=5, a module-level function); NEW in extra98: first standalone asyncio.sleep module invariant in asynciocoroutineident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra98.Event_mro_len_is_3:
  description: "asyncio.Event.__mro__.__len__() == 3 — asyncio.Event's MRO is [Event, _LoopBoundMixin, object]; this 3-element chain reflects Event's single-base inheritance from _LoopBoundMixin (which itself inherits from object); contrast with asyncio.Semaphore whose MRO has length 4 because Semaphore inherits from _ContextManagerMixin which in turn inherits from _LoopBoundMixin; Event does not use _ContextManagerMixin (it cannot be used as a context manager) while Semaphore and Lock both support 'async with'; NEW in extra98: first standalone Event MRO length invariant in asynciocoroutineident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra98.Semaphore_mro_len_is_4:
  description: "asyncio.Semaphore.__mro__.__len__() == 4 — asyncio.Semaphore's MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; this 4-element chain is one deeper than asyncio.Event (len=3) because Semaphore inherits from _ContextManagerMixin (enabling 'async with' usage) which itself inherits from _LoopBoundMixin; asyncio.Lock has the same MRO length of 4; asyncio.BoundedSemaphore has MRO length 5 because it adds Semaphore itself to the chain; NEW in extra98: first standalone Semaphore MRO length invariant in asynciocoroutineident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra98.gather_module_is_asyncio_tasks:
  description: "asyncio.gather.__module__.__eq__('asyncio.tasks') returns True — asyncio.gather is defined in Lib/asyncio/tasks.py alongside asyncio.sleep and asyncio.wait; all three are module-level functions in tasks.py that are re-exported through the asyncio package's public namespace; asyncio.gather.__qualname__ is 'gather' (len=6); asyncio.gather is not a coroutine function itself (inspect.iscoroutinefunction returns False for gather) even though it schedules and aggregates coroutines; NEW in extra98: first standalone asyncio.gather module invariant in asynciocoroutineident98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.gather.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true
