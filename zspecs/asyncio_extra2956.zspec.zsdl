# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __invert__, __round__, __trunc__ absence across a representative
# selection of asyncio classes in a single table for concise coverage.
# ---------------------------------------------------------------------------

table as2956.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Task_inv",       operator.contains, [Task.__dict__,      "__invert__"], false]
    - ["comb_Task_rnd",       operator.contains, [Task.__dict__,      "__round__"],  false]
    - ["comb_Task_trunc",     operator.contains, [Task.__dict__,      "__trunc__"],  false]
    - ["comb_Future_inv",     operator.contains, [Future.__dict__,    "__invert__"], false]
    - ["comb_Future_rnd",     operator.contains, [Future.__dict__,    "__round__"],  false]
    - ["comb_Future_trunc",   operator.contains, [Future.__dict__,    "__trunc__"],  false]
    - ["comb_Lock_inv",       operator.contains, [Lock.__dict__,      "__invert__"], false]
    - ["comb_Lock_rnd",       operator.contains, [Lock.__dict__,      "__round__"],  false]
    - ["comb_Lock_trunc",     operator.contains, [Lock.__dict__,      "__trunc__"],  false]
    - ["comb_Semaphore_inv",  operator.contains, [Semaphore.__dict__, "__invert__"], false]
    - ["comb_Semaphore_rnd",  operator.contains, [Semaphore.__dict__, "__round__"],  false]
    - ["comb_Semaphore_trunc",operator.contains, [Semaphore.__dict__, "__trunc__"],  false]
    - ["comb_Timeout_inv",    operator.contains, [Timeout.__dict__,   "__invert__"], false]
    - ["comb_Timeout_rnd",    operator.contains, [Timeout.__dict__,   "__round__"],  false]
    - ["comb_Timeout_trunc",  operator.contains, [Timeout.__dict__,   "__trunc__"],  false]
    - ["comb_TaskGroup_inv",  operator.contains, [TaskGroup.__dict__, "__invert__"], false]
    - ["comb_TaskGroup_rnd",  operator.contains, [TaskGroup.__dict__, "__round__"],  false]
    - ["comb_TaskGroup_trunc",operator.contains, [TaskGroup.__dict__, "__trunc__"],  false]
    - ["comb_Handle_inv",     operator.contains, [Handle.__dict__,    "__invert__"], false]
    - ["comb_Handle_rnd",     operator.contains, [Handle.__dict__,    "__round__"],  false]
    - ["comb_Handle_trunc",   operator.contains, [Handle.__dict__,    "__trunc__"],  false]
    - ["comb_Queue_inv",      operator.contains, [Queue.__dict__,     "__invert__"], false]
    - ["comb_Queue_rnd",      operator.contains, [Queue.__dict__,     "__round__"],  false]
    - ["comb_Queue_trunc",    operator.contains, [Queue.__dict__,     "__trunc__"],  false]
