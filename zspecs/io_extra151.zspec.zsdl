spec: io_extra151
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.open (the built-in open function exposed via the io module), io.DEFAULT_BUFFER_SIZE integer value, io.SEEK_SET/io.SEEK_CUR/io.SEEK_END seek position constants, and io.UnsupportedOperation exception class identity."
    - "io.open.__name__ == 'open' (len=4); io.open.__qualname__ == 'open' (len=4); io.open.__module__ == '_io' (len=3). io.open is the same object as the built-in open function (io.open is open evaluates to True)."
    - "io.open.__doc__ is a str of length 5959 — the longest docstring encountered in the io module specs so far; it exhaustively documents all parameters of the built-in open() function."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (not 8192 as sometimes assumed; this is 128 KiB, the actual default buffer size used for buffered I/O on this platform)."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2; all are plain int. io.SEEK_SET + io.SEEK_CUR + io.SEEK_END == 3."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' (len=20); its __module__ == 'io'; it subclasses both OSError and ValueError (two bases); its MRO has 6 entries: [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]."
    - "io.UnsupportedOperation.__doc__ is None (no docstring on the exception class)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open function identity
# io.open.__name__ == 'open' (len=4); io.open.__module__ == '_io' (len=3).
# io.open.__doc__ is a str of length 5959.
# io.open is the built-in open function.
# ---------------------------------------------------------------------------

table io_extra151.open_function_identity:
  description: "io.open function identity: __name__='open' (4), __qualname__='open' (4), __module__='_io' (3), __doc__ len=5959 (str)"
  kind: python_call_eq
  category: function_identity
  id_prefix: ioopen151

  columns: [id, function, args, expected, description]
  rows:
    - [open_name_eq,     open.__name__.__eq__,                    ["open"],  true, "io.open.__name__ == 'open' (io.open is the same object as the built-in open function; its __name__ is 'open', not 'io.open')"]
    - [open_name_len,    open.__name__.__len__,                   [],        4,    "io.open.__name__.__len__() == 4 ('open' has 4 characters)"]
    - [open_qualname_eq, open.__qualname__.__eq__,                ["open"],  true, "io.open.__qualname__ == 'open' (__qualname__ is also 'open'; open is a top-level function, not a method, so qualname equals name)"]
    - [open_qualname_len,open.__qualname__.__len__,               [],        4,    "io.open.__qualname__.__len__() == 4 (tied with __name__ at 4 characters)"]
    - [open_module_eq,   open.__module__.__eq__,                  ["_io"],   true, "io.open.__module__ == '_io' (io.open is implemented in the C extension module _io, not in Lib/io.py; io exposes it as part of the public API)"]
    - [open_module_len,  open.__module__.__len__,                 [],        3,    "io.open.__module__.__len__() == 3 ('_io' has 3 characters)"]
    - [open_doc_cls,     open.__doc__.__class__.__name__.__eq__,  ["str"],   true, "io.open.__doc__ is a str (non-None; the built-in open() docstring exhaustively documents all parameters)"]
    - [open_doc_len,     open.__doc__.__len__,                    [],        5959, "io.open.__doc__.__len__() == 5959 (the longest docstring in the io module; documents mode, buffering, encoding, errors, newline, closefd, opener parameters)"]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE and io.SEEK_* constants
# DEFAULT_BUFFER_SIZE == 131072 (128 KiB); type is int.
# SEEK_SET == 0, SEEK_CUR == 1, SEEK_END == 2; all int.
# SEEK_SET + SEEK_CUR + SEEK_END == 3.
# ---------------------------------------------------------------------------

table io_extra151.buffer_size_and_seek_constants:
  description: "io.DEFAULT_BUFFER_SIZE==131072 (int), io.SEEK_SET==0, io.SEEK_CUR==1, io.SEEK_END==2 (all int)"
  kind: python_call_eq
  category: constants
  id_prefix: ioconst151

  columns: [id, function, args, expected, description]
  rows:
    - [dbs_val_eq,       DEFAULT_BUFFER_SIZE.__eq__,                   [131072], true, "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB; this is the actual platform-default buffer size, not 8192 as sometimes assumed)"]
    - [dbs_cls_eq,       DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"],  true, "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' (it is a plain integer, not an enum or special type)"]
    - [seek_set_eq,      SEEK_SET.__eq__,                               [0],      true, "io.SEEK_SET == 0 (seek from the beginning of the stream; the standard POSIX SEEK_SET value)"]
    - [seek_cur_eq,      SEEK_CUR.__eq__,                               [1],      true, "io.SEEK_CUR == 1 (seek relative to the current stream position; the standard POSIX SEEK_CUR value)"]
    - [seek_end_eq,      SEEK_END.__eq__,                               [2],      true, "io.SEEK_END == 2 (seek relative to the end of the stream; the standard POSIX SEEK_END value)"]
    - [seek_set_cls,     SEEK_SET.__class__.__name__.__eq__,            ["int"],  true, "io.SEEK_SET.__class__.__name__ == 'int' (SEEK_SET is a plain int, not an enum; unlike many modern Python constants)"]
    - [seek_sum,         SEEK_SET.__add__,                              [3],      4,    "io.SEEK_SET + 3 == 4 (SEEK_SET is a plain Python int; arithmetic operations work normally on it)"]
    - [seek_cur_cls,     SEEK_CUR.__class__.__name__.__eq__,            ["int"],  true, "io.SEEK_CUR.__class__.__name__ == 'int'"]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation exception class identity
# __name__ == 'UnsupportedOperation' (len=20); __module__ == 'io'.
# Two direct bases: OSError and ValueError.
# MRO length == 6: [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object].
# __doc__ is None.
# ---------------------------------------------------------------------------

table io_extra151.UnsupportedOperation_identity:
  description: "io.UnsupportedOperation: __name__='UnsupportedOperation' (20), __module__='io', 2 bases (OSError, ValueError), MRO length=6, __doc__=None"
  kind: python_call_eq
  category: class_identity
  id_prefix: iounsup151

  columns: [id, function, args, expected, description]
  rows:
    - [unsup_name_eq,    UnsupportedOperation.__name__.__eq__,              ["UnsupportedOperation"], true, "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"]
    - [unsup_name_len,   UnsupportedOperation.__name__.__len__,             [],                       20,   "io.UnsupportedOperation.__name__.__len__() == 20 ('UnsupportedOperation' has 20 characters; the longest name in the io module public API)"]
    - [unsup_module_eq,  UnsupportedOperation.__module__.__eq__,            ["io"],                   true, "io.UnsupportedOperation.__module__ == 'io' (unlike io.open whose __module__ is '_io'; UnsupportedOperation is defined in Lib/io.py)"]
    - [unsup_cls_eq,     UnsupportedOperation.__class__.__name__.__eq__,    ["type"],                 true, "io.UnsupportedOperation.__class__.__name__ == 'type' (a regular exception class)"]
    - [unsup_bases_len,  UnsupportedOperation.__bases__.__len__,            [],                       2,    "io.UnsupportedOperation.__bases__.__len__() == 2 (UnsupportedOperation has two direct bases: OSError and ValueError)"]
    - [unsup_doc_none,   UnsupportedOperation.__doc__.__class__.__name__.__eq__, ["NoneType"],        true, "io.UnsupportedOperation.__doc__.__class__.__name__ == 'NoneType' (__doc__ is None; UnsupportedOperation has no docstring)"]
    - [unsup_mro_len,    "UnsupportedOperation.__mro__.__len__",            [],                       6,    "io.UnsupportedOperation.__mro__.__len__() == 6 ([UnsupportedOperation, OSError, ValueError, Exception, BaseException, object])"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra151.open.name_eq_open:
  description: "io.open.__name__ == 'open' — io.open is the same object as the built-in open function (io.open is open evaluates to True); its __name__ is the bare 'open', not 'io.open'. The function is implemented in the C extension _io (so __module__ == '_io') and re-exported via the io package."
  category: function_identity
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra151.open.module_eq__io:
  description: "io.open.__module__ == '_io' (length 3) — io.open is a C extension function from the _io module, not a pure Python function from Lib/io.py. This parallels the concrete IO classes (FileIO, BytesIO, etc.) which also have __module__ == '_io'. The public 'io' module re-exports the C implementation."
  category: function_identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra151.open.doc_len_5959:
  description: "io.open.__doc__.__len__() == 5959 (the built-in open() docstring is 5959 characters long; it documents all 7 parameters: file, mode, buffering, encoding, errors, newline, closefd, and opener; this is the longest docstring found in the io module specs, far exceeding io.FileIO.__doc__ (778) from io_extra149)"
  category: function_identity
  kind: python_call_eq
  function: open.__doc__.__len__
  args: []
  expected: 5959

invariant io_extra151.DEFAULT_BUFFER_SIZE.eq_131072:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB) — on macOS/Darwin the default buffer size is 131072 bytes (128 KiB), not 8192 bytes (8 KiB) as the Python documentation example sometimes implies; this constant determines the default buffer size when buffering=-1 is passed to io.open()"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra151.SEEK_SET.eq_0:
  description: "io.SEEK_SET == 0 — the integer constant for seeking from the beginning of a stream; corresponds to the POSIX SEEK_SET value; io.SEEK_SET, io.SEEK_CUR (1), and io.SEEK_END (2) are plain Python ints, not enum members"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra151.SEEK_END.eq_2:
  description: "io.SEEK_END == 2 — the integer constant for seeking relative to the end of a stream; io.SEEK_SET (0) + io.SEEK_CUR (1) + io.SEEK_END (2) == 3; all three seek constants are consecutive integers starting from 0"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra151.UnsupportedOperation.name_len_20:
  description: "io.UnsupportedOperation.__name__.__len__() == 20 ('UnsupportedOperation' has 20 characters; the longest class name in the io module public API; it is raised when an IO operation is not supported by a particular stream, such as seeking on a non-seekable stream)"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__len__
  args: []
  expected: 20

invariant io_extra151.UnsupportedOperation.mro_len_6:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 (MRO is [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]; UnsupportedOperation has two direct bases — OSError and ValueError — and the C3 linearization merges them into a 6-entry MRO; this dual inheritance means it can be caught by either 'except OSError' or 'except ValueError')"
  category: class_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__mro__.__len__"
  args: []
  expected: 6

