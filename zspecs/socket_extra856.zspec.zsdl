spec: socket_extra856
python: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/socket.py"
    - "cpython/Modules/socketmodule.c"
  not_derived_from:
    - "any third-party networking library"
  notes:
    - "Covers __class__.__name__ checks on socket address family and socket type constants"
    - "AF_INET, AF_INET6, AF_UNIX are AddressFamily enum members (Python 3.4+)"
    - "SOCK_STREAM, SOCK_DGRAM, SOCK_RAW are SocketKind enum members (Python 3.4+)"
    - "SOL_SOCKET, SO_*, and IPPROTO_* constants are plain int values"
  created_at: "2026-04-12"

table socket_extra856.constant_class_names:
  description: "Verify __class__.__name__ of socket address family, socket type, and protocol constants"
  kind: python_call_eq
  category: introspection
  id_prefix: sk856xx
  columns: [id, function, args, expected]
  rows:
    - [sk856xx001, "socket.AF_INET.__class__.__name__.__eq__", ["AddressFamily"], true]
    - [sk856xx002, "socket.AF_INET6.__class__.__name__.__eq__", ["AddressFamily"], true]
    - [sk856xx003, "socket.AF_UNIX.__class__.__name__.__eq__", ["AddressFamily"], true]
    - [sk856xx004, "socket.SOCK_STREAM.__class__.__name__.__eq__", ["SocketKind"], true]
    - [sk856xx005, "socket.SOCK_DGRAM.__class__.__name__.__eq__", ["SocketKind"], true]
    - [sk856xx006, "socket.SOCK_RAW.__class__.__name__.__eq__", ["SocketKind"], true]
    - [sk856xx007, "socket.SOL_SOCKET.__class__.__name__.__eq__", ["int"], true]
    - [sk856xx008, "socket.SO_REUSEADDR.__class__.__name__.__eq__", ["int"], true]
    - [sk856xx009, "socket.SO_KEEPALIVE.__class__.__name__.__eq__", ["int"], true]
    - [sk856xx010, "socket.IPPROTO_TCP.__class__.__name__.__eq__", ["int"], true]
    - [sk856xx011, "socket.IPPROTO_UDP.__class__.__name__.__eq__", ["int"], true]
    - [sk856xx012, "socket.IPPROTO_IP.__class__.__name__.__eq__", ["int"], true]
