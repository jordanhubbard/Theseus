spec: multiprocessing_extra2086
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__/__release_buffer__ dict-presence checks."
    - "multiprocessing types span Process, synchronize primitives (Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition), and queue types."
    - "None of these types define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "__format__ is the string-formatting protocol; multiprocessing types use the default object.__format__."
    - "__bytes__ is the bytes-conversion protocol; IPC objects are not directly byte-serializable via bytes()."
    - "__fspath__ is the filesystem-path protocol (os.fspath); multiprocessing types are not path-like objects."
    - "__buffer__ and __release_buffer__ are the PEP 688 buffer protocol; multiprocessing types do not expose raw buffers."
    - "multiprocessing.synchronize classes are verified directly (not via the top-level context-bound factories)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2086.format_protocol:
  description: "multiprocessing Process and synchronize types __format__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2086

  columns: [id, function, args, expected]
  rows:
    - ["mp2086001", "multiprocessing.Process.__dict__.__contains__", ["__format__"], false]
    - ["mp2086002", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__format__"], false]
    - ["mp2086003", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__format__"], false]
    - ["mp2086004", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__format__"], false]
    - ["mp2086005", "multiprocessing.synchronize.BoundedSemaphore.__dict__.__contains__", ["__format__"], false]
    - ["mp2086006", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__format__"], false]
    - ["mp2086007", "multiprocessing.synchronize.Condition.__dict__.__contains__", ["__format__"], false]
    - ["mp2086008", "multiprocessing.queues.Queue.__dict__.__contains__", ["__format__"], false]
    - ["mp2086009", "multiprocessing.queues.SimpleQueue.__dict__.__contains__", ["__format__"], false]
    - ["mp2086010", "multiprocessing.queues.JoinableQueue.__dict__.__contains__", ["__format__"], false]

