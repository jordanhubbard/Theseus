spec: theseus_logging_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_logging_cr2)
blocks: logging

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html"
    - "https://docs.python.org/3/library/logging.html#logrecord-attributes"
  notes:
    - "Clean-room extended logging utilities. Do NOT import logging."
    - "LogRecord(name, level, pathname, lineno, msg, args, exc_info): structured log record."
    - "Formatter(fmt): format log records using % style format strings."
    - "getLevelName(level): return string name for numeric level (e.g. 20 -> 'INFO')."
    - "Level constants: DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50."
    - "logging2_formatter(): Formatter('%(message)s').format(LogRecord('root', 20, '', 0, 'hello', [], None)) == 'hello'."
    - "logging2_record_level(): LogRecord('root', 20, '', 0, 'msg', [], None).levelname == 'INFO'."
    - "logging2_level_name(): getLevelName(20) == 'INFO'."
    - "Zero-arg invariant signatures — def logging2_formatter(): return hardcoded_result"
    - "Export: LogRecord, Formatter, getLevelName, DEBUG, INFO, WARNING, ERROR, CRITICAL."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_logging_cr2.formatter:
  description: "Formatter('%(message)s').format(LogRecord(..., 'hello', ...)) == 'hello'"
  category: formatter
  kind: python_call_eq
  function: logging2_formatter
  args: []
  expected: "hello"

invariant theseus_logging_cr2.record_level:
  description: "LogRecord with level=20 has levelname == 'INFO'"
  category: record
  kind: python_call_eq
  function: logging2_record_level
  args: []
  expected: "INFO"

invariant theseus_logging_cr2.level_name:
  description: "getLevelName(20) == 'INFO'"
  category: getLevelName
  kind: python_call_eq
  function: logging2_level_name
  args: []
  expected: "INFO"
