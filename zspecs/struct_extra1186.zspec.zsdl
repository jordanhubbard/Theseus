spec: struct_extra1186
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct.__dict__/__mro__/__bases__ class names (mappingproxy/tuple/tuple), struct.error.__dict__/__mro__/__bases__ class names (mappingproxy/tuple/tuple), struct.Struct.__subclasses__ and struct.error.__subclasses__ qualname and class name, and MRO/bases lengths for Struct and error"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1186.struct_class_dict_mro_bases:
  description: "struct.Struct __dict__/__mro__/__bases__ class names confirming mappingproxy and tuple types"
  kind: python_call_eq
  category: struct_class_dict_mro_bases
  id_prefix: st1186dm
  columns: [id, function, args, expected]
  rows:
    - [st1186dm001, struct.Struct.__dict__.__class__.__name__.__eq__,             ["mappingproxy"],  true]
    - [st1186dm002, struct.Struct.__dict__.__class__.__qualname__.__eq__,         ["mappingproxy"],  true]
    - [st1186dm003, struct.Struct.__dict__.__class__.__module__.__eq__,           ["builtins"],      true]
    - [st1186dm004, struct.Struct.__mro__.__class__.__name__.__eq__,              ["tuple"],         true]
    - [st1186dm005, struct.Struct.__mro__.__class__.__qualname__.__eq__,          ["tuple"],         true]
    - [st1186dm006, struct.Struct.__mro__.__class__.__module__.__eq__,            ["builtins"],      true]
    - [st1186dm007, struct.Struct.__bases__.__class__.__name__.__eq__,            ["tuple"],         true]
    - [st1186dm008, struct.Struct.__bases__.__class__.__module__.__eq__,          ["builtins"],      true]
    - [st1186dm009, struct.Struct.__mro__.__len__,                                [],                2]
    - [st1186dm010, struct.Struct.__bases__.__len__,                              [],                1]

table struct_extra1186.error_class_dict_mro_bases:
  description: "struct.error __dict__/__mro__/__bases__ class names and lengths"
  kind: python_call_eq
  category: error_class_dict_mro_bases
  id_prefix: st1186em
  columns: [id, function, args, expected]
  rows:
    - [st1186em001, struct.error.__dict__.__class__.__name__.__eq__,              ["mappingproxy"],  true]
    - [st1186em002, struct.error.__dict__.__class__.__qualname__.__eq__,          ["mappingproxy"],  true]
    - [st1186em003, struct.error.__dict__.__class__.__module__.__eq__,            ["builtins"],      true]
    - [st1186em004, struct.error.__mro__.__class__.__name__.__eq__,               ["tuple"],         true]
    - [st1186em005, struct.error.__mro__.__class__.__qualname__.__eq__,           ["tuple"],         true]
    - [st1186em006, struct.error.__mro__.__class__.__module__.__eq__,             ["builtins"],      true]
    - [st1186em007, struct.error.__bases__.__class__.__name__.__eq__,             ["tuple"],         true]
    - [st1186em008, struct.error.__bases__.__class__.__module__.__eq__,           ["builtins"],      true]
    - [st1186em009, struct.error.__mro__.__len__,                                 [],                4]
    - [st1186em010, struct.error.__bases__.__len__,                               [],                1]

table struct_extra1186.subclasses_qualname_and_class_name:
  description: "struct.Struct.__subclasses__ and struct.error.__subclasses__ qualname and class name"
  kind: python_call_eq
  category: subclasses_qualname_class_name
  id_prefix: st1186sc
  columns: [id, function, args, expected]
  rows:
    - [st1186sc001, struct.Struct.__subclasses__.__qualname__.__eq__,             ["Struct.__subclasses__"],  true]
    - [st1186sc002, struct.Struct.__subclasses__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [st1186sc003, struct.Struct.__subclasses__.__class__.__module__.__eq__,     ["builtins"],               true]
    - [st1186sc004, struct.error.__subclasses__.__qualname__.__eq__,              ["error.__subclasses__"],   true]
    - [st1186sc005, struct.error.__subclasses__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [st1186sc006, struct.error.__subclasses__.__class__.__module__.__eq__,      ["builtins"],               true]
    - [st1186sc007, struct.Struct.__subclasses__.__qualname__.__class__.__name__.__eq__, ["str"],             true]
    - [st1186sc008, struct.error.__subclasses__.__qualname__.__class__.__name__.__eq__,  ["str"],             true]
    - [st1186sc009, struct.Struct.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"],             true]
