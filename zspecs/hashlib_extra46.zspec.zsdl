spec: hashlib_extra46
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra45.zspec.zsdl — covers sha3_224/__qualname__.__eq__('openssl_sha3_224') and sha3_384/__qualname__.__eq__('openssl_sha3_384'); sha3_224/sha3_384 __qualname__.__len__()==16."
    - "hashlib_extra36.zspec.zsdl — covers sha3_224/__name__.__len__()==16 and sha3_384/__name__.__len__()==16 (length checks only, NOT __name__.__eq__ string values); sha3_224/sha3_384 __module__.__len__()==8 (length only)."
    - "hashlib_extra32.zspec.zsdl — covers sha3_256/__name__.__len__()==16 and __module__.__len__()==8; sha1/sha512/sha224/sha384/blake2b/blake2s __module__.__len__()."
    - "hashlib_extra10.zspec.zsdl — covers sha3_224/__name__.__eq__('sha3_224') and sha3_384/__name__.__eq__('sha3_384') with stale pre-OpenSSL values; sha3_224/__module__.__eq__('_sha3') and sha3_384/__module__.__eq__('_sha3') with stale pre-OpenSSL values. On CPython 3.12+ / macOS with OpenSSL backend, the actual __name__ is 'openssl_sha3_224' and __module__ is '_hashlib'."
  notes:
    - "This spec extends hashlib through hashlib_extra45; it does NOT duplicate invariants present in those files."
    - "Coverage gap: hashlib_extra10 covers sha3_224/__name__.__eq__('sha3_224') and sha3_384/__name__.__eq__('sha3_384') with stale pre-OpenSSL values, and sha3_224/__module__.__eq__('_sha3') / sha3_384/__module__.__eq__('_sha3') with stale pre-OpenSSL values. On OpenSSL-backed CPython 3.12+, the actual values are __name__=='openssl_sha3_224' and __module__=='_hashlib'. hashlib_extra36 covers __name__.__len__()==16 and __module__.__len__()==8 for sha3_224 and sha3_384 (length checks only). NO prior spec checks sha3_224/__name__.__eq__('openssl_sha3_224') or sha3_384/__name__.__eq__('openssl_sha3_384') as correct string eq values. NO prior spec checks sha3_224/__module__.__eq__('_hashlib') or sha3_384/__module__.__eq__('_hashlib') as correct string eq values. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224'. On OpenSSL-backed CPython 3.12+, the SHA3-224 constructor has __name__ == 'openssl_sha3_224'. extra36 covers __name__.__len__()==16 (length only); extra10 has stale value 'sha3_224'; no prior spec checks __name__.__eq__('openssl_sha3_224'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__ == 'openssl_sha3_384'. Same pattern as sha3_224. extra36 covers __name__.__len__()==16 (length only); extra10 has stale value 'sha3_384'; no prior spec checks __name__.__eq__('openssl_sha3_384'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__module__ == '_hashlib'. On OpenSSL-backed CPython 3.12+, the SHA3-224 constructor lives in '_hashlib'. extra36 covers __module__.__len__()==8 (length only); extra10 has stale value '_sha3'; no prior spec checks __module__.__eq__('_hashlib') for sha3_224. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__module__ == '_hashlib'. Same pattern as sha3_224. extra36 covers __module__.__len__()==8 (length only); extra10 has stale value '_sha3'; no prior spec checks __module__.__eq__('_hashlib') for sha3_384. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_224 and sha3_384 __name__.__eq__ string values (correct OpenSSL)
#
# hashlib_extra10 has stale pre-OpenSSL values 'sha3_224'/'sha3_384' for __name__.__eq__.
# hashlib_extra36 covers sha3_224/__name__.__len__()==16 and sha3_384/__name__.__len__()==16
#   (length checks only, NOT string eq values).
# On OpenSSL-backed CPython 3.12+, __name__ == 'openssl_sha3_224' / 'openssl_sha3_384'.
# NO prior spec checks __name__.__eq__ with the correct OpenSSL-backed values for
# sha3_224 or sha3_384.
# ---------------------------------------------------------------------------

table hashlib_extra46.sha3_224_384_name_eq:
  description: "hashlib.sha3_224/sha3_384 __name__.__eq__ string values (correct openssl_sha3_* values) — novel: extra10 has stale '_sha3' pre-OpenSSL values; extra36 covers __name__.__len__ only; no prior spec checks __name__.__eq__('openssl_sha3_224') or __name__.__eq__('openssl_sha3_384') as correct values"
  kind: python_call_eq
  category: function_names
  id_prefix: hs3ne46

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_name_eq, sha3_224.__name__.__eq__, ["openssl_sha3_224"], true]
    - [sha3_384_name_eq, sha3_384.__name__.__eq__, ["openssl_sha3_384"], true]

# ---------------------------------------------------------------------------
# hashlib.sha3_224 and sha3_384 __module__.__eq__ string values (correct OpenSSL)
#
# hashlib_extra10 has stale pre-OpenSSL values '_sha3' for __module__.__eq__.
# hashlib_extra36 covers sha3_224/__module__.__len__()==8 and
#   sha3_384/__module__.__len__()==8 (length checks only).
# On OpenSSL-backed CPython 3.12+, __module__ == '_hashlib'.
# NO prior spec checks __module__.__eq__('_hashlib') for sha3_224 or sha3_384.
# ---------------------------------------------------------------------------

table hashlib_extra46.sha3_224_384_module_eq:
  description: "hashlib.sha3_224/sha3_384 __module__.__eq__ string values ('_hashlib') — novel: extra10 has stale '_sha3' pre-OpenSSL values; extra36 covers __module__.__len__ only; no prior spec checks __module__.__eq__('_hashlib') for sha3_224 or sha3_384"
  kind: python_call_eq
  category: function_module
  id_prefix: hs3me46

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_module_eq, sha3_224.__module__.__eq__, ["_hashlib"], true]
    - [sha3_384_module_eq, sha3_384.__module__.__eq__, ["_hashlib"], true]
