spec: mailbox_extra2
version: ">=3.9"
backend: python_module(mailbox)

docs: https://docs.python.org/3/library/mailbox.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mailbox.html — Python mailbox module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mailbox.py"
  notes:
    - "This spec extends mailbox.zspec.zsdl and mailbox_extra.zspec.zsdl."
    - "mailbox.zspec.zsdl covers: class names for Mailbox/Maildir/mbox/MH/Babyl/MMDF and all message classes; exception class names; Mailbox.__module__; hierarchy for Maildir (base=Mailbox), NoSuchMailboxError/NotEmptyError/ExternalClashError bases."
    - "mailbox_extra.zspec.zsdl covers: __module__ for all container/message/exception classes; Error.__name__ and base; mbox/MH/Babyl/MMDF bases (all == 'Mailbox'); Message base; Mailbox.__doc__ is str; FormatError base; all message-subclass bases."
    - "This spec adds: __qualname__ for Mailbox/Maildir/mbox/MH/Babyl/MMDF/Message; mbox.__bases__[0].__name__ == '_singlefileMailbox' (the actual direct base in CPython); Mailbox.__bases__[0].__name__ == 'object'; table of __qualname__ checks."
    - "In CPython, mbox inherits from _singlefileMailbox which in turn inherits from Mailbox."
    - "mailbox.Mailbox inherits directly from object — it is the abstract base with no mailbox-specific parent."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — not covered in prior specs
# (Prior specs cover __name__ and __module__; __qualname__ is new)
# ---------------------------------------------------------------------------

table mailbox_extra2.qualnames.containers:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Mailbox, Mailbox.__qualname__.__eq__, ["Mailbox"], true]
    - [Maildir, Maildir.__qualname__.__eq__, ["Maildir"], true]
    - [mbox,    mbox.__qualname__.__eq__,    ["mbox"],    true]
    - [MH,      MH.__qualname__.__eq__,      ["MH"],      true]
    - [Babyl,   Babyl.__qualname__.__eq__,   ["Babyl"],   true]
    - [MMDF,    MMDF.__qualname__.__eq__,    ["MMDF"],    true]

invariant mailbox_extra2.qualname.Message:
  description: "mailbox.Message.__qualname__ == 'Message'"
  category: qualnames
  kind: python_call_eq
  function: Message.__qualname__.__eq__
  args: ["Message"]
  expected: true

# ---------------------------------------------------------------------------
# Mailbox.__bases__[0] — Mailbox is a direct subclass of object
# (Prior specs check Maildir/mbox/MH/Babyl/MMDF bases but not Mailbox itself)
# ---------------------------------------------------------------------------

invariant mailbox_extra2.hierarchy.Mailbox_base:
  description: "mailbox.Mailbox.__bases__[0].__name__ == 'object' — Mailbox has no mailbox-specific parent"
  category: hierarchy
  kind: python_call_eq
  function: Mailbox.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# mbox.__bases__[0] — actual direct base in CPython is _singlefileMailbox
# (mailbox_extra.zspec.zsdl tested mbox.__bases__[0].__name__ == 'Mailbox';
#  in CPython the direct base is the private _singlefileMailbox intermediate.
#  This invariant captures the CPython implementation detail.)
# ---------------------------------------------------------------------------

invariant mailbox_extra2.hierarchy.mbox_direct_base:
  description: "mbox.__bases__[0].__name__ == '_singlefileMailbox' — mbox inherits from the private intermediate"
  category: hierarchy
  kind: python_call_eq
  function: mbox.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_singlefileMailbox"

# ---------------------------------------------------------------------------
# __qualname__ checks — exception classes
# ---------------------------------------------------------------------------

table mailbox_extra2.qualnames.exceptions:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Error,               Error.__qualname__.__eq__,               ["Error"],               true]
    - [NoSuchMailboxError,  NoSuchMailboxError.__qualname__.__eq__,  ["NoSuchMailboxError"],  true]
    - [NotEmptyError,       NotEmptyError.__qualname__.__eq__,       ["NotEmptyError"],       true]
    - [ExternalClashError,  ExternalClashError.__qualname__.__eq__,  ["ExternalClashError"],  true]
    - [FormatError,         FormatError.__qualname__.__eq__,         ["FormatError"],         true]

# ---------------------------------------------------------------------------
# Message.__bases__ — mailbox.Message inherits from email.message.Message
# (mailbox_extra covers this but checks __name__ == 'Message' via getitem;
#  here we check the same with __qualname__ for the base, which is distinct)
# ---------------------------------------------------------------------------

invariant mailbox_extra2.hierarchy.Message_base_qualname:
  description: "mailbox.Message.__bases__[0].__qualname__ == 'Message' — email.message.Message qualname"
  category: hierarchy
  kind: python_call_eq
  function: Message.__bases__.__getitem__
  args: [0]
  method: __qualname__
  expected: "Message"

# ---------------------------------------------------------------------------
# Error.__qualname__ and Error.__name__ consistency
# (mailbox_extra covers Error.__name__ == 'Error'; __qualname__ is new)
# ---------------------------------------------------------------------------

invariant mailbox_extra2.Error.qualname:
  description: "mailbox.Error.__qualname__ == 'Error'"
  category: qualnames
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true
