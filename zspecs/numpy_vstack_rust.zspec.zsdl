spec: numpy_vstack_rust
version: ">=3.9"
backend: rust_module(numpy_vstack_rust)

docs: https://numpy.org/doc/stable/reference/generated/numpy.vstack.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/ — NumPy documentation"
  not_derived_from:
    - "NumPy source: numpy/core/shape_base.py"
  notes:
    - "numpy.vstack stacks arrays row-wise (vertically, along axis 0)."
    - "numpy.hstack stacks arrays column-wise (horizontally, along axis 1 for 2D)."
    - "vstack([[1,2],[3,4],[5,6]]).tolist() == [[1,2],[3,4],[5,6]] — 3×2 matrix."
    - "vstack([[1,2,3],[4,5,6]]).tolist() == [[1,2,3],[4,5,6]] — 2×3 matrix."
    - "hstack([[1,2],[3,4]]).tolist() == [1,2,3,4] — concatenated 1D arrays."
    - "hstack([[1,2,3],[4,5,6]]).tolist() == [1,2,3,4,5,6] — flat concatenation."
    - "For 2D arrays, hstack concatenates columns: hstack([[[1],[2]],[[3],[4]]]).tolist() == [[1,3],[2,4]]."
    - "All test vectors verified against numpy 2.2.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# vstack — vertical stack (stack rows)
table numpy_vstack_rust.vstack.vectors:
  kind: python_call_eq
  category: vstack
  id_prefix: nvs_vs
  function: vstack
  method_chain: tolist

  columns: [id, args, expected]
  rows:
    - [three_rows,  [[[1, 2], [3, 4], [5, 6]]],  [[1, 2], [3, 4], [5, 6]]]
    - [two_rows,    [[[1, 2, 3], [4, 5, 6]]],      [[1, 2, 3], [4, 5, 6]]]
    - [single_row,  [[[1, 2, 3]]],                 [[1, 2, 3]]]

# hstack — horizontal stack (concatenate along columns)
table numpy_vstack_rust.hstack.vectors:
  kind: python_call_eq
  category: hstack
  id_prefix: nvs_hs
  function: hstack
  method_chain: tolist

  columns: [id, args, expected]
  rows:
    - [two_1d,    [[[1, 2], [3, 4]]],    [1, 2, 3, 4]]
    - [three_1d,  [[[1, 2], [3, 4], [5, 6]]], [1, 2, 3, 4, 5, 6]]
    - [single_1d, [[[1, 2, 3]]],          [1, 2, 3]]

# column_stack — stack 1D arrays as columns in 2D matrix
table numpy_vstack_rust.column_stack.vectors:
  kind: python_call_eq
  category: column_stack
  id_prefix: nvs_cs
  function: column_stack
  method_chain: tolist

  columns: [id, args, expected]
  rows:
    - [two_cols,   [[[1, 2, 3], [4, 5, 6]]],   [[1, 4], [2, 5], [3, 6]]]
    - [three_cols, [[[1, 2], [3, 4], [5, 6]]],  [[1, 3, 5], [2, 4, 6]]]

