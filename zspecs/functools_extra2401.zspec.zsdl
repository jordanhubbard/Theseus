spec: functools_extra2401
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "CPython source — Lib/functools.py and Modules/_functoolsmodule.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 607 (_extra2401): __hash__ and __eq__ implementation type classification."
    - "functools.partial is a C extension type; its __hash__ and __eq__ are inherited from object as wrapper_descriptor."
    - "functools.partial does NOT set __hash__ = None in Python 3.14 (unlike older docs); it is hashable."
    - "functools.partialmethod, cached_property, and _lru_cache_wrapper all inherit __hash__ and __eq__ from object."
    - "None of these classes define __hash__ or __eq__ in their own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __hash__ implementation type for functools classes (class level)
# ===

table functools_extra2401.hash_class_types:
  description: "__hash__ implementation type (class-level) for functools types"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2401
  columns: [id, function, args, expected]
  rows:
    - ["ft2401001", "functools.partial.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401002", "functools.partialmethod.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401003", "functools.cached_property.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401004", "functools._lru_cache_wrapper.__hash__.__class__.__name__", [], "wrapper_descriptor"]

# ===
# Table 2: __eq__ implementation type for functools classes (class level)
# ===

table functools_extra2401.eq_class_types:
  description: "__eq__ implementation type (class-level) for functools types"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2401
  columns: [id, function, args, expected]
  rows:
    - ["ft2401005", "functools.partial.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401006", "functools.partialmethod.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401007", "functools.cached_property.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401008", "functools._lru_cache_wrapper.__eq__.__class__.__name__", [], "wrapper_descriptor"]

# ===
# Table 3: __hash__ NOT in class __dict__ (inherited, not overridden)
# ===

table functools_extra2401.hash_not_in_dict:
  description: "__hash__ is not in __dict__ for functools types that inherit from object"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2401
  columns: [id, function, args, expected]
  rows:
    - ["ft2401009", "functools.partial.__dict__.__contains__", ["__hash__"], false]
    - ["ft2401010", "functools.partialmethod.__dict__.__contains__", ["__hash__"], false]
    - ["ft2401011", "functools.cached_property.__dict__.__contains__", ["__hash__"], false]
    - ["ft2401012", "functools._lru_cache_wrapper.__dict__.__contains__", ["__hash__"], false]

# ===
# Table 4: __eq__ NOT in class __dict__ (inherited, not overridden)
# ===

table functools_extra2401.eq_not_in_dict:
  description: "__eq__ is not in __dict__ for functools types that inherit from object"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2401
  columns: [id, function, args, expected]
  rows:
    - ["ft2401013", "functools.partial.__dict__.__contains__", ["__eq__"], false]
    - ["ft2401014", "functools.partialmethod.__dict__.__contains__", ["__eq__"], false]
    - ["ft2401015", "functools.cached_property.__dict__.__contains__", ["__eq__"], false]
    - ["ft2401016", "functools._lru_cache_wrapper.__dict__.__contains__", ["__eq__"], false]

# ===
# Table 5: __hash__ is wrapper_descriptor on object (the inherited source)
# ===

table functools_extra2401.object_hash_descriptor:
  description: "object.__hash__ is the wrapper_descriptor that functools types inherit; __qualname__ confirms identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2401
  columns: [id, function, args, expected]
  rows:
    - ["ft2401017", "object.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401018", "object.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2401019", "functools.partial.__hash__.__qualname__", [], "object.__hash__"]
    - ["ft2401020", "functools.partial.__eq__.__qualname__", [], "object.__eq__"]
    - ["ft2401021", "functools._lru_cache_wrapper.__hash__.__qualname__", [], "object.__hash__"]
    - ["ft2401022", "functools.cached_property.__hash__.__qualname__", [], "object.__hash__"]
    - ["ft2401023", "functools.partialmethod.__hash__.__qualname__", [], "object.__hash__"]
