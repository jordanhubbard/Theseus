spec: theseus_urllib_cr
version: ">=3.0"
backend: python_cleanroom(theseus_urllib_cr)
blocks: urllib

docs: https://docs.python.org/3/library/urllib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.html"
  not_derived_from:
    - "CPython source: Lib/urllib/__init__.py"
  notes:
    - "Clean-room urllib namespace package. Do NOT import urllib."

error_model: python_exceptions

invariant theseus_urllib_cr.urllib2_package:
  description: "urllib package is importable as a namespace"
  category: behavior
  kind: python_call_eq
  function: urllib2_package
  args: []
  expected: true

invariant theseus_urllib_cr.urllib2_name:
  description: "urllib package has correct __name__"
  category: behavior
  kind: python_call_eq
  function: urllib2_name
  args: []
  expected: true

invariant theseus_urllib_cr.urllib2_path:
  description: "urllib package has __path__ (is a package)"
  category: behavior
  kind: python_call_eq
  function: urllib2_path
  args: []
  expected: true
