spec: abc_extra2416
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/abc.html"
    - "CPython source — Lib/abc.py and Modules/_abc.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "abc.ABC and abc.ABCMeta do NOT define __iter__ or __next__; they are abstract base class infrastructure, not iterators."
    - "abc.abstractclassmethod, abc.abstractproperty, abc.abstractstaticmethod are deprecated class-based decorators; none define __iter__/__next__."
    - "abc.abstractmethod is a plain Python function (not a class), so its __dict__ is a function's attribute dict; no __iter__/__next__ there."
    - "ABCMeta defines __instancecheck__ and __subclasscheck__ for isinstance/issubclass dispatch, but not iteration protocol."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ absence in class __dict__ for abc infrastructure types
# ===

table abc_extra2416.iter_not_in_dict:
  description: "abc.ABC, abc.ABCMeta, and abc decorator classes do not define __iter__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2416
  columns: [id, function, args, expected]
  rows:
    - ["ab2416001", "abc.ABC.__dict__.__contains__", ["__iter__"], false]
    - ["ab2416002", "abc.ABCMeta.__dict__.__contains__", ["__iter__"], false]
    - ["ab2416003", "abc.abstractclassmethod.__dict__.__contains__", ["__iter__"], false]
    - ["ab2416004", "abc.abstractproperty.__dict__.__contains__", ["__iter__"], false]
    - ["ab2416005", "abc.abstractstaticmethod.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ absence in class __dict__ for abc infrastructure types
# ===

table abc_extra2416.next_not_in_dict:
  description: "abc.ABC, abc.ABCMeta, and abc decorator classes do not define __next__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2416
  columns: [id, function, args, expected]
  rows:
    - ["ab2416006", "abc.ABC.__dict__.__contains__", ["__next__"], false]
    - ["ab2416007", "abc.ABCMeta.__dict__.__contains__", ["__next__"], false]
    - ["ab2416008", "abc.abstractclassmethod.__dict__.__contains__", ["__next__"], false]
    - ["ab2416009", "abc.abstractproperty.__dict__.__contains__", ["__next__"], false]
    - ["ab2416010", "abc.abstractstaticmethod.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: ABCMeta metaclass protocol keys present vs iteration keys absent
# ===

table abc_extra2416.abcmeta_protocol_keys:
  description: "ABCMeta defines metaclass protocol methods (__instancecheck__, __subclasscheck__, __new__) but not iteration protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2416
  columns: [id, function, args, expected]
  rows:
    - ["ab2416011", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab2416012", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]
    - ["ab2416013", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab2416014", "abc.ABCMeta.__dict__.__contains__", ["__iter__"], false]
    - ["ab2416015", "abc.ABCMeta.__dict__.__contains__", ["__next__"], false]

# ===
# Table 4: ABC class __dict__ contents — slots and abstractmethods, no iter protocol
# ===

table abc_extra2416.abc_dict_contents:
  description: "abc.ABC defines __abstractmethods__ and __slots__ in its __dict__ but neither __iter__ nor __next__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2416
  columns: [id, function, args, expected]
  rows:
    - ["ab2416016", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab2416017", "abc.ABC.__dict__.__contains__", ["__slots__"], true]
    - ["ab2416018", "abc.ABC.__dict__.__contains__", ["__iter__"], false]
    - ["ab2416019", "abc.ABC.__dict__.__contains__", ["__next__"], false]
    - ["ab2416020", "abc.abstractclassmethod.__dict__.__contains__", ["__iter__"], false]
    - ["ab2416021", "abc.abstractproperty.__dict__.__contains__", ["__iter__"], false]
