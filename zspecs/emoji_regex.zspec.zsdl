spec: emoji_regex
version: ">=10.0.0"
backend: node(emoji-regex)

docs: https://github.com/mathiasbynens/emoji-regex#readme

provenance:
  derived_from:
    - "emoji-regex README — https://github.com/mathiasbynens/emoji-regex#readme"
    - "Unicode Technical Standard #51 — Emoji"
    - "Test vectors verified with emoji-regex via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "emoji-regex source"
  notes:
    - "Returns a regex matching all UTS #51 emoji sequences (Mathias Bynens, generated from the Unicode emoji-test data)."
    - "Install: npm install emoji-regex"
    - "v10 ESM with CJS shim; default export is the regex factory."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "null"
  stickiness: "N/A — each call returns a fresh regex (with /g flag)."
  codes: {}

# .test() — basic emoji detection
invariant emoji_regex.detects_party_popper:
  description: "regex.test('🎉') is true"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: test, args: ["🎉"]}
  expected: true

invariant emoji_regex.detects_smiley:
  description: "Detects smiley face 😀"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: test, args: ["😀"]}
  expected: true

invariant emoji_regex.no_emoji_in_plain_text:
  description: "Plain ASCII text has no emoji"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: test, args: ["Hello World"]}
  expected: false

invariant emoji_regex.detects_in_middle_of_text:
  description: "Emoji embedded in text is detected"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: test, args: ["before 🎉 after"]}
  expected: true

# Default regex has /g flag set
invariant emoji_regex.is_global:
  description: "Returned regex has the global flag"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: global}
  expected: true

invariant emoji_regex.flags_string:
  description: "Returned regex has flags 'g' (global only — emoji-regex relies on surrogate pair literals, not /u)"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: flags}
  expected: "g"

# Empty string detection
invariant emoji_regex.empty_string_no_match:
  description: "test('') returns false"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: test, args: [""]}
  expected: false
