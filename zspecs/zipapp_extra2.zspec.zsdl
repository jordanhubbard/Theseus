spec: zipapp_extra2
version: ">=3.9"
backend: python_module(zipapp)

docs: https://docs.python.org/3/library/zipapp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipapp.html — Python zipapp module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipapp.py"
  notes:
    - "This spec extends zipapp.zspec.zsdl and zipapp_extra.zspec.zsdl."
    - "Focus: __name__, __module__, __qualname__ attributes for zipapp functions and classes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function_names — create_archive, get_interpreter
# ---------------------------------------------------------------------------

table zipapp_extra2.function_names:
  kind: python_call_eq
  category: names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [create_archive, create_archive.__name__.__eq__, ["create_archive"], true]
    - [get_interpreter, get_interpreter.__name__.__eq__, ["get_interpreter"], true]

# ---------------------------------------------------------------------------
# function_modules — create_archive, get_interpreter
# ---------------------------------------------------------------------------

invariant zipapp_extra2.create_archive.module:
  description: "zipapp.create_archive.__module__ == 'zipapp'"
  category: modules
  kind: python_call_eq
  function: create_archive.__module__.__eq__
  args: ["zipapp"]
  expected: true

invariant zipapp_extra2.get_interpreter.module:
  description: "zipapp.get_interpreter.__module__ == 'zipapp'"
  category: modules
  kind: python_call_eq
  function: get_interpreter.__module__.__eq__
  args: ["zipapp"]
  expected: true

# ---------------------------------------------------------------------------
# class identity — ZipAppError
# ---------------------------------------------------------------------------

invariant zipapp_extra2.ZipAppError.name:
  description: "zipapp.ZipAppError.__name__ == 'ZipAppError'"
  category: class_names
  kind: python_call_eq
  function: ZipAppError.__name__.__eq__
  args: ["ZipAppError"]
  expected: true

invariant zipapp_extra2.ZipAppError.module:
  description: "zipapp.ZipAppError.__module__ == 'zipapp'"
  category: class_names
  kind: python_call_eq
  function: ZipAppError.__module__.__eq__
  args: ["zipapp"]
  expected: true

invariant zipapp_extra2.ZipAppError.base:
  description: "zipapp.ZipAppError.__bases__[0].__name__ == 'ValueError'"
  category: class_names
  kind: python_call_eq
  function: ZipAppError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# qualnames — create_archive, get_interpreter
# ---------------------------------------------------------------------------

invariant zipapp_extra2.create_archive.qualname:
  description: "zipapp.create_archive.__qualname__ == 'create_archive'"
  category: qualnames
  kind: python_call_eq
  function: create_archive.__qualname__.__eq__
  args: ["create_archive"]
  expected: true

invariant zipapp_extra2.get_interpreter.qualname:
  description: "zipapp.get_interpreter.__qualname__ == 'get_interpreter'"
  category: qualnames
  kind: python_call_eq
  function: get_interpreter.__qualname__.__eq__
  args: ["get_interpreter"]
  expected: true
