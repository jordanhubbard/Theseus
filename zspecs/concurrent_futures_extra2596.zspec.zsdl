spec: concurrent_futures_extra2596
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 2596 theme: __get__, __set__, __delete__ descriptor protocol dict-presence — checking whether concurrent.futures classes implement the descriptor protocol."
    - "concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor, and BrokenExecutor do NOT define __get__, __set__, or __delete__ in their own __dict__ on Python 3.14.4."
    - "These classes are executor and future abstractions for async parallel work; none are descriptor classes. The absence of __get__/__set__/__delete__ confirms they are ordinary (non-descriptor) classes."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table concurrent_futures_extra2596.future_descriptor_protocol:
  description: "concurrent.futures.Future __get__/__set__/__delete__ dict-presence — all False; not a descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2596
  columns: [id, function, args, expected]
  rows:
    - ["cf2596001", "concurrent.futures.Future.__dict__.__contains__",                ["__get__"],    false]
    - ["cf2596002", "concurrent.futures.Future.__dict__.__contains__",                ["__set__"],    false]
    - ["cf2596003", "concurrent.futures.Future.__dict__.__contains__",                ["__delete__"], false]
    - ["cf2596004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",    ["__get__"],    false]
    - ["cf2596005", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",    ["__set__"],    false]
    - ["cf2596006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",    ["__delete__"], false]

