spec: csv_extra9
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra8."
    - "csv_extra7 covers reader.__name__, writer.__name__, DictReader.__name__, DictWriter.__name__."
    - "csv_extra6 covers Dialect.__bases__[0].__name__ == 'object' and excel.__module__."
    - "csv_extra5 covers __qualname__ for reader, writer, DictReader, DictWriter, and module-level functions."
    - "csv_extra8 covers Sniffer.__name__, Error.__name__, register_dialect.__name__, and __module__ for Sniffer/Error/Dialect."
    - "csv_extra2 covers csv.list_dialects() return value (list of strings containing 'excel')."
    - "This spec adds: DictReader.__bases__[0].__name__ == 'object', DictWriter.__bases__[0].__name__ == 'object'; reader/__class__.__name__ == 'type', writer/__class__.__name__ == 'type', DictReader/__class__.__name__ == 'type', DictWriter/__class__.__name__ == 'type'; list_dialects().__class__.__name__ == 'list'; unregister_dialect.__module__ == '_csv'."
    - "csv.DictReader.__bases__[0].__name__ == 'object' — DictReader inherits directly from object (no intermediate base)."
    - "csv.DictWriter.__bases__[0].__name__ == 'object' — DictWriter also inherits directly from object."
    - "csv.reader.__class__.__name__ == 'type' — reader is a C-extension type, so its metaclass is 'type'."
    - "csv.writer.__class__.__name__ == 'type' — writer is similarly a C-extension type."
    - "csv.DictReader.__class__.__name__ == 'type' — DictReader is a pure-Python class whose metaclass is 'type'."
    - "csv.DictWriter.__class__.__name__ == 'type' — DictWriter likewise has 'type' as its metaclass."
    - "csv.list_dialects().__class__.__name__ == 'list' — list_dialects() returns a plain Python list."
    - "csv.unregister_dialect.__module__ == '_csv' — unregister_dialect is a C-extension builtin defined in _csv."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DictReader and DictWriter base class hierarchy.
# csv_extra6 covers Dialect.__bases__[0].__name__ == 'object'.
# No prior csv spec checks DictReader or DictWriter __bases__[0].
# ---------------------------------------------------------------------------

table csv_extra9.dict_base_classes:
  kind: python_call_eq
  category: hierarchy
  id_prefix: dictbase

  columns: [id, function, args, expected]
  rows:
    - [DictReader, DictReader.__bases__.__getitem__, [0], "object"]
    - [DictWriter, DictWriter.__bases__.__getitem__, [0], "object"]

# ---------------------------------------------------------------------------
# Metaclass checks — reader, writer, DictReader, DictWriter.
# All four are class objects (type objects); their __class__.__name__ == 'type'.
# No prior csv spec checks __class__.__name__ for any of these four symbols.
# ---------------------------------------------------------------------------

table csv_extra9.class_metaclasses:
  kind: python_call_eq
  category: metaclasses
  id_prefix: meta9

  columns: [id, function, args, expected]
  rows:
    - [reader,     reader.__class__.__name__.__eq__,     ["type"], true]
    - [writer,     writer.__class__.__name__.__eq__,     ["type"], true]
    - [DictReader, DictReader.__class__.__name__.__eq__, ["type"], true]
    - [DictWriter, DictWriter.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# list_dialects() return type.
# csv_extra2 verifies that 'excel' is in the returned list and that the list
# has a positive length, but no prior spec checks the return type itself.
# ---------------------------------------------------------------------------

invariant csv_extra9.list_dialects.return_type:
  description: "csv.list_dialects().__class__.__name__ == 'list' — list_dialects returns a plain Python list"
  category: list_dialects
  kind: python_call_eq
  function: list_dialects
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# unregister_dialect.__module__ — defined in the _csv C extension.
# csv_extra5 covers unregister_dialect.__qualname__; no prior spec covers
# its __module__ attribute.
# ---------------------------------------------------------------------------

invariant csv_extra9.unregister_dialect.module:
  description: "csv.unregister_dialect.__module__ == '_csv' — implemented in the _csv C extension"
  category: modules
  kind: python_call_eq
  function: unregister_dialect.__module__.__eq__
  args: ["_csv"]
  expected: true
