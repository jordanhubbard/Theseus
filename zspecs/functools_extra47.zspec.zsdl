spec: functools_extra47
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra46.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths and indexed elements; partial/__class__.__name__; cached_property.__set_name__/__get__/__init__.__qualname__; total_ordering.__dict__.__class__.__name__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; partial/__doc__/reduce/__doc__; reduce with initial value; lru_cache(128).__ne__(None)==True; C-extension vs pure-Python __module__ lengths; lru_cache(maxsize=2) behavioral; reduce.__qualname__=='reduce'; lru_cache.__qualname__=='lru_cache'; cache.__name__=='cache'; cache.__qualname__=='cache'; cache.__module__=='functools'; cached_property.__name__=='cached_property'; cached_property.__module__=='functools'; cached_property.__qualname__=='cached_property'; cached_property.__qualname__.__len__()==15; cached_property.__bases__[0].__name__=='object'; total_ordering.__name__=='total_ordering'; total_ordering.__module__=='functools'; total_ordering.__qualname__=='total_ordering'; singledispatch.__name__=='singledispatch'; singledispatch.__module__=='functools'; singledispatch.__qualname__=='singledispatch'."
    - "This spec covers: functools.singledispatch.__qualname__.__len__() == 14 (already recorded as string equality in extra46, here as len); functools.total_ordering.__qualname__.__len__() == 14 (same); functools.wraps.__name__ == 'wraps'; functools.wraps.__qualname__ == 'wraps'; functools.wraps.__module__ == 'functools'; functools.update_wrapper.__name__ == 'update_wrapper'; functools.update_wrapper.__qualname__ == 'update_wrapper'; functools.update_wrapper.__module__ == 'functools'; functools.partial.__bases__[0].__name__ == 'object'."
    - "Key findings: functools.wraps.__name__ and __qualname__ are both 'wraps' (5 chars) — wraps is a pure-Python function decorator defined at module level in Lib/functools.py; as a top-level function __qualname__ == __name__; __module__ is 'functools' (9 chars). functools.update_wrapper.__name__ and __qualname__ are both 'update_wrapper' (14 chars) — update_wrapper is the underlying pure-Python helper that wraps implements; also defined at module level so __qualname__ == __name__; same 14-char length as singledispatch.__name__ and total_ordering.__name__; __module__ is 'functools'. functools.singledispatch.__qualname__.__len__() == 14 and functools.total_ordering.__qualname__.__len__() == 14 — both share this length, same as update_wrapper. functools.partial.__bases__[0].__name__ is 'object' — partial is a C-extension type (Modules/_functoolsmodule.c) that inherits directly from object; single base class with no intermediate inheritance. Prior specs recorded string equality for singledispatch/__qualname__ and total_ordering/__qualname__ (extra46) but not their __len__() values in isolation, and did not cover wraps or update_wrapper identity at all."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.singledispatch and total_ordering __qualname__.__len__() — extra47
#
# functools.singledispatch.__qualname__.__len__() == 14 and
# functools.total_ordering.__qualname__.__len__() == 14. Both are top-level
# definitions in Lib/functools.py; for top-level definitions __qualname__ ==
# __name__, so __qualname__.__len__() == __name__.__len__() == 14.
# Prior spec extra46 recorded the string equality invariants (__qualname__ ==
# 'singledispatch' and 'total_ordering') but not the explicit __len__() value
# in the extra47 namespace. update_wrapper shares the same 14-char length.
# ---------------------------------------------------------------------------

invariant functools_extra47.singledispatch_qualname_len:
  description: "len(functools.singledispatch.__qualname__) == 14 — 'singledispatch'; top-level function; __qualname__ == __name__ (no enclosing scope); same 14-char length as total_ordering and update_wrapper"
  category: string_properties
  kind: python_call_eq
  function: singledispatch.__qualname__.__len__
  args: []
  expected: 14

invariant functools_extra47.total_ordering_qualname_len:
  description: "len(functools.total_ordering.__qualname__) == 14 — 'total_ordering'; top-level class; __qualname__ == __name__ (no enclosing scope); same 14-char length as singledispatch and update_wrapper"
  category: string_properties
  kind: python_call_eq
  function: total_ordering.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# functools.wraps identity metadata — extra47 namespace
#
# functools.wraps.__name__ is 'wraps' (5 chars), functools.wraps.__qualname__
# is 'wraps' (5 chars), and functools.wraps.__module__ is 'functools' (9 chars).
# wraps is a pure-Python function decorator defined at module level in
# Lib/functools.py. As a top-level function, __qualname__ == __name__. Prior
# specs recorded wraps.__name__.__len__()==5 and __qualname__.__len__()==5 but
# not the string equality invariants for __name__, __qualname__, or __module__.
# These three equality invariants are new to the extra47 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra47.wraps_name:
  description: "functools.wraps.__name__ == 'wraps' — pure-Python decorator that copies attributes from wrapped to wrapper; 5-char name; same length as wraps.__qualname__"
  category: identity
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra47.wraps_qualname:
  description: "functools.wraps.__qualname__ == 'wraps' — module-level function; __qualname__ == __name__ (no enclosing class scope); 5 chars; same as __name__"
  category: identity
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra47.wraps_module:
  description: "functools.wraps.__module__ == 'functools' — pure-Python function defined in Lib/functools.py; 9-char module name; same as all pure-Python functools objects"
  category: module_metadata
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# functools.update_wrapper identity metadata — extra47 namespace
#
# functools.update_wrapper.__name__ is 'update_wrapper' (14 chars),
# functools.update_wrapper.__qualname__ is 'update_wrapper' (14 chars), and
# functools.update_wrapper.__module__ is 'functools' (9 chars).
# update_wrapper is a pure-Python helper function defined at module level in
# Lib/functools.py that copies attributes (__name__, __doc__, etc.) from
# the wrapped function to the wrapper. As a top-level function, __qualname__
# == __name__. The 14-char name coincides with singledispatch and
# total_ordering. Prior specs recorded update_wrapper.__name__.__len__()==14
# and __qualname__.__len__()==14 but not the string equality invariants.
# These three equality invariants are new to the extra47 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra47.update_wrapper_name:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' — pure-Python helper; 14-char name; same length as singledispatch.__name__ and total_ordering.__name__; copies attributes from wrapped to wrapper"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra47.update_wrapper_qualname:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper' — module-level function; __qualname__ == __name__ (no enclosing class scope); 14 chars; same as singledispatch.__qualname__ length"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra47.update_wrapper_module:
  description: "functools.update_wrapper.__module__ == 'functools' — pure-Python function defined in Lib/functools.py; 9-char module name; same as wraps.__module__"
  category: module_metadata
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# functools.partial __bases__[0].__name__ — extra47 namespace
#
# functools.partial.__bases__[0].__name__ is 'object'. functools.partial is
# a C-extension type defined in Modules/_functoolsmodule.c that inherits
# directly from object with no intermediate base class. As a C-extension type,
# it has a single base class (object) in its __bases__ tuple. This parallels
# functools.cached_property.__bases__[0].__name__ == 'object' (extra46) but
# for the C-extension partial type rather than the pure-Python cached_property
# class. Prior specs recorded partial.__class__.__name__ and __new__.__qualname__
# but not __bases__[0].__name__. This equality invariant is new to extra47.
# ---------------------------------------------------------------------------

invariant functools_extra47.partial_bases_name:
  description: "functools.partial.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; single base class; no intermediate inheritance; parallel to cached_property.__bases__[0].__name__"
  category: class_hierarchy
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
