  function: CalledProcessError.__module__.__len__
  args: []
  expected: 10

invariant subprocess_extra21.TimeoutExpired.module_len:
  description: "subprocess.TimeoutExpired.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: type_attrs
