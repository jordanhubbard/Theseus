# ---------------------------------------------------------------------------
# Standalone invariants — run string lengths
# ---------------------------------------------------------------------------

invariant subprocess_extra21.run.module_len:
  description: "subprocess.run.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: function_attrs
  kind: python_call_eq
  function: run.__module__.__len__
  args: []
  expected: 10

invariant subprocess_extra21.run.name_len:
  description: "subprocess.run.__name__.__len__() == 3 — 'run' has 3 characters"
  category: function_attrs
