invariant subprocess_extra21.CalledProcessError.name_len:
  description: "subprocess.CalledProcessError.__name__.__len__() == 18 — 'CalledProcessError' has 18 characters"
  category: type_attrs
  kind: python_call_eq
  function: CalledProcessError.__name__.__len__
  args: []
