spec: subprocess_extra21
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra20.zspec.zsdl — covers run/__module__.__len__()==10 and Popen/__module__.__len__()==10 in a table; NOT __module__.__len__() for CompletedProcess/CalledProcessError/TimeoutExpired/SubprocessError, NOT __name__.__len__() for any class or function."
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra20.zspec.zsdl."
    - "Prior specs covered: Popen/CompletedProcess/CalledProcessError/TimeoutExpired/__name__/__module__/__qualname__, run/call/check_call/check_output/__name__/__module__/__qualname__, PIPE/STDOUT/DEVNULL values, Popen/__bases__[0].__name__, exception bases, SubprocessError/__name__/__bases__[0].__name__, Popen.__init__.__name__, run/__module__.__len__()==10, Popen/__module__.__len__()==10."
    - "This spec covers: __module__.__len__() for Popen/CompletedProcess/CalledProcessError/TimeoutExpired/run/SubprocessError (all 10, 'subprocess'); __name__.__len__() for Popen/CompletedProcess/CalledProcessError/TimeoutExpired/run/SubprocessError."
    - "All __module__ strings are 'subprocess' (len 10). __name__ lengths: Popen=5, CompletedProcess=16, CalledProcessError=18, TimeoutExpired=14, run=3, SubprocessError=15."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# subprocess class __module__ string lengths
#
# subprocess_extra20 covers run.__module__.__len__() and Popen.__module__.__len__()
# in a table. No prior subprocess spec checks __len__() for CompletedProcess,
# CalledProcessError, TimeoutExpired, or SubprocessError __module__ strings.
# All are defined in subprocess.py so their __module__ == 'subprocess' (len 10).
# ---------------------------------------------------------------------------

table subprocess_extra21.class_module_lengths:
  description: "__module__.__len__() == 10 for subprocess classes (all 'subprocess')"
  kind: python_call_eq
  category: type_attrs
  id_prefix: clsmodlen21

  columns: [id, function, args, expected]
  rows:
    - [Popen,               Popen.__module__.__len__,               [], 10]
    - [CompletedProcess,    CompletedProcess.__module__.__len__,    [], 10]
    - [CalledProcessError,  CalledProcessError.__module__.__len__,  [], 10]
    - [TimeoutExpired,      TimeoutExpired.__module__.__len__,      [], 10]
    - [SubprocessError,     SubprocessError.__module__.__len__,     [], 10]

# ---------------------------------------------------------------------------
# subprocess class __name__ string lengths
#
# No prior subprocess spec checks __len__() on class __name__ strings.
# Lengths: Popen=5, CompletedProcess=16, CalledProcessError=18,
# TimeoutExpired=14, SubprocessError=15.
# ---------------------------------------------------------------------------

table subprocess_extra21.class_name_lengths:
  description: "__name__.__len__() for subprocess classes"
  kind: python_call_eq
  category: type_attrs
  id_prefix: clsnlen21

  columns: [id, function, args, expected]
  rows:
    - [Popen,              Popen.__name__.__len__,              [], 5]
    - [CompletedProcess,   CompletedProcess.__name__.__len__,   [], 16]
    - [CalledProcessError, CalledProcessError.__name__.__len__, [], 18]
    - [TimeoutExpired,     TimeoutExpired.__name__.__len__,     [], 14]
    - [SubprocessError,    SubprocessError.__name__.__len__,    [], 15]

# ---------------------------------------------------------------------------
# subprocess.run __module__ and __name__ string lengths
#
# subprocess_extra20 covers run.__module__.__len__() as a standalone invariant.
# No prior subprocess spec checks run.__name__.__len__(). run.__name__ == 'run'
# (len 3).
# ---------------------------------------------------------------------------

table subprocess_extra21.run_string_lengths:
  description: "__module__.__len__() and __name__.__len__() for subprocess.run"
  kind: python_call_eq
  category: function_attrs
  id_prefix: runlen21

  columns: [id, function, args, expected]
  rows:
    - [run_module_len, run.__module__.__len__, [], 10]
    - [run_name_len,   run.__name__.__len__,   [], 3]

# ---------------------------------------------------------------------------
# Standalone invariants — class __module__ string lengths
# ---------------------------------------------------------------------------

invariant subprocess_extra21.Popen.module_len:
  description: "subprocess.Popen.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: type_attrs
  kind: python_call_eq
  function: Popen.__module__.__len__
  args: []
  expected: 10

invariant subprocess_extra21.CompletedProcess.module_len:
  description: "subprocess.CompletedProcess.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: type_attrs
  kind: python_call_eq
  function: CompletedProcess.__module__.__len__
  args: []
  expected: 10

invariant subprocess_extra21.CalledProcessError.module_len:
  description: "subprocess.CalledProcessError.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: type_attrs
