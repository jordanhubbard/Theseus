  function: TimeoutExpired.__module__.__len__
  args: []
  expected: 10

invariant subprocess_extra21.SubprocessError.module_len:
  description: "subprocess.SubprocessError.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: type_attrs
  kind: python_call_eq
  function: SubprocessError.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone invariants — class __name__ string lengths
# ---------------------------------------------------------------------------

invariant subprocess_extra21.Popen.name_len:
  description: "subprocess.Popen.__name__.__len__() == 5 — 'Popen' has 5 characters"
  category: type_attrs
  kind: python_call_eq
  function: Popen.__name__.__len__
  args: []
  expected: 5

invariant subprocess_extra21.CompletedProcess.name_len:
  description: "subprocess.CompletedProcess.__name__.__len__() == 16 — 'CompletedProcess' has 16 characters"
  category: type_attrs
