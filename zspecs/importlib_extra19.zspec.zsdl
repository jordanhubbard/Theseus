spec: importlib_extra19
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "importlib_extra18.zspec.zsdl — covers import_module/__name__.__len__()==13, reload/__name__.__len__()==6, import_module/__module__.__len__()==9, reload/__module__.__len__()==9, submodule __name__ lengths; NOT __name__.__class__.__name__ for submodules, NOT __name__.__len__() or __package__.__len__() for the importlib module itself."
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra18.zspec.zsdl."
    - "Prior specs covered: importlib.__name__/__package__, import_module/reload __name__/__module__/__qualname__, util/resources/abc/machinery __name__ and lengths, import_module/reload __module__.__len__()==9, import_module/reload name lengths."
    - "This spec covers: importlib.import_module.__name__.__len__(), importlib.reload.__name__.__len__(), importlib.import_module.__module__.__len__(), importlib.reload.__module__.__len__(), importlib.__name__.__len__(), importlib.__package__.__len__(), importlib.util.__name__.__class__.__name__, importlib.resources.__name__.__class__.__name__, importlib.abc.__name__.__class__.__name__, importlib.machinery.__name__.__class__.__name__."
    - "importlib.__name__ == 'importlib' (len 9); importlib.__package__ == 'importlib' (len 9). Both are strings so their __class__.__name__ == 'str'."
    - "importlib.util.__name__.__class__.__name__ == 'str'; same for resources, abc, machinery — all submodule __name__ attributes are str instances."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib top-level function __name__ and __module__ string lengths
#
# importlib_extra18 covers these lengths but they are repeated here as part
# of a combined companion table covering both __name__ and __module__ lengths
# together with module-level string lengths for completeness.
# importlib.import_module.__name__ == 'import_module' (len 13)
# importlib.reload.__name__ == 'reload' (len 6)
# importlib.import_module.__module__ == 'importlib' (len 9)
# importlib.reload.__module__ == 'importlib' (len 9)
# ---------------------------------------------------------------------------

table importlib_extra19.toplevel_function_name_lengths:
  description: "__name__.__len__() for importlib top-level functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnnlen19

  columns: [id, function, args, expected]
  rows:
    - [import_module, import_module.__name__.__len__, [], 13]
    - [reload,        reload.__name__.__len__,        [], 6]

table importlib_extra19.toplevel_function_module_lengths:
  description: "__module__.__len__() for importlib top-level functions (both 9, for 'importlib')"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnmodlen19

  columns: [id, function, args, expected]
  rows:
    - [import_module, import_module.__module__.__len__, [], 9]
    - [reload,        reload.__module__.__len__,        [], 9]

# ---------------------------------------------------------------------------
# importlib module-level __name__ and __package__ string lengths
#
# importlib.__name__ == 'importlib' (len 9).
# importlib.__package__ == 'importlib' (len 9).
# Prior specs confirm these values but no prior importlib spec checks __len__().
# ---------------------------------------------------------------------------

table importlib_extra19.module_identity_lengths:
  description: "__name__ and __package__ string lengths for the importlib module (both 9)"
  kind: python_call_eq
  category: module_attrs
  id_prefix: modidlen19

  columns: [id, function, args, expected]
  rows:
    - [name_len,    __name__.__len__,    [], 9]
    - [package_len, __package__.__len__, [], 9]

# ---------------------------------------------------------------------------
# importlib submodule __name__ type — __class__.__name__
#
# Prior specs confirm __name__ values for util/resources/abc/machinery.
# No prior importlib spec checks that these __name__ strings are instances
# of str (i.e., __name__.__class__.__name__ == 'str').
# ---------------------------------------------------------------------------

table importlib_extra19.submodule_name_class_names:
  description: "__name__.__class__.__name__ == 'str' for importlib submodules"
  kind: python_call_eq
  category: submodule_attrs
  id_prefix: subnclsn19

  columns: [id, function, args, expected]
  rows:
    - [util,      util.__name__.__class__.__name__.__eq__,      ["str"], true]
    - [resources, resources.__name__.__class__.__name__.__eq__, ["str"], true]
    - [abc,       abc.__name__.__class__.__name__.__eq__,       ["str"], true]
    - [machinery, machinery.__name__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — module-level string lengths
# ---------------------------------------------------------------------------

invariant importlib_extra19.module.name_len:
  description: "importlib.__name__.__len__() == 9 — 'importlib' has 9 characters"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant importlib_extra19.module.package_len:
  description: "importlib.__package__.__len__() == 9 — 'importlib' has 9 characters"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Standalone invariants — top-level function string lengths
# ---------------------------------------------------------------------------

invariant importlib_extra19.import_module.name_len:
  description: "importlib.import_module.__name__.__len__() == 13 — 'import_module' has 13 characters"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__name__.__len__
  args: []
  expected: 13

invariant importlib_extra19.reload.name_len:
  description: "importlib.reload.__name__.__len__() == 6 — 'reload' has 6 characters"
  category: function_attrs
  kind: python_call_eq
  function: reload.__name__.__len__
  args: []
  expected: 6

invariant importlib_extra19.import_module.module_len:
  description: "importlib.import_module.__module__.__len__() == 9 — 'importlib' has 9 characters"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__module__.__len__
  args: []
  expected: 9

invariant importlib_extra19.reload.module_len:
  description: "importlib.reload.__module__.__len__() == 9 — 'importlib' has 9 characters"
  category: function_attrs
  kind: python_call_eq
  function: reload.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Standalone invariants — submodule __name__ class names
# ---------------------------------------------------------------------------

invariant importlib_extra19.util.name_class:
  description: "importlib.util.__name__.__class__.__name__ == 'str' — submodule __name__ is a str"
  category: submodule_attrs
  kind: python_call_eq
  function: util.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant importlib_extra19.resources.name_class:
  description: "importlib.resources.__name__.__class__.__name__ == 'str' — submodule __name__ is a str"
  category: submodule_attrs
  kind: python_call_eq
  function: resources.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant importlib_extra19.abc.name_class:
  description: "importlib.abc.__name__.__class__.__name__ == 'str' — submodule __name__ is a str"
  category: submodule_attrs
  kind: python_call_eq
  function: abc.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant importlib_extra19.machinery.name_class:
  description: "importlib.machinery.__name__.__class__.__name__ == 'str' — submodule __name__ is a str"
  category: submodule_attrs
  kind: python_call_eq
  function: machinery.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
