spec: inspect_extra2401
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/inspect.html"
    - "CPython source — Lib/inspect.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 607 (_extra2401): __hash__ and __eq__ implementation type classification."
    - "inspect.Parameter defines custom __hash__ and __eq__ (both 'function') — it is hashable."
    - "inspect.Signature defines custom __hash__ and __eq__ (both 'function') — it is hashable."
    - "inspect.BoundArguments defines __eq__ (function) but sets __hash__ = None — it is unhashable."
    - "BoundArguments.__hash__.__class__.__name__ == 'NoneType' because __hash__ is None."
    - "inspect.FullArgSpec and inspect.ArgInfo are namedtuples; they inherit wrapper_descriptor hash/eq from object/tuple."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __hash__ implementation type for inspect classes (class level)
# ===

table inspect_extra2401.hash_class_types:
  description: "__hash__ implementation type (class-level) for key inspect types"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2401
  columns: [id, function, args, expected]
  rows:
    - ["in2401001", "inspect.Parameter.__hash__.__class__.__name__", [], "function"]
    - ["in2401002", "inspect.Signature.__hash__.__class__.__name__", [], "function"]
    - ["in2401003", "inspect.BoundArguments.__hash__.__class__.__name__", [], "NoneType"]
    - ["in2401004", "inspect.FullArgSpec.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["in2401005", "inspect.ArgInfo.__hash__.__class__.__name__", [], "wrapper_descriptor"]

# ===
# Table 2: __eq__ implementation type for inspect classes (class level)
# ===

table inspect_extra2401.eq_class_types:
  description: "__eq__ implementation type (class-level) for key inspect types"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2401
  columns: [id, function, args, expected]
  rows:
    - ["in2401006", "inspect.Parameter.__eq__.__class__.__name__", [], "function"]
    - ["in2401007", "inspect.Signature.__eq__.__class__.__name__", [], "function"]
    - ["in2401008", "inspect.BoundArguments.__eq__.__class__.__name__", [], "function"]
    - ["in2401009", "inspect.FullArgSpec.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["in2401010", "inspect.ArgInfo.__eq__.__class__.__name__", [], "wrapper_descriptor"]

# ===
# Table 3: __hash__ and __eq__ presence in class __dict__
# ===

table inspect_extra2401.dict_membership:
  description: "__hash__ and __eq__ presence in __dict__ for inspect types"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2401
  columns: [id, function, args, expected]
  rows:
    - ["in2401011", "inspect.Parameter.__dict__.__contains__", ["__hash__"], true]
    - ["in2401012", "inspect.Parameter.__dict__.__contains__", ["__eq__"], true]
    - ["in2401013", "inspect.Signature.__dict__.__contains__", ["__hash__"], true]
    - ["in2401014", "inspect.Signature.__dict__.__contains__", ["__eq__"], true]
    - ["in2401015", "inspect.BoundArguments.__dict__.__contains__", ["__hash__"], true]
    - ["in2401016", "inspect.BoundArguments.__dict__.__contains__", ["__eq__"], true]
    - ["in2401017", "inspect.FullArgSpec.__dict__.__contains__", ["__hash__"], false]
    - ["in2401018", "inspect.FullArgSpec.__dict__.__contains__", ["__eq__"], false]
    - ["in2401019", "inspect.ArgInfo.__dict__.__contains__", ["__hash__"], false]
    - ["in2401020", "inspect.ArgInfo.__dict__.__contains__", ["__eq__"], false]

# ===
# Table 4: BoundArguments __hash__ is None (unhashable sentinel)
# ===

table inspect_extra2401.bound_arguments_unhashable:
  description: "inspect.BoundArguments sets __hash__ = None making it unhashable"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2401
  columns: [id, function, args, expected]
  rows:
    - ["in2401021", "inspect.BoundArguments.__dict__.__getitem__", ["__hash__"], null]
