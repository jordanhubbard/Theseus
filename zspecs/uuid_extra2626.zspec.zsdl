spec: uuid_extra2626
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid.zspec.zsdl — covers uuid1/uuid4/uuid5 function identity and basic UUID properties"
    - "uuid_extra269.zspec.zsdl — covers UUID string representations (str/repr/urn/hex) for nil and max UUID"
  notes:
    - "Wave 622 (uuid_extra2626) theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "Neither uuid.UUID nor uuid.SafeUUID define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is a protocol method for sized iterators; UUID objects are not iterators."
    - "__missing__ is a dict subclass hook; UUID and SafeUUID are not dict subclasses."
    - "__reversed__ is an iterator protocol method; UUID and SafeUUID do not support reverse iteration."
    - "uuid.UUID DOES define hex/int/urn/version/__str__/__repr__/__init__ in its __dict__."
    - "uuid.SafeUUID DOES define __new__/_generate_next_value_/_member_names_/_value2member_map_/__doc__ in its __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — uuid.UUID and uuid.SafeUUID
# ---------------------------------------------------------------------------

table uuid_extra2626.no_length_hint_in_uuid_classes:
  description: "__length_hint__ is absent from uuid.UUID and uuid.SafeUUID __dict__s — UUID objects are not sized iterators and do not implement the length-hint protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2626

  columns: [id, function, args, expected]
  rows:
    - ["uu2626001", "uuid.UUID.__dict__.__contains__",     ["__length_hint__"], false]
    - ["uu2626002", "uuid.SafeUUID.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — uuid.UUID and uuid.SafeUUID
# ---------------------------------------------------------------------------

table uuid_extra2626.no_missing_in_uuid_classes:
  description: "__missing__ is absent from uuid.UUID and uuid.SafeUUID __dict__s — UUID and SafeUUID are not dict subclasses and do not implement missing-key lookup"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2626

  columns: [id, function, args, expected]
  rows:
    - ["uu2626003", "uuid.UUID.__dict__.__contains__",     ["__missing__"], false]
    - ["uu2626004", "uuid.SafeUUID.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — uuid.UUID and uuid.SafeUUID
# ---------------------------------------------------------------------------

table uuid_extra2626.no_reversed_in_uuid_classes:
  description: "__reversed__ is absent from uuid.UUID and uuid.SafeUUID __dict__s — UUID and SafeUUID do not support reverse iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2626

  columns: [id, function, args, expected]
  rows:
    - ["uu2626005", "uuid.UUID.__dict__.__contains__",     ["__reversed__"], false]
    - ["uu2626006", "uuid.SafeUUID.__dict__.__contains__", ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Complementary: uuid.UUID defines its core attributes; uuid.SafeUUID defines
# its enum infrastructure — confirming the classes are well-populated even
# though none of the three protocol methods appear.
# ---------------------------------------------------------------------------

table uuid_extra2626.uuid_classes_have_core_attrs:
  description: "uuid.UUID defines hex/int/urn/__str__/__repr__/__init__ in __dict__; uuid.SafeUUID defines __new__/_generate_next_value_/_member_names_ — but neither class defines __length_hint__/__missing__/__reversed__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2626

  columns: [id, function, args, expected]
  rows:
    - ["uu2626007", "uuid.UUID.__dict__.__contains__",     ["hex"],                 true]
    - ["uu2626008", "uuid.UUID.__dict__.__contains__",     ["int"],                 true]
    - ["uu2626009", "uuid.UUID.__dict__.__contains__",     ["urn"],                 true]
    - ["uu2626010", "uuid.UUID.__dict__.__contains__",     ["__str__"],             true]
    - ["uu2626011", "uuid.UUID.__dict__.__contains__",     ["__repr__"],            true]
    - ["uu2626012", "uuid.UUID.__dict__.__contains__",     ["__init__"],            true]
    - ["uu2626013", "uuid.UUID.__dict__.__contains__",     ["__length_hint__"],     false]
    - ["uu2626014", "uuid.UUID.__dict__.__contains__",     ["__missing__"],         false]
    - ["uu2626015", "uuid.UUID.__dict__.__contains__",     ["__reversed__"],        false]
    - ["uu2626016", "uuid.SafeUUID.__dict__.__contains__", ["__new__"],             true]
    - ["uu2626017", "uuid.SafeUUID.__dict__.__contains__", ["_generate_next_value_"], true]
    - ["uu2626018", "uuid.SafeUUID.__dict__.__contains__", ["_member_names_"],      true]
    - ["uu2626019", "uuid.SafeUUID.__dict__.__contains__", ["__length_hint__"],     false]
    - ["uu2626020", "uuid.SafeUUID.__dict__.__contains__", ["__missing__"],         false]
    - ["uu2626021", "uuid.SafeUUID.__dict__.__contains__", ["__reversed__"],        false]
