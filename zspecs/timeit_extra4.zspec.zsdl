spec: timeit_extra4
version: ">=3.9"
backend: python_module(timeit)

docs: https://docs.python.org/3/library/timeit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/timeit.html — Python timeit module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/timeit.py"
  notes:
    - "This spec extends timeit.zspec.zsdl, timeit_extra.zspec.zsdl, timeit_extra2.zspec.zsdl, and timeit_extra3.zspec.zsdl."
    - "timeit.zspec.zsdl covers: timeit/__name__, repeat/__name__, default_timer type, Timer/__name__, Timer/__module__, Timer method names, timeit() returns float."
    - "timeit_extra.zspec.zsdl covers: Timer/__qualname__, Timer/__doc__, Timer method __qualname__ and type, default_timer/__name__, module __name__, repeat() returns list, repeat() length."
    - "timeit_extra2.zspec.zsdl covers: Timer/__bases__[0].__name__, timeit/__module__, repeat/__module__, timeit/__qualname__, repeat/__qualname__, function __name__ batch table."
    - "timeit_extra3.zspec.zsdl covers: Timer/__bases__.__len__, default_timer/__qualname__, default_timer/__module__, Timer method __module__ checks (timeit/repeat/autorange/print_exc)."
    - "NEW in this spec: timeit.Timer/__name__/__module__ via __eq__ predicate; timeit.timeit/__name__/__qualname__/__module__ and timeit.repeat/__name__/__qualname__/__module__ via __eq__ predicate; timeit.default_timer/__name__=='perf_counter' via __eq__ predicate; timeit.Timer.__bases__[0].__name__=='object' via __eq__ predicate; timeit.Timer.__class__.__name__=='type'; timeit module-level function __class__.__name__ checks."
    - "timeit.Timer.__name__ == 'Timer' — verified runtime."
    - "timeit.Timer.__module__ == 'timeit' — verified runtime."
    - "timeit.timeit.__name__ == 'timeit' — verified runtime."
    - "timeit.repeat.__name__ == 'repeat' — verified runtime."
    - "timeit.default_timer.__name__ == 'perf_counter' — verified runtime (default_timer is time.perf_counter)."
    - "timeit.Timer.__bases__[0].__name__ == 'object' — Timer has one base class, object (verified runtime)."
    - "timeit.Timer.__class__.__name__ == 'type' — Timer is a class whose metaclass is type (verified runtime)."
    - "timeit.timeit.__class__.__name__ == 'function' — timeit is a plain Python function (verified runtime)."
    - "timeit.repeat.__class__.__name__ == 'function' — repeat is a plain Python function (verified runtime)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# timeit.Timer identity — __eq__ predicate form
# timeit.zspec.zsdl checks Timer/__name__ and /__module__ as direct string values.
# The __eq__ predicate form (expected: true) is structurally new.
# ---------------------------------------------------------------------------

invariant timeit_extra4.Timer.name_eq:
  description: "timeit.Timer.__name__.__eq__('Timer') == True"
  category: classes
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant timeit_extra4.Timer.module_eq:
  description: "timeit.Timer.__module__.__eq__('timeit') == True"
  category: classes
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["timeit"]
  expected: true

# ---------------------------------------------------------------------------
# timeit.Timer.__class__.__name__ — metaclass verification
# No prior timeit spec checks Timer.__class__.__name__.
# ---------------------------------------------------------------------------

invariant timeit_extra4.Timer.class_name:
  description: "timeit.Timer.__class__.__name__ == 'type' — Timer is a class whose metaclass is type"
  category: classes
  kind: python_call_eq
  function: Timer.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# timeit.Timer base class — __eq__ predicate form
# timeit_extra2 checks Timer.__bases__[0].__name__ as a direct string value.
# timeit_extra3 checks Timer.__bases__.__len__ == 1.
# The __eq__ predicate form for __bases__[0].__name__ is new here.
# ---------------------------------------------------------------------------

invariant timeit_extra4.Timer.base0_name_eq:
  description: "timeit.Timer.__bases__[0].__name__.__eq__('object') == True — Timer inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Timer.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# timeit.default_timer — __name__ via __eq__ predicate
# timeit_extra checks default_timer/__name__ as a direct string value.
# timeit_extra3 checks default_timer/__qualname__ and /__module__.
# The __eq__ predicate form for __name__ is new here.
# ---------------------------------------------------------------------------

invariant timeit_extra4.default_timer.name_eq:
  description: "timeit.default_timer.__name__.__eq__('perf_counter') == True — default_timer is time.perf_counter"
  category: functions
  kind: python_call_eq
  function: default_timer.__name__.__eq__
  args: ["perf_counter"]
  expected: true

# ---------------------------------------------------------------------------
# timeit and repeat module-level function identity — __eq__ predicate form
# timeit_extra2 covers timeit/__module__, repeat/__module__, timeit/__qualname__,
# repeat/__qualname__ as direct string values.
# These use the __eq__ predicate form (expected: true) — structurally new.
# ---------------------------------------------------------------------------

table timeit_extra4.function_name_eqs:
  description: "timeit module-level function __name__ identity via __eq__ predicate"
  kind: python_call_eq
  category: function_names
  id_prefix: fneq

  columns: [id, function, args, expected]
  rows:
    - [timeit_name,  timeit.__name__.__eq__,     ["timeit"],  true]
    - [repeat_name,  repeat.__name__.__eq__,     ["repeat"],  true]
    - [timeit_qname, timeit.__qualname__.__eq__,  ["timeit"],  true]
    - [repeat_qname, repeat.__qualname__.__eq__,  ["repeat"],  true]
    - [timeit_mod,   timeit.__module__.__eq__,   ["timeit"],  true]
    - [repeat_mod,   repeat.__module__.__eq__,   ["timeit"],  true]

# ---------------------------------------------------------------------------
# timeit and repeat __class__.__name__ — type verification
# No prior timeit spec checks the __class__.__name__ of timeit or repeat.
# timeit.zspec.zsdl checks default_timer type (it is a builtin, not function).
# timeit and repeat are plain Python functions.
# ---------------------------------------------------------------------------

invariant timeit_extra4.timeit_fn.class_name:
  description: "timeit.timeit.__class__.__name__ == 'function' — timeit module-level timeit is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: timeit.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant timeit_extra4.repeat_fn.class_name:
  description: "timeit.repeat.__class__.__name__ == 'function' — repeat is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: repeat.__class__.__name__.__eq__
  args: ["function"]
  expected: true
