  category: class_metadata
  kind: python_call_eq
  function: Path.write_text.__qualname__.__eq__
  args: ["Path.write_text"]
  expected: true

invariant pathlib.Path.write_bytes.qualname:
  description: "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes'"
