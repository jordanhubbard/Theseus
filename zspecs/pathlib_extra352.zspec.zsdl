spec: pathlib_extra352
version: ">=3.6"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path class method identity — __qualname__ attributes
# ---------------------------------------------------------------------------

invariant pathlib.Path.cwd.qualname:
  description: "pathlib.Path.cwd.__qualname__ == 'Path.cwd'"
  category: class_metadata
  kind: python_call_eq
  function: Path.cwd.__qualname__.__eq__
  args: ["Path.cwd"]
  expected: true

invariant pathlib.Path.home.qualname:
  description: "pathlib.Path.home.__qualname__ == 'Path.home'"
  category: class_metadata
  kind: python_call_eq
  function: Path.home.__qualname__.__eq__
  args: ["Path.home"]
  expected: true

invariant pathlib.Path.stat.qualname:
  description: "pathlib.Path.stat.__qualname__ == 'Path.stat'"
  category: class_metadata
  kind: python_call_eq
  function: Path.stat.__qualname__.__eq__
  args: ["Path.stat"]
  expected: true

invariant pathlib.Path.open.qualname:
  description: "pathlib.Path.open.__qualname__ == 'Path.open'"
  category: class_metadata
  kind: python_call_eq
  function: Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

