spec: theseus_codeop_cr
version: ">=3.0"
backend: python_cleanroom(theseus_codeop_cr)
blocks: codeop

docs: https://docs.python.org/3/library/codeop.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/codeop.html"
  not_derived_from:
    - "CPython source: Lib/codeop.py"
  notes:
    - "Clean-room codeop module. Do NOT import codeop."

error_model: python_exceptions

invariant theseus_codeop_cr.codeop2_compile_complete:
  description: "compile_command('x=1') returns a code object"
  category: behavior
  kind: python_call_eq
  function: codeop2_compile_complete
  args: []
  expected: true

invariant theseus_codeop_cr.codeop2_compile_incomplete:
  description: "compile_command('def f():') returns None (incomplete)"
  category: behavior
  kind: python_call_eq
  function: codeop2_compile_incomplete
  args: []
  expected: true

invariant theseus_codeop_cr.codeop2_commandcompiler:
  description: "CommandCompiler() is callable"
  category: behavior
  kind: python_call_eq
  function: codeop2_commandcompiler
  args: []
  expected: true
