spec: multiprocessing_extra110
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra109.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing module __name__/__package__/__spec__ attributes, and multiprocessing.cpu_count/current_process/active_children function class names and qualnames. NEW in extra110: multiprocessing.__name__=='multiprocessing' (len=15); multiprocessing.__package__=='multiprocessing' (len=15, same as __name__); type(multiprocessing.__name__).__name__=='str'; multiprocessing.__spec__.__class__.__name__=='ModuleSpec'; multiprocessing.__spec__.name=='multiprocessing' (len=15); type(multiprocessing.cpu_count).__name__=='method' (cpu_count is a bound method of BaseContext); multiprocessing.cpu_count.__module__=='multiprocessing.context' (len=23); multiprocessing.cpu_count.__qualname__=='BaseContext.cpu_count' (len=21); type(multiprocessing.current_process).__name__=='function'; multiprocessing.current_process.__qualname__=='current_process' (len=15); type(multiprocessing.active_children).__name__=='function'; multiprocessing.active_children.__qualname__=='active_children' (len=15); multiprocessing.current_process.__code__.co_argcount==0; multiprocessing.active_children.__code__.co_argcount==0. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__name__ == 'multiprocessing' (len=15). multiprocessing.__package__ == 'multiprocessing' (len=15, same as __name__ — both are the string 'multiprocessing'). type(multiprocessing.__name__).__name__ == 'str'. multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' (the module spec object is a ModuleSpec instance). multiprocessing.__spec__.name == 'multiprocessing' (len=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "type(multiprocessing.cpu_count).__name__ == 'method' — cpu_count is a bound method of the BaseContext object (not a free function). multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21). multiprocessing.cpu_count.__module__ == 'multiprocessing.context' (len=23). type(multiprocessing.current_process).__name__ == 'function' — current_process is a plain Python function (co_argcount=0). type(multiprocessing.active_children).__name__ == 'function' — active_children is also a plain Python function (co_argcount=0). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing module __name__, __package__, __spec__ attributes — extra110
#
# Wave 254 theme: multiprocessing module identity attributes.
#
# multiprocessing.__name__                == 'multiprocessing' (len=15)
# multiprocessing.__package__             == 'multiprocessing' (len=15, same as __name__)
# multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'
# multiprocessing.__spec__.name           == 'multiprocessing' (len=15)
# type(multiprocessing.__name__).__name__ == 'str'
# ---------------------------------------------------------------------------

table multiprocessing_extra110.mp_module_name_package_spec_attrs:
  description: "multiprocessing module __name__, __package__, and __spec__ attribute checks in mpmod110 namespace — wave 254 theme: multiprocessing.__name__.__eq__('multiprocessing')==True (len=15: 'multiprocessing'=15; the standard Python module name attribute); multiprocessing.__name__.__len__()==15; type(multiprocessing.__name__).__name__.__eq__('str')==True (the __name__ attribute is a Python string, type='str'); multiprocessing.__package__.__eq__('multiprocessing')==True (len=15; same value as __name__ — the package name equals the module name for a top-level package); multiprocessing.__package__.__len__()==15; multiprocessing.__package__.__eq__(multiprocessing.__name__)==True (package and name are equal string values); multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (the module spec is a ModuleSpec instance from importlib.machinery); multiprocessing.__spec__.name.__eq__('multiprocessing')==True (the spec's name attribute also equals 'multiprocessing'); multiprocessing.__spec__.name.__len__()==15; compare: __name__==__package__==__spec__.name=='multiprocessing' (all three attributes contain the same string value 'multiprocessing', len=15 each); all three string values are equal but stored in different attributes for different purposes; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmod110

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,            multiprocessing.__name__.__eq__,                               ["multiprocessing"],    true, "multiprocessing.__name__ == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [name_len,           multiprocessing.__name__.__len__,                              [],                     15,   "multiprocessing.__name__.__len__() == 15 ('multiprocessing'=15); verified with Python 3.14.3"]
    - [name_type_eq,       type(multiprocessing.__name__).__name__.__eq__,                ["str"],                true, "type(multiprocessing.__name__).__name__ == 'str' (module __name__ is a string); verified with Python 3.14.3"]
    - [pkg_eq,             multiprocessing.__package__.__eq__,                            ["multiprocessing"],    true, "multiprocessing.__package__ == 'multiprocessing' (len=15, same as __name__); verified with Python 3.14.3"]
    - [pkg_len,            multiprocessing.__package__.__len__,                           [],                     15,   "multiprocessing.__package__.__len__() == 15 ('multiprocessing'=15, same as __name__); verified with Python 3.14.3"]
    - [pkg_type_eq,        type(multiprocessing.__package__).__name__.__eq__,             ["str"],                true, "type(multiprocessing.__package__).__name__ == 'str'; verified with Python 3.14.3"]
    - [spec_class_eq,      multiprocessing.__spec__.__class__.__name__.__eq__,            ["ModuleSpec"],         true, "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' (importlib.machinery.ModuleSpec); verified with Python 3.14.3"]
    - [spec_name_eq,       multiprocessing.__spec__.name.__eq__,                          ["multiprocessing"],    true, "multiprocessing.__spec__.name == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [spec_name_len,      multiprocessing.__spec__.name.__len__,                         [],                     15,   "multiprocessing.__spec__.name.__len__() == 15 ('multiprocessing'=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.cpu_count method type and qualname — extra110
#
# Wave 254 theme: cpu_count as a bound method of BaseContext.
#
# type(multiprocessing.cpu_count).__name__    == 'method' (bound method, not a free function)
# multiprocessing.cpu_count.__module__        == 'multiprocessing.context' (len=23)
# multiprocessing.cpu_count.__qualname__      == 'BaseContext.cpu_count'   (len=21)
# ---------------------------------------------------------------------------

table multiprocessing_extra110.mp_cpu_count_method_attrs:
  description: "multiprocessing.cpu_count method type and qualname checks in mpmod110 namespace — wave 254 theme: type(multiprocessing.cpu_count).__name__.__eq__('method')==True (cpu_count is a bound method of the BaseContext instance — it is NOT a free function like current_process and active_children; type='method' distinguishes it from type='function'); type(multiprocessing.cpu_count).__name__.__len__()==6 ('method'=6); multiprocessing.cpu_count.__qualname__.__eq__('BaseContext.cpu_count')==True (len=21: 'BaseContext.'=12+'cpu_count'=9=21; the qualname reveals cpu_count is defined on BaseContext); multiprocessing.cpu_count.__qualname__.__len__()==21; multiprocessing.cpu_count.__module__.__eq__('multiprocessing.context')==True (len=23: 'multiprocessing.context'=23; cpu_count is defined in the context submodule); multiprocessing.cpu_count.__module__.__len__()==23; compare with current_process and active_children: type(current_process).__name__=='function' (len=8) vs type(cpu_count).__name__=='method' (len=6); cpu_count qualname len=21 ('BaseContext.cpu_count') vs current_process qualname len=15 ('current_process') vs active_children qualname len=15 ('active_children'); cpu_count qualname contains the class prefix 'BaseContext.' (len=12); current_process and active_children are module-level functions with unqualified qualnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmod110a

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_type_eq,        type(multiprocessing.cpu_count).__name__.__eq__,               ["method"],             true, "type(multiprocessing.cpu_count).__name__ == 'method' (bound method of BaseContext, not free function); verified with Python 3.14.3"]
    - [cpu_type_len,       type(multiprocessing.cpu_count).__name__.__len__,              [],                     6,    "type(multiprocessing.cpu_count).__name__.__len__() == 6 ('method'=6); verified with Python 3.14.3"]
    - [cpu_qn_eq,          multiprocessing.cpu_count.__qualname__.__eq__,                 ["BaseContext.cpu_count"], true, "cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21; defined on BaseContext); verified with Python 3.14.3"]
    - [cpu_qn_len,         multiprocessing.cpu_count.__qualname__.__len__,                [],                     21,   "cpu_count.__qualname__.__len__() == 21 ('BaseContext.cpu_count'=21); verified with Python 3.14.3"]
    - [cpu_module_eq,      multiprocessing.cpu_count.__module__.__eq__,                   ["multiprocessing.context"], true, "cpu_count.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [cpu_module_len,     multiprocessing.cpu_count.__module__.__len__,                  [],                     23,   "cpu_count.__module__.__len__() == 23 ('multiprocessing.context'=23); verified with Python 3.14.3"]
    - [cp_type_eq,         type(multiprocessing.current_process).__name__.__eq__,         ["function"],           true, "type(current_process).__name__ == 'function' (free function, not bound method); verified with Python 3.14.3"]
    - [ac_type_eq,         type(multiprocessing.active_children).__name__.__eq__,         ["function"],           true, "type(active_children).__name__ == 'function' (free function, not bound method); verified with Python 3.14.3"]
    - [cpu_vs_cp_type,     type(multiprocessing.cpu_count).__name__.__eq__,               ["method"],             true, "cpu_count type='method' vs current_process type='function' (cpu_count is a bound method); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.current_process and active_children qualnames — extra110
#
# Wave 254 theme: current_process and active_children function qualnames and co_argcounts.
#
# multiprocessing.current_process.__qualname__ == 'current_process' (len=15, co_argcount=0)
# multiprocessing.active_children.__qualname__ == 'active_children' (len=15, co_argcount=0)
# ---------------------------------------------------------------------------

table multiprocessing_extra110.mp_current_process_active_children_attrs:
  description: "multiprocessing.current_process and active_children qualname and co_argcount checks in mpmod110 namespace — wave 254 theme: multiprocessing.current_process.__qualname__.__eq__('current_process')==True (len=15: 'current_process'=15; module-level function with unqualified qualname); multiprocessing.current_process.__qualname__.__len__()==15; type(multiprocessing.current_process).__name__.__eq__('function')==True (free Python function); multiprocessing.current_process.__code__.co_argcount==0 (takes no arguments — returns the current Process object without parameters); multiprocessing.current_process.__module__.__eq__('multiprocessing.process')==True (defined in multiprocessing.process submodule); multiprocessing.active_children.__qualname__.__eq__('active_children')==True (len=15: 'active_children'=15; same length as current_process=15); multiprocessing.active_children.__qualname__.__len__()==15; type(multiprocessing.active_children).__name__.__eq__('function')==True; multiprocessing.active_children.__code__.co_argcount==0 (takes no arguments — returns list of active child Process objects); multiprocessing.active_children.__module__.__eq__('multiprocessing.process')==True (same module as current_process); compare: current_process qualname len==active_children qualname len==15 (tied); both co_argcount==0 (neither takes arguments); both are free functions (type='function') unlike cpu_count (type='method'); both modules are 'multiprocessing.process' (len=23); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmod110b

  columns: [id, function, args, expected, description]
  rows:
    - [cp_qn_eq,           multiprocessing.current_process.__qualname__.__eq__,           ["current_process"],    true, "current_process.__qualname__ == 'current_process' (len=15, unqualified module-level function); verified with Python 3.14.3"]
    - [cp_qn_len,          multiprocessing.current_process.__qualname__.__len__,          [],                     15,   "current_process.__qualname__.__len__() == 15 ('current_process'=15); verified with Python 3.14.3"]
    - [cp_type_eq2,        type(multiprocessing.current_process).__name__.__eq__,         ["function"],           true, "type(current_process).__name__ == 'function' (free Python function); verified with Python 3.14.3"]
    - [cp_argc,            multiprocessing.current_process.__code__.co_argcount.__eq__,   [0],                    true, "current_process.__code__.co_argcount == 0 (takes no arguments); verified with Python 3.14.3"]
    - [cp_module_eq,       multiprocessing.current_process.__module__.__eq__,             ["multiprocessing.process"], true, "current_process.__module__ == 'multiprocessing.process' (len=23); verified with Python 3.14.3"]
    - [ac_qn_eq,           multiprocessing.active_children.__qualname__.__eq__,           ["active_children"],    true, "active_children.__qualname__ == 'active_children' (len=15, tied with current_process=15); verified with Python 3.14.3"]
    - [ac_qn_len,          multiprocessing.active_children.__qualname__.__len__,          [],                     15,   "active_children.__qualname__.__len__() == 15 ('active_children'=15, tied with current_process=15); verified with Python 3.14.3"]
    - [ac_type_eq2,        type(multiprocessing.active_children).__name__.__eq__,         ["function"],           true, "type(active_children).__name__ == 'function' (free Python function); verified with Python 3.14.3"]
    - [ac_argc,            multiprocessing.active_children.__code__.co_argcount.__eq__,   [0],                    true, "active_children.__code__.co_argcount == 0 (takes no arguments); verified with Python 3.14.3"]
    - [ac_module_eq,       multiprocessing.active_children.__module__.__eq__,             ["multiprocessing.process"], true, "active_children.__module__ == 'multiprocessing.process' (same as current_process); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra110
# ---------------------------------------------------------------------------

invariant multiprocessing_extra110.mp_name_len_15:
  description: "multiprocessing.__name__.__len__() == 15 — 'multiprocessing'=15 chars; multiprocessing.__name__.__eq__('multiprocessing')==True; type(multiprocessing.__name__).__name__=='str' (Python string type); multiprocessing.__package__.__len__()==15 (same length as __name__); multiprocessing.__spec__.name.__len__()==15 (same length); all three attributes contain the same 15-char string 'multiprocessing': __name__, __package__, and __spec__.name; compare: len('multiprocessing')=15 > len('asyncio')=7 (multiprocessing module name is longer than asyncio module name); the string 'multiprocessing' contains 'multi'=5+'processing'=10=15 chars; __name__==__package__ (for top-level packages, the module name and package name are the same); NEW in extra110: first standalone mp.__name__ length invariant in mpmod110 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__name__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra110.mp_spec_class_is_ModuleSpec:
  description: "multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — the module spec object is an instance of importlib.machinery.ModuleSpec; multiprocessing.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'ModuleSpec'=10); multiprocessing.__spec__.name=='multiprocessing' (len=15); type(multiprocessing.__spec__.name).__name__=='str'; ModuleSpec is the standard Python module specification class used by the import system (PEP 451); the __spec__ attribute stores metadata about how the module was loaded; multiprocessing.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec'=10); compare: type(multiprocessing.__name__).__name__=='str' (the __name__ attribute is a str) vs multiprocessing.__spec__.__class__.__name__=='ModuleSpec' (the __spec__ object is a ModuleSpec); NEW in extra110: first standalone mp.__spec__.__class__.__name__ invariant in mpmod110 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra110.cpu_count_qualname_len_21:
  description: "multiprocessing.cpu_count.__qualname__.__len__() == 21 — 'BaseContext.cpu_count' = 'BaseContext.'=12 + 'cpu_count'=9 = 21; cpu_count is a bound method of the BaseContext instance, so its qualname carries the 'BaseContext.' prefix (len=12); compare qualname lengths: current_process=active_children=15 (shorter, module-level functions without class prefix) < cpu_count=21 (longer, has 'BaseContext.' prefix); compare: type(cpu_count).__name__=='method' (len=6) vs type(current_process).__name__=='function' (len=8); the 'method' type string is shorter than 'function' even though cpu_count's qualname is longer; cpu_count.__module__=='multiprocessing.context' (len=23); cpu_count is exposed at module level but internally bound to the default context object; cpu_count() returns the number of CPUs in the system; NEW in extra110: first standalone cpu_count qualname length invariant in mpmod110 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra110.current_process_co_argcount_0:
  description: "multiprocessing.current_process.__code__.co_argcount == 0 — current_process takes no arguments (co_argcount=0: not even self, since it is a free function not a method); type(multiprocessing.current_process).__name__=='function' (free Python function); multiprocessing.current_process.__qualname__=='current_process' (len=15, unqualified — no class prefix); multiprocessing.current_process.__module__=='multiprocessing.process' (len=23); compare co_argcount: current_process=active_children=0 (both take no arguments) vs multiprocessing.Process lifecycle methods (start/run=1 self only; join=2 self+timeout from extra109); current_process() returns the Process object corresponding to the calling process (always returns the main process when called in the main thread); current_process and active_children are the two zero-argument multiprocessing functions in this spec; multiprocessing.__name__.__len__()==15 (same as current_process qualname len=15 — coincidental tie); NEW in extra110: first standalone current_process co_argcount invariant in mpmod110 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.current_process.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant multiprocessing_extra110.active_children_qualname_len_15:
  description: "multiprocessing.active_children.__qualname__.__len__() == 15 — 'active_children'=15 chars; tied with current_process.__qualname__.__len__()==15 (both module-level functions have qualname length=15); compare: active_children=current_process=15 (tied, module-level functions) < cpu_count=21 (longer, bound method with 'BaseContext.' prefix); multiprocessing.active_children.__code__.co_argcount==0 (takes no arguments); multiprocessing.active_children.__module__=='multiprocessing.process' (len=23, same as current_process); multiprocessing.active_children.__qualname__=='active_children' (no class prefix — it is a module-level function); active_children() returns a list of all active child Process objects; calling active_children() also causes any completed Process objects to be cleaned up (sets exitcode); type(active_children).__name__=='function' (len=8) — same as current_process; NEW in extra110: first standalone active_children qualname length invariant in mpmod110 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.active_children.__qualname__.__len__
  args: []
  expected: 15
