spec: io_extra257
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers io.StringIO method identity: read, write, seek, tell, getvalue, close, readline, readlines, writelines."
    - "All of these are method_descriptor objects defined in the C extension _io (not in Lib/io.py); their __class__.__name__ is 'method_descriptor'."
    - "io.StringIO.read.__qualname__ == 'StringIO.read', io.StringIO.write.__qualname__ == 'StringIO.write', etc. — qualnames are prefixed with 'StringIO.'."
    - "io.StringIO.readlines and io.StringIO.writelines are inherited from _IOBase; their __qualname__ values are '_IOBase.readlines' and '_IOBase.writelines' respectively."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.StringIO core method __name__ identity
#
# read, write, seek, tell, getvalue, close are all method_descriptor objects
# implemented in the _io C extension. Their __name__ values match the method
# name exactly.
# ---------------------------------------------------------------------------

table io_extra257.stringio_method_names:
  description: "io.StringIO core method __name__ identity — read, write, seek, tell, getvalue, close; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ioxsmn257

  columns: [id, function, args, expected, description]
  rows:
    - [read_name,
       "StringIO.read.__name__.__eq__",
       ["read"],
       true,
       "io.StringIO.read.__name__.__eq__('read') == True — StringIO.read is a method_descriptor for reading up to n characters from a StringIO buffer; its __name__ is 'read'; str.__eq__('read') returns True; new to extra257"]
    - [write_name,
       "StringIO.write.__name__.__eq__",
       ["write"],
       true,
       "io.StringIO.write.__name__.__eq__('write') == True — StringIO.write is a method_descriptor for writing a string to the buffer; its __name__ is 'write'; str.__eq__('write') returns True; new to extra257"]
    - [seek_name,
       "StringIO.seek.__name__.__eq__",
       ["seek"],
       true,
       "io.StringIO.seek.__name__.__eq__('seek') == True — StringIO.seek is a method_descriptor for repositioning the stream position; its __name__ is 'seek'; str.__eq__('seek') returns True; new to extra257"]
    - [tell_name,
       "StringIO.tell.__name__.__eq__",
       ["tell"],
       true,
       "io.StringIO.tell.__name__.__eq__('tell') == True — StringIO.tell is a method_descriptor for returning the current stream position; its __name__ is 'tell'; str.__eq__('tell') returns True; new to extra257"]
    - [getvalue_name,
       "StringIO.getvalue.__name__.__eq__",
       ["getvalue"],
       true,
       "io.StringIO.getvalue.__name__.__eq__('getvalue') == True — StringIO.getvalue is a method_descriptor for returning the entire buffer contents as a string; its __name__ is 'getvalue'; str.__eq__('getvalue') returns True; new to extra257"]
    - [close_name,
       "StringIO.close.__name__.__eq__",
       ["close"],
       true,
       "io.StringIO.close.__name__.__eq__('close') == True — StringIO.close is a method_descriptor for flushing and closing the stream; its __name__ is 'close'; str.__eq__('close') returns True; new to extra257"]

# ---------------------------------------------------------------------------
# Table 2: io.StringIO additional method __name__ identity
#
# readline, readlines (inherited from _IOBase), writelines (inherited from
# _IOBase) are also method_descriptor objects available on StringIO.
# ---------------------------------------------------------------------------

table io_extra257.stringio_additional_method_names:
  description: "io.StringIO readline, readlines, writelines __name__ identity; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ioxsamn257

  columns: [id, function, args, expected, description]
  rows:
    - [readline_name,
       "StringIO.readline.__name__.__eq__",
       ["readline"],
       true,
       "io.StringIO.readline.__name__.__eq__('readline') == True — StringIO.readline reads up to the next newline or size characters; its __name__ is 'readline'; str.__eq__('readline') returns True; new to extra257"]
    - [readlines_name,
       "StringIO.readlines.__name__.__eq__",
       ["readlines"],
       true,
       "io.StringIO.readlines.__name__.__eq__('readlines') == True — StringIO.readlines is inherited from _IOBase and reads all lines into a list; its __name__ is 'readlines'; str.__eq__('readlines') returns True; new to extra257"]
    - [writelines_name,
       "StringIO.writelines.__name__.__eq__",
       ["writelines"],
       true,
       "io.StringIO.writelines.__name__.__eq__('writelines') == True — StringIO.writelines is inherited from _IOBase and writes a list of strings to the buffer; its __name__ is 'writelines'; str.__eq__('writelines') returns True; new to extra257"]
    - [readline_class,
       "StringIO.readline.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.readline.__class__.__name__.__eq__('method_descriptor') == True — StringIO.readline is a C-level method_descriptor, not a Python function; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra257"]
    - [readlines_class,
       "StringIO.readlines.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.readlines.__class__.__name__.__eq__('method_descriptor') == True — StringIO.readlines is a C-level method_descriptor inherited from _IOBase; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra257"]
    - [writelines_class,
       "StringIO.writelines.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.writelines.__class__.__name__.__eq__('method_descriptor') == True — StringIO.writelines is a C-level method_descriptor inherited from _IOBase; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra257"]

# ---------------------------------------------------------------------------
# Table 3: io.StringIO method __qualname__ identity
#
# Qualnames for methods defined directly on StringIO use the 'StringIO.'
# prefix. readlines and writelines are inherited from _IOBase and therefore
# carry the '_IOBase.' prefix.
# ---------------------------------------------------------------------------

table io_extra257.stringio_method_qualnames:
  description: "io.StringIO method __qualname__ identity — direct and inherited methods; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ioxsmq257

  columns: [id, function, args, expected, description]
  rows:
    - [read_qualname,
       "StringIO.read.__qualname__.__eq__",
       ["StringIO.read"],
       true,
       "io.StringIO.read.__qualname__.__eq__('StringIO.read') == True — StringIO.read is defined directly on StringIO so its __qualname__ is 'StringIO.read'; str.__eq__('StringIO.read') returns True; new to extra257"]
    - [write_qualname,
       "StringIO.write.__qualname__.__eq__",
       ["StringIO.write"],
       true,
       "io.StringIO.write.__qualname__.__eq__('StringIO.write') == True — StringIO.write is defined directly on StringIO so its __qualname__ is 'StringIO.write'; str.__eq__('StringIO.write') returns True; new to extra257"]
    - [seek_qualname,
       "StringIO.seek.__qualname__.__eq__",
       ["StringIO.seek"],
       true,
       "io.StringIO.seek.__qualname__.__eq__('StringIO.seek') == True — StringIO.seek is defined directly on StringIO so its __qualname__ is 'StringIO.seek'; str.__eq__('StringIO.seek') returns True; new to extra257"]
    - [tell_qualname,
       "StringIO.tell.__qualname__.__eq__",
       ["StringIO.tell"],
       true,
       "io.StringIO.tell.__qualname__.__eq__('StringIO.tell') == True — StringIO.tell is defined directly on StringIO so its __qualname__ is 'StringIO.tell'; str.__eq__('StringIO.tell') returns True; new to extra257"]
    - [getvalue_qualname,
       "StringIO.getvalue.__qualname__.__eq__",
       ["StringIO.getvalue"],
       true,
       "io.StringIO.getvalue.__qualname__.__eq__('StringIO.getvalue') == True — StringIO.getvalue is defined directly on StringIO so its __qualname__ is 'StringIO.getvalue'; str.__eq__('StringIO.getvalue') returns True; new to extra257"]
    - [readlines_qualname,
       "StringIO.readlines.__qualname__.__eq__",
       ["_IOBase.readlines"],
       true,
       "io.StringIO.readlines.__qualname__.__eq__('_IOBase.readlines') == True — readlines is inherited from the _IOBase C base class, so its __qualname__ is '_IOBase.readlines', not 'StringIO.readlines'; str.__eq__('_IOBase.readlines') returns True; new to extra257"]
    - [writelines_qualname,
       "StringIO.writelines.__qualname__.__eq__",
       ["_IOBase.writelines"],
       true,
       "io.StringIO.writelines.__qualname__.__eq__('_IOBase.writelines') == True — writelines is inherited from the _IOBase C base class, so its __qualname__ is '_IOBase.writelines', not 'StringIO.writelines'; str.__eq__('_IOBase.writelines') returns True; new to extra257"]

# ---------------------------------------------------------------------------
# Table 4: io.StringIO method __class__.__name__ — all are method_descriptor
# ---------------------------------------------------------------------------

table io_extra257.stringio_method_class_names:
  description: "io.StringIO core method __class__.__name__ — all are 'method_descriptor'; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ioxsmcn257

  columns: [id, function, args, expected, description]
  rows:
    - [read_class,
       "StringIO.read.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.read.__class__.__name__.__eq__('method_descriptor') == True — StringIO.read is a C-level method_descriptor, not a Python function or wrapper_descriptor; str.__eq__('method_descriptor') returns True; new to extra257"]
    - [write_class,
       "StringIO.write.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.write.__class__.__name__.__eq__('method_descriptor') == True — StringIO.write is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra257"]
    - [seek_class,
       "StringIO.seek.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.seek.__class__.__name__.__eq__('method_descriptor') == True — StringIO.seek is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra257"]
    - [tell_class,
       "StringIO.tell.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.tell.__class__.__name__.__eq__('method_descriptor') == True — StringIO.tell is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra257"]
    - [getvalue_class,
       "StringIO.getvalue.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.getvalue.__class__.__name__.__eq__('method_descriptor') == True — StringIO.getvalue is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra257"]
    - [close_class,
       "StringIO.close.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.StringIO.close.__class__.__name__.__eq__('method_descriptor') == True — StringIO.close is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra257"]

# ---------------------------------------------------------------------------
# Standalone invariants — io_extra257
# ---------------------------------------------------------------------------

invariant io_extra257.stringio_read_name:
  description: "io.StringIO.read.__name__ == 'read' — StringIO.read is a C-level method_descriptor; new to extra257"
  kind: python_call_eq
  function: StringIO.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra257.stringio_write_name:
  description: "io.StringIO.write.__name__ == 'write' — StringIO.write is a C-level method_descriptor; new to extra257"
  kind: python_call_eq
  function: StringIO.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra257.stringio_read_qualname:
  description: "io.StringIO.read.__qualname__ == 'StringIO.read' — read is defined directly on StringIO; new to extra257"
  kind: python_call_eq
  function: StringIO.read.__qualname__.__eq__
  args: ["StringIO.read"]
  expected: true

invariant io_extra257.stringio_readlines_qualname:
  description: "io.StringIO.readlines.__qualname__ == '_IOBase.readlines' — readlines is inherited from _IOBase; new to extra257"
  kind: python_call_eq
  function: "StringIO.readlines.__qualname__.__eq__"
  args: ["_IOBase.readlines"]
  expected: true

invariant io_extra257.stringio_writelines_qualname:
  description: "io.StringIO.writelines.__qualname__ == '_IOBase.writelines' — writelines is inherited from _IOBase; new to extra257"
  kind: python_call_eq
  function: "StringIO.writelines.__qualname__.__eq__"
  args: ["_IOBase.writelines"]
  expected: true

invariant io_extra257.stringio_seek_is_method_descriptor:
  description: "io.StringIO.seek.__class__.__name__ == 'method_descriptor' — all StringIO methods are C-level method_descriptors; new to extra257"
  kind: python_call_eq
  function: StringIO.seek.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra257.stringio_getvalue_name:
  description: "io.StringIO.getvalue.__name__ == 'getvalue' — StringIO.getvalue returns entire buffer as a string; new to extra257"
  kind: python_call_eq
  function: StringIO.getvalue.__name__.__eq__
  args: ["getvalue"]
  expected: true
