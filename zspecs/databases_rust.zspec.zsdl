error_model: python_exceptions

# databases_client_name — Database class name
invariant databases_rust.client.class_name:
  description: "databases.Database.__name__ == 'Database'"
  category: client
  kind: python_call_eq
  function: databases_client_name
  args: []
  expected: "Database"

# databases_has_url — DatabaseURL present
invariant databases_rust.module.has_url:
  description: "databases.DatabaseURL is available"
  category: module
  kind: python_call_eq
  function: databases_has_url
  args: []
  expected: true

# databases_version_nonempty — version non-empty
invariant databases_rust.version.nonempty:
  description: "databases.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: databases_version_nonempty
  args: []
  expected: true

