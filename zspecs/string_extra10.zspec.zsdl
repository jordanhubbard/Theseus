spec: string_extra10
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra9.zspec.zsdl."
    - "string_extra9 covers: name_attrs table (Template/Formatter/capwords/ascii_letters); capwords two-word and three-word; ascii_letters first/last char; ascii_letters.endswith('Z')."
    - "string_extra8 covers: standalone __len__ for all constants; Formatter/Template __name__/__module__ standalone."
    - "string_extra7 covers: printable/ascii_letters membership; hexdigits membership; whitespace vtab/ff; Formatter instance class name; base class names; capwords already-title-case/empty."
    - "string_extra6 covers: whitespace/punctuation/ascii_letters membership; capwords with sep."
    - "string_extra5 covers: Template/__qualname__; Formatter/__qualname__; capwords/__qualname__; ascii_uppercase/lowercase exact values."
    - "NOT yet covered: string.Formatter.mro().__len__() == 2."
    - "NOT yet covered: string.Template.mro().__len__() == 2."
    - "NOT yet covered: string.Template('$greeting world').substitute(greeting='Hello') == 'Hello world'."
    - "NOT yet covered: string.Template('$x and $y').safe_substitute(x='hello') == 'hello and $y' (missing key preserved)."
    - "NOT yet covered: string.ascii_lowercase.startswith('a') == True."
    - "NOT yet covered: string.ascii_uppercase.startswith('A') == True."
    - "NOT yet covered: string.digits[0] == '0' — first digit character."
    - "NOT yet covered: string.digits[-1] == '9' — last digit character. (extra7 covers digits first/last; this is a different spec namespace.)"
    - "NOT yet covered: string.digits.endswith('9') == True."
    - "NOT yet covered: string.Formatter().format('{0}', 'world') == 'world' — positional placeholder."
    - "NOT yet covered: string.Formatter().format('{name}', name='X') == 'X' — keyword placeholder."
    - "string.Formatter.mro().__len__() == 2 — Formatter inherits directly from object."
    - "string.Template.mro().__len__() == 2 — Template inherits directly from object."
    - "string.Template('$greeting world').substitute(greeting='Hello') == 'Hello world'."
    - "string.Template('$x and $y').safe_substitute(x='hello') == 'hello and $y' — missing key left as-is."
    - "string.ascii_lowercase.startswith('a') == True."
    - "string.ascii_uppercase.startswith('A') == True."
    - "string.digits.endswith('9') == True."
    - "string.Formatter().format('{0}', 'world') == 'world' — positional format."
    - "string.Formatter().format('{name}', name='X') == 'X' — keyword format."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Formatter and Template MRO lengths
#
# string_extra2 and string_extra7 confirm that both classes inherit directly from
# object via __bases__[0].__name__ == 'object'. No prior spec checks the MRO
# length (2 for a class that inherits only from object). Formatter.mro() is
# [Formatter, object], so __len__() == 2; same for Template.
# ---------------------------------------------------------------------------

invariant string_extra10.Formatter.mro_len:
  description: "string.Formatter.mro().__len__() == 2 — [Formatter, object]"
  category: class_identity
  kind: python_call_eq
  function: Formatter.mro
  args: []
  method: __len__
  expected: 2

invariant string_extra10.Template.mro_len:
  description: "string.Template.mro().__len__() == 2 — [Template, object]"
  category: class_identity
  kind: python_call_eq
  function: Template.mro
  args: []
  method: __len__
  expected: 2

# ---------------------------------------------------------------------------
# Template.substitute — basic variable substitution
#
# No prior spec tests Template.substitute() as a standalone invariant.
# Template('$greeting world').substitute(greeting='Hello') == 'Hello world'.
# ---------------------------------------------------------------------------

invariant string_extra10.Template.substitute_basic:
  description: "string.Template('$greeting world').substitute(greeting='Hello') == 'Hello world'"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["$greeting world"]
  method: substitute
  method_args: []
  kwargs: {}
  expected: "Hello world"

# ---------------------------------------------------------------------------
# Template.safe_substitute — missing key preserved
#
# No prior spec tests Template.safe_substitute() with a missing key.
# Template('$x and $y').safe_substitute(x='hello') leaves '$y' unexpanded.
# Result is 'hello and $y'.
# ---------------------------------------------------------------------------

invariant string_extra10.Template.safe_substitute_missing_key:
  description: "string.Template('$x and $y').safe_substitute(x='hello') == 'hello and $y'"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["$x and $y"]
  method: safe_substitute
  method_args: []
  kwargs: {}
  expected: "hello and $y"

# ---------------------------------------------------------------------------
# ascii_lowercase and ascii_uppercase — startswith checks
#
# string_extra5 covers the exact values of ascii_lowercase and ascii_uppercase.
# No prior spec checks startswith() on either constant.
# ascii_lowercase starts with 'a'; ascii_uppercase starts with 'A'.
# ---------------------------------------------------------------------------

invariant string_extra10.ascii_lowercase.startswith_a:
  description: "string.ascii_lowercase.startswith('a') == True — begins with lowercase a"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.startswith
  args: ["a"]
  expected: true

invariant string_extra10.ascii_uppercase.startswith_A:
  description: "string.ascii_uppercase.startswith('A') == True — begins with uppercase A"
  category: constants
  kind: python_call_eq
  function: ascii_uppercase.startswith
  args: ["A"]
  expected: true

# ---------------------------------------------------------------------------
# digits — endswith check
#
# string_extra7 covers digits[0] == '0' and digits[-1] == '9' as a table.
# No prior spec checks digits.endswith('9') as a standalone boolean.
# ---------------------------------------------------------------------------

invariant string_extra10.digits.endswith_nine:
  description: "string.digits.endswith('9') == True — digits ends with character '9'"
  category: constants
  kind: python_call_eq
  function: digits.endswith
  args: ["9"]
  expected: true

# ---------------------------------------------------------------------------
# Formatter().format — positional and keyword placeholders
#
# string_extra4 covers Formatter().format with a plain format string (no {}).
# No prior spec covers Formatter().format with a {0} positional placeholder
# or a {name} keyword placeholder.
# ---------------------------------------------------------------------------

invariant string_extra10.Formatter.format_positional:
  description: "string.Formatter().format('{0}', 'world') == 'world' — positional placeholder"
  category: Formatter
  kind: python_call_eq
  function: Formatter
  args: []
  method: format
  method_args: ["{0}", "world"]
  expected: "world"

invariant string_extra10.Formatter.format_keyword:
  description: "string.Formatter().format('{name}', name='X') == 'X' — keyword placeholder"
  category: Formatter
  kind: python_call_eq
  function: Formatter
  args: []
  method: format
  method_args: ["{name}"]
  kwargs: {name: "X"}
  expected: "X"

# ---------------------------------------------------------------------------
# Table: MRO lengths for Formatter and Template
#
# No prior spec provides a table of MRO lengths for string module classes.
# Both Formatter and Template inherit directly from object (len 2).
# ---------------------------------------------------------------------------

table string_extra10.mro_lengths:
  description: "string.Formatter and string.Template MRO lengths"
  kind: python_call_eq
  category: class_identity
  id_prefix: smro

  columns: [id, function, args, expected]
  rows:
    - [Formatter_mro, Formatter.mro.__len__, [], 2]
    - [Template_mro,  Template.mro.__len__,  [], 2]
