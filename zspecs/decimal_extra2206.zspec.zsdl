  columns: [id, function, args, expected]
  rows:
    - ["dc2206013", "decimal.Decimal.__dict__.__contains__", ["__lt__"], true]
    - ["dc2206014", "decimal.Decimal.__dict__.__contains__", ["__le__"], true]
    - ["dc2206015", "decimal.Context.__dict__.__contains__", ["__lt__"], false]
    - ["dc2206016", "decimal.Context.__dict__.__contains__", ["__le__"], false]

