spec: decimal_extra2206
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2206 (decimal_extra2206): rich comparison operator protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "decimal.Decimal defines all six comparison dunders (__lt__, __le__, __gt__, __ge__, __eq__, __ne__) in its own __dict__ — Decimal is a full numeric type implementing IEEE 754 arithmetic, requiring explicit ordering and equality definitions that correctly handle NaN and special values."
    - "decimal.Context does NOT define any of the six comparison dunders in its own __dict__ — the arithmetic context object is a configuration container, not a numeric value, and uses default object identity semantics."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2206.decimal_comparison_protocol:
  description: "decimal.Decimal rich comparison operator dict-presence checks — Decimal defines all six comparison operators directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2206

  columns: [id, function, args, expected]
  rows:
    - ["dc2206001", "decimal.Decimal.__dict__.__contains__", ["__lt__"], true]
    - ["dc2206002", "decimal.Decimal.__dict__.__contains__", ["__le__"], true]
    - ["dc2206003", "decimal.Decimal.__dict__.__contains__", ["__gt__"], true]
    - ["dc2206004", "decimal.Decimal.__dict__.__contains__", ["__ge__"], true]
    - ["dc2206005", "decimal.Decimal.__dict__.__contains__", ["__eq__"], true]
    - ["dc2206006", "decimal.Decimal.__dict__.__contains__", ["__ne__"], true]

table decimal_extra2206.context_comparison_protocol:
  description: "decimal.Context rich comparison operator dict-presence checks — Context defines none of the six comparison operators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2206

  columns: [id, function, args, expected]
  rows:
    - ["dc2206007", "decimal.Context.__dict__.__contains__", ["__lt__"], false]
    - ["dc2206008", "decimal.Context.__dict__.__contains__", ["__le__"], false]
    - ["dc2206009", "decimal.Context.__dict__.__contains__", ["__gt__"], false]
    - ["dc2206010", "decimal.Context.__dict__.__contains__", ["__ge__"], false]
    - ["dc2206011", "decimal.Context.__dict__.__contains__", ["__eq__"], false]
    - ["dc2206012", "decimal.Context.__dict__.__contains__", ["__ne__"], false]

