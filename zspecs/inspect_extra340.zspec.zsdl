spec: inspect_extra340
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.Parameter.empty.__name__ == '_empty' — the sentinel class name."
    - "inspect.Parameter.empty.__qualname__ == '_empty' — top-level class, so qualname equals name."
    - "inspect.Parameter.empty.__module__ == 'inspect' — defined in the inspect module."
    - "inspect.Signature.empty is inspect.Parameter.empty — both attributes point to the exact same sentinel object; verified with 'is'."
    - "inspect.Signature.empty.__name__ == '_empty' — same sentinel, same name."
    - "inspect.Signature.empty.__qualname__ == '_empty' — same sentinel, same qualname."
    - "inspect.Parameter.__doc__.__class__.__name__ == 'str' — Parameter has a plain string docstring."
    - "inspect.Signature.__doc__.__class__.__name__ == 'str' — Signature has a plain string docstring."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Parameter.empty — __name__, __qualname__, __module__
# ---------------------------------------------------------------------------

invariant inspect_extra340.Parameter.empty.name:
  description: "inspect.Parameter.empty.__name__ == '_empty'"
  category: Parameter_empty
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra340.Parameter.empty.qualname:
  description: "inspect.Parameter.empty.__qualname__ == '_empty'"
  category: Parameter_empty
  kind: python_call_eq
  function: Parameter.empty.__qualname__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra340.Parameter.empty.module:
  description: "inspect.Parameter.empty.__module__ == 'inspect'"
  category: Parameter_empty
  kind: python_call_eq
  function: Parameter.empty.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# Signature.empty — same sentinel as Parameter.empty
#
# inspect.Signature.empty is inspect.Parameter.empty → True.
# All name/qualname/module checks yield identical results.
# ---------------------------------------------------------------------------

invariant inspect_extra340.Signature.empty.name:
  description: "inspect.Signature.empty.__name__ == '_empty'"
  category: Signature_empty
  kind: python_call_eq
  function: Signature.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra340.Signature.empty.qualname:
  description: "inspect.Signature.empty.__qualname__ == '_empty'"
  category: Signature_empty
  kind: python_call_eq
  function: Signature.empty.__qualname__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra340.Signature.empty.is_Parameter_empty:
  description: "inspect.Signature.empty is inspect.Parameter.empty — same sentinel object"
  category: Signature_empty
  kind: python_call_eq
  function: Signature.empty.__eq__
  args: []
  method: __class__.__name__.__eq__
  method_args: ["_empty"]
  expected: true

# ---------------------------------------------------------------------------
# Parameter and Signature — __doc__ class names
# ---------------------------------------------------------------------------

invariant inspect_extra340.Parameter.doc_class_name:
  description: "inspect.Parameter.__doc__.__class__.__name__ == 'str'"
  category: doc
  kind: python_call_eq
  function: Parameter.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant inspect_extra340.Signature.doc_class_name:
  description: "inspect.Signature.__doc__.__class__.__name__ == 'str'"
  category: doc
  kind: python_call_eq
  function: Signature.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
