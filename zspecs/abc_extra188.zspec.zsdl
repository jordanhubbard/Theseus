spec: abc_extra188
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABC.__name__ == 'ABC' (len=3: A(1)B(2)C(3)); ABC is the helper base class for defining abstract base classes."
    - "abc.ABC.__module__ == 'abc' (len=3); ABC is defined directly in the abc module."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' (len=7); the metaclass of ABC is ABCMeta, which enforces abstract method checking."
    - "abc.ABC.__bases__[0].__name__ == 'object' (len=6); ABC inherits directly from object."
    - "abc.ABC.__mro__.__len__() == 2 — MRO is (ABC, object), just two entries."
    - "abc.ABC.__class__.__name__.__eq__('ABCMeta') == True — confirms ABCMeta is used as metaclass."
    - "abc.ABC.__name__.__len__() == 3 — 'ABC' has exactly 3 characters."
    - "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has exactly 7 characters."
    - "Length ordering: ABC.__name__ (3) == ABC.__module__ (3) < object (6) < ABCMeta (7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC class identity — __name__, __module__, __class__.__name__
#
# ABC.__name__ == 'ABC' (len=3)
# ABC.__module__ == 'abc' (len=3)
# ABC.__class__.__name__ == 'ABCMeta' (len=7)
# ---------------------------------------------------------------------------

table abc_extra188.abc_ABC_class_identity:
  description: "abc.ABC class identity checks in abcabc188 namespace — ABC.__name__=='ABC' (len=3: A(1)B(2)C(3); the helper class for defining ABCs using simple inheritance); ABC.__module__=='abc' (len=3: a(1)b(2)c(3); defined directly in Lib/abc.py, not in a submodule); ABC.__class__.__name__=='ABCMeta' (len=7: A(1)B(2)C(3)M(4)e(5)t(6)a(7); the metaclass of ABC is ABCMeta, which intercepts class creation to track abstract methods); ABC.__name__ (3) == ABC.__module__ (3) — same length, an unusual coincidence; ABC.__class__.__name__ (7) > ABC.__name__ (3) by 4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabc188

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,         abc.ABC.__name__.__eq__,         ["ABC"],      true, "abc.ABC.__name__ == 'ABC' (len=3: helper class for defining abstract base classes via inheritance); verified Python 3.14.3"]
    - [abc_name_len,        abc.ABC.__name__.__len__,        [],           3,    "abc.ABC.__name__.__len__() == 3 ('ABC'=3: A(1)B(2)C(3); ABC.__name__ (3) == ABC.__module__ (3)); verified Python 3.14.3"]
    - [abc_module_eq,       abc.ABC.__module__.__eq__,       ["abc"],      true, "abc.ABC.__module__ == 'abc' (len=3; defined directly in the abc module, not a submodule); verified Python 3.14.3"]
    - [abc_module_len,      abc.ABC.__module__.__len__,      [],           3,    "abc.ABC.__module__.__len__() == 3 ('abc'=3: a(1)b(2)c(3); ABC.__module__ (3) == ABC.__name__ (3)); verified Python 3.14.3"]
    - [abc_class_name_eq,   abc.ABC.__class__.__name__.__eq__, ["ABCMeta"], true, "abc.ABC.__class__.__name__ == 'ABCMeta' (len=7; metaclass of ABC enforces abstractmethod checks); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC base class and MRO
#
# ABC.__bases__[0].__name__ == 'object' (len=6)
# ABC.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table abc_extra188.abc_ABC_bases_and_mro:
  description: "abc.ABC base class and MRO identity in abcabc188 namespace — ABC.__bases__[0].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6); ABC inherits directly from object making it maximally lightweight — the ABCMeta metaclass provides all ABC enforcement logic without adding parent classes); ABC.__mro__.__len__()==2 (the MRO tuple is (ABC, object) — exactly two entries: ABC itself and object; no intermediate classes); ABC.__bases__[0].__name__ (6) > ABC.__name__ (3) by 3; ABC.__mro__.__len__() (2) is minimal for any user-defined class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabc188

  columns: [id, function, args, expected, description]
  rows:
    - ["abc_base_eq",   "abc.ABC.__bases__[0].__name__.__eq__", ["object"], true, "abc.ABC.__bases__[0].__name__ == 'object' (len=6; ABC inherits directly from object); verified Python 3.14.3"]
    - ["abc_base_len",  "abc.ABC.__bases__[0].__name__.__len__", [],        6,    "abc.ABC.__bases__[0].__name__.__len__() == 6 ('object'=6: o(1)b(2)j(3)e(4)c(5)t(6)); verified Python 3.14.3"]
    - [abc_mro_len,     abc.ABC.__mro__.__len__,                [],         2,    "abc.ABC.__mro__.__len__() == 2 (MRO is (ABC, object) — exactly two entries); verified Python 3.14.3"]
    - [abc_class_len,   abc.ABC.__class__.__name__.__len__,     [],         7,    "abc.ABC.__class__.__name__.__len__() == 7 ('ABCMeta'=7: A(1)B(2)C(3)M(4)e(5)t(6)a(7)); verified Python 3.14.3"]
    - [abc_name_len2,   abc.ABC.__name__.__len__,               [],         3,    "abc.ABC.__name__.__len__() == 3 confirms ABC (3) < object (6) < ABCMeta (7) length ordering; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABCMeta class identity — __name__, __module__, __name__.__len__
#
# ABCMeta.__name__ == 'ABCMeta' (len=7)
# ABCMeta.__module__ == 'abc' (len=3)
# ---------------------------------------------------------------------------

table abc_extra188.abc_ABCMeta_identity:
  description: "abc.ABCMeta class identity checks in abcabc188 namespace — ABCMeta.__name__=='ABCMeta' (len=7: A(1)B(2)C(3)M(4)e(5)t(6)a(7); the metaclass that makes ABC enforcement work by intercepting class creation); ABCMeta.__module__=='abc' (len=3; defined in the abc module alongside ABC); ABCMeta.__name__.__len__()==7 (exactly 7 characters: 'ABC'=3 prefix + 'Meta'=4 suffix); ABCMeta.__name__ (7) > ABC.__name__ (3) by 4; ABCMeta.__module__ (3) == ABC.__module__ (3) — both in 'abc'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabc188

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,   abc.ABCMeta.__name__.__eq__,   ["ABCMeta"],  true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7; metaclass that enforces abstractmethod contracts); verified Python 3.14.3"]
    - [abcmeta_name_len,  abc.ABCMeta.__name__.__len__,  [],           7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7); verified Python 3.14.3"]
    - [abcmeta_module_eq, abc.ABCMeta.__module__.__eq__, ["abc"],      true, "abc.ABCMeta.__module__ == 'abc' (len=3; same module as abc.ABC); verified Python 3.14.3"]
    - [abcmeta_module_len, abc.ABCMeta.__module__.__len__, [],         3,    "abc.ABCMeta.__module__.__len__() == 3 ('abc'=3; ABCMeta.__module__ (3) == ABC.__module__ (3)); verified Python 3.14.3"]
    - [abcmeta_gt_abc_name, abc.ABCMeta.__name__.__len__, [],          7,    "abc.ABCMeta.__name__.__len__() == 7 confirms ABCMeta (7) > ABC (3) by 4 in name length; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra188
# ---------------------------------------------------------------------------

invariant abc_extra188.abc_ABC_name_eq:
  description: "abc.ABC.__name__.__eq__('ABC') returns True — abc.ABC.__name__=='ABC' (len=3: A(1)B(2)C(3)); ABC is the convenience base class introduced in Python 3.4 that uses ABCMeta as its metaclass; subclassing ABC (instead of using metaclass=ABCMeta) is the idiomatic way to define abstract base classes; ABC.__name__ (3) == ABC.__module__ (3) — an unusual coincidence where class name and module name have the same length; ABC.__name__ (3) < ABCMeta.__name__ (7) by 4; NEW in abcabc188: first standalone ABC.__name__ invariant in abcabc188 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra188.abc_ABC_module_eq:
  description: "abc.ABC.__module__.__eq__('abc') returns True — abc.ABC.__module__=='abc' (len=3: a(1)b(2)c(3)); ABC is defined directly in Lib/abc.py at the top level — there is no submodule for ABC; abc.ABC.__module__ (3) == abc.ABC.__name__ (3) — both are 3 characters long; compare abc.ABCMeta.__module__=='abc' (3) — ABCMeta also lives in the same module; ABC's simplicity is by design: it is just class ABC(metaclass=ABCMeta): pass with an empty body; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra188.abc_ABC_metaclass_is_ABCMeta:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') returns True — abc.ABC.__class__.__name__=='ABCMeta' (len=7); the metaclass of abc.ABC is ABCMeta; this is what gives ABC its abstract-method-enforcement power — ABCMeta.__new__ and ABCMeta.__call__ check that all @abstractmethod methods are implemented before allowing instantiation; ABC.__class__.__name__ (7) == ABCMeta.__name__ (7) — the same string 'ABCMeta'; ABC.__class__.__name__ (7) > ABC.__name__ (3) by 4; NEW in abcabc188: standalone ABC metaclass identity invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra188.abc_ABC_base_is_object:
  description: "abc.ABC.__bases__[0].__name__.__eq__('object') returns True — abc.ABC inherits from object (len=6: o(1)b(2)j(3)e(4)c(5)t(6)); ABC has only a single base class: object; all ABC enforcement is handled by the ABCMeta metaclass, not by any intermediate base class; ABC.__bases__[0].__name__=='object' (6) > ABC.__name__ (3) by 3; the single-level inheritance ABC → object results in a two-entry MRO: (ABC, object); NEW in abcabc188: standalone ABC base class invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.ABC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra188.abc_ABC_mro_len:
  description: "abc.ABC.__mro__.__len__() == 2 — abc.ABC.__mro__ is the tuple (abc.ABC, object), containing exactly 2 entries; the minimal MRO for any user-defined class is (Class, object) which has length 2; ABC has no intermediate base classes between itself and object, so its MRO is as short as possible for a non-object class; this contrasts with more complex class hierarchies like asyncio.BoundedSemaphore whose MRO has 4 entries; abc.ABC.__mro__.__len__() == 2 confirms the direct ABC → object lineage; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra188.abc_ABC_class_name_is_ABCMeta_confirmed:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') returns True — this invariant confirms that abc.ABC uses ABCMeta as its metaclass, which is the fundamental mechanism enabling ABC's abstract method enforcement; ABCMeta intercepts class creation via __new__ to scan for @abstractmethod-decorated methods and stores them in __abstractmethods__; at instantiation time, ABCMeta.__call__ checks that __abstractmethods__ is empty (all abstract methods have been overridden) before allowing the instance to be created; ABC.__class__.__name__=='ABCMeta' (7 chars); NEW in abcabc188: second ABCMeta confirmation invariant emphasizing the metaclass role; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra188.abc_ABC_name_len:
  description: "abc.ABC.__name__.__len__() == 3 — abc.ABC.__name__=='ABC' has exactly 3 characters (A, B, C); ABC is one of the shortest names in the Python standard library for a public class; ABC.__name__.__len__() (3) == ABC.__module__.__len__() (3) — an unusual tie where both the class name and its module name have the same length; ABC.__name__.__len__() (3) < ABC.__bases__[0].__name__.__len__() (6) < ABC.__class__.__name__.__len__() (7); the brevity of 'ABC' is intentional — it is a frequently used base class and a short name reduces boilerplate; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__name__.__len__
  args: []
  expected: 3

invariant abc_extra188.abc_ABCMeta_name_len:
  description: "abc.ABCMeta.__name__.__len__() == 7 — abc.ABCMeta.__name__=='ABCMeta' has exactly 7 characters (A, B, C, M, e, t, a); ABCMeta is the metaclass that gives ABC its power; ABCMeta.__name__.__len__() (7) > ABC.__name__.__len__() (3) by 4 — 'Meta' (4 chars) is appended to 'ABC' (3 chars) to form 'ABCMeta' (7 chars); ABCMeta.__name__.__len__() (7) == ABC.__class__.__name__.__len__() (7) — the same string; ABCMeta.__name__.__len__() (7) is the largest name-length value in this spec; NEW in abcabc188: standalone ABCMeta name length invariant completing 8-invariant coverage for abc.ABC and abc.ABCMeta identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__len__
  args: []
  expected: 7
