spec: statistics_extra22
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra through statistics_extra21."
    - "statistics_extra21 covers NormalDist.from_samples, __repr__, __eq__, __hash__ qualnames and len invariants for all NormalDist methods."
    - "No prior spec covers __qualname__ for NormalDist property fget functions (mean, stdev, variance, median)."
    - "No prior spec covers StatisticsError.__bases__[0].__name__ or __module__."
    - "No prior spec covers NormalDist.__module__."
    - "NormalDist property getters follow 'NormalDist.<attr>' pattern for __qualname__."
    - "StatisticsError inherits from ValueError; its __module__ is 'statistics'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist property fget __qualname__ values
#
# statistics_extra17 through extra21 cover NormalDist and its methods but
# none records the __qualname__ of property fget functions.
# NormalDist exposes mean, stdev, variance, and median as properties; their
# fget functions carry __qualname__ == 'NormalDist.<attr>'.
# ---------------------------------------------------------------------------

table statistics_extra22.normaldist_property_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [mean,     NormalDist.mean.fget.__qualname__.__eq__,     ["NormalDist.mean"],     true, "NormalDist.mean.fget.__qualname__ == 'NormalDist.mean'"]
    - [stdev,    NormalDist.stdev.fget.__qualname__.__eq__,    ["NormalDist.stdev"],    true, "NormalDist.stdev.fget.__qualname__ == 'NormalDist.stdev'"]
    - [variance, NormalDist.variance.fget.__qualname__.__eq__, ["NormalDist.variance"], true, "NormalDist.variance.fget.__qualname__ == 'NormalDist.variance'"]
    - [median,   NormalDist.median.fget.__qualname__.__eq__,   ["NormalDist.median"],   true, "NormalDist.median.fget.__qualname__ == 'NormalDist.median'"]

# ---------------------------------------------------------------------------
# NormalDist property fget __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant statistics_extra22.mean.fget_qualname_len:
  description: "len(statistics.NormalDist.mean.fget.__qualname__) == 15 — 'NormalDist.mean' is 15 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.mean.fget.__qualname__.__len__
  args: []
  expected: 15

invariant statistics_extra22.stdev.fget_qualname_len:
  description: "len(statistics.NormalDist.stdev.fget.__qualname__) == 16 — 'NormalDist.stdev' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.stdev.fget.__qualname__.__len__
  args: []
  expected: 16

invariant statistics_extra22.variance.fget_qualname_len:
  description: "len(statistics.NormalDist.variance.fget.__qualname__) == 19 — 'NormalDist.variance' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.variance.fget.__qualname__.__len__
  args: []
  expected: 19

invariant statistics_extra22.median.fget_qualname_len:
  description: "len(statistics.NormalDist.median.fget.__qualname__) == 17 — 'NormalDist.median' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.median.fget.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# StatisticsError base class and module
#
# No prior spec records StatisticsError.__bases__[0].__name__ or __module__.
# StatisticsError inherits from ValueError and lives in the statistics module.
# ---------------------------------------------------------------------------

invariant statistics_extra22.StatisticsError.base_name:
  description: "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError' — inherits from ValueError"
  category: class_identity
  kind: python_call_eq
  function: "StatisticsError.__bases__[0].__name__.__eq__"
  args: ["ValueError"]
  expected: true

invariant statistics_extra22.StatisticsError.module:
  description: "statistics.StatisticsError.__module__ == 'statistics'"
  category: class_identity
  kind: python_call_eq
  function: StatisticsError.__module__.__eq__
  args: ["statistics"]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist __module__
#
# No prior spec records NormalDist.__module__.
# ---------------------------------------------------------------------------

invariant statistics_extra22.NormalDist.module:
  description: "statistics.NormalDist.__module__ == 'statistics'"
  category: class_identity
  kind: python_call_eq
  function: NormalDist.__module__.__eq__
  args: ["statistics"]
  expected: true
