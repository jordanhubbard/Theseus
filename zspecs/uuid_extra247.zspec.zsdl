spec: uuid_extra247
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace, July 2005"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 247 theme: uuid NAMESPACE constant hex values and version identity."
    - "uuid.NAMESPACE_DNS.hex == '6ba7b8109dad11d180b400c04fd430c8'. NAMESPACE_DNS is a version-1 UUID defined in RFC 4122 Appendix C. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.hex == '6ba7b8119dad11d180b400c04fd430c8'. NAMESPACE_URL is a version-1 UUID for URL namespacing. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.hex == '6ba7b8129dad11d180b400c04fd430c8'. NAMESPACE_OID is a version-1 UUID for ISO OID namespacing. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.hex == '6ba7b8149dad11d180b400c04fd430c8'. NAMESPACE_X500 is a version-1 UUID for X.500 DN namespacing. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.version == 1. All four RFC 4122 namespace UUIDs are version 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__name__ == '__str__'. UUID.__str__ is a Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'. Qualname carries class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The four RFC 4122 namespace UUIDs (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) are pre-defined UUIDs used as namespace seeds for uuid3() and uuid5() name-based UUID generation. Each is a version-1 UUID whose byte values are specified in RFC 4122 Appendix C."
    - "Note: NAMESPACE_DNS hex '6ba7b810...' corresponds to str '6ba7b810-9dad-11d1-80b4-00c04fd430c8'. NAMESPACE_URL differs by one digit in position 8 (hex digit 1 vs 0). NAMESPACE_OID differs by 2 (hex digit 2). NAMESPACE_X500 differs by 4 (hex digit 4)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8')
# uuid.NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8')
# uuid.NAMESPACE_OID.hex.__eq__('6ba7b8129dad11d180b400c04fd430c8')
# uuid.NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8')
#
# Wave 247 theme: uuid NAMESPACE constant hex values.
#
# The four RFC 4122 predefined namespace UUIDs are version-1 UUIDs whose
# 128-bit integer values are specified in RFC 4122 Appendix C. The .hex
# property returns the UUID as a 32-character lowercase hexadecimal string
# without hyphens. NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, and
# NAMESPACE_X500 differ only in a single nibble of the time_low field.
# These constants are used as the namespace seed for uuid3() (MD5) and
# uuid5() (SHA-1) name-based UUID generation.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra247.NAMESPACE_hex_values:
  description: "uuid NAMESPACE constant .hex values — NAMESPACE_DNS/URL/OID/X500 hex values match RFC 4122 Appendix C — .hex returns 32-char lowercase hex without hyphens; the four namespace UUIDs are version-1 constants used as seeds for uuid3()/uuid5() name-based generation; wave 247 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns247a

  columns: [id, function, args, expected, description]
  rows:
    - [dns_hex,   NAMESPACE_DNS.hex.__eq__,   ["6ba7b8109dad11d180b400c04fd430c8"], true, "uuid.NAMESPACE_DNS.hex == '6ba7b8109dad11d180b400c04fd430c8'; RFC 4122 DNS namespace UUID hex"]
    - [url_hex,   NAMESPACE_URL.hex.__eq__,   ["6ba7b8119dad11d180b400c04fd430c8"], true, "uuid.NAMESPACE_URL.hex == '6ba7b8119dad11d180b400c04fd430c8'; RFC 4122 URL namespace UUID hex"]
    - [oid_hex,   NAMESPACE_OID.hex.__eq__,   ["6ba7b8129dad11d180b400c04fd430c8"], true, "uuid.NAMESPACE_OID.hex == '6ba7b8129dad11d180b400c04fd430c8'; RFC 4122 OID namespace UUID hex"]
    - [x500_hex,  NAMESPACE_X500.hex.__eq__,  ["6ba7b8149dad11d180b400c04fd430c8"], true, "uuid.NAMESPACE_X500.hex == '6ba7b8149dad11d180b400c04fd430c8'; RFC 4122 X.500 namespace UUID hex"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version.__eq__(1)
# uuid.NAMESPACE_URL.version.__eq__(1)
# uuid.NAMESPACE_OID.version.__eq__(1)
# uuid.NAMESPACE_X500.version.__eq__(1)
#
# Wave 247 theme: uuid NAMESPACE constant version identity.
#
# All four RFC 4122 predefined namespace UUIDs have version == 1. UUID version
# is encoded in bits 12-15 of the time_hi_and_version field (nibble 13 of the
# 32-char hex string). For version 1, that nibble is '1'. The .version property
# on a UUID object returns the integer version number (1-5 for standard UUIDs).
# Version 1 UUIDs are time-based. The namespace UUIDs were originally generated
# as version-1 UUIDs and are now fixed constants in RFC 4122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra247.NAMESPACE_version_identity:
  description: "uuid NAMESPACE constant .version values — NAMESPACE_DNS/URL/OID/X500 all have .version == 1 — version is encoded in bits 12-15 of time_hi_and_version field; version 1 is time-based; namespace UUIDs were originally generated as version-1 and are now fixed RFC 4122 Appendix C constants; used as seeds for uuid3()/uuid5(); wave 247 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidns247b

  columns: [id, function, args, expected, description]
  rows:
    - [dns_version,   NAMESPACE_DNS.version.__eq__,   [1], true, "uuid.NAMESPACE_DNS.version == 1; time-based version-1 UUID from RFC 4122 Appendix C"]
    - [url_version,   NAMESPACE_URL.version.__eq__,   [1], true, "uuid.NAMESPACE_URL.version == 1; time-based version-1 UUID from RFC 4122 Appendix C"]
    - [oid_version,   NAMESPACE_OID.version.__eq__,   [1], true, "uuid.NAMESPACE_OID.version == 1; time-based version-1 UUID from RFC 4122 Appendix C"]
    - [x500_version,  NAMESPACE_X500.version.__eq__,  [1], true, "uuid.NAMESPACE_X500.version == 1; time-based version-1 UUID from RFC 4122 Appendix C"]

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__name__.__eq__('__str__')
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__')
#
# Wave 247 theme: uuid.UUID.__str__ method identity.
#
# UUID.__str__ is a Python function defined in Lib/uuid.py. It returns the
# canonical hyphenated form of the UUID: 8-4-4-4-12 hexadecimal digits
# separated by hyphens (e.g., '6ba7b810-9dad-11d1-80b4-00c04fd430c8').
# __str__.__name__ == '__str__' (bare dunder name) and __qualname__ ==
# 'UUID.__str__' (class-prefixed, confirming defined in the UUID class body).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra247.UUID_str_method_identity:
  description: "uuid.UUID.__str__ method __name__ and __qualname__ identity — UUID.__str__.__name__=='__str__' and UUID.__str__.__qualname__=='UUID.__str__' — UUID.__str__ returns canonical 8-4-4-4-12 hyphenated hex form; Python function in Lib/uuid.py; __qualname__ carries class prefix; wave 247 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidstr247

  columns: [id, function, args, expected, description]
  rows:
    - [str_name,      UUID.__str__.__name__.__eq__,      ["__str__"],      true, "uuid.UUID.__str__.__name__ == '__str__'; bare dunder name without class prefix"]
    - [str_qualname,  UUID.__str__.__qualname__.__eq__,  ["UUID.__str__"], true, "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'; class-prefixed qualname confirms defined in UUID body"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8') — standalone
#
# uuid.NAMESPACE_DNS.hex is '6ba7b8109dad11d180b400c04fd430c8'. NAMESPACE_DNS
# is the predefined RFC 4122 namespace UUID for the DNS namespace. It is used
# as the namespace seed when generating name-based UUIDs (uuid3 or uuid5) for
# DNS host names: uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org'). The .hex
# property returns the UUID's 128 bits as a 32-character lowercase hexadecimal
# string with no hyphens, no braces, and no prefix. The value
# '6ba7b8109dad11d180b400c04fd430c8' is the canonical hex encoding of the
# NAMESPACE_DNS constant as specified in RFC 4122 Appendix C.
# This is the first standalone anchor for NAMESPACE_DNS.hex under uuidns247a.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra247.NAMESPACE_DNS_hex:
  description: "uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8') == True — NAMESPACE_DNS is the RFC 4122 DNS namespace seed UUID used in uuid.uuid5(NAMESPACE_DNS, 'python.org'); .hex returns 32-char lowercase hex without hyphens; value '6ba7b8109dad11d180b400c04fd430c8' is canonical per RFC 4122 Appendix C; first standalone for NAMESPACE_DNS.hex under uuidns247a; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.hex.__eq__
  args: ["6ba7b8109dad11d180b400c04fd430c8"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8') — standalone
#
# uuid.NAMESPACE_URL.hex is '6ba7b8119dad11d180b400c04fd430c8'. NAMESPACE_URL
# is the predefined RFC 4122 namespace UUID for the URL namespace. It is used
# as the seed when generating name-based UUIDs for URLs:
# uuid.uuid5(uuid.NAMESPACE_URL, 'https://example.com'). NAMESPACE_URL differs
# from NAMESPACE_DNS only in the 8th hexadecimal digit (position index 7):
# '0' for DNS vs '1' for URL. Both are version-1 UUIDs from RFC 4122 Appendix C.
# This is the first standalone anchor for NAMESPACE_URL.hex under uuidns247a.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra247.NAMESPACE_URL_hex:
  description: "uuid.NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8') == True — NAMESPACE_URL is the RFC 4122 URL namespace seed UUID used in uuid.uuid5(NAMESPACE_URL, 'https://example.com'); differs from NAMESPACE_DNS only at hex digit index 7 ('1' vs '0'); value '6ba7b8119dad11d180b400c04fd430c8' is canonical per RFC 4122 Appendix C; first standalone for NAMESPACE_URL.hex under uuidns247a; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_URL.hex.__eq__
  args: ["6ba7b8119dad11d180b400c04fd430c8"]
  expected: true
