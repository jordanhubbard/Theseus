# ---------------------------------------------------------------------------
# Standalone invariants — extra93
# ---------------------------------------------------------------------------

invariant asyncio_extra93.Task_module_is_asyncio_c_ext:
  description: "asyncio.Task.__module__.__eq__('_asyncio') returns True — Task is implemented as a C extension type in Modules/_asyncio.c (not a pure-Python class in Lib/asyncio/tasks.py); its __module__ reflects the C extension module _asyncio, not the asyncio package; this contrasts with TaskGroup and Runner which are pure-Python; NEW in extra93: first standalone __module__ invariant for Task in asynciotaskfuture93 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra93.Task_base_is_Future:
  description: "asyncio.Task.__bases__[0].__name__.__eq__('Future') returns True — Task directly inherits from Future (both are C extension types in _asyncio); Task.__mro__ is [Task, Future, object] giving mro length 3; the inheritance confirms that every Task is also a Future; NEW in extra93: first standalone __bases__ invariant for Task in asynciotaskfuture93 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra93.Future_module_is_asyncio_c_ext:
  description: "asyncio.Future.__module__.__eq__('_asyncio') returns True — Future is implemented as a C extension type in Modules/_asyncio.c; its __module__ is '_asyncio', not 'asyncio.futures'; this is the case even though there is a pure-Python fallback in Lib/asyncio/futures.py; NEW in extra93: first standalone __module__ invariant for Future in asynciotaskfuture93 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra93.TaskGroup_module_is_asyncio_taskgroups:
  description: "asyncio.TaskGroup.__module__.__eq__('asyncio.taskgroups') returns True — TaskGroup is a pure-Python class defined in Lib/asyncio/taskgroups.py; it was added in Python 3.11 as a structured concurrency primitive; its __module__ is 'asyncio.taskgroups', not '_asyncio'; NEW in extra93: first standalone __module__ invariant for TaskGroup in asynciotaskfuture93 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TaskGroup.__module__.__eq__
  args: ["asyncio.taskgroups"]
  expected: true

invariant asyncio_extra93.Runner_module_is_asyncio_runners:
  description: "asyncio.Runner.__module__.__eq__('asyncio.runners') returns True — Runner is a pure-Python class defined in Lib/asyncio/runners.py; it was added in Python 3.11 as a convenience class for running asyncio code from synchronous contexts; its __module__ is 'asyncio.runners', not '_asyncio'; NEW in extra93: first standalone __module__ invariant for Runner in asynciotaskfuture93 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Runner.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true
