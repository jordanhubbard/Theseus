spec: asyncio_extra93
version: ">=3.11"
backend: python_module(asyncio)
extends: asyncio_extra92

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asyncio.c"
    - "CPython source: Lib/asyncio/taskgroups.py"
    - "CPython source: Lib/asyncio/runners.py"
  notes:
    - "This spec extends asyncio_extra92.zspec.zsdl."
    - "This spec covers: wave 253 theme — asyncio Task and Future class identity (__module__, __bases__[0].__name__, __mro__.__len__()), TaskGroup identity, Runner identity. NEW in extra93: asyncio.Task.__module__=='_asyncio' (C extension type from Modules/_asyncio.c); asyncio.Task.__bases__[0].__name__=='Future'; asyncio.Task.__mro__.__len__()==3; asyncio.Future.__module__=='_asyncio' (C extension type); asyncio.Future.__bases__[0].__name__=='object'; asyncio.Future.__mro__.__len__()==2; asyncio.TaskGroup.__module__=='asyncio.taskgroups'; asyncio.TaskGroup.__bases__[0].__name__=='object'; asyncio.TaskGroup.__mro__.__len__()==2; asyncio.Runner.__module__=='asyncio.runners'; asyncio.Runner.__bases__[0].__name__=='object'; asyncio.Runner.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__module__ == '_asyncio'. Task is a C extension type defined in Modules/_asyncio.c, not a pure-Python class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__bases__[0].__name__ == 'Future'. Task inherits from Future (both C extension types in _asyncio). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__mro__.__len__() == 3. MRO is [Task, Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__module__ == '_asyncio'. Future is a C extension type defined in Modules/_asyncio.c. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__bases__[0].__name__ == 'object'. Future directly inherits from object (no intermediate base). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__mro__.__len__() == 2. MRO is [Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups'. TaskGroup is a pure-Python class added in Python 3.11. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__bases__[0].__name__ == 'object'. TaskGroup inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__mro__.__len__() == 2. MRO is [TaskGroup, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Runner.__module__ == 'asyncio.runners'. Runner is a pure-Python class added in Python 3.11. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Runner.__bases__[0].__name__ == 'object'. Runner inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Runner.__mro__.__len__() == 2. MRO is [Runner, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task class identity — extra93
#
# Wave 253 theme: asyncio Task and Future class identity.
#
# Task.__module__ == '_asyncio'  (C extension type)
# Task.__bases__[0].__name__ == 'Future'
# Task.__mro__.__len__() == 3
# Task.__name__ == 'Task'
# Task.__qualname__ == 'Task'
# ---------------------------------------------------------------------------

table asyncio_extra93.Task_class_identity:
  description: "asyncio Task class identity checks in asynciotaskfuture93 namespace — wave 253 theme: asyncio Task and Future class identity; Task.__module__.__eq__('_asyncio')==True (Task is a C extension type from Modules/_asyncio.c, not a pure-Python class); Task.__bases__[0].__name__.__eq__('Future')==True (Task inherits from Future); Task.__mro__.__len__()==3 (MRO is [Task, Future, object]); Task.__name__.__eq__('Task')==True; Task.__qualname__.__eq__('Task')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotaskfuture93

  columns: [id, function, args, expected, description]
  rows:
    - [task_module,         Task.__module__.__eq__,                    ["_asyncio"], true, "Task.__module__ == '_asyncio' — Task is a C extension type; verified with Python 3.14.3"]
    - [task_bases0_name,    "Task.__bases__[0].__name__.__eq__",       ["Future"],   true, "Task.__bases__[0].__name__ == 'Future' — Task inherits from Future; verified with Python 3.14.3"]
    - [task_mro_len,        Task.__mro__.__len__,                      [],           3,    "Task.__mro__.__len__() == 3 — MRO is [Task, Future, object]; verified with Python 3.14.3"]
    - [task_name,           Task.__name__.__eq__,                      ["Task"],     true, "Task.__name__ == 'Task' — class name; verified with Python 3.14.3"]
    - [task_qualname,       Task.__qualname__.__eq__,                  ["Task"],     true, "Task.__qualname__ == 'Task' — qualified name; verified with Python 3.14.3"]

