table concurrent_futures_extra193.cf_BrokenThreadPool_identity:
  description: "concurrent.futures.thread.BrokenThreadPool identity checks in cfexceptions2193 namespace — BrokenThreadPool.__name__=='BrokenThreadPool' (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16; raised when a worker thread in a ThreadPoolExecutor terminates abnormally, rendering the pool unusable); BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25; defined in the thread submodule); BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor' (len=14; same base class as BrokenProcessPool — both inherit from BrokenExecutor); BrokenThreadPool.__name__ (16) < BrokenProcessPool.__name__ (17) by 1; BrokenThreadPool.__module__ (25) < BrokenProcessPool.__module__ (26) by 1; verified with Python 3.14.3"
  kind: python_call_eq
  category: BrokenThreadPool
  id_prefix: cfexceptions2193

  columns: [id, function, args, expected, description]
  rows:
    - [btp_name_eq,    concurrent.futures.thread.BrokenThreadPool.__name__.__eq__,                ["BrokenThreadPool"],            true, "concurrent.futures.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16; raised on abnormal worker thread termination); verified Python 3.14.3"]
    - [btp_name_len,   concurrent.futures.thread.BrokenThreadPool.__name__.__len__,               [],                              16,   "concurrent.futures.thread.BrokenThreadPool.__name__.__len__() == 16 ('BrokenThreadPool'=16: 'Broken'=6+'Thread'=6+'Pool'=4=16); verified Python 3.14.3"]
    - [btp_module_eq,  concurrent.futures.thread.BrokenThreadPool.__module__.__eq__,              ["concurrent.futures.thread"],   true, "concurrent.futures.thread.BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25); verified Python 3.14.3"]
    - [btp_module_len, concurrent.futures.thread.BrokenThreadPool.__module__.__len__,             [],                              25,   "concurrent.futures.thread.BrokenThreadPool.__module__.__len__() == 25 ('concurrent.futures.thread'=25); verified Python 3.14.3"]
    - ["btp_base_eq",  "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],              true, "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor' (len=14; same base as BrokenProcessPool); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra193
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra193.cf_InvalidStateError_name_eq:
  description: "concurrent.futures.InvalidStateError.__name__.__eq__('InvalidStateError') returns True — InvalidStateError.__name__=='InvalidStateError' (len=17: 'Invalid'=7+'State'=5+'Error'=5=17); raised when a Future method is invoked in an invalid state, e.g. calling set_result() on a Future that already has a result, or calling result() on a Future that was cancelled; InvalidStateError.__name__ (17) == BrokenProcessPool.__name__ (17) — coincidentally identical lengths; InvalidStateError.__name__ (17) > BrokenThreadPool.__name__ (16) by 1; NEW in cfexceptions2193: first standalone InvalidStateError.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: InvalidStateError
  kind: python_call_eq
  function: concurrent.futures.InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra193.cf_InvalidStateError_module_eq:
  description: "concurrent.futures.InvalidStateError.__module__.__eq__('concurrent.futures._base') returns True — InvalidStateError.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24); the _base submodule holds the core Future, Executor, and base exception class implementations; the leading underscore marks it as a private implementation detail; InvalidStateError.__module__ (24) < BrokenProcessPool.__module__ (26) by 2; InvalidStateError.__module__ (24) < BrokenThreadPool.__module__ (25) by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: InvalidStateError
  kind: python_call_eq
  function: concurrent.futures.InvalidStateError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra193.cf_InvalidStateError_base_eq:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__('Error') returns True — InvalidStateError.__bases__[0].__name__=='Error' (len=5: E(1)r(2)r(3)o(4)r(5)); concurrent.futures.Error is the base exception for all errors in the concurrent.futures package; it allows callers to catch all concurrent.futures exceptions with a single except clause; InvalidStateError.__bases__[0].__name__ (5: 'Error') < BrokenProcessPool.__bases__[0].__name__ (14: 'BrokenExecutor') by 9; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: InvalidStateError
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra193.cf_BrokenProcessPool_name_eq:
  description: "concurrent.futures.process.BrokenProcessPool.__name__.__eq__('BrokenProcessPool') returns True — BrokenProcessPool.__name__=='BrokenProcessPool' (len=17: 'Broken'=6+'Process'=7+'Pool'=4=17); BrokenProcessPool is raised when a worker process in a ProcessPoolExecutor terminates abnormally (e.g. via SIGKILL or a segfault), leaving the pool in an unusable broken state; subsequent submissions raise BrokenProcessPool; BrokenProcessPool.__name__ (17) == InvalidStateError.__name__ (17) — coincidentally the same length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: BrokenProcessPool
  kind: python_call_eq
  function: concurrent.futures.process.BrokenProcessPool.__name__.__eq__
  args: ["BrokenProcessPool"]
  expected: true

invariant concurrent_futures_extra193.cf_BrokenProcessPool_module_eq:
  description: "concurrent.futures.process.BrokenProcessPool.__module__.__eq__('concurrent.futures.process') returns True — BrokenProcessPool.__module__=='concurrent.futures.process' (len=26: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26); BrokenProcessPool is defined in Lib/concurrent/futures/process.py alongside ProcessPoolExecutor; BrokenProcessPool.__module__ (26) > BrokenThreadPool.__module__ (25) by 1 — 'process' (7) is one character longer than 'thread' (6); BrokenProcessPool.__module__ (26) > InvalidStateError.__module__ (24) by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: BrokenProcessPool
  kind: python_call_eq
  function: concurrent.futures.process.BrokenProcessPool.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra193.cf_BrokenProcessPool_base_eq:
  description: "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor') returns True — BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor' (len=14: 'Broken'=6+'Executor'=8=14); BrokenExecutor is the shared base for both BrokenProcessPool and BrokenThreadPool; it in turn inherits from concurrent.futures.Error; BrokenProcessPool.__bases__[0].__name__ (14: 'BrokenExecutor') == BrokenThreadPool.__bases__[0].__name__ (14: 'BrokenExecutor') — both broken-pool exceptions share the same immediate base class; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: BrokenProcessPool
  kind: python_call_eq
  function: "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra193.cf_BrokenThreadPool_name_eq:
  description: "concurrent.futures.thread.BrokenThreadPool.__name__.__eq__('BrokenThreadPool') returns True — BrokenThreadPool.__name__=='BrokenThreadPool' (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16); BrokenThreadPool is raised when a worker thread in a ThreadPoolExecutor terminates abnormally, leaving the pool in a broken state; BrokenThreadPool.__name__ (16) < BrokenProcessPool.__name__ (17) by 1 — 'Thread' (6) is one character shorter than 'Process' (7); BrokenThreadPool.__name__ (16) < InvalidStateError.__name__ (17) by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: BrokenThreadPool
  kind: python_call_eq
  function: concurrent.futures.thread.BrokenThreadPool.__name__.__eq__
  args: ["BrokenThreadPool"]
  expected: true

invariant concurrent_futures_extra193.cf_BrokenThreadPool_module_eq:
  description: "concurrent.futures.thread.BrokenThreadPool.__module__.__eq__('concurrent.futures.thread') returns True — BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25); BrokenThreadPool is defined in Lib/concurrent/futures/thread.py alongside ThreadPoolExecutor; BrokenThreadPool.__module__ (25) < BrokenProcessPool.__module__ (26) by 1 — 'thread' (6) is one character shorter than 'process' (7); NEW in cfexceptions2193: completing 8-invariant coverage for concurrent.futures exception identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: BrokenThreadPool
  kind: python_call_eq
  function: concurrent.futures.thread.BrokenThreadPool.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true
