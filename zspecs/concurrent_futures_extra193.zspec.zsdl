table concurrent_futures_extra193.cf_BrokenProcessPool_identity:
  description: "concurrent.futures.process.BrokenProcessPool identity checks in cfexceptions2193 namespace — BrokenProcessPool.__name__=='BrokenProcessPool' (len=17: 'Broken'=6+'Process'=7+'Pool'=4=17; raised when a worker process in a ProcessPoolExecutor terminates abnormally, rendering the pool unusable); BrokenProcessPool.__module__=='concurrent.futures.process' (len=26: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26; defined in the process submodule); BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor' (len=14; inherits from concurrent.futures.BrokenExecutor, the base for broken pool errors); BrokenProcessPool.__module__ (26) > InvalidStateError.__module__ (24) by 2; verified with Python 3.14.3"
  kind: python_call_eq
  category: BrokenProcessPool
  id_prefix: cfexceptions2193

  columns: [id, function, args, expected, description]
  rows:
    - [bpp_name_eq,    concurrent.futures.process.BrokenProcessPool.__name__.__eq__,                ["BrokenProcessPool"],              true, "concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17; raised on abnormal worker process termination); verified Python 3.14.3"]
    - [bpp_name_len,   concurrent.futures.process.BrokenProcessPool.__name__.__len__,               [],                                 17,   "concurrent.futures.process.BrokenProcessPool.__name__.__len__() == 17 ('BrokenProcessPool'=17: 'Broken'=6+'Process'=7+'Pool'=4=17); verified Python 3.14.3"]
    - [bpp_module_eq,  concurrent.futures.process.BrokenProcessPool.__module__.__eq__,              ["concurrent.futures.process"],     true, "concurrent.futures.process.BrokenProcessPool.__module__ == 'concurrent.futures.process' (len=26); verified Python 3.14.3"]
    - [bpp_module_len, concurrent.futures.process.BrokenProcessPool.__module__.__len__,             [],                                 26,   "concurrent.futures.process.BrokenProcessPool.__module__.__len__() == 26 ('concurrent.futures.process'=26); verified Python 3.14.3"]
    - ["bpp_base_eq",  "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],                 true, "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor' (len=14; inherits from BrokenExecutor base class); verified Python 3.14.3"]

