spec: concurrent_futures_extra193
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' (len=17); raised when an operation is performed on a Future in an invalid state."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base' (len=24); defined in the private _base submodule."
    - "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error' (len=5); inherits from concurrent.futures.Error."
    - "concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17); raised when a worker process in a ProcessPoolExecutor terminates abnormally."
    - "concurrent.futures.process.BrokenProcessPool.__module__ == 'concurrent.futures.process' (len=26); defined in the process submodule."
    - "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor' (len=14); inherits from concurrent.futures.BrokenExecutor."
    - "concurrent.futures.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16); raised when a worker thread in a ThreadPoolExecutor terminates abnormally."
    - "concurrent.futures.thread.BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25); defined in the thread submodule."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.InvalidStateError identity
#
# InvalidStateError.__name__ == 'InvalidStateError' (len=17)
# InvalidStateError.__module__ == 'concurrent.futures._base' (len=24)
# InvalidStateError.__bases__[0].__name__ == 'Error' (len=5)
# ---------------------------------------------------------------------------

table concurrent_futures_extra193.cf_InvalidStateError_identity:
  description: "concurrent.futures.InvalidStateError identity checks in cfexceptions2193 namespace — InvalidStateError.__name__=='InvalidStateError' (len=17: 'Invalid'=7+'State'=5+'Error'=5=17; raised when a Future method is called in an invalid state, e.g. set_result() on an already-finished Future); InvalidStateError.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; defined in the private _base implementation submodule); InvalidStateError.__bases__[0].__name__=='Error' (len=5; inherits from concurrent.futures.Error, the base exception for all concurrent.futures errors); InvalidStateError.__name__ (17) == BrokenProcessPool.__name__ (17) — coincidentally the same length; verified with Python 3.14.3"
  kind: python_call_eq
  category: InvalidStateError
  id_prefix: cfexceptions2193

  columns: [id, function, args, expected, description]
  rows:
    - [ise_name_eq,    concurrent.futures.InvalidStateError.__name__.__eq__,                   ["InvalidStateError"],          true, "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' (len=17; raised for invalid Future state operations); verified Python 3.14.3"]
    - [ise_name_len,   concurrent.futures.InvalidStateError.__name__.__len__,                  [],                             17,   "concurrent.futures.InvalidStateError.__name__.__len__() == 17 ('InvalidStateError'=17: 'Invalid'=7+'State'=5+'Error'=5=17); verified Python 3.14.3"]
    - [ise_module_eq,  concurrent.futures.InvalidStateError.__module__.__eq__,                 ["concurrent.futures._base"],   true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base' (len=24; defined in the private _base submodule); verified Python 3.14.3"]
    - [ise_module_len, concurrent.futures.InvalidStateError.__module__.__len__,                [],                             24,   "concurrent.futures.InvalidStateError.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified Python 3.14.3"]
    - ["ise_base_eq",  "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__",    ["Error"],                      true, "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error' (len=5; inherits from concurrent.futures.Error); verified Python 3.14.3"]

