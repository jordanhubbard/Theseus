spec: object_pick
version: ">=0.1.1"
backend: node(object-pick)

docs: https://www.npmjs.com/package/object-pick

provenance:
  derived_from:
    - "object-pick README — https://www.npmjs.com/package/object-pick"
    - "Test vectors verified with object-pick via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-pick source"
  notes:
    - "object-pick is an npm package. Install: npm install object-pick"
    - "Returns a new object with only the specified keys from the source object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new object containing only the picked keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_pick.pick:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: objpick

  columns: [id, args, expected]
  rows:
    - [two_keys, [{"a": 1, "b": 2, "c": 3}, ["a", "c"]], {"a": 1, "c": 3}]
    - [one_key,  [{"x": 10, "y": 20}, ["x"]],             {"x": 10}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:14:23Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
