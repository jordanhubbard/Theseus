  columns: [id, function, args, expected]
  rows:
    - ["dc3001013", operator.contains, [decimal.Decimal.__dict__,          "__delitem__"], false]
    - ["dc3001014", operator.contains, [decimal.Context.__dict__,          "__delitem__"], false]
    - ["dc3001015", operator.contains, [decimal.DecimalException.__dict__, "__delitem__"], false]
    - ["dc3001016", operator.contains, [decimal.FloatOperation.__dict__,   "__delitem__"], false]
    - ["dc3001017", operator.contains, [decimal.Clamped.__dict__,          "__delitem__"], false]
    - ["dc3001018", operator.contains, [decimal.Overflow.__dict__,         "__delitem__"], false]

