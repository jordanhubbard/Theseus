  rows:
    - ["dc3001007", operator.contains, [decimal.Decimal.__dict__,          "__setitem__"], false]
    - ["dc3001008", operator.contains, [decimal.Context.__dict__,          "__setitem__"], false]
    - ["dc3001009", operator.contains, [decimal.Underflow.__dict__,        "__setitem__"], false]
    - ["dc3001010", operator.contains, [decimal.Inexact.__dict__,          "__setitem__"], false]
    - ["dc3001011", operator.contains, [decimal.Rounded.__dict__,          "__setitem__"], false]
    - ["dc3001012", operator.contains, [decimal.Subnormal.__dict__,        "__setitem__"], false]

# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# decimal types do not support subscript deletion; none define __delitem__; all false.
# ---------------------------------------------------------------------------

table dc3001.delitem:
  description: "decimal types __delitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
