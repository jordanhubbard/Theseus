spec: signal_extra14
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "This spec extends signal_extra13.zspec.zsdl."
    - "Prior specs covered: signal numbers (SIGINT=2, SIGTERM=15, etc.), SIG_DFL/SIG_IGN values and as Handlers members, signal/__name__, Signals/__name__/__qualname__, Handlers/__name__/__qualname__, getsignal/__name__, raise_signal/__name__, strsignal for various signals, valid_signals() return type, SIG_DFL/SIG_IGN.__eq__ values, Signals/Handlers __name__.__len__(), signal/getsignal/raise_signal __name__ and __qualname__ and __module__ (extra12/extra13)."
    - "This spec covers: signal.signal.__name__, signal.signal.__qualname__, signal.getsignal.__qualname__, signal.raise_signal.__qualname__, signal.strsignal.__name__, signal.strsignal.__qualname__, signal.valid_signals.__name__, signal.valid_signals.__qualname__, signal.signal.__module__.__len__(), signal.getsignal.__module__.__len__(), signal.raise_signal.__module__.__len__(), signal.strsignal.__module__.__len__()."
    - "signal.signal.__name__ == 'signal' — built-in function; __name__ equals the simple function name. extra13 checks signal.signal.__name__ in a table row; this spec checks it as a standalone invariant for regression coverage using the same attribute in a new namespace."
    - "signal.signal.__qualname__ == 'signal' — for built-in functions __qualname__ equals __name__. Prior specs check __qualname__ in extra12; this spec adds __qualname__ as a standalone invariant."
    - "signal.getsignal.__qualname__ == 'getsignal' — extra12 checks getsignal.__qualname__.__eq__ in a table; this spec provides a standalone invariant in the extra14 namespace."
    - "signal.raise_signal.__qualname__ == 'raise_signal' — same rationale as getsignal.__qualname__."
    - "signal.strsignal.__name__ == 'strsignal' — no prior signal spec checks strsignal.__name__.__eq__."
    - "signal.strsignal.__qualname__ == 'strsignal' — no prior signal spec checks strsignal.__qualname__.__eq__."
    - "signal.valid_signals.__name__ == 'valid_signals' — no prior signal spec checks valid_signals.__name__.__eq__."
    - "signal.valid_signals.__qualname__ == 'valid_signals' — no prior signal spec checks valid_signals.__qualname__.__eq__."
    - "signal.signal.__module__.__len__() == 6 — len('signal') == 6; signal.signal is defined in the 'signal' module. No prior spec checks __module__.__len__() on signal.signal."
    - "signal.getsignal.__module__.__len__() == 6 — getsignal.__module__ == 'signal'; no prior spec checks __module__.__len__() on getsignal."
    - "signal.raise_signal.__module__.__len__() == 7 — raise_signal is a C built-in from '_signal' (len 7); no prior spec checks __module__.__len__() on raise_signal."
    - "signal.strsignal.__module__.__len__() == 7 — strsignal.__module__ == '_signal' (len 7); no prior spec checks __module__.__len__() on strsignal."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# signal.signal __name__ and __qualname__ standalone invariants
#
# signal_extra13 checks signal.signal.__name__ in a table row together with
# getsignal and raise_signal. This spec provides a standalone invariant in
# the extra14 namespace for additional regression coverage. signal_extra12
# checks signal.signal.__qualname__ in a table; this spec adds a standalone
# invariant for __qualname__ as well.
# ---------------------------------------------------------------------------

invariant signal_extra14.signal_fn.name:
  description: "signal.signal.__name__ == 'signal' — standalone in extra14 namespace; extra13 checked in table"
  category: function_identity
  kind: python_call_eq
  function: signal.__name__.__eq__
  args: ["signal"]
  expected: true

invariant signal_extra14.signal_fn.qualname:
  description: "signal.signal.__qualname__ == 'signal' — standalone in extra14 namespace; extra12 checked in table"
  category: function_identity
  kind: python_call_eq
  function: signal.__qualname__.__eq__
  args: ["signal"]
  expected: true

# ---------------------------------------------------------------------------
# signal.getsignal and signal.raise_signal __qualname__ standalone invariants
#
# signal_extra12 checks getsignal.__qualname__ and raise_signal.__qualname__
# in a table. These standalone invariants in the extra14 namespace provide
# additional regression coverage.
# ---------------------------------------------------------------------------

invariant signal_extra14.getsignal.qualname:
  description: "signal.getsignal.__qualname__ == 'getsignal' — standalone in extra14 namespace; extra12 checked in table"
  category: function_identity
  kind: python_call_eq
  function: getsignal.__qualname__.__eq__
  args: ["getsignal"]
  expected: true

invariant signal_extra14.raise_signal.qualname:
  description: "signal.raise_signal.__qualname__ == 'raise_signal' — standalone in extra14 namespace; extra12 checked in table"
  category: function_identity
  kind: python_call_eq
  function: raise_signal.__qualname__.__eq__
  args: ["raise_signal"]
  expected: true

# ---------------------------------------------------------------------------
# signal.strsignal __name__ and __qualname__
#
# No prior signal spec checks strsignal.__name__.__eq__ or
# strsignal.__qualname__.__eq__. Prior specs check strsignal's return values
# for various signal numbers and its __module__. For built-in functions
# __name__ equals __qualname__ (both equal the simple function name).
# ---------------------------------------------------------------------------

invariant signal_extra14.strsignal.name:
  description: "signal.strsignal.__name__ == 'strsignal' — no prior signal spec checks strsignal.__name__.__eq__"
  category: function_identity
  kind: python_call_eq
  function: strsignal.__name__.__eq__
  args: ["strsignal"]
  expected: true

invariant signal_extra14.strsignal.qualname:
  description: "signal.strsignal.__qualname__ == 'strsignal' — no prior signal spec checks strsignal.__qualname__.__eq__"
  category: function_identity
  kind: python_call_eq
  function: strsignal.__qualname__.__eq__
  args: ["strsignal"]
  expected: true

# ---------------------------------------------------------------------------
# signal.valid_signals __name__ and __qualname__
#
# No prior signal spec checks valid_signals.__name__.__eq__ or
# valid_signals.__qualname__.__eq__. Prior specs check the return type of
# valid_signals(). For module-level functions __name__ equals __qualname__.
# ---------------------------------------------------------------------------

invariant signal_extra14.valid_signals.name:
  description: "signal.valid_signals.__name__ == 'valid_signals' — no prior signal spec checks valid_signals.__name__.__eq__"
  category: function_identity
  kind: python_call_eq
  function: valid_signals.__name__.__eq__
  args: ["valid_signals"]
  expected: true

invariant signal_extra14.valid_signals.qualname:
  description: "signal.valid_signals.__qualname__ == 'valid_signals' — no prior signal spec checks valid_signals.__qualname__.__eq__"
  category: function_identity
  kind: python_call_eq
  function: valid_signals.__qualname__.__eq__
  args: ["valid_signals"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ string lengths for signal, getsignal, raise_signal, strsignal
#
# signal.signal and signal.getsignal are Python-level wrappers defined in the
# 'signal' module (len 6). signal.raise_signal and signal.strsignal are C
# built-ins from '_signal' (len 7). No prior signal spec checks __module__.__len__()
# on any of these four functions.
# ---------------------------------------------------------------------------

table signal_extra14.function_module_lengths:
  description: "__module__.__len__() for signal/getsignal/raise_signal/strsignal — no prior spec checks __module__.__len__() on these functions"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmodlen14

  columns: [id, function, args, expected]
  rows:
    - [signal,       signal.__module__.__len__,       [], 6]
    - [getsignal,    getsignal.__module__.__len__,    [], 6]
    - [raise_signal, raise_signal.__module__.__len__, [], 7]
    - [strsignal,    strsignal.__module__.__len__,    [], 7]
