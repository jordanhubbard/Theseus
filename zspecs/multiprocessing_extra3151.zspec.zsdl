    - ["mp3151022", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__contains__"], true]
    - ["mp3151023", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__contains__"], true]
    - ["mp3151024", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__contains__"], true]

# ---------------------------------------------------------------------------
# combined — __setitem__, __delitem__, __contains__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __setitem__:  true for BaseListProxy, _BaseDictProxy; false for all others.
# __delitem__:  true for BaseListProxy, _BaseDictProxy; false for all others.
# __contains__: true for BaseListProxy, _BaseDictProxy, _BaseSetProxy; false for others.
#
# The manager proxy classes exhibit the precise collection protocol of their
# underlying Python type:
#   BaseListProxy  (proxies list): __setitem__=true, __delitem__=true, __contains__=true
#   _BaseDictProxy (proxies dict): __setitem__=true, __delitem__=true, __contains__=true
#   _BaseSetProxy  (proxies set):  __setitem__=false, __delitem__=false, __contains__=true
#
# This is the clearest wave yet to distinguish the three proxy classes.
# _BaseSetProxy's pattern (__contains__=true, __setitem__/__delitem__=false)
# precisely captures the read-only membership semantics of Python sets —
# `x in s` works; `s[x]=v` and `del s[x]` do not. Set mutation goes through
# add()/discard()/remove() methods, which the proxy also forwards.
#
# Cross-wave pattern for manager proxies (selected highlights):
#   Wave 654 (mp3106): __lt__/__le__/__gt__ — _BaseSetProxy true (set ordering).
#   Wave 656 (mp3136): __len__ — all 3 proxies true; __getitem__ — list+dict true, set false.
#   Wave 657 (mp3151): __setitem__/__delitem__ — list+dict true, set false;
#                      __contains__ — all 3 proxies true.
#
# Cross-wave summary for all mp subjects:
#   Wave 652 (mp3076): __get__/__set__/__delete__ — all false for all 8.
#   Wave 653 (mp3091): __hash__/__eq__/__bool__ — all false for all 8.
#   Wave 654 (mp3106): __lt__/__le__/__gt__ — _BaseSetProxy true; others false.
#   Wave 655 (mp3121): __ge__ — _BaseSetProxy true; __repr__ — Pool true; __str__ all false.
#   Wave 656 (mp3136): __call__ all false; __len__ — 3 proxies true; __getitem__ — list+dict true.
#   Wave 657 (mp3151): __setitem__/__delitem__ — list+dict proxies true; __contains__ — all 3 proxies true.
# ---------------------------------------------------------------------------

