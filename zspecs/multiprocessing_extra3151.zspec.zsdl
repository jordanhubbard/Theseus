    - ["mp3151011", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__delitem__"], false]
    - ["mp3151012", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__delitem__"], false]
    - ["mp3151013", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__delitem__"], false]
    - ["mp3151014", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__delitem__"], true]
    - ["mp3151015", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__delitem__"], true]
    - ["mp3151016", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__delitem__"], false]

# ---------------------------------------------------------------------------
# __contains__ dict-presence — operator.contains(Cls.__dict__, '__contains__')
#
# multiprocessing.managers.BaseListProxy: TRUE — proxies `x in proxy_list`
#   to the managed list (linear membership search in the server process).
# multiprocessing.managers._BaseDictProxy: TRUE — proxies `k in proxy_dict`
#   (key membership test) to the managed dict in the server process.
# multiprocessing.managers._BaseSetProxy: TRUE — proxies `x in proxy_set`
#   (set membership test) to the managed set. Sets define __contains__
#   but NOT __setitem__ or __delitem__ — this matches Python's set semantics.
# All other 5 classes: false — no membership test defined.
# Note: _BaseSetProxy is the only proxy class that defines __contains__
#   but not __setitem__ — reflecting the fundamental asymmetry of Python sets.
# ---------------------------------------------------------------------------

