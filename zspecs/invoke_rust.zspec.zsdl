spec: invoke_rust
version: ">=3.9"
backend: rust_module(invoke_rust)

docs: https://www.pyinvoke.org/

provenance:
  derived_from:
    - "https://www.pyinvoke.org/ — Invoke documentation"
  not_derived_from:
    - "invoke source: invoke/__init__.py"
  notes:
    - "Invoke is a Python task execution tool."
    - "invoke.task is available as a decorator."
    - "invoke.Collection is available."
    - "invoke.__version__ is a non-empty string."
    - "invoke.Collection.__name__ == 'Collection'."
    - "Expose invoke_collection_name() -> str: invoke.Collection.__name__."
    - "Expose invoke_has_task() -> bool: hasattr(invoke, 'task')."
    - "Expose invoke_version_nonempty() -> bool: len(invoke.__version__) > 0."
    - "All test vectors verified against invoke 2.2.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# invoke_collection_name — Collection class name
invariant invoke_rust.collection.class_name:
  description: "invoke.Collection.__name__ == 'Collection'"
  category: collection
  kind: python_call_eq
  function: invoke_collection_name
  args: []
  expected: "Collection"

# invoke_has_task — task decorator present
invariant invoke_rust.module.has_task:
  description: "invoke.task is available"
  category: module
  kind: python_call_eq
  function: invoke_has_task
  args: []
  expected: true

# invoke_version_nonempty — version non-empty
invariant invoke_rust.version.nonempty:
  description: "invoke.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: invoke_version_nonempty
  args: []
  expected: true

