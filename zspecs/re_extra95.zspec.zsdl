spec: re_extra95
version: ">=3.9"
backend: python_module(re)
extends: re_extra94

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra94."
    - "This spec covers: re module top-level function __qualname__ string equality."
    - "re.compile.__qualname__ = 'compile' (len=7) — the qualname is just the plain function name."
    - "re.match.__qualname__ = 'match' (len=5) — the qualname is just the plain function name."
    - "re.fullmatch.__qualname__ = 'fullmatch' (len=9)."
    - "re.search.__qualname__ = 'search' (len=6)."
    - "re.sub.__qualname__ = 'sub' (len=3)."
    - "re.subn.__qualname__ = 'subn' (len=4)."
    - "re.split.__qualname__ = 'split' (len=5)."
    - "re.findall.__qualname__ = 'findall' (len=7)."
    - "re.finditer.__qualname__ = 'finditer' (len=8)."
    - "re.escape.__qualname__ = 'escape' (len=6)."
    - "re.purge.__qualname__ = 'purge' (len=5)."
    - "re.template is not present in Python 3.14 (was removed in 3.13)."
    - "All top-level function qualnames are the plain function names (not module-prefixed), as they are regular Python functions defined at module scope."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile / re.match / re.fullmatch / re.search __qualname__ equality
# All are plain Python functions; their __qualname__ is just the function name.
# compile=7, match=5, fullmatch=9, search=6.
# ---------------------------------------------------------------------------

table re_extra95.compile_match_fullmatch_search_qualname_eq:
  description: "re.compile, re.match, re.fullmatch, re.search __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: refnqualname95

  columns: [id, function, args, expected]
  rows:
    - [compile_qname_eq,   compile.__qualname__.__eq__,   ["compile"],   true]
    - [compile_qname_not,  compile.__qualname__.__eq__,   ["match"],     false]
    - [match_qname_eq,     match.__qualname__.__eq__,     ["match"],     true]
    - [fullmatch_qname_eq, fullmatch.__qualname__.__eq__,  ["fullmatch"], true]
    - [search_qname_eq,    search.__qualname__.__eq__,    ["search"],    true]

# ---------------------------------------------------------------------------
# re.sub / re.subn / re.split __qualname__ equality
# sub=3, subn=4, split=5.
# ---------------------------------------------------------------------------

table re_extra95.sub_subn_split_qualname_eq:
  description: "re.sub, re.subn, re.split __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: refnqualname95

  columns: [id, function, args, expected]
  rows:
    - [sub_qname_eq,   sub.__qualname__.__eq__,   ["sub"],   true]
    - [sub_qname_not,  sub.__qualname__.__eq__,   ["subn"],  false]
    - [subn_qname_eq,  subn.__qualname__.__eq__,  ["subn"],  true]
    - [split_qname_eq, split.__qualname__.__eq__, ["split"], true]

# ---------------------------------------------------------------------------
# re.findall / re.finditer / re.escape / re.purge __qualname__ equality
# findall=7, finditer=8, escape=6, purge=5.
# ---------------------------------------------------------------------------

table re_extra95.findall_finditer_escape_purge_qualname_eq:
  description: "re.findall, re.finditer, re.escape, re.purge __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: refnqualname95

  columns: [id, function, args, expected]
  rows:
    - [findall_qname_eq,  findall.__qualname__.__eq__,  ["findall"],  true]
    - [finditer_qname_eq, finditer.__qualname__.__eq__, ["finditer"], true]
    - [escape_qname_eq,   escape.__qualname__.__eq__,   ["escape"],   true]
    - [purge_qname_eq,    purge.__qualname__.__eq__,    ["purge"],    true]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for all re top-level functions
# compile=7, match=5, fullmatch=9, search=6, sub=3, subn=4, split=5,
# findall=7, finditer=8, escape=6, purge=5.
# ---------------------------------------------------------------------------

table re_extra95.all_funcs_qualname_len:
  description: "re top-level function __qualname__.__len__() values for all functions"
  kind: python_call_eq
  category: qualname
  id_prefix: refnqualname95

  columns: [id, function, args, expected]
  rows:
    - [compile_qlen,   compile.__qualname__.__len__,   [], 7]
    - [match_qlen,     match.__qualname__.__len__,     [], 5]
    - [fullmatch_qlen, fullmatch.__qualname__.__len__,  [], 9]
    - [search_qlen,    search.__qualname__.__len__,    [], 6]
    - [sub_qlen,       sub.__qualname__.__len__,       [], 3]
    - [subn_qlen,      subn.__qualname__.__len__,      [], 4]
    - [split_qlen,     split.__qualname__.__len__,     [], 5]
    - [findall_qlen,   findall.__qualname__.__len__,   [], 7]
    - [finditer_qlen,  finditer.__qualname__.__len__,  [], 8]
    - [escape_qlen,    escape.__qualname__.__len__,    [], 6]
    - [purge_qlen,     purge.__qualname__.__len__,     [], 5]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra95.compile.qualname_eq_compile:
  description: "re.compile.__qualname__ == 'compile' (the qualname is the plain function name, length 7)"
  category: qualname
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra95.fullmatch.qualname_eq_fullmatch:
  description: "re.fullmatch.__qualname__ == 'fullmatch' (the qualname is the plain function name, length 9)"
  category: qualname
  kind: python_call_eq
  function: fullmatch.__qualname__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra95.sub.qualname_len_3:
  description: "re.sub.__qualname__.__len__() == 3 ('sub' is the shortest qualname among re top-level functions)"
  category: qualname
  kind: python_call_eq
  function: sub.__qualname__.__len__
  args: []
  expected: 3

invariant re_extra95.finditer.qualname_len_8:
  description: "re.finditer.__qualname__.__len__() == 8 ('finditer' has 8 characters)"
  category: qualname
  kind: python_call_eq
  function: finditer.__qualname__.__len__
  args: []
  expected: 8

invariant re_extra95.escape.qualname_eq_escape:
  description: "re.escape.__qualname__ == 'escape' (the qualname is the plain function name, length 6)"
  category: qualname
  kind: python_call_eq
  function: escape.__qualname__.__eq__
  args: ["escape"]
  expected: true
