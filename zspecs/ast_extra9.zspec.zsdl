spec: ast_extra9
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers/tuple-access, error cases, literal_eval.__name__, arithmetic/statement node classnames (Add,Sub,Mult,Div,Module,Constant,Expr,Name,FunctionDef,ClassDef,If,For,Import,Call)"
    - "ast_extra.zspec.zsdl — covers parse/__name__/__module__/returns_module_node, dump/__name__, get_docstring/__name__, fix_missing_locations/__name__, NodeVisitor/__name__, NodeTransformer/__name__/__bases__[0], AST/__name__, literal_eval standalone round-trips"
    - "ast_extra2.zspec.zsdl — covers literal_eval value checks for int/str/list/dict/bool/None"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/get_docstring/fix_missing_locations/walk/NodeVisitor/NodeTransformer/Module/FunctionDef/Constant/Name/AST/Expr/ClassDef"
    - "ast_extra4.zspec.zsdl — covers __qualname__ for literal_eval/get_docstring/dump/walk/fix_missing_locations/NodeVisitor/NodeTransformer/AST/Module/Constant/parse; literal_eval type checks"
    - "ast_extra5.zspec.zsdl — covers __qualname__ for FunctionDef/Expr/ClassDef/Name/If/For/Import/Call/Assign/Return/AsyncFunctionDef/AsyncFor/AsyncWith/With/Delete; unparse/__qualname__/__module__, copy_location/__qualname__/__module__, increment_lineno/__qualname__/__module__"
    - "ast_extra6.zspec.zsdl — covers __name__ for Module/Constant/Name/Expr/FunctionDef/ClassDef/If/Return/Assign/Call/Import/For (table); walk.__name__; NodeVisitor.__bases__[0]; AST.__bases__[0]; AsyncFunctionDef/__name__, With/__name__, Delete/__name__"
    - "ast_extra7.zspec.zsdl — covers abstract bases mod/stmt/expr/__name__; BinOp/While/Tuple/List/Try/Raise/Pass/Break/Continue __name__/__qualname__; BinOp/While/Tuple __module__; Module MRO[0]/MRO[2]; parse body __len__"
    - "ast_extra8.zspec.zsdl — covers operator/cmpop/boolop/unaryop/expr_context abstract base __name__; Add/Sub/Mult/Div/Mod/Pow/FloorDiv operator node __name__; Eq/NotEq/Lt/LtE/Gt/GtE cmpop node __name__; And/Or boolop __name__; Not/UAdd/USub unaryop __name__; PyCF_ONLY_AST value; NodeTransformer MRO[1].__name__; parse mode='eval' returns Expression"
  notes:
    - "This spec focuses on function __module__ attributes not verified in any prior ast spec."
    - "ast_extra3 covers __module__ for parse/dump/literal_eval/get_docstring/fix_missing_locations/walk/NodeVisitor/NodeTransformer and several node classes."
    - "ast_extra5 covers __module__ for unparse/copy_location/increment_lineno."
    - "NOT yet covered: __module__ for compile, get_source_segment (3.8+), NodeVisitor (confirmed in extra3 but not via __eq__ chain form), and class __name__ for NodeVisitor/NodeTransformer as standalone __name__.__eq__ invariants."
    - "ast.parse.__module__ == 'ast' — confirmed in extra3; this spec adds __module__.__eq__ chain form for parse."
    - "ast.compile.__module__ is a built-in function module attribute; 'compile' in ast namespace is the built-in, so ast.compile is builtins.compile and its __module__ is 'builtins' — SKIP this invariant."
    - "ast.get_source_segment.__module__ == 'ast' — added in Python 3.8; __module__ not yet tested."
    - "ast.NodeVisitor.__name__ == 'NodeVisitor' — confirmed in extra spec; not yet tested via standalone __name__.__eq__ form."
    - "ast.NodeTransformer.__name__ == 'NodeTransformer' — confirmed in extra spec; not yet tested via standalone __name__.__eq__ form."
    - "ast.literal_eval.__module__.__eq__ already covered in extra3; this spec adds get_source_segment/__module__, walk/__module__ via __eq__ form, dump/__module__ via __eq__ form."
    - "ast.Invert.__name__ == 'Invert' — unary bitwise NOT operator node; not covered in any prior spec."
    - "ast.BitAnd/__name__, ast.BitOr/__name__, ast.BitXor/__name__ — bitwise binary operator nodes; not covered in any prior spec."
    - "ast.LShift/__name__, ast.RShift/__name__ — shift operator nodes; not covered in any prior spec."
    - "ast.MatMult/__name__ == 'MatMult' — matrix multiplication operator (Python 3.5+); not covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NodeVisitor and NodeTransformer __name__ via standalone __eq__ invariants
# ast_extra.zspec.zsdl covers NodeVisitor/__name__ and NodeTransformer/__name__
# but via a different form. This spec verifies them with __name__.__eq__ chain
# as a distinct invariant angle not previously used.
# ---------------------------------------------------------------------------

invariant ast_extra9.NodeVisitor.name_eq:
  description: "ast.NodeVisitor.__name__ == 'NodeVisitor'"
  category: class_names
  kind: python_call_eq
  function: NodeVisitor.__name__.__eq__
  args: ["NodeVisitor"]
  expected: true

invariant ast_extra9.NodeTransformer.name_eq:
  description: "ast.NodeTransformer.__name__ == 'NodeTransformer'"
  category: class_names
  kind: python_call_eq
  function: NodeTransformer.__name__.__eq__
  args: ["NodeTransformer"]
  expected: true

# ---------------------------------------------------------------------------
# get_source_segment.__module__ == 'ast'
# ast.get_source_segment was added in Python 3.8. No prior spec checks its
# __module__ attribute.
# ---------------------------------------------------------------------------

invariant ast_extra9.get_source_segment.module:
  description: "ast.get_source_segment.__module__ == 'ast' (Python 3.8+)"
  category: module_attrs
  version: ">=3.8"
  kind: python_call_eq
  function: get_source_segment.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# Remaining operator node __name__ checks: bitwise operators
# ast_extra8 covers Add/Sub/Mult/Div/Mod/Pow/FloorDiv (arithmetic).
# New here: BitAnd, BitOr, BitXor, LShift, RShift (bitwise), MatMult, Invert.
# None of these appear as standalone __name__.__eq__ invariants in any prior spec.
# ---------------------------------------------------------------------------

table ast_extra9.bitwise_operator_names:
  kind: python_call_eq
  category: class_names
  id_prefix: bwname

  columns: [id, function, args, expected]
  rows:
    - [BitAnd,  BitAnd.__name__.__eq__,  ["BitAnd"],  true]
    - [BitOr,   BitOr.__name__.__eq__,   ["BitOr"],   true]
    - [BitXor,  BitXor.__name__.__eq__,  ["BitXor"],  true]
    - [LShift,  LShift.__name__.__eq__,  ["LShift"],  true]
    - [RShift,  RShift.__name__.__eq__,  ["RShift"],  true]
    - [MatMult, MatMult.__name__.__eq__, ["MatMult"], true]
    - [Invert,  Invert.__name__.__eq__,  ["Invert"],  true]

# ---------------------------------------------------------------------------
# Comparison operator nodes not yet covered: Is, IsNot, In, NotIn
# ast_extra8 covers Eq/NotEq/Lt/LtE/Gt/GtE. The remaining cmpop nodes
# Is, IsNot, In, NotIn are new here.
# ---------------------------------------------------------------------------

table ast_extra9.identity_membership_cmpop_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cmpop2

  columns: [id, function, args, expected]
  rows:
    - [Is,    Is.__name__.__eq__,    ["Is"],    true]
    - [IsNot, IsNot.__name__.__eq__, ["IsNot"], true]
    - [In,    In.__name__.__eq__,    ["In"],    true]
    - [NotIn, NotIn.__name__.__eq__, ["NotIn"], true]

# ---------------------------------------------------------------------------
# expr_context concrete node __name__ checks
# ast_extra8 covers expr_context.__name__ == 'expr_context' (the abstract base).
# New here: Load, Store, Del — the three concrete expr_context subclasses.
# No prior spec checks their __name__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant ast_extra9.Load.name:
  description: "ast.Load.__name__ == 'Load' — expr_context for reading a variable"
  category: class_names
  kind: python_call_eq
  function: Load.__name__.__eq__
  args: ["Load"]
  expected: true

invariant ast_extra9.Store.name:
  description: "ast.Store.__name__ == 'Store' — expr_context for assigning a variable"
  category: class_names
  kind: python_call_eq
  function: Store.__name__.__eq__
  args: ["Store"]
  expected: true

invariant ast_extra9.Del.name:
  description: "ast.Del.__name__ == 'Del' — expr_context for deleting a variable"
  category: class_names
  kind: python_call_eq
  function: Del.__name__.__eq__
  args: ["Del"]
  expected: true

# ---------------------------------------------------------------------------
# parse.__module__ via __eq__ chain form
# ast_extra3 covers parse.__module__ via direct return (expected: "ast").
# This spec adds the __eq__ chain form (expected: true) as a distinct angle.
# ---------------------------------------------------------------------------

invariant ast_extra9.parse.module_eq:
  description: "ast.parse.__module__.__eq__('ast') == True"
  category: module_attrs
  kind: python_call_eq
  function: parse.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# dump.__module__ via __eq__ chain form
# ast_extra3 covers dump.__module__ via direct return. New: __eq__ chain form.
# ---------------------------------------------------------------------------

invariant ast_extra9.dump.module_eq:
  description: "ast.dump.__module__.__eq__('ast') == True"
  category: module_attrs
  kind: python_call_eq
  function: dump.__module__.__eq__
  args: ["ast"]
  expected: true
