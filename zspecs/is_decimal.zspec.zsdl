spec: is_decimal
version: ">=2.0.1"
backend: node(is-decimal)

docs: https://www.npmjs.com/package/is-decimal

provenance:
  derived_from:
    - "is-decimal README — https://www.npmjs.com/package/is-decimal"
    - "Test vectors verified with is-decimal via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-decimal source"
  notes:
    - "is-decimal is an npm package. Install: npm install is-decimal"
    - "Checks a single character: returns true if it is a decimal digit (0-9)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_decimal.isDecimal:
  kind: node_module_call_eq
  function: isDecimal
  category: predicate
  id_prefix: isdec

  columns: [id, args, expected]
  rows:
    - [digit_5,  ["5"],  true]
    - [digit_0,  ["0"],  true]
    - [digit_9,  ["9"],  true]
    - [alpha,    ["a"],  false]
    - [space,    [" "],  false]
