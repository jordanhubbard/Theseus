       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass is defined as 'def isclass(object):' with exactly one positional parameter object and no other parameters; co_argcount counts positional parameters only and equals 1; int.__eq__(1) returns True; no prior inspect spec checks isclass.__code__.co_argcount via inspfunc71; new to extra71"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra71
# ---------------------------------------------------------------------------

invariant inspect_extra71.getmembers_co_name:
  description: "inspect.getmembers.__code__.co_name.__eq__('getmembers') == True — co_name records the name from the def statement; wave 237 getmembers __code__; new to extra71"
  kind: python_call_eq
  function: getmembers.__code__.co_name.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra71.getmembers_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers(object, predicate=None) has 2 positional parameters; wave 237 getmembers __code__; new to extra71"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra71.isfunction_co_argcount:
  description: "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction(object) has 1 positional parameter; wave 237 isfunction __code__; new to extra71"
  kind: python_call_eq
  function: isfunction.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra71.signature_co_argcount:
  description: "inspect.signature.__code__.co_argcount.__eq__(1) == True — signature(obj, *, ...) has 1 positional parameter; wave 237 signature __code__; new to extra71"
  kind: python_call_eq
  function: signature.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra71.isclass_co_argcount:
  description: "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass(object) has 1 positional parameter; wave 237 isclass __code__; new to extra71"
  kind: python_call_eq
  function: isclass.__code__.co_argcount.__eq__
  args: [1]
  expected: true
