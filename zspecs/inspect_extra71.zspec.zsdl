spec: inspect_extra71
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra70.zspec.zsdl."
    - "Wave 237 theme: inspect function __code__ deep chains — first __code__ for inspect."
    - "getmembers.__code__.co_name == 'getmembers' — getmembers is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "getmembers.__code__.co_argcount == 2 — getmembers(object, predicate=None) has 2 positional parameters. Verified with Python 3.14.3."
    - "isfunction.__code__.co_name == 'isfunction' — isfunction is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "isfunction.__code__.co_argcount == 1 — isfunction(object) has 1 positional parameter. Verified with Python 3.14.3."
    - "signature.__code__.co_name == 'signature' — signature is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "signature.__code__.co_argcount == 1 — signature(obj) has 1 positional parameter; follow_wrapped and globals are keyword-only. Verified with Python 3.14.3."
    - "getdoc.__code__.co_name == 'getdoc' — getdoc is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "getdoc.__code__.co_argcount == 1 — getdoc(object) has 1 positional parameter. Verified with Python 3.14.3."
    - "isclass.__code__.co_name == 'isclass' — isclass is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "isclass.__code__.co_argcount == 1 — isclass(object) has 1 positional parameter. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getmembers __code__ attributes — extra71
#
# Wave 237 theme: getmembers is a pure-Python function with __code__.
#
# inspect.getmembers is defined in Lib/inspect.py as:
#   def getmembers(object, predicate=None):
#
# Its __code__ object has:
#   co_name      == 'getmembers'
#   co_argcount  == 2   (object and predicate are both positional; predicate has a default)
#
# No prior inspect spec checks getmembers.__code__ attributes via inspfunc71. New to extra71.
# ---------------------------------------------------------------------------

table inspect_extra71.getmembers_code:
  description: "getmembers.__code__.co_name=='getmembers', co_argcount==2; wave 237 getmembers __code__ attributes; new to extra71"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspfunc71

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_name_eq_getmembers,
       getmembers.__code__.co_name.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_name.__eq__('getmembers') == True — getmembers is a pure-Python function in Lib/inspect.py that returns all members of an object in a list of (name, value) pairs sorted by name; it is defined as 'def getmembers(object, predicate=None):' so the code object's co_name is 'getmembers' (10 chars); str.__eq__('getmembers') returns True; no prior inspect spec checks getmembers.__code__.co_name via inspfunc71; new to extra71"]
    - [getmembers_co_argcount_eq_2,
       getmembers.__code__.co_argcount.__eq__,
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers is defined as 'def getmembers(object, predicate=None):' with two positional parameters object and predicate (predicate has a default of None but is positional, not keyword-only); co_argcount counts positional parameters including those with defaults and equals 2; int.__eq__(2) returns True; no prior inspect spec checks getmembers.__code__.co_argcount via inspfunc71; new to extra71"]

# ---------------------------------------------------------------------------
# isfunction __code__ attributes — extra71
#
# Wave 237 theme: isfunction is a pure-Python function with __code__.
#
# inspect.isfunction is defined in Lib/inspect.py as:
#   def isfunction(object):
#
# Its __code__ object has:
#   co_name      == 'isfunction'
#   co_argcount  == 1
#
# No prior inspect spec checks isfunction.__code__ attributes via inspfunc71. New to extra71.
# ---------------------------------------------------------------------------

table inspect_extra71.isfunction_code:
  description: "isfunction.__code__.co_name=='isfunction', co_argcount==1; wave 237 isfunction __code__ attributes; new to extra71"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspfunc71

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_co_name_eq_isfunction,
       isfunction.__code__.co_name.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — isfunction is a pure-Python function in Lib/inspect.py that returns True if the object is a Python function; it is defined as 'def isfunction(object):' so the code object's co_name is 'isfunction' (10 chars); str.__eq__('isfunction') returns True; no prior inspect spec checks isfunction.__code__.co_name via inspfunc71; new to extra71"]
    - [isfunction_co_argcount_eq_1,
       isfunction.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction is defined as 'def isfunction(object):' with exactly one positional parameter object and no other parameters; co_argcount counts positional parameters only and equals 1; int.__eq__(1) returns True; no prior inspect spec checks isfunction.__code__.co_argcount via inspfunc71; new to extra71"]

# ---------------------------------------------------------------------------
# signature and getdoc __code__ attributes — extra71
#
# Wave 237 theme: signature and getdoc are pure-Python functions with __code__.
#
# inspect.signature is defined as:  def signature(obj, *, follow_wrapped=True, globals=None, ...):
# inspect.getdoc is defined as:     def getdoc(object):
#
# signature.__code__.co_name      == 'signature'
# signature.__code__.co_argcount  == 1   (obj is positional; follow_wrapped, globals are keyword-only)
# getdoc.__code__.co_name         == 'getdoc'
# getdoc.__code__.co_argcount     == 1   (object is the only positional parameter)
#
# No prior inspect spec checks these functions' __code__ attributes via inspfunc71. New to extra71.
# ---------------------------------------------------------------------------

table inspect_extra71.signature_getdoc_code:
  description: "signature.__code__.co_name=='signature', co_argcount==1; getdoc.__code__.co_name=='getdoc', co_argcount==1; wave 237 signature/getdoc __code__; new to extra71"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspfunc71

  columns: [id, function, args, expected, description]
  rows:
    - [signature_co_name_eq_signature,
       signature.__code__.co_name.__eq__,
       ["signature"],
       true,
       "inspect.signature.__code__.co_name.__eq__('signature') == True — signature is a pure-Python function in Lib/inspect.py that returns a Signature object for the given callable; it is defined as 'def signature(obj, *, follow_wrapped=True, globals=None, ...):' so co_name is 'signature' (9 chars); str.__eq__('signature') returns True; no prior inspect spec checks signature.__code__.co_name via inspfunc71; new to extra71"]
    - [signature_co_argcount_eq_1,
       signature.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — signature is defined with one positional parameter obj followed by keyword-only parameters (follow_wrapped, globals, etc. after the * separator); co_argcount counts only the positional parameter obj and equals 1; int.__eq__(1) returns True; no prior inspect spec checks signature.__code__.co_argcount via inspfunc71; new to extra71"]
    - [getdoc_co_name_eq_getdoc,
       getdoc.__code__.co_name.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — getdoc is a pure-Python function in Lib/inspect.py that retrieves and cleans up the docstring for an object; it is defined as 'def getdoc(object):' so co_name is 'getdoc' (6 chars); str.__eq__('getdoc') returns True; no prior inspect spec checks getdoc.__code__.co_name via inspfunc71; new to extra71"]
    - [getdoc_co_argcount_eq_1,
       getdoc.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc is defined as 'def getdoc(object):' with exactly one positional parameter object; co_argcount equals 1; int.__eq__(1) returns True; no prior inspect spec checks getdoc.__code__.co_argcount via inspfunc71; new to extra71"]

