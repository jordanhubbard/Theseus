spec: uuid_extra2671
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 625: checks uuid.UUID and uuid.SafeUUID __dict__ for __sub__, __floordiv__, __mod__ presence. uuid.UUID is a plain Python class; uuid.SafeUUID is an IntEnum subclass. All return False — neither defines __sub__, __floordiv__, nor __mod__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table uuid_extra2671.UUID_dict_presence:
  description: "uuid.UUID __dict__ does not contain __sub__, __floordiv__, or __mod__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2671ud
  columns: [id, function, args, expected]
  rows:
    - ["uu2671ud001", uuid.UUID.__dict__.__contains__, ["__sub__"],      false]
    - ["uu2671ud002", uuid.UUID.__dict__.__contains__, ["__floordiv__"], false]
    - ["uu2671ud003", uuid.UUID.__dict__.__contains__, ["__mod__"],      false]

