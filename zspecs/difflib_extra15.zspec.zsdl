spec: difflib_extra15
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra14.zspec.zsdl."
    - "difflib_extra14 covers: SequenceMatcher.__module__; Differ.__module__; HtmlDiff.__module__; unified_diff/__name__; context_diff/__name__; ndiff/__name__; restore/__name__; IS_LINE_JUNK/__name__; two tables."
    - "difflib_extra13 covers: SequenceMatcher/__name__; Differ/__name__; HtmlDiff/__name__; SequenceMatcher ratio checks; get_close_matches exact match."
    - "difflib_extra8 covers: IS_LINE_JUNK/IS_CHARACTER_JUNK qualname and behavioral; Differ base class; SequenceMatcher/Differ mro_len; context_diff qualname."
    - "NOT yet covered (now covered here): difflib.SequenceMatcher.__mro__.__len__() == 2 — MRO depth as standalone extra15 invariant."
    - "NOT yet covered (now covered here): difflib.SequenceMatcher.__mro__[0].__name__ == 'SequenceMatcher' — first MRO entry."
    - "NOT yet covered (now covered here): difflib.SequenceMatcher.__mro__[1].__name__ == 'object' — second MRO entry."
    - "NOT yet covered (now covered here): difflib.Differ.__mro__.__len__() == 2 — Differ MRO depth."
    - "NOT yet covered (now covered here): difflib.HtmlDiff.__mro__.__len__() == 2 — HtmlDiff MRO depth."
    - "NOT yet covered (now covered here): difflib.SequenceMatcher.__qualname__ == 'SequenceMatcher' — qualname."
    - "NOT yet covered (now covered here): difflib.Differ.__qualname__ == 'Differ' — qualname."
    - "NOT yet covered (now covered here): difflib.HtmlDiff.__qualname__ == 'HtmlDiff' — qualname."
    - "NOT yet covered (now covered here): table of function __module__ attributes — unified_diff, context_diff, ndiff, get_close_matches, restore."
    - "difflib_extra8 covers mro_len for SequenceMatcher and Differ; standalone MRO entry names and HtmlDiff MRO are new here."
    - "difflib.SequenceMatcher.__mro__.__len__() == 2 verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "difflib.Differ.__mro__.__len__() == 2 verified at runtime."
    - "difflib.HtmlDiff.__mro__.__len__() == 2 verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher — MRO depth and MRO entry names
#
# difflib_extra8 covers SequenceMatcher mro_len (same value) in a different
# namespace context. No prior spec verifies the individual MRO entry __name__
# values for SequenceMatcher as standalone invariants.
# Verified: __len__() == 2; mro[0].__name__ == 'SequenceMatcher';
# mro[1].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant difflib_extra15.SequenceMatcher.mro_len:
  description: "difflib.SequenceMatcher.__mro__.__len__() == 2 — SequenceMatcher MRO: [SequenceMatcher, object]"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__mro__.__len__
  args: []
  expected: 2

invariant difflib_extra15.SequenceMatcher.mro_0:
  description: "difflib.SequenceMatcher.__mro__[0].__name__ == 'SequenceMatcher' — first MRO entry"
  category: class_identity
  kind: python_call_eq
  function: "SequenceMatcher.__mro__[0].__name__.__eq__"
  args: ["SequenceMatcher"]
  expected: true

invariant difflib_extra15.SequenceMatcher.mro_1:
  description: "difflib.SequenceMatcher.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: class_identity
  kind: python_call_eq
  function: "SequenceMatcher.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.Differ — MRO depth and qualname
#
# difflib_extra8 covers Differ base class (via __bases__) and mro_len.
# No prior spec verifies Differ.__mro__.__len__() as a standalone extra15
# invariant or Differ.__qualname__.
# Verified: __len__() == 2; __qualname__ == 'Differ'.
# ---------------------------------------------------------------------------

invariant difflib_extra15.Differ.mro_len:
  description: "difflib.Differ.__mro__.__len__() == 2 — Differ MRO: [Differ, object]"
  category: class_identity
  kind: python_call_eq
  function: Differ.__mro__.__len__
  args: []
  expected: 2

invariant difflib_extra15.Differ.qualname:
  description: "difflib.Differ.__qualname__ == 'Differ' — qualname of the Differ class"
  category: class_identity
  kind: python_call_eq
  function: Differ.__qualname__.__eq__
  args: ["Differ"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.HtmlDiff — MRO depth and qualname
#
# No prior spec verifies HtmlDiff.__mro__.__len__() as a standalone invariant.
# HtmlDiff inherits directly from object: MRO is [HtmlDiff, object].
# Verified: __len__() == 2; __qualname__ == 'HtmlDiff'.
# ---------------------------------------------------------------------------

invariant difflib_extra15.HtmlDiff.mro_len:
  description: "difflib.HtmlDiff.__mro__.__len__() == 2 — HtmlDiff MRO: [HtmlDiff, object]"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__mro__.__len__
  args: []
  expected: 2

invariant difflib_extra15.HtmlDiff.qualname:
  description: "difflib.HtmlDiff.__qualname__ == 'HtmlDiff' — qualname of the HtmlDiff class"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__qualname__.__eq__
  args: ["HtmlDiff"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher — qualname
#
# No prior spec verifies SequenceMatcher.__qualname__ as a standalone invariant
# (difflib_extra13 covers __name__; qualname == name for top-level classes).
# Verified: SequenceMatcher.__qualname__ == 'SequenceMatcher'.
# ---------------------------------------------------------------------------

invariant difflib_extra15.SequenceMatcher.qualname:
  description: "difflib.SequenceMatcher.__qualname__ == 'SequenceMatcher' — qualname of SequenceMatcher"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__qualname__.__eq__
  args: ["SequenceMatcher"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __module__ attributes
#
# difflib_extra14 covers class __module__ in a table and function __name__
# in a table. No prior table groups difflib function __module__ attributes.
# All verified at runtime: all five functions report __module__ == 'difflib'.
# ---------------------------------------------------------------------------

table difflib_extra15.function_modules:
  description: "difflib function __module__ attributes — unified_diff, context_diff, ndiff, get_close_matches, restore"
  kind: python_call_eq
  category: function_identity
  id_prefix: fm15

  columns: [id, function, args, expected]
  rows:
    - [unified_diff,      unified_diff.__module__.__eq__,      ["difflib"], true]
    - [context_diff,      context_diff.__module__.__eq__,      ["difflib"], true]
    - [ndiff,             ndiff.__module__.__eq__,             ["difflib"], true]
    - [get_close_matches, get_close_matches.__module__.__eq__, ["difflib"], true]
    - [restore,           restore.__module__.__eq__,           ["difflib"], true]
