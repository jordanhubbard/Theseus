spec: pathlib_extra119
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra118.zspec.zsdl."
    - "This spec covers: pathlib.PurePath private property fget __qualname__ equality strings for _tail, _raw_path, _str_normcase, and _parts_normcase."
    - "These are implementation-detail properties on PurePath not covered by prior specs which focused on public properties."
    - "pathlib.PurePath._tail.fget.__qualname__ == 'PurePath._tail' (len 14); type 'function'."
    - "pathlib.PurePath._raw_path.fget.__qualname__ == 'PurePath._raw_path' (len 18); type 'function'."
    - "pathlib.PurePath._str_normcase.fget.__qualname__ == 'PurePath._str_normcase' (len 22); type 'function'."
    - "pathlib.PurePath._parts_normcase.fget.__qualname__ == 'PurePath._parts_normcase' (len 24); type 'function'."
    - "All four private properties follow the 'PurePath.<name>' fget qualname convention like public properties."
    - "pathlib_extra37 covered fget qualname LENGTHS via __dict__ bracket access; this spec covers fget qualname string EQUALITY via direct attribute access."
    - "pathlib_extra117 covered public property fget qualname equality; this spec covers the private property counterparts."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath._tail and pathlib.PurePath._raw_path property fget qualnames
# Both are implementation-detail properties not part of the public API.
# _tail.fget.__qualname__ == 'PurePath._tail' (14 chars); type 'function'.
# _raw_path.fget.__qualname__ == 'PurePath._raw_path' (18 chars); type 'function'.
# Both use the 'PurePath.' prefix (9 chars) because they are defined on PurePath.
# '_tail' stores the path components after the root/anchor.
# '_raw_path' stores the original path string before normalization.
# ---------------------------------------------------------------------------

table pathlib_extra119.PurePath_tail_rawpath_fget_qualnames:
  description: "pathlib.PurePath._tail.fget.__qualname__='PurePath._tail'(14), _raw_path.fget.__qualname__='PurePath._raw_path'(18); both type 'function'; implementation-detail properties using 'PurePath.' prefix"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibpv119a

  columns: [id, function, args, expected, description]
  rows:
    - [tail_fget_type,       "PurePath._tail.fget.__class__.__name__.__eq__",         ["function"],             true,  "type(pathlib.PurePath._tail.fget).__name__ == 'function' (pure Python property getter for the private _tail implementation attribute)"]
    - [tail_fget_qn_eq,      "PurePath._tail.fget.__qualname__.__eq__",               ["PurePath._tail"],       true,  "pathlib.PurePath._tail.fget.__qualname__ == 'PurePath._tail' (14 chars; private property storing normalized path components after anchor)"]
    - [tail_fget_qn_len,     "PurePath._tail.fget.__qualname__.__len__",              [],                       14,    "pathlib.PurePath._tail.fget.__qualname__.__len__() == 14 ('PurePath._tail' has 14 chars; 'PurePath.'(9) + '_tail'(5) == 14)"]
    - [rawpath_fget_type,    "PurePath._raw_path.fget.__class__.__name__.__eq__",     ["function"],             true,  "type(pathlib.PurePath._raw_path.fget).__name__ == 'function' (pure Python property getter for the raw unprocessed path string)"]
    - [rawpath_fget_qn_eq,   "PurePath._raw_path.fget.__qualname__.__eq__",           ["PurePath._raw_path"],  true,  "pathlib.PurePath._raw_path.fget.__qualname__ == 'PurePath._raw_path' (18 chars; private property holding the original path string)"]
    - [rawpath_fget_qn_len,  "PurePath._raw_path.fget.__qualname__.__len__",          [],                       18,    "pathlib.PurePath._raw_path.fget.__qualname__.__len__() == 18 ('PurePath._raw_path' has 18 chars; 'PurePath.'(9) + '_raw_path'(9) == 18)"]
    - [rawpath_gt_tail,      "PurePath._raw_path.fget.__qualname__.__len__.__gt__",   [14],                     true,  "len('PurePath._raw_path') > len('PurePath._tail') (18 > 14; _raw_path is 4 chars longer than _tail)"]
    - [tail_ne_rawpath,      "PurePath._tail.fget.__qualname__.__eq__",               ["PurePath._raw_path"],   false, "pathlib.PurePath._tail.fget.__qualname__ != 'PurePath._raw_path' (distinct qualname strings for distinct implementation-detail properties)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath._str_normcase and pathlib.PurePath._parts_normcase fget qualnames
# Both are implementation-detail properties for cached normalized representations.
# _str_normcase.fget.__qualname__ == 'PurePath._str_normcase' (22 chars); type 'function'.
# _parts_normcase.fget.__qualname__ == 'PurePath._parts_normcase' (24 chars); type 'function'.
# These store case-normalized versions of the path for case-insensitive comparisons.
# ---------------------------------------------------------------------------

table pathlib_extra119.PurePath_strnormcase_partsnormcase_fget_qualnames:
  description: "pathlib.PurePath._str_normcase.fget.__qualname__='PurePath._str_normcase'(22), _parts_normcase.fget.__qualname__='PurePath._parts_normcase'(24); both type 'function'; cache properties for case-insensitive path comparisons"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibpv119b

  columns: [id, function, args, expected, description]
  rows:
    - [stnorm_fget_type,     "PurePath._str_normcase.fget.__class__.__name__.__eq__",    ["function"],                  true,  "type(pathlib.PurePath._str_normcase.fget).__name__ == 'function' (pure Python property getter for normalized string cache)"]
    - [stnorm_fget_qn_eq,    "PurePath._str_normcase.fget.__qualname__.__eq__",          ["PurePath._str_normcase"],    true,  "pathlib.PurePath._str_normcase.fget.__qualname__ == 'PurePath._str_normcase' (22 chars; cached case-normalized path string)"]
    - [stnorm_fget_qn_len,   "PurePath._str_normcase.fget.__qualname__.__len__",         [],                            22,    "pathlib.PurePath._str_normcase.fget.__qualname__.__len__() == 22 ('PurePath._str_normcase' has 22 chars; 'PurePath.'(9)+'_str_normcase'(13)==22)"]
    - [ptnorm_fget_type,     "PurePath._parts_normcase.fget.__class__.__name__.__eq__",  ["function"],                  true,  "type(pathlib.PurePath._parts_normcase.fget).__name__ == 'function' (pure Python property getter for normalized parts tuple cache)"]
    - [ptnorm_fget_qn_eq,    "PurePath._parts_normcase.fget.__qualname__.__eq__",        ["PurePath._parts_normcase"],  true,  "pathlib.PurePath._parts_normcase.fget.__qualname__ == 'PurePath._parts_normcase' (24 chars; cached case-normalized parts tuple)"]
    - [ptnorm_fget_qn_len,   "PurePath._parts_normcase.fget.__qualname__.__len__",       [],                            24,    "pathlib.PurePath._parts_normcase.fget.__qualname__.__len__() == 24 ('PurePath._parts_normcase' has 24 chars; longest private property qualname)"]
    - [ptnorm_gt_stnorm,     "PurePath._parts_normcase.fget.__qualname__.__len__.__gt__", [22],                         true,  "len('PurePath._parts_normcase') > len('PurePath._str_normcase') (24 > 22; _parts_normcase is 2 chars longer)"]
    - [stnorm_gt_rawpath,    "PurePath._str_normcase.fget.__qualname__.__len__.__gt__",  [18],                          true,  "len('PurePath._str_normcase') > len('PurePath._raw_path') (22 > 18; _str_normcase is 4 chars longer than _raw_path)"]
    - [stnorm_ne_ptnorm,     "PurePath._str_normcase.fget.__qualname__.__eq__",          ["PurePath._parts_normcase"],  false, "pathlib.PurePath._str_normcase.fget.__qualname__ != 'PurePath._parts_normcase' (distinct properties: str is the string form; parts is the tuple form)"]

# ---------------------------------------------------------------------------
# PurePath private property fget type check and length ordering
# All four private properties have fget of type 'function'.
# Length ordering: _tail(14) < _raw_path(18) < _str_normcase(22) < _parts_normcase(24).
# Path.name.fget inherits from PurePath: Path.name.fget is PurePath.name.fget.
# The 'PurePath.' prefix (9 chars) is shared by all PurePath properties.
# ---------------------------------------------------------------------------

table pathlib_extra119.PurePath_private_fget_type_and_ordering:
  description: "All four PurePath private property fgets are type 'function'; ordering by qualname length: _tail(14) < _raw_path(18) < _str_normcase(22) < _parts_normcase(24)"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibpv119c

  columns: [id, function, args, expected, description]
  rows:
    - [tail_type_is_fn,      "PurePath._tail.fget.__class__.__name__.__eq__",           ["function"],             true,  "PurePath._tail.fget is type 'function' (all four private PurePath property getters are pure Python functions)"]
    - [rawpath_type_is_fn,   "PurePath._raw_path.fget.__class__.__name__.__eq__",       ["function"],             true,  "PurePath._raw_path.fget is type 'function' (same as _tail; all private property fgets are pure Python)"]
    - [tail_lt_rawpath,      "PurePath._tail.fget.__qualname__.__len__.__lt__",         [18],                     true,  "len('PurePath._tail') < len('PurePath._raw_path') (14 < 18; _tail is 4 chars shorter than _raw_path)"]
    - [rawpath_lt_stnorm,    "PurePath._raw_path.fget.__qualname__.__len__.__lt__",     [22],                     true,  "len('PurePath._raw_path') < len('PurePath._str_normcase') (18 < 22; _raw_path is 4 chars shorter than _str_normcase)"]
    - [stnorm_lt_ptnorm,     "PurePath._str_normcase.fget.__qualname__.__len__.__lt__", [24],                     true,  "len('PurePath._str_normcase') < len('PurePath._parts_normcase') (22 < 24; _str_normcase is 2 chars shorter)"]
    - [tail_prefix_eq,       "PurePath._tail.fget.__qualname__.__contains__",          ["PurePath."],             true,  "pathlib.PurePath._tail.fget.__qualname__ contains 'PurePath.' prefix (all PurePath property fgets use this 9-char prefix)"]
    - [ptnorm_ne_tail,       "PurePath._parts_normcase.fget.__qualname__.__eq__",       ["PurePath._tail"],       false, "pathlib.PurePath._parts_normcase.fget.__qualname__ != 'PurePath._tail' (24 chars vs 14 chars; very different lengths)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra119.PurePath._tail_fget_qualname:
  description: "pathlib.PurePath._tail.fget.__qualname__ == 'PurePath._tail' (length 14; type is 'function'; _tail is an implementation-detail property on PurePath that stores the normalized path component tuple after the anchor/root; it is a lazy-computed cached property; 'PurePath.'(9) + '_tail'(5) == 14; the fget qualname follows the same 'PurePath.<name>' pattern as all public property getters like PurePath.name(13) and PurePath.parts(14))"
  category: qualnames
  kind: python_call_eq
  function: "PurePath._tail.fget.__qualname__.__eq__"
  args: ["PurePath._tail"]
  expected: true

invariant pathlib_extra119.PurePath._raw_path_fget_qualname_len:
  description: "pathlib.PurePath._raw_path.fget.__qualname__.__len__() == 18 ('PurePath._raw_path' has 18 characters; 'PurePath.'(9) + '_raw_path'(9) == 18; type is 'function'; _raw_path stores the original unprocessed path string argument before any normalization; it is 4 chars longer than _tail(14) and 4 chars shorter than _str_normcase(22))"
  category: qualnames
  kind: python_call_eq
  function: "PurePath._raw_path.fget.__qualname__.__len__"
  args: []
  expected: 18

invariant pathlib_extra119.PurePath._str_normcase_fget_qualname:
  description: "pathlib.PurePath._str_normcase.fget.__qualname__ == 'PurePath._str_normcase' (length 22; type is 'function'; _str_normcase is a cached property returning the case-normalized string representation of the path, used for case-insensitive comparison on Windows paths; 'PurePath.'(9) + '_str_normcase'(13) == 22; pathlib_extra37 covered the __len__() via __dict__ bracket access; this spec covers the __eq__ string check via direct attribute access)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath._str_normcase.fget.__qualname__.__eq__"
  args: ["PurePath._str_normcase"]
  expected: true

invariant pathlib_extra119.PurePath._parts_normcase_fget_qualname_len:
  description: "pathlib.PurePath._parts_normcase.fget.__qualname__.__len__() == 24 ('PurePath._parts_normcase' has 24 characters; 'PurePath.'(9) + '_parts_normcase'(15) == 24; type is 'function'; _parts_normcase is a cached property returning the case-normalized path parts tuple for case-insensitive comparisons; it is the longest qualname among the four private PurePath properties: _tail(14) < _raw_path(18) < _str_normcase(22) < _parts_normcase(24))"
  category: qualnames
  kind: python_call_eq
  function: "PurePath._parts_normcase.fget.__qualname__.__len__"
  args: []
  expected: 24

invariant pathlib_extra119.PurePath._parts_normcase_fget_qualname_eq:
  description: "pathlib.PurePath._parts_normcase.fget.__qualname__ == 'PurePath._parts_normcase' (24 chars; type is 'function'; this is the longest private property fget qualname on PurePath — longer than _str_normcase(22), _raw_path(18), and _tail(14); the '_parts_normcase' suffix(15) plus the 'PurePath.' prefix(9) gives 24 total; pathlib_extra37 covered this length via __dict__ bracket notation; this spec verifies the string equality via direct attribute access)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath._parts_normcase.fget.__qualname__.__eq__"
  args: ["PurePath._parts_normcase"]
  expected: true
