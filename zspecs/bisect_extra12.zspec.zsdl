spec: bisect_extra12
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras through bisect_extra11.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for bisect_left/bisect_right/insort_left/insort_right; __name__/__qualname__ for bisect/insort as aliases; behavioral vectors on [1,2,3,4,5]; [1,2,3,3,3,4]; [1,2,3,3,4]; [2,4,6,8,10]; [1,3,5,7]; [1,3,5,7,9]; [6,12,18,24,30]; [6,12,18,18,24,30]; [10,20,30,40,50]; [1,2,3,3,5]; [5,10,15,20,25,25,30]."
    - "NOT yet covered: __name__.__len__ for bisect_left/bisect_right/insort_left/insort_right; __module__.__len__ for any bisect function; bisect_left([1,2,3], 2) == 1; bisect_right([1,2,3], 2) == 2."
    - "bisect_left([1,2,3], 2) == 1 — target 2 is at index 1; left insertion point is 1."
    - "bisect_right([1,2,3], 2) == 2 — target 2 is at index 1; right insertion point is 2 (one past)."
    - "bisect_left.__name__.__len__() == 11 — len('bisect_left')."
    - "bisect_right.__name__.__len__() == 12 — len('bisect_right')."
    - "insort_left.__name__.__len__() == 11 — len('insort_left')."
    - "insort_right.__name__.__len__() == 12 — len('insort_right')."
    - "All four bisect/insort functions have __module__ == '_bisect'; len('_bisect') == 7."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Behavioral invariants — [1, 2, 3] fixture with target 2
#
# No prior bisect spec tests bisect_left or bisect_right on the canonical
# [1, 2, 3] list with target value 2. This is the simplest 3-element sorted
# list containing the target. bisect_left returns 1 (target found at index 1);
# bisect_right returns 2 (one past the found element).
# ---------------------------------------------------------------------------

invariant bisect_extra12.bisect_left.simple_three_target_two:
  description: "bisect_left([1,2,3], 2) == 1 — target at index 1; left insertion point is 1"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3], 2]
  expected: 1

invariant bisect_extra12.bisect_right.simple_three_target_two:
  description: "bisect_right([1,2,3], 2) == 2 — target at index 1; right insertion point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3], 2]
  expected: 2

# ---------------------------------------------------------------------------
# __name__.__len__ — name length for the four primary bisect functions
#
# No prior bisect spec records __name__.__len__() for any bisect function.
# Length of 'bisect_left' == 11; 'bisect_right' == 12;
# 'insort_left' == 11; 'insort_right' == 12.
# ---------------------------------------------------------------------------

table bisect_extra12.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: bnamelen12

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__name__.__len__,  [], 11]
    - [bisect_right, bisect_right.__name__.__len__, [], 12]
    - [insort_left,  insort_left.__name__.__len__,  [], 11]
    - [insort_right, insort_right.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# __module__.__len__ — module name length for bisect_left and bisect_right
#
# No prior bisect spec records __module__.__len__() for any function.
# All four primary functions have __module__ == '_bisect'; len('_bisect') == 7.
# ---------------------------------------------------------------------------

invariant bisect_extra12.bisect_left.module_len:
  description: "bisect.bisect_left.__module__.__len__() == 7 — len('_bisect')"
  category: module_attr_lengths
  kind: python_call_eq
  function: bisect_left.__module__.__len__
  args: []
  expected: 7

invariant bisect_extra12.bisect_right.module_len:
  description: "bisect.bisect_right.__module__.__len__() == 7 — len('_bisect')"
  category: module_attr_lengths
  kind: python_call_eq
  function: bisect_right.__module__.__len__
  args: []
  expected: 7

invariant bisect_extra12.insort_left.module_len:
  description: "bisect.insort_left.__module__.__len__() == 7 — len('_bisect')"
  category: module_attr_lengths
  kind: python_call_eq
  function: insort_left.__module__.__len__
  args: []
  expected: 7

invariant bisect_extra12.insort_right.module_len:
  description: "bisect.insort_right.__module__.__len__() == 7 — len('_bisect')"
  category: module_attr_lengths
  kind: python_call_eq
  function: insort_right.__module__.__len__
  args: []
  expected: 7
