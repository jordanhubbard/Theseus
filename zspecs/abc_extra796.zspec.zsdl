table abc_extra796.name:
  description: "abc.ABC and ABCMeta dunder method qualname and class identity checks"
  kind: python_call_eq
  category: stdlib_abc
  id_prefix: ab796xx
  columns: [id, function, args, expected]
  rows:
    - [ab796xx001, abc.ABCMeta.__new__.__qualname__.__eq__, ["ABCMeta.__new__"], true]
    - [ab796xx002, abc.ABCMeta.__init__.__qualname__.__eq__, ["ABCMeta.__init__"], true]
    - [ab796xx003, abc.ABCMeta.register.__qualname__.__eq__, ["ABCMeta.register"], true]
    - [ab796xx004, abc.ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true]
    - [ab796xx005, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true]
    - [ab796xx006, abc.ABCMeta.__subclasshook__.__qualname__.__eq__, ["ABCMeta.__subclasshook__"], true]
    - [ab796xx007, abc.abstractmethod.__init__.__qualname__.__eq__, ["abstractmethod.__init__"], true]
    - [ab796xx008, abc.abstractmethod.__call__.__qualname__.__eq__, ["abstractmethod.__call__"], true]
    - [ab796xx009, abc.abstractmethod.__get__.__qualname__.__eq__, ["abstractmethod.__get__"], true]
    - [ab796xx010, abc.abstractmethod.__isabstractmethod__.__class__.__name__.__eq__, ["bool"], true]
    - [ab796xx011, abc.ABC.__class__.__name__.__eq__, ["ABCMeta"], true]
    - [ab796xx012, abc.ABCMeta.__class__.__name__.__eq__, ["type"], true]
