spec: uuid_extra212
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__name__ == 'uuid' (4 chars)."
    - "uuid.UUID.__name__ == 'UUID' (4 chars)."
    - "uuid.uuid1.__name__ == 'uuid1' (5 chars); uuid3.__name__ == 'uuid3'; uuid4.__name__ == 'uuid4'; uuid5.__name__ == 'uuid5'."
    - "uuid.NAMESPACE_DNS/URL/OID/X500 are all UUID instances — predefined RFC 4122 namespaces."
    - "uuid.RESERVED_NCS is a str constant — 'reserved for NCS compatibility'."
    - "uuid.UUID.__name__.__eq__('UUID') == True."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module and function __name__.__len__() checks
#
# uuid.__name__.__len__()      == 4  ('uuid')
# uuid.UUID.__name__.__len__() == 4  ('UUID')
# uuid.uuid1.__name__.__len__() == 5 ('uuid1')
# uuid.uuid3.__name__.__len__() == 5 ('uuid3')
# uuid.uuid4.__name__.__len__() == 5 ('uuid4')
# uuid.uuid5.__name__.__len__() == 5 ('uuid5')
# ---------------------------------------------------------------------------

table uuid_extra212.function_name_lengths:
  description: "uuid function __name__.__len__() checks in uuid212 namespace — wave 212 theme: module name 'uuid' is 4 chars; UUID class name is 4 chars; uuid1/uuid3/uuid4/uuid5 generator function names are 5 chars each; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuid212

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,  uuid.__name__.__len__,      [], 4, "uuid.__name__.__len__() == 4 — module name 'uuid' is 4 characters"]
    - [UUID_name_len,    uuid.UUID.__name__.__len__,  [], 4, "uuid.UUID.__name__.__len__() == 4 — class name 'UUID' is 4 characters"]
    - [uuid1_name_len,   uuid.uuid1.__name__.__len__, [], 5, "uuid.uuid1.__name__.__len__() == 5 — function name 'uuid1' is 5 characters"]
    - [uuid3_name_len,   uuid.uuid3.__name__.__len__, [], 5, "uuid.uuid3.__name__.__len__() == 5 — function name 'uuid3' is 5 characters"]
    - [uuid4_name_len,   uuid.uuid4.__name__.__len__, [], 5, "uuid.uuid4.__name__.__len__() == 5 — function name 'uuid4' is 5 characters"]
    - [uuid5_name_len,   uuid.uuid5.__name__.__len__, [], 5, "uuid.uuid5.__name__.__len__() == 5 — function name 'uuid5' is 5 characters"]

# ---------------------------------------------------------------------------
# uuid namespace constants — class name checks
#
# uuid.NAMESPACE_DNS.__class__.__name__  == 'UUID'
# uuid.NAMESPACE_URL.__class__.__name__  == 'UUID'
# uuid.NAMESPACE_OID.__class__.__name__  == 'UUID'
# uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'
# ---------------------------------------------------------------------------

table uuid_extra212.namespace_constant_types:
  description: "uuid RFC 4122 namespace constant type checks in uuid212a namespace — wave 212 theme: NAMESPACE_DNS/URL/OID/X500 are predefined RFC 4122 namespaces; all are UUID instances; NAMESPACE_DNS is the DNS namespace UUID; NAMESPACE_URL is the URL namespace UUID; NAMESPACE_OID is the ISO OID namespace UUID; NAMESPACE_X500 is the X.500 DN namespace UUID; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuid212a

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class,   "uuid.NAMESPACE_DNS.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — DNS namespace is a UUID instance (RFC 4122 Appendix C)"]
    - [ns_url_class,   "uuid.NAMESPACE_URL.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — URL namespace is a UUID instance (RFC 4122 Appendix C)"]
    - [ns_oid_class,   "uuid.NAMESPACE_OID.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — ISO OID namespace is a UUID instance (RFC 4122 Appendix C)"]
    - [ns_x500_class,  "uuid.NAMESPACE_X500.__class__.__name__.__eq__", ["UUID"], true, "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — X.500 DN namespace is a UUID instance (RFC 4122 Appendix C)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__name__ identity and uuid.RESERVED_NCS type check
#
# uuid.UUID.__name__.__eq__('UUID')         == True
# uuid.RESERVED_NCS.__class__.__name__      == 'str'
# ---------------------------------------------------------------------------

invariant uuid_extra212.UUID_name_eq:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — UUID class name is exactly 'UUID'; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "uuid.UUID.__name__.__eq__"
  args: ["UUID"]
  expected: true

invariant uuid_extra212.reserved_ncs_class:
  description: "uuid.RESERVED_NCS.__class__.__name__ == 'str' — RESERVED_NCS is a string constant ('reserved for NCS compatibility'); this is the variant description string for NCS-compatible UUIDs; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "uuid.RESERVED_NCS.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
