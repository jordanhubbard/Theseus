invariant io_extra212.FileIO_init_defaults_class_name:
  description: "_pyio.FileIO.__init__.__defaults__.__class__.__name__ == 'tuple' — FileIO.__init__ is a Python function with three default values (mode='r', closefd=True, opener=None); __defaults__ is a tuple; io.FileIO is a C extension with no __defaults__ attribute but _pyio.FileIO is the pure-Python equivalent; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: FileIO.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant io_extra212.FileIO_init_defaults_len_3:
  description: "_pyio.FileIO.__init__.__defaults__.__len__() == 3 — three positional defaults: mode='r', closefd=True, opener=None; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: FileIO.__init__.__defaults__.__len__
  args: []
  expected: 3

