spec: io_extra212
version: ">=3.9"
backend: python_module(_pyio)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/ — C extension implementations"
  notes:
    - "This spec covers: __defaults__ attributes of io class __init__ methods via the pure-Python _pyio module, since io.FileIO/StringIO/BytesIO/BufferedReader are C extensions (wrapper_descriptor) with no __defaults__ attribute."
    - "_pyio.FileIO.__init__.__defaults__ == ('r', True, None) — three defaults: mode='r', closefd=True, opener=None. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 3."
    - "_pyio.StringIO.__init__.__defaults__ == ('', '\\n') — two defaults: initial_value='' and newline='\\n'. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 2."
    - "_pyio.BytesIO.__init__.__defaults__ == (None,) — one default: initial_bytes=None. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "_pyio.BufferedReader.__init__.__defaults__ == (131072,) — one default: buffer_size=131072 (io.DEFAULT_BUFFER_SIZE). __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "The value 131072 equals io.DEFAULT_BUFFER_SIZE (2^17 = 131072). BufferedWriter and BufferedRWPair also default to 131072."
    - "All io.FileIO/StringIO/BytesIO/BufferedReader in the io module are C extensions imported from _io — they are wrapper_descriptor objects with no __defaults__ attribute. The _pyio module provides equivalent pure-Python implementations with inspectable __defaults__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _pyio.FileIO.__init__.__defaults__ — class name and length
#
# _pyio.FileIO.__init__ is a Python function with three default values:
#   mode='r', closefd=True, opener=None
# __defaults__ is a tuple of length 3.
# __defaults__.__class__.__name__ == 'tuple'
# __defaults__.__len__() == 3
# ---------------------------------------------------------------------------

table io_extra212.FileIO_init_defaults:
  description: "_pyio.FileIO.__init__.__defaults__ class name and length — defaults tuple ('r', True, None) for mode/closefd/opener params; __class__.__name__=='tuple'; __len__()==3; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: iodefaults212

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_defs_cls,     FileIO.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"], true, "_pyio.FileIO.__init__.__defaults__.__class__.__name__ == 'tuple' — three defaults: mode='r', closefd=True, opener=None; verified Python 3.14.3"]
    - [fileio_defs_len,     FileIO.__init__.__defaults__.__len__,                  [],        3,    "_pyio.FileIO.__init__.__defaults__.__len__() == 3 — defaults are (mode='r', closefd=True, opener=None); verified Python 3.14.3"]
    - [fileio_defs_not_none, FileIO.__init__.__defaults__.__class__.__name__.__eq__, ["NoneType"], false, "_pyio.FileIO.__init__.__defaults__.__class__.__name__ != 'NoneType' — FileIO has defaults unlike abstract base classes; verified Python 3.14.3"]
    - [fileio_defs_not_list, FileIO.__init__.__defaults__.__class__.__name__.__eq__, ["list"],     false, "_pyio.FileIO.__init__.__defaults__.__class__.__name__ != 'list' — __defaults__ is always a tuple in Python; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# _pyio.StringIO and _pyio.BytesIO __init__.__defaults__ — class name and length
#
# _pyio.StringIO.__init__ defaults: initial_value='', newline='\n'
#   __defaults__ == ('', '\n')  — length 2
# _pyio.BytesIO.__init__ defaults: initial_bytes=None
#   __defaults__ == (None,)  — length 1
# Both have __defaults__.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table io_extra212.StringIO_BytesIO_defaults:
  description: "_pyio.StringIO and BytesIO __init__.__defaults__ class name and length — StringIO: ('', '\\n') len=2; BytesIO: (None,) len=1; both are tuple; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: iodefaults212

  columns: [id, function, args, expected, description]
  rows:
    - [stringio_defs_cls,  StringIO.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"], true, "_pyio.StringIO.__init__.__defaults__.__class__.__name__ == 'tuple' — defaults are ('', '\\n') for initial_value and newline; verified Python 3.14.3"]
    - [stringio_defs_len,  StringIO.__init__.__defaults__.__len__,                   [],        2,    "_pyio.StringIO.__init__.__defaults__.__len__() == 2 — defaults for initial_value='' and newline='\\n'; verified Python 3.14.3"]
    - [bytesio_defs_cls,   BytesIO.__init__.__defaults__.__class__.__name__.__eq__,  ["tuple"], true, "_pyio.BytesIO.__init__.__defaults__.__class__.__name__ == 'tuple' — default is (None,) for initial_bytes; verified Python 3.14.3"]
    - [bytesio_defs_len,   BytesIO.__init__.__defaults__.__len__,                    [],        1,    "_pyio.BytesIO.__init__.__defaults__.__len__() == 1 — single default: initial_bytes=None; verified Python 3.14.3"]
    - [stringio_not_bytesio_len, StringIO.__init__.__defaults__.__len__,             [],        2,    "_pyio.StringIO.__init__.__defaults__.__len__() == 2, not 1 (StringIO has two defaults vs BytesIO's one); verified Python 3.14.3"]

