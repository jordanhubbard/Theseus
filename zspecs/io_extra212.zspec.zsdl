table io_extra212.BufferedReader_defaults:
  description: "_pyio.BufferedReader.__init__.__defaults__ class name and length — default (131072,) for buffer_size=DEFAULT_BUFFER_SIZE; __class__.__name__=='tuple'; __len__()==1; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: iodefaults212

  columns: [id, function, args, expected, description]
  rows:
    - [bufrd_defs_cls,      BufferedReader.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"],    true,  "_pyio.BufferedReader.__init__.__defaults__.__class__.__name__ == 'tuple' — default buffer_size=131072; verified Python 3.14.3"]
    - [bufrd_defs_len,      BufferedReader.__init__.__defaults__.__len__,                   [],           1,     "_pyio.BufferedReader.__init__.__defaults__.__len__() == 1 — single default: buffer_size=131072; verified Python 3.14.3"]
    - [bufrd_defs_not_none, BufferedReader.__init__.__defaults__.__class__.__name__.__eq__, ["NoneType"], false, "_pyio.BufferedReader.__init__.__defaults__.__class__.__name__ != 'NoneType' — defaults tuple exists; verified Python 3.14.3"]
    - [bytesio_bufrd_len_eq, BytesIO.__init__.__defaults__.__len__,                         [],           1,     "_pyio.BytesIO.__init__.__defaults__.__len__() == 1 — same length as BufferedReader (both have exactly one default); verified Python 3.14.3"]

