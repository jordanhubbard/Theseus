spec: functools_extra17
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra16.zspec.zsdl."
    - "functools_extra16 covers: reduce(max, seq); reduce(min, seq); reduce(max, ascending); partial(int, base=2).__call__('101')==5; partial(min,5).__call__(3)==3; partial(min,5).__call__(10)==5; partial(pow,2).__call__(10)==1024; partial(max,10).__call__(20)==20; partial(max,10).__call__(7)==10."
    - "functools_extra15 covers: partialmethod.__name__; partialmethod.__qualname__; partialmethod.__name__.__len__()==13; partialmethod.__qualname__.__len__()==13; total_ordering.__qualname__==total_ordering; WRAPPER_ASSIGNMENTS[5]=='__type_params__'; WRAPPER_UPDATES.__contains__('__dict__')==True."
    - "functools_extra14 covers: __name__.__len__() for cmp_to_key/total_ordering/lru_cache/singledispatch/singledispatchmethod; __qualname__.__len__() for the same set."
    - "functools_extra13 covers: __name__.__len__() for reduce/partial/wraps/cached_property; __qualname__.__len__() and __qualname__ string equality for partial/wraps/cached_property."
    - "NOT yet covered: wraps/__name__.__eq__ ('wraps'); singledispatch/__name__.__eq__ ('singledispatch'); cached_property/__name__.__eq__ ('cached_property'); cmp_to_key/__name__.__eq__ ('cmp_to_key'); lru_cache/__name__.__eq__ ('lru_cache'); reduce(operator.mul,...); WRAPPER_ASSIGNMENTS[0]/__eq__; WRAPPER_ASSIGNMENTS[1]/__eq__; WRAPPER_ASSIGNMENTS[2]/__eq__."
    - "functools.wraps.__name__ == 'wraps' — name equality (extra13 covers __len__() only)."
    - "functools.singledispatch.__name__ == 'singledispatch' — name equality (extra14 covers __len__() only)."
    - "functools.cached_property.__name__ == 'cached_property' — name equality (extra13 covers __len__() only)."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — name equality (extra14 covers __len__() only)."
    - "functools.lru_cache.__name__ == 'lru_cache' — name equality (extra14 covers __len__() only)."
    - "functools.reduce(operator.mul, [1,2,3,4]) == 24 — fold by multiplication."
    - "functools.WRAPPER_ASSIGNMENTS.__getitem__(0) == '__module__' — first tuple element."
    - "functools.WRAPPER_ASSIGNMENTS.__getitem__(1) == '__name__' — second tuple element."
    - "functools.WRAPPER_ASSIGNMENTS.__getitem__(2) == '__qualname__' — third tuple element."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ equality for wraps, singledispatch, cached_property, cmp_to_key,
# lru_cache — not yet asserted as standalone __eq__ invariants
#
# functools_extra13 covers __name__.__len__() for wraps and cached_property.
# functools_extra14 covers __name__.__len__() for singledispatch, cmp_to_key,
# and lru_cache. None of these have had their __name__ compared to the actual
# string value via __eq__ as a standalone invariant. These invariants supply that
# behavioral axis: name equality, not just length.
# ---------------------------------------------------------------------------

invariant functools_extra17.wraps.name_eq:
  description: "functools.wraps.__name__ == 'wraps' — name equality (extra13 covers __len__==5 only)"
  category: function_names
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra17.singledispatch.name_eq:
  description: "functools.singledispatch.__name__ == 'singledispatch' — name equality (extra14 covers __len__ only)"
  category: function_names
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra17.cached_property.name_eq:
  description: "functools.cached_property.__name__ == 'cached_property' — name equality (extra13 covers __len__ only)"
  category: function_names
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra17.cmp_to_key.name_eq:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' — name equality (extra14 covers __len__ only)"
  category: function_names
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra17.lru_cache.name_eq:
  description: "functools.lru_cache.__name__ == 'lru_cache' — name equality (extra14 covers __len__ only)"
  category: function_names
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

# ---------------------------------------------------------------------------
# reduce with operator.mul — fold by multiplication
#
# functools_extra2 covers reduce(operator.add, [1,2,3,4]) == 10.
# functools_extra16 covers reduce(max, seq) and reduce(min, seq).
# No prior spec tests reduce(operator.mul, seq). The fold by multiplication
# computes the product: reduce(mul, [1,2,3,4]) == 1*2*3*4 == 24.
# ---------------------------------------------------------------------------

invariant functools_extra17.reduce.mul_product:
  description: "reduce(mul, [1,2,3,4]) == 24 — fold by multiplication: 1*2*3*4"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: [mul, [1, 2, 3, 4]]
  expected: 24

invariant functools_extra17.reduce.mul_single:
  description: "reduce(mul, [1,2,3,4,5]) == 120 — fold by multiplication: 5!"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: [mul, [1, 2, 3, 4, 5]]
  expected: 120

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS element values — indices 0, 1, 2
#
# functools_extra9 covers WRAPPER_ASSIGNMENTS/__len__() == 5 (or 6 on 3.13+).
# functools_extra15 covers WRAPPER_ASSIGNMENTS[5] == '__type_params__'.
# No prior spec asserts WRAPPER_ASSIGNMENTS[0], [1], or [2] as standalone
# __eq__ invariants. These three indices are stable across Python 3.9+:
# [0]=='__module__', [1]=='__name__', [2]=='__qualname__'.
# ---------------------------------------------------------------------------

invariant functools_extra17.WRAPPER_ASSIGNMENTS.index0:
  description: "WRAPPER_ASSIGNMENTS[0] == '__module__' — first tuple element is stable across 3.9+"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [0]
  expected: "__module__"

invariant functools_extra17.WRAPPER_ASSIGNMENTS.index1:
  description: "WRAPPER_ASSIGNMENTS[1] == '__name__' — second tuple element is stable across 3.9+"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [1]
  expected: "__name__"

invariant functools_extra17.WRAPPER_ASSIGNMENTS.index2:
  description: "WRAPPER_ASSIGNMENTS[2] == '__qualname__' — third tuple element is stable across 3.9+"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [2]
  expected: "__qualname__"

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS.__contains__ — membership checks for stable attribute names
#
# functools_extra15 covers WRAPPER_UPDATES.__contains__('__dict__') == True.
# No prior spec tests WRAPPER_ASSIGNMENTS.__contains__ for any attribute name.
# '__module__', '__name__', and '__doc__' are present in all Python 3.9+ versions.
# ---------------------------------------------------------------------------

invariant functools_extra17.WRAPPER_ASSIGNMENTS.contains_module:
  description: "WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — present since 3.2+"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra17.WRAPPER_ASSIGNMENTS.contains_doc:
  description: "WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — present in all supported versions"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true
