spec: multiprocessing_extra184
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "multiprocessing.synchronize.Lock.__name__ == 'Lock' (len=4); Lock.__bases__[0].__name__ == 'SemLock'."
    - "multiprocessing.synchronize.RLock.__name__ == 'RLock' (len=5); RLock.__bases__[0].__name__ == 'SemLock' (not Lock — verified Python 3.14.3)."
    - "multiprocessing.synchronize.Semaphore.__name__ == 'Semaphore' (len=9); Semaphore.__module__ == 'multiprocessing.synchronize'."
    - "multiprocessing.synchronize.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16); BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

