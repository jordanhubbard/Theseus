spec: decimal_extra75
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra74."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for arithmetic/conversion/comparison dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context.__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership."
    - "This spec covers: Context.__init__/__class__.__name__ (wrapper_descriptor, no __code__); Context.sqrt/__class__.__name__; Context.exp/__class__.__name__; Context.ln/__class__.__name__; Context.log10/__class__.__name__; Context.power/__class__.__name__; Context.__dict__.__class__.__name__; Context.__dict__.__contains__ for __init__, sqrt, exp, power, ln, log10; Context.__bases__[0].__name__; Context.__mro__.__len__()."
    - "decimal.Context.__init__.__class__.__name__ == 'wrapper_descriptor' — Context is a C type; __init__ is a C slot wrapper without __code__."
    - "decimal.Context.sqrt.__class__.__name__ == 'method_descriptor' — sqrt is a C method_descriptor on the Context C type."
    - "decimal.Context.exp.__class__.__name__ == 'method_descriptor' — exp is a C method_descriptor on the Context C type."
    - "decimal.Context.ln.__class__.__name__ == 'method_descriptor' — ln is a C method_descriptor on the Context C type."
    - "decimal.Context.log10.__class__.__name__ == 'method_descriptor' — log10 is a C method_descriptor on the Context C type."
    - "decimal.Context.power.__class__.__name__ == 'method_descriptor' — power is a C method_descriptor on the Context C type."
    - "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy' — the __dict__ of a C type is a mappingproxy."
    - "decimal.Context.__dict__.__contains__('__init__') == True — __init__ is defined directly in Context."
    - "decimal.Context.__dict__.__contains__('sqrt') == True — sqrt is defined directly in Context."
    - "decimal.Context.__dict__.__contains__('exp') == True — exp is defined directly in Context."
    - "decimal.Context.__dict__.__contains__('power') == True — power is defined directly in Context."
    - "decimal.Context.__dict__.__contains__('ln') == True — ln is defined directly in Context."
    - "decimal.Context.__dict__.__contains__('log10') == True — log10 is defined directly in Context."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object."
    - "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context.__init__ class name
# Context is a C type; __init__ is a wrapper_descriptor (C slot), not a Python
# function, so it has no __code__ attribute.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra75.Context_init_class:
  description: "Context.__init__.__class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra75

  columns: [id, function, args, expected]
  rows:
    - [ctx_init_cls, Context.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Context.sqrt, Context.exp, Context.ln, Context.log10 class names
# All four are C method_descriptors defined directly on the Context C type.
# __class__.__name__ == 'method_descriptor' for each.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra75.Context_math_methods_class:
  description: "Context.sqrt, Context.exp, Context.ln, Context.log10 __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra75

  columns: [id, function, args, expected]
  rows:
    - [sqrt_cls,  Context.sqrt.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [exp_cls,   Context.exp.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [ln_cls,    Context.ln.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [log10_cls, Context.log10.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# Context.power __class__.__name__ and Context.__dict__ class name
# power is also a method_descriptor. Context.__dict__ is a mappingproxy.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra75.Context_power_and_dict_class:
  description: "Context.power __class__.__name__ and Context.__dict__.__class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra75

  columns: [id, function, args, expected]
  rows:
    - [power_cls,    Context.power.__class__.__name__.__eq__,         ["method_descriptor"], true]
    - [ctx_dict_cls, Context.__dict__.__class__.__name__.__eq__,      ["mappingproxy"],      true]

# ---------------------------------------------------------------------------
# Context.__dict__ membership, __bases__[0].__name__, and __mro__.__len__()
# __init__, sqrt, exp, power, ln, log10 are all defined directly on Context.
# Context inherits from object only; MRO length 2.
# Function values with [ must be double-quoted.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra75.Context_dict_membership_and_hierarchy:
  description: "Context.__dict__ membership for key methods and Context hierarchy"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalextra75

  columns: [id, function, args, expected]
  rows:
    - [has_init,     "Context.__dict__.__contains__", ["__init__"], true]
    - [has_sqrt,     "Context.__dict__.__contains__", ["sqrt"],     true]
    - [has_exp,      "Context.__dict__.__contains__", ["exp"],      true]
    - [has_power,    "Context.__dict__.__contains__", ["power"],    true]
    - [has_ln,       "Context.__dict__.__contains__", ["ln"],       true]
    - [has_log10,    "Context.__dict__.__contains__", ["log10"],    true]
    - [ctx_base0,    "Context.__bases__[0].__name__.__eq__",        ["object"],  true]
    - [ctx_mro_len,  Context.__mro__.__len__,                       [],          2]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra75.Context_init.class_name:
  description: "decimal.Context.__init__.__class__.__name__ == 'wrapper_descriptor' (C slot, no __code__)"
  category: class_identity
  kind: python_call_eq
  function: Context.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra75.Context_sqrt.class_name:
  description: "decimal.Context.sqrt.__class__.__name__ == 'method_descriptor'"
  category: class_identity
  kind: python_call_eq
  function: Context.sqrt.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra75.Context_dict.class_name:
  description: "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_identity
  kind: python_call_eq
  function: Context.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant decimal_extra75.Context_dict.has_sqrt:
  description: "decimal.Context.__dict__.__contains__('sqrt') == True"
  category: class_dict
  kind: python_call_eq
  function: "Context.__dict__.__contains__"
  args: ["sqrt"]
  expected: true

invariant decimal_extra75.Context.mro_len:
  description: "decimal.Context.__mro__.__len__() == 2 ([Context, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2
