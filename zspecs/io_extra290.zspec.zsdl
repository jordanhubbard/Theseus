spec: io_extra290
version: ">=3.9"
backend: python_module(_io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers IOBase, RawIOBase, FileIO, BytesIO, StringIO, BufferedRandom, TextIOWrapper, IncrementalNewlineDecoder class names and modules"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper, BufferedRandom, UnsupportedOperation"
    - "io_extra289.zspec.zsdl — covers BytesIO write/read roundtrip behavior"
  notes:
    - "This spec focuses on the _io module's own identity as a C built-in extension."
    - "_io.__name__ == '_io' — the module's __name__ attribute reflects the internal C module name."
    - "_io.__loader__.__name__ == 'BuiltinImporter' — the module was loaded by importlib._bootstrap.BuiltinImporter."
    - "_io.__spec__.origin == 'built-in' — the import system marks built-in C extensions with origin 'built-in'."
    - "_io.__spec__.name == '_io' — the spec name matches the module name."
    - "_io.__package__ == '' — built-in modules have an empty package string."
    - "_io.BytesIO.__module__ == '_io' — BytesIO is defined in the C extension, not in the pure-Python io wrapper."
    - "_io.StringIO.__module__ == '_io' — StringIO is also defined in the C extension."
    - "_io.BufferedReader.__module__ == '_io' — BufferedReader is a C class."
    - "_io.FileIO.__module__ == '_io' — FileIO is a C class."
    - "Contrast: io.__spec__.origin == 'frozen' — the pure-Python io wrapper module is a frozen module, not built-in."
    - "Contrast: io.__loader__.__name__ == 'FrozenImporter' — io uses FrozenImporter, not BuiltinImporter."
    - "Contrast: io.BytesIO.__module__ == '_io' — even via the io namespace, BytesIO's module is '_io'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _io module identity — name, loader, spec origin, spec name, package
#
# The _io module is a built-in C extension. Its __spec__.origin is 'built-in',
# its __loader__ is BuiltinImporter, and __package__ is ''.
# ---------------------------------------------------------------------------

table io_extra290.module_identity:
  description: "_io module identity: __name__, __loader__, __spec__.origin, __spec__.name, __package__"
  kind: python_call_eq
  category: module_identity
  id_prefix: mid290

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,    __name__.__eq__,                ["_io"],          true, "_io.__name__ == '_io' — the C module name"]
    - [loader_name,    __loader__.__name__.__eq__,      ["BuiltinImporter"], true, "_io.__loader__.__name__ == 'BuiltinImporter' — loaded by the built-in importer"]
    - [spec_origin,    __spec__.origin.__eq__,          ["built-in"],    true, "_io.__spec__.origin == 'built-in' — built-in C extension"]
    - [spec_name,      __spec__.name.__eq__,            ["_io"],          true, "_io.__spec__.name == '_io' — spec name matches module name"]
    - [package,        __package__.__eq__,              [""],             true, "_io.__package__ == '' — built-in modules have empty package string"]

# ---------------------------------------------------------------------------
# _io class __module__ attributes — all classes are defined in the C extension
#
# BytesIO, StringIO, BufferedReader, FileIO, BufferedWriter all have
# __module__ == '_io', confirming they originate from the C extension.
# ---------------------------------------------------------------------------

table io_extra290.class_modules:
  description: "_io classes have __module__ == '_io' confirming C-extension origin"
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod290

  columns: [id, function, args, expected, description]
  rows:
    - [BytesIO_module,        BytesIO.__module__.__eq__,         ["_io"], true, "_io.BytesIO.__module__ == '_io'"]
    - [StringIO_module,       StringIO.__module__.__eq__,        ["_io"], true, "_io.StringIO.__module__ == '_io'"]
    - [BufferedReader_module, BufferedReader.__module__.__eq__,  ["_io"], true, "_io.BufferedReader.__module__ == '_io'"]
    - [FileIO_module,         FileIO.__module__.__eq__,          ["_io"], true, "_io.FileIO.__module__ == '_io'"]
    - [BufferedWriter_module, BufferedWriter.__module__.__eq__,  ["_io"], true, "_io.BufferedWriter.__module__ == '_io'"]
    - [TextIOWrapper_module,  TextIOWrapper.__module__.__eq__,   ["_io"], true, "_io.TextIOWrapper.__module__ == '_io'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra290.module_name_is__io:
  description: "_io.__name__ == '_io' — the built-in C extension reports its internal name, not 'io'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra290.loader_is_BuiltinImporter:
  description: "_io.__loader__.__name__ == 'BuiltinImporter' — built-in modules are loaded by importlib._bootstrap.BuiltinImporter"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["BuiltinImporter"]
  expected: true

invariant io_extra290.spec_origin_is_built_in:
  description: "_io.__spec__.origin == 'built-in' — the import system classifies built-in C extensions with origin 'built-in'"
  category: module_identity
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["built-in"]
  expected: true

invariant io_extra290.BytesIO_module_is__io:
  description: "_io.BytesIO.__module__ == '_io' — BytesIO is implemented in the C extension, not in the pure-Python io wrapper"
  category: class_modules
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra290.FileIO_base_is__RawIOBase:
  description: "_io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO's direct base class is _RawIOBase from the C extension"
  category: class_hierarchy
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_RawIOBase"

invariant io_extra290.BytesIO_base_is__BufferedIOBase:
  description: "_io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO's direct base class is _BufferedIOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_BufferedIOBase"

invariant io_extra290.StringIO_base_is__TextIOBase:
  description: "_io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO's direct base class is _TextIOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_TextIOBase"
