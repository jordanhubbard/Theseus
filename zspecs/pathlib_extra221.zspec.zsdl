spec: pathlib_extra221
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra220.zspec.zsdl — covers pathlib class __doc__ string contains checks"
  notes:
    - "pathlib.Path(42) raises TypeError: argument should be a str or an os.PathLike object where __fspath__ returns a str; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/etc/passwd').relative_to('/usr') raises ValueError: '/etc/passwd' is not in the subpath of '/usr'; confirmed Python 3.14.3 macOS."
    - "pathlib.Path('/tmp/theseus_nonexistent_xyz').chmod(0o644) raises FileNotFoundError; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath('/tmp') raises NotImplementedError: cannot instantiate 'WindowsPath' on your system; confirmed Python 3.14.3 macOS (POSIX)."
    - "pathlib.PurePosixPath('\\x00') does NOT raise in Python 3.14.3; null bytes are accepted in PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath'; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__name__ == 'PurePath'; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib constructor errors
# Path(42) raises TypeError; WindowsPath on POSIX raises NotImplementedError
# ---------------------------------------------------------------------------

table pathlib_extra221.constructor_errors:
  description: "pathlib constructor errors for invalid argument types and platform-incompatible classes"
  kind: python_call_raises
  category: errors
  id_prefix: pathlibconstrerr221a

  columns: [id, function, args, expected, description]
  rows:
    - [path_int_arg,         pathlib.Path,        [42],        TypeError,          "pathlib.Path(42) raises TypeError — argument must be str or os.PathLike, not int"]
    - [windowspath_on_posix, pathlib.WindowsPath, ["/tmp"],    NotImplementedError, "pathlib.WindowsPath('/tmp') raises NotImplementedError on POSIX systems"]

# ---------------------------------------------------------------------------
# Table 2: pathlib operation errors
# relative_to non-relative path and chmod on nonexistent
# ---------------------------------------------------------------------------

table pathlib_extra221.operation_errors:
  description: "pathlib.PurePosixPath.relative_to raises ValueError for non-subpath; Path.chmod raises FileNotFoundError for missing file"
  kind: python_call_raises
  category: errors
  id_prefix: pathliboPerr221b

  columns: [id, function, args, expected, description]
  rows:
    - [relative_to_non_subpath, pathlib.PurePosixPath,  ["/etc/passwd"],  ValueError,         "pathlib.PurePosixPath('/etc/passwd').relative_to('/usr') raises ValueError — not in subpath"]
    - [chmod_nonexistent,       pathlib.Path,            ["/tmp/theseus_nonexistent_xyz"],  FileNotFoundError,  "pathlib.Path('/tmp/nonexistent').chmod(0o644) raises FileNotFoundError — path does not exist"]

# ---------------------------------------------------------------------------
# Table 3: pathlib class identity checks
# __name__ for PurePath, PurePosixPath, PurePosixPath
# ---------------------------------------------------------------------------

table pathlib_extra221.class_name_identity:
  description: "pathlib class __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibcnameid221c

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_name,       pathlib.PurePath.__name__.__eq__,       ["PurePath"],       true,  "pathlib.PurePath.__name__ == 'PurePath'; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_name,  pathlib.PurePosixPath.__name__.__eq__,  ["PurePosixPath"],  true,  "pathlib.PurePosixPath.__name__ == 'PurePosixPath'; confirmed Python 3.14.3 macOS"]
    - [path_name,           pathlib.Path.__name__.__eq__,           ["Path"],           true,  "pathlib.Path.__name__ == 'Path'; confirmed Python 3.14.3 macOS"]
    - [windowspath_name,    pathlib.WindowsPath.__name__.__eq__,    ["WindowsPath"],    true,  "pathlib.WindowsPath.__name__ == 'WindowsPath'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra221.path_int_arg:
  description: "pathlib.Path(42) raises TypeError — argument must be str or os.PathLike, not int; confirmed Python 3.14.3 macOS"
  category: errors
  kind: python_call_raises
  function: pathlib.Path
  args: [42]
  expected: TypeError

invariant pathlib_extra221.windowspath_on_posix:
  description: "pathlib.WindowsPath('/tmp') raises NotImplementedError on POSIX systems; confirmed Python 3.14.3 macOS"
  category: errors
  kind: python_call_raises
  function: pathlib.WindowsPath
  args: ["/tmp"]
  expected: NotImplementedError

invariant pathlib_extra221.purepath_name:
  description: "pathlib.PurePath.__name__ == 'PurePath'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra221.pureposixpath_name:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra221.path_name:
  description: "pathlib.Path.__name__ == 'Path'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__name__.__eq__
  args: ["Path"]
  expected: true
