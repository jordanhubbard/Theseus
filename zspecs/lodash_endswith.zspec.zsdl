spec: lodash_endswith
version: ">=4.0.0"
backend: node(lodash.endswith)

docs: https://lodash.com/docs/#endsWith

provenance:
  derived_from:
    - "lodash.endswith README — https://www.npmjs.com/package/lodash.endswith"
    - "Test vectors verified with lodash.endswith@4.2.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.endswith exports the _.endsWith function directly as module.exports."
    - "endsWith(string, target, position) checks if string ends with target."
    - "Optional position acts as the end of the string for the check."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_endswith.endswith:
  kind: node_module_call_eq
  function: ~
  category: endswith
  id_prefix: lew

  columns: [id, args, expected]
  rows:
    - [match,       ["hello world", "world"],    true]
    - [no_match,    ["hello world", "hello"],    false]
    - [empty_tgt,   ["hello", ""],               true]
    - [full_match,  ["abc", "abc"],              true]
    - [with_pos,    ["hello", "ell", 4],         true]
