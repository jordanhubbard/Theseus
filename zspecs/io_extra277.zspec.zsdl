spec: io_extra277
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.open is an alias for the C-extension builtin_function_or_method from _io."
    - "io.open.__name__ == 'open' and io.open.__module__ == '_io'."
    - "io.open.__qualname__ == 'open' (same as __name__ for top-level builtins)."
    - "io.open_code is a separate builtin for opening source files; __name__ == 'open_code'."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB) on CPython 3.14.3 — NOT 8192."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2; all of type int."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: io.open and io.open_code function identity
# ---------------------------------------------------------------------------

table io_extra277.open_function_identity:
  description: "io.open and io.open_code __name__, __module__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ofi

  columns: [id, function, args, expected, description]
  rows:
    - [open_name,       open.__name__.__eq__,                ["open"],                       true, "io.open.__name__ == 'open'"]
    - [open_module,     open.__module__.__eq__,              ["_io"],                        true, "io.open.__module__ == '_io'"]
    - [open_class,      open.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "io.open.__class__.__name__ == 'builtin_function_or_method'"]
    - [open_qualname,   open.__qualname__.__eq__,            ["open"],                       true, "io.open.__qualname__ == 'open'"]
    - [open_code_name,  open_code.__name__.__eq__,           ["open_code"],                  true, "io.open_code.__name__ == 'open_code'"]
    - [open_code_mod,   open_code.__module__.__eq__,         ["_io"],                        true, "io.open_code.__module__ == '_io'"]
    - [open_code_class, open_code.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "io.open_code.__class__.__name__ == 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# Table: io module integer constants
# ---------------------------------------------------------------------------

table io_extra277.io_constants:
  description: "io module integer constants: DEFAULT_BUFFER_SIZE (131072), SEEK_SET (0), SEEK_CUR (1), SEEK_END (2)"
  kind: python_call_eq
  category: identity
  id_prefix: con

  columns: [id, function, args, expected, description]
  rows:
    - [default_buf_val,   DEFAULT_BUFFER_SIZE.__eq__,             [131072], true, "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB on CPython 3.14.3)"]
    - [default_buf_class, DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true, "type(io.DEFAULT_BUFFER_SIZE).__name__ == 'int'"]
    - [seek_set_val,      SEEK_SET.__eq__,                        [0],     true, "io.SEEK_SET == 0"]
    - [seek_cur_val,      SEEK_CUR.__eq__,                        [1],     true, "io.SEEK_CUR == 1"]
    - [seek_end_val,      SEEK_END.__eq__,                        [2],     true, "io.SEEK_END == 2"]
    - [seek_set_class,    SEEK_SET.__class__.__name__.__eq__,     ["int"], true, "type(io.SEEK_SET).__name__ == 'int'"]
    - [seek_cur_class,    SEEK_CUR.__class__.__name__.__eq__,     ["int"], true, "type(io.SEEK_CUR).__name__ == 'int'"]
    - [seek_end_class,    SEEK_END.__class__.__name__.__eq__,     ["int"], true, "type(io.SEEK_END).__name__ == 'int'"]

# ---------------------------------------------------------------------------
# Standalone invariants: open qualname and open_code identity
# ---------------------------------------------------------------------------

invariant io_extra277.open.qualname:
  description: "io.open.__qualname__ == 'open'"
  category: identity
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant io_extra277.open_code.qualname:
  description: "io.open_code.__qualname__ == 'open_code'"
  category: identity
  kind: python_call_eq
  function: open_code.__qualname__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra277.DEFAULT_BUFFER_SIZE.is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra277.SEEK_SET.value:
  description: "io.SEEK_SET == 0"
  category: identity
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra277.SEEK_CUR.value:
  description: "io.SEEK_CUR == 1"
  category: identity
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra277.SEEK_END.value:
  description: "io.SEEK_END == 2"
  category: identity
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true
