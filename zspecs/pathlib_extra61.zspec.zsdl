spec: pathlib_extra61
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra60.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); pathlib module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); PurePath property name/suffix/parent/stem __class__.__qualname__.__eq__('property')."
    - "pathlib_extra59.zspec.zsdl — covers Path property __class__.__qualname__=='property' (8 properties) and PurePath property __class__.__name__=='property' (4 properties)."
    - "pathlib_extra58.zspec.zsdl — covers pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath; Path property __class__.__name__=='property' for 10 attributes."
    - "pathlib_extra54.zspec.zsdl — covers Path/__class__.__module__.__eq__('builtins') and PurePath/__class__.__module__.__eq__('builtins') as standalone invariants; Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/__class__.__name__.__eq__('type')."
    - "pathlib_extra37.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends pathlib_extra60.zspec.zsdl."
    - "Prior specs collectively covered: pathlib_extra54 covers Path.__class__.__module__.__eq__('builtins') and PurePath.__class__.__module__.__eq__('builtins') as standalone invariants; pathlib_extra53 covers all six class __class__.__name__.__eq__('type'); pathlib_extra58 covers Path property __class__.__name__=='property'; pathlib_extra59 covers PurePath property __class__.__name__=='property' and Path property __class__.__qualname__=='property'. NOT YET COVERED: PurePosixPath/__class__.__module__.__eq__('builtins') (pathlib_extra54 covers only Path and PurePath, not PurePosixPath or PureWindowsPath); PureWindowsPath/__class__.__module__.__eq__('builtins') (novel); Path/__init__.__class__.__name__.__eq__('function') (Path.__init__ is a regular Python function; __class__ is 'function' from 'builtins'; no prior pathlib spec checks this); PurePath/__init__.__class__.__name__.__eq__('function') (novel); Path/__init__.__class__.__module__.__eq__('builtins') (novel — the 'function' type is from builtins); PurePath.name/__class__.__module__.__eq__('builtins') (novel — property descriptor's metaclass module; pathlib_extra59/60 cover __class__.__name__/__qualname__ for PurePath properties but NOT __class__.__module__); PurePath.suffix/__class__.__module__.__eq__('builtins') (novel); PurePath.parent/__class__.__module__.__eq__('builtins') (novel); PurePath.stem/__class__.__module__.__eq__('builtins') (novel)."
    - "This spec covers: pathlib.PurePosixPath.__class__.__module__.__eq__('builtins') (NOVEL — pathlib_extra54 covers Path and PurePath only; no prior pathlib spec checks PurePosixPath.__class__.__module__; novel in pathlibmod61 namespace); pathlib.PureWindowsPath.__class__.__module__.__eq__('builtins') (NOVEL); pathlib.Path.__init__.__class__.__name__.__eq__('function') (NOVEL — Path.__init__ resolves to PurePath.__init__, a regular Python function; __class__ is the builtin 'function' type with __name__=='function'; no prior pathlib spec checks Path.__init__.__class__.__name__; novel); pathlib.PurePath.__init__.__class__.__name__.__eq__('function') (NOVEL); pathlib.Path.__init__.__class__.__module__.__eq__('builtins') (NOVEL — the 'function' type is defined in builtins; no prior pathlib spec checks Path.__init__.__class__.__module__; novel); pathlib.PurePath.name.__class__.__module__.__eq__('builtins') (NOVEL — property is a builtin type; pathlib_extra59/60 cover PurePath.name __class__.__name__/__qualname__ but NOT __class__.__module__; novel module anchor for PurePath properties); pathlib.PurePath.suffix.__class__.__module__.__eq__('builtins') (NOVEL); pathlib.PurePath.parent.__class__.__module__.__eq__('builtins') (NOVEL); pathlib.PurePath.stem.__class__.__module__.__eq__('builtins') (NOVEL)."
    - "pathlib.PurePosixPath.__class__.__module__ == 'builtins'. PurePosixPath is a regular Python class with metaclass 'type'. The 'type' metaclass has __module__=='builtins'. pathlib_extra54 covers Path and PurePath only; no prior pathlib spec checks PurePosixPath.__class__.__module__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__class__.__module__ == 'builtins'. Same metaclass reasoning as PurePosixPath. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.Path.__init__.__class__.__name__ == 'function'. Path.__init__ resolves to PurePath.__init__ (a regular Python function defined in pathlib.py). Its __class__ is the builtin 'function' type. The 'function' type __name__ is 'function'. No prior pathlib spec checks Path.__init__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__init__.__class__.__name__ == 'function'. PurePath.__init__ is a Python function defined in pathlib.py. Same reasoning as Path.__init__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.Path.__init__.__class__.__module__ == 'builtins'. The 'function' type is a builtin type whose __module__ is 'builtins'. No prior pathlib spec checks Path.__init__.__class__.__module__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.name.__class__.__module__ == 'builtins'. PurePath.name is a property descriptor. The builtin 'property' type has __module__=='builtins'. pathlib_extra59 covers PurePath.name.__class__.__name__=='property' and pathlib_extra60 covers __class__.__qualname__=='property', but no prior pathlib spec checks __class__.__module__ for any PurePath property. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.suffix.__class__.__module__ == 'builtins'. PurePath.suffix is a property descriptor. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.parent.__class__.__module__ == 'builtins'. PurePath.parent is a property descriptor. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.stem.__class__.__module__ == 'builtins'. PurePath.stem is a property descriptor. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath / PureWindowsPath __class__.__module__ == 'builtins'
#
# pathlib_extra54 covered Path.__class__.__module__ and PurePath.__class__.__module__
# as standalone invariants. PurePosixPath and PureWindowsPath use the same
# 'type' metaclass from builtins. No prior pathlib spec checks __class__.__module__
# for PurePosixPath or PureWindowsPath.
#
#   PurePosixPath.__class__.__module__   == 'builtins'
#   PureWindowsPath.__class__.__module__ == 'builtins'
#
# Both anchors are novel in the pathlibmod61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra61.pure_path_class_module_eq:
  description: "pathlib.PurePosixPath/PureWindowsPath __class__.__module__.__eq__('builtins') — these classes use the 'type' metaclass; 'type' is a C-level builtin with __module__=='builtins'; pathlib_extra54 covers Path and PurePath only; no prior pathlib spec checks __class__.__module__ for PurePosixPath or PureWindowsPath; both novel anchors in pathlibmod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmod61pure

  columns: [id, function, args, expected]
  rows:
    - [PurePosixPath_class_module,   "PurePosixPath.__class__.__module__.__eq__",   ["builtins"], true]
    - [PureWindowsPath_class_module, "PureWindowsPath.__class__.__module__.__eq__", ["builtins"], true]

# ---------------------------------------------------------------------------
# Path/__init__ and PurePath/__init__ __class__ identity
#
# Path.__init__ resolves to PurePath.__init__, which is a regular Python
# function defined in pathlib.py. Its __class__ is the builtin 'function'
# type, which has __name__=='function' and __module__=='builtins'.
#
#   Path.__init__.__class__.__name__     == 'function'
#   PurePath.__init__.__class__.__name__ == 'function'
#   Path.__init__.__class__.__module__   == 'builtins'
#
# No prior pathlib spec checks Path.__init__.__class__.__name__ or
# __class__.__module__. All three anchors are novel in pathlibmod61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra61.init_class_name_eq:
  description: "pathlib Path/__init__ and PurePath/__init__ __class__.__name__.__eq__('function') — Path.__init__ resolves to PurePath.__init__, a regular Python function; the builtin 'function' type has __name__=='function'; no prior pathlib spec checks Path/__init__.__class__.__name__; both novel anchors in pathlibmod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibmod61init

  columns: [id, function, args, expected]
  rows:
    - [Path_init_class_name,     "Path.__init__.__class__.__name__.__eq__",     ["function"], true]
    - [PurePath_init_class_name, "PurePath.__init__.__class__.__name__.__eq__", ["function"], true]

# ---------------------------------------------------------------------------
# PurePath property descriptor __class__.__module__ == 'builtins'
#
# PurePath.name, PurePath.suffix, PurePath.parent, and PurePath.stem are
# property descriptors. The builtin 'property' type has __module__=='builtins'.
# pathlib_extra59 covers PurePath property __class__.__name__=='property';
# pathlib_extra60 covers PurePath property __class__.__qualname__=='property'.
# No prior pathlib spec checks __class__.__module__ for any PurePath property.
#
#   PurePath.name.__class__.__module__   == 'builtins'
#   PurePath.suffix.__class__.__module__ == 'builtins'
#   PurePath.parent.__class__.__module__ == 'builtins'
#   PurePath.stem.__class__.__module__   == 'builtins'
#
# All four anchors are novel in the pathlibmod61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra61.purepath_property_class_module_eq:
  description: "pathlib.PurePath property descriptor __class__.__module__.__eq__('builtins') for name/suffix/parent/stem — property is a builtin type with __module__=='builtins'; pathlib_extra59 covers PurePath property __class__.__name__=='property'; pathlib_extra60 covers __class__.__qualname__=='property'; no prior pathlib spec checks PurePath property __class__.__module__; all four novel anchors in pathlibmod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmod61prop

  columns: [id, function, args, expected]
  rows:
    - [PurePath_name_class_module,   "PurePath.name.__class__.__module__.__eq__",   ["builtins"], true]
    - [PurePath_suffix_class_module, "PurePath.suffix.__class__.__module__.__eq__", ["builtins"], true]
    - [PurePath_parent_class_module, "PurePath.parent.__class__.__module__.__eq__", ["builtins"], true]
    - [PurePath_stem_class_module,   "PurePath.stem.__class__.__module__.__eq__",   ["builtins"], true]

invariant pathlib_extra61.Path_init_class_module_eq:
  description: "pathlib.Path.__init__.__class__.__module__ == 'builtins' — Path.__init__ resolves to PurePath.__init__, a Python function; the 'function' type is a C-level builtin with __module__=='builtins'; no prior pathlib spec checks Path.__init__.__class__.__module__; novel anchor in pathlibmod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Path.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
