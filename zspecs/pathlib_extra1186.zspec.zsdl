    - "https://docs.python.org/3/library/pathlib.html — pathlib class __dict__.__class__.__name__ (mappingproxy), __mro__.__class__.__name__ (tuple), and __subclasses__.__qualname__ checks for Path, PurePath, PurePosixPath, PosixPath"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.Path.__dict__.__class__.__name__, pathlib.PurePath.__dict__.__class__.__name__, pathlib.PurePosixPath.__dict__.__class__.__name__, pathlib.PosixPath.__dict__.__class__.__name__ (all mappingproxy); pathlib.Path.__mro__.__class__.__name__, pathlib.PurePath.__mro__.__class__.__name__ (tuple); pathlib.PurePath.__subclasses__.__qualname__, pathlib.Path.__subclasses__.__qualname__; none of these __dict__.__class__.__name__, __mro__.__class__.__name__, or __subclasses__.__qualname__ checks were covered in _extra1156 or _extra1171"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

