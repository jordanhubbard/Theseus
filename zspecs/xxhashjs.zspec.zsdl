spec: xxhashjs
version: ">=0.2.0"
backend: node(xxhashjs)

docs: https://www.npmjs.com/package/xxhashjs

provenance:
  derived_from:
    - "xxhashjs README — https://www.npmjs.com/package/xxhashjs"
    - "Test vectors verified with xxhashjs via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "xxhashjs source"
  notes:
    - "xxhashjs is an npm package. Install: npm install xxhashjs"
    - "xxhash.h32(str, seed).toString() returns the 32-bit xxHash as a decimal string."
    - "xxhash.h64(str, seed).toString() returns the 64-bit xxHash as a decimal string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns decimal hash string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table xxhashjs.h32:
  kind: node_factory_call_eq
  factory: h32
  method: toString
  category: hash
  id_prefix: xxh32

  columns: [id, factory_args, expected]
  rows:
    - [hello, ["hello", 0], "4211111929"]
    - [world, ["world", 0], "413819571"]

table xxhashjs.h64:
  kind: node_factory_call_eq
  factory: h64
  method: toString
  category: hash
  id_prefix: xxh64

  columns: [id, factory_args, expected]
  rows:
    - [hello, ["hello", 0], "2794345569481354659"]
