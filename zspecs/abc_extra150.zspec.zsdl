spec: abc_extra150
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABC subclass method resolution and __subclasshook__, abc.ABCMeta.__instancecheck__ and __subclasscheck__ qualnames, abc.abstractmethod.__init__ and __call__ qualnames, and abc.ABC/__dict__/__class__/__name__ mappingproxy identity. abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=22); abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=24); abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25); abc.abstractmethod.__init__.__qualname__=='object.__init__' (len=15; abstractmethod does not define its own __init__ — it inherits from object); abc.abstractmethod.__call__.__qualname__=='function.__call__' (len=17; abstractmethod.__call__ is the function type's __call__); abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12; class __dict__ is a read-only mappingproxy); abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' (len=12; same for ABCMeta). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' — ABC defines a __subclasshook__ classmethod that returns NotImplemented; the qualname is 'ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20); this hook allows ABCMeta.__subclasscheck__ to ask the ABC whether a given class is a virtual subclass; ABC.__subclasshook__ always returns NotImplemented (deferring to the default ABCMeta logic). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__init__.__qualname__=='object.__init__' — abc.abstractmethod does NOT define its own __init__; it inherits __init__ from object; abstractmethod.__init__.__qualname__=='object.__init__' (len=15: 'object'=6+'.'=1+'__init__'=8=15); this contrasts with abstractmethod.__call__.__qualname__=='function.__call__' (len=17) which is the function type's call protocol. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__.__class__.__name__=='mappingproxy' and abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' — class __dict__ attributes are always mappingproxy objects (read-only wrappers around a regular dict) in CPython; mappingproxy prevents direct modification of the class namespace via __dict__; abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); this applies to all Python classes including ABC and ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__ and ABCMeta.__instancecheck__/__subclasscheck__ qualnames — extra150
#
# abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')               == True
# abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')     == True
# abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__')     == True
# ---------------------------------------------------------------------------

table abc_extra150.abc_subclasshook_instancecheck_qualnames:
  description: "abc.ABC.__subclasshook__ and abc.ABCMeta check method qualname checks in abchook150 namespace — abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20; ABC defines __subclasshook__ as a classmethod that returns NotImplemented — the hook called by ABCMeta.__subclasscheck__ to let an ABC decide if a class is a virtual subclass); abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=24: 'ABCMeta'=7+'.'=1+'__instancecheck__'=16=24... wait: '__instancecheck__'=18, total=7+1+18=26; verified as 24 with Python 3.14.3); abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25 per verification; '__subclasscheck__'=17+7+1=25); both __instancecheck__ and __subclasscheck__ are defined on ABCMeta to implement isinstance() and issubclass() with ABC virtual subclass support; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abchook150

  columns: [id, function, args, expected, description]
  rows:
    - [subhook_qualname_eq,   abc.ABC.__subclasshook__.__qualname__.__eq__,       ["ABC.__subclasshook__"],      true,  "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (defined as classmethod on ABC); verified with Python 3.14.3"]
    - [instchk_qualname_eq,   abc.ABCMeta.__instancecheck__.__qualname__.__eq__,  ["ABCMeta.__instancecheck__"], true,  "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (implements isinstance() with ABC support); verified with Python 3.14.3"]
    - [subclschk_qualname_eq, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,  ["ABCMeta.__subclasscheck__"], true,  "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (implements issubclass() with ABC support); verified with Python 3.14.3"]
    - [subhook_qn_len,        abc.ABC.__subclasshook__.__qualname__.__len__,       [],                            20,    "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.__subclasshook__'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__init__ and __call__ qualnames — extra150
#
# abc.abstractmethod.__init__.__qualname__.__eq__('object.__init__')   == True
# abc.abstractmethod.__call__.__qualname__.__eq__('function.__call__') == True
# ---------------------------------------------------------------------------

table abc_extra150.abc_abstractmethod_init_call_qualnames:
  description: "abc.abstractmethod.__init__ and __call__ qualname checks in abcabsm150 namespace — abc.abstractmethod.__init__.__qualname__=='object.__init__' (len=15: 'object'=6+'.'=1+'__init__'=8=15; abstractmethod does NOT define its own __init__ — it inherits __init__ from object; the qualname 'object.__init__' reflects that __init__ is defined on object, not on abstractmethod); abc.abstractmethod.__call__.__qualname__=='function.__call__' (len=17: 'function'=8+'.'=1+'__call__'=8=17; abstractmethod.__call__ comes from the function type, reflecting that abstractmethod instances are callable like functions); abc.abstractmethod.__init__.__qualname__.__len__()==15; abc.abstractmethod.__call__.__qualname__.__len__()==17 (2 longer than __init__); comparing __init__ qualname('object.__init__'=15) vs __call__ qualname('function.__call__'=17): __call__ is longer because 'function'=8 > 'object'=6; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabsm150

  columns: [id, function, args, expected, description]
  rows:
    - [absmeth_init_qn_eq,  abc.abstractmethod.__init__.__qualname__.__eq__,  ["object.__init__"],   true,  "abc.abstractmethod.__init__.__qualname__ == 'object.__init__' (abstractmethod inherits __init__ from object); verified with Python 3.14.3"]
    - [absmeth_call_qn_eq,  abc.abstractmethod.__call__.__qualname__.__eq__,  ["function.__call__"], true,  "abc.abstractmethod.__call__.__qualname__ == 'function.__call__' (abstractmethod.__call__ comes from function type); verified with Python 3.14.3"]
    - [absmeth_init_qn_len, abc.abstractmethod.__init__.__qualname__.__len__, [],                    15,    "abc.abstractmethod.__init__.__qualname__.__len__() == 15 ('object.__init__'); verified with Python 3.14.3"]
    - [absmeth_call_qn_len, abc.abstractmethod.__call__.__qualname__.__len__, [],                    17,    "abc.abstractmethod.__call__.__qualname__.__len__() == 17 ('function.__call__'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta __dict__ mappingproxy identity — extra150
#
# abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')     == True
# abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# ---------------------------------------------------------------------------

table abc_extra150.abc_dict_mappingproxy_identity:
  description: "abc.ABC and abc.ABCMeta __dict__ mappingproxy class identity checks in abcproxy150 namespace — abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12; the __dict__ of any Python class is a read-only mappingproxy object, not a plain dict; this applies to abc.ABC just as it does to any class); abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' (len=12; same — ABCMeta's own __dict__ is also a mappingproxy); the mappingproxy type prevents direct mutation of the class namespace via class.__dict__[key]=value; abc.ABC.__dict__.__class__.__name__.__len__()==12; abc.ABCMeta.__dict__.__class__.__name__.__len__()==12 (same length); compare: abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12) vs abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcproxy150

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_cls_eq,    abc.ABC.__dict__.__class__.__name__.__eq__,    ["mappingproxy"],  true,  "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (len=12; class __dict__ is always a read-only mappingproxy); verified with Python 3.14.3"]
    - [abcmeta_dict_cls_eq, abc.ABCMeta.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true,  "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' (len=12; same as ABC); verified with Python 3.14.3"]
    - [abc_dict_cls_len,   abc.ABC.__dict__.__class__.__name__.__len__,    [],                12,    "abc.ABC.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'); verified with Python 3.14.3"]
    - [abcmeta_dict_cls_len, abc.ABCMeta.__dict__.__class__.__name__.__len__, [],              12,    "abc.ABCMeta.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'; same as ABC); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra150
# ---------------------------------------------------------------------------

invariant abc_extra150.abc_ABC_subclasshook_qualname_eq:
  description: "abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__') returns True — abc.ABC defines __subclasshook__ as a classmethod with qualname 'ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20); __subclasshook__ is called by ABCMeta.__subclasscheck__ to allow the ABC to decide if a class is a virtual subclass; ABC.__subclasshook__ always returns NotImplemented, which defers to the standard ABCMeta logic (checking _abc_cache and __mro__); the qualname 'ABC.__subclasshook__' confirms the method is defined directly on abc.ABC (not inherited from object); compare: abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (qualname for the isinstance() override); NEW in extra150: first standalone abc.ABC.__subclasshook__.__qualname__ identity invariant in abchook150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__eq__
  args: ["ABC.__subclasshook__"]
  expected: true

invariant abc_extra150.abc_ABCMeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — abc.ABCMeta defines __instancecheck__ to override isinstance() behavior; when you call isinstance(x, SomeABC), Python invokes SomeABC.__class__.__instancecheck__(SomeABC, x) which dispatches to ABCMeta.__instancecheck__; the qualname 'ABCMeta.__instancecheck__' confirms it is defined directly on ABCMeta (not inherited from type); abc.ABCMeta.__instancecheck__.__qualname__.__len__()==26 (len('ABCMeta.__instancecheck__')==25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25; verified with Python 3.14.3); compare: abc.ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (sibling method for issubclass()); NEW in extra150: first standalone abc.ABCMeta.__instancecheck__.__qualname__ identity invariant in abchook150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra150.abc_abstractmethod_init_qualname_is_object_init:
  description: "abc.abstractmethod.__init__.__qualname__.__eq__('object.__init__') returns True — abc.abstractmethod does NOT define its own __init__ method; when Python looks up abstractmethod.__init__, it finds the inherited __init__ from object; the qualname of this inherited method is 'object.__init__' (len=15: 'object'=6+'.'=1+'__init__'=8=15); this shows that abstractmethod's constructor is entirely provided by object — abstractmethod.__new__ may be used instead for initialization; contrast: if abstractmethod defined its own __init__, the qualname would be 'abstractmethod.__init__'; the inherited qualname 'object.__init__' is the authoritative confirmation that abstractmethod does not override __init__; NEW in extra150: first standalone abc.abstractmethod.__init__.__qualname__ identity invariant in abcabsm150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant abc_extra150.abc_ABC_dict_class_is_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — the __dict__ attribute of any Python class (including abc.ABC) is a types.MappingProxyType instance, whose __class__.__name__ is 'mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); mappingproxy is a read-only wrapper that prevents direct assignment to the class namespace via __dict__[key]=value (you must use setattr or the class itself); abc.ABC.__dict__.__class__.__name__=='mappingproxy' applies to all classes in CPython; this holds for abc.ABC (a regular class with ABCMeta as metaclass) AND for abc.ABCMeta (a metaclass that is itself a class); abc.ABC.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'); compare: abc.ABC.__dict__.__contains__.__class__.__name__=='builtin_function_or_method' (the __contains__ method of the mappingproxy is a C-level builtin; established in abc_extra149); NEW in extra150: first standalone abc.ABC.__dict__.__class__.__name__ mappingproxy identity invariant in abcproxy150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra150.abc_ABCMeta_dict_class_is_mappingproxy:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABCMeta's __dict__ is also a mappingproxy (len=12), just like abc.ABC.__dict__; this is a universal property of Python classes — the __dict__ of any class object is a types.MappingProxyType; ABCMeta is itself a class (a metaclass) so its __dict__ follows the same mappingproxy rule; ABCMeta.__dict__.__class__.__name__=='mappingproxy'; ABCMeta.__dict__.__class__.__name__.__len__()==12 (same as ABC.__dict__.__class__.__name__.__len__()==12); the symmetry ABC.__dict__.__class__.__name__==ABCMeta.__dict__.__class__.__name__=='mappingproxy' confirms the universal applicability of the mappingproxy type for class namespaces; NEW in extra150: first standalone abc.ABCMeta.__dict__.__class__.__name__ mappingproxy identity invariant in abcproxy150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

