spec: hashlib_extra33
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra32.zspec.zsdl — covers sha1/sha512/sha224/sha384 __module__.__len__()==8; blake2b/blake2s __module__.__len__()==7; new __module__.__len__()==7; new __name__.__len__()==10; blake2b/blake2s __name__.__len__()==7; sha3_256 __name__/__module__.__len__()."
  notes:
    - "This spec extends hashlib through hashlib_extra32; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: md5/sha1/sha256/sha512/sha224/sha384/blake2b/blake2s __name__/__qualname__/__module__ and their __len__() variants; new/__name__/__module__/__len__(); sha3_256 __name__/__module__/__len__(); algorithms_guaranteed/__class__/__name__/__eq__ and __len__() (exact count 14, >=5, >=8); HASH.__name__ (via md5 instances in earlier specs)."
    - "This spec covers: HASH.update.__qualname__.__len__() (NOVEL — 'HASH.update' has 11 characters; no prior spec checks __qualname__.__len__() for any HASH method); HASH.digest.__qualname__.__len__() (NOVEL — 'HASH.digest' has 11 characters); HASH.hexdigest.__qualname__.__len__() (NOVEL — 'HASH.hexdigest' has 14 characters); HASH.copy.__qualname__.__len__() (NOVEL — 'HASH.copy' has 9 characters); HASH.__mro__.__len__() (NOVEL — HASH inherits only from object, depth 2); HASH.__bases__[0].__name__ (NOVEL — 'object'); sha3_512.__name__.__len__() (NOVEL — 'openssl_sha3_512' has 16 characters); sha3_512.__module__.__len__() (NOVEL); shake_128.__name__.__len__() (NOVEL — 'openssl_shake_128' has 17 characters); shake_256.__name__.__len__() (NOVEL — 'openssl_shake_256' has 17 characters); algorithms_guaranteed.__class__.__name__.__len__() (NOVEL — 'set' has 3 characters); algorithms_available.__class__.__name__.__len__() (NOVEL — 'set' has 3 characters)."
    - "HASH.update.__qualname__ == 'HASH.update' (len 11). The HASH C type uses the class name 'HASH' as prefix in method qualnames. No prior spec checks __qualname__.__len__() for any HASH instance method. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "HASH.digest.__qualname__ == 'HASH.digest' (len 11). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "HASH.hexdigest.__qualname__ == 'HASH.hexdigest' (len 14). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "HASH.copy.__qualname__ == 'HASH.copy' (len 9). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "HASH.__mro__.__len__() == 2: HASH inherits directly from object; MRO is [HASH, object]. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "HASH.__bases__[0].__name__ == 'object': HASH directly subclasses object. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512' (len 16). No prior spec checks __name__.__len__() for sha3_512. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__module__ == '_hashlib' (len 8). Novel __len__ check for sha3_512. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128' (len 17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256' (len 17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3: 'set' has 3 characters. Prior specs check __class__.__name__.__eq__('set') but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__.__len__() == 3: 'set' has 3 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH method __qualname__.__len__() — novel invariants
#
# The HASH C type (backing hashlib.md5(), sha1(), etc.) has methods whose
# qualnames include the 'HASH.' class prefix. No prior spec checks
# __qualname__.__len__() for any HASH instance method.
# update: 'HASH.update' (11), digest: 'HASH.digest' (11),
# hexdigest: 'HASH.hexdigest' (14), copy: 'HASH.copy' (9).
# ---------------------------------------------------------------------------

invariant hashlib_extra33.HASH.update.qualname_len:
  description: "HASH.update.__qualname__.__len__() == 11 — 'HASH.update' has 11 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: md5().__class__.update.__qualname__.__len__
  args: []
  expected: 11

invariant hashlib_extra33.HASH.hexdigest.qualname_len:
  description: "HASH.hexdigest.__qualname__.__len__() == 14 — 'HASH.hexdigest' has 14 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: md5().__class__.hexdigest.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# HASH.__mro__.__len__() and __bases__[0].__name__ — novel
#
# No prior spec checks the MRO depth or base class name for the HASH C type.
# HASH directly subclasses object: __mro__ == [HASH, object] (depth 2).
# ---------------------------------------------------------------------------

invariant hashlib_extra33.HASH.mro_len:
  description: "HASH.__mro__.__len__() == 2 — HASH inherits directly from object, MRO depth is 2, novel invariant"
  category: class_hierarchy
  kind: python_call_eq
  function: md5().__class__.__mro__.__len__
  args: []
  expected: 2

invariant hashlib_extra33.HASH.bases_name:
  description: "HASH.__bases__[0].__name__ == 'object' — HASH directly subclasses object, novel invariant"
  category: class_hierarchy
  kind: python_call_eq
  function: "md5().__class__.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Table: HASH method __qualname__.__len__() — all four methods
#
# Groups all four HASH instance method __qualname__.__len__() checks.
# All are novel; no prior spec covers __qualname__.__len__() for HASH methods.
# ---------------------------------------------------------------------------

table hashlib_extra33.hash_method_qualname_lengths:
  description: "HASH.update/digest/hexdigest/copy __qualname__.__len__() — novel invariants, accessed via md5().__class__"
  kind: python_call_eq
  category: function_names
  id_prefix: hmql33

  columns: [id, function, args, expected]
  rows:
    - [update,    md5().__class__.update.__qualname__.__len__,    [], 11]
    - [digest,    md5().__class__.digest.__qualname__.__len__,    [], 11]
    - [hexdigest, md5().__class__.hexdigest.__qualname__.__len__, [], 14]
    - [copy,      md5().__class__.copy.__qualname__.__len__,      [], 9]

# ---------------------------------------------------------------------------
# sha3_512 and shake_128/shake_256 __name__.__len__() — novel
#
# extra32 covers sha3_256.__name__.__len__()==16 and sha3_256.__module__.__len__()==8.
# No prior spec checks __name__.__len__() for sha3_512, shake_128, or shake_256.
# sha3_512.__name__ == 'openssl_sha3_512' (16);
# shake_128.__name__ == 'openssl_shake_128' (17);
# shake_256.__name__ == 'openssl_shake_256' (17).
# ---------------------------------------------------------------------------

table hashlib_extra33.sha3_shake_name_lengths:
  description: "sha3_512/shake_128/shake_256 __name__.__len__() and __module__.__len__() — novel invariants"
  kind: python_call_eq
  category: function_names
  id_prefix: hlssn33

  columns: [id, function, args, expected]
  rows:
    - [sha3_512_name_len,   sha3_512.__name__.__len__,   [], 16]
    - [sha3_512_module_len, sha3_512.__module__.__len__,  [], 8]
    - [shake_128_name_len,  shake_128.__name__.__len__,   [], 17]
    - [shake_256_name_len,  shake_256.__name__.__len__,   [], 17]
    - [shake_128_module_len, shake_128.__module__.__len__, [], 8]
    - [shake_256_module_len, shake_256.__module__.__len__, [], 8]

# ---------------------------------------------------------------------------
# algorithms_guaranteed and algorithms_available __class__.__name__.__len__()
#
# Prior specs check __class__.__name__.__eq__('set') for both attributes but
# no prior spec checks __class__.__name__.__len__(). 'set' has 3 characters.
# ---------------------------------------------------------------------------

invariant hashlib_extra33.algorithms_guaranteed.classname_len:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3 — 'set' has 3 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__len__
  args: []
  expected: 3

invariant hashlib_extra33.algorithms_available.classname_len:
  description: "hashlib.algorithms_available.__class__.__name__.__len__() == 3 — 'set' has 3 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__len__
  args: []
  expected: 3
