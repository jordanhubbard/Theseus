spec: struct_extra2461
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether struct.Struct defines the length protocol in its class __dict__."
    - "struct.Struct.__dict__.__contains__('__len__') == False — Struct objects are not sequences; len(s) raises TypeError."
    - "struct.Struct.__dict__.__contains__('__length_hint__') == False — Struct objects do not define __length_hint__ either."
    - "struct.Struct.__dict__.__contains__('size') == True — size is a descriptor in Struct.__dict__ giving the packed byte count."
    - "struct.Struct.__dict__.__contains__('format') == True — format is a descriptor in Struct.__dict__ storing the format string."
    - "struct.Struct.__dict__.__contains__('pack') == True — pack is a method descriptor in Struct.__dict__."
    - "struct.Struct.__dict__.__contains__('unpack') == True — unpack is a method descriptor in Struct.__dict__."
    - "struct.Struct.__dict__.__contains__('pack_into') == True — pack_into is a method descriptor in Struct.__dict__."
    - "struct.Struct.__dict__.__contains__('unpack_from') == True — unpack_from is a method descriptor in Struct.__dict__."
    - "struct.Struct.__dict__.__contains__('iter_unpack') == True — iter_unpack is a method descriptor in Struct.__dict__."
    - "struct.Struct.__dict__.__contains__('__iter__') == False — Struct is not iterable."
    - "struct.Struct.__dict__.__contains__('__hash__') == False — Struct does not define __hash__ in its class __dict__."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ and __length_hint__ absence — core theme of this spec
# struct.Struct defines neither __len__ nor __length_hint__ in its class __dict__.
# The packed byte count is exposed via .size, not len().
# ---------------------------------------------------------------------------

table struct_extra2461.Struct.len_protocol:
  description: "struct.Struct class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2461

  columns: [id, function, args, expected]
  rows:
    - ["st2461-001", "Struct.__dict__.__contains__", ["__len__"],         false]
    - ["st2461-002", "Struct.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Descriptor presence — size and format are in Struct.__dict__
# The .size attribute (not __len__) is the canonical way to query packed length.
# ---------------------------------------------------------------------------

table struct_extra2461.Struct.descriptor_presence:
  description: "struct.Struct class __dict__ contains size and format descriptors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2461

  columns: [id, function, args, expected]
  rows:
    - ["st2461-010", "Struct.__dict__.__contains__", ["size"],   true]
    - ["st2461-011", "Struct.__dict__.__contains__", ["format"], true]

# ---------------------------------------------------------------------------
# Method presence — pack, unpack, pack_into, unpack_from, iter_unpack
# All five pack/unpack methods are defined directly in Struct.__dict__.
# ---------------------------------------------------------------------------

table struct_extra2461.Struct.method_presence:
  description: "struct.Struct class __dict__ contains all five pack/unpack methods"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2461

  columns: [id, function, args, expected]
  rows:
    - ["st2461-020", "Struct.__dict__.__contains__", ["pack"],        true]
    - ["st2461-021", "Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st2461-022", "Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st2461-023", "Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2461-024", "Struct.__dict__.__contains__", ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# Absent protocols — Struct does not define iteration, truthiness, or hash
# __iter__, __bool__, __hash__ are absent from Struct.__dict__.
# ---------------------------------------------------------------------------

table struct_extra2461.Struct.absent_protocols:
  description: "struct.Struct class __dict__ does not contain __iter__, __bool__, or __hash__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2461

  columns: [id, function, args, expected]
  rows:
    - ["st2461-030", "Struct.__dict__.__contains__", ["__iter__"], false]
    - ["st2461-031", "Struct.__dict__.__contains__", ["__bool__"], false]
    - ["st2461-032", "Struct.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# Struct class identity
# Confirm the class name and module for struct.Struct.
# ---------------------------------------------------------------------------

invariant struct_extra2461.Struct.class_name:
  description: "struct.Struct.__name__ == 'Struct'"
  category: class_metadata
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra2461.Struct.module_name:
  description: "struct.Struct.__module__ == '_struct' — Struct is defined in the _struct C extension"
  category: class_metadata
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true
