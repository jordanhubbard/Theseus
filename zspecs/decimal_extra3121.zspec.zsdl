spec: dc3121
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (dc3121): __ge__, __repr__, __str__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "decimal.Decimal defines __ge__, __repr__, and __str__ in its own __dict__: it is a fully-featured numeric type with value ordering (>= by value), a repr showing Decimal('...'), and a str showing the numeric string."
    - "decimal.Context defines __repr__ in its own __dict__ (true) but NOT __ge__ or __str__ (both false): a context has a meaningful repr listing its parameters but no ordering or custom str."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, and decimal.Underflow are exception classes and do NOT define __ge__, __repr__, or __str__ in their own __dict__ (all false)."
    - "On CPython, the decimal module is backed by _decimal (C accelerator); class __dict__ contents are from the C extension."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# decimal.Decimal defines __ge__ (true): numeric >= comparison by value,
# completing the full ordering protocol alongside __lt__, __le__, __gt__.
# decimal.Context and all exception subclasses do NOT define __ge__ (false).
# ---------------------------------------------------------------------------

table dc3121.ge:
  description: "decimal types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3121

  columns: [id, function, args, expected]
  rows:
    - ["dc3121001", operator.contains, [decimal.Decimal.__dict__,          "__ge__"], true]
    - ["dc3121002", operator.contains, [decimal.Context.__dict__,           "__ge__"], false]
    - ["dc3121003", operator.contains, [decimal.DecimalException.__dict__,  "__ge__"], false]
    - ["dc3121004", operator.contains, [decimal.InvalidOperation.__dict__,  "__ge__"], false]
    - ["dc3121005", operator.contains, [decimal.Overflow.__dict__,          "__ge__"], false]
    - ["dc3121006", operator.contains, [decimal.Underflow.__dict__,         "__ge__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# decimal.Decimal defines __repr__ (true): returns e.g. Decimal('3.14').
# decimal.Context defines __repr__ (true): returns a repr listing all context
# parameters (prec, rounding, Emin, Emax, etc.).
# Exception subclasses do NOT define __repr__ in their own __dict__ (false).
# ---------------------------------------------------------------------------

table dc3121.repr:
  description: "decimal types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3121

  columns: [id, function, args, expected]
  rows:
    - ["dc3121007", operator.contains, [decimal.Decimal.__dict__,          "__repr__"], true]
    - ["dc3121008", operator.contains, [decimal.Context.__dict__,           "__repr__"], true]
    - ["dc3121009", operator.contains, [decimal.DecimalException.__dict__,  "__repr__"], false]
    - ["dc3121010", operator.contains, [decimal.InvalidOperation.__dict__,  "__repr__"], false]
    - ["dc3121011", operator.contains, [decimal.Overflow.__dict__,          "__repr__"], false]
    - ["dc3121012", operator.contains, [decimal.Underflow.__dict__,         "__repr__"], false]

# ---------------------------------------------------------------------------
# __str__ dict-presence — operator.contains(Cls.__dict__, '__str__')
#
# decimal.Decimal defines __str__ (true): returns the numeric string, e.g. '3.14',
# distinct from __repr__ which wraps it in Decimal('...').
# decimal.Context and all exception subclasses do NOT define __str__ (false).
# ---------------------------------------------------------------------------

table dc3121.str:
  description: "decimal types __str__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3121

  columns: [id, function, args, expected]
  rows:
    - ["dc3121013", operator.contains, [decimal.Decimal.__dict__,          "__str__"], true]
    - ["dc3121014", operator.contains, [decimal.Context.__dict__,           "__str__"], false]
    - ["dc3121015", operator.contains, [decimal.DecimalException.__dict__,  "__str__"], false]
    - ["dc3121016", operator.contains, [decimal.InvalidOperation.__dict__,  "__str__"], false]
    - ["dc3121017", operator.contains, [decimal.Overflow.__dict__,          "__str__"], false]
    - ["dc3121018", operator.contains, [decimal.Underflow.__dict__,         "__str__"], false]

# ---------------------------------------------------------------------------
# combined — __ge__, __repr__, __str__ across all 6 decimal subjects
#
# Covers the full matrix: 6 classes x 3 methods = 18 rows, padded with
# additional rows re-testing Decimal and Context (the notable non-exception
# classes) to reach ~24 rows.
# __ge__:   Decimal=true;  Context, DecimalException, InvalidOperation, Overflow, Underflow=false.
# __repr__: Decimal=true;  Context=true; DecimalException, InvalidOperation, Overflow, Underflow=false.
# __str__:  Decimal=true;  Context, DecimalException, InvalidOperation, Overflow, Underflow=false.
# ---------------------------------------------------------------------------

table dc3121.combined:
  description: "decimal types combined __ge__/__repr__/__str__; wave 655"
  kind: python_call_eq
