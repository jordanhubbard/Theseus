    - ["dc3121026", operator.contains, [decimal.DecimalException.__dict__,  "__repr__"], false]
    - ["dc3121027", operator.contains, [decimal.DecimalException.__dict__,  "__str__"],  false]
    - ["dc3121028", operator.contains, [decimal.InvalidOperation.__dict__,  "__ge__"],   false]
    - ["dc3121029", operator.contains, [decimal.InvalidOperation.__dict__,  "__repr__"], false]
    - ["dc3121030", operator.contains, [decimal.InvalidOperation.__dict__,  "__str__"],  false]
    - ["dc3121031", operator.contains, [decimal.Overflow.__dict__,          "__ge__"],   false]
    - ["dc3121032", operator.contains, [decimal.Overflow.__dict__,          "__repr__"], false]
    - ["dc3121033", operator.contains, [decimal.Overflow.__dict__,          "__str__"],  false]
    - ["dc3121034", operator.contains, [decimal.Underflow.__dict__,         "__ge__"],   false]
    - ["dc3121035", operator.contains, [decimal.Underflow.__dict__,         "__repr__"], false]
    - ["dc3121036", operator.contains, [decimal.Underflow.__dict__,         "__str__"],  false]
