spec: socket_extra190
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec covers socket.socket class identity and Python-defined method __module__ attributes."
    - "socket.socket is a Python class defined in Lib/socket.py that inherits from _socket.socket (C extension)."
    - "socket.socket.__module__ == 'socket' — the Python-level socket class is defined in the 'socket' module."
    - "socket.socket.__name__ == 'socket' — the class name is 'socket' (same as the module name)."
    - "socket.socket.__qualname__ == 'socket' — top-level class, qualname equals name."
    - "socket.socket.__class__.__name__ == 'type' — socket is a class object with metaclass 'type'."
    - "socket.socket.__bases__[0].__name__ == 'socket' — the base class is _socket.socket, also named 'socket'."
    - "socket.socket.__bases__[0].__module__ == '_socket' — the C-level base class is in the _socket extension."
    - "socket.socket.__init__.__module__ == 'socket' — __init__ is Python-defined in Lib/socket.py."
    - "socket.socket.accept.__module__ == 'socket' — accept() is a Python wrapper defined in Lib/socket.py."
    - "socket.socket.close.__module__ == 'socket' — close() is Python-defined in Lib/socket.py."
    - "socket.socket.makefile.__module__ == 'socket' — makefile() is Python-defined in Lib/socket.py."
    - "C-extension methods (bind, connect, listen, fileno, setsockopt) do NOT have a __module__ attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class — core identity checks
#
# socket.socket.__module__ == 'socket'
# socket.socket.__name__ == 'socket'
# socket.socket.__qualname__ == 'socket'
# socket.socket.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table socket_extra190.socket_class_identity:
  description: "socket.socket class identity checks in socketsocket190 namespace — socket.socket is the Python class defined in Lib/socket.py; socket.__module__.__eq__('socket')==True (len=6: 'socket'=6; the Python wrapper class is defined in the 'socket' module, not '_socket'); socket.__name__.__eq__('socket')==True (len=6: class name 'socket' happens to be the same as the module name 'socket' — an unusual coincidence); socket.__qualname__.__eq__('socket')==True (qualname equals name because socket is a top-level class, not nested); socket.__class__.__name__.__eq__('type')==True (the metaclass of socket.socket is the built-in 'type'; 'type'=4 chars, shortest value in spec); these identity checks confirm that socket.socket is a proper Python class object backed by C infrastructure; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketsocket190

  columns: [id, function, args, expected, description]
  rows:
    - [module_eq,   socket.__module__.__eq__,          ["socket"], true, "socket.socket.__module__ == 'socket' (Python class in Lib/socket.py, not '_socket' C extension); verified with Python 3.14.3"]
    - [name_eq,     socket.__name__.__eq__,             ["socket"], true, "socket.socket.__name__ == 'socket' (class name equals module name — unusual); verified with Python 3.14.3"]
    - [qualname_eq, socket.__qualname__.__eq__,         ["socket"], true, "socket.socket.__qualname__ == 'socket' (top-level class, qualname equals name); verified with Python 3.14.3"]
    - [class_eq,    socket.__class__.__name__.__eq__,   ["type"],   true, "socket.socket.__class__.__name__ == 'type' (len=4, shortest value in spec; socket is a regular class); verified with Python 3.14.3"]
    - [init_mod_eq, socket.__init__.__module__.__eq__,  ["socket"], true, "socket.socket.__init__.__module__ == 'socket' (Python-defined __init__ in Lib/socket.py); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.socket base class — __bases__[0] identity
#
# socket.socket.__bases__[0].__name__ == 'socket'   (the _socket.socket C class)
# socket.socket.__bases__[0].__module__ == '_socket'
# ---------------------------------------------------------------------------

table socket_extra190.socket_base_identity:
  description: "socket.socket base class identity checks in socketsocket190 namespace — socket.socket.__bases__[0] is _socket.socket (the C-level socket class); the Python socket.socket inherits from _socket.socket to add Python-level wrapper methods; __bases__[0].__name__.__eq__('socket')==True (len=6: both the C-level base class and the Python class are named 'socket'; this is the same name at two levels of the inheritance hierarchy); __bases__[0].__module__.__eq__('_socket')==True (len=7: '_socket'=7; the base class is from the C extension module, unlike the derived class whose __module__='socket'=6); the leading underscore in '_socket' distinguishes the private C module from the public Python wrapper; '__bases__[0]' syntax requires quoting in invariant function fields; all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: socketsocket190a

  columns: [id, function, args, expected, description]
  rows:
    - [base_name_eq,     "socket.__bases__[0].__name__.__eq__",     ["socket"],  true, "socket.socket.__bases__[0].__name__ == 'socket' (C-level base class also named 'socket'); verified with Python 3.14.3"]
    - [base_module_eq,   "socket.__bases__[0].__module__.__eq__",   ["_socket"], true, "socket.socket.__bases__[0].__module__ == '_socket' (base class is in _socket C extension, not Python 'socket'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.socket Python-defined methods — __module__ checks
#
# accept, close, makefile all have __module__ == 'socket'
# C-extension methods (bind, connect, listen) do NOT have __module__
# ---------------------------------------------------------------------------

table socket_extra190.socket_method_modules:
  description: "socket.socket Python-defined method __module__ checks in socketsocket190 namespace — some socket.socket methods are Python wrappers defined in Lib/socket.py and thus have __module__=='socket'; other methods are raw C extension wrappers (method_descriptor type) and do NOT have __module__; accept.__module__.__eq__('socket')==True (accept() reads a connection and returns (conn, addr); it is a Python wrapper that calls the C-level accept and wraps the result); close.__module__.__eq__('socket')==True (close() is Python-defined to properly handle socket cleanup); makefile.__module__.__eq__('socket')==True (makefile() creates a file-like object wrapping the socket; it is entirely Python-defined); sendfile.__module__.__eq__('socket')==True (sendfile() is Python-defined, uses os.sendfile or fallback); __enter__.__module__.__eq__('socket')==True (context manager support is Python-defined); __repr__.__module__.__eq__('socket')==True (__repr__ formats the socket info string in Python); all six return 'socket' confirming Python-level implementation; contrast: bind, connect, listen, fileno, setsockopt are C wrappers without __module__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: method_modules
  id_prefix: socketsocket190b

  columns: [id, function, args, expected, description]
  rows:
    - [accept_mod_eq,   socket.accept.__module__.__eq__,   ["socket"], true, "socket.socket.accept.__module__ == 'socket' (Python wrapper in Lib/socket.py); verified with Python 3.14.3"]
    - [close_mod_eq,    socket.close.__module__.__eq__,    ["socket"], true, "socket.socket.close.__module__ == 'socket' (Python-defined cleanup handler); verified with Python 3.14.3"]
    - [makefile_eq,     socket.makefile.__module__.__eq__, ["socket"], true, "socket.socket.makefile.__module__ == 'socket' (Python-defined file-like wrapper); verified with Python 3.14.3"]
    - [sendfile_eq,     socket.sendfile.__module__.__eq__, ["socket"], true, "socket.socket.sendfile.__module__ == 'socket' (Python-defined; uses os.sendfile or fallback); verified with Python 3.14.3"]
    - [enter_mod_eq,    socket.__enter__.__module__.__eq__, ["socket"], true, "socket.socket.__enter__.__module__ == 'socket' (Python-defined context manager entry); verified with Python 3.14.3"]
    - [repr_mod_eq,     socket.__repr__.__module__.__eq__, ["socket"], true, "socket.socket.__repr__.__module__ == 'socket' (Python-defined repr for socket info string); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket_extra190
# ---------------------------------------------------------------------------

invariant socket_extra190.socket_module_is_socket:
  description: "socket.socket.__module__ == 'socket' — the socket.socket class is defined in Lib/socket.py (the pure-Python wrapper module), so its __module__ attribute is 'socket' (len=6); contrast with socket.socket.__bases__[0].__module__=='_socket' (the C-level base class); socket.socket.__name__=='socket' (class name equals module name — unusual); socket.socket.__qualname__=='socket' (top-level class); socket.socket.__class__.__name__=='type' (ordinary Python class with metaclass 'type'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra190.socket_init_module_is_socket:
  description: "socket.socket.__init__.__module__ == 'socket' — __init__ is a Python function defined in Lib/socket.py; socket.socket.__init__.__qualname__ == 'socket.__init__'; the __init__ method initializes the socket by calling the underlying _socket.socket C constructor; socket.socket.__init__.__module__=='socket' (Python-defined, not '_socket'); socket.socket.__init__.__qualname__.__len__()==15 ('socket.__init__'=6+1+8=15 chars); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: socket.__init__.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra190.socket_class_is_type:
  description: "socket.socket.__class__.__name__ == 'type' — socket.socket is a class whose metaclass is the built-in 'type'; 'type'=4 chars (shortest string value in this spec); this is the standard Python metaclass; socket.socket is not a metaclass itself — it is a regular class; socket.socket.__name__=='socket'; socket.socket.__module__=='socket'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: socket.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant socket_extra190.socket_name_is_socket:
  description: "socket.socket.__name__ == 'socket' — the class is named 'socket' (len=6); this is the same name as the module name 'socket', which is an unusual situation in Python (most classes have names distinct from their module); socket.socket.__qualname__=='socket' (qualname equals name for top-level classes); socket.socket.__module__=='socket'; socket.socket.__bases__[0].__name__=='socket' (the C base class is also named 'socket' — both the Python and C levels share the name 'socket'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra190.socket_qualname_is_socket:
  description: "socket.socket.__qualname__ == 'socket' — the qualified name of socket.socket is 'socket' (len=6); qualname equals name because socket.socket is a top-level class (not nested inside another class or function); if socket were a nested class, its qualname would be something like 'outer.socket'; socket.socket.__qualname__==socket.socket.__name__ (both are 'socket'); socket.socket.__module__=='socket'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra190.socket_base_name_is_socket:
  description: "socket.socket.__bases__[0].__name__ == 'socket' — the first base class of socket.socket is _socket.socket, which is also named 'socket'; this means both the derived Python class and its C-level base class share the name 'socket'; socket.socket.__bases__[0].__module__=='_socket' (the base class is in the C extension module); socket.socket inherits from _socket.socket to gain the C-level socket system call bindings; the Python wrapper adds accept(), close(), makefile(), sendfile(), and context manager support; '__bases__[0]' — the bracket index syntax — requires double-quoting in ZSDL function fields; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: "socket.__bases__[0].__name__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra190.socket_base_module_is_csocket:
  description: "socket.socket.__bases__[0].__module__ == '_socket' — the C-level base class _socket.socket has __module__=='_socket' (len=7); '_socket' is the private C extension module (Modules/socketmodule.c in CPython); it is distinct from the public 'socket' Python module (Lib/socket.py); '__bases__[0]' — the bracket index syntax — requires double-quoting in ZSDL function fields; socket.socket.__module__=='socket' (len=6) vs base.__module__=='_socket' (len=7): the C module name has a leading underscore prefix making it one character longer; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: "socket.__bases__[0].__module__.__eq__"
  args: ["_socket"]
  expected: true

invariant socket_extra190.socket_accept_module_is_socket:
  description: "socket.socket.accept.__module__ == 'socket' — accept() is a Python-defined method in Lib/socket.py; it calls the C-level accept() internally and wraps the result in a Python socket.socket object; socket.socket.accept.__qualname__=='socket.accept'; socket.socket.accept.__class__.__name__=='function' (Python function); contrast with bind, connect, listen which are C-level method_descriptors without __module__; accept being Python-defined is what enables the result to be a socket.socket instance (with Python wrapper) rather than a raw _socket.socket; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_modules
  kind: python_call_eq
  function: socket.accept.__module__.__eq__
  args: ["socket"]
  expected: true

