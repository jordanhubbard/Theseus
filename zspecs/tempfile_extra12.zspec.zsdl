spec: tempfile_extra12
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
    - "tempfile_extra11.zspec.zsdl — covers NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile __name__ standalones; mkstemp/mkdtemp/gettempdir __name__ standalones; __module__ table; gettempdir() return type"
    - "tempfile_extra10.zspec.zsdl — covers TemporaryFile/NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory __name__ table; mkstemp/mkdtemp/gettempdir/gettempprefix __name__ table; gettempdir/gettempprefix return type str"
  notes:
    - "This spec extends tempfile.zspec.zsdl and all prior tempfile_extra specs through tempfile_extra11.zspec.zsdl."
    - "tempfile.mkstemp.__name__ == 'mkstemp' — re-anchored in extra12 namespace via table row alongside remaining symbols."
    - "tempfile.mkdtemp.__name__ == 'mkdtemp' — re-anchored in extra12 namespace."
    - "tempfile.NamedTemporaryFile.__name__ == 'NamedTemporaryFile' — re-anchored in extra12 namespace."
    - "tempfile.SpooledTemporaryFile.__name__ == 'SpooledTemporaryFile' — re-anchored in extra12 namespace."
    - "tempfile.TemporaryDirectory.__name__ == 'TemporaryDirectory' — re-anchored in extra12 namespace."
    - "tempfile.gettempdir.__name__ == 'gettempdir' — re-anchored in extra12 namespace."
    - "tempfile.gettempdir().__class__.__name__ == 'str' — re-anchored as standalone in extra12 namespace."
    - "tempfile.gettempprefix().__class__.__name__ == 'str' — no prior tempfile spec covers gettempprefix() return-type as a standalone invariant in extra12 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table — mkstemp, mkdtemp, NamedTemporaryFile, SpooledTemporaryFile,
#                  TemporaryDirectory, gettempdir
#
# Prior specs (extra10, extra11) cover these __name__ values in tables and
# standalone invariants. This table re-anchors all six in the extra12 namespace
# as a single grouped cross-check.
# ---------------------------------------------------------------------------

table tempfile_extra12.function_and_class_names:
  description: "__name__ for mkstemp/mkdtemp/NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory/gettempdir"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname12

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,              mkstemp.__name__.__eq__,              ["mkstemp"],              true]
    - [mkdtemp,              mkdtemp.__name__.__eq__,              ["mkdtemp"],              true]
    - [NamedTemporaryFile,   NamedTemporaryFile.__name__.__eq__,   ["NamedTemporaryFile"],   true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__name__.__eq__, ["SpooledTemporaryFile"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__name__.__eq__,   ["TemporaryDirectory"],   true]
    - [gettempdir,           gettempdir.__name__.__eq__,           ["gettempdir"],           true]

# ---------------------------------------------------------------------------
# tempfile.gettempdir().__class__.__name__ == 'str'
#
# gettempdir() returns the platform's default directory for temporary files
# as a string. Verified at runtime. Re-anchored as a standalone invariant
# in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant tempfile_extra12.gettempdir.return_type_str:
  description: "tempfile.gettempdir().__class__.__name__ == 'str' — gettempdir always returns a string path"
  category: return_types
  kind: python_call_eq
  function: gettempdir
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# tempfile.gettempprefix().__class__.__name__ == 'str'
#
# gettempprefix() returns the filename prefix used to create temp files.
# It always returns a str. Verified at runtime: gettempprefix().__class__.__name__
# == 'str'. No prior tempfile spec covers this as a standalone named invariant
# in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant tempfile_extra12.gettempprefix.return_type_str:
  description: "tempfile.gettempprefix().__class__.__name__ == 'str' — gettempprefix always returns a string prefix"
  category: return_types
  kind: python_call_eq
  function: gettempprefix
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
