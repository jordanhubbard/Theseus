spec: functools_extra1321
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ output class checks for functools classes."
    - "functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor' — partial is a C type; __repr__ is a wrapper_descriptor inherited from object but overridden in C."
    - "functools.partial.__repr__.__qualname__ == 'partial.__repr__' — C-level override named after its class."
    - "functools.cached_property.__repr__.__class__.__name__ == 'wrapper_descriptor' — pure Python class that inherits __repr__ from object without override."
    - "functools.cached_property.__repr__.__qualname__ == 'object.__repr__' — inherited directly from object."
    - "functools.singledispatchmethod.__repr__.__class__.__name__ == 'function' — pure Python class that defines its own __repr__ as a Python function."
    - "functools.singledispatchmethod.__repr__.__qualname__ == 'singledispatchmethod.__repr__' — defined in the class body."
    - "functools.partialmethod.__repr__.__class__.__name__ == 'function' — partialmethod uses a module-level helper function _partial_repr as its __repr__."
    - "functools.partialmethod.__repr__.__qualname__ == '_partial_repr' — the helper is a module-level function, not a method."
    - "repr(functools.partial).__class__.__name__ == 'str' — repr of the class object itself always returns a str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra1321.partial_repr_str_checks:
  description: "functools.partial __repr__ and __str__ class name and qualname identity; partial is a C type with wrapper_descriptor __repr__"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: fu1321pa
  columns: [id, function, args, expected]
  rows:
    - [fu1321pa001, functools.partial.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"],  true]
    - [fu1321pa002, functools.partial.__repr__.__qualname__.__eq__,        ["partial.__repr__"],    true]
    - [fu1321pa003, functools.partial.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [fu1321pa004, functools.partial.__str__.__qualname__.__eq__,         ["object.__str__"],      true]
    - [fu1321pa005, repr(functools.partial).__class__.__name__.__eq__,     ["str"],                 true]
    - [fu1321pa006, repr(functools.cached_property).__class__.__name__.__eq__, ["str"],             true]

table functools_extra1321.cached_property_repr_str_checks:
  description: "functools.cached_property __repr__ and __str__ class name and qualname; inherits from object without override"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: fu1321cp
  columns: [id, function, args, expected]
  rows:
    - [fu1321cp001, functools.cached_property.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"],  true]
    - [fu1321cp002, functools.cached_property.__repr__.__qualname__.__eq__,        ["object.__repr__"],     true]
    - [fu1321cp003, functools.cached_property.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [fu1321cp004, functools.cached_property.__str__.__qualname__.__eq__,         ["object.__str__"],      true]
    - [fu1321cp005, repr(functools.singledispatchmethod).__class__.__name__.__eq__, ["str"],                 true]
    - [fu1321cp006, repr(functools.partialmethod).__class__.__name__.__eq__,        ["str"],                 true]

table functools_extra1321.singledispatchmethod_partialmethod_repr_checks:
  description: "functools.singledispatchmethod and partialmethod __repr__ class name and qualname; both define __repr__ as Python functions"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: fu1321sd
  columns: [id, function, args, expected]
  rows:
    - [fu1321sd001, functools.singledispatchmethod.__repr__.__class__.__name__.__eq__,  ["function"],                      true]
    - [fu1321sd002, functools.singledispatchmethod.__repr__.__qualname__.__eq__,        ["singledispatchmethod.__repr__"],  true]
    - [fu1321sd003, functools.singledispatchmethod.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"],             true]
    - [fu1321sd004, functools.singledispatchmethod.__str__.__qualname__.__eq__,         ["object.__str__"],                 true]
    - [fu1321sd005, functools.partialmethod.__repr__.__class__.__name__.__eq__,         ["function"],                      true]
    - [fu1321sd006, functools.partialmethod.__repr__.__qualname__.__eq__,               ["_partial_repr"],                  true]
    - [fu1321sd007, functools.partialmethod.__str__.__class__.__name__.__eq__,          ["wrapper_descriptor"],             true]
    - [fu1321sd008, functools.partialmethod.__str__.__qualname__.__eq__,                ["object.__str__"],                 true]
