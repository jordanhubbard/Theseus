spec: theseus_textwrap_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_textwrap_cr2)
blocks: textwrap

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html"
  notes:
    - "Clean-room extended textwrap. Do NOT import textwrap."
    - "TextWrapper class with width, initial_indent, subsequent_indent, break_long_words."
    - "TextWrapper.wrap(text): return list of wrapped lines."
    - "TextWrapper.fill(text): return single string with newlines."
    - "shorten(text, width, **kwargs): truncate to fit width, append placeholder '...'."
    - "indent(text, prefix, predicate=None): add prefix to lines."
    - "textwrap2_wrap_width(): TextWrapper(width=10).wrap('hello world') == ['hello', 'world']."
    - "textwrap2_shorten(): shorten('Hello world', width=8, placeholder='...') == 'Hello...'."
    - "textwrap2_indent(): indent('hello\\nworld', '  ') == '  hello\\n  world'."
    - "Export: TextWrapper, wrap, fill, shorten, indent, dedent."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_textwrap_cr2.wrap_width:
  description: "TextWrapper(width=10).wrap('hello world') == ['hello', 'world']"
  category: wrap
  kind: python_call_eq
  function: textwrap2_wrap_width
  args: []
  expected: ["hello", "world"]

invariant theseus_textwrap_cr2.shorten:
  description: "shorten('Hello world', width=8, placeholder='...') == 'Hello...'"
  category: shorten
  kind: python_call_eq
  function: textwrap2_shorten
  args: []
  expected: "Hello..."

invariant theseus_textwrap_cr2.indent:
  description: "indent('hello\\nworld', '  ') == '  hello\\n  world'"
  category: indent
  kind: python_call_eq
  function: textwrap2_indent
  args: []
  expected: "  hello\n  world"
