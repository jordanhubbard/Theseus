# All nine values are false; re types do not implement in-place division or
# modulo operators in their own __dict__s. re.RegexFlag is an IntFlag subclass;
# __itruediv__, __ifloordiv__, __imod__ are not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

