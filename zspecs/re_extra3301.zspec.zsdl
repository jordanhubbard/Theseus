spec: re3301
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (re3301): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __itruediv__, __ifloordiv__, __imod__ dict-presence (in-place /=, //=, %=)."
    - "No re class defines __itruediv__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; arithmetic is not part of their protocol."
    - "No re class defines __ifloordiv__ in its own __dict__: re types are not numeric operands; in-place floor division is not defined on any re type."
    - "No re class defines __imod__ in its own __dict__: in-place modulo is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): the in-place augmented assignment methods __itruediv__, __ifloordiv__, __imod__ are not defined in re.RegexFlag.__dict__ itself; flag composition uses | not /= or //= or %=."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — operator.contains(Cls.__dict__, '__itruediv__')
#
# No re class defines __itruediv__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but in-place true division is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3301.itruediv:
  description: "re types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3301

  columns: [id, function, args, expected]
  rows:
    - ["re3301001", operator.contains, [re.Pattern.__dict__,   "__itruediv__"], false]
    - ["re3301002", operator.contains, [re.Match.__dict__,     "__itruediv__"], false]
    - ["re3301003", operator.contains, [re.RegexFlag.__dict__, "__itruediv__"], false]

# ---------------------------------------------------------------------------
# __ifloordiv__ dict-presence — operator.contains(Cls.__dict__, '__ifloordiv__')
#
# No re class defines __ifloordiv__ in its own __dict__; all false.
# re types are not numeric operands; in-place floor division is not part of the
# re type protocol. re.RegexFlag (IntFlag) does not define __ifloordiv__ in its
# own __dict__.
# ---------------------------------------------------------------------------

