spec: hashlib_extra2476
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "hashlib_extra306.zspec.zsdl and other pre-existing hashlib_extra files"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — membership test and item access protocol checks in class __dict__."
    - "hashlib.HASH (the CPython internal C type returned by md5(), sha256(), etc.) does NOT define __contains__ or __getitem__ in its own __dict__; it is not a mapping or sequence type."
    - "hashlib.blake2b and hashlib.blake2s are separate C extension types; neither defines __contains__ or __getitem__ in their __dict__."
    - "hashlib.HASH defines the hash API in its __dict__: update, digest, hexdigest, copy, digest_size, block_size, name — but no membership or item-access protocol."
    - "hashlib.blake2b and hashlib.blake2s define BLAKE2-specific constants (SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE) in their __dict__ but no __contains__ or __getitem__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH — __contains__ and __getitem__ absent
#
# hashlib.HASH is the CPython C type for standard hash objects (md5, sha256,
# sha512, sha1, etc.). It does NOT define __contains__ or __getitem__ in its
# class __dict__. Hash objects are not mappings, sequences, or sets and do not
# support membership testing or item access by subscript.
# ---------------------------------------------------------------------------

table hashlib_extra2476.hash_contains_getitem_absent:
  description: "hashlib.HASH.__dict__: __contains__ and __getitem__ absent — HASH is not a mapping or sequence; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2476

  columns: [id, function, args, expected]
  rows:
    - ["hl2476-001", "hashlib.HASH.__dict__.__contains__", ["__contains__"], false]
    - ["hl2476-002", "hashlib.HASH.__dict__.__contains__", ["__getitem__"], false]
    - ["hl2476-003", "hashlib.HASH.__dict__.__contains__", ["__setitem__"], false]
    - ["hl2476-004", "hashlib.HASH.__dict__.__contains__", ["__delitem__"], false]
    - ["hl2476-005", "hashlib.HASH.__dict__.__contains__", ["__iter__"], false]
    - ["hl2476-006", "hashlib.HASH.__dict__.__contains__", ["__len__"], false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.HASH — hash API methods present in __dict__
#
# These own attributes confirm the standard hash interface is directly defined
# on HASH. Their presence in __dict__ contrasts with the absent mapping and
# sequence protocols above: hash objects expose a fixed algorithmic API, not
# a container protocol.
# ---------------------------------------------------------------------------

table hashlib_extra2476.hash_api_present:
  description: "hashlib.HASH.__dict__: standard hash API methods present; contrasts with absent __contains__/__getitem__; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2476

  columns: [id, function, args, expected]
  rows:
    - ["hl2476-007", "hashlib.HASH.__dict__.__contains__", ["update"],      true]
    - ["hl2476-008", "hashlib.HASH.__dict__.__contains__", ["digest"],      true]
    - ["hl2476-009", "hashlib.HASH.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl2476-010", "hashlib.HASH.__dict__.__contains__", ["copy"],        true]
    - ["hl2476-011", "hashlib.HASH.__dict__.__contains__", ["digest_size"], true]
    - ["hl2476-012", "hashlib.HASH.__dict__.__contains__", ["block_size"],  true]
    - ["hl2476-013", "hashlib.HASH.__dict__.__contains__", ["name"],        true]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2b — __contains__ and __getitem__ absent
#
# hashlib.blake2b is a distinct C extension type (from _blake2). It does NOT
# define __contains__ or __getitem__ in its own __dict__. Like HASH, it is not
# a mapping or sequence type.
# ---------------------------------------------------------------------------

table hashlib_extra2476.blake2b_contains_getitem_absent:
  description: "hashlib.blake2b.__dict__: __contains__ and __getitem__ absent; BLAKE2-specific API present; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2476

  columns: [id, function, args, expected]
  rows:
    - ["hl2476-014", "hashlib.blake2b.__dict__.__contains__", ["__contains__"],  false]
    - ["hl2476-015", "hashlib.blake2b.__dict__.__contains__", ["__getitem__"],   false]
    - ["hl2476-016", "hashlib.blake2b.__dict__.__contains__", ["SALT_SIZE"],     true]
    - ["hl2476-017", "hashlib.blake2b.__dict__.__contains__", ["MAX_DIGEST_SIZE"], true]

# ---------------------------------------------------------------------------
# Table 4: hashlib.blake2s — __contains__ and __getitem__ absent
#
# hashlib.blake2s is the 256-bit BLAKE2 variant C extension type. Like blake2b
# it defines no __contains__ or __getitem__ in its __dict__. New to extra2476.
# ---------------------------------------------------------------------------

table hashlib_extra2476.blake2s_contains_getitem_absent:
  description: "hashlib.blake2s.__dict__: __contains__ and __getitem__ absent; BLAKE2-specific constants present; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2476

  columns: [id, function, args, expected]
  rows:
    - ["hl2476-018", "hashlib.blake2s.__dict__.__contains__", ["__contains__"],  false]
    - ["hl2476-019", "hashlib.blake2s.__dict__.__contains__", ["__getitem__"],   false]
    - ["hl2476-020", "hashlib.blake2s.__dict__.__contains__", ["SALT_SIZE"],     true]
    - ["hl2476-021", "hashlib.blake2s.__dict__.__contains__", ["PERSON_SIZE"],   true]
