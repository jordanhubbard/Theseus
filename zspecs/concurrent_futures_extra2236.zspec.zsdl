spec: concurrent_futures_extra2236
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py — Future and Executor base classes"
    - "CPython source: Lib/concurrent/futures/thread.py — ThreadPoolExecutor"
    - "CPython source: Lib/concurrent/futures/process.py — ProcessPoolExecutor"
  notes:
    - "Wave 2236 (_extra2236): __slots__ and slot descriptor protocol — __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__ presence in concurrent.futures class dicts."
    - "All 4 classes (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor) are pure Python."
    - "__slots__ is NOT in the __dict__ of any of the 4 classes — none define __slots__ in their class body."
    - "concurrent.futures.Future has __weakref__ and __dict__ in its class dict — it is a top-level base class without __slots__ and these descriptors appear in its dict."
    - "concurrent.futures.Executor has __weakref__ and __dict__ in its class dict — same reason as Future."
    - "concurrent.futures.ThreadPoolExecutor does NOT have __weakref__ or __dict__ in its class dict — it inherits from Executor which already provides them."
    - "concurrent.futures.ProcessPoolExecutor does NOT have __weakref__ or __dict__ in its class dict — same as ThreadPoolExecutor."
    - "__abstractmethods__ is NOT in the __dict__ of any of the 4 classes — none of them carry unimplemented abstract methods."
    - "concurrent.futures.Future, ThreadPoolExecutor, and ProcessPoolExecutor define __init__ in their class dict. Executor does NOT define __init__ — it uses object.__init__."
    - "__new__ is NOT in the __dict__ of any of the 4 classes — all use object.__new__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __slots__ dict-presence — all 4 concurrent.futures classes
#
# __slots__ is NOT in the __dict__ of any concurrent.futures class. None of
# Future, Executor, ThreadPoolExecutor, or ProcessPoolExecutor define __slots__
# in their class body — all rely on per-instance __dict__. All 4 return False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2236.slots_dict_presence:
  description: "__slots__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2236

  columns: [id, function, args, expected]
  rows:
    - ["cf2236001", "concurrent.futures.Future.__dict__.__contains__", ["__slots__"], false]
    - ["cf2236002", "concurrent.futures.Executor.__dict__.__contains__", ["__slots__"], false]
    - ["cf2236003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__slots__"], false]
    - ["cf2236004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__slots__"], false]

# ---------------------------------------------------------------------------
# Table 2: __weakref__ dict-presence — all 4 concurrent.futures classes
#
# __weakref__ IS in the __dict__ of concurrent.futures.Future and Executor.
# These are root classes in their respective hierarchies without __slots__,
# so CPython places a __weakref__ slot descriptor in their own class dict.
# ThreadPoolExecutor and ProcessPoolExecutor inherit __weakref__ support
# from Executor and do not repeat it in their own class dict.
# Future=True, Executor=True, ThreadPoolExecutor=False, ProcessPoolExecutor=False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2236.weakref_dict_presence:
  description: "__weakref__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — Future and Executor True, subclasses False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2236

  columns: [id, function, args, expected]
  rows:
    - ["cf2236005", "concurrent.futures.Future.__dict__.__contains__", ["__weakref__"], true]
    - ["cf2236006", "concurrent.futures.Executor.__dict__.__contains__", ["__weakref__"], true]
    - ["cf2236007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__weakref__"], false]
    - ["cf2236008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__weakref__"], false]

# ---------------------------------------------------------------------------
# Table 3: __dict__ dict-presence — all 4 concurrent.futures classes
#
# A __dict__ descriptor in a class's own __dict__ signals that the class
# introduces per-instance attribute storage. concurrent.futures.Future and
# Executor are top-level classes; CPython inserts __dict__ descriptors in
# their own class dicts. ThreadPoolExecutor and ProcessPoolExecutor inherit
# instance dict support from Executor and have no __dict__ descriptor in
# their own class dict.
# Future=True, Executor=True, ThreadPoolExecutor=False, ProcessPoolExecutor=False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2236.dict_dict_presence:
  description: "__dict__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — Future and Executor True, subclasses False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2236

  columns: [id, function, args, expected]
  rows:
    - ["cf2236009", "concurrent.futures.Future.__dict__.__contains__", ["__dict__"], true]
    - ["cf2236010", "concurrent.futures.Executor.__dict__.__contains__", ["__dict__"], true]
    - ["cf2236011", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__dict__"], false]
    - ["cf2236012", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__dict__"], false]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__ dict-presence — all 4 concurrent.futures classes
#
# __abstractmethods__ is NOT in the __dict__ of any concurrent.futures class.
# Although Executor is conceptually abstract and its submit() raises
# NotImplementedError, it does NOT use the abc.ABCMeta machinery and therefore
# carries no __abstractmethods__ frozenset in its class dict. All 4 False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2236.abstractmethods_dict_presence:
  description: "__abstractmethods__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2236

  columns: [id, function, args, expected]
  rows:
    - ["cf2236013", "concurrent.futures.Future.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["cf2236014", "concurrent.futures.Executor.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["cf2236015", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["cf2236016", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 5: __init__ dict-presence — all 4 concurrent.futures classes
#
# __init__ IS in the __dict__ of Future, ThreadPoolExecutor, and
# ProcessPoolExecutor — each defines custom initialization in its class body.
# Executor does NOT define __init__; it relies on object.__init__ and uses
# a context-manager pattern without constructor arguments.
# Future=True, Executor=False, ThreadPoolExecutor=True, ProcessPoolExecutor=True.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2236.init_dict_presence:
  description: "__init__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — Future/TPE/PPE True, Executor False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2236

  columns: [id, function, args, expected]
  rows:
    - ["cf2236017", "concurrent.futures.Future.__dict__.__contains__", ["__init__"], true]
    - ["cf2236018", "concurrent.futures.Executor.__dict__.__contains__", ["__init__"], false]
    - ["cf2236019", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__init__"], true]
    - ["cf2236020", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init__"], true]

# ---------------------------------------------------------------------------
# Table 6: __new__ dict-presence — all 4 concurrent.futures classes
#
# __new__ is NOT in the __dict__ of any concurrent.futures class. None of
# Future, Executor, ThreadPoolExecutor, or ProcessPoolExecutor override
# __new__ — all rely on object.__new__ for instance creation. All 4 False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2236.new_dict_presence:
  description: "__new__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2236

  columns: [id, function, args, expected]
  rows:
    - ["cf2236021", "concurrent.futures.Future.__dict__.__contains__", ["__new__"], false]
    - ["cf2236022", "concurrent.futures.Executor.__dict__.__contains__", ["__new__"], false]
    - ["cf2236023", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__new__"], false]
    - ["cf2236024", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 7: Cross-check — slot descriptor protocol summary
#
# This table collects the distinguishing cases across all four classes:
# the presence of __weakref__ and __dict__ in base classes but not subclasses,
# the absence of __slots__ everywhere, and the selective presence of __init__.
# Provides a concise verifiable summary of the slot descriptor protocol
# for the concurrent.futures hierarchy.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2236.slot_protocol_summary:
  description: "Slot descriptor protocol cross-check — __slots__ absent everywhere; __weakref__/__dict__ in base classes; __init__ in concrete classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2236

  columns: [id, function, args, expected]
  rows:
    - ["cf2236025", "concurrent.futures.Future.__dict__.__contains__", ["__slots__"], false]
    - ["cf2236026", "concurrent.futures.Future.__dict__.__contains__", ["__weakref__"], true]
    - ["cf2236027", "concurrent.futures.Future.__dict__.__contains__", ["__dict__"], true]
    - ["cf2236028", "concurrent.futures.Executor.__dict__.__contains__", ["__weakref__"], true]
    - ["cf2236029", "concurrent.futures.Executor.__dict__.__contains__", ["__dict__"], true]
    - ["cf2236030", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__weakref__"], false]
    - ["cf2236031", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__weakref__"], false]
    - ["cf2236032", "concurrent.futures.Executor.__dict__.__contains__", ["__init__"], false]
    - ["cf2236033", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__init__"], true]
    - ["cf2236034", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init__"], true]
