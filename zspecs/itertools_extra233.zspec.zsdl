spec: itertools_extra233
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.tee and itertools.product __doc__ contracts."
    - "itertools.tee.__name__ == 'tee' (len=3) — tee is a builtin_function_or_method in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.tee.__module__ == 'itertools' — tee is part of the itertools C extension module. Verified with Python 3.14.3."
    - "itertools.tee.__doc__.__contains__('Returns') == True — tee docstring starts with 'Returns a tuple of n independent iterators.' (len=43). Verified with Python 3.14.3."
    - "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a function, not a type. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product' (len=7) — product is a C extension type (class). Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' — product is part of the itertools C extension module. Verified with Python 3.14.3."
    - "itertools.product.__class__.__name__ == 'type' — product is a C extension type. Verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object' — product inherits directly from object. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__contains__('product') == True — product docstring contains the word 'product'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.tee __doc__ and identity contracts
#
# itertools.tee.__name__ == 'tee' (len=3)
# itertools.tee.__module__ == 'itertools'
# itertools.tee.__doc__.__contains__('Returns') == True
# itertools.tee.__doc__.__len__() == 43
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
#
# tee is a builtin function (not a class/type) in itertoolsmodule.c.
# New to extra233.
# ---------------------------------------------------------------------------

table itertools_extra233.tee_identity:
  description: "itertools.tee identity contracts: name, module, doc class, doc contains 'Returns'; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra233teeid

  columns: [id, function, args, expected, description]
  rows:
    - [tee_name_eq,
       tee.__name__.__eq__,
       ["tee"],
       true,
       "itertools.tee.__name__.__eq__('tee') == True — tee is a builtin_function_or_method in itertoolsmodule.c that returns n independent iterators; __name__ is 'tee' (len=3); new to extra233"]
    - [tee_name_len_3,
       tee.__name__.__len__,
       [],
       3,
       "itertools.tee.__name__.__len__() == 3 — 'tee' has exactly 3 characters (t-e-e); str.__len__() returns 3; new to extra233"]
    - [tee_module_eq,
       tee.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.tee.__module__.__eq__('itertools') == True — tee is defined in the itertools C extension module; __module__ is 'itertools'; new to extra233"]
    - [tee_doc_contains_returns,
       tee.__doc__.__contains__,
       ["Returns"],
       true,
       "itertools.tee.__doc__.__contains__('Returns') == True — tee docstring 'Returns a tuple of n independent iterators.' begins with 'Returns'; str.__contains__('Returns') returns True; new to extra233"]
    - [tee_doc_len_43,
       tee.__doc__.__len__,
       [],
       43,
       "itertools.tee.__doc__.__len__() == 43 — 'Returns a tuple of n independent iterators.' has exactly 43 characters; str.__len__() returns 43; new to extra233"]

# ---------------------------------------------------------------------------
# Table 2: itertools.tee __class__ and itertools.product name contracts
#
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
# itertools.product.__name__ == 'product' (len=7)
# itertools.product.__module__ == 'itertools'
# itertools.product.__class__.__name__ == 'type'
# itertools.product.__qualname__ == 'product'
#
# product is a C extension type (unlike tee which is a function).
# New to extra233.
# ---------------------------------------------------------------------------

table itertools_extra233.tee_class_product_name:
  description: "itertools.tee __class__ is builtin_function_or_method; product name and module contracts; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra233teeproductid

  columns: [id, function, args, expected, description]
  rows:
    - [tee_class_eq,
       tee.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — tee is a builtin function, not a class; its __class__.__name__ is 'builtin_function_or_method'; new to extra233"]
    - [product_name_eq,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C extension type for cartesian products of iterables; __name__ is 'product' (len=7); new to extra233"]
    - [product_name_len_7,
       product.__name__.__len__,
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — 'product' has exactly 7 characters (p-r-o-d-u-c-t); str.__len__() returns 7; new to extra233"]
    - [product_module_eq,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is defined in the itertools C extension module; __module__ is 'itertools'; new to extra233"]
    - [product_qualname_eq,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is a top-level class with unqualified qualname 'product'; new to extra233"]

# ---------------------------------------------------------------------------
# Table 3: itertools.product __class__, __bases__, and __doc__ contracts
#
# itertools.product.__class__.__name__ == 'type'
# itertools.product.__bases__[0].__name__ == 'object'
# itertools.product.__doc__.__contains__('product') == True
# itertools.product.__doc__.__class__.__name__ == 'str'
# itertools.tee.__qualname__ == 'tee'
#
# product is a C extension type whose metaclass is the built-in type and whose
# sole base class is object. New to extra233.
# ---------------------------------------------------------------------------

table itertools_extra233.product_class_doc:
  description: "itertools.product __class__ is type, base is object, __doc__ contains 'product'; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra233productclassid

  columns: [id, function, args, expected, description]
  rows:
    - [product_class_is_type,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a C extension type whose metaclass is the built-in type; __class__.__name__ is 'type'; new to extra233"]
    - [product_base_is_object,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — product inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra233"]
    - [product_doc_contains_product,
       product.__doc__.__contains__,
       ["product"],
       true,
       "itertools.product.__doc__.__contains__('product') == True — product docstring contains the word 'product'; str.__contains__('product') returns True; new to extra233"]
    - [product_doc_class_is_str,
       product.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__.__eq__('str') == True — the docstring of product is a plain Python str object; __class__.__name__ is 'str'; new to extra233"]
    - [tee_qualname_eq,
       tee.__qualname__.__eq__,
       ["tee"],
       true,
       "itertools.tee.__qualname__.__eq__('tee') == True — tee is a top-level builtin function with unqualified qualname 'tee'; str.__eq__('tee') returns True; new to extra233"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra233
# ---------------------------------------------------------------------------

invariant itertools_extra233.tee_name_eq:
  description: "itertools.tee.__name__ == 'tee' (len=3); new to extra233"
  kind: python_call_eq
  function: tee.__name__.__eq__
  args: ["tee"]
  expected: true

invariant itertools_extra233.tee_name_len_3:
  description: "itertools.tee.__name__.__len__() == 3 — 'tee' has 3 characters; new to extra233"
  kind: python_call_eq
  function: tee.__name__.__len__
  args: []
  expected: 3

invariant itertools_extra233.tee_module_eq:
  description: "itertools.tee.__module__ == 'itertools'; new to extra233"
  kind: python_call_eq
  function: tee.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra233.tee_doc_contains_returns:
  description: "itertools.tee.__doc__.__contains__('Returns') == True — tee docstring starts with 'Returns'; new to extra233"
  kind: python_call_eq
  function: tee.__doc__.__contains__
  args: ["Returns"]
  expected: true

invariant itertools_extra233.tee_doc_len_43:
  description: "itertools.tee.__doc__.__len__() == 43 — tee docstring has 43 characters; new to extra233"
  kind: python_call_eq
  function: tee.__doc__.__len__
  args: []
  expected: 43

invariant itertools_extra233.tee_class_eq:
  description: "itertools.tee.__class__.__name__ == 'builtin_function_or_method'; new to extra233"
  kind: python_call_eq
  function: tee.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra233.tee_qualname_eq:
  description: "itertools.tee.__qualname__ == 'tee'; new to extra233"
  kind: python_call_eq
  function: tee.__qualname__.__eq__
  args: ["tee"]
  expected: true

invariant itertools_extra233.product_name_eq:
  description: "itertools.product.__name__ == 'product' (len=7); new to extra233"
  kind: python_call_eq
  function: product.__name__.__eq__
  args: ["product"]
  expected: true

invariant itertools_extra233.product_module_eq:
  description: "itertools.product.__module__ == 'itertools'; new to extra233"
  kind: python_call_eq
  function: product.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra233.product_class_is_type:
  description: "itertools.product.__class__.__name__ == 'type' — product is a C extension type; new to extra233"
  kind: python_call_eq
  function: product.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra233.product_base_is_object:
  description: "itertools.product.__bases__[0].__name__ == 'object' — product inherits from object; new to extra233"
  kind: python_call_eq
  function: "product.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra233.product_doc_contains_product:
  description: "itertools.product.__doc__.__contains__('product') == True — product docstring contains 'product'; new to extra233"
  kind: python_call_eq
  function: product.__doc__.__contains__
  args: ["product"]
  expected: true
