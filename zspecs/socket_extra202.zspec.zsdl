  notes:
    - "socket.__spec__.name == 'socket' — the ModuleSpec name matches the module name."
    - "socket.__spec__.has_location == True — socket is a Python source file (Lib/socket.py) with a known location on disk."
    - "socket.__spec__.parent == '' — socket is a top-level module; parent is the empty string."
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance."
    - "socket.__spec__.origin.__class__.__name__ == 'str' — the origin attribute (path to socket.py) is a plain str."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

