spec: inspect_extra74
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra73.zspec.zsdl."
    - "Wave 240 theme: inspect FrameInfo/FullArgSpec class identity and getfullargspec/getcallargs/ismethod code attrs."
    - "FrameInfo.__name__ == 'FrameInfo' — FrameInfo is a NamedTuple subclass in inspect.py. Verified with Python 3.14.3."
    - "FrameInfo.__module__ == 'inspect' — FrameInfo is defined in the inspect module. Verified with Python 3.14.3."
    - "FrameInfo.__bases__[0].__name__ == '_FrameInfo' — In Python 3.14 FrameInfo is a two-step NamedTuple; its direct base is the internal _FrameInfo namedtuple. Verified with Python 3.14.3."
    - "FrameInfo.__mro__.__len__() == 4 — FrameInfo MRO is [FrameInfo, _FrameInfo, tuple, object] with 4 entries. Verified with Python 3.14.3."
    - "FullArgSpec.__name__ == 'FullArgSpec' — FullArgSpec is a NamedTuple defined in inspect.py and still present in Python 3.14. Verified with Python 3.14.3."
    - "FullArgSpec.__module__ == 'inspect' — FullArgSpec is defined in the inspect module. Verified with Python 3.14.3."
    - "FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a simple NamedTuple; its direct base is tuple. Verified with Python 3.14.3."
    - "FullArgSpec.__mro__.__len__() == 3 — FullArgSpec MRO is [FullArgSpec, tuple, object] with 3 entries. Verified with Python 3.14.3."
    - "getfullargspec.__code__.co_name == 'getfullargspec' — co_name matches the def statement. Verified with Python 3.14.3."
    - "getfullargspec.__code__.co_argcount == 1 — getfullargspec(func) takes 1 positional arg. Verified with Python 3.14.3."
    - "getcallargs.__code__.co_name == 'getcallargs' — getcallargs still exists in Python 3.14 (deprecated but present); co_name matches the def. Verified with Python 3.14.3."
    - "getcallargs.__code__.co_argcount == 1 — getcallargs(func, /, *args, **kwds): co_argcount == 1. Verified with Python 3.14.3."
    - "ismethod.__code__.co_name == 'ismethod' — ismethod is a pure-Python function. Verified with Python 3.14.3."
    - "ismethod.__code__.co_argcount == 1 — ismethod(object) takes 1 positional arg. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FrameInfo class identity — extra74
#
# Wave 240 theme: FrameInfo NamedTuple class identity attributes.
#
# inspect.FrameInfo is a NamedTuple subclass defined in Lib/inspect.py.
# In Python 3.14 it has a two-step NamedTuple hierarchy.
#
# FrameInfo.__name__              == 'FrameInfo'
# FrameInfo.__module__            == 'inspect'
# FrameInfo.__bases__[0].__name__ == '_FrameInfo'
# FrameInfo.__mro__.__len__()     == 4
#
# No prior inspect spec checks FrameInfo identity via inspmore74. New to extra74.
# ---------------------------------------------------------------------------

table inspect_extra74.FrameInfo_identity:
  description: "FrameInfo.__name__=='FrameInfo', __module__=='inspect', __bases__[0].__name__=='_FrameInfo', __mro__.__len__()==4; wave 240 FrameInfo identity; new to extra74"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore74

  columns: [id, function, args, expected, description]
  rows:
    - [FrameInfo_name_eq_FrameInfo,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a NamedTuple subclass defined in Lib/inspect.py representing information about a stack frame; its __name__ attribute stores the class name as a str 'FrameInfo' (9 chars); str.__eq__('FrameInfo') returns True; no prior inspect spec checks FrameInfo.__name__ via inspmore74; new to extra74"]
    - [FrameInfo_module_eq_inspect,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in Lib/inspect.py and its __module__ attribute records the module name as the str 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks FrameInfo.__module__ via inspmore74; new to extra74"]
    - [FrameInfo_bases0_name_eq_FrameInfo_internal,
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — in Python 3.14 FrameInfo is built as a two-step NamedTuple; its direct base class is the internal _FrameInfo namedtuple (not tuple directly); __bases__[0].__name__ == '_FrameInfo' (10 chars); str.__eq__('_FrameInfo') returns True; no prior inspect spec checks FrameInfo.__bases__[0].__name__ via inspmore74; new to extra74"]
    - [FrameInfo_mro_len_eq_4,
       FrameInfo.__mro__.__len__,
       [],
       4,
       "inspect.FrameInfo.__mro__.__len__() == 4 — FrameInfo's MRO in Python 3.14 is [FrameInfo, _FrameInfo, tuple, object] with exactly 4 entries due to the two-step NamedTuple hierarchy; tuple.__len__() returns 4; no prior inspect spec checks FrameInfo.__mro__.__len__ via inspmore74; new to extra74"]

# ---------------------------------------------------------------------------
# FullArgSpec class identity — extra74
#
# Wave 240 theme: FullArgSpec NamedTuple class identity attributes.
#
# inspect.FullArgSpec is a simple NamedTuple in Lib/inspect.py (still present in Python 3.14).
#
# FullArgSpec.__name__              == 'FullArgSpec'
# FullArgSpec.__module__            == 'inspect'
# FullArgSpec.__bases__[0].__name__ == 'tuple'
# FullArgSpec.__mro__.__len__()     == 3
#
# No prior inspect spec checks FullArgSpec identity via inspmore74. New to extra74.
# ---------------------------------------------------------------------------

table inspect_extra74.FullArgSpec_identity:
  description: "FullArgSpec.__name__=='FullArgSpec', __module__=='inspect', __bases__[0].__name__=='tuple', __mro__.__len__()==3; wave 240 FullArgSpec identity; new to extra74"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore74

  columns: [id, function, args, expected, description]
  rows:
    - [FullArgSpec_name_eq_FullArgSpec,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a NamedTuple defined in Lib/inspect.py that holds the result of getfullargspec(); it is still present in Python 3.14 (deprecated but not removed); __name__ stores the class name as a str 'FullArgSpec' (11 chars); str.__eq__('FullArgSpec') returns True; no prior inspect spec checks FullArgSpec.__name__ via inspmore74; new to extra74"]
    - [FullArgSpec_module_eq_inspect,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in Lib/inspect.py and its __module__ attribute records the module name as the str 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks FullArgSpec.__module__ via inspmore74; new to extra74"]
    - [FullArgSpec_bases0_name_eq_tuple,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a simple NamedTuple with no additional intermediate base; its direct base class is the built-in tuple type; __bases__[0].__name__ == 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior inspect spec checks FullArgSpec.__bases__[0].__name__ via inspmore74; new to extra74"]
    - [FullArgSpec_mro_len_eq_3,
       FullArgSpec.__mro__.__len__,
       [],
       3,
       "inspect.FullArgSpec.__mro__.__len__() == 3 — FullArgSpec is a simple NamedTuple; its MRO is [FullArgSpec, tuple, object] with exactly 3 entries; tuple.__len__() returns 3; no prior inspect spec checks FullArgSpec.__mro__.__len__ via inspmore74; new to extra74"]

# ---------------------------------------------------------------------------
# getfullargspec and getcallargs code attributes — extra74
#
# Wave 240 theme: code object name and argcount for getfullargspec and getcallargs.
#
# inspect.getfullargspec.__code__.co_name     == 'getfullargspec'
# inspect.getfullargspec.__code__.co_argcount == 1
# inspect.getcallargs.__code__.co_name        == 'getcallargs'
# inspect.getcallargs.__code__.co_argcount    == 1
#
# No prior inspect spec checks these code attrs via inspmore74. New to extra74.
# ---------------------------------------------------------------------------

table inspect_extra74.getfullargspec_getcallargs_code:
  description: "getfullargspec/__code__.co_name=='getfullargspec', co_argcount==1; getcallargs/__code__.co_name=='getcallargs', co_argcount==1; wave 240 function code attrs; new to extra74"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspmore74

  columns: [id, function, args, expected, description]
  rows:
    - [getfullargspec_co_name_eq_getfullargspec,
       getfullargspec.__code__.co_name.__eq__,
       ["getfullargspec"],
       true,
       "inspect.getfullargspec.__code__.co_name.__eq__('getfullargspec') == True — getfullargspec is a pure-Python function in Lib/inspect.py; its code object's co_name stores the name from the def statement which is 'getfullargspec' (14 chars); str.__eq__('getfullargspec') returns True; no prior inspect spec checks getfullargspec.__code__.co_name via inspmore74; new to extra74"]
    - [getfullargspec_co_argcount_eq_1,
       getfullargspec.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getfullargspec.__code__.co_argcount.__eq__(1) == True — getfullargspec is defined as 'def getfullargspec(func):' with 1 positional parameter; co_argcount counts only positional parameters and equals 1; int.__eq__(1) returns True; no prior inspect spec checks getfullargspec.__code__.co_argcount via inspmore74; new to extra74"]
    - [getcallargs_co_name_eq_getcallargs,
       getcallargs.__code__.co_name.__eq__,
       ["getcallargs"],
       true,
       "inspect.getcallargs.__code__.co_name.__eq__('getcallargs') == True — getcallargs is a pure-Python function in Lib/inspect.py (deprecated but present in Python 3.14); its code object's co_name stores the name from the def statement which is 'getcallargs' (11 chars); str.__eq__('getcallargs') returns True; no prior inspect spec checks getcallargs.__code__.co_name via inspmore74; new to extra74"]
    - [getcallargs_co_argcount_eq_1,
       getcallargs.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getcallargs.__code__.co_argcount.__eq__(1) == True — getcallargs is defined as 'def getcallargs(func, /, *args, **kwds):' with 1 positional-or-keyword parameter (func); co_argcount counts positional-or-keyword parameters only (not *args or **kwds) and equals 1; int.__eq__(1) returns True; no prior inspect spec checks getcallargs.__code__.co_argcount via inspmore74; new to extra74"]

# ---------------------------------------------------------------------------
# ismethod code attributes — extra74
#
# Wave 240 theme: ismethod co_name and co_argcount.
#
# inspect.ismethod.__code__.co_name     == 'ismethod'
# inspect.ismethod.__code__.co_argcount == 1
#
# No prior inspect spec checks ismethod code attrs via inspmore74. New to extra74.
# ---------------------------------------------------------------------------

table inspect_extra74.ismethod_code:
  description: "ismethod/__code__.co_name=='ismethod', co_argcount==1; wave 240 ismethod code attrs; new to extra74"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspmore74

  columns: [id, function, args, expected, description]
  rows:
    - [ismethod_co_name_eq_ismethod,
       ismethod.__code__.co_name.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__code__.co_name.__eq__('ismethod') == True — ismethod is a pure-Python function in Lib/inspect.py that returns True if the object is a bound method; its code object's co_name stores the name from the def statement which is 'ismethod' (8 chars); str.__eq__('ismethod') returns True; no prior inspect spec checks ismethod.__code__.co_name via inspmore74; new to extra74"]
    - [ismethod_co_argcount_eq_1,
       ismethod.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.ismethod.__code__.co_argcount.__eq__(1) == True — ismethod is defined as 'def ismethod(object):' with 1 positional parameter; co_argcount counts only positional parameters and equals 1; int.__eq__(1) returns True; no prior inspect spec checks ismethod.__code__.co_argcount via inspmore74; new to extra74"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra74
# ---------------------------------------------------------------------------

invariant inspect_extra74.FrameInfo_name:
  description: "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo class name is 'FrameInfo'; wave 240 FrameInfo identity; new to extra74"
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra74.FrameInfo_mro_len:
  description: "inspect.FrameInfo.__mro__.__len__() == 4 — FrameInfo MRO has 4 entries [FrameInfo, _FrameInfo, tuple, object]; wave 240 FrameInfo identity; new to extra74"
  kind: python_call_eq
  function: FrameInfo.__mro__.__len__
  args: []
  expected: 4

invariant inspect_extra74.FullArgSpec_name:
  description: "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec class name is 'FullArgSpec'; wave 240 FullArgSpec identity; new to extra74"
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra74.getfullargspec_co_name:
  description: "inspect.getfullargspec.__code__.co_name.__eq__('getfullargspec') == True — getfullargspec co_name is 'getfullargspec'; wave 240 function code attrs; new to extra74"
  kind: python_call_eq
  function: getfullargspec.__code__.co_name.__eq__
  args: ["getfullargspec"]
  expected: true

invariant inspect_extra74.ismethod_co_name:
  description: "inspect.ismethod.__code__.co_name.__eq__('ismethod') == True — ismethod co_name is 'ismethod'; wave 240 ismethod code attrs; new to extra74"
  kind: python_call_eq
  function: ismethod.__code__.co_name.__eq__
  args: ["ismethod"]
  expected: true
