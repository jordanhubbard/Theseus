spec: decimal_extra173
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal arithmetic method names — __add__, __sub__, __mul__, __truediv__, __mod__, __pow__, __neg__, __abs__ — all are wrapper_descriptor instances on the C-implemented Decimal type."
    - "decimal.Decimal is implemented in C (_decimal extension) so its special methods are wrapper_descriptor objects, not Python slot wrappers."
    - "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' — verified Python 3.14.3 macOS."
    - "Name length groupings: __add__==__sub__==__mul__==__mod__==__pow__==__neg__==__abs__ (7); __truediv__ (11)."
    - "A 7-way tie at length 7: __add__ (7) == __sub__ (7) == __mul__ (7) == __mod__ (7) == __pow__ (7) == __neg__ (7) == __abs__ (7)."
    - "__truediv__ (11) is the only method with a different length; __truediv__ (11) > all others (7) by 4 characters."
    - "Length ordering: __add__==__sub__==__mul__==__mod__==__pow__==__neg__==__abs__ (7) < __truediv__ (11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal binary arithmetic method names (__add__, __sub__, __mul__)
# All three have len==7 — part of the 7-way tie at length 7
# ---------------------------------------------------------------------------

table decimal_extra173.binary_arith_method_names:
  description: "decimal.Decimal binary arithmetic method names: __add__.__name__=='__add__' (len=7); __sub__.__name__=='__sub__' (len=7); __mul__.__name__=='__mul__' (len=7); all three share length 7 — part of the 7-way tie"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmath173

  columns: [id, function, args, expected, description]
  rows:
    - [add_name,      "Decimal.__add__.__name__.__eq__",      ["__add__"], true, "decimal.Decimal.__add__.__name__ == '__add__' — __add__ implements the + operator for Decimal; '__add__' has 7 characters: _(1)_(2)a(3)d(4)d(5)_(6)_(7); __add__ (7) is part of the 7-way tie at length 7; confirmed Python 3.14.3 macOS"]
    - [add_name_len,  "Decimal.__add__.__name__.__len__",     [],          7,    "decimal.Decimal.__add__.__name__.__len__() == 7 — '__add__' has 7 characters; __add__ (7) == __sub__ (7) == __mul__ (7) == __mod__ (7) == __pow__ (7) == __neg__ (7) == __abs__ (7): a 7-way tie; __add__ (7) < __truediv__ (11); confirmed Python 3.14.3 macOS"]
    - [sub_name,      "Decimal.__sub__.__name__.__eq__",      ["__sub__"], true, "decimal.Decimal.__sub__.__name__ == '__sub__' — __sub__ implements the - operator for Decimal; '__sub__' has 7 characters: _(1)_(2)s(3)u(4)b(5)_(6)_(7); __sub__ (7) == __add__ (7): both share length 7 as part of the 7-way tie; confirmed Python 3.14.3 macOS"]
    - [sub_name_len,  "Decimal.__sub__.__name__.__len__",     [],          7,    "decimal.Decimal.__sub__.__name__.__len__() == 7 — '__sub__' has 7 characters; __sub__ (7) == __add__ (7) == __mul__ (7): all binary arithmetic operators share length 7; confirmed Python 3.14.3 macOS"]
    - [mul_name,      "Decimal.__mul__.__name__.__eq__",      ["__mul__"], true, "decimal.Decimal.__mul__.__name__ == '__mul__' — __mul__ implements the * operator for Decimal; '__mul__' has 7 characters: _(1)_(2)m(3)u(4)l(5)_(6)_(7); __mul__ (7) == __add__ (7) == __sub__ (7): a 3-way tie among the first three arithmetic operators, extending to a 7-way tie overall; confirmed Python 3.14.3 macOS"]
    - [mul_name_len,  "Decimal.__mul__.__name__.__len__",     [],          7,    "decimal.Decimal.__mul__.__name__.__len__() == 7 — '__mul__' has 7 characters; __mul__ (7) is part of the 7-way tie; __mul__ (7) < __truediv__ (11): __truediv__ is the only outlier at length 11; confirmed Python 3.14.3 macOS"]
    - [add_class,     "Decimal.__add__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C type so its special methods are wrapper_descriptor objects; all Decimal arithmetic methods (__add__, __sub__, __mul__, __truediv__, __mod__, __pow__, __neg__, __abs__) share this class; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal division and modulo method names (__truediv__, __mod__)
# __truediv__ (11) is the unique outlier; __mod__ (7) is in the tie group
# ---------------------------------------------------------------------------

table decimal_extra173.division_method_names:
  description: "decimal.Decimal division/modulo method names: __truediv__.__name__=='__truediv__' (len=11); __mod__.__name__=='__mod__' (len=7); __truediv__ (11) > __mod__ (7) by 4: __truediv__ is the longest Decimal arithmetic method name"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmath173

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_name,      "Decimal.__truediv__.__name__.__eq__",  ["__truediv__"], true, "decimal.Decimal.__truediv__.__name__ == '__truediv__' — __truediv__ implements the / operator for Decimal; '__truediv__' has 11 characters: _(1)_(2)t(3)r(4)u(5)e(6)d(7)i(8)v(9)_(10)_(11); __truediv__ (11) is the only Decimal arithmetic method not in the 7-way tie; confirmed Python 3.14.3 macOS"]
    - [truediv_name_len,  "Decimal.__truediv__.__name__.__len__", [],              11,   "decimal.Decimal.__truediv__.__name__.__len__() == 11 — '__truediv__' has 11 characters; __truediv__ (11) > __add__==__sub__==__mul__==__mod__==__pow__==__neg__==__abs__ (7) by 4: __truediv__ is uniquely the longest arithmetic method name; confirmed Python 3.14.3 macOS"]
    - [mod_name,          "Decimal.__mod__.__name__.__eq__",      ["__mod__"],     true, "decimal.Decimal.__mod__.__name__ == '__mod__' — __mod__ implements the % operator for Decimal; '__mod__' has 7 characters: _(1)_(2)m(3)o(4)d(5)_(6)_(7); __mod__ (7) is part of the 7-way tie; confirmed Python 3.14.3 macOS"]
    - [mod_name_len,      "Decimal.__mod__.__name__.__len__",     [],              7,    "decimal.Decimal.__mod__.__name__.__len__() == 7 — '__mod__' has 7 characters; __mod__ (7) == __add__ (7) == __sub__ (7) == __mul__ (7) == __pow__ (7) == __neg__ (7) == __abs__ (7): all in the 7-way tie; __mod__ (7) < __truediv__ (11); confirmed Python 3.14.3 macOS"]
    - [truediv_class,     "Decimal.__truediv__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__truediv__.__class__.__name__ == 'wrapper_descriptor' — __truediv__ is a C wrapper_descriptor like all Decimal arithmetic methods; confirmed Python 3.14.3 macOS"]
    - [mod_class,         "Decimal.__mod__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true, "decimal.Decimal.__mod__.__class__.__name__ == 'wrapper_descriptor' — __mod__ is a C wrapper_descriptor; all Decimal arithmetic special methods share this descriptor class; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal power and unary method names (__pow__, __neg__, __abs__)
# All three have len==7 — completing the 7-way tie
# ---------------------------------------------------------------------------

table decimal_extra173.power_and_unary_method_names:
  description: "decimal.Decimal power and unary method names: __pow__.__name__=='__pow__' (len=7); __neg__.__name__=='__neg__' (len=7); __abs__.__name__=='__abs__' (len=7); all three are in the 7-way tie at length 7"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmath173

  columns: [id, function, args, expected, description]
  rows:
    - [pow_name,      "Decimal.__pow__.__name__.__eq__",      ["__pow__"], true, "decimal.Decimal.__pow__.__name__ == '__pow__' — __pow__ implements the ** operator for Decimal; '__pow__' has 7 characters: _(1)_(2)p(3)o(4)w(5)_(6)_(7); __pow__ (7) is part of the 7-way tie; confirmed Python 3.14.3 macOS"]
    - [pow_name_len,  "Decimal.__pow__.__name__.__len__",     [],          7,    "decimal.Decimal.__pow__.__name__.__len__() == 7 — '__pow__' has 7 characters; __pow__ (7) == __neg__ (7) == __abs__ (7) == __add__ (7) == __sub__ (7) == __mul__ (7) == __mod__ (7): the 7-way tie; __pow__ (7) < __truediv__ (11); confirmed Python 3.14.3 macOS"]
    - [neg_name,      "Decimal.__neg__.__name__.__eq__",      ["__neg__"], true, "decimal.Decimal.__neg__.__name__ == '__neg__' — __neg__ implements unary negation (-x) for Decimal; '__neg__' has 7 characters: _(1)_(2)n(3)e(4)g(5)_(6)_(7); __neg__ (7) is part of the 7-way tie; confirmed Python 3.14.3 macOS"]
    - [neg_name_len,  "Decimal.__neg__.__name__.__len__",     [],          7,    "decimal.Decimal.__neg__.__name__.__len__() == 7 — '__neg__' has 7 characters; __neg__ (7) == __abs__ (7): both unary methods share length 7; all 7 non-truediv methods share length 7; confirmed Python 3.14.3 macOS"]
    - [abs_name,      "Decimal.__abs__.__name__.__eq__",      ["__abs__"], true, "decimal.Decimal.__abs__.__name__ == '__abs__' — __abs__ implements the abs() built-in for Decimal; '__abs__' has 7 characters: _(1)_(2)a(3)b(4)s(5)_(6)_(7); __abs__ (7) == __neg__ (7): both unary operators share length 7; the full 7-way tie: __add__==__sub__==__mul__==__mod__==__pow__==__neg__==__abs__ (7); confirmed Python 3.14.3 macOS"]
    - [abs_name_len,  "Decimal.__abs__.__name__.__len__",     [],          7,    "decimal.Decimal.__abs__.__name__.__len__() == 7 — '__abs__' has 7 characters; __abs__ (7) completes the 7-way tie: __add__==__sub__==__mul__==__mod__==__pow__==__neg__==__abs__ all have length 7; __truediv__ (11) is the sole outlier at length 11 — 4 characters longer than the tie group; confirmed Python 3.14.3 macOS"]
    - [abs_class,     "Decimal.__abs__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__abs__.__class__.__name__ == 'wrapper_descriptor' — __abs__ is a C wrapper_descriptor; all Decimal arithmetic methods are wrapper_descriptor instances; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra173.add_name_is_dunder_add:
  description: "decimal.Decimal.__add__.__name__ == '__add__' — __add__ is the addition operator; len=7; __add__ (7) is part of the 7-way tie at length 7 among Decimal arithmetic methods; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__add__.__name__.__eq__"
  args: ["__add__"]
  expected: true

invariant decimal_extra173.sub_name_len_is_7:
  description: "decimal.Decimal.__sub__.__name__.__len__() == 7 — '__sub__' has 7 characters; __sub__ (7) == __add__ (7): both share length 7 as part of the 7-way tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__sub__.__name__.__len__"
  args: []
  expected: 7

invariant decimal_extra173.truediv_name_len_is_11:
  description: "decimal.Decimal.__truediv__.__name__.__len__() == 11 — '__truediv__' has 11 characters; __truediv__ (11) is the only Decimal arithmetic method not in the 7-way tie; __truediv__ (11) > all others (7) by 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__truediv__.__name__.__len__"
  args: []
  expected: 11

invariant decimal_extra173.mul_name_is_dunder_mul:
  description: "decimal.Decimal.__mul__.__name__ == '__mul__' — __mul__ implements multiplication; len=7; __mul__ (7) == __add__ (7) == __sub__ (7): a 3-way tie among the first three binary operators, part of the overall 7-way tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__mul__.__name__.__eq__"
  args: ["__mul__"]
  expected: true

invariant decimal_extra173.neg_name_is_dunder_neg:
  description: "decimal.Decimal.__neg__.__name__ == '__neg__' — __neg__ implements unary negation; len=7; __neg__ (7) == __abs__ (7): both unary methods share length 7, completing the 7-way tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__neg__.__name__.__eq__"
  args: ["__neg__"]
  expected: true

invariant decimal_extra173.abs_name_len_is_7:
  description: "decimal.Decimal.__abs__.__name__.__len__() == 7 — '__abs__' has 7 characters; __abs__ (7) completes the 7-way tie: __add__==__sub__==__mul__==__mod__==__pow__==__neg__==__abs__ (7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__abs__.__name__.__len__"
  args: []
  expected: 7

invariant decimal_extra173.add_class_is_wrapper_descriptor:
  description: "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C extension type so its special methods are wrapper_descriptor objects; all 8 covered methods (__add__, __sub__, __mul__, __truediv__, __mod__, __pow__, __neg__, __abs__) share this class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__add__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra173.mod_name_is_dunder_mod:
  description: "decimal.Decimal.__mod__.__name__ == '__mod__' — __mod__ implements the modulo operator; len=7; __mod__ (7) is part of the 7-way tie; __mod__ (7) < __truediv__ (11): __truediv__ is 4 characters longer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Decimal.__mod__.__name__.__eq__"
  args: ["__mod__"]
  expected: true
