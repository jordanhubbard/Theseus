spec: itertools_extra253
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.accumulate, itertools.compress, itertools.pairwise, and itertools.batched type identity behavioral contracts."
    - "itertools.accumulate.__class__.__name__ == 'type' — accumulate is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools' — accumulate is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.accumulate.__name__ == 'accumulate' — accumulate type name is 'accumulate'. Verified with Python 3.14.3."
    - "itertools.compress.__class__.__name__ == 'type' — compress is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools' — compress is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.compress.__name__ == 'compress' — compress type name is 'compress'. Verified with Python 3.14.3."
    - "itertools.pairwise.__class__.__name__ == 'type' — pairwise is a C-level iterator type added in Python 3.10; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools' — pairwise is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.pairwise.__name__ == 'pairwise' — pairwise type name is 'pairwise'. Verified with Python 3.14.3."
    - "itertools.batched.__class__.__name__ == 'type' — batched is a C-level iterator type added in Python 3.12; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.batched.__module__ == 'itertools' — batched is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.batched.__name__ == 'batched' — batched type name is 'batched'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.accumulate type identity
#
# itertools.accumulate.__class__.__name__ == 'type'
# itertools.accumulate.__module__ == 'itertools'
# itertools.accumulate.__name__ == 'accumulate'
#
# accumulate is a C-level lazy iterator type that produces running totals
# (or other accumulated results from a binary function). New to extra253.
# ---------------------------------------------------------------------------

table itertools_extra253.accumulate_identity:
  description: "itertools.accumulate __name__, __module__, __class__.__name__ identity contracts; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: iteraccum253

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_name_eq,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate is a C-level iterator type producing running totals; __name__ is 'accumulate'; new to extra253"]
    - [accumulate_module_eq,
       accumulate.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — accumulate is defined in the itertools C extension; __module__ is 'itertools'; new to extra253"]
    - [accumulate_class_name_eq,
       accumulate.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.accumulate.__class__.__name__.__eq__('type') == True — accumulate is a C-level type (not a function); __class__.__name__ is 'type'; new to extra253"]
    - [accumulate_name_len_10,
       accumulate.__name__.__len__,
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 characters; new to extra253"]
    - [accumulate_module_len_9,
       accumulate.__module__.__len__,
       [],
       9,
       "itertools.accumulate.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra253"]

# ---------------------------------------------------------------------------
# Table 2: itertools.compress type identity
#
# itertools.compress.__class__.__name__ == 'type'
# itertools.compress.__module__ == 'itertools'
# itertools.compress.__name__ == 'compress'
#
# compress is a C-level iterator type that filters one iterable using
# boolean selectors from a second iterable. New to extra253.
# ---------------------------------------------------------------------------

table itertools_extra253.compress_identity:
  description: "itertools.compress __name__, __module__, __class__.__name__ identity contracts; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: itercompress253

  columns: [id, function, args, expected, description]
  rows:
    - [compress_name_eq,
       compress.__name__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress is a C-level iterator type filtering elements by boolean selectors; __name__ is 'compress'; new to extra253"]
    - [compress_module_eq,
       compress.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — compress is defined in the itertools C extension; __module__ is 'itertools'; new to extra253"]
    - [compress_class_name_eq,
       compress.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.compress.__class__.__name__.__eq__('type') == True — compress is a C-level type (not a function); __class__.__name__ is 'type'; new to extra253"]
    - [compress_name_len_8,
       compress.__name__.__len__,
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — 'compress' has 8 characters; new to extra253"]
    - [compress_module_len_9,
       compress.__module__.__len__,
       [],
       9,
       "itertools.compress.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra253"]

# ---------------------------------------------------------------------------
# Table 3: itertools.pairwise type identity (Python 3.10+)
#
# itertools.pairwise.__class__.__name__ == 'type'
# itertools.pairwise.__module__ == 'itertools'
# itertools.pairwise.__name__ == 'pairwise'
#
# pairwise was added in Python 3.10. It is a C-level iterator type that
# yields successive overlapping pairs from an iterable. New to extra253.
# ---------------------------------------------------------------------------

table itertools_extra253.pairwise_identity:
  description: "itertools.pairwise __name__, __module__, __class__.__name__ identity contracts (Python 3.10+); new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: iterpairwise253

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_name_eq,
       pairwise.__name__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise is a C-level iterator type yielding successive overlapping pairs (Python 3.10+); __name__ is 'pairwise'; new to extra253"]
    - [pairwise_module_eq,
       pairwise.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is defined in the itertools C extension; __module__ is 'itertools'; new to extra253"]
    - [pairwise_class_name_eq,
       pairwise.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.pairwise.__class__.__name__.__eq__('type') == True — pairwise is a C-level type (not a function); __class__.__name__ is 'type'; new to extra253"]
    - [pairwise_name_len_8,
       pairwise.__name__.__len__,
       [],
       8,
       "itertools.pairwise.__name__.__len__() == 8 — 'pairwise' has 8 characters; new to extra253"]
    - [pairwise_module_len_9,
       pairwise.__module__.__len__,
       [],
       9,
       "itertools.pairwise.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra253"]

# ---------------------------------------------------------------------------
# Table 4: itertools.batched type identity (Python 3.12+)
#
# itertools.batched.__class__.__name__ == 'type'
# itertools.batched.__module__ == 'itertools'
# itertools.batched.__name__ == 'batched'
#
# batched was added in Python 3.12. It is a C-level iterator type that
# yields non-overlapping chunks of up to n elements from an iterable.
# New to extra253.
# ---------------------------------------------------------------------------

table itertools_extra253.batched_identity:
  description: "itertools.batched __name__, __module__, __class__.__name__ identity contracts (Python 3.12+); new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: iterbatched253

  columns: [id, function, args, expected, description]
  rows:
    - [batched_name_eq,
       batched.__name__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — batched is a C-level iterator type yielding non-overlapping chunks (Python 3.12+); __name__ is 'batched'; new to extra253"]
    - [batched_module_eq,
       batched.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.batched.__module__.__eq__('itertools') == True — batched is defined in the itertools C extension; __module__ is 'itertools'; new to extra253"]
    - [batched_class_name_eq,
       batched.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.batched.__class__.__name__.__eq__('type') == True — batched is a C-level type (not a function); __class__.__name__ is 'type'; new to extra253"]
    - [batched_name_len_7,
       batched.__name__.__len__,
       [],
       7,
       "itertools.batched.__name__.__len__() == 7 — 'batched' has 7 characters; new to extra253"]
    - [batched_module_len_9,
       batched.__module__.__len__,
       [],
       9,
       "itertools.batched.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra253"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra253
# ---------------------------------------------------------------------------

invariant itertools_extra253.accumulate.name_eq:
  description: "itertools.accumulate.__name__ == 'accumulate' — C-level iterator type producing running totals; new to extra253"
  category: identity
  kind: python_call_eq
  function: accumulate.__name__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra253.accumulate.module_eq:
  description: "itertools.accumulate.__module__ == 'itertools' — defined in the itertools C extension; new to extra253"
  category: identity
  kind: python_call_eq
  function: accumulate.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra253.accumulate.class_is_type:
  description: "itertools.accumulate.__class__.__name__ == 'type' — accumulate is a C-level type, not a function; new to extra253"
  category: identity
  kind: python_call_eq
  function: accumulate.__class__.__name__.__eq__
  args: ["type"]
  expected: true

