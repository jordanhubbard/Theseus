spec: io_extra63
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra62.zspec.zsdl — covers BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase __repr__.__class__.__name__.__eq__('wrapper_descriptor'); io.__spec__.__class__.__name__.__eq__('ModuleSpec'); io.__spec__.name.__class__.__name__.__eq__('str'); BytesIO/StringIO __hash__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "io_extra61.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __class__.__module__.__eq__('builtins'); IOBase/RawIOBase/BufferedIOBase/TextIOBase __class__.__module__.__eq__('abc'); io.__spec__.name.__eq__('io') and __len__()==2."
    - "io_extra60.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); io module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "io_extra59.zspec.zsdl — covers DEFAULT_BUFFER_SIZE __class__.__module__ equality/length; BufferedIOBase/TextIOBase __module__ equality/length."
    - "io_extra58.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __module__.__eq__('_io'); IOBase/RawIOBase __module__.__eq__('io'); open __module__.__eq__('_io')."
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method qualname equality for read/write/seek/tell/getvalue."
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname for io classes and module."
    - "io_extra37.zspec.zsdl — covers __dict__.__class__.__name__.__len__()==12 for StringIO/BytesIO/IOBase/FileIO/RawIOBase/BufferedReader/TextIOWrapper."
  notes:
    - "This spec extends io_extra62.zspec.zsdl."
    - "Prior specs collectively covered: io_extra62 covers __repr__.__class__.__name__ and __hash__.__class__.__name__ for BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase; io_extra61 covers __spec__.name; io_extra58 covers __module__. NOT YET COVERED: io.__all__.__class__.__name__.__eq__('list') — no prior io spec checks io.__all__.__class__.__name__; novel; io.__all__.__len__()==24 — no prior io spec checks the length of io.__all__; novel; BytesIO/StringIO/TextIOWrapper __eq__.__class__.__name__.__eq__('wrapper_descriptor') — no prior io spec checks __eq__.__class__.__name__ for any io class; novel; IOBase/RawIOBase __eq__.__class__.__name__.__eq__('wrapper_descriptor') — no prior io spec checks __eq__.__class__.__name__ for io ABCs; novel."
    - "io has __all__ defined as a list. Verified: hasattr(io, '__all__') == True. io.__all__ is a plain Python list with 24 entries: ['BlockingIOError', 'open', 'open_code', 'IOBase', 'RawIOBase', 'FileIO', 'BytesIO', 'StringIO', 'BufferedIOBase', 'BufferedReader', 'BufferedWriter', 'BufferedRWPair', 'BufferedRandom', 'TextIOBase', 'TextIOWrapper', 'UnsupportedOperation', 'SEEK_SET', 'SEEK_CUR', 'SEEK_END', 'DEFAULT_BUFFER_SIZE', 'text_encoding', 'IncrementalNewlineDecoder', 'Reader', 'Writer']. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__all__.__class__.__name__ == 'list'. The __all__ attribute is a plain Python list. __class__.__name__ == 'list'. No prior io spec checks __all__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__all__.__len__() == 24. The io module's __all__ list has 24 entries. No prior io spec checks __all__.__len__(). Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BytesIO.__eq__.__class__.__name__ == 'wrapper_descriptor'. BytesIO is a C-extension type that does NOT define __eq__ in its own __dict__ (confirmed: '__eq__' in BytesIO.__dict__ == False). It inherits object.__eq__, which is a wrapper_descriptor. No prior io spec checks __eq__.__class__.__name__ for any io class. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.StringIO.__eq__.__class__.__name__ == 'wrapper_descriptor'. StringIO does not define __eq__ in its own __dict__. Same as BytesIO — inherits object.__eq__ as wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.__eq__.__class__.__name__ == 'wrapper_descriptor'. TextIOWrapper does not define __eq__ in its own __dict__. Inherits object.__eq__ as wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.IOBase.__eq__.__class__.__name__ == 'wrapper_descriptor'. IOBase is an ABC that does not define __eq__ in its own __dict__. Inherits object.__eq__ as wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__eq__.__class__.__name__ == 'wrapper_descriptor'. RawIOBase is an ABC that does not define __eq__ in its own __dict__. Inherits object.__eq__ as wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module __all__ identity
#
# The io module defines __all__ as a plain Python list with 24 entries covering
# all public names exported by the module: BlockingIOError, open, open_code,
# IOBase, RawIOBase, FileIO, BytesIO, StringIO, BufferedIOBase, BufferedReader,
# BufferedWriter, BufferedRWPair, BufferedRandom, TextIOBase, TextIOWrapper,
# UnsupportedOperation, SEEK_SET, SEEK_CUR, SEEK_END, DEFAULT_BUFFER_SIZE,
# text_encoding, IncrementalNewlineDecoder, Reader, Writer.
#
#   io.__all__.__class__.__name__ == 'list'
#   io.__all__.__len__()          == 24
#
# No prior io spec checks io.__all__.__class__.__name__ or its length.
# Both anchors are novel in the ioall63 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra63.all_identity:
  description: "io module __all__.__class__.__name__.__eq__('list') and __all__.__len__()==24 — io defines __all__ as a plain Python list with 24 public names; no prior io spec checks __all__.__class__.__name__ or its length; both novel anchors in ioall63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: ioall63all

  columns: [id, function, args, expected]
  rows:
    - [all_class_name, "__all__.__class__.__name__.__eq__", ["list"], true]
    - [all_len,        "__all__.__len__",                   [],        24  ]

# ---------------------------------------------------------------------------
# io BytesIO/StringIO/TextIOWrapper __eq__.__class__.__name__ == 'wrapper_descriptor'
#
# BytesIO, StringIO, and TextIOWrapper are C-extension types that do NOT define
# __eq__ in their own __dict__ (confirmed: '__eq__' in T.__dict__ == False for
# all three). They all inherit object.__eq__, which is a wrapper_descriptor.
# None of these io types define custom equality — identity-based equality is
# inherited from object.
#
#   BytesIO.__eq__.__class__.__name__     == 'wrapper_descriptor'
#   StringIO.__eq__.__class__.__name__    == 'wrapper_descriptor'
#   TextIOWrapper.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior io spec checks __eq__.__class__.__name__ for any io class.
# All three anchors are novel in the ioall63 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra63.cext_eq_class_name:
  description: "io BytesIO/StringIO/TextIOWrapper __eq__.__class__.__name__.__eq__('wrapper_descriptor') — C-extension io types do not define __eq__ in their own __dict__; they inherit object.__eq__ which is a wrapper_descriptor; no prior io spec checks __eq__.__class__.__name__ for any io class; all three novel anchors in ioall63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioall63ceq

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_eq_class_name,      "BytesIO.__eq__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true]
    - [StringIO_eq_class_name,     "StringIO.__eq__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true]
    - [TextIOWrapper_eq_class_name, "TextIOWrapper.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# io IOBase/RawIOBase __eq__.__class__.__name__ == 'wrapper_descriptor'
#
# IOBase and RawIOBase are abstract base classes that do NOT define __eq__ in
# their own __dict__ (confirmed: '__eq__' in T.__dict__ == False for both).
# They inherit object.__eq__, which is a wrapper_descriptor. These ABCs do not
# define custom equality semantics.
#
#   IOBase.__eq__.__class__.__name__    == 'wrapper_descriptor'
#   RawIOBase.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior io spec checks __eq__.__class__.__name__ for io ABCs.
# Both anchors are novel in the ioall63 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra63.abc_eq_class_name:
  description: "io IOBase/RawIOBase __eq__.__class__.__name__.__eq__('wrapper_descriptor') — abstract base classes that do not define __eq__ in their own __dict__; they inherit object.__eq__ which is a wrapper_descriptor; no prior io spec checks __eq__.__class__.__name__ for io ABCs; both novel anchors in ioall63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioall63aeq

  columns: [id, function, args, expected]
  rows:
    - [IOBase_eq_class_name,    "IOBase.__eq__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [RawIOBase_eq_class_name, "RawIOBase.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

invariant io_extra63.all_class_name_list:
  description: "io.__all__.__class__.__name__ == 'list' — the io module defines __all__ as a plain Python list; no prior io spec checks __all__.__class__.__name__; novel anchor in ioall63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant io_extra63.all_len_24:
  description: "io.__all__.__len__() == 24 — the io module's __all__ list contains 24 public names; no prior io spec checks the length of __all__; novel anchor in ioall63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 24

invariant io_extra63.BytesIO_eq_class_name_wrapper_descriptor:
  description: "io.BytesIO.__eq__.__class__.__name__ == 'wrapper_descriptor' — BytesIO is a C-extension type that does not define __eq__ in its own __dict__ (confirmed: '__eq__' in BytesIO.__dict__ == False); it inherits object.__eq__ which is a wrapper_descriptor; no prior io spec checks __eq__.__class__.__name__ for any io class; novel anchor in ioall63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra63.IOBase_eq_class_name_wrapper_descriptor:
  description: "io.IOBase.__eq__.__class__.__name__ == 'wrapper_descriptor' — IOBase is an abstract base class that does not define __eq__ in its own __dict__; it inherits object.__eq__ which is a wrapper_descriptor; no prior io spec checks __eq__.__class__.__name__ for io ABCs; novel anchor in ioall63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
