spec: importlib_resources_extra
version: ">=3.9"
backend: python_module(importlib.resources)

docs: https://docs.python.org/3/library/importlib.resources.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.resources.html — Python importlib.resources documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/resources/__init__.py"
    - "CPython source: Lib/importlib/resources/_common.py"
    - "CPython source: Lib/importlib/resources/_functional.py"
    - "importlib_resources.zspec.zsdl — covers __name__ for files/as_file/open_binary/read_binary/open_text/read_text/path/contents; files/__class__.__name__=='function'; as_file/__class__.__name__=='function'."
  notes:
    - "This spec extends importlib_resources.zspec.zsdl with new axes not covered there."
    - "importlib_resources.zspec.zsdl covers: __name__ for all 8 legacy+modern functions; callable type checks for files and as_file."
    - "New axes: __qualname__ for files/as_file/open_binary/read_binary/open_text/read_text/path/contents; __module__ for files/as_file/open_binary/read_binary; is_resource __name__/__qualname__/__module__; ResourceReader __name__/__module__; module __name__/__package__/__spec__.name."
    - "files.__qualname__ == 'files' — top-level function, qualname equals name."
    - "files.__module__ == 'importlib.resources._common' — files is defined in the _common submodule."
    - "as_file.__module__ == 'importlib.resources._common' — as_file is defined in the _common submodule."
    - "open_binary.__module__ == 'importlib.resources._functional' — legacy functions are in _functional."
    - "read_binary.__module__ == 'importlib.resources._functional'."
    - "open_text.__module__ == 'importlib.resources._functional'."
    - "read_text.__module__ == 'importlib.resources._functional'."
    - "path.__module__ == 'importlib.resources._functional'."
    - "contents.__module__ == 'importlib.resources._functional'."
    - "is_resource.__name__ == 'is_resource' — present in Python 3.9+, deprecated in 3.11."
    - "is_resource.__module__ == 'importlib.resources._functional'."
    - "ResourceReader.__name__ == 'ResourceReader' — abstract base class for resource readers."
    - "ResourceReader.__module__ == 'importlib.resources.abc'."
    - "importlib.resources.__name__ == 'importlib.resources' — the module's own fully-qualified name."
    - "importlib.resources.__package__ == 'importlib.resources' — resources is itself a package."
    - "importlib.resources.__spec__.name == 'importlib.resources' — the spec identifies the module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — __name__, __package__, __spec__.name
#
# importlib_resources.zspec.zsdl does not check these module-level attrs.
# ---------------------------------------------------------------------------

invariant importlib_resources_extra.module_name:
  description: "importlib.resources.__name__ == 'importlib.resources'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["importlib.resources"]
  expected: true

invariant importlib_resources_extra.module_package:
  description: "importlib.resources.__package__ == 'importlib.resources'"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: ["importlib.resources"]
  expected: true

invariant importlib_resources_extra.module_spec_name:
  description: "importlib.resources.__spec__.name == 'importlib.resources'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["importlib.resources"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ — all public functions
#
# importlib_resources.zspec.zsdl covers __name__ for each function.
# __qualname__ for top-level functions equals __name__; this is a distinct
# invariant axis not yet covered.
# ---------------------------------------------------------------------------

table importlib_resources_extra.function_qualnames:
  kind: python_call_eq
  category: function_attrs
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [files,        files.__qualname__.__eq__,        ["files"],        true]
    - [as_file,      as_file.__qualname__.__eq__,      ["as_file"],      true]
    - [open_binary,  open_binary.__qualname__.__eq__,  ["open_binary"],  true]
    - [read_binary,  read_binary.__qualname__.__eq__,  ["read_binary"],  true]
    - [open_text,    open_text.__qualname__.__eq__,    ["open_text"],    true]
    - [read_text,    read_text.__qualname__.__eq__,    ["read_text"],    true]
    - [path,         path.__qualname__.__eq__,         ["path"],         true]
    - [contents,     contents.__qualname__.__eq__,     ["contents"],     true]

# ---------------------------------------------------------------------------
# Function __module__ — identifies which internal submodule defines each function
#
# The modern API (files, as_file) lives in _common; legacy functions live
# in _functional. importlib_resources.zspec.zsdl does not check __module__.
# ---------------------------------------------------------------------------

table importlib_resources_extra.function_modules:
  kind: python_call_eq
  category: function_attrs
  id_prefix: fmodule

  columns: [id, function, args, expected]
  rows:
    - [files,       files.__module__.__eq__,       ["importlib.resources._common"],     true]
    - [as_file,     as_file.__module__.__eq__,     ["importlib.resources._common"],     true]
    - [open_binary, open_binary.__module__.__eq__, ["importlib.resources._functional"], true]
    - [read_binary, read_binary.__module__.__eq__, ["importlib.resources._functional"], true]
    - [open_text,   open_text.__module__.__eq__,   ["importlib.resources._functional"], true]
    - [read_text,   read_text.__module__.__eq__,   ["importlib.resources._functional"], true]
    - [path,        path.__module__.__eq__,        ["importlib.resources._functional"], true]
    - [contents,    contents.__module__.__eq__,    ["importlib.resources._functional"], true]

# ---------------------------------------------------------------------------
# is_resource — __name__, __qualname__, __module__
#
# importlib_resources.zspec.zsdl does not cover is_resource.
# is_resource is present in Python 3.9+ (deprecated in 3.11).
# ---------------------------------------------------------------------------

table importlib_resources_extra.is_resource_attrs:
  kind: python_call_eq
  category: function_attrs
  id_prefix: is_res

  columns: [id, function, args, expected]
  rows:
    - [name,     is_resource.__name__.__eq__,     ["is_resource"],                       true]
    - [qualname, is_resource.__qualname__.__eq__, ["is_resource"],                       true]
    - [module,   is_resource.__module__.__eq__,   ["importlib.resources._functional"],   true]

# ---------------------------------------------------------------------------
# ResourceReader — __name__ and __module__
#
# ResourceReader is an abstract base class for implementing resource readers.
# It is accessible as importlib.resources.ResourceReader.
# Not covered in any prior importlib_resources spec.
# ---------------------------------------------------------------------------

invariant importlib_resources_extra.ResourceReader_name:
  description: "importlib.resources.ResourceReader.__name__ == 'ResourceReader'"
  category: class_attrs
  kind: python_call_eq
  function: ResourceReader.__name__.__eq__
  args: ["ResourceReader"]
  expected: true

invariant importlib_resources_extra.ResourceReader_module:
  description: "importlib.resources.ResourceReader.__module__ == 'importlib.resources.abc'"
  category: class_attrs
  kind: python_call_eq
  function: ResourceReader.__module__.__eq__
  args: ["importlib.resources.abc"]
  expected: true
