spec: threading_extra260
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Condition class identity — name, module, bases; wait/notify/notify_all/__enter__/__exit__/wait_for qualnames; threading.Barrier class identity — name, module, bases; wait/reset/abort qualnames."
    - "threading.Condition.__name__ == 'Condition' — Python class name. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object. Verified with Python 3.14.3."
    - "threading.Condition does NOT have acquire/release attributes — it delegates lock operations to an underlying lock object; those methods are not defined in Condition's own __dict__. Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' — wait method qualname. Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' — notify method qualname. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' — notify_all method qualname. Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__qualname__ == 'Condition.__enter__' — __enter__ is a distinct method in Condition. Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__qualname__ == 'Condition.__exit__' — __exit__ is a distinct method in Condition. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' — wait_for predicate-based wait method qualname. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' — Python class name. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — wait method qualname. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' — reset method qualname. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' — abort method qualname. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition class identity contracts
#
# threading.Condition.__name__              == 'Condition'
# threading.Condition.__module__            == 'threading'
# threading.Condition.__bases__[0].__name__ == 'object'
# threading.Condition.__qualname__          == 'Condition'
# threading.Condition.wait.__qualname__     == 'Condition.wait'
#
# Condition is a Python class implementing a condition variable.
# Note: Condition does NOT have acquire/release in its own __dict__;
# it delegates to an underlying lock. New to extra260.
# ---------------------------------------------------------------------------

table threading_extra260.condition_identity:
  description: "threading.Condition name, module, base, qualname, wait qualname contracts; new to extra260"
  kind: python_call_eq
  category: identity
  id_prefix: thco260

  columns: [id, function, args, expected, description]
  rows:
    - [cond_name_eq,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Python class name; new to extra260"]
    - [cond_module_eq,
       Condition.__module__.__eq__,
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — defined in Lib/threading.py; new to extra260"]
    - [cond_base_name_eq,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra260"]
    - [cond_qualname_eq,
       Condition.__qualname__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__qualname__.__eq__('Condition') == True — top-level class; qualname equals name; new to extra260"]
    - [cond_wait_qualname_eq,
       Condition.wait.__qualname__.__eq__,
       ["Condition.wait"],
       true,
       "threading.Condition.wait.__qualname__.__eq__('Condition.wait') == True — wait method qualname; new to extra260"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition method qualname contracts
#
# threading.Condition.notify.__qualname__      == 'Condition.notify'
# threading.Condition.notify_all.__qualname__  == 'Condition.notify_all'
# threading.Condition.__enter__.__qualname__   == 'Condition.__enter__'
# threading.Condition.__exit__.__qualname__    == 'Condition.__exit__'
# threading.Condition.wait_for.__qualname__    == 'Condition.wait_for'
#
# All methods are defined in Condition's own __dict__. New to extra260.
# ---------------------------------------------------------------------------

table threading_extra260.condition_methods:
  description: "threading.Condition notify, notify_all, __enter__, __exit__, wait_for qualname contracts; new to extra260"
  kind: python_call_eq
  category: identity
  id_prefix: thcm260

  columns: [id, function, args, expected, description]
  rows:
    - [cond_notify_qualname_eq,
       Condition.notify.__qualname__.__eq__,
       ["Condition.notify"],
       true,
       "threading.Condition.notify.__qualname__.__eq__('Condition.notify') == True — notify method qualname; new to extra260"]
    - [cond_notify_all_qualname_eq,
       Condition.notify_all.__qualname__.__eq__,
       ["Condition.notify_all"],
       true,
       "threading.Condition.notify_all.__qualname__.__eq__('Condition.notify_all') == True — notify_all method qualname; new to extra260"]
    - [cond_enter_qualname_eq,
       Condition.__enter__.__qualname__.__eq__,
       ["Condition.__enter__"],
       true,
       "threading.Condition.__enter__.__qualname__.__eq__('Condition.__enter__') == True — __enter__ is a distinct method in Condition; new to extra260"]
    - [cond_exit_qualname_eq,
       Condition.__exit__.__qualname__.__eq__,
       ["Condition.__exit__"],
       true,
       "threading.Condition.__exit__.__qualname__.__eq__('Condition.__exit__') == True — __exit__ is a distinct method in Condition; new to extra260"]
    - [cond_wait_for_qualname_eq,
       Condition.wait_for.__qualname__.__eq__,
       ["Condition.wait_for"],
       true,
       "threading.Condition.wait_for.__qualname__.__eq__('Condition.wait_for') == True — wait_for predicate-based wait method qualname; new to extra260"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier class identity contracts
#
# threading.Barrier.__name__              == 'Barrier'
# threading.Barrier.__module__            == 'threading'
# threading.Barrier.__bases__[0].__name__ == 'object'
# threading.Barrier.wait.__qualname__     == 'Barrier.wait'
# threading.Barrier.reset.__qualname__    == 'Barrier.reset'
#
# Barrier is a Python class implementing a thread barrier. New to extra260.
# ---------------------------------------------------------------------------

table threading_extra260.barrier_identity:
  description: "threading.Barrier name, module, base, wait qualname, reset qualname contracts; new to extra260"
  kind: python_call_eq
  category: identity
  id_prefix: thba260

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_eq,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Python class name; new to extra260"]
    - [barrier_module_eq,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — defined in Lib/threading.py; new to extra260"]
    - [barrier_base_name_eq,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra260"]
    - [barrier_wait_qualname_eq,
       Barrier.wait.__qualname__.__eq__,
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — wait method qualname; new to extra260"]
    - [barrier_reset_qualname_eq,
       Barrier.reset.__qualname__.__eq__,
       ["Barrier.reset"],
       true,
       "threading.Barrier.reset.__qualname__.__eq__('Barrier.reset') == True — reset method qualname; new to extra260"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra260
# ---------------------------------------------------------------------------

invariant threading_extra260.condition.name_eq:
  description: "threading.Condition.__name__ == 'Condition' — Python class name; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra260.condition.module_eq:
  description: "threading.Condition.__module__ == 'threading' — defined in Lib/threading.py; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra260.condition.base_is_object:
  description: "threading.Condition.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra260"
  category: identity
  kind: python_call_eq
  function: "Condition.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra260.condition.wait_qualname:
  description: "threading.Condition.wait.__qualname__ == 'Condition.wait' — wait method qualname; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.wait.__qualname__.__eq__
  args: ["Condition.wait"]
  expected: true

invariant threading_extra260.condition.notify_qualname:
  description: "threading.Condition.notify.__qualname__ == 'Condition.notify' — notify method qualname; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.notify.__qualname__.__eq__
  args: ["Condition.notify"]
  expected: true

invariant threading_extra260.condition.notify_all_qualname:
  description: "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' — notify_all method qualname; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__eq__
  args: ["Condition.notify_all"]
  expected: true

invariant threading_extra260.condition.enter_qualname:
  description: "threading.Condition.__enter__.__qualname__ == 'Condition.__enter__' — __enter__ is a distinct method in Condition; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.__enter__.__qualname__.__eq__
  args: ["Condition.__enter__"]
  expected: true

invariant threading_extra260.condition.exit_qualname:
  description: "threading.Condition.__exit__.__qualname__ == 'Condition.__exit__' — __exit__ is a distinct method in Condition; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.__exit__.__qualname__.__eq__
  args: ["Condition.__exit__"]
  expected: true

invariant threading_extra260.condition.wait_for_qualname:
  description: "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' — wait_for predicate-based wait method qualname; new to extra260"
  category: identity
  kind: python_call_eq
  function: Condition.wait_for.__qualname__.__eq__
  args: ["Condition.wait_for"]
  expected: true

invariant threading_extra260.barrier.name_eq:
  description: "threading.Barrier.__name__ == 'Barrier' — Python class name; new to extra260"
  category: identity
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra260.barrier.module_eq:
  description: "threading.Barrier.__module__ == 'threading' — defined in Lib/threading.py; new to extra260"
  category: identity
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra260.barrier.base_is_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra260"
  category: identity
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra260.barrier.wait_qualname:
  description: "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — wait method qualname; new to extra260"
  category: identity
  kind: python_call_eq
  function: Barrier.wait.__qualname__.__eq__
  args: ["Barrier.wait"]
  expected: true

invariant threading_extra260.barrier.reset_qualname:
  description: "threading.Barrier.reset.__qualname__ == 'Barrier.reset' — reset method qualname; new to extra260"
  category: identity
  kind: python_call_eq
  function: Barrier.reset.__qualname__.__eq__
  args: ["Barrier.reset"]
  expected: true

invariant threading_extra260.barrier.abort_qualname:
  description: "threading.Barrier.abort.__qualname__ == 'Barrier.abort' — abort method qualname; new to extra260"
