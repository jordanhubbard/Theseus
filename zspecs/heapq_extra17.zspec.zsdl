spec: heapq_extra17
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl through heapq_extra16.zspec.zsdl."
    - "heapq_extra12 covers heappush/heappop/heapify/heapreplace __qualname__ as standalone invariants."
    - "heapq_extra15 covers merge/nlargest/nsmallest __qualname__ as standalone invariants."
    - "heapq_extra16 covers heappushpop.__qualname__ standalone and __qualname__.__len__() table for all 7 functions."
    - "NOT yet covered: standalone __qualname__.__eq__ invariants for nlargest/nsmallest/merge in extra17 namespace; standalone __qualname__.__eq__ invariants for heappush/heappop/heapify/heapreplace in extra17 namespace confirming same values; a unified table of __qualname__.__eq__ for all 8 functions."
    - "Focus: unified __qualname__.__eq__ table for all 8 heapq callables in extra17 namespace."
    - "heapq.heappush.__qualname__ == 'heappush' — C builtin qualname. Verified Python 3.12 macOS."
    - "heapq.heappop.__qualname__ == 'heappop' — C builtin qualname. Verified."
    - "heapq.heapify.__qualname__ == 'heapify' — C builtin qualname. Verified."
    - "heapq.heapreplace.__qualname__ == 'heapreplace' — C builtin qualname. Verified."
    - "heapq.heappushpop.__qualname__ == 'heappushpop' — C builtin qualname. Verified."
    - "heapq.nlargest.__qualname__ == 'nlargest' — pure-Python function qualname. Verified."
    - "heapq.nsmallest.__qualname__ == 'nsmallest' — pure-Python function qualname. Verified."
    - "heapq.merge.__qualname__ == 'merge' — pure-Python function qualname. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Unified __qualname__.__eq__ table for all 8 heapq callables
#
# Prior specs cover __qualname__ via standalone invariants (extra12, extra15,
# extra16) and via __qualname__.__len__() (extra16 table). This extra17 table
# consolidates __qualname__.__eq__ for all 8 callables in a single table under
# the extra17 namespace. For C builtins __qualname__ == __name__; for
# pure-Python functions (merge, nlargest, nsmallest) the same holds at top
# level. id_prefix hqeq17 does not conflict with any prior heapq spec.
# ---------------------------------------------------------------------------

table heapq_extra17.qualname_eq:
  description: "__qualname__.__eq__ for all 8 heapq callables — confirming qualname matches function name"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hqeq17

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__qualname__.__eq__,    ["heappush"],    true]
    - [heappop,     heappop.__qualname__.__eq__,     ["heappop"],     true]
    - [heapify,     heapify.__qualname__.__eq__,     ["heapify"],     true]
    - [heapreplace, heapreplace.__qualname__.__eq__, ["heapreplace"], true]
    - [heappushpop, heappushpop.__qualname__.__eq__, ["heappushpop"], true]
    - [nlargest,    nlargest.__qualname__.__eq__,    ["nlargest"],    true]
    - [nsmallest,   nsmallest.__qualname__.__eq__,   ["nsmallest"],   true]
    - [merge,       merge.__qualname__.__eq__,       ["merge"],       true]
