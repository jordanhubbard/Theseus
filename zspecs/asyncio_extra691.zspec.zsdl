    - [as691el005, asyncio.AbstractEventLoop.is_closed.__qualname__.__eq__,            ["AbstractEventLoop.is_closed"],            true]
    - [as691el006, asyncio.AbstractEventLoop.close.__qualname__.__eq__,                ["AbstractEventLoop.close"],                true]
    - [as691el007, asyncio.AbstractEventLoop.call_soon.__qualname__.__eq__,            ["AbstractEventLoop.call_soon"],            true]
    - [as691el008, asyncio.AbstractEventLoop.call_later.__qualname__.__eq__,           ["AbstractEventLoop.call_later"],           true]
