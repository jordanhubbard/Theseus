spec: lzma_extra10
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
    - "lzma_extra9.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __module__; LZMAFile.__bases__[0].__name__ == 'BaseStream'; LZMAError.__qualname__/bases; open/compress/decompress __module__; FORMAT_XZ/CHECK_CRC32 __class__.__name__ == 'int'."
    - "lzma_extra8.zspec.zsdl — covers LZMAFile.__init__/readable/writable/seekable __qualname__ (extra8); LZMACompressor.compress/flush __qualname__ (extra8); LZMADecompressor.decompress __qualname__ (extra8)."
    - "lzma_extra7.zspec.zsdl — covers LZMAFile.read/write/seek/tell/close __qualname__ (extra7); LZMACompressor/LZMADecompressor __qualname__ standalone (extra7); open/compress/decompress __qualname__ (extra7 anchor)."
    - "lzma_extra6.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __qualname__ standalone (extra6); open/compress/decompress __qualname__ standalone (extra6); lzma.__name__ standalone (extra6)."
    - "lzma_extra2.zspec.zsdl — covers class __qualname__ table (LZMAFile/LZMACompressor/LZMADecompressor/LZMAError); LZMAError.__bases__[0].__name__ bool form."
    - "lzma.zspec.zsdl — covers LZMAError.__bases__[0].__name__ string form; LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__ table."
  notes:
    - "This spec extends lzma through lzma_extra9; it does NOT duplicate invariants present in those files."
    - "Focus: FORMAT_ALONE/FORMAT_RAW/CHECK_NONE/CHECK_SHA256 __class__.__name__ == 'int' (novel — extra9 covers FORMAT_XZ and CHECK_CRC32); FILTER_LZMA1/FILTER_LZMA2/FILTER_DELTA __class__.__name__ == 'int' (novel filter-constant type checks); LZMACompressor/__bases__[0].__name__ and LZMADecompressor/__bases__[0].__name__ (novel hierarchy invariants); lzma.__loader__.__class__.__name__ and lzma.__spec__.__class__.__name__ (novel loader/spec type invariants)."
    - "FORMAT_ALONE.__class__.__name__ == 'int': value 2 is a plain Python int. extra9 covers FORMAT_XZ; FORMAT_ALONE is novel. Verified 2026-04-09."
    - "FORMAT_RAW.__class__.__name__ == 'int': value 3 is a plain Python int. Not covered in any prior lzma spec. Verified 2026-04-09."
    - "CHECK_NONE.__class__.__name__ == 'int': value 0 is a plain Python int. extra9 covers CHECK_CRC32; CHECK_NONE is novel. Verified 2026-04-09."
    - "CHECK_SHA256.__class__.__name__ == 'int': value 10 is a plain Python int. Not covered in any prior lzma spec. Verified 2026-04-09."
    - "FILTER_LZMA1.__class__.__name__ == 'int': filter constants are plain Python ints. Not covered in any prior lzma spec. Verified 2026-04-09."
    - "FILTER_LZMA2.__class__.__name__ == 'int': filter constant is a plain Python int. Verified 2026-04-09."
    - "FILTER_DELTA.__class__.__name__ == 'int': filter constant is a plain Python int. Verified 2026-04-09."
    - "LZMACompressor.__bases__[0].__name__ == 'object': LZMACompressor is a direct C extension subclass of object. No prior lzma spec checks this. Verified 2026-04-09."
    - "LZMADecompressor.__bases__[0].__name__ == 'object': same as LZMACompressor. No prior lzma spec checks this. Verified 2026-04-09."
    - "lzma.__loader__.__class__.__name__ == 'SourceFileLoader': lzma is a pure-Python module. No prior lzma spec checks this. Verified 2026-04-09."
    - "lzma.__spec__.__class__.__name__ == 'ModuleSpec': import system attaches a ModuleSpec to every module. No prior lzma spec checks this. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FORMAT_ALONE.__class__.__name__ == 'int' — novel, extra10 anchor
#
# lzma_extra9 covers FORMAT_XZ.__class__.__name__ == 'int'. FORMAT_ALONE
# (value 2, the legacy .lzma format) is a distinct constant not covered in
# any prior lzma spec. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.FORMAT_ALONE.class_is_int:
  description: "lzma.FORMAT_ALONE.__class__.__name__ == 'int' — format constant is a plain Python int (extra10)"
  category: type_identity
  kind: python_call_eq
  function: FORMAT_ALONE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# FORMAT_RAW.__class__.__name__ == 'int' — novel, extra10 anchor
#
# No prior lzma spec checks FORMAT_RAW.__class__.__name__. FORMAT_RAW (value 3)
# is the raw-stream format constant. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.FORMAT_RAW.class_is_int:
  description: "lzma.FORMAT_RAW.__class__.__name__ == 'int' — format constant is a plain Python int (extra10)"
  category: type_identity
  kind: python_call_eq
  function: FORMAT_RAW.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# CHECK_NONE.__class__.__name__ == 'int' — novel, extra10 anchor
#
# lzma_extra9 covers CHECK_CRC32.__class__.__name__ == 'int'. CHECK_NONE
# (value 0, disables integrity checking) is a distinct constant. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.CHECK_NONE.class_is_int:
  description: "lzma.CHECK_NONE.__class__.__name__ == 'int' — check constant is a plain Python int (extra10)"
  category: type_identity
  kind: python_call_eq
  function: CHECK_NONE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# CHECK_SHA256.__class__.__name__ == 'int' — novel, extra10 anchor
#
# No prior lzma spec checks CHECK_SHA256.__class__.__name__. CHECK_SHA256
# (value 10) is a plain Python int. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.CHECK_SHA256.class_is_int:
  description: "lzma.CHECK_SHA256.__class__.__name__ == 'int' — check constant is a plain Python int (extra10)"
  category: type_identity
  kind: python_call_eq
  function: CHECK_SHA256.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# FILTER_LZMA1.__class__.__name__ == 'int' — novel, extra10 anchor
#
# No prior lzma spec checks any FILTER_* constant's __class__.__name__.
# FILTER_LZMA1 is the LZMA1 filter constant (plain Python int). Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.FILTER_LZMA1.class_is_int:
  description: "lzma.FILTER_LZMA1.__class__.__name__ == 'int' — filter constant is a plain Python int (extra10)"
  category: type_identity
  kind: python_call_eq
  function: FILTER_LZMA1.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# FILTER_LZMA2.__class__.__name__ == 'int' — novel, extra10 anchor
#
# No prior lzma spec checks FILTER_LZMA2.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.FILTER_LZMA2.class_is_int:
  description: "lzma.FILTER_LZMA2.__class__.__name__ == 'int' — filter constant is a plain Python int (extra10)"
  category: type_identity
  kind: python_call_eq
  function: FILTER_LZMA2.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# FILTER_DELTA.__class__.__name__ == 'int' — novel, extra10 anchor
#
# No prior lzma spec checks FILTER_DELTA.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.FILTER_DELTA.class_is_int:
  description: "lzma.FILTER_DELTA.__class__.__name__ == 'int' — filter constant is a plain Python int (extra10)"
  category: type_identity
  kind: python_call_eq
  function: FILTER_DELTA.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# LZMACompressor.__bases__[0].__name__ == 'object' — novel, extra10 anchor
#
# No prior lzma spec checks LZMACompressor.__bases__[0].__name__. LZMACompressor
# is a C extension type that directly subclasses object. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.LZMACompressor.base_name:
  description: "lzma.LZMACompressor.__bases__[0].__name__ == 'object' — LZMACompressor directly subclasses object (extra10)"
  category: hierarchy
  kind: python_call_eq
  function: "LZMACompressor.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# LZMADecompressor.__bases__[0].__name__ == 'object' — novel, extra10 anchor
#
# No prior lzma spec checks LZMADecompressor.__bases__[0].__name__. Same as
# LZMACompressor — a direct C extension subclass of object. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.LZMADecompressor.base_name:
  description: "lzma.LZMADecompressor.__bases__[0].__name__ == 'object' — LZMADecompressor directly subclasses object (extra10)"
  category: hierarchy
  kind: python_call_eq
  function: "LZMADecompressor.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# lzma.__loader__.__class__.__name__ == 'SourceFileLoader' — novel, extra10 anchor
#
# No prior lzma spec checks the loader class name. lzma is a pure-Python
# stdlib module loaded by importlib's SourceFileLoader. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.loader.class_name:
  description: "lzma.__loader__.__class__.__name__ == 'SourceFileLoader' — module is loaded by SourceFileLoader (extra10)"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# lzma.__spec__.__class__.__name__ == 'ModuleSpec' — novel, extra10 anchor
#
# No prior lzma spec checks the spec object's class name. The import system
# attaches a ModuleSpec instance to every module as __spec__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra10.spec.class_name:
  description: "lzma.__spec__.__class__.__name__ == 'ModuleSpec' — module's __spec__ is a ModuleSpec instance (extra10)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# int type identity table — FORMAT_ALONE, FORMAT_RAW, CHECK_NONE, CHECK_SHA256,
#                           FILTER_LZMA1, FILTER_LZMA2, FILTER_DELTA (extra10)
#
# No prior lzma spec presents these seven constants as int-type-identity checks.
# This table anchors all seven from the extra10 namespace.
# ---------------------------------------------------------------------------

table lzma_extra10.constant_int_types:
  kind: python_call_eq
  category: type_identity
  id_prefix: ci10

  columns: [id, function, args, expected]
  rows:
    - [FORMAT_ALONE,  FORMAT_ALONE.__class__.__name__.__eq__,  ["int"], true]
    - [FORMAT_RAW,    FORMAT_RAW.__class__.__name__.__eq__,    ["int"], true]
    - [CHECK_NONE,    CHECK_NONE.__class__.__name__.__eq__,    ["int"], true]
    - [CHECK_SHA256,  CHECK_SHA256.__class__.__name__.__eq__,  ["int"], true]
    - [FILTER_LZMA1,  FILTER_LZMA1.__class__.__name__.__eq__,  ["int"], true]
    - [FILTER_LZMA2,  FILTER_LZMA2.__class__.__name__.__eq__,  ["int"], true]
    - [FILTER_DELTA,  FILTER_DELTA.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# module_identity table — loader and spec class names (extra10)
#
# No prior lzma spec presents loader/spec class-name checks in a table.
# ---------------------------------------------------------------------------

table lzma_extra10.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: mid10

  columns: [id, function, args, expected]
  rows:
    - [loader_class, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]
    - [spec_class,   __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],       true]
