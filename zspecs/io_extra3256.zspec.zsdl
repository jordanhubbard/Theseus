spec: io3256
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (io3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __rpow__, __rlshift__, __rrshift__ dict-presence (reflected power/shift)."
    - "No io class defines __rpow__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types, and do not implement reflected exponentiation."
    - "No io class defines __rlshift__ in its own __dict__: stream I/O classes do not implement reflected left-shift; the << operator on streams is not defined."
    - "No io class defines __rrshift__ in its own __dict__: stream I/O classes do not implement reflected right-shift."
    - "Key finding: decimal.Decimal.__rpow__ = true (consistent with wave 660 __pow__ = true); __rlshift__/__rrshift__ = false (no bitwise shift on Decimal)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rpow__ dict-presence — operator.contains(Cls.__dict__, '__rpow__')
#
# No io class defines __rpow__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the reflected exponentiation operator.
# ---------------------------------------------------------------------------

table io3256.rpow:
  description: "io types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3256

  columns: [id, function, args, expected]
  rows:
    - ["io3256001", operator.contains, [io.RawIOBase.__dict__,       "__rpow__"], false]
    - ["io3256002", operator.contains, [io.BufferedIOBase.__dict__,  "__rpow__"], false]
    - ["io3256003", operator.contains, [io.TextIOBase.__dict__,      "__rpow__"], false]
