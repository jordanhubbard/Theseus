spec: inspect_extra238
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.getmembers, inspect.signature, and inspect.Parameter identity contracts."
    - "inspect.getmembers.__name__ == 'getmembers' (len=10) — Python function name. Verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' (len=7) — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.signature.__name__ == 'signature' (len=9) — Python function name. Verified with Python 3.14.3."
    - "inspect.signature.__module__ == 'inspect' (len=7) — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' (len=9) — class name. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' (len=7) — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers and inspect.signature function identity
#
# inspect.getmembers.__name__ == 'getmembers' (len=10)
# inspect.getmembers.__module__ == 'inspect' (len=7)
# inspect.signature.__name__ == 'signature' (len=9)
# inspect.signature.__module__ == 'inspect' (len=7)
# inspect.getmembers.__class__.__name__ == 'function'
#
# Both are Python functions in Lib/inspect.py. New to extra238.
# ---------------------------------------------------------------------------

table inspect_extra238.insp238fn_function_identity:
  description: "inspect.getmembers and inspect.signature function identity: name, module, class; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: insp238fn

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_eq,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — getmembers is a Python function in Lib/inspect.py; __name__ is 'getmembers' (len=10); new to extra238"]
    - [getmembers_module_eq,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra238"]
    - [signature_name_eq,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__.__eq__('signature') == True — signature is a Python function in Lib/inspect.py; __name__ is 'signature' (len=9); new to extra238"]
    - [signature_module_eq,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra238"]
    - [getmembers_class_is_function,
       getmembers.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getmembers.__class__.__name__.__eq__('function') == True — getmembers is a Python function; its __class__ is the built-in function type; new to extra238"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers and signature length and doc contracts
#
# inspect.getmembers.__name__.__len__() == 10
# inspect.getmembers.__module__.__len__() == 7
# inspect.signature.__name__.__len__() == 9
# inspect.getmembers.__doc__.__contains__('members') == True
# inspect.signature.__doc__.__contains__('signature') == True
#
# Length and doc contracts. New to extra238.
# ---------------------------------------------------------------------------

table inspect_extra238.insp238fn_lengths_and_docs:
  description: "inspect.getmembers and signature length and doc contracts; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: insp238fndoc

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_len_10,
       getmembers.__name__.__len__,
       [],
       10,
       "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has exactly 10 characters; str.__len__() returns 10; new to extra238"]
    - [getmembers_module_len_7,
       getmembers.__module__.__len__,
       [],
       7,
       "inspect.getmembers.__module__.__len__() == 7 — 'inspect' has exactly 7 characters (i-n-s-p-e-c-t); str.__len__() returns 7; new to extra238"]
    - [signature_name_len_9,
       signature.__name__.__len__,
       [],
       9,
       "inspect.signature.__name__.__len__() == 9 — 'signature' has exactly 9 characters; str.__len__() returns 9; new to extra238"]
    - [getmembers_doc_contains_members,
       getmembers.__doc__.__contains__,
       ["members"],
       true,
       "inspect.getmembers.__doc__.__contains__('members') == True — docstring describes returning all members of an object; str.__contains__('members') returns True; new to extra238"]
    - [signature_doc_contains_callable,
       signature.__doc__.__contains__,
       ["callable"],
       true,
       "inspect.signature.__doc__.__contains__('callable') == True — docstring describes getting a signature for the passed callable; str.__contains__('callable') returns True; new to extra238"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter class identity contracts
#
# inspect.Parameter.__name__ == 'Parameter' (len=9)
# inspect.Parameter.__module__ == 'inspect' (len=7)
# inspect.Parameter.__bases__[0].__name__ == 'object'
# inspect.Parameter.__class__.__name__ == 'type'
# inspect.Parameter.__doc__.__contains__('parameter') == True
#
# Parameter is a Python class in Lib/inspect.py. New to extra238.
# ---------------------------------------------------------------------------

table inspect_extra238.insp238param_identity:
  description: "inspect.Parameter class identity: name, module, bases, class, doc; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: insp238param

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a Python class in Lib/inspect.py; __name__ is 'Parameter' (len=9); new to extra238"]
    - [parameter_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra238"]
    - [parameter_bases_0_is_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; __bases__[0] is object; new to extra238"]
    - [parameter_class_is_type,
       Parameter.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a class; its metaclass is the built-in type type; new to extra238"]
    - [parameter_doc_contains_parameter,
       Parameter.__doc__.__contains__,
       ["parameter"],
       true,
       "inspect.Parameter.__doc__.__contains__('parameter') == True — docstring describes representing a parameter in a function signature; str.__contains__('parameter') returns True; new to extra238"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra238
# ---------------------------------------------------------------------------

invariant inspect_extra238.getmembers_name_eq:
  description: "inspect.getmembers.__name__ == 'getmembers' (len=10); new to extra238"
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra238.getmembers_name_len_10:
  description: "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters; new to extra238"
  kind: python_call_eq
  function: getmembers.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra238.getmembers_module_eq:
  description: "inspect.getmembers.__module__ == 'inspect'; new to extra238"
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra238.getmembers_module_len_7:
  description: "inspect.getmembers.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra238"
  kind: python_call_eq
  function: getmembers.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra238.signature_name_eq:
  description: "inspect.signature.__name__ == 'signature' (len=9); new to extra238"
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra238.signature_module_eq:
  description: "inspect.signature.__module__ == 'inspect'; new to extra238"
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra238.parameter_name_eq:
  description: "inspect.Parameter.__name__ == 'Parameter' (len=9); new to extra238"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra238.parameter_name_len_9:
  description: "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters; new to extra238"
  kind: python_call_eq
  function: Parameter.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra238.parameter_module_eq:
  description: "inspect.Parameter.__module__ == 'inspect'; new to extra238"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra238.parameter_module_len_7:
  description: "inspect.Parameter.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra238"
  kind: python_call_eq
  function: Parameter.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra238.parameter_bases_0_is_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object'; new to extra238"
  kind: python_call_eq
  function: "Parameter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
