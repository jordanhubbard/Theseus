spec: statistics_extra21
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra through statistics_extra20."
    - "statistics_extra17/18 cover __qualname__.__eq__ for all top-level functions and the NormalDist/StatisticsError classes."
    - "statistics_extra19 covers __qualname__.__len__ for top-level functions and NormalDist/StatisticsError."
    - "statistics_extra20 covers __qualname__.__eq__ and selected len invariants for NormalDist.__init__, pdf, cdf, inv_cdf, __add__, __mul__, overlap."
    - "No prior spec covers __qualname__ for NormalDist.from_samples, __repr__, __eq__, __hash__."
    - "No prior spec covers __qualname__.__len__ for NormalDist.__add__, __mul__, __repr__, __eq__, __hash__, from_samples."
    - "All NormalDist methods are defined directly on the class; qualname follows 'NormalDist.<name>'."
    - "Focus: NormalDist additional method __qualname__ values not yet recorded."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist additional method __qualname__ values
#
# statistics_extra20 recorded qualname for __init__, pdf, cdf, inv_cdf,
# __add__, __mul__, overlap.  The following methods are not yet covered:
# from_samples, __repr__, __eq__, __hash__.
# ---------------------------------------------------------------------------

table statistics_extra21.normaldist_extra_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [from_samples, NormalDist.from_samples.__qualname__.__eq__, ["NormalDist.from_samples"], true, "NormalDist.from_samples.__qualname__ == 'NormalDist.from_samples'"]
    - [repr,         NormalDist.__repr__.__qualname__.__eq__,     ["NormalDist.__repr__"],     true, "NormalDist.__repr__.__qualname__ == 'NormalDist.__repr__'"]
    - [eq,           NormalDist.__eq__.__qualname__.__eq__,       ["NormalDist.__eq__"],       true, "NormalDist.__eq__.__qualname__ == 'NormalDist.__eq__'"]
    - [hash,         NormalDist.__hash__.__qualname__.__eq__,     ["NormalDist.__hash__"],     true, "NormalDist.__hash__.__qualname__ == 'NormalDist.__hash__'"]

# ---------------------------------------------------------------------------
# NormalDist method __qualname__ length invariants (uncovered methods)
#
# statistics_extra20 recorded len for __init__, pdf, cdf, inv_cdf, overlap.
# No prior spec records len for __add__, __mul__, from_samples, __repr__,
# __eq__, __hash__.
# ---------------------------------------------------------------------------

invariant statistics_extra21.add.qualname_len:
  description: "len(statistics.NormalDist.__add__.__qualname__) == 18 — 'NormalDist.__add__' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__add__.__qualname__.__len__
  args: []
  expected: 18

invariant statistics_extra21.mul.qualname_len:
  description: "len(statistics.NormalDist.__mul__.__qualname__) == 18 — 'NormalDist.__mul__' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__mul__.__qualname__.__len__
  args: []
  expected: 18

invariant statistics_extra21.from_samples.qualname_len:
  description: "len(statistics.NormalDist.from_samples.__qualname__) == 23 — 'NormalDist.from_samples' is 23 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.from_samples.__qualname__.__len__
  args: []
  expected: 23

invariant statistics_extra21.repr.qualname_len:
  description: "len(statistics.NormalDist.__repr__.__qualname__) == 19 — 'NormalDist.__repr__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__repr__.__qualname__.__len__
  args: []
  expected: 19

invariant statistics_extra21.eq.qualname_len:
  description: "len(statistics.NormalDist.__eq__.__qualname__) == 17 — 'NormalDist.__eq__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__eq__.__qualname__.__len__
  args: []
  expected: 17

invariant statistics_extra21.hash.qualname_len:
  description: "len(statistics.NormalDist.__hash__.__qualname__) == 19 — 'NormalDist.__hash__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__hash__.__qualname__.__len__
  args: []
  expected: 19
