    - [ab1486mm002, abc.ABCMeta.__dict__.__contains__, ["__new__"],           true]
    - [ab1486mm003, abc.ABCMeta.__dict__.__contains__, ["__enter__"],         false]
    - [ab1486mm004, abc.ABCMeta.__dict__.__contains__, ["__exit__"],          false]
