spec: uuid_extra260
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra259.zspec.zsdl — covers UUID property fget __name__/__qualname__/__class__.__name__ identity for urn/bytes_le/fields/version/variant."
    - "uuid_extra258.zspec.zsdl — covers UUID.__str__/__repr__/__hash__/__eq__ method identity; UUID comparison method identity; UUID qualnames; UUID.bytes/hex/version fget identity."
    - "uuid_extra257.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 function identity; NAMESPACE_* class names; UUID.__name__/__module__/__bases__."
  notes:
    - "uuid.UUID.__init__.__name__ == '__init__' — UUID.__init__ is a pure-Python function in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__init__.__class__.__name__ == 'function' — UUID.__init__ is a pure-Python function (not C-level). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__init__.__module__ == 'uuid' — defined in the uuid module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' — qualname confirms class membership. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__new__.__name__ == '__new__' — UUID.__new__ inherits from object.__new__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__new__.__class__.__name__ == 'builtin_function_or_method' — object.__new__ is a C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__setattr__.__name__ == '__setattr__' — UUID overrides __setattr__ to make instances immutable. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__setattr__.__class__.__name__ == 'function' — UUID.__setattr__ is a pure-Python function in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID('not-a-valid-uuid') raises ValueError — UUID constructor validates the format string and raises ValueError on invalid input. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__init__ and __new__ method identity
# UUID.__init__ is a pure-Python function; UUID.__new__ inherits object.__new__
# (a C builtin). UUID.__setattr__ is also a pure-Python override.
# ---------------------------------------------------------------------------

table uuid_extra260.UUID_init_new_identity:
  description: "uuid.UUID __init__/__new__/__setattr__ method identity — __init__/__setattr__ are pure-Python 'function'; __new__ is 'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinit260

  columns: [id, function, args, expected, description]
  rows:
    - [init_name,        UUID.__init__.__name__.__eq__,              ["__init__"],    true, "uuid.UUID.__init__.__name__ == '__init__' — pure-Python UUID constructor in Lib/uuid.py"]
    - [init_class,       UUID.__init__.__class__.__name__.__eq__,    ["function"],    true, "uuid.UUID.__init__.__class__.__name__ == 'function' — pure-Python function, not C-level"]
    - [init_module,      UUID.__init__.__module__.__eq__,            ["uuid"],         true, "uuid.UUID.__init__.__module__ == 'uuid' — defined in the uuid module"]
    - [new_name,         UUID.__new__.__name__.__eq__,               ["__new__"],     true, "uuid.UUID.__new__.__name__ == '__new__' — inherits object.__new__ from C runtime"]
    - [new_class,        UUID.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "uuid.UUID.__new__.__class__.__name__ == 'builtin_function_or_method' — object.__new__ is C builtin"]

# ---------------------------------------------------------------------------
# uuid.UUID constructor error cases
# uuid.UUID('not-a-valid-uuid') raises ValueError — invalid hex string.
# uuid.UUID(int=-1) raises ValueError — int must be 0..2**128-1.
# ---------------------------------------------------------------------------

invariant uuid_extra260.UUID_invalid_string_raises:
  description: "uuid.UUID('not-a-valid-uuid') raises ValueError — UUID constructor validates the format string; invalid hex/format raises ValueError; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: UUID
  args: ["not-a-valid-uuid"]
  raises: ValueError

invariant uuid_extra260.UUID_init_qualname_eq:
  description: "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' — qualname confirms class membership; pure-Python method in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

invariant uuid_extra260.UUID_setattr_name_eq:
  description: "uuid.UUID.__setattr__.__name__ == '__setattr__' — UUID overrides __setattr__ to enforce immutability; pure-Python function in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__setattr__.__name__.__eq__
  args: ["__setattr__"]
  expected: true

invariant uuid_extra260.UUID_setattr_class_eq:
  description: "uuid.UUID.__setattr__.__class__.__name__ == 'function' — UUID.__setattr__ is a pure-Python function; enforces UUID immutability by raising AttributeError on set; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__setattr__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuid_extra260.UUID_setattr_module_eq:
  description: "uuid.UUID.__setattr__.__module__ == 'uuid' — UUID.__setattr__ is defined in the uuid module (Lib/uuid.py); not inherited from object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__setattr__.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra260.UUID_name_eq:
  description: "uuid.UUID.__name__ == 'UUID' — the UUID class name is 'UUID'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra260.UUID_module_eq:
  description: "uuid.UUID.__module__ == 'uuid' — UUID class is defined in the uuid module (Lib/uuid.py); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true
