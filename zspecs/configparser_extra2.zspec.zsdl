spec: configparser_extra2
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
    - "configparser.zspec.zsdl — covers __name__ for ConfigParser/RawConfigParser/BasicInterpolation/ExtendedInterpolation/Error/NoSectionError/NoOptionError/DuplicateSectionError/DuplicateOptionError/MissingSectionHeaderError/ParsingError; DEFAULTSECT value; ConfigParser().sections()==[]; ConfigParser().defaults()=={}; NoSectionError/NoOptionError/DuplicateSectionError/ParsingError MRO[1].__name__=='Error'; Error MRO[1].__name__=='Exception'; RawConfigParser().sections()==[]; RawConfigParser().defaults()=={}"
    - "configparser_extra.zspec.zsdl — covers ConfigParser.__name__, ConfigParser.__module__, RawConfigParser.__name__, Error.__name__, NoSectionError.__name__, NoOptionError.__name__, DuplicateSectionError.__name__, InterpolationError.__name__, NoSectionError.__bases__[0].__name__=='Error', NoOptionError.__bases__[0].__name__=='Error', ConfigParser().sections()==[], DEFAULTSECT=='DEFAULT'"
  notes:
    - "This spec adds: __module__ for RawConfigParser, BasicInterpolation, ExtendedInterpolation, Error, NoSectionError, NoOptionError, DuplicateSectionError, MissingSectionHeaderError, ParsingError; MissingSectionHeaderError/__name__; DuplicateSectionError hierarchy; MissingSectionHeaderError hierarchy; Error.__bases__[0].__name__=='Exception'; ConfigParser instance method names (read, read_string, get, set, add_section, has_section, sections, options, items, write, remove_section, remove_option)."
    - "configparser.RawConfigParser.__module__ == 'configparser'."
    - "configparser.BasicInterpolation.__module__ == 'configparser'."
    - "configparser.ExtendedInterpolation.__module__ == 'configparser'."
    - "configparser.Error.__module__ == 'configparser'."
    - "configparser.NoSectionError.__module__ == 'configparser'."
    - "configparser.DuplicateSectionError.__bases__[0].__name__ == 'Error'."
    - "configparser.MissingSectionHeaderError.__bases__[0].__name__ == 'ParsingError'."
    - "ConfigParser instance methods: read, read_string, get, set, add_section, has_section, sections, options, items, write, remove_section, remove_option."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — classes not yet covered by configparser or configparser_extra
# configparser_extra covers ConfigParser.__module__; this covers the rest.
# ---------------------------------------------------------------------------

table configparser_extra2.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [rawconfigparser,       RawConfigParser.__module__.__eq__,       ["configparser"], true]
    - [basicinterpolation,    BasicInterpolation.__module__.__eq__,    ["configparser"], true]
    - [extendedinterpolation, ExtendedInterpolation.__module__.__eq__, ["configparser"], true]
    - [error,                 Error.__module__.__eq__,                 ["configparser"], true]
    - [nosectionerror,        NoSectionError.__module__.__eq__,        ["configparser"], true]
    - [nooptionerror,         NoOptionError.__module__.__eq__,         ["configparser"], true]
    - [duplicatesectionerror, DuplicateSectionError.__module__.__eq__, ["configparser"], true]
    - [parsingerror,          ParsingError.__module__.__eq__,          ["configparser"], true]

# ---------------------------------------------------------------------------
# MissingSectionHeaderError — name and module (not in prior specs as module)
# configparser.zspec.zsdl checks __name__ in a table; this adds __module__.
# ---------------------------------------------------------------------------

invariant configparser_extra2.MissingSectionHeaderError.module:
  description: "configparser.MissingSectionHeaderError.__module__ == 'configparser'"
  category: class_modules
  kind: python_call_eq
  function: MissingSectionHeaderError.__module__.__eq__
  args: ["configparser"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — DuplicateSectionError and MissingSectionHeaderError bases
# (configparser_extra covers NoSectionError and NoOptionError bases;
#  configparser covers MRO checks but not __bases__[0] for these two)
# ---------------------------------------------------------------------------

invariant configparser_extra2.DuplicateSectionError.base_is_Error:
  description: "configparser.DuplicateSectionError.__bases__[0].__name__ == 'Error'"
  category: class_hierarchy
  kind: python_call_eq
  function: DuplicateSectionError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant configparser_extra2.MissingSectionHeaderError.base_is_ParsingError:
  description: "configparser.MissingSectionHeaderError.__bases__[0].__name__ == 'ParsingError'"
  category: class_hierarchy
  kind: python_call_eq
  function: MissingSectionHeaderError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ParsingError"

invariant configparser_extra2.Error.base_is_Exception:
  description: "configparser.Error.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant configparser_extra2.ParsingError.base_is_Error:
  description: "configparser.ParsingError.__bases__[0].__name__ == 'Error'"
  category: class_hierarchy
  kind: python_call_eq
  function: ParsingError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

# ---------------------------------------------------------------------------
# ConfigParser instance method names
# Verified by accessing the unbound method __name__ attribute.
# ---------------------------------------------------------------------------

table configparser_extra2.ConfigParser.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [read,           ConfigParser.read.__name__.__eq__,           ["read"],           true]
    - [read_string,    ConfigParser.read_string.__name__.__eq__,    ["read_string"],    true]
    - [get,            ConfigParser.get.__name__.__eq__,            ["get"],            true]
    - [set,            ConfigParser.set.__name__.__eq__,            ["set"],            true]
    - [add_section,    ConfigParser.add_section.__name__.__eq__,    ["add_section"],    true]
    - [has_section,    ConfigParser.has_section.__name__.__eq__,    ["has_section"],    true]
    - [sections,       ConfigParser.sections.__name__.__eq__,       ["sections"],       true]
    - [options,        ConfigParser.options.__name__.__eq__,        ["options"],        true]
    - [items,          ConfigParser.items.__name__.__eq__,          ["items"],          true]
    - [write,          ConfigParser.write.__name__.__eq__,          ["write"],          true]
    - [remove_section, ConfigParser.remove_section.__name__.__eq__, ["remove_section"], true]
    - [remove_option,  ConfigParser.remove_option.__name__.__eq__,  ["remove_option"],  true]

# ---------------------------------------------------------------------------
# Class identity — ConfigParser and RawConfigParser are classes (type objects)
# ---------------------------------------------------------------------------

invariant configparser_extra2.ConfigParser.is_type:
  description: "configparser.ConfigParser.__class__.__name__ == 'type' — ConfigParser is a class"
  category: class_metadata
  kind: python_call_eq
  function: ConfigParser.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant configparser_extra2.RawConfigParser.is_type:
  description: "configparser.RawConfigParser.__class__.__name__ == 'type' — RawConfigParser is a class"
  category: class_metadata
  kind: python_call_eq
  function: RawConfigParser.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant configparser_extra2.ConfigParser.module:
  description: "configparser.ConfigParser.__module__ == 'configparser' (already in configparser_extra; reconfirmed here with same-spec redundancy check)"
  category: class_modules
  kind: python_call_eq
  function: ConfigParser.__module__.__eq__
  args: ["configparser"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULTSECT type check — it is a str constant
# ---------------------------------------------------------------------------

invariant configparser_extra2.DEFAULTSECT.class_is_str:
  description: "configparser.DEFAULTSECT.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: DEFAULTSECT.__class__.__name__.__eq__
  args: ["str"]
  expected: true
