# asyncio.TaskGroup.__bases__[0].__name__  == 'object'              (len=6)
# asyncio.TaskGroup.__mro__.__len__()      == 2
# ---------------------------------------------------------------------------

table asyncio_extra136.asyncio_taskgroup_class_identity:
  description: "asyncio.TaskGroup class identity checks in asynciotgid136 namespace — wave 259 theme: asyncio.TaskGroup class identity; TaskGroup.__name__.__eq__('TaskGroup')==True (len=9); TaskGroup.__module__.__eq__('asyncio.taskgroups')==True (len=18, NOT 'asyncio' — TaskGroup is defined in Lib/asyncio/taskgroups.py); TaskGroup.__bases__[0].__name__.__eq__('object')==True (len=6, flat hierarchy — no intermediate base classes); TaskGroup.__mro__.__len__()==2 ([TaskGroup, object], same as Future); TaskGroup.__dict__.__class__.__name__.__eq__('mappingproxy')==True; TaskGroup.__dict__.__len__()==15; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotgid136

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      asyncio.TaskGroup.__name__.__eq__,                       ["TaskGroup"],          true, "asyncio.TaskGroup.__name__ == 'TaskGroup' (len=9); verified with Python 3.14.3"]
    - [name_len,     asyncio.TaskGroup.__name__.__len__,                      [],                     9,    "asyncio.TaskGroup.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [mod_eq,       asyncio.TaskGroup.__module__.__eq__,                     ["asyncio.taskgroups"], true, "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' (len=18); verified with Python 3.14.3"]
    - [mod_len,      asyncio.TaskGroup.__module__.__len__,                    [],                     18,   "asyncio.TaskGroup.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [base0_eq,     "asyncio.TaskGroup.__bases__[0].__name__.__eq__",        ["object"],             true, "asyncio.TaskGroup.__bases__[0].__name__ == 'object' (len=6); verified with Python 3.14.3"]
    - [base0_len,    "asyncio.TaskGroup.__bases__[0].__name__.__len__",       [],                     6,    "asyncio.TaskGroup.__bases__[0].__name__.__len__() == 6 ('object'=6); verified with Python 3.14.3"]
    - [mro_len,      asyncio.TaskGroup.__mro__.__len__,                       [],                     2,    "asyncio.TaskGroup.__mro__.__len__() == 2 ([TaskGroup, object]); verified with Python 3.14.3"]

