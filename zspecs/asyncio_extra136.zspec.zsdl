# ---------------------------------------------------------------------------
# Standalone invariants — extra136
# ---------------------------------------------------------------------------

invariant asyncio_extra136.TaskGroup_name_len_9:
  description: "asyncio.TaskGroup.__name__.__len__() == 9 — asyncio.TaskGroup.__name__ is 'TaskGroup' (9 chars: 'Task'=4 + 'Group'=5 = 9); TaskGroup was added in Python 3.11 (PEP 654) and lives in Lib/asyncio/taskgroups.py with __module__=='asyncio.taskgroups' (len=18); TaskGroup.__mro__.__len__()==2 ([TaskGroup, object]) — flat hierarchy; TaskGroup.__dict__.__len__()==15; NEW in extra136: first standalone TaskGroup name length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.TaskGroup.__name__.__len__
  args: []
  expected: 9

invariant asyncio_extra136.TaskGroup_module_len_18:
  description: "asyncio.TaskGroup.__module__.__len__() == 18 — asyncio.TaskGroup.__module__ is 'asyncio.taskgroups' (18 chars: 'asyncio'=7 + '.'=1 + 'taskgroups'=10 = 18); TaskGroup is NOT in the top-level asyncio namespace directly — its __module__ is 'asyncio.taskgroups' (the submodule), not 'asyncio'; asyncio.Condition.__module__ is 'asyncio.locks' (len=13); asyncio.TaskGroup.__name__.__len__()==9; NEW in extra136: first standalone TaskGroup module length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.TaskGroup.__module__.__len__
  args: []
  expected: 18

invariant asyncio_extra136.TaskGroup_mro_len_2:
  description: "asyncio.TaskGroup.__mro__.__len__() == 2 — asyncio.TaskGroup's MRO is [TaskGroup, object] (length=2); this is the minimum possible MRO depth for a Python class (every class's MRO ends in object); TaskGroup has no intermediate base classes — it inherits directly from object; by contrast asyncio.Condition.__mro__.__len__()==4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); asyncio.TaskGroup.__bases__[0].__name__ is 'object' (len=6); NEW in extra136: first standalone TaskGroup MRO length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.TaskGroup.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra136.TaskGroup_aenter_qualname_len_20:
  description: "asyncio.TaskGroup.__aenter__.__qualname__.__len__() == 20 — asyncio.TaskGroup.__aenter__.__qualname__ is 'TaskGroup.__aenter__' (20 chars: 'TaskGroup'=9 + '.'=1 + '__aenter__'=10 = 20); compare with __aexit__.__qualname__.__len__()==19 ('__aexit__'=9, one fewer char than '__aenter__'=10); TaskGroup.__aenter__.__code__.co_argcount==1 (self only); TaskGroup.__aexit__.__code__.co_argcount==4 (self, et, exc, tb); NEW in extra136: first standalone TaskGroup.__aenter__ qualname length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.TaskGroup.__aenter__.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra136.TaskGroup_aexit_qualname_len_19:
  description: "asyncio.TaskGroup.__aexit__.__qualname__.__len__() == 19 — asyncio.TaskGroup.__aexit__.__qualname__ is 'TaskGroup.__aexit__' (19 chars: 'TaskGroup'=9 + '.'=1 + '__aexit__'=9 = 19); this is one less than __aenter__.__qualname__.__len__()==20 because '__aexit__'=9 chars vs '__aenter__'=10 chars; TaskGroup.__aexit__.__code__.co_argcount==4 (self, et, exc, tb — the full exception info triple); NEW in extra136: first standalone TaskGroup.__aexit__ qualname length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.TaskGroup.__aexit__.__qualname__.__len__
  args: []
  expected: 19
