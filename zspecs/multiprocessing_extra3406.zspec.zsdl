    - ["mp3406002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__bool__"], false]
    - ["mp3406003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__bool__"], false]
    - ["mp3406004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__bool__"], false]
    - ["mp3406005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__bool__"], false]
    - ["mp3406006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__bool__"], false]
    - ["mp3406007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__bool__"], false]
    - ["mp3406008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__bool__"], false]

# ---------------------------------------------------------------------------
# __str__ dict-presence — operator.contains(Cls.__dict__, '__str__')
#
# All 8 multiprocessing classes return false for __str__.
# str() delegates to __str__ when defined in the class's own __dict__.
# multiprocessing types rely on inherited __str__ from object — none of
#   the 8 classes define a custom __str__ in their own __dict__.
# managers.BaseListProxy: relays collection operations to the managed server
#   process via proxy methods, but does not define __str__ in its __dict__.
# managers._BaseDictProxy: proxies dict operations; __str__ is not defined
#   in its own __dict__.
# managers._BaseSetProxy: proxies set operations; __str__ is not defined
#   in its own __dict__.
# multiprocessing.Process: subprocess lifecycle manager; str(process) falls
#   back to inherited behavior; __str__ is absent from Process.__dict__.
# pool.Pool/AsyncResult/MapResult/SyncManager: process-management types with
#   no __str__ customization in their own __dict__.
# ---------------------------------------------------------------------------

table mp3406.str:
  description: "multiprocessing types __str__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3406

  columns: [id, function, args, expected]
