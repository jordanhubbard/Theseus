    - ["mp3406021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__repr__"], false]
    - ["mp3406022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__repr__"], false]
    - ["mp3406023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__repr__"], false]
    - ["mp3406024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__repr__"], false]

# ---------------------------------------------------------------------------
# combined — __bool__, __str__, __repr__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __bool__: false for all 8 — not in any type's own __dict__.
# __str__: false for all 8 — not in any type's own __dict__.
# __repr__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# The proxy types (_BaseSetProxy, _BaseDictProxy, BaseListProxy) are the most
#   analytically interesting subjects here. _BaseSetProxy proxies set — set
#   uses __len__ for truth testing, not __bool__, and defines neither __str__
#   nor __repr__ in its own __dict__. _BaseDictProxy proxies dict — same
#   pattern. BaseListProxy proxies list — while list exposes __add__ and __mul__
#   (the only true results across mp waves 658–670), it defines neither __bool__
#   nor __str__ nor __repr__ in its own __dict__, because list relies on __len__
#   for truth testing and falls back to inherited __str__/__repr__.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — not through Python display protocol overrides in any class __dict__.
# ---------------------------------------------------------------------------

