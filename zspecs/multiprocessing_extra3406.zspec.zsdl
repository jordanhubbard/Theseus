spec: mp3406
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 674 (mp3406): __bool__, __str__, __repr__ dict-presence (bool(x), str(x), repr(x)) for multiprocessing types."
    - "Theme: __bool__/__str__/__repr__ dict-presence (bool(x), str(x), repr(x))."
    - "All values False — multiprocessing types are process-based concurrency primitives with no custom bool/str/repr defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__bool__): all 8 multiprocessing classes return false for __bool__. bool() delegates to __bool__ (truth-value testing protocol) when defined in the class's own __dict__. multiprocessing.Process: a subprocess lifecycle manager with no __bool__ in its own __dict__ — process liveness is checked via is_alive(), not __bool__. pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types with no truth-value protocol in their own __dict__. managers.SyncManager: server process manager with no __bool__ in its __dict__. managers.BaseListProxy: proxies list — list defines no __bool__ in its own __dict__; truth testing of list relies on __len__. managers._BaseDictProxy: proxies dict — dict defines no __bool__ in its own __dict__. managers._BaseSetProxy: proxies set — set defines no __bool__ in its own __dict__."
    - "Key finding (__str__): all 8 multiprocessing classes return false for __str__. str() delegates to __str__ when defined in the class's own __dict__. multiprocessing types rely on inherited __str__ from object — none of the 8 classes define a custom __str__ in their own __dict__. The proxy types (_BaseSetProxy, _BaseDictProxy, BaseListProxy) relay operations to the managed server process, but do not define __str__ in their own __dict__; string rendering falls back to inherited behavior."
    - "Key finding (__repr__): all 8 multiprocessing classes return false for __repr__. repr() delegates to __repr__ when defined in the class's own __dict__. None of the 8 multiprocessing classes define a Python-level __repr__ in their own __dict__. managers.BaseListProxy key note: BaseListProxy defines __getitem__ and other collection protocol methods in its __dict__, but __repr__ is not among them."
    - "All 24 values in this wave are false. multiprocessing is a process-based concurrency library; its types interact exclusively through explicit method calls, subprocess lifecycle management, and IPC — not through Python display protocol overrides in any class __dict__."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
    - "  Wave 668 (mp3316): __ipow__/__ilshift__/__irshift__ — all false for all 8."
    - "  Wave 669 (mp3331): __iand__/__ior__/__ixor__ — all false for all 8."
    - "  Wave 670 (mp3346): __neg__/__pos__/__abs__ — all false for all 8."
    - "  Wave 671 (mp3361): __invert__/__floor__/__ceil__ — all false for all 8."
    - "  Wave 672 (mp3376): __trunc__/__round__/__index__ — all false for all 8."
    - "  Wave 673 (mp3391): __int__/__float__/__complex__ — all false for all 8."
    - "  Wave 674 (mp3406): __bool__/__str__/__repr__ — all false for all 8."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# All 8 multiprocessing classes return false for __bool__.
# bool() delegates to __bool__ (truth-value testing protocol) when defined
#   in the class's own __dict__.
# multiprocessing.Process: a subprocess lifecycle manager; process liveness
#   is checked via is_alive(), not __bool__. __bool__ is absent from
#   Process.__dict__.
# pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types
#   with no truth-value protocol defined in their own __dict__.
# managers.SyncManager: server process manager with no __bool__ in its
#   __dict__. Manager liveness is checked via is_alive(), not __bool__.
# managers.BaseListProxy: proxies list — list itself uses __len__ for
#   truth testing; __bool__ is not defined in BaseListProxy.__dict__.
# managers._BaseDictProxy: proxies dict — dict uses __len__ for truth
#   testing; __bool__ is not defined in _BaseDictProxy.__dict__.
# managers._BaseSetProxy: proxies set — set uses __len__ for truth
#   testing; __bool__ is not defined in _BaseSetProxy.__dict__.
# ---------------------------------------------------------------------------

table mp3406.bool:
  description: "multiprocessing types __bool__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
