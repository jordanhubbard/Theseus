    - ["mp3406009",  operator.contains, [multiprocessing.Process.__dict__,                 "__str__"], false]
    - ["mp3406010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__str__"], false]
    - ["mp3406011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__str__"], false]
    - ["mp3406012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__str__"], false]
    - ["mp3406013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__str__"], false]
    - ["mp3406014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__str__"], false]
    - ["mp3406015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__str__"], false]
    - ["mp3406016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__str__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# All 8 multiprocessing classes return false for __repr__.
# repr() delegates to __repr__ when defined in the class's own __dict__.
# None of the 8 multiprocessing classes define a Python-level __repr__
#   in their own __dict__.
# managers.BaseListProxy key note: BaseListProxy defines __getitem__,
#   __setitem__, __delitem__, __len__, __contains__, __add__, __mul__,
#   and other collection protocol methods in its __dict__, but __repr__
#   is not among them. The proxy's representation falls back to inherited
#   behavior.
# managers._BaseDictProxy: defines dict proxy methods in its __dict__,
#   but not __repr__.
# managers._BaseSetProxy: defines set proxy methods in its __dict__,
#   but not __repr__.
# multiprocessing.Process: repr falls back to inherited; __repr__ is
#   absent from Process.__dict__.
# pool.Pool/AsyncResult/MapResult/SyncManager: no __repr__ in their own
#   __dict__; representation falls back to inherited behavior.
# ---------------------------------------------------------------------------

