spec: jsonpath
version: ">=0.2.0"
backend: node(jsonpath)

docs: https://www.npmjs.com/package/jsonpath

provenance:
  derived_from:
    - "jsonpath README — https://www.npmjs.com/package/jsonpath"
    - "Test vectors verified with jsonpath via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "jsonpath source"
  notes:
    - "jsonpath is an npm package. Install: npm install jsonpath"
    - "jp.query(obj, expr) returns an array of all matching values."
    - "Uses JSONPath expression syntax: $.field, $.a.b, $.a[0], $.a[*]."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of matching values."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table jsonpath.query:
  kind: node_module_call_eq
  function: query
  category: query
  id_prefix: jpq

  columns: [id, args, expected]
  rows:
    - [root_field,  [{"a": 1}, "$.a"],                 [1]]
    - [nested,      [{"a": {"b": 2}}, "$.a.b"],         [2]]
    - [array_index, [{"a": [10, 20, 30]}, "$.a[1]"],    [20]]
    - [wildcard,    [{"a": [1, 2, 3]}, "$.a[*]"],       [1, 2, 3]]
    - [no_match,    [{"a": 1}, "$.b"],                  []]
