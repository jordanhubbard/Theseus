spec: abc_extra537
version: ">=3.9"
backend: python_module(abc)
docs: "abc.ABC and ABCMeta __doc__ and __qualname__ identity checks"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table abc_extra537.doc_class_names:
  description: "abc symbols __doc__.__class__.__name__ is str"
  kind: python_call_eq
  category: identity
  id_prefix: abcdoc
  columns: [id, function, args, expected]
  rows:
    - [abcdoc001, abc.ABC.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [abcdoc002, abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [abcdoc003, abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [abcdoc004, abc.abstractproperty.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [abcdoc005, abc.get_cache_token.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra537.qualnames:
  description: "abc symbols __qualname__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: abcqual
  columns: [id, function, args, expected]
  rows:
    - [abcqual001, abc.ABC.__qualname__.__eq__, ["ABC"], true]
    - [abcqual002, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
    - [abcqual003, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [abcqual004, abc.abstractproperty.__qualname__.__eq__, ["abstractproperty"], true]
    - [abcqual005, abc.get_cache_token.__qualname__.__eq__, ["get_cache_token"], true]
