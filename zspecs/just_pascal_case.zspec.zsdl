spec: just_pascal_case
version: ">=3.2.0"
backend: node(just-pascal-case)

docs: https://www.npmjs.com/package/just-pascal-case

provenance:
  derived_from:
    - "just-pascal-case README — https://www.npmjs.com/package/just-pascal-case"
    - "Test vectors verified with just-pascal-case via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-pascal-case source"
  notes:
    - "just-pascal-case is an npm package. Install: npm install just-pascal-case"
    - "Converts a string to PascalCase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_pascal_case.convert:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: jpsc

  columns: [id, args, expected]
  rows:
    - [from_kebab,  ["foo-bar"],  "FooBar"]
    - [from_snake,  ["foo_bar"],  "FooBar"]
    - [from_space,  ["foo bar"],  "FooBar"]
