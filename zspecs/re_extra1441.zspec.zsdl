spec: re_extra1441
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 543 (_extra1441): ABC machinery focus — __subclasshook__ and __instancecheck__ checks."
    - "re.error, re.Pattern, re.Match all use plain 'type' metaclass — no ABCMeta involvement."
    - "__subclasshook__ is inherited from object.__dict__ — not present in any re class __dict__."
    - "__instancecheck__ is on the plain 'type' metaclass — not in the class __dict__ itself."
    - "All __subclasshook__.__class__.__name__ and __instancecheck__.__class__.__name__ yield 'builtin_function_or_method'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1441.subclasshook_class_name:
  description: "re class __subclasshook__.__class__.__name__ — all resolve as builtin_function_or_method"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: re1441sh
  columns: [id, function, args, expected]
  rows:
    - [re1441sh001, re.error.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [re1441sh002, re.Pattern.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [re1441sh003, re.Match.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]

table re_extra1441.instancecheck_class_name:
  description: "re class __instancecheck__.__class__.__name__ — all resolve as builtin_function_or_method (plain type metaclass)"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: re1441ic
  columns: [id, function, args, expected]
  rows:
    - [re1441ic001, re.error.__instancecheck__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [re1441ic002, re.Pattern.__instancecheck__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [re1441ic003, re.Match.__instancecheck__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]

table re_extra1441.subclasshook_not_in_dict:
  description: "re class __dict__ does NOT contain __subclasshook__ — inherited from object"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: re1441sd
  columns: [id, function, args, expected]
  rows:
    - [re1441sd001, re.error.__dict__.__contains__,   ["__subclasshook__"], false]
    - [re1441sd002, re.Pattern.__dict__.__contains__, ["__subclasshook__"], false]
    - [re1441sd003, re.Match.__dict__.__contains__,   ["__subclasshook__"], false]

table re_extra1441.instancecheck_not_in_dict:
  description: "re class __dict__ does NOT contain __instancecheck__ — it is on the metaclass"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: re1441id
  columns: [id, function, args, expected]
  rows:
    - [re1441id001, re.error.__dict__.__contains__,   ["__instancecheck__"], false]
    - [re1441id002, re.Pattern.__dict__.__contains__, ["__instancecheck__"], false]
    - [re1441id003, re.Match.__dict__.__contains__,   ["__instancecheck__"], false]

table re_extra1441.plain_type_metaclass:
  description: "re classes use plain 'type' metaclass — no ABCMeta involvement"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: re1441mc
  columns: [id, function, args, expected]
  rows:
    - [re1441mc001, re.error.__class__.__name__.__eq__,   ["type"], true]
    - [re1441mc002, re.Pattern.__class__.__name__.__eq__, ["type"], true]
    - [re1441mc003, re.Match.__class__.__name__.__eq__,   ["type"], true]

table re_extra1441.doc_and_module_in_dict:
  description: "re classes carry __doc__ and __module__ in their own __dict__"
  kind: python_call_eq
  category: abc_machinery
  id_prefix: re1441dm
  columns: [id, function, args, expected]
  rows:
    - [re1441dm001, re.error.__dict__.__contains__,   ["__doc__"], true]
    - [re1441dm002, re.Pattern.__dict__.__contains__, ["__doc__"], true]
    - [re1441dm003, re.Match.__dict__.__contains__,   ["__doc__"], true]
    - [re1441dm004, re.error.__dict__.__contains__,   ["__module__"], true]
    - [re1441dm005, re.Pattern.__dict__.__contains__, ["__module__"], true]
    - [re1441dm006, re.Match.__dict__.__contains__,   ["__module__"], true]
