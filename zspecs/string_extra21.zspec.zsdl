spec: string_extra21
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra20.zspec.zsdl."
    - "string_extra5 covers: Formatter.__qualname__=='Formatter'; Template.__qualname__=='Template'; capwords.__qualname__=='capwords'."
    - "string_extra20 covers: Formatter/Template/capwords __qualname__.__len__() checks; ascii_letters.__contains__('A'); digits.__contains__('5')."
    - "string_extra covers: ascii_letters/__class__.__name__=='str' and digits/__class__.__name__=='str' in a type-is-str table."
    - "string_extra17 covers: ascii_letters/__class__.__name__=='str' and digits/__class__.__name__=='str' as extra17 namespace anchors."
    - "No prior spec covers Formatter.format.__qualname__, Formatter.vformat.__qualname__, or Formatter.parse.__qualname__ as method qualnames."
    - "No prior spec covers Template.substitute.__qualname__ or Template.safe_substitute.__qualname__ as method qualnames."
    - "string.Formatter.format.__qualname__ == 'Formatter.format' — method qualname includes owning class. Verified at runtime."
    - "string.Formatter.vformat.__qualname__ == 'Formatter.vformat' — method qualname includes owning class. Verified at runtime."
    - "string.Formatter.parse.__qualname__ == 'Formatter.parse' — method qualname includes owning class. Verified at runtime."
    - "string.Template.substitute.__qualname__ == 'Template.substitute' — method qualname includes owning class. Verified at runtime."
    - "string.Template.safe_substitute.__qualname__ == 'Template.safe_substitute' — method qualname includes owning class. Verified at runtime."
    - "string.capwords.__qualname__ == 'capwords' — re-anchored in extra21 namespace as standalone invariant (extra5 covers same value)."
    - "string.ascii_letters.__class__.__name__ == 'str' — re-anchored in extra21 namespace (extra/extra17 cover same value)."
    - "string.digits.__class__.__name__ == 'str' — re-anchored in extra21 namespace (extra/extra17 cover same value)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter.format — __qualname__
#
# No prior spec verifies Formatter.format.__qualname__. For a method defined
# in class Formatter, __qualname__ takes the form 'Formatter.format'.
# Verified at runtime: 'Formatter.format'.
# ---------------------------------------------------------------------------

invariant string_extra21.Formatter.format_qualname:
  description: "string.Formatter.format.__qualname__ == 'Formatter.format' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.format.__qualname__.__eq__
  args: ["Formatter.format"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.vformat — __qualname__
#
# No prior spec verifies Formatter.vformat.__qualname__. For a method defined
# in class Formatter, __qualname__ takes the form 'Formatter.vformat'.
# Verified at runtime: 'Formatter.vformat'.
# ---------------------------------------------------------------------------

invariant string_extra21.Formatter.vformat_qualname:
  description: "string.Formatter.vformat.__qualname__ == 'Formatter.vformat' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.vformat.__qualname__.__eq__
  args: ["Formatter.vformat"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter.parse — __qualname__
#
# No prior spec verifies Formatter.parse.__qualname__. For a method defined
# in class Formatter, __qualname__ takes the form 'Formatter.parse'.
# Verified at runtime: 'Formatter.parse'.
# ---------------------------------------------------------------------------

invariant string_extra21.Formatter.parse_qualname:
  description: "string.Formatter.parse.__qualname__ == 'Formatter.parse' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Formatter.parse.__qualname__.__eq__
  args: ["Formatter.parse"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.substitute — __qualname__
#
# No prior spec verifies Template.substitute.__qualname__. For a method defined
# in class Template, __qualname__ takes the form 'Template.substitute'.
# Verified at runtime: 'Template.substitute'.
# ---------------------------------------------------------------------------

invariant string_extra21.Template.substitute_qualname:
  description: "string.Template.substitute.__qualname__ == 'Template.substitute' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Template.substitute.__qualname__.__eq__
  args: ["Template.substitute"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.safe_substitute — __qualname__
#
# No prior spec verifies Template.safe_substitute.__qualname__. For a method
# defined in class Template, __qualname__ takes the form
# 'Template.safe_substitute'. Verified at runtime: 'Template.safe_substitute'.
# ---------------------------------------------------------------------------

invariant string_extra21.Template.safe_substitute_qualname:
  description: "string.Template.safe_substitute.__qualname__ == 'Template.safe_substitute' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Template.safe_substitute.__qualname__.__eq__
  args: ["Template.safe_substitute"]
  expected: true

# ---------------------------------------------------------------------------
# string.capwords — __qualname__ (extra21 namespace anchor)
#
# string_extra5 covers capwords.__qualname__ == 'capwords'. This invariant
# re-anchors the same value in the extra21 namespace for cross-spec consistency.
# Verified at runtime: 'capwords'.
# ---------------------------------------------------------------------------

invariant string_extra21.capwords.qualname:
  description: "string.capwords.__qualname__ == 'capwords' — top-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: capwords.__qualname__.__eq__
  args: ["capwords"]
  expected: true

# ---------------------------------------------------------------------------
# string.ascii_letters — __class__.__name__ (extra21 namespace anchor)
#
# string_extra and string_extra17 cover ascii_letters.__class__.__name__ == 'str'.
# Re-anchored here as a named standalone invariant in extra21 namespace.
# Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra21.ascii_letters.class_name:
  description: "string.ascii_letters.__class__.__name__ == 'str' — ascii_letters is a str constant"
  category: string_constants
  kind: python_call_eq
  function: ascii_letters.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.digits — __class__.__name__ (extra21 namespace anchor)
#
# string_extra and string_extra17 cover digits.__class__.__name__ == 'str'.
# Re-anchored here as a named standalone invariant in extra21 namespace.
# Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra21.digits.class_name:
  description: "string.digits.__class__.__name__ == 'str' — digits is a str constant"
  category: string_constants
  kind: python_call_eq
  function: digits.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Formatter and Template method __qualname__ values
#
# No prior spec groups Formatter and Template method __qualname__ checks into
# a single table. Covers format, vformat, parse, substitute, safe_substitute.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra21.method_qualnames:
  description: "string module Formatter and Template method __qualname__ values"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Formatter_format,
       Formatter.format.__qualname__.__eq__,
       ["Formatter.format"],
       true,
       "Formatter.format.__qualname__ == 'Formatter.format'"]
    - [Formatter_vformat,
       Formatter.vformat.__qualname__.__eq__,
       ["Formatter.vformat"],
       true,
       "Formatter.vformat.__qualname__ == 'Formatter.vformat'"]
    - [Formatter_parse,
       Formatter.parse.__qualname__.__eq__,
       ["Formatter.parse"],
       true,
       "Formatter.parse.__qualname__ == 'Formatter.parse'"]
    - [Template_substitute,
       Template.substitute.__qualname__.__eq__,
       ["Template.substitute"],
       true,
       "Template.substitute.__qualname__ == 'Template.substitute'"]
    - [Template_safe_substitute,
       Template.safe_substitute.__qualname__.__eq__,
       ["Template.safe_substitute"],
       true,
       "Template.safe_substitute.__qualname__ == 'Template.safe_substitute'"]
