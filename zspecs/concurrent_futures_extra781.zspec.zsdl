spec: concurrent_futures_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - concurrent.futures standard library documentation
    - CPython source for concurrent.futures module
  not_derived_from:
    - any third-party futures implementations
    - tornado or twisted future abstractions
  notes:
    - Covers module identity attributes and class __qualname__ checks
    - Doc class checks confirm attributes are strings not None
  created_at: "2026-04-12"

table concurrent_futures_extra781.name:
  description: concurrent.futures module identity attribute checks
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: cf781
  columns: [id, function, args, expected]
  rows:
    - [cf781xx001, concurrent.futures.__name__.__eq__, ["concurrent.futures"], true]
    - [cf781xx002, concurrent.futures.__package__.__eq__, ["concurrent.futures"], true]
    - [cf781xx003, concurrent.futures.Future.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf781xx004, concurrent.futures.Executor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf781xx005, concurrent.futures.CancelledError.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf781xx006, concurrent.futures.BrokenExecutor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf781xx007, concurrent.futures.Future.__qualname__.__eq__, ["Future"], true]
    - [cf781xx008, concurrent.futures.Executor.__qualname__.__eq__, ["Executor"], true]
    - [cf781xx009, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__, ["ThreadPoolExecutor"], true]
    - [cf781xx010, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true]
    - [cf781xx011, concurrent.futures.wait.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf781xx012, concurrent.futures.as_completed.__doc__.__class__.__name__.__eq__, ["str"], true]
