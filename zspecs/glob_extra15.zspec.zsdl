spec: glob_extra15
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra11.zspec.zsdl — covers __module__ equality and __qualname__ equality for glob/iglob/escape; __name__ equality for all three."
    - "glob_extra13.zspec.zsdl — covers __qualname__.__len__() and __module__.__len__() for glob/iglob/escape."
    - "glob_extra14.zspec.zsdl — covers __qualname__.__class__.__name__ == 'str' for glob/iglob/escape; translate __qualname__/__module__ equality; translate __qualname__.__len__()."
  notes:
    - "This spec extends glob_extra14.zspec.zsdl."
    - "Focus: module-level dunder attributes glob.__name__ and glob.__package__ (value, class, length); __module__.__class__.__name__ for glob/iglob/escape (module strings are str objects); translate.__name__ and __module__.__class__.__name__."
    - "glob.__name__ == 'glob' — covered in prior specs at function level, but the module-level __name__ attribute class and length have not been checked."
    - "glob.__package__ == '' — no prior glob spec covers __package__ value or class check."
    - "glob.__name__.__class__.__name__ == 'str' — module __name__ is a str object. No prior spec checks the class of the module __name__ attribute."
    - "glob.__package__.__class__.__name__ == 'str' — module __package__ is a str object."
    - "glob.__name__.__len__() == 4 — same length as 'glob'. No prior spec checks this on the module attribute."
    - "glob.__package__.__len__() == 0 — empty string for top-level module."
    - "glob.glob.__module__.__class__.__name__ == 'str' — the __module__ attribute on a function is a str. No prior spec checks this class name axis for any glob function."
    - "glob.iglob.__module__.__class__.__name__ == 'str' — same."
    - "glob.escape.__module__.__class__.__name__ == 'str' — same."
    - "glob.translate.__name__.__eq__('translate') — translate.__name__ matches simple name. Verified."
    - "glob.translate.__module__.__class__.__name__ == 'str' — translate's module attr is a str. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: glob module-level dunder attributes __name__ and __package__
#
# glob_extra11 checks function __module__ equality and function __qualname__.
# No prior glob spec checks the module object's own __name__ attribute class
# or __package__ attribute (value, class, length). These are module-level
# (not function-level) attributes and form a novel axis.
# Verified: __name__='glob' (class='str', len=4), __package__='' (class='str', len=0).
# ---------------------------------------------------------------------------

table glob_extra15.module_dunder_attrs:
  description: "glob module __name__ and __package__ value and class checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: mda15

  columns: [id, function, args, expected]
  rows:
    - [name_value,         "__name__.__eq__",                  ["glob"], true]
    - [name_class,         "__name__.__class__.__name__.__eq__", ["str"], true]
    - [name_len,           "__name__.__len__",                  [],       4]
    - [package_value,      "__package__.__eq__",               [""],     true]
    - [package_class,      "__package__.__class__.__name__.__eq__", ["str"], true]
    - [package_len,        "__package__.__len__",              [],       0]

# ---------------------------------------------------------------------------
# Table: __module__.__class__.__name__ for glob public functions
#
# glob_extra11 verifies that __module__ == 'glob' for all three public
# functions. glob_extra13 checks __module__.__len__() == 4 for all three.
# No prior spec checks that __module__ is itself a str object via
# __class__.__name__. This provides a novel type-checking axis.
# Verified: all three yield 'str'.
# ---------------------------------------------------------------------------

table glob_extra15.function_module_class_names:
  description: "__module__.__class__.__name__ == 'str' for glob/iglob/escape — module attr is a str object"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmcn15

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__module__.__class__.__name__.__eq__",   ["str"], true]
    - [iglob,  "iglob.__module__.__class__.__name__.__eq__",  ["str"], true]
    - [escape, "escape.__module__.__class__.__name__.__eq__", ["str"], true]

# ---------------------------------------------------------------------------
# Standalone: glob.__name__.__class__.__name__ == 'str'
#
# The module-level __name__ attribute of any Python module is a plain str.
# No prior glob spec explicitly checks the class of the module __name__
# attribute (as opposed to function __qualname__ or __module__ class checks).
# Verified: type(glob.__name__).__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant glob_extra15.module.name_is_str:
  description: "glob.__name__.__class__.__name__ == 'str' — the module __name__ attribute is a Python string"
  category: module_identity
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.__package__ == ''
#
# Top-level modules have __package__ equal to the empty string.
# No prior glob spec covers the __package__ value.
# Verified: glob.__package__ == ''.
# ---------------------------------------------------------------------------

invariant glob_extra15.module.package_value:
  description: "glob.__package__ == '' — top-level module has empty string package attribute"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.translate.__name__ == 'translate'
#
# glob_extra14 covers translate.__qualname__ == 'translate' and
# translate.__module__ == 'glob'. No prior spec covers translate.__name__
# (the simple name attribute, as opposed to __qualname__).
# For a top-level function, __name__ == __qualname__. Verified.
# ---------------------------------------------------------------------------

invariant glob_extra15.translate.name:
  description: "glob.translate.__name__ == 'translate' — simple function name attribute; equals __qualname__ for top-level functions"
  category: function_identity
  kind: python_call_eq
  function: translate.__name__.__eq__
  args: ["translate"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.translate.__module__.__class__.__name__ == 'str'
#
# glob_extra14 checks translate.__module__ == 'glob'. No prior spec checks
# that translate.__module__ is a str object (class name check).
# Verified: glob.translate.__module__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant glob_extra15.translate.module_is_str:
  description: "glob.translate.__module__.__class__.__name__ == 'str' — function __module__ attribute is a Python string"
  category: function_identity
  kind: python_call_eq
  function: translate.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
