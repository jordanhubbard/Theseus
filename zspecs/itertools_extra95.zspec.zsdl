spec: itertools_extra95
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra94

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra94.zspec.zsdl."
    - "This spec covers: itertools C-type __mro__.__len__() — all 18 types yield 2 (C type → object) (Wave 254)."
    - "itertools.chain.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.product.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.combinations.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.permutations.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.accumulate.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.groupby.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.islice.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.starmap.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.filterfalse.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.takewhile.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.dropwhile.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.count.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.repeat.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.cycle.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.compress.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.pairwise.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "itertools.zip_longest.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __mro__.__len__() — group 1 (chain through islice)
#
# Wave 254 theme: all itertools C types have mro length 2 (C type → object).
#
# itertools.chain.__mro__.__len__() == 2
# itertools.product.__mro__.__len__() == 2
# itertools.combinations.__mro__.__len__() == 2
# itertools.combinations_with_replacement.__mro__.__len__() == 2
# itertools.permutations.__mro__.__len__() == 2
#
# C extension types with no explicit base class have mro [type, object], length 2.
# New to extra95.
# ---------------------------------------------------------------------------

table itertools_extra95.mro_len_group1:
  description: "chain/product/combinations/combinations_with_replacement/permutations __mro__.__len__() == 2; C types with mro [type, object]; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmrolen95

  columns: [id, function, args, expected, description]
  rows:
    - [chain_mro_len_eq_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — chain is a C extension type defined in Modules/itertoolsmodule.c; C types with no explicit base class have mro [chain, object]; tuple.__len__() returns 2; prior spec extra94 checked __bases__[0].__name__; this spec (extra95) checks mro length; new to extra95"]
    - [product_mro_len_eq_2,
       "product.__mro__.__len__",
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — product is a C extension type; mro is [product, object]; tuple.__len__() returns 2; new to extra95"]
    - [combinations_mro_len_eq_2,
       "combinations.__mro__.__len__",
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — combinations is a C extension type; mro is [combinations, object]; tuple.__len__() returns 2; new to extra95"]
    - ["combinations_with_replacement_mro_len_eq_2",
       "combinations_with_replacement.__mro__.__len__",
       [],
       2,
       "itertools.combinations_with_replacement.__mro__.__len__() == 2 — combinations_with_replacement is a C extension type; mro is [combinations_with_replacement, object]; tuple.__len__() returns 2; new to extra95"]
    - [permutations_mro_len_eq_2,
       "permutations.__mro__.__len__",
       [],
       2,
       "itertools.permutations.__mro__.__len__() == 2 — permutations is a C extension type; mro is [permutations, object]; tuple.__len__() returns 2; new to extra95"]

