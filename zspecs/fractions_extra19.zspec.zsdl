spec: fractions_extra19
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra through fractions_extra18."
    - "fractions_extra18 covers __qualname__.__eq__ for all nine Fraction methods and __qualname__.__len__ for __add__, __str__, __repr__, limit_denominator."
    - "No prior spec covers __qualname__.__len__ for Fraction.__neg__ and Fraction.__abs__."
    - "No prior spec covers __qualname__.__len__ for the closure-based operators __sub__, __mul__, __truediv__."
    - "Fraction.__neg__ and __abs__ are defined directly on Fraction; qualname is 'Fraction.<name>' (16 chars each)."
    - "Fraction.__sub__, __mul__, __truediv__ share the _operator_fallbacks closure; qualname length is 45 (same as __add__)."
    - "Focus: __qualname__.__len__ for Fraction methods not yet length-verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.__neg__ and __abs__ __qualname__ length invariants
#
# fractions_extra18 recorded __qualname__.__eq__ for __neg__ and __abs__ but
# did not record the character length.  These two methods are defined directly
# on Fraction, so their qualname is 'Fraction.__neg__' (16 chars) and
# 'Fraction.__abs__' (16 chars) respectively.
# ---------------------------------------------------------------------------

invariant fractions_extra19.neg.qualname_len:
  description: "len(fractions.Fraction.__neg__.__qualname__) == 16 — 'Fraction.__neg__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__neg__.__qualname__.__len__
  args: []
  expected: 16

invariant fractions_extra19.abs.qualname_len:
  description: "len(fractions.Fraction.__abs__.__qualname__) == 16 — 'Fraction.__abs__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__abs__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Closure-based operator __qualname__ length invariants
#
# fractions_extra18 recorded __qualname__.__len__ for __add__ only (45 chars).
# No prior spec records length for __sub__, __mul__, __truediv__.
# All four share the same _operator_fallbacks closure pattern; length is 45.
# ---------------------------------------------------------------------------

table fractions_extra19.closure_qualname_lengths:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [sub,      "Fraction.__sub__.__qualname__.__len__",      [], 45, "len(Fraction.__sub__.__qualname__) == 45 — closure pattern length"]
    - [mul,      "Fraction.__mul__.__qualname__.__len__",      [], 45, "len(Fraction.__mul__.__qualname__) == 45 — closure pattern length"]
    - [truediv,  "Fraction.__truediv__.__qualname__.__len__",  [], 45, "len(Fraction.__truediv__.__qualname__) == 45 — closure pattern length"]
