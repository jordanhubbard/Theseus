spec: pathlib_extra267
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.Path.__module__ == 'pathlib'; pathlib.PurePath.__bases__[0].__name__ == 'object'."
    - "pathlib.PosixPath and pathlib.WindowsPath each have Path as their direct base class."
    - "On macOS/Linux, pathlib.WindowsPath exists as a class but cannot be instantiated; only identity is tested."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path class identity
# ---------------------------------------------------------------------------

invariant pathlib_extra267.Path.name:
  description: "pathlib.Path.__name__ == 'Path'"
  category: identity
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra267.Path.qualname:
  description: "pathlib.Path.__qualname__ == 'Path'"
  category: identity
  kind: python_call_eq
  function: Path.__qualname__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra267.Path.module:
  description: "pathlib.Path.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra267.Path.base:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath'"
  category: identity
  kind: python_call_eq
  function: Path.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "PurePath"

# ---------------------------------------------------------------------------
# pathlib.PurePath class identity
# ---------------------------------------------------------------------------

invariant pathlib_extra267.PurePath.name:
  description: "pathlib.PurePath.__name__ == 'PurePath'"
  category: identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra267.PurePath.qualname:
  description: "pathlib.PurePath.__qualname__ == 'PurePath'"
  category: identity
  kind: python_call_eq
  function: PurePath.__qualname__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra267.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra267.PurePath.base:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: PurePath.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

