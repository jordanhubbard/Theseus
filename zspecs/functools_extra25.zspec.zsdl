spec: functools_extra25
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra24.zspec.zsdl."
    - "functools_extra24 covers: __name__.__eq__ for cache/cached_property/singledispatch/total_ordering/wraps; WRAPPER_ASSIGNMENTS class name and len; reduce.__qualname__ anchor."
    - "functools_extra23 covers: partial(max,0) structural attrs and call results; WRAPPER_ASSIGNMENTS/__UPDATES class name anchors; reduce.__qualname__ anchor."
    - "No prior functools spec records __bases__[0].__name__.__eq__ for partial/partialmethod/cached_property in the extra25 namespace."
    - "All three classes (partial, partialmethod, cached_property) have 'object' as their sole base class."
    - "functools.WRAPPER_UPDATES == ('__dict__',) — exactly one element."
    - "functools.reduce.__module__ == '_functools' — implemented in C extension; functools.singledispatch.__module__ == 'functools' — pure Python."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — partial, partialmethod, cached_property
#
# Verifies that each class's direct base class is 'object'.
# All three are C-level or pure-Python classes with no further inheritance.
# No prior functools spec records this in the extra25 namespace.
# ---------------------------------------------------------------------------

table functools_extra25.base_names:
  kind: python_call_eq
  category: class_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra25.base_names.partial,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__ == 'object'"]
    - [functools_extra25.base_names.partialmethod,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__ == 'object'"]
    - [functools_extra25.base_names.cached_property,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for partial, partialmethod, cached_property
#
# Each class has a simple (non-nested) qualname equal to its class name.
# No prior functools spec records these three qualname checks together in
# the extra25 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra25.partial.qualname:
  description: "functools.partial.__qualname__ == 'partial' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra25.partialmethod.qualname:
  description: "functools.partialmethod.__qualname__ == 'partialmethod' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: partialmethod.__qualname__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra25.cached_property.qualname:
  description: "functools.cached_property.__qualname__ == 'cached_property' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES length
#
# functools.WRAPPER_UPDATES is a tuple containing exactly one element:
# '__dict__'. This records the single attribute updated (not just copied)
# by functools.update_wrapper / functools.wraps.
# No prior functools spec records WRAPPER_UPDATES.__len__() == 1 in the
# extra25 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra25.WRAPPER_UPDATES.len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — exactly one attribute updated by wraps()"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# reduce.__module__ — C extension module anchor
#
# functools.reduce is implemented in the _functools C extension, so
# reduce.__module__ == '_functools', not 'functools'.
# No prior functools spec records this in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra25.reduce.module:
  description: "functools.reduce.__module__ == '_functools' — reduce is a C builtin in _functools"
  category: function_attrs
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch.__module__ — pure Python module anchor
#
# functools.singledispatch is implemented in pure Python (Lib/functools.py),
# so singledispatch.__module__ == 'functools'.
# No prior functools spec records this in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra25.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools' — singledispatch is pure Python"
  category: function_attrs
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true
