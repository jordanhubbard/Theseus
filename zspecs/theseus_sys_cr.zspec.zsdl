spec: theseus_sys_cr
version: ">=3.0"
backend: python_cleanroom(theseus_sys_cr)
blocks: sys

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sys.html"
  not_derived_from:
    - "CPython source: Modules/sysmodule.c"
  notes:
    - "Clean-room sys module. Do NOT import sys directly."

error_model: python_exceptions

invariant theseus_sys_cr.sys2_version:
  description: "sys.version_info has correct major version"
  category: behavior
  kind: python_call_eq
  function: sys2_version
  args: []
  expected: true

invariant theseus_sys_cr.sys2_platform:
  description: "sys.platform is a non-empty string"
  category: behavior
  kind: python_call_eq
  function: sys2_platform
  args: []
  expected: true

invariant theseus_sys_cr.sys2_modules:
  description: "sys.modules is a dict containing builtins"
  category: behavior
  kind: python_call_eq
  function: sys2_modules
  args: []
  expected: true
