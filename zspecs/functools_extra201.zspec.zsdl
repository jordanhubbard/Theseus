spec: functools_extra201
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.partial.__name__ == 'partial' (len=7); partial is a C-level type implemented in _functools; its __name__ is 'partial'; verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' (len=9); although implemented in _functools, partial's __module__ is 'functools' (the public namespace); verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' (len=3); partial has a docstring so __doc__ is a Python str instance; verified with Python 3.14.3."
    - "functools.partial.func.__class__.__name__ == 'member_descriptor' (len=17); func is a slot member of the partial C type, accessed as a member_descriptor on the class; verified with Python 3.14.3."
    - "functools.partial.args.__class__.__name__ == 'member_descriptor' (len=17); args is a slot member of the partial C type, accessed as a member_descriptor on the class; verified with Python 3.14.3."
    - "functools.partial.keywords.__class__.__name__ == 'member_descriptor' (len=17); keywords is a slot member of the partial C type, accessed as a member_descriptor on the class; verified with Python 3.14.3."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' (len=15); the __new__ slot for the partial class has qualname 'partial.__new__'; verified with Python 3.14.3."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' (len=16); the __call__ slot for the partial class has qualname 'partial.__call__'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial __name__, __module__, and __doc__ class identity
#
# functools.partial.__name__                 == 'partial' (len=7)
# functools.partial.__module__               == 'functools' (len=9)
# functools.partial.__doc__.__class__.__name__ == 'str' (len=3)
#
# partial is a C-level type in _functools; its public __module__ is 'functools'.
# New to extra201.
# ---------------------------------------------------------------------------

table functools_extra201.partial_name_module_doc:
  description: "functools.partial identity: __name__=='partial'(len=7); __module__=='functools'(len=9); __doc__.__class__.__name__=='str'(len=3); new to extra201"
  kind: python_call_eq
  category: identity
  id_prefix: functpartialobj201

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C-level type that returns a new partial object; __name__ is 'partial' (len=7); str.__eq__('partial') returns True; verified with Python 3.14.3; new to extra201"]
    - [partial_name_len,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; verified with Python 3.14.3; new to extra201"]
    - [partial_module_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — although implemented in _functools, partial's __module__ is 'functools' (the public namespace); __module__ is 'functools' (len=9); str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra201"]
    - [partial_module_len,
       partial.__module__.__len__,
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra201"]
    - [partial_doc_class_eq,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial has a docstring so __doc__ is a Python str instance; __doc__.__class__.__name__ is 'str' (len=3); str.__eq__('str') returns True; verified with Python 3.14.3; new to extra201"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial slot descriptors — func, args, keywords
#
# functools.partial.func.__class__.__name__     == 'member_descriptor' (len=17)
# functools.partial.args.__class__.__name__     == 'member_descriptor' (len=17)
# functools.partial.keywords.__class__.__name__ == 'member_descriptor' (len=17)
#
# func, args, and keywords are C-level slot members on the partial type class,
# so accessing them on the class itself returns member_descriptor objects.
# New to extra201.
# ---------------------------------------------------------------------------

table functools_extra201.partial_slot_descriptors:
  description: "functools.partial slot descriptor class names: func/args/keywords each have __class__.__name__=='member_descriptor'(len=17); new to extra201"
