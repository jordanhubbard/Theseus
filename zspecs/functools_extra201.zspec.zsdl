    - [func_class_len,
       partial.func.__class__.__name__.__len__,
       [],
       17,
       "functools.partial.func.__class__.__name__.__len__() == 17 — 'member_descriptor' has 17 characters; str.__len__() returns 17; verified with Python 3.14.3; new to extra201"]
    - [args_class_eq,
       partial.args.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.args.__class__.__name__.__eq__('member_descriptor') == True — args is a C-level slot member on the partial type; accessing it on the class returns a member_descriptor; __class__.__name__ is 'member_descriptor' (len=17); str.__eq__('member_descriptor') returns True; verified with Python 3.14.3; new to extra201"]
    - [keywords_class_eq,
       partial.keywords.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — keywords is a C-level slot member on the partial type; accessing it on the class returns a member_descriptor; __class__.__name__ is 'member_descriptor' (len=17); str.__eq__('member_descriptor') returns True; verified with Python 3.14.3; new to extra201"]
    - [keywords_class_len,
       partial.keywords.__class__.__name__.__len__,
       [],
       17,
       "functools.partial.keywords.__class__.__name__.__len__() == 17 — 'member_descriptor' has 17 characters; str.__len__() returns 17; verified with Python 3.14.3; new to extra201"]

# ---------------------------------------------------------------------------
