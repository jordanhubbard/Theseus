spec: traceback_extra6
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl and prior extras."
    - "Prior specs cover: __name__ (traceback.zspec + traceback_extra + traceback_extra4), __module__ (traceback_extra + traceback_extra4), __qualname__ (traceback_extra5 covers TracebackException, StackSummary, FrameSummary, print_exc, format_exc, format_tb, print_tb, extract_tb, extract_stack, format_stack)."
    - "This spec adds __qualname__ for functions not yet covered: format_exception, print_exception, print_stack, walk_tb, walk_stack, clear_frames, format_exception_only, format_list, print_list."
    - "This spec also adds __bases__ checks for StackSummary (inherits from list) and FrameSummary (inherits from object)."
    - "traceback.StackSummary.__bases__[0].__name__ == 'list' — StackSummary subclasses list."
    - "traceback.FrameSummary.__bases__[0].__name__ == 'object' — FrameSummary inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — functions not yet covered by traceback_extra5
# format_exception, print_exception, print_stack, walk_tb, walk_stack,
# clear_frames, format_exception_only, format_list, print_list
# ---------------------------------------------------------------------------

table traceback_extra6.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [format_exception,      format_exception.__qualname__.__eq__,      ["format_exception"],      true]
    - [print_exception,       print_exception.__qualname__.__eq__,       ["print_exception"],       true]
    - [print_stack,           print_stack.__qualname__.__eq__,           ["print_stack"],           true]
    - [walk_tb,               walk_tb.__qualname__.__eq__,               ["walk_tb"],               true]
    - [walk_stack,            walk_stack.__qualname__.__eq__,            ["walk_stack"],            true]
    - [clear_frames,          clear_frames.__qualname__.__eq__,          ["clear_frames"],          true]
    - [format_exception_only, format_exception_only.__qualname__.__eq__,  ["format_exception_only"], true]
    - [format_list,           format_list.__qualname__.__eq__,           ["format_list"],           true]
    - [print_list,            print_list.__qualname__.__eq__,            ["print_list"],            true]

# ---------------------------------------------------------------------------
# __bases__ checks — StackSummary and FrameSummary class hierarchy
# StackSummary subclasses list; FrameSummary inherits from object.
# ---------------------------------------------------------------------------

invariant traceback_extra6.StackSummary.base_is_list:
  description: "traceback.StackSummary.__bases__[0].__name__ == 'list' — StackSummary subclasses list"
  category: hierarchy
  kind: python_call_eq
  function: StackSummary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "list"

invariant traceback_extra6.FrameSummary.base_is_object:
  description: "traceback.FrameSummary.__bases__[0].__name__ == 'object' — FrameSummary inherits from object"
  category: hierarchy
  kind: python_call_eq
  function: FrameSummary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
