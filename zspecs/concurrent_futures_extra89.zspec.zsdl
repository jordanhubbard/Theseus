invariant concurrent_futures_extra89.Future_result_qualname:
  description: "concurrent.futures.Future.result.__qualname__.__eq__('Future.result') returns True — the qualname 'Future.result' confirms this method is defined directly on the Future class (not inherited from a base class or defined in a nested scope); NEW in extra89: first standalone __qualname__ invariant for Future.result in cfmqualname89 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra89.Future_set_running_or_notify_cancel_qualname:
  description: "concurrent.futures.Future.set_running_or_notify_cancel.__qualname__.__eq__('Future.set_running_or_notify_cancel') returns True — this internal method transitions a Future to the RUNNING state; its qualname confirms it is defined on Future directly; NEW in extra89: first standalone __qualname__ invariant for Future.set_running_or_notify_cancel in cfmqualname89 namespace; wave 252; verified with Python 3.14.3"
  category: identity
