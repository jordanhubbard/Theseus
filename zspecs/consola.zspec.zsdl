spec: consola
version: ">=3.0.0"
backend: node(consola)

docs: https://github.com/unjs/consola#readme

provenance:
  derived_from:
    - "consola README — https://github.com/unjs/consola#readme"
    - "Test vectors verified with consola via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "consola source"
  notes:
    - "Elegant console wrapper — used across the Nuxt / unjs ecosystem."
    - "Install: npm install consola"
    - "v3 ESM only; named exports createConsola / consola (default instance) / LogLevels / LogTypes."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "Logger writes to stdout/stderr with ANSI styling."
  stickiness: "N/A — each Consola instance independent."
  codes: {}

# LogLevels constant table
invariant consola.LogLevels_fatal_zero:
  description: "LogLevels.fatal is 0"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "LogLevels.fatal"}
  expected: 0

invariant consola.LogLevels_error_zero:
  description: "LogLevels.error is 0 (same as fatal)"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "LogLevels.error"}
  expected: 0

invariant consola.LogLevels_warn_one:
  description: "LogLevels.warn is 1"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "LogLevels.warn"}
  expected: 1

invariant consola.LogLevels_log_two:
  description: "LogLevels.log is 2"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "LogLevels.log"}
  expected: 2

invariant consola.LogLevels_info_three:
  description: "LogLevels.info is 3"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "LogLevels.info"}
  expected: 3

invariant consola.LogLevels_debug_four:
  description: "LogLevels.debug is 4"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "LogLevels.debug"}
  expected: 4

invariant consola.LogLevels_trace_five:
  description: "LogLevels.trace is 5"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "LogLevels.trace"}
  expected: 5

# Logger instance shape
invariant consola.createConsola_default_level_three:
  description: "createConsola() default level is 3 (info)"
  category: instance
  kind: node_chain_eq
  entry: named
  function: createConsola
  entry_args: []
  chain:
    - {get: level}
  expected: 3

invariant consola.has_info_method:
  description: "Consola instance has .info method"
  category: instance
  kind: node_chain_eq
  entry: named
  function: createConsola
  entry_args: []
  chain:
    - {get: "info.constructor.name"}
  expected: "Function"

invariant consola.has_success_method:
  description: "Consola instance has .success method (consola-specific)"
  category: instance
  kind: node_chain_eq
  entry: named
  function: createConsola
  entry_args: []
  chain:
    - {get: "success.constructor.name"}
  expected: "Function"
