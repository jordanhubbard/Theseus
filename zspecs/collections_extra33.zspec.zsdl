spec: collections_extra33
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra32.zspec.zsdl."
    - "Prior specs covered: all class __name__/__module__/__qualname__/__bases__, __mro__.__len__ for deque(2)/Counter(3)/OrderedDict(3)/ChainMap(8)/UserList(9), __bases__[0].__name__ for all eight classes, __qualname__.__len__ for all nine top-level symbols, method qualnames (__eq__) for deque.append/appendleft/rotate; OrderedDict.move_to_end; Counter.update/most_common."
    - "This spec covers: __qualname__.__len__() for deque instance methods (append/appendleft/pop/popleft/rotate/extend/extendleft); Counter instance method qualname lengths (most_common/elements/subtract); OrderedDict instance method qualname lengths (move_to_end/popitem/__repr__)."
    - "deque.append.__qualname__ == 'deque.append' (len=12); deque.appendleft.__qualname__ == 'deque.appendleft' (len=16)."
    - "deque.pop.__qualname__ == 'deque.pop' (len=9); deque.popleft.__qualname__ == 'deque.popleft' (len=13)."
    - "deque.rotate.__qualname__ == 'deque.rotate' (len=12); deque.extend.__qualname__ == 'deque.extend' (len=12)."
    - "deque.extendleft.__qualname__ == 'deque.extendleft' (len=16) — ties with appendleft as longest deque method qualname."
    - "Counter.most_common.__qualname__ == 'Counter.most_common' (len=19) — longest Counter method qualname."
    - "Counter.elements.__qualname__ == 'Counter.elements' (len=16); Counter.subtract.__qualname__ == 'Counter.subtract' (len=16)."
    - "OrderedDict.move_to_end.__qualname__ == 'OrderedDict.move_to_end' (len=23) — longest method qualname in any core collection class."
    - "OrderedDict.popitem.__qualname__ == 'OrderedDict.popitem' (len=19)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# deque method __qualname__.__len__() table (extra33 namespace)
#
# Prior specs confirmed deque method qualnames via __qualname__.__eq__ but
# never measured their lengths with __len__. Each qualname has the form
# 'deque.<method>':
#   append -> 12, appendleft -> 16, pop -> 9, popleft -> 13,
#   rotate -> 12, extend -> 12, extendleft -> 16.
# appendleft and extendleft share the maximum length of 16; pop is shortest at 9.
# No prior collections spec records these qualname lengths in the extra33 namespace.
# ---------------------------------------------------------------------------

table collections_extra33.deque_method_qualname_lens:
  description: "__qualname__.__len__() for deque instance methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: deque_method_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [append,      deque.append.__qualname__.__len__,      [], 12]
    - [appendleft,  deque.appendleft.__qualname__.__len__,  [], 16]
    - [pop,         deque.pop.__qualname__.__len__,         [], 9]
    - [popleft,     deque.popleft.__qualname__.__len__,     [], 13]
    - [rotate,      deque.rotate.__qualname__.__len__,      [], 12]
    - [extend,      deque.extend.__qualname__.__len__,      [], 12]
    - [extendleft,  deque.extendleft.__qualname__.__len__,  [], 16]

# ---------------------------------------------------------------------------
# Counter and OrderedDict method __qualname__.__len__() table (extra33 namespace)
#
# Counter methods use qualnames of the form 'Counter.<method>':
#   most_common -> 19, elements -> 16, subtract -> 16.
# OrderedDict methods use qualnames of the form 'OrderedDict.<method>':
#   move_to_end -> 23, popitem -> 19.
# OrderedDict.move_to_end (23) is the longest method qualname in any core
# collection class. Counter.most_common (19) matches OrderedDict.popitem (19).
# No prior collections spec records these qualname lengths together in the
# extra33 namespace.
# ---------------------------------------------------------------------------

table collections_extra33.counter_ordereddict_method_qualname_lens:
  description: "__qualname__.__len__() for Counter and OrderedDict instance methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: method_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Counter_most_common,     Counter.most_common.__qualname__.__len__,     [], 19]
    - [Counter_elements,        Counter.elements.__qualname__.__len__,         [], 16]
    - [Counter_subtract,        Counter.subtract.__qualname__.__len__,         [], 16]
    - [OrderedDict_move_to_end, OrderedDict.move_to_end.__qualname__.__len__, [], 23]
    - [OrderedDict_popitem,     OrderedDict.popitem.__qualname__.__len__,      [], 19]

# ---------------------------------------------------------------------------
# deque.appendleft.__qualname__.__len__() == 16 — standalone (extra33 namespace)
#
# 'deque.appendleft' has 16 characters, making it (along with 'deque.extendleft')
# the longest method qualname among deque's seven commonly-used mutating methods.
# appendleft pushes an element onto the left end of the deque in O(1) time.
# No prior collections spec records this standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra33.deque.appendleft.qualname_len:
  description: "len(collections.deque.appendleft.__qualname__) == 16 — tied for longest deque method qualname"
  category: method_qualname_lengths
  kind: python_call_eq
  function: deque.appendleft.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# OrderedDict.move_to_end.__qualname__.__len__() == 23 — standalone
# (extra33 namespace)
#
# 'OrderedDict.move_to_end' has 23 characters, making it the longest method
# qualname among all core collection classes covered in this spec family.
# move_to_end(key, last=True) relocates an existing key to either end of the
# OrderedDict in O(1) time. No prior collections spec records this standalone
# in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra33.OrderedDict.move_to_end.qualname_len:
  description: "len(collections.OrderedDict.move_to_end.__qualname__) == 23 — longest method qualname in core collections"
  category: method_qualname_lengths
  kind: python_call_eq
  function: OrderedDict.move_to_end.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# Counter.most_common.__qualname__.__len__() == 19 — standalone
# (extra33 namespace)
#
# 'Counter.most_common' has 19 characters, matching OrderedDict.popitem (19)
# and making it the longest Counter method qualname. most_common() returns a
# list of (element, count) pairs ordered from most to least frequent.
# No prior collections spec records this standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra33.Counter.most_common.qualname_len:
  description: "len(collections.Counter.most_common.__qualname__) == 19 — longest Counter method qualname"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Counter.most_common.__qualname__.__len__
  args: []
  expected: 19
