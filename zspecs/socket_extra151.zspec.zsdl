spec: socket_extra151
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra150.zspec.zsdl — covers _socket.__dict__.__len__()==235 / _socket.__dict__.__class__.__name__.__eq__('dict') / _socket.__dict__.__contains__('socket'/'AF_INET'/'IPPROTO_TCP'/'SO_REUSEADDR'/'gethostname'/'getaddrinfo'/'gethostbyname'/'inet_aton') / _socket.socket.__dict__.__len__()==37 (table + invariants)."
    - "socket_extra149.zspec.zsdl — covers socket.__dict__.__len__()==267 / socket.socket.__dict__.__len__()==28 / socket.AddressFamily.__dict__.__len__()==25 / socket.SocketKind.__dict__.__len__()==20 / all three class dicts are mappingproxy / socket.__dict__.__class__.__name__.__eq__('dict') (table + invariants)."
    - "socket_extra145.zspec.zsdl — covers socket.AF_UNSPEC/__class__.__name__.__eq__('AddressFamily') / AF_UNIX.name.__eq__('AF_UNIX') / IPPROTO_TCP/__class__.__name__.__eq__('int') (table + invariants)."
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 enum member .name values / SOCK_STREAM/SOCK_DGRAM .name values / AddressFamily/SocketKind class __name__ values (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra150."
    - "Wave 333 theme: socket module AF_* and SOCK_* integer constant values — AF_INET.__eq__(2) / AF_INET6.__eq__(30) [macOS] / SOCK_STREAM.__eq__(1) / SOCK_DGRAM.__eq__(2) / AF_UNIX.__eq__(1). Also type names: AF_INET.__class__.__name__=='AddressFamily' / SOCK_STREAM.__class__.__name__=='SocketKind'."
    - "socket.AF_INET.__eq__(2) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__eq__(30) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0 (macOS-specific; Linux uses 10)."
    - "socket.SOCK_STREAM.__eq__(1) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__eq__(2) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__eq__(1) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.AF_INET and other AF_* constants are AddressFamily IntEnum members on modern Python (3.4+), not plain ints. __eq__(2) returns True because IntEnum supports integer equality comparison. The integer values: AF_INET=2 is universal (all platforms); AF_INET6=30 is macOS-specific (Linux uses AF_INET6=10); AF_UNIX=1 is common (macOS and Linux agree)."
    - "Note: socket.SOCK_STREAM and SOCK_DGRAM are SocketKind IntEnum members. SOCK_STREAM=1 (TCP; connection-oriented byte stream) and SOCK_DGRAM=2 (UDP; connectionless datagram) are universal across platforms. The SocketKind class wraps SOCK_* constants just as AddressFamily wraps AF_* constants."
    - "Note: AF_UNIX and SOCK_STREAM both have integer value 1, and AF_INET and SOCK_DGRAM both have integer value 2. This coincidence is because AF_* and SOCK_* are from separate namespaces (AddressFamily and SocketKind), so there is no conflict. AF_UNIX=1 (Unix domain sockets) is not the same as SOCK_STREAM=1 (TCP socket type)."
    - "Note: socket.AF_INET.__class__.__name__ == 'AddressFamily' (13 chars). socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (10 chars). These are IntEnum subclasses added in Python 3.4 to wrap the raw C integer constants from _socket. extra145 anchors AF_UNSPEC.__class__.__name__ == 'AddressFamily'; extra142 anchors AddressFamily.__name__ and SocketKind.__name__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2)
# socket.AF_INET6.__eq__(30)
# socket.AF_UNIX.__eq__(1)
#
# Wave 333 theme: AF_* address family integer values on macOS.
#
# AF_INET=2, AF_INET6=30 (macOS-specific; Linux=10), AF_UNIX=1. These are IntEnum
# members of AddressFamily that compare equal to their underlying integer values.
# extra142 anchors AF_INET.name and AF_INET6.name; no prior socket spec anchors
# AF_INET.__eq__(2) or AF_INET6.__eq__(30) or AF_UNIX.__eq__(1) as a table under
# sockconst151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra151.af_constants_integer_values:
  description: "socket.AF_INET.__eq__(2)==True / AF_INET6.__eq__(30)==True / AF_UNIX.__eq__(1)==True — AF_* are AddressFamily IntEnum members; AF_INET=2 is universal; AF_INET6=30 is macOS-specific (Linux uses 10); AF_UNIX=1 is common across macOS and Linux; IntEnum equality supports comparison with plain ints; extra142 anchors AF_INET.name and AF_INET6.name; first sockconst151 anchor for AF_* integer value equality"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst151

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_eq_2,   "AF_INET.__eq__",  [2],  true, "socket.AF_INET.__eq__(2) == True (IPv4 address family; value 2 is universal across all platforms)"]
    - [AF_INET6_eq_30, "AF_INET6.__eq__", [30], true, "socket.AF_INET6.__eq__(30) == True (IPv6; value 30 on macOS/Darwin; Linux uses 10)"]
    - [AF_UNIX_eq_1,   "AF_UNIX.__eq__",  [1],  true, "socket.AF_UNIX.__eq__(1) == True (Unix domain sockets; value 1 on macOS and Linux)"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__eq__(1)
# socket.SOCK_DGRAM.__eq__(2)
#
# Wave 333 theme: SOCK_* socket type integer values.
#
# SOCK_STREAM=1 (TCP; connection-oriented byte stream) and SOCK_DGRAM=2 (UDP;
# connectionless datagram) are the two most commonly used socket types. They are
# SocketKind IntEnum members. SOCK_STREAM=1 is universal across platforms.
# SOCK_DGRAM=2 is also universal. extra142 anchors SOCK_STREAM.name and SOCK_DGRAM.name;
# no prior socket spec anchors SOCK_STREAM.__eq__(1) or SOCK_DGRAM.__eq__(2) as a table
# under sockconst151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra151.sock_constants_integer_values:
  description: "socket.SOCK_STREAM.__eq__(1)==True / SOCK_DGRAM.__eq__(2)==True / SOCK_STREAM.__class__.__name__.__eq__('SocketKind')==True / SOCK_DGRAM.__class__.__name__.__eq__('SocketKind')==True — SOCK_STREAM=1 (TCP/connection-oriented byte stream; universal) / SOCK_DGRAM=2 (UDP/connectionless datagram; universal); both are SocketKind IntEnum members; extra142 anchors .name values; first sockconst151 anchor for SOCK_* integer equality and class name"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst151

  columns: [id, function, args, expected, description]
  rows:
    - [SOCK_STREAM_eq_1,          "SOCK_STREAM.__eq__",                   [1],            true, "socket.SOCK_STREAM.__eq__(1) == True (TCP; connection-oriented byte stream; value 1 is universal)"]
    - [SOCK_DGRAM_eq_2,           "SOCK_DGRAM.__eq__",                    [2],            true, "socket.SOCK_DGRAM.__eq__(2) == True (UDP; connectionless datagram; value 2 is universal)"]
    - [SOCK_STREAM_class_kind,    "SOCK_STREAM.__class__.__name__.__eq__", ["SocketKind"], true, "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (10 chars; IntEnum subclass wrapping SOCK_* constants)"]
    - [SOCK_DGRAM_class_kind,     "SOCK_DGRAM.__class__.__name__.__eq__",  ["SocketKind"], true, "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' (10 chars; IntEnum subclass wrapping SOCK_* constants)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily')
# socket.AF_INET6.__class__.__name__.__eq__('AddressFamily')
# socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily')
#
# Wave 333 theme: AF_* constants are AddressFamily IntEnum members, not plain ints.
#
# On modern Python (3.4+), AF_* constants are members of the AddressFamily IntEnum class
# rather than plain ints. Their __class__.__name__ is 'AddressFamily' (13 chars).
# This contrasts with IPPROTO_TCP which remains a plain int (anchored in extra145).
# No prior socket spec anchors AF_INET6.__class__.__name__ or AF_UNIX.__class__.__name__
# as a table under sockconst151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra151.af_constants_class_name:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily')==True / AF_INET6.__class__.__name__.__eq__('AddressFamily')==True / AF_UNIX.__class__.__name__.__eq__('AddressFamily')==True — all three AF_* constants are AddressFamily IntEnum members (13 chars); added Python 3.4; contrasts with IPPROTO_TCP (plain int, extra145); extra145 anchors AF_UNSPEC.__class__.__name__; first sockconst151 anchor for AF_INET6/AF_UNIX class names"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst151

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_class_AddressFamily,  "AF_INET.__class__.__name__.__eq__",  ["AddressFamily"], true, "socket.AF_INET.__class__.__name__ == 'AddressFamily' (13 chars; IntEnum member, not plain int)"]
    - [AF_INET6_class_AddressFamily, "AF_INET6.__class__.__name__.__eq__", ["AddressFamily"], true, "socket.AF_INET6.__class__.__name__ == 'AddressFamily' (13 chars; IntEnum member; value 30 on macOS)"]
    - [AF_UNIX_class_AddressFamily,  "AF_UNIX.__class__.__name__.__eq__",  ["AddressFamily"], true, "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (13 chars; IntEnum member; value 1)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) — standalone
#
# socket.AF_INET.__eq__(2) is True. AF_INET is the address family for IPv4 sockets.
# Its integer value is 2 on all platforms (macOS, Linux, Windows). It is an
# AddressFamily IntEnum member that compares equal to the plain integer 2. The
# expression AF_INET == 2 is equivalent to calling AF_INET.__eq__(2) and returns True.
# extra145 anchors socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily'; extra142
# anchors AF_INET.name == 'AF_INET'; no prior socket spec anchors AF_INET.__eq__(2)
# as a standalone under sockconst151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra151.AF_INET_eq_2:
  description: "socket.AF_INET.__eq__(2) == True — IPv4 address family; value 2 is universal across macOS/Linux/Windows; AddressFamily IntEnum member; compares equal to plain int 2; extra145 anchors AF_UNSPEC class name; extra142 anchors AF_INET.name; no prior socket spec anchors this as a standalone; first standalone under sockconst151"
  category: identity
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__eq__(1) — standalone
#
# socket.SOCK_STREAM.__eq__(1) is True. SOCK_STREAM is the socket type for TCP
# (Transmission Control Protocol) — a connection-oriented, reliable byte-stream protocol.
# Its integer value is 1 on all platforms (macOS, Linux, Windows). It is a SocketKind
# IntEnum member that compares equal to the plain integer 1. Note that AF_UNIX also
# has integer value 1, but AF_UNIX is in the AddressFamily enum while SOCK_STREAM is
# in the SocketKind enum — no conflict since they are separate namespaces. extra142
# anchors SOCK_STREAM.name; no prior socket spec anchors SOCK_STREAM.__eq__(1) as a
# standalone under sockconst151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra151.SOCK_STREAM_eq_1:
  description: "socket.SOCK_STREAM.__eq__(1) == True — TCP socket type; value 1 is universal across platforms; SocketKind IntEnum member; coincidentally same integer value as AF_UNIX=1 but from different enum namespace; extra142 anchors SOCK_STREAM.name; no prior socket spec anchors this as a standalone; first standalone under sockconst151"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET.__class__.__name__ is 'AddressFamily' (13 chars). On modern Python
# (3.4+), AF_* constants are no longer plain ints — they are IntEnum members of the
# AddressFamily class. This means they have all the properties of Python enums (name,
# value, etc.) while still supporting integer arithmetic and comparison. The class name
# 'AddressFamily' (13 chars) is 3 chars longer than 'SocketKind' (10 chars). extra145
# anchors AF_UNSPEC.__class__.__name__ == 'AddressFamily' as a standalone; no prior
# socket spec anchors AF_INET.__class__.__name__ == 'AddressFamily' as a standalone
# under sockconst151. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra151.AF_INET_class_AddressFamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — 'AddressFamily' (13 chars); IntEnum member (Python 3.4+); not a plain int; supports .name/.value and integer arithmetic; 'AddressFamily' (13) is 3 longer than 'SocketKind' (10); extra145 anchors AF_UNSPEC class name; no prior socket spec anchors this as a standalone; first standalone under sockconst151"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true
